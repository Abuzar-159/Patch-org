trigger CancellationCreditNote on ERP7__Credit_Note__c (before insert) {    try{    List<ERP7__Credit_Note__c> existingCancelCreditNotes = new List<ERP7__Credit_Note__c>();    existingCancelCreditNotes = [select Id, Name, ERP7__Credit_Note__c from ERP7__Credit_Note__c  where ERP7__Type__c = 'Cancelled'];    if(existingCancelCreditNotes.size()>0){        Map<Id, ERP7__Credit_Note__c> existingMap = new Map<Id, ERP7__Credit_Note__c>();        for(ERP7__Credit_Note__c cred : existingCancelCreditNotes){            existingMap.put(cred.ERP7__Credit_Note__c, cred);        }        for(ERP7__Credit_Note__c credNote : Trigger.New){            if(existingMap.containskey(credNote.ERP7__Credit_Note__c)) {credNote.addError('We have already recorded cancellation credit note against this Credit Note'); }        }    }    }catch(Exception e){        system.debug('Exception'+e+e.getLineNumber()+e.getMessage());    }}