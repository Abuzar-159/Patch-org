.size()>0) WS = [Select Id, Name, Organisation__c, Organisation_Business_Unit__c, Product__c, Quantity__c, Stock_Outward_Line_Item__c From Warranty__c Where Stock_Outward_Line_Item__c In: stoliIds];  if(WS != null) for(Warranty__c W : WS) lineWarranty.put(W.Stock_Outward_Line_Item__c, W);                        }                                                for (Stock_Outward_Line_Item__c STOLI: STOLIS) {                             if (!lineWarranty.containsKey(STOLI.Id) && itemPolicy.containsKey(STOLI.Product__c)) {                                 Warranty_Return_Policy__c itmPolicy = itemPolicy.get(STOLI.Product__c);  Warranty__c W = new Warranty__c();                                if(Schema.sObjectType.Warranty__c.fields.Organisation__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Organisation__c.isUpdateable()) W.Organisation__c = STOLI.Order_Product__r.Organisation__c;                                if(Schema.sObjectType.Warranty__c.fields.Organisation_Business_Unit__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Organisation_Business_Unit__c.isUpdateable()) W.Organisation_Business_Unit__c = STOLI.Order_Product__r.Organisation_Business_Unit__c;                                if(Schema.sObjectType.Warranty__c.fields.Product__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Product__c.isUpdateable()) W.Product__c = STOLI.Product__c;                                if(Schema.sObjectType.Warranty__c.fields.Quantity__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Quantity__c.isUpdateable()) W.Quantity__c = STOLI.Quantity__c;                                if(Schema.sObjectType.Warranty__c.fields.Stock_Outward_Line_Item__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Stock_Outward_Line_Item__c.isUpdateable()) W.Stock_Outward_Line_Item__c = STOLI.Id;                                if(Schema.sObjectType.Warranty__c.fields.ERP7__Order_Product__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.ERP7__Order_Product__c.isUpdateable()) W.ERP7__Order_Product__c = STOLI.Order_Product__c;                                if(Schema.sObjectType.Warranty__c.fields.Type__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Type__c.isUpdateable()) W.Type__c = 'Standard';                                if(Schema.sObjectType.Warranty__c.fields.Valid_From__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Valid_From__c.isUpdateable()) W.Valid_From__c = System.Today();                                if(Schema.sObjectType.Warranty__c.fields.Valid_Till__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Valid_Till__c.isUpdateable()) W.Valid_Till__c = System.Today() + integer.Valueof(itmPolicy.Days_of_Warranty__c);                                if(Schema.sObjectType.Warranty__c.fields.Warranty_Return_Policy__c.isCreateable() && Schema.sObjectType.Warranty__c.fields.Warranty_Return_Policy__c.isUpdateable()) W.Warranty_Return_Policy__c = itmPolicy.Id;                                 Warranties2Insert.add(W);                            }                        }                    } else Trigger_New[0].addError('No stock outwards created for this sales order to issue warranty');                }                
                
                if (Warranties2Insert.size() > 0 && Schema.sObjectType.Warranty__c.isCreateable() && Schema.sObjectType.Warranty__c.isUpdateable()) { DMLManager.UpsertAsUser(Warranties2Insert); } else{/*not alloed to insert warranty*/}
                
                if (cancelledPOIds.size() > 0) {                    List < ERP7__Stock_Outward_Line_Item__c > cancelStock = [Select Id, Name, Order__c, ERP7__Status__c, ERP7__Fixed_Asset__c From ERP7__Stock_Outward_Line_Item__c Where Order__c In: cancelledPOIds And ERP7__Status__c != 'Rejected'];                      List < Id > AssetsIds = new List < Id > ();  for (ERP7__Stock_Outward_Line_Item__c soli: cancelStock) { if(Schema.sObjectType.ERP7__Stock_Outward_Line_Item__c.fields.ERP7__Status__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Outward_Line_Item__c.fields.ERP7__Status__c.isUpdateable()) soli.ERP7__Status__c = 'Rejected'; if(soli.ERP7__Fixed_Asset__c != Null) AssetsIds.add(soli.ERP7__Fixed_Asset__c);}                     List < ERP7__Asset__c > assets2Update = [Select Id, Name, ERP7__Available__c, ERP7__Status__c From ERP7__Asset__c Where Id In: AssetsIds];                     for (ERP7__Asset__c Asset: assets2Update) { if(Schema.sObjectType.ERP7__Asset__c.fields.ERP7__Available__c.isCreateable() && Schema.sObjectType.ERP7__Asset__c.fields.ERP7__Available__c.isUpdateable()) Asset.ERP7__Available__c = true; if(Schema.sObjectType.ERP7__Asset__c.fields.ERP7__Status__c.isCreateable() && Schema.sObjectType.ERP7__Asset__c.fields.ERP7__Status__c.isUpdateable()) Asset.ERP7__Status__c = 'Available'; }                      List < ERP7__Logistic__c > cancelLogistics = [Select Id, Name, ERP7__Order_S__c, ERP7__Closed__c From ERP7__Logistic__c Where ERP7__Order_S__c In: cancelledPOIds And ERP7__Closed__c = false];  for (ERP7__Logistic__c logis: cancelLogistics) { if(Schema.sObjectType.ERP7__Logistic__c.fields.ERP7__Closed__c.isCreateable() && Schema.sObjectType.ERP7__Logistic__c.fields.ERP7__Closed__c.isUpdateable()) logis.ERP7__Closed__c = true; }                      if (cancelStock.size() > 0 && Schema.sObjectType.ERP7__Stock_Outward_Line_Item__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Outward_Line_Item__c.isUpdateable()) { upsert cancelStock;}else{/*not allowed*/} if (assets2Update.size() > 0 && Schema.sObjectType.ERP7__Asset__c.isCreateable() && Schema.sObjectType.ERP7__Asset__c.isUpdateable()) { upsert assets2Update;} else{/*not allowed*/} if (cancelLogistics.size() > 0 && Schema.sObjectType.ERP7__Logistic__c.isCreateable() && Schema.sObjectType.ERP7__Logistic__c.isUpdateable()) { upsert cancelLogistics;} else{/*not allowed*/}                }        
