            }
            system.debug('Stocks : ' + Stocks.size());
            if (Stocks.size() > 0 && Schema.sObjectType.ERP7__Inventory_Stock__c.isCreateable() && Schema.sObjectType.ERP7__Inventory_Stock__c.isUpdateable()) {
                upsert Stocks;
            } else {
                /*(' no access stock');*/ }
            for (ERP7__Stock_Inward_Line_Item__c inward: StockInwardMap.KeySet()) {
                Id StockId = StockInwardMap.get(inward).Id;
                inward.ERP7__Site_ProductService_InventoryStock__c = StockId;
            }
            system.debug('SPLIs : ' + SPLIs.size());
            if (SPLIs.size() > 0 && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.isUpdateable()) {
