            } else {
                /*('No access stock inward');*/ }
        } catch (exception e) {
            system.debug('error : ' + e.getLineNumber() + 'Msg : ' + e.getMessage());
            string errMsg = e.getMessage();
            if (errMsg.contains('UNABLE_TO_LOCK_ROW')) System.enqueueJob(new HandleFailedSerialsQueueable(serList));
        }
