    @future public static void createInventorySB(set < Id > serIds,String batchLotId) {
        /* Shaguftha (08_04_24) added try catch and also the in the catch the queueable method to handle failed serials */
        List < ERP7__Serial_Number__c > serList = new List < ERP7__Serial_Number__c > ();
        try {
            Boolean QAisEnaled = false;
            ERP7__Functionality_Control__c FC = new ERP7__Functionality_Control__c();
            FC = ERP7__Functionality_Control__c.getValues(userInfo.getuserid());
            if (FC == null) {
                FC = ERP7__Functionality_Control__c.getValues(userInfo.getProfileId());
                if (FC == null) FC = ERP7__Functionality_Control__c.getInstance();
            }
            if (FC != null) {
                QAisEnaled = FC.ERP7__Enable_QA_in_Manufacturing_process__c;
            }
            serList = [Select Id, Name, ERP7__Product__r.ERP7__QA_Handling_Inbound_Post_MO_Completion__c, ERP7__Product__r.ERP7__Quality_Check_QA__c, ERP7__Available__c, ERP7__Scrap__c, ERP7__Production_Version__c, ERP7__Product__c, ERP7__Product__r.Serialise__c, ERP7__Manufacturing_Order__c, ERP7__WIP__c, ERP7__Manufacturing_Order__r.ERP7__Order_Product__c, ERP7__Manufacturing_Order__r.ERP7__Order__c from ERP7__Serial_Number__c where Id In: serIds];
            set < Id > WIPIds = new set < Id > ();
            for (ERP7__Serial_Number__c ser1: serList) {
                WIPIds.add(ser1.ERP7__WIP__c);
            }
            List < ERP7__WIP_Flow__c > WIPs = [Select Id, Name, ERP7__Work_Orders__c, ERP7__WIP__c, ERP7__Finished_Products_Site__c,ERP7__Expiry_Date__c from ERP7__WIP_Flow__c where ERP7__WIP__c IN: WIPIds];
            Map < Id, ERP7__WIP_Flow__c > WIPFlowMap = new Map < Id, ERP7__WIP_Flow__c > ();
            for (ERP7__WIP_Flow__c wip: WIPs) {
                WIPFlowMap.put(wip.ERP7__WIP__c, wip);
            }
            Map < ERP7__Stock_Inward_Line_Item__c, ERP7__Inventory_Stock__c > StockInwardMap = new Map < ERP7__Stock_Inward_Line_Item__c, ERP7__Inventory_Stock__c > ();
            List < ERP7__Stock_Inward_Line_Item__c > SPLIs = new List < ERP7__Stock_Inward_Line_Item__c > ();
            List < ERP7__Inventory_Stock__c > Stocks = new List < ERP7__Inventory_Stock__c > ();
            for (ERP7__Serial_Number__c ser: serList) {
                if (ser.ERP7__Product__r.Serialise__c) {
                    ERP7__Inventory_Stock__c Stock = new ERP7__Inventory_Stock__c();
                    Stock.ERP7__Prevent_Calculating_site_Stocks__c = true;
                    Stock.ERP7__Manufacturing_Order__c = ser.ERP7__Manufacturing_Order__c;
                    Stock.ERP7__Active__c = true;
                    Stock.Name = ser.Name;
                    Stock.ERP7__Checked_In_Date__c = system.today();
                    Stock.ERP7__Status__c = 'Checked In';
                    Stock.ERP7__Product__c = ser.ERP7__Product__c;
                    Stock.ERP7__Version__c = ser.ERP7__Production_Version__c;
                    Stock.ERP7__Scrap__c = ser.ERP7__Scrap__c;
                    Stock.ERP7__Serial__c = ser.Id;
                    //new added on 22/5/25
                    if (WIPFlowMap.containsKey(ser.ERP7__WIP__c) && WIPFlowMap.get(ser.ERP7__WIP__c).ERP7__Expiry_Date__c != null) {
                        if (Schema.sObjectType.ERP7__Inventory_Stock__c.fields.ERP7__Expiry_Date__c.isCreateable() && Schema.sObjectType.ERP7__Inventory_Stock__c.fields.ERP7__Expiry_Date__c.isUpdateable()) {
                            Stock.ERP7__Expiry_Date__c = WIPFlowMap.get(ser.ERP7__WIP__c).ERP7__Expiry_Date__c;
                        }
                    }
                    //till this by matheen same for createInventory method
                    if(batchLotId!=''){
                        Stock.ERP7__Batch_Lot__c=batchLotId;
                    }
                    ERP7__Stock_Inward_Line_Item__c SPLI = new ERP7__Stock_Inward_Line_Item__c();
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Manufacturing_Order__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Manufacturing_Order__c.isUpdateable()) {
                        SPLI.ERP7__Manufacturing_Order__c = ser.ERP7__Manufacturing_Order__c;
                    } else {
                        /*No access*/ }
                    if (WIPFlowMap.containsKey(ser.ERP7__WIP__c)) {
                        Stock.ERP7__Work_Order__c = WIPFlowMap.get(ser.ERP7__WIP__c).ERP7__Work_Orders__c;
                        Stock.ERP7__WIP_Flow__c = WIPFlowMap.get(ser.ERP7__WIP__c).Id;
                        Stock.ERP7__Warehouse__c = WIPFlowMap.get(ser.ERP7__WIP__c).ERP7__Finished_Products_Site__c;
                        if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Work_Order__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Work_Order__c.isUpdateable()) {
                            SPLI.ERP7__Work_Order__c = WIPFlowMap.get(ser.ERP7__WIP__c).ERP7__Work_Orders__c;
                        } else {}
                        if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__WIP_Flow__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__WIP_Flow__c.isUpdateable()) {
                            SPLI.ERP7__WIP_Flow__c = WIPFlowMap.get(ser.ERP7__WIP__c).Id;
                        } else {}
                    }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.Name.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.Name.isUpdateable()) {
                        SPLI.Name = ser.Name;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Material_Batch_Lot__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Material_Batch_Lot__c.isUpdateable()) {
                        SPLI.ERP7__Material_Batch_Lot__c =batchLotId ;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Product__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Product__c.isUpdateable()) {
                        SPLI.ERP7__Product__c = ser.ERP7__Product__c;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Active__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Active__c.isUpdateable()) {
                        SPLI.ERP7__Active__c = true;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Quantity__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Quantity__c.isUpdateable()) {
                        SPLI.ERP7__Quantity__c = 1;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Unit_Price__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Unit_Price__c.isUpdateable()) {
                        SPLI.ERP7__Unit_Price__c = 0;
                    } else {
                        /*No access*/ }
                    if (Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Version__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Version__c.isUpdateable()) {
                        SPLI.ERP7__Version__c = ser.ERP7__Production_Version__c;
                    } else {
                        /*No access*/ }
                    if (ser.ERP7__Manufacturing_Order__r.ERP7__Order__c != null && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Sales_Order__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Sales_Order__c.isUpdateable()) {
                        SPLI.ERP7__Order__c = ser.ERP7__Manufacturing_Order__r.ERP7__Order__c;
                    } else {
                        /*No access*/ }
                    if (ser.ERP7__Manufacturing_Order__r.ERP7__Order_Product__c != null && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Sales_Order_Line_Item__c.isCreateable() && Schema.sObjectType.ERP7__Stock_Inward_Line_Item__c.fields.ERP7__Sales_Order_Line_Item__c.isUpdateable()) {
                        SPLI.ERP7__Order_Product__c = ser.ERP7__Manufacturing_Order__r.ERP7__Order_Product__c;
                    } else {
                        /*No access*/ }
                    SPLI.ERP7__Scrap__c = ser.ERP7__Scrap__c;
                    SPLI.ERP7__Serial__c = ser.Id;
                    if (QAisEnaled && (ser.ERP7__Product__r.ERP7__Quality_Check_QA__c || ser.ERP7__Product__r.ERP7__QA_Handling_Inbound_Post_MO_Completion__c)) {
                        SPLI.ERP7__Status__c = 'Quality Check(QA)';
                    }
