    @future public static void MaintainserialStocks(Set<Id> serialIds){
        if(serialIds.size() > 0){
            List<ERP7__Serial_Number__c> serialtoupdate = new List<ERP7__Serial_Number__c>();
            List<ERP7__Serial_Number__c> serialLst = [Select Id,Name,ERP7__Available__c from ERP7__Serial_Number__c where Id In:serialIds FOR UPDATE];
            List<ERP7__Inventory_Stock__c> invlst = [Select Id,Name,ERP7__Number_of_Item_In_Stock__c,ERP7__Serial__c from ERP7__Inventory_Stock__c where ERP7__Serial__c IN :serialIds];
            if(invlst.size() > 0){
                Map<Id,ERP7__Inventory_Stock__c> serInvmap = new Map<Id,ERP7__Inventory_Stock__c>();
                for(ERP7__Inventory_Stock__c inv : invlst){
                    serInvmap.put(inv.ERP7__Serial__c,inv);
                }
                if(serInvmap.size() > 0){
                    for(ERP7__Serial_Number__c ser:serialLst){
                        if(serInvmap.containsKey(ser.Id) && serInvmap.get(ser.Id).ERP7__Number_of_Item_In_Stock__c == 0 && serInvmap.get(ser.Id).ERP7__Serial__c == ser.Id){
                            ser.ERP7__Available__c = false;
                            serialtoupdate.add(ser); 
                        }
                        else if(ser.ERP7__Available__c == false && serInvmap.containsKey(ser.Id) && serInvmap.get(ser.Id).ERP7__Number_of_Item_In_Stock__c > 0){                            ser.ERP7__Available__c = true;                            serialtoupdate.add(ser);                         }
                        
                    }
                }
                
            }
            if(serialtoupdate.size() > 0) update serialtoupdate;
        }
    }
