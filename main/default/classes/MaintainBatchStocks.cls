    @future 
    public static void MaintainBatchStocks(Set<Id> BatchIds){
        if(BatchIds.size() > 0){
            List<ERP7__Batch__c> Batches = Database.query('Select Id, Name, ERP7__Account__c, ERP7__Active__c, ERP7__Inward_Quantity__c, ERP7__Outward_Quantity__c, ERP7__Product__c From ERP7__Batch__c Where Id IN :BatchIds');
            
            List<String> negList = new List<String>{'Quality Check(QA)','Awaiting Stock', 'Rejected','QC hold','Scrap','Contrôle de qualité'}; // added status scrap and QC hold  04/12/23
                
                List<ERP7__Stock_Inward_Line_Item__c> StockInwards = Database.query('Select Id, Name, ERP7__Active__c, ERP7__Material_Batch_Lot__c, ERP7__Quantity__c, ERP7__Scrap__c From ERP7__Stock_Inward_Line_Item__c Where ERP7__Material_Batch_Lot__c IN :BatchIds and ERP7__Status__c NOT IN :negList and ERP7__Scrap__c = false');// added scrap = false condition in where clause 04/12/23
            
            List<String> posList = new List<String>{'Committed', 'Returned to Supplier','Reserved'};
                
                List<ERP7__Stock_Outward_Line_Item__c> StockOutwards = Database.query('Select Id, Name, ERP7__Active__c, ERP7__Material_Batch_Lot__c, ERP7__Quantity__c From ERP7__Stock_Outward_Line_Item__c Where ERP7__Material_Batch_Lot__c IN :BatchIds and ERP7__Status__c IN :posList');
            
            for(ERP7__Batch__c Batch : Batches){
                Decimal inCount = 0;
                Decimal outCount = 0;
                for(ERP7__Stock_Inward_Line_Item__c Inward : StockInwards){
                    if(Batch.Id == Inward.ERP7__Material_Batch_Lot__c && Inward.ERP7__Quantity__c != Null && !Inward.ERP7__Scrap__c) inCount += Inward.ERP7__Quantity__c;
                }
                for(ERP7__Stock_Outward_Line_Item__c outward : StockOutwards){
                    if(Batch.Id == outward.ERP7__Material_Batch_Lot__c && outward.ERP7__Quantity__c != Null) outCount += Outward.ERP7__Quantity__c;
                }
                if(Schema.sObjectType.ERP7__Batch__c.fields.ERP7__Inward_Quantity__c.isUpdateable()){ Batch.ERP7__Inward_Quantity__c = inCount; }else{/*No access*/}
                if(Schema.sObjectType.ERP7__Batch__c.fields.ERP7__Outward_Quantity__c.isUpdateable()){ Batch.ERP7__Outward_Quantity__c = outCount; }else{/*No access*/}
            }
            
            if(Batches.size() > 0 && Schema.sObjectType.ERP7__Batch__c.isUpdateable()){ update Batches; }else{/*not allowed to update*/}     
        }
    }
    
