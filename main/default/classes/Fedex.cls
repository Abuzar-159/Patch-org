    @AuraEnabled
    public static String getProvinceCode(String provinceName) { 
        List<ERP7__Province_Codes__c> provinceList = new List<ERP7__Province_Codes__c>();
        if(String.isNotEmpty(provinceName)) {
            provinceList = [Select Id, Name, ERP7__Code__c, ERP7__Province__c From ERP7__Province_Codes__c Where ERP7__Province__c =: provinceName Limit 1];
        } 
        if(provinceList.size() > 0) return provinceList[0].ERP7__Code__c; else return '';
    }
    
    @AuraEnabled
    public static String getCountryCode(String countryName) { 
        List<ERP7__Country_Codes__c> countryList = new  List<ERP7__Country_Codes__c>();
        if(String.isNotEmpty(countryName)) {
            countryList = [Select Id, Name, ERP7__Code__c, ERP7__Country__c From ERP7__Country_Codes__c Where ERP7__Country__c =: countryName  Limit 1];
        } 
        if(countryList.size() > 0) return countryList[0].ERP7__Code__c; else return ''; 
    }
    
    @AuraEnabled
    public static String getStreet(String AddressLine1, String AddressLine2, String AddressLine3) {
        if((AddressLine1 != Null && AddressLine1 != '') && (AddressLine2 != Null && AddressLine2 != '') && (AddressLine3 != Null && AddressLine3 != '')) {
            return AddressLine1 +', '+ AddressLine2 +', '+ AddressLine3; } 
        else if((AddressLine1 != Null && AddressLine1 != '') && (AddressLine2 != Null && AddressLine2 != '')) { return AddressLine1 +', '+ AddressLine2; }
        else if(AddressLine1 != Null && AddressLine1 != '') { return AddressLine1; }
        else return '';
    }
    
