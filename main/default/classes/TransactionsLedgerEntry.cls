                    else{ hasAccess=false; errormsg='You are not allowed to create or update records'; }
                    // updating total due for account
                    if( updateTotalDue>0 && accIdToUpdate!=null ){                        try{                            List<Account> acc =[Select id,ERP7__Total_Due__c, ERP7__Paid_Out__c from Account where id=:accIdToUpdate];                             if(acc.size()>0){                                acc[0].ERP7__Total_Due__c = acc[0].ERP7__Total_Due__c - updateTotalDue;                            }                        }catch(Exception e){                        }                                            }                 
                                        //updating the credit note entry for Account
                     if(accToUpdate.size()>0){                        try{                            try{                                if(transInvoice.values()!=null){ List<ERP7__Invoice__c> inv = [Select id, ERP7__Credit_Note_Issued__c,ERP7__Credit_Note__c from ERP7__Invoice__c where id IN : transInvoice.values()]; for(ERP7__Invoice__c invc : inv){ if(Schema.sObjectType.ERP7__Invoice__c.fields.ERP7__Credit_Note_Issued__c.isCreateable() && Schema.sObjectType.ERP7__Invoice__c.fields.ERP7__Credit_Note_Issued__c.isUpdateable()) invc.ERP7__Credit_Note_Issued__c = true; if(Schema.sObjectType.ERP7__Invoice__c.fields.ERP7__Credit_Note__c.isCreateable() && Schema.sObjectType.ERP7__Invoice__c.fields.ERP7__Credit_Note__c.isUpdateable()) invc.ERP7__Credit_Note__c = finalCreditNote.get(invCreditNote.get(invc.Id)); } if(inv.size()>0){ if(Schema.sObjectType.ERP7__Invoice__c.isCreateable() && Schema.sObjectType.ERP7__Invoice__c.isUpdateable()) upsert inv; else{ } } }                            }catch(Exception e){                                }                            try{                                if(finalCreditNote.size()>0){ List<ERP7__Credit_Note__c> updateCreditNotes = [Select id,ERP7__Credit__c from ERP7__Credit_Note__c where id IN: finalCreditNote.keyset()]; for(ERP7__Credit_Note__c c : updateCreditNotes){ if(Schema.sObjectType.ERP7__Credit_Note__c.fields.ERP7__Credit__c.isCreateable() && Schema.sObjectType.ERP7__Credit_Note__c.fields.ERP7__Credit__c.isUpdateable()) c.ERP7__Credit__c = finalCreditNote.get(c.id); } if(updateCreditNotes.size()>0 && Schema.sObjectType.ERP7__Credit_Note__c.isCreateable() && Schema.sObjectType.ERP7__Credit_Note__c.isUpdateable()) upsert updateCreditNotes; else{ } }                            }catch(Exception e){                            }                            List<Account> acc = [Select id,ERP7__Total_Due__c, ERP7__Credit_Balance__c from Account where id IN : accToUpdate.keySet() ];                             for(Account a : acc){ if(Schema.sObjectType.Account.fields.ERP7__Credit_Balance__c.isCreateable() && Schema.sObjectType.Account.fields.ERP7__Credit_Balance__c.isUpdateable()){ if( a.ERP7__Credit_Balance__c == null) a.ERP7__Credit_Balance__c = 0; a.ERP7__Credit_Balance__c += accToUpdate.get(a.id); } if(Schema.sObjectType.Account.fields.ERP7__Total_Due__c.isCreateable() && Schema.sObjectType.Account.fields.ERP7__Total_Due__c.isUpdateable()){ if(a.ERP7__Total_Due__c == null) a.ERP7__Total_Due__c = 0; if(checkPaymentForAccount.get(a.id) ==null )a.ERP7__Total_Due__c -= accToUpdate.get(a.id); } }                            if(acc.size()>0 && Schema.sObjectType.Account.isCreateable() && Schema.sObjectType.Account.isUpdateable()) upsert acc; else{ }                        }catch(Exception e){                        }                    }                    
                                        
                    //updating the vendor account for PO Payment
                    try{
                        if(vendorPaymentUpdate.size() > 0 ){ List<Account> vendorAccounts = [ Select id, ERP7__Paid_In__c from Account where ID IN : vendorPaymentUpdate.keySet() ]; for( Account a : vendorAccounts ){ if(Schema.sObjectType.Account.fields.ERP7__Paid_In__c.isCreateable() && Schema.sObjectType.Account.fields.ERP7__Paid_In__c.isUpdateable())  a.ERP7__Paid_In__c = a.ERP7__Paid_In__c == null ? vendorPaymentUpdate.get(a.Id) : a.ERP7__Paid_In__c + vendorPaymentUpdate.get(a.Id); } if( vendorAccounts.size() > 0 && Schema.sObjectType.Account.isCreateable() && Schema.sObjectType.Account.isUpdateable()) upsert vendorAccounts; else{ } } 
                    }catch(Exception e){
                        //('Exception in Transactionledgerentry '+e);
                    }
                    //End of updating the vendor account for PO Payment
                    
                    
                    //Updating the account for debit payments
                    try{
                        if(accToUpdateForDebit.size()>0){  List<Account> acc =[Select id,ERP7__Total_Due__c, ERP7__Paid_Out__c from Account where id IN : accToUpdateForDebit.keySet()]; for(Account a : acc){ if(Schema.sObjectType.Account.fields.ERP7__Paid_Out__c.isCreateable() && Schema.sObjectType.Account.fields.ERP7__Paid_Out__c.isUpdateable()){ if( a.ERP7__Paid_Out__c == Null )a.ERP7__Paid_Out__c = 0; a.ERP7__Paid_Out__c += accToUpdateForDebit.get(a.Id); } if(Schema.sObjectType.Account.fields.ERP7__Total_Due__c.isCreateable() && Schema.sObjectType.Account.fields.ERP7__Total_Due__c.isUpdateable()){ if( a.ERP7__Total_Due__c == Null )a.ERP7__Total_Due__c = 0; a.ERP7__Total_Due__c = a.ERP7__Total_Due__c - accToUpdateForDebit.get(a.Id); } } if(acc.size() > 0 && Schema.sObjectType.Account.isCreateable() && Schema.sObjectType.Account.isUpdateable()) upsert acc; else{ }
                        }
                    }catch(Exception e){
