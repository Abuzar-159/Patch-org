                        </apex:outputPanel>
                        <!-- end of display Comment panel -->
                        
                     </apex:outputPanel>       
                 </apex:outputPanel>       
                 <!-- end of showComments list panel -->
                  
                <!-- Add Atachments -->      
                <apex:outputPanel id="showAttach">                
                <apex:outputPanel id="attachment" rendered="{!showAttachBlock}">                    
                    <table border="" width="100%">
                        <tr>
                            <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">FileName</td>
                            <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">Select Attachment</td>
                            <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">Attached Date</td>
                            <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP"> Action </td>
                        </tr>

                        <apex:variable var="attachmentCounter" value="{!0}" />
                        <apex:repeat value="{!attachmentList}" var="attach">
                        <tr>
                            <td align="center">
                                   
                                <apex:outputLink value="{!URLFOR($Action.Attachment.Download,attach.Att.Id)}" styleClass="titlesB" style="color:red;" 
                                rendered="{!if(attach.Att.id != Null,true,false)}" target="_blank">
                                    <apex:outputText value="{!attach.attName}" rendered="{!$ObjectType.Attachment.fields.Name.Accessible}"/>
                                </apex:outputLink> 
                            </td>

                            <td align="center">
                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/whiteplus.png')}" title="Add Attachment" onclick=" if('{!preventDisplay}' == 'false') { popupAttach('{!attachmentCounter + 1}');}" />
                            </td>

                            <td align="center">
                                <apex:outputText value="{0,date, dd/MM/YYYY HH:MM}" rendered="{!$ObjectType.attachment.fields.createdDate.Accessible}">
                                    <apex:param value="{!attach.dt}" />
                                </apex:outputText>
                            </td>

                            <td align="center">
                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/plus.png')}" style="cursor:pointer;" 
                                    rendered="{!if(attachmentCounter == 0 && !(preventDisplay), true, false)}" onclick="addAttachment('{!attachmentCounter + 1}');" title="Add Attachment"></apex:image>
                                                
                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/minus.png')}" rendered="{!if(attachmentCounter != 0 && attachmentListSize > 1 && !(preventDisplay), true, false)}"
                                    style="cursor:pointer;" onclick="removeAttachment('{!attachmentCounter + 1}');" title="Remove Attachment"></apex:image>    
                            </td>
                        </tr>
                        <apex:variable var="attachmentCounter" value="{!attachmentCounter + 1}" />
                        </apex:repeat>
                    </table>                            
                </apex:outputPanel> 
                </apex:outputPanel>
                <!-- end of attachment list panel -->
                
                </div>
                <!-- end of right DIV -->
                    
                </div>
                <!-- end of main DIV -->
                                                
                </div>
                <!-- end of popup DIV -->
                
                <!-- Attachment Popup block -->
                <div id="fade" class="popupBackground"></div>
                <div id="light9" class="customPopup" style="border:1px solid;">
                    <DIV class="headerTitle"></DIV>
                    <div style="position:absolute; top: -1px; left:358px;">
                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/close.png')}" onclick="closeAttachmentPopup();"></apex:image>
                    </div>
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="30">&nbsp;</td>
                        </tr>

                        <tr>
                            <td width="7%"> 
                                <apex:inputHidden value="{!currentIndex}" id="indexvalform" />
                            </td>
                            <td width="24%" class="rtext" style="font-weight:bold;">File Upload:</td>
                            <td width="69%" align="left">
                                <apex:inputFile value="{!newAttachment.body}" filename="{!newAttachment.name}" id="attId" />
                            </td>
                        </tr>
                    </table>                               
                               
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td width="55%" align="center" height="40">&nbsp;</td>
                        </tr>
                        
                        <tr>
                            <td width="55%" align="center">
                                <apex:commandLink value="Upload" action="{!uploadAttachment}" styleClass="newcase-btn"
                                    onclick="var ik = document.getElementById('{!$Component.popform.attId}').value; if(ik == '') return false;" rendered="{!$ObjectType.Attachment.Deletable}"/>
                            </td>
                        </tr>
                        
                        <tr><td width="14%">&nbsp;</td></tr>
                </table>
                </div> 
                <!-- end of attachment popup -->
                </apex:form>                        
                
