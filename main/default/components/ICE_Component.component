  <script>
  <!-- Function for Showing popup -->
    function OpenICEpopup()
    {
        // alert('hello popup');     
         document.getElementById('light10').style.display = 'block';
         document.getElementById('fade1').style.display = 'block';
         //testFunction();
         popLookup();
    } 
 
  <!-- Function for closing popup -->
    function closeIcePopup() {      
        document.getElementById('light10').style.display = 'none';
        document.getElementById('fade1').style.display = 'none';  
        hideIcePopup();
    }
      
  <!-- Attachment popup -->                        
    function popupAttach(identifier) {
        document.getElementById('light9').style.display = 'block';
        document.getElementById('fade').style.display = 'block';        
        document.getElementById('{!$Component.popform.indexvalform}').value = identifier;
    }

  <!-- Hide attachment popup -->            
    function closeAttachmentPopup() {
        document.getElementById('light9').style.display = 'none';
        document.getElementById('fade').style.display = 'none';
        document.getElementById('{!$Component.popform.abodynew}').value = null;
    }                        
    
  <!-- Adding multiple attachment -->
    function addAttachment(index) {
        //alert('index in addAttachment : = ' + index);
        document.getElementById('{!$Component.myFrm.cntValue}').value = index;
        addAttachments();
    }
    
  <!-- Remove attachment -->    
    function removeAttachment(index) {
        //alert('index in removeAttachment : = ' + index);                
        document.getElementById('{!$Component.myFrm.cntValue}').value = index;
        var r = confirm("Are you sure you want to delete?");
        if (r == true) {            
            removeAttachments(index);                       
        }
    }                  
            
  <!-- Ice form vaidation -->           
    function iceValidate() {
        //alert('ice validate ');             
        var sub = document.getElementById('{!$Component.myFrm.sub}').value;     
        var assistance = $('[id$=assist]').val();
        var topic = $('[id$=topic]').val();
        var sev = $('[id$=sev]').val();
        var desp = $('[id$=desp]').val();        
        
        if (assistance == '' || topic == '' || sev == '-- Select severity level --' || sub == '' || desp == '') {         
            if (assistance == '') {
                document.getElementById('cat').style.display = '';
            } else {
                document.getElementById('cat').style.display = 'none';
            }

            if (topic == '' || topic == null) {
                document.getElementById('top').style.display = '';
            } else {
                document.getElementById('top').style.display = 'none';
            }

            if (sev == '-- Select severity level --') {
                document.getElementById('seve').style.display = '';
            } else {
                document.getElementById('seve').style.display = 'none';
            }

            if (sub == '' || sub == null) {
                document.getElementById('sub').style.display = '';
            } else {
                document.getElementById('sub').style.display = 'none';
            }

            if (desp == '' || desp == null) {
                document.getElementById('desp').style.display = '';
            } else {
                document.getElementById('desp').style.display = 'none';
            }
        } else {      
            newICE(assistance, topic, sev, sub, desp);
        } 
    }     
            
  <!-- Hide error messages -->
    function hideErr(val, str) {
        if (val != '' && str == 'top') {
            document.getElementById('top').style.display = 'none';
        } else if (val != '' && str == 'sever') {
            document.getElementById('seve').style.display = 'none';
        } else if (val != '' && str == 'sub') {
            document.getElementById('sub').style.display = 'none';
        } else if (val != '' && str == 'desp') {
            document.getElementById('desp').style.display = 'none';
        } else if (val != '' && str == 'comDes') {
            document.getElementById('comDes').style.display = 'none';
        }
    }

  <!-- OnChange pass value to controller -->
    function passValue(value) {
        //alert('2 funct : = ' + value);        
        popLookup(value);
    }        
       
  <!-- comment validation -->            
    function commentValidate() {
        //alert('inside commentValidate');
        var comDesp = document.getElementById('{!$Component.myFrm.comments}').value;
        
        if (comDesp == '') {
            if (comDesp == '') {
                document.getElementById('comDes').style.display = '';
            } else {
                document.getElementById('comDes').style.display = 'none';
            }
        } else {
            uploadComments(comDesp);
        }
    }       
 </script>
 
