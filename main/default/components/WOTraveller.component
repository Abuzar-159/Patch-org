                <td style="font: bold 12px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;padding:5px;border-left:1px solid #ddd;border-top:1px solid #ddd;">DOM</td>
                <td style="font: bold 12px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;padding:5px;border-left:1px solid #ddd;border-top:1px solid #ddd;border-right:1px solid #ddd;">BARCODE</td>
            </tr>
            <apex:variable var="BTCount" value="{!1}"/>
