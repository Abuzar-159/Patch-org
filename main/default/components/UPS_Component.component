            details = e.split(',');        
            
            if(details[0] != null && details[0] != '') ser_code = details[0];
            if(details[1] != null && details[1] != '') ser_desp = details[1];      
            if(details[2] != null && details[2] != '') {
                del_date1 = details[2];
                var dt = new Date(del_date1);
                var day = ("0" + dt.getDate()).slice(-2);
                var mon = ("0" + (dt.getMonth()+1)).slice(-2);
                var yy = dt.getFullYear();
                var del_date = yy +'-'+ mon +'-'+ day;
                del_date1 = del_date;
            }
            jQuery('[id$=rad1]').val(ser_code);
            jQuery('[id$=rad2]').val(del_date);
            jQuery('[id$=rad3]').val(ser_desp);          
