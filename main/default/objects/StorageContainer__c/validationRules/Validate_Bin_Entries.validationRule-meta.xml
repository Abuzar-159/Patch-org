<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Bin_Entries</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Active__c, Location__r.Total_Bins__c+1 &gt; Location__r.Bin_Capacity__c )</errorConditionFormula>
    <errorMessage>Location is already occupied with allowed number of Bins</errorMessage>
</ValidationRule>
