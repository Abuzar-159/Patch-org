<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Approve_Stock_Take_Before_Posting</fullName>
    <active>true</active>
    <errorConditionFormula>AND( Posted__c , NOT(ISPICKVAL( Status__c , &apos;Approved&apos;)) )</errorConditionFormula>
    <errorMessage>Please Approve the Stock Take Before Posting</errorMessage>
</ValidationRule>
