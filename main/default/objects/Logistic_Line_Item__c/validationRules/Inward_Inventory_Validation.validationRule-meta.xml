<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Inward_Inventory_Validation</fullName>
    <active>false</active>
    <errorConditionFormula>OR( Quantity_Received__c &gt;  Quantity__c,  Putaway_Quantity__c  &gt;  Quantity__c )</errorConditionFormula>
    <errorMessage>Excess Inventory count in your Quantity Received or Putaway Process</errorMessage>
</ValidationRule>
