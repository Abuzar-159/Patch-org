<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Total_Down_Payment_Amount_per_item__c</fullName>
    <deprecated>false</deprecated>
    <description>Created this field for accounting deferred income based of the line items</description>
    <formula>IF( Invoice__r.Total_Down_Payment_Amount__c &gt; 0 , ( Invoice__r.Total_Down_Payment_Amount__c /  Invoice__r.Sales_Order_Amount__c ) *  Total_Price__c , 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>This Filed is user for dividing the down payment amount per item</inlineHelpText>
    <label>Total Down Payment Amount per item</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
