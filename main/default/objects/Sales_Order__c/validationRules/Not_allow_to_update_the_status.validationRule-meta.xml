<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Not_allow_to_update_the_status</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
 ISPICKVAL((Status__c ), &quot;Shipped&quot;),
 ISPICKVAL(Status__c, &quot;Delivered&quot;),
(Total_Logistic_Quantity__c = Shipped_Quantity__c)
)</errorConditionFormula>
    <errorMessage>Cannot change the status until all the quantity is shipped or delivered</errorMessage>
</ValidationRule>
