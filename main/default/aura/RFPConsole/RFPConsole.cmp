<aura:component controller="ManageRFP" access="global" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" >
    
    <head>
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        <ltng:require styles="{!join(',',$Resource.SLDS+ '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierRequests.css"/>
    </head>
    
    <!--tab1-->
    <aura:attribute name = "RFPWrap" type = "object[]" default="{'sObjectType' : 'RFPWrapper'}"/>
    <aura:attribute name = "reqSupplier" type = "Request_Supplier__c" default="{'sObjectType' : 'ERP7__Request_Supplier__c'}"/>
    <aura:attribute name = "request" type = "Request__c" default="{'sObjectType' : 'ERP7__Request__c'}"/>
    <aura:attribute name = "reqContactList" type = "Request_Contact__c[]" default="{'sObjectType' : 'ERP7__Request_Contact__c'}"/>
    <aura:attribute name = "reqAttachment" type = "Attachment[]" default="{'sObjectType' : 'Attachment'}"/>
    <!--tab2-->
    <aura:attribute name = "reqRequirements" type = "object[]" default="{'sObjectType' : 'requirementWrappers'}"/>
    <aura:attribute name = "reqResponses" type = "object[]"/>
    <aura:attribute name = "requirements" type = "Requirement__c[]" default="{'sObjectType' : 'ERP7__Requirement__c'}"/>
    <!--tab3-->
    <aura:attribute name = "assignFAQsList" type = "FAQ_Assignment__c[]" default="{'sObjectType' : 'ERP7__FAQ_Assignment__c'}"/>
    <aura:attribute name = "allFAQs" type = "FAQ__c[]" default="{'sObjectType' : 'ERP7__FAQ__c'}"/>
    <aura:attribute name = "currentFAQs" type = "FAQ__c[]" default="{'sObjectType' : 'ERP7__FAQ__c'}"/>
    
    <aura:attribute name = "MOrderId" type = "Id" default=""/>
    <aura:attribute name = "reqSupplierId" type = "Id" default=""/><!--a0a1o00000DJsHjAAL-->
    <aura:attribute name = "requestId" type = "Id" default=""/><!--a3S1o0000002fEaEAI-->
    <aura:attribute name = "reqSupplierName" type = "String" default=""/>
    <aura:attribute name = "RFPTab" type = "Boolean" default="true"/>
    <aura:attribute name = "RandRTab" type = "Boolean" default="false"/>
    <aura:attribute name = "FAQsTab" type = "Boolean" default="false"/>
    <aura:attribute name = "resetRandR" type = "Boolean" default="true"/>
    <aura:attribute name = "allowReq" type = "Boolean" default="true"/>
    <aura:attribute name = "searchQuestionStr" type = "String" default=""/>
    <aura:attribute name="FileList" type="object[]"/>
    <aura:attribute name="resRatingOptions" type="List[]"/>
    <aura:attribute name="resComplianceOptions" type="List[]"/>
    <aura:attribute name = "RFPnav" type = "String" default=""/>
    <aura:attribute name = "currentSupplier" type = "Id" default=""/>
    
    <aura:attribute name = "serverSuccess" type = "String" default=""/>
    <aura:attribute name = "exceptionError" type = "String" default=""/>
    <aura:method name="saveAll" action="{!c.saveallResponses}">
        <aura:attribute name="param1" type="Boolean" default="false"/>
    </aura:method>
    <aura:method name="backMethod" action="{!c.navBack}">
    </aura:method>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name = "refresh" type = "Boolean" default="true"/>
    <aura:attribute name = "showSubmitModal" type = "Boolean" default="false"/>
    <aura:attribute name = "frominitial" type = "Boolean" default="false"/>
     <aura:attribute name = "showSpinner" type = "Boolean" default="false"/>
    <aura:attribute name = "donotsetRatingCompliance" type = "Boolean" default="false"/>
    
    <div class="maqsood erp_mark7 RFPCon-class2 bg-white heighvh" aura:id="RFPbody" >
        <aura:if isTrue="{!v.showSpinner}"> 
        <span class="RFPCon-class1">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading..." aura:id="mainSpin" class="mainSpinClass"/>
        </span>
        </aura:if>
        <!--Success Message-->
        <div class="{!if(and(v.serverSuccess != '', v.serverSuccess != undefined),'slds-notify_container slds-is-fixed RFPCon-class3','slds-notify_container slds-is-fixed RFPCon-class4')}"><!--   -->
            <div class="slds-notify slds-notify_toast slds-theme_success" role="status">
                <span class="slds-assistive-text">success</span>
                <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="Description of icon when needed">
                    <lightning:icon iconName="action:approval" size="x-small" alternativeText="Success!" title="Success" />
                </span>
                <div class="slds-notify__content">
                    <h2 class="slds-text-heading_small ">{!v.serverSuccess}</h2>
                </div>
                <div class="slds-notify__close">
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeSuccess}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />		
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <!--Success Message End-->
        
        <!--Error Message-->
        <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed RFPCon-class3','slds-notify_container slds-is-fixed RFPCon-class4')}">
            <div class="slds-notify slds-notify_toast slds-theme_error RFPCon-class5" role="status" >
                <span class="slds-assistive-text">error</span>
                <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                    <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="Error!" title="Error" />
                </span>
                <div class="slds-notify__content">
                    <h2 class="slds-text-heading_x-small RFPCon-class6">{!v.exceptionError}
                    </h2>
                </div>
                <div class="slds-notify__close RFPCon-class10" >
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />		
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <!--Error Message End-->
        
        <div class="erp_Mark7 bg-white pb-5">
            <!--RFP Tab Start-->
            <div class="{!(v.RFPTab)?'slds-show':'slds-hide'}" id="rfphome" aura:id="rfphome">
                <div class="slds-page-header">
                    <div class="slds-page-header__row">
                        <div class="slds-page-header__col-title">
                            <div class="slds-media">
                                <div class="slds-media__figure">
                                    <span class="slds-icon_container slds-icon-standard-avatar" >
                                        <lightning:icon iconName="standard:record"  size="large" alternativeText="record!" title="record" />
                                        <span class="slds-assistive-text">RFP</span>
                                    </span>
                                </div>
                                <div class="slds-media__body">
                                    <p class="slds-text-title--caps slds-line-height--reset" data-aura-rendered-by="520:0">Request For Proposal</p>
                                    <div class="slds-page-header__name">
                                        <div class="slds-page-header__name-title">
                                            <!--aura:if isTrue="{!and(v.requestId, v.frominitial == true)}"><{!v.requestId}-->
                                            <h1>
                                                <span class="slds-page-header__title slds-truncate" title="">{!v.request.Name}</span>
                                            </h1>
                                                <!--aura:set attribute="else">
                                                    <div class="slds-grid slds-grid_vertical-align-center slds-grid_align-end">
                                                        <div class="slds-col">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Request__c" IconName="standard:account" selectedRecordId="{!v.requestId}" label="Select Request" aura:id="newreqId" qry=" AND ERP7__Status__c = 'Open' "  />
                                                        </div>
                                                        
                                                        <div onclick="{!c.changedRequestId}" class="slds-col">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Request_Supplier__c" IconName="standard:account" selectedRecordId="{!v.reqSupplierId}" label="Select Request Supplier" aura:id="newreqId" qry="{!'AND ERP7__Request__c = \'' + v.requestId + '\''}"  />
                                                        </div>
                                                    </div>
                                                </aura:set>
                                            </aura:if-->
                                        </div>
                                    </div>
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row m-0 ">
                    <div class="col-md-4 col-sm-12 mt-3">
                        <div class="card mb-4 RFPCon-class7" >
                            <div class="card-body">
                                <h5 class="mb-4"><strong>Details</strong></h5>
                                <div class="row mt-2">
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Request Date:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedDateTime value="{!v.request.ERP7__Request_Date__c}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Response Due Date:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedDateTime value="{!v.request.ERP7__Response_Due_Date__c}" />
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                    
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Organisation:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedText value="{!v.request.ERP7__Organisation__r.Name}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Organisation Business Unit:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedText value="{!v.request.ERP7__Organisation_Business_Unit__r.Name}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Channel:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedText value="{!v.request.ERP7__Channel__r.Name}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12 mt-2">
                                        <div class="slds-grid">
                                            <div class="slds-col col-6 p-0">
                                                <label for="exampleInputEmail1">Distribution Channel:&nbsp;</label>
                                            </div>
                                            <div class="slds-col">
                                                <lightning:formattedText value="{!v.request.ERP7__Distribution_Channel__r.Name}" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8 col-sm-12 mt-3">
                        <div class="card mb-4">
                            <div class="card-body RFPCon-class8" >
                                <h5 class="mb-4"><strong>Description</strong></h5>
                                <div class="row mt-2">
                                    <div class="col-md-12" >
                                        <div class="Service-Description maq">
                                            <div class="scroll-bar-wrap">
                                                <div class="scroll-box RFPCon-class9" >
                                                    <p>
                                                        <lightning:formattedRichText value="{!v.request.ERP7__Description__c}"/>
                                                    </p>
                                                </div>
                                                <div class="cover-bar"></div>
                                            </div>
                                        </div>
                                        
                                        
                                    </div>
                                    
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row m-0 ">
                    <div class="col-md-4 col-sm-12 mt-2 RFPCon-class1" >
                        
                        <div class="card mb-4 RFPCon-class12" >
                            <div class="card-body">
                                <h5 class="mb-4"><strong>Documents for reference</strong></h5>
                                <div class="Service-Description maq">
                                    <div class="scroll-bar-wrap">
                                        <div class="scroll-box RFPCon-class13" >
                                            <aura:iteration items="{!v.reqAttachment}" var="att" indexVar="AttIndex">
                                                <div class="row mt-2">
                                                    <div class="col-md-12 mt-2">
                                                        
                                                        <div class="slds-grid">
                                                            <label for="exampleInputEmail1"><strong>{!AttIndex+1+'. '}</strong>&nbsp;</label>
                                                            <a href="{!'/lightning/r/' + att.ContentDocumentId + '/view'}" target="_blank">
                                                                <lightning:formattedText value="{!att.ContentDocument.Title}"/>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aura:iteration>
                                        </div>
                                        <div class="cover-bar"></div>
                                    </div>
                                </div>
                                
                            </div>
                            
                        </div>
                        
                    </div>
                    <div class="col-md-8 col-sm-12 mt-2 RFPCon-class1" >
                        <div class="card mb-4">
                            <div class="card-body RFPCon-class14">
                                <h5 class="mb-4"><strong>RFP Contacts</strong></h5>
                                <div class="row mt-2">
                                    <div class="col-md-12" >
                                        <div class="Service-Description maq">
                                            <div class="scroll-bar-wrap">
                                                <div class="scroll-box RFPCon-class15">
                                                    <div class="table-responsive RFPCon-class16" tabindex="1" >
                                                        <table class="table">
                                                            <thead class="">
                                                                <tr>
                                                                    <th class="text-left">Name</th>
                                                                    <th class="text-left">Email</th>
                                                                    <th class="text-left">Phone</th>
                                                                    <th class="text-left">Department</th>
                                                                    <th class="text-left">Role</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <aura:iteration items="{!v.reqContactList}" var="contact" indexVar="conIndex">
                                                                    <tr>
                                                                        <td class="text-left">
                                                                            <lightning:formattedText value="{!contact.Name}"/>
                                                                        </td>
                                                                        <td class="text-left">
                                                                            <lightning:formattedText value="{!contact.ERP7__Email__c}"/>
                                                                        </td>
                                                                        <td class="text-left">
                                                                            <lightning:formattedText value="{!contact.ERP7__Phone__c}"/>
                                                                        </td>
                                                                        <td class="text-left">
                                                                            <lightning:formattedText value="{!contact.ERP7__Department__c}"/>
                                                                        </td>
                                                                        <td class="text-left">
                                                                            <lightning:formattedText value="{!contact.ERP7__Role__c}"/>
                                                                        </td>
                                                                    </tr>
                                                                </aura:iteration>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    
                                                </div>
                                                <div class="cover-bar"></div>
                                            </div>
                                        </div>
                                        
                                        
                                    </div>
                                    
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slds-docked-form-footer RFPCon-class16">
                    <lightning:button onclick="{!c.navBack}" label="Cancel" class="slds-button slds-button_neutral"/>
                    <lightning:button onclick="{!c.tab2}" disabled="{!equals(v.allowReq, false)}" label="Request and Responses" class="slds-button slds-button_brand"/>
                    <lightning:button onclick="{!c.tab3}" disabled="{!equals(v.allowReq, false)}" label="FAQs" class="slds-button slds-button_brand"/>
                </div>
            </div>
            <!--RFP Tab End-->
            
            <!--Req and Res Tab Start-->
            <aura:if isTrue="{!v.refresh}">
                <aura:if isTrue = "{!v.reqSupplier.ERP7__Is_Submitted__c}">
                    <div class="{!(v.RandRTab)?'slds-show':'slds-hide'}" id="rrhome" aura:id="rrhome">
                        <div class="slds-page-header">
                            <div class="slds-page-header__row">
                                <div class="slds-page-header__col-title">
                                    <div class="slds-media">
                                        <div class="slds-media__figure">
                                            <span class="slds-icon_container slds-icon-standard-avatar" >
                                                <lightning:icon iconName="standard:record"  size="large" alternativeText="record!" title="record" />
                                                <span class="slds-assistive-text">R&amp;P</span>
                                            </span>
                                        </div>
                                        <div class="slds-media__body">
                                            <p class="slds-text-title--caps slds-line-height--reset" data-aura-rendered-by="520:0">Requests &amp; Responses</p>
                                            <div class="slds-page-header__name">
                                                <div class="slds-page-header__name-title">
                                                    <h1>
                                                        <span class="slds-page-header__title slds-truncate" title="">{!v.request.Name}</span>
                                                    </h1>
                                                </div>
                                            </div>
                                            
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <aura:if isTrue="{!v.resetRandR}">
                            <aura:iteration items="{!v.reqRequirements}" var = "require" indexVar = "reqIndex">
                                <div class="col-md-12 col-lg-12 mb-4 mt-3">
                                    <div class="card mb-4 bl-blue">
                                        <div class="card-body">
                                            <div class="d-flex flex-row mb-3">
                                                <a onclick="{!c.selectRequirement}" data-index="{!reqIndex}"  data-record-id="{!require.Req.Id}">
                                                    <figure class="avatar avatar-sm RFPCon-class17" >
                                                        <div class="rounded-circle"  alt="avatar">{!reqIndex + 1}</div>
                                                    </figure>    
                                                </a>
                                                <div class="pl-3">
                                                    <a onclick="{!c.selectRequirement}" data-index="{!reqIndex}"  data-record-id="{!require.Req.Id}">
                                                        <p class="font-weight-medium mb-0 RFPCon-class18" >
                                                            <strong>
                                                                <lightning:formattedText value = "{!require.Req.Name}"/>
                                                            </strong>
                                                        </p>
                                                        <!--<p class="text-muted mb-0 text-small">09.01.2020 - 12:45</p>-->
                                                    </a>
                                                </div>
                                            </div>
                                            <p>
                                                <lightning:formattedRichText value="{!require.Req.ERP7__Question__c}"/>
                                            </p>
                                           <!-- <aura:if isTrue = "{!require.isCurrentReq}">-->
                                                <div class="mt-3">
                                                    <div class="RFPCon-class19">
                                                        
                                                    </div> 
                                                    <div class="areadownresponse">
                                                        <p ><strong>Responses</strong></p>
                                                        <!--Parent Res-->
                                                        <aura:if isTrue="{!not(greaterthan(require.ResPackList.length,0))}">
                                                            <div class="no projects RFPCon-class20">
                                                                <div class="slds-notify_container slds-is-relative RFPCon-class21" >
                                                                    <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                        <div>
                                                                            <span class="slds-assistive-text">warning</span>
                                                                            <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No Projects">
                                                                                <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                            </span>
                                                                        </div>
                                                                        <div class="slds-notify__content RFPCon-class22" >
                                                                            <h2 class="slds-text-heading_small RFPCon-class23" >Sorry, No Response Available.</h2>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <aura:set attribute="else">
                                                                <aura:if isTrue="{!require.ResPackList.length > 0}">
                                                                <aura:iteration items = "{!require.ResPackList}" var = "response" indexVar = "resIndex">
                                                                    <div class="slds-grid slds-wrap pt-2 pb-2 RFPCon-class24"  > 
                                                                        <div class="col-md-6 col-sm-12  pt-0 pb-2">
                                                                            <div class="scroll-bar-wrap">
                                                                                <div class="scroll-box RFPCon-class9" >
                                                                                    <div aura:id="output" class="">
                                                                                        <lightning:formattedRichText value="{!response.Res.ERP7__Response_Answer__c}" />
                                                                                    </div>
                                                                                </div>
                                                                                <div class="cover-bar"></div>
                                                                            </div>
                                                                            
                                                                        </div>                                                            
                                                                        <div class=" col-md-3 col-sm-12">
                                                                            <div class=" slds-grid ">
                                                                                <div class="col-6">
                                                                                    <label for="exampleFormControlSelect2"><strong>Rating : </strong></label>&nbsp;
                                                                                     <lightning:formattedText value = "{!response.Res.ERP7__Supplier_Rating__c}"/> 
                                                                                </div>    
                                                                                <div class="col-6" >
                                                                                    <label for="exampleFormControlSelect2"><strong>Compliance : </strong></label>&nbsp;
                                                                                     <lightning:formattedText value = "{!response.Res.ERP7__Supplier_Compliancy__c}"/>
                                                                                </div>    
                                                                            </div>
                                                                            
                                                                            
                                                                        </div>
                                                                        
                                                                        <div class="col-md-3 col-sm-12 comment-contaiener">
                                                                            <div class="slds-col text-left pt-2">
                                                                                <!--<a herf="#"> ERP7 Pre-Requisites.docx </a>-->
                                                                                <aura:If isTrue="{!not(response.Att.Id == undefined)}">
                                                                                    <div class="slds-grid">
                                                                                        <div class="col-5 p-0 RFPCon-class25" >
                                                                                            <label for="exampleFormControlSelect2"><strong>Attachment : </strong></label>&nbsp;
                                                                                        </div>    
                                                                                        <div class="col-7 p-0 RFPCon-class27"  >
                                                                                            <div class="slds-truncate2"><lightning:formattedUrl value="{!'/'+response.Att.Id}" label="{!response.Att.Name}" target="_blank" class="fcolor"/></div>
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:If>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </aura:iteration>
                                                                </aura:if>
                                                            </aura:set>
                                                        </aura:if>
                                                        <!--Parent Res End-->
                                                        
                                                        <!--CHILD req-->
                                                        <aura:iteration items="{!require.childReqs}" var = "chRequire" indexVar = "cReqIndex">
                                                            <div class="col-md-12 col-lg-12 mb-4 mt-3">
                                                                <div class="card mb-4 bl-blue">
                                                                    <div class="card-body">
                                                                        <div class="d-flex flex-row mb-3">
                                                                            <a onclick="{!c.selectChRequirement}" data-req-index="{!reqIndex}" data-index="{!cReqIndex}"  data-record-id="{!chRequire.Req.Id}">
                                                                                <figure class="avatar avatar-sm RFPCon-class17" >
                                                                                    <div class="rounded-circle"  alt="avatar">{!(reqIndex + 1)+'.'+ (cReqIndex+1)}</div>
                                                                                </figure>    
                                                                            </a>
                                                                            <div class="pl-3">
                                                                                <a onclick="{!c.selectChRequirement}" data-req-index="{!reqIndex}" data-index="{!cReqIndex}"  data-record-id="{!chRequire.Req.Id}">
                                                                                    <p class="font-weight-medium mb-0 RFPCon-class18" >
                                                                                        <strong>
                                                                                            <lightning:formattedText value = "{!chRequire.Req.Name}"/>
                                                                                        </strong>
                                                                                    </p>
                                                                                </a>
                                                                            </div>
                                                                        </div>
                                                                        <p>
                                                                            <lightning:formattedRichText value="{!chRequire.Req.ERP7__Question__c}"/>
                                                                        </p>
                                                                        <!--<aura:if isTrue = "{!chRequire.isCurrentReq}">-->
                                                                            <div class="mt-3">
                                                                                <div class="RFPCon-class19">
                                                                                    
                                                                                </div> 
                                                                                <div class="areadownresponse">
                                                                                    <p ><strong>Responses</strong></p>
                                                                                    <!--Child Res-->
                                                                                    <aura:if isTrue="{!not(greaterthan(chRequire.ResPackList.length,0))}">
                                                                                        <div class="no projects RFPCon-class20" >
                                                                                            <div class="slds-notify_container slds-is-relative RFPCon-class21">
                                                                                                <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                                                    <div>
                                                                                                        <span class="slds-assistive-text">warning</span>
                                                                                                        <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No Projects">
                                                                                                            <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                                                        </span>
                                                                                                    </div>
                                                                                                    <div class="slds-notify__content RFPCon-class22" >
                                                                                                        <h2 class="slds-text-heading_small RFPCon-class23" >Sorry, No Response Available.</h2>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                        <aura:set attribute="else">
                                                                                            <aura:iteration items = "{!chRequire.ResPackList}" var = "chResponse" indexVar = "cResIndex">
                                                                                                <div class="slds-grid slds-wrap pt-2 pb-2 RFPCon-class28" >
                                                                                                    <div class="col-md-6 col-sm-12  pt-0 pb-2">
                                                                                                        <div aura:id="output" class="">
                                                                                                            <lightning:formattedRichText value="{!chResponse.Res.ERP7__Response_Answer__c}" />
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    
                                                                                                    
                                                                                                    <div class="col-md-3 col-sm-12">
                                                                                                        <div class=" slds-grid ">
                                                                                                            <div class="col-6" >
                                                                                                                <label for="exampleFormControlSelect2"><strong>Rating : </strong></label>&nbsp;
                                                                                                                <lightning:formattedText value = "{!chResponse.Res.ERP7__Supplier_Rating__c}"/>
                                                                                                            </div>    
                                                                                                            <div class="col-6"  >
                                                                                                                <label for="exampleFormControlSelect2"><strong>Compliance : </strong></label>&nbsp;
                                                                                                                 <lightning:formattedText value = "{!chResponse.Res.ERP7__Supplier_Compliancy__c}"/>
                                                                                                            </div>    
                                                                                                        </div>
                                                                                                       
                                                                                                    </div>
                                                                                                    
                                                                                                    <div class="col-md-3 col-sm-12 comment-contaiener">
                                                                                                        <div class="slds-col text-left pt-2">
                                                                                                            <aura:If isTrue="{!not(chResponse.Att.Id == undefined)}">
                                                                                                                <div class="slds-grid">
                                                                                                                    <div class="col-5 p-0 RFPCon-class25" >
                                                                                                                        <label for="exampleFormControlSelect2"><strong>Attachment : </strong></label>&nbsp;
                                                                                                                    </div>    
                                                                                                                    <div class="col-7 p-0 RFPCon-class27"  >
                                                                                                                        <div class="slds-truncate2"><lightning:formattedUrl value="{!'/'+chResponse.Att.Id}" label="{!chResponse.Att.Name}" target="_blank" class="fcolor"/></div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </aura:If>
                                                                                                        </div>
                                                                                                        
                                                                                                    </div>
                                                                                                </div>
                                                                                            </aura:iteration>
                                                                                        </aura:set>
                                                                                    </aura:if>
                                                                                    <!--Child Res End-->
                                                                                </div>
                                                                            </div>
                                                                       <!-- </aura:if>-->
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </aura:iteration>
                                                        <!--Child Req End-->
                                                    </div>
                                                </div>
                                          <!--  </aura:if>-->
                                        </div>
                                    </div>
                                </div>
                            </aura:iteration>
                            <div class="pb-5"></div>
                            <!--Parent Req End-->
                        </aura:if>
                        <div class="slds-docked-form-footer RFPCon-class16" >
                            <lightning:button onclick="{!c.tab1}" label="Back" variant="neutral"/>
                            <lightning:button label="Save" disabled="true" variant="brand" />
                        </div>
                    </div>
                    <aura:set attribute = "else">
                        <div class="{!(v.RandRTab)?'slds-show':'slds-hide'}" id="rrhome" aura:id="rrhome">
                            <div class="slds-page-header">
                                <div class="slds-page-header__row">
                                    <div class="slds-page-header__col-title">
                                        <div class="slds-media">
                                            <div class="slds-media__figure">
                                                <span class="slds-icon_container slds-icon-standard-avatar" >
                                                    <lightning:icon iconName="standard:record"  size="large" alternativeText="record!" title="record" />
                                                    <span class="slds-assistive-text">R&amp;P</span>
                                                </span>
                                            </div>
                                            <div class="slds-media__body">
                                                <p class="slds-text-title--caps slds-line-height--reset" data-aura-rendered-by="520:0">Requests &amp; Responses</p>
                                                <div class="slds-page-header__name">
                                                    <div class="slds-page-header__name-title">
                                                        <h1>
                                                            <span class="slds-page-header__title slds-truncate" title="">{!v.request.Name}</span>
                                                        </h1>
                                                    </div>
                                                </div>
                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <aura:if isTrue="{!v.resetRandR}">
                                <aura:iteration items="{!v.reqRequirements}" var = "require" indexVar = "reqIndex">
                                    <div class="col-md-12 col-lg-12 mb-4 mt-3">
                                        <div class="card mb-4 bl-blue">
                                            <div class="card-body">
                                                <div class="d-flex flex-row mb-3">
                                                    <a onclick="{!c.selectRequirement}" data-index="{!reqIndex}"  data-record-id="{!require.Req.Id}">
                                                        <figure class="avatar avatar-sm RFPCon-class17" >
                                                            <div class="rounded-circle" alt="avatar">{!reqIndex + 1}</div>
                                                        </figure>    
                                                    </a>
                                                    <div class="pl-3">
                                                        <a onclick="{!c.selectRequirement}" data-index="{!reqIndex}"  data-record-id="{!require.Req.Id}">
                                                            <p class="font-weight-medium mb-0 RFPCon-class18" >
                                                                <strong>
                                                                    <lightning:formattedText value = "{!require.Req.Name}"/>
                                                                </strong>
                                                            </p>
                                                        </a>
                                                    </div>
                                                </div>
                                                <p>
                                                    <lightning:formattedRichText value="{!require.Req.ERP7__Question__c}"/>
                                                </p>
                                               <!-- <aura:if isTrue = "{!require.isCurrentReq}"> -->
                                                    <div class="mt-3">
                                                        <div class="RFPCon-class19">
                                                            <a onclick="{!c.addNew}" data-index="{!reqIndex}"  data-record-id="{!require.Req.Id}" class="RFPCon-class29" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                <i class="fa fa-plus RFPCon-class30" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                &nbsp;New
                                                            </a>
                                                        </div>   
                                                        <p ><strong>Response</strong></p> 
                                                        <div class="areadownresponse">
                                                            <!--Parent Res-->
                                                            <aura:if isTrue="{!not(greaterthan(require.ResPackList.length,0))}">
                                                                <div class="no projects RFPCon-class20" >
                                                                    <div class="slds-notify_container slds-is-relative RFPCon-class21" >
                                                                        <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                            <div>
                                                                                <span class="slds-assistive-text">warning</span>
                                                                                <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No Projects">
                                                                                    <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                                </span>
                                                                            </div>
                                                                            <div class="slds-notify__content RFPCon-class22" >
                                                                                <h2 class="slds-text-heading_small RFPCon-class23" >Please add your  response.</h2>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <aura:set attribute="else">
                                                                    <aura:if isTrue="{!require.ResPackList.length > 0}">
                                                                        <aura:iteration items = "{!require.ResPackList}" var="response" indexVar = "resIndex">
                                                                            <div class="slds-grid slds-wrap pt-2 pb-2"> 
                                                                                <div class="col-md-1 col-sm-12 text-center pt-2 pb-2">
                                                                                    <a class="svg RFPCon-class31" onclick="{!c.deleteRes}" data-index="{!resIndex}" data-record="{!response.Res.Id}" data-req-index="{!reqIndex}" data-req-id="{!require.Req.Id}" >
                                                                                        <lightning:icon iconName="action:delete" size="x-small" alternativeText="delete!" title="delete" />
                                                                                    </a>
                                                                                </div>
                                                                                <div class="col-md-6 col-sm-12  pt-0 pb-2">
                                                                                    <lightning:textarea value="{!response.Res.ERP7__Response_Answer__c}" placeholder="Enter Response..." onchange="{!c.testmethods}"/>
                                                                                </div>
                                                                                
                                                                                <div class="col-md-3 col-sm-12">
                                                                                    <div class=" slds-grid ">
                                                                                         
                                                                                        <div class="col-6 " >
                                                                                            <lightning:select label="Rating" name="suppRatingSelect" aura:id="suppRatingSelect" value="{!response.Res.ERP7__Supplier_Rating__c}">
                                                                                                <aura:iteration items="{!v.resRatingOptions}" var="option">
                                                                                                    <option text="{!option.label}" value="{!option.id}" selected="{!option.selected}"/>
                                                                                                </aura:iteration>
                                                                                            </lightning:select>
                                                                                        </div>      
                                                                                    
                                                                                        
                                                                                        <div class="col-6">
                                                                                            <lightning:select label="Compliance" name="supComplianceSelect" aura:id="supComplianceSelect" value="{!response.Res.ERP7__Supplier_Compliancy__c}">
                                                                                                <aura:iteration items="{!v.resComplianceOptions}" var="option">
                                                                                                    <option text="{!option.label}" value="{!option.id}" selected="{!option.selected}"/>
                                                                                                </aura:iteration>
                                                                                            </lightning:select>
                                                                                        </div>
                                                                                    </div>
                                                                                    
                                                                                </div>
                                                                                
                                                                                <div class="col-md-2 col-sm-12 comment-contaiener">
                                                                                    <div class="slds-col text-left pt-2">
                                                                                        <aura:If isTrue="{!not(response.Att.Id == undefined)}">
                                                                                            <div class="slds-grid">
                                                                                                <div class="slds-col">
                                                                                                    <div class="slds-grid">
                                                                                                        <a onclick="{!c.DeleteResAT}" data-record="{!response.Att}" data-record-id="{!response.Att.Id}" data-index="{!reqIndex}" data-PIndex="" title="delete" class=" RFPCon-class33">
                                                                                                            <i class="fa fa-minus-circle" aria-hidden="true"></i>
                                                                                                        </a>
                                                                                                        &nbsp;
                                                                                                        <div class="slds-truncate RFPCon-class34" ><lightning:formattedUrl value="{!'/'+response.Att.Id}" label="{!response.Att.Name}" title="{!response.Att.Name}" target="_blank" class="fcolor"/></div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <aura:set attribute="else">
                                                                                                <aura:renderIf isTrue="{!and(response.Att.Id == undefined, response.Res.Id != undefined)}">
                                                                                                    <div class="slds-col">
                                                                                                        <lightning:input aura:id="responsefile" type="file" files="{!v.FileList}" name="{!response.Res.Id}" onchange="{!c.onFileUploaded}" onfocus="{!c.reRender}" oncomplete="{!c.reRender}" onblur="{!c.reRender}" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" multiple="true" class="RFPCon-class35" title="{!(reqIndex+'-'+'')}"/>
                                                                                                    </div>
                                                                                                </aura:renderIf>
                                                                                            </aura:set>
                                                                                        </aura:If>
                                                                                    </div>
                                                                                    
                                                                                </div>
                                                                            </div>
                                                                        </aura:iteration>
                                                                    </aura:if>
                                                                </aura:set>
                                                            </aura:if>
                                                            
                                                            <!--Parent Res End-->
                                                            
                                                            <!--CHILD req-->
                                                            <aura:iteration items="{!require.childReqs}" var = "chRequire" indexVar = "cReqIndex">
                                                                <div class="col-md-12 col-lg-12 mb-4 mt-3">
                                                                    <div class="card mb-4 bl-blue">
                                                                        <div class="card-body">
                                                                            <div class="d-flex flex-row mb-3">
                                                                                <a onclick="{!c.selectChRequirement}" data-req-index="{!reqIndex}" data-index="{!cReqIndex}"  data-record-id="{!chRequire.Req.Id}">
                                                                                    <figure class="avatar avatar-sm RFPCon-class17" >
                                                                                        <div class="rounded-circle"  alt="avatar">{!(reqIndex + 1)+'.'+ (cReqIndex+1)}</div>
                                                                                    </figure>    
                                                                                </a>
                                                                                <div class="pl-3">
                                                                                    <a onclick="{!c.selectChRequirement}" data-req-index="{!reqIndex}" data-index="{!cReqIndex}"  data-record-id="{!chRequire.Req.Id}">
                                                                                        <p class="font-weight-medium mb-0 RFPCon-class18" >
                                                                                            <strong>
                                                                                                <lightning:formattedText value = "{!chRequire.Req.Name}"/>
                                                                                            </strong>
                                                                                        </p>
                                                                                    </a>
                                                                                </div>
                                                                            </div>
                                                                            <p>
                                                                                <lightning:formattedRichText value="{!chRequire.Req.ERP7__Question__c}"/>
                                                                            </p>
                                                                           <!-- <aura:if isTrue = "{!chRequire.isCurrentReq}">-->
                                                                                <div class="mt-3">
                                                                                    <div class="RFPCon-class19">
                                                                                        <a onclick="{!c.addChNew}" data-index="{!cReqIndex}" data-req-index="{!reqIndex}" data-record-id="{!chRequire.Req.Id}" class="RFPCon-class29" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                            <i class="fa fa-plus RFPCon-class30" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                            &nbsp;New
                                                                                        </a>
                                                                                    </div>   <p ><strong>Response</strong></p> 
                                                                                    <div class="areadownresponse">
                                                                                        <!--Child Res-->
                                                                                        <aura:if isTrue="{!not(greaterthan(chRequire.ResPackList.length,0))}">
                                                                                            <div class="no projects RFPCon-class20" >
                                                                                                <div class="slds-notify_container slds-is-relative RFPCon-class21" >
                                                                                                    <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                                                        <div>
                                                                                                            <span class="slds-assistive-text">warning</span>
                                                                                                            <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No Projects">
                                                                                                                <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                                                            </span>
                                                                                                        </div>
                                                                                                        <div class="slds-notify__content RFPCon-class22" >
                                                                                                            <h2 class="slds-text-heading_small RFPCon-class23" >Please add your  response.</h2>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <aura:set attribute="else">
                                                                                                <aura:iteration items = "{!chRequire.ResPackList}" var = "chResponse" indexVar = "cResIndex">
                                                                                                    <div class="slds-grid slds-wrap pt-2 pb-2"> 
                                                                                                        <div class="col-md-1 col-sm-12 text-center pt-2 pb-2">
                                                                                                            <a class="svg RFPCon-class31" onclick="{!c.deleteChRes}" data-index="{!cResIndex}" data-record-id="{!chResponse.Res.Id}" data-record="{!cReqIndex}" data-req-index="{!reqIndex}">
                                                                                                                <lightning:icon iconName="action:delete" size="x-small" alternativeText="delete!" title="delete" />
                                                                                                            </a>
                                                                                                        </div>
                                                                                                        <div class="col-md-5 col-sm-12  pt-0 pb-2">
                                                                                                            <lightning:textarea value="{!chResponse.Res.ERP7__Response_Answer__c}" class="" placeholder="Enter Response..."/>
                                                                                                        </div>
                                                                                                        <div class="col-md-3 col-sm-12">
                                                                                                            <div class=" slds-grid ">
                                                                                                                <div class="col-6 " >
                                                                                                                    <label for="exampleFormControlSelect2"><strong>Rating</strong></label>&nbsp;
                                                                                                                    <lightning:select class="" name="chSuppRatingSelect" aura:id="chSuppRatingSelect" value="{!chResponse.Res.ERP7__Supplier_Rating__c}">
                                                                                                                        <aura:iteration items="{!v.resRatingOptions}" var="option">
                                                                                                                            <option text="{!option.label}" value="{!option.id}" selected="{!option.selected}"/>
                                                                                                                        </aura:iteration>
                                                                                                                    </lightning:select>
                                                                                                                </div>    
                                                                                                                <div class="col-6" >
                                                                                                                     <label for="exampleFormControlSelect2"><strong>Compliance</strong></label>&nbsp;
                                                                                                                     <lightning:select class="" name="chSupComplianceSelect" aura:id="chSupComplianceSelect" value="{!chResponse.Res.ERP7__Supplier_Compliancy__c}">
                                                                                                                        <aura:iteration items="{!v.resComplianceOptions}" var="option">
                                                                                                                            <option text="{!option.label}" value="{!option.id}" selected="{!option.selected}"/>
                                                                                                                        </aura:iteration>
                                                                                                                    </lightning:select>
                                                                                                                </div>      
                                                                                                            </div>
                                                                                                            
                                                                                                            
                                                                                                        </div>
                                                                                                        <div class="col-md-3 col-sm-12 comment-contaiener">
                                                                                                            <div class="slds-col text-right pt-2">
                                                                                                                <aura:If isTrue="{!not(chResponse.Att.Id == undefined)}">
                                                                                                                    <div class="slds-grid">
                                                                                                                        <div class="slds-col">
                                                                                                                            <div class="slds-grid">
                                                                                                                                <a onclick="{!c.DeleteResAT}" data-record="{!chResponse.Att}" data-record-id="{!chResponse.Att.Id}" data-index="{!reqIndex}" data-PIndex="{!cReqIndex}" title="delete" class="RFPCon-class33">
                                                                                                                                    <i class="fa fa-minus-circle" aria-hidden="true"></i>
                                                                                                                                </a>
                                                                                                                                &nbsp;
                                                                                                                                <div class="slds-truncate RFPCon-class34" >
                                                                                                                                    <lightning:formattedUrl value="{!'/'+chResponse.Att.Id}" label="{!chResponse.Att.Name}" title="{!chResponse.Att.Name}" target="_blank" class="fcolor"/>
                                                                                                                                </div> 
                                                                                                                            </div>    
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                    <aura:set attribute="else">
                                                                                                                        <aura:renderIf isTrue="{!and(chResponse.Att.Id == undefined, chResponse.Res.Id != undefined)}">
                                                                                                                            <div class="slds-col">
                                                                                                                                <lightning:input type="file" files="{!v.FileList}" name="{!chResponse.Res.Id}" onchange="{!c.onFileUploaded}" onfocus="{!c.reRender}" oncomplete="{!c.reRender}" onblur="{!c.reRender}" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" multiple="true" class="RFPCon-class35" title="{!(reqIndex+'-'+cReqIndex)}"/>
                                                                                                                            </div>
                                                                                                                        </aura:renderIf>
                                                                                                                    </aura:set>
                                                                                                                </aura:If>
                                                                                                            </div>
                                                                                                            
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </aura:iteration>
                                                                                            </aura:set>
                                                                                        </aura:if>
                                                                                        <!--Child Res End-->
                                                                                    </div>
                                                                                </div>
                                                                           <!-- </aura:if> -->
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </aura:iteration>
                                                            
                                                            <!--Child Req End-->
                                                        </div>
                                                    </div>
                                               <!-- </aura:if>-->
                                            </div>
                                        </div>
                                    </div>
                                </aura:iteration>
                                <div class="mb-4"></div>
                                <!--Parent Req End-->
                            </aura:if>
                            <div class="slds-docked-form-footer RFPCon-class16">
                                <lightning:button onclick="{!c.tab1}" label="Back" variant="neutral" />
                                <lightning:button onclick="{!c.saveallResponses}" label="Save" variant="brand"/>
                                <lightning:button onclick="{!c.openSubmitModal}" label="Submit" variant="success"/>
                            </div>
                        </div>
                        
                        
                        
                    </aura:set>
                </aura:if>
            </aura:if>
            <!--Req and Res Tab End-->
            
            <!--Submit Modal Starts Here-->
            <aura:if isTrue="{!v.showSubmitModal}">
                <div aura:id="mySubmitModal" role="dialog" class="slds-modal slds-fade-in-open RFPCon-class36">
                    <div class="slds-modal__container RFPCon-class37">
                        <div class="slds-modal__content slds-p-around_medium">
                            <p class="RFPCon-class38" style="text-align : center !important;">
                                Are you sure you want to submit all changes?
                            </p>
                        </div>
                        <div class="slds-modal__footer RFPCon-class38" >
                            <button class="slds-button slds-button--neutral" onclick="{!c.closeSubmitModal}">No</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.submitRequests}">Yes</button>
                        </div>
                    </div>
                </div>
                <div class="slds-backdrop_open" aura:id="mySubmitModalBackdrop"></div>
            </aura:if>
            <!--Submit Modal Ends Here-->
            
            <!--FAQs Tab Start-->
            <div class="{!(v.FAQsTab)?'slds-show':'slds-hide'}" id="faqhome" aura:id="faqhome">
                <div class="slds-page-header">
                    <div class="slds-page-header__row">
                        <div class="slds-page-header__col-title">
                            <div class="slds-media">
                                <div class="slds-media__figure">
                                    <span class="slds-icon_container slds-icon-standard-avatar" >
                                        <lightning:icon iconName="standard:record"  size="large" alternativeText="record!" title="record" />
                                        <span class="slds-assistive-text">FAQs</span>
                                    </span>
                                </div>
                                <div class="slds-media__body">
                                    <p class="slds-text-title--caps slds-line-height--reset" data-aura-rendered-by="520:0">FAQs</p>
                                    <div class="slds-page-header__name">
                                        <div class="slds-page-header__name-title">
                                            <h1>
                                                <span class="slds-page-header__title slds-truncate" title="">{!v.request.Name}</span>
                                            </h1>
                                        </div>
                                    </div>
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="container-fluid RFPCon-class39" >
                    <div class="col-md-3 pl-0 mb-2 RFPCon-class40" >  
                        <div class="slds-grid" >
                            <span onkeypress="{!c.searchQuestion}" class="">
                                <lightning:input onchange= "{!c.searchQuestion}" type="Search" name="searchQ" value="{!v.searchQuestionStr}" placeholder="Search Question..."/>
                            </span>
                        </div> 
                    </div>
                </div>
                <div class="col-12 mt-2 " >
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="row mt-2">
                                <div class="col-md-12" >
                                    <div class="Service-Description maq">
                                        <div class="scroll-bar-wrap"> 
                                            <div class="scroll-box RFPCon-class41">
                                                <aura:if isTrue="{!not(greaterthan(v.currentFAQs.length,0))}">
                                                    <div class="no projects RFPCon-class20" >
                                                        <div class="slds-notify_container slds-is-relative RFPCon-class21">
                                                            <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                <div>
                                                                    <span class="slds-assistive-text">warning</span>
                                                                    <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No Projects">
                                                                        <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                    </span>
                                                                </div>
                                                                <div class="slds-notify__content RFPCon-class22">
                                                                    <h2 class="slds-text-heading_small RFPCon-class23" >Sorry, No FAQs Available.</h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <aura:set attribute="else">
                                                        <div class="table-responsive RFPCon-class16" tabindex="1" >
                                                            <table class="table">
                                                                <thead class="">
                                                                    <tr>
                                                                        <th width="50%" class="text-left">Question</th>
                                                                        <th width="50%" class="text-left">Answer</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <aura:iteration items="{!v.currentFAQs}" var="FAQ" indexVar="conIndex">
                                                                        <tr>
                                                                            <td width="50%" class="text-left">
                                                                                <div class="slds-truncate3"><lightning:formattedRichText value="{!FAQ.ERP7__Question__c}"/></div>
                                                                            </td>
                                                                            <td width="50%" class="text-left">
                                                                                <div class="slds-truncate3"><lightning:formattedRichText value="{!FAQ.ERP7__Answer__c}"/></div>
                                                                            </td>
                                                                        </tr>
                                                                    </aura:iteration>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                            <div class="cover-bar"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slds-docked-form-footer RFPCon-class16" >
                    <lightning:button onclick="{!c.tab1}" label="Back" class="slds-button slds-button_neutral"/>
                </div>
            </div>
            <!--FAQs Tab End-->
        </div>
    </div>
</aura:component>