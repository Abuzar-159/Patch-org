<aura:component access="global" implements="force:appHostable" controller="ManageRFP"> 
    <head>
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="/resource/RatingPlugin/css/jquery.raty.css, /resource/SLDS0120/assets/styles/salesforce-lightning-design-system-ltng.css"
                  scripts="/resource/RatingPlugin/js/jquery.js, /resource/RatingPlugin/js/jquery.raty.js"
                  afterScriptsLoaded="{!c.doInit}"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/comparerfp.css"/>
        <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>
    </head> 
    
    <aura:attribute name = "RFPWrap" type = "object[]" default="{'sObjectType' : 'RFPWrapper'}"/>
    <aura:attribute name = "reqSuppliers" type = "object[]" default="{'sObjectType' : 'supRFPWrapper'}"/>
    <aura:attribute name = "request" type = "Request__c" default="{'sObjectType' : 'ERP7__Request__c'}"/>
    <aura:attribute name = "requestId" type = "Id" default="a3S1o0000002fEaEAI"/>
    <aura:attribute name = "requestStatus" type = "String" default="Open"/>
    <aura:attribute name = "view" type = "String" default="list"/>
    
    <aura:attribute name = "serverSuccess" type = "String" default=""/>
    <aura:attribute name = "exceptionError" type = "String" default=""/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name = "fromDetailPage" type = "Boolean" default="false" access="global"/>
    <aura:attribute name = "showReceive" type = "Boolean" default="false"/>
     <aura:attribute name = "fromRFPPage" type = "Boolean" default="false" access="global"/>
    
    <span class="comparerfp-class2">
        <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading..." aura:id="mainSpin" class="mainSpinClass"/>
    </span>
    
    <div class="maqsood erp_mark7 comparerfp-class1" aura:id="body">
        
        <div class="{!if(and(v.serverSuccess != '', v.serverSuccess != undefined),'slds-notify_container slds-is-fixed comparerfp-class3','slds-notify_container slds-is-fixed comparerfp-class4')}">
            <div class="slds-notify slds-notify_toast slds-theme_success" role="status">
                <span class="slds-assistive-text">success</span>
                <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="Description of icon when needed">
                    <lightning:icon iconName="utility:success" variant="inverse" size="x-small" alternativeText="success" title="success" />
                </span>
                <div class="slds-notify__content">
                    <h2 class="slds-text-heading_small ">{!v.serverSuccess}</h2>
                </div>
                <div class="slds-notify__close">
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeSuccess}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close" title="close" />
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed comparerfp-class3','slds-notify_container slds-is-fixed comparerfp-class4')}">
            <div class="slds-notify slds-notify_toast slds-theme_error comparerfp-class5" role="status">
                <span class="slds-assistive-text">error</span>
                <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                    <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="error" title="error" />
                </span>
                <div class="slds-notify__content">
                    <h2 class="slds-text-heading_x-small comparerfp-class6">{!v.exceptionError}
                    </h2>
                </div>
                <div class="slds-notify__close comparerfp-class7">
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close" title="close" />
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="erp_Mark7 pb-5">
            <div class="row m-0 ">
                <div class="col-md-4 col-sm-12 mt-3">
                    <div class="card mb-4 comparerfp-class8">
                        <div class="card-body">
                            <h5 class="mb-4" ><strong>Details</strong></h5>
                            <div class="row mt-2">
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Name:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedText value="{!v.request.Name}" />
                                        </div>  
                                        
                                    </div>
                                </div>
                                
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Request Date:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedDateTime value="{!v.request.ERP7__Request_Date__c}" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Response Due Date:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedDateTime value="{!v.request.ERP7__Response_Due_Date__c}" />
                                        </div>
                                    </div>
                                </div>
                                
                                
                                
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Organisation:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedText value="{!v.request.ERP7__Organisation__r.Name}" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Channel:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedText value="{!v.request.ERP7__Channel__r.Name}" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 mt-2">
                                    <div class="slds-grid">
                                        <div class="slds-col col-6 p-0">
                                            <label for="exampleInputEmail1" class="comparerfp-class9">Distribution Channel:&nbsp;</label>
                                        </div>
                                        <div class="slds-col">
                                            <lightning:formattedText value="{!v.request.ERP7__Distribution_Channel__r.Name}" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-8 col-sm-12 mt-3">
                    <div class="card mb-4">
                        <div class="card-body comparerfp-class10">
                            <h5 class="mb-4"><strong>Description</strong></h5>
                            <div class="row mt-2">
                                <div class="col-md-12" >
                                    <div class="Service-Description maq">
                                        <div class="scroll-bar-wrap">
                                            <div class="scroll-box comparerfp-class11">
                                                <p>
                                                   <lightning:formattedRichText value="{!v.request.ERP7__Description__c}"/>
                                                </p>
                                            </div>
                                            <div class="comparerfp-cover-bar"></div>
                                        </div> 
                                    </div>
                                    
                                    
                                </div>
                                
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="container-fluid">	 
                 <div class="card shadow-sm comparerfp-class12">
                     <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="mb-4"><strong>Suppliers</strong></h5>
                            <div>
                                <a class="mr-3" aura:id="gridIcon" onclick="{!c.changeView}" data-record = "grid">
                                    <i class="fa fa-th-large"></i>
                                </a>
                                <a class="mr-3 acitve-list" aura:id="listIcon" onclick="{!c.changeView}" data-record = "list">
                                    <i class="fa fa-list"></i>
                                </a>
                            </div>
                        </div>
                        <div class="{!(v.view == 'list')?'slds-show':'slds-hide'}">
                            <div class="table-responsive comparerfp-class13" tabindex="1">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th class="text-left">Name</th>
                                            <th class="text-left">Supplier</th>
                                            <th class="text-left">Rating</th>
                                            <th class="text-left">Score</th>
                                            <th class="text-left">Submitted Date</th>
                                            <th class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items = "{!v.reqSuppliers}" var = "sup" indexVar="suppIndex">
                                            <tr>
                                                <td>
                                                    <a onclick="{!c.evaluateReq}" data-index="{!suppIndex}" data-record-id="{!sup.supplier.Id}">
                                                        <lightning:formattedText value="{!sup.supplier.Name}"/>
                                                    </a>
                                                </td>
                                                <td class="text-left">
                                                    <aura:if isTrue="{!and(sup.supplier.ERP7__Supplier__c != undefined,sup.supplier.ERP7__Supplier__c != null)}">
                                                        <lightning:formattedUrl value="{!'/'+sup.supplier.ERP7__Supplier__c}" label="{!sup.supplier.ERP7__Supplier__r.Name}" target="_blank"/>
                                                    </aura:if>
                                                </td>
                                                <td class="text-left">
                                                    <lightning:formattedNumber value="{!sup.avgRating+ ' '}"  maximumFractionDigits="2"/>
                                                </td>
                                                <td class="text-left">
                                                    <lightning:formattedNumber value="{!sup.avgScore+ ' '}"  maximumFractionDigits="2"/>%
                                                </td>
                                                <td>
                                                    <lightning:formattedDateTime value="{!sup.supplier.ERP7__Submit_Date__c}"/>
                                                </td>
                                                <td class="text-center">
                                                    <a onclick="{!c.navPO}" data-index="{!suppIndex}" class="slds-button slds-button_brand color-white">Create PO</a>
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="{!(v.view == 'grid')?'slds-show':'slds-hide'}">
                            <div class="row m-0">
                                
                                <aura:iteration items = "{!v.reqSuppliers}" var = "sup" indexVar="suppIndex">
                                    <div class="col-md-3">
                                        <div class="card comparerfp-class14">
                                            <div class="card-body">
                                                <div class="d-flex align-items-center">
                                                    <h5 class="mb-0">
                                                        <a onclick="{!c.evaluateReq}" data-index="{!suppIndex}" data-record-id="{!sup.supplier.Id}">
                                                            <lightning:formattedText value="{!sup.supplier.Name}"/>
                                                        </a>
                                                    </h5>
                                                </div>
                                                <div class="text-muted small mt-1 mb-3">
                                                    <lightning:formattedUrl value="{!'/'+sup.supplier.ERP7__Supplier__c}" label="{!sup.supplier.ERP7__Supplier__r.Name}" target="_blank"/>
                                                   <!-- <a onclick="{!c.navSupplier}" data-record-id="{!sup.supplier.ERP7__Supplier__c}">
                                                        <lightning:formattedText value="{!sup.supplier.ERP7__Supplier__r.Name}"/>
                                                    </a>-->
                                                </div>
                                                
                                                <p class="medium">
                                                    <div class="slds-grid">Submitted Date&nbsp;:&nbsp; 
                                                        <lightning:formattedDateTime value="{!sup.supplier.ERP7__Submit_Date__c}"/>
                                                    </div>
                                                </p>
                                                <div class="row">
                                                    <div class="col">
                                                        <div class="text-muted mb-1 small">Rating</div>
                                                        <div>
                                                            <lightning:formattedNumber value="{!sup.avgRating+ ' '}" maximumFractionDigits="2"/>
                                                        </div>
                                                    </div>
                                                    <div class="col">
                                                        <div class="text-muted mb-1 small">Score</div>
                                                        <div>
                                                            <lightning:formattedNumber value="{!sup.avgScore+ ' '}"  maximumFractionDigits="2"/>%
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <hr class="m-0"/>
                                            <div class="card-body text-center">
                                                <a onclick="{!c.navPO}" data-index="{!suppIndex}" class="slds-button slds-button_brand color-white">Create PO</a>
                                            </div>
                                        </div>
                                    </div>
                                </aura:iteration>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-docked-form-footer" >
                <div class="col-md-12" style="text-align:center;" > 
                    <lightning:button label="Back" onclick="{!c.gobacktoPage}"/>
                </div>
            </div>
        </div>
    </div>
</aura:component>