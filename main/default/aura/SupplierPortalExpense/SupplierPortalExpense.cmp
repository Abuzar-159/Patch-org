<aura:component controller="SupplierPortalPO" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global">
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/SupplierPortalComm/CSS/SupplierportalComm.css'}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require scripts="{!join(',',
                           $Resource.ProductListComm + '/ProductListComm/script/common_scripts.min.js',                           
                           $Resource.ProductListComm + '/ProductListComm/script/main.js',
                           $Resource.ProductListComm + '/ProductListComm/script/carousel_with_thumbs.js'
                           )}"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierPortalExpense.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="ExpenseList" type="Expense__c[]"/>
    <aura:attribute name="ExpenseListDup" type="Expense__c[]"/>
    <aura:attribute name="SelectedPOS" type="List"/>
    <aura:attribute name="PNS" type="Object"/>
    <aura:attribute Name="searchStr" type="String"/>
    <aura:attribute name="expenseTab" type="Boolean" default="true"/>
    <aura:attribute name="OrderBy" type="String" default="Name"/> 
    <aura:attribute name="Order" type="String" default="DESC"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUserRecord}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUser}"/>
    <aura:handler name="SortRecord" event="c:SortRecord" action="{!c.SortRecodEventHandler}"/>
    <aura:attribute name="NoSlotsMessage" type="String"/>
    <aura:attribute name="selectedTab" type="String" default="Vendor"/>
    <aura:attribute name="SearchString" type="String" default=""/>
    <aura:attribute name="show" type="Integer" default="10"/>
    <aura:attribute name="startCount" type="Integer" default="0"/>
    <aura:attribute name="endCount" type="Integer" default="0"/>
    <aura:attribute name="Offset" type="Integer" default="0"/>
    <aura:attribute name="recSize" type="Integer" default="0"/>
    <aura:attribute name="PageNum" type="Integer" default="0"/>
    <aura:attribute name="revert" type="Boolean" default="true"/>
    <aura:method name="doInit" action="{!c.doInit}"/>
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:handler event="c:SupplierPortalCommEvent" action="{!c.doInit}"/>
    <aura:handler event="force:navigateToSObject" action="{!c.navigate}"/> 
    
    <aura:attribute name="CheckOffset" type="Boolean" default="false"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    
    <div aura:id="sldshide"> 
        <div class="maqsood erp_Mark7 erp_mark7 SupplierPE_class1" aura:Id="body">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="spinner" class="slds-hide"/>
            
            <div>
                <div class="container-fluid SupplierPE_class2">
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPE_class3" onclick="{!c.getTimesheets}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-timer mb-0 SupplierPE_class4"></i>
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Timesheets</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPE_class5" onclick="{!c.getContracts}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-pencil-alt mb-0 SupplierPE_class6-1"></i>
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Contracts</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPE_class6" onclick="{!c.getPO}" href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-files mb-0 SupplierPE_class7"></i>
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Purchase Orders</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPE_class8" onclick="{!c.getWO}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-files mb-0 SupplierPE_class9"></i>
                                        
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Work Orders</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        
                    </div>
                    
                    <div class="card shadow-custom SupplierPE_class10">
                        <div class="card-body">  
                            <div class="card-body pb-0  pl-2 pt-2">
                                <div class="d-flex justify-content-between pb-2">
                                    <div class="breadcrumbs">
                                        
                                        <h6 class="card-title mb-1">
                                            <a class="SupplierPE_class11" onclick="{!c.home}" href="" >
                                                Home&nbsp;
                                            </a>
                                            >&nbsp;Expenses
                                        </h6>
                                    </div>
                                    
                                  
                                    <div>
                                        <a href="javascript:void(0);" target="_blank" onclick="{!c.createExpense}" class="SupplierPE_class12" data-aura-rendered-by="121:945;a"><i class="fa fa-plus SupplierPE_class13" aria-hidden="true" data-aura-rendered-by="122:945;a"></i> &nbsp;New Expense </a>
                                    </div>        
                                </div>
                                
                                <div class="container-fluid pl-0">
                                    <div class="col-md-3 pl-0">
                                       <c:SearchRecord searchString="{!v.SearchString}" Placeholder="Expense.." aura:id="Expense_Id"/>
                                    </div>
                                </div>
                                
                                
                            </div>
                            
                            <div class="table-responsive SupplierPE_class14" tabindex="1">
                                <table class="table">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            
                                            <th scope="col">
                                                <div class="slds-truncate2" title="expense"> NAME
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="Name" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                           
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                            
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Project">Project 
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__Project__r.Name" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                        
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Status">Status 
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__Status__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                    
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                       <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                           
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                               <th scope="col">
                                                <div class="slds-truncate2" title="Date">Date
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__Date__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                           
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                            
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Submitted Amount">Submitted Amount 
                                                    
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__Amount_Submitted__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                 
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                            
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Vat">Vat/Tax
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__VAT_Amount__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                     
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                            
                                                    </span>
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Claimed Amount">Claimed Amount
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="Name" id="ERP7__Amount__c" title="Descending Order" class="arrowColor">
                                                       <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                        
                                                    </span> 
                                                    <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                           
                                                    </span>
                                                </div>
                                            </th>
                                         
                                            <th class="slds-cell-shrink" scope="col"></th>
                                        </tr>
                                    </thead>
                                    <aura:if isTrue="{!not(greaterthan(v.ExpenseList.length, 0))}">
                                        <tr>
                                            <td colspan="8">
                                                <div class="no projects" >
                                                    <div class="slds-notify_container slds-is-relative">
                                                        <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                            <div>
                                                                <span class="slds-assistive-text">warning</span>
                                                                <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No PO">
                                                                    <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                </span>
                                                            </div>
                                                            <div class="slds-notify__content">
                                                                <h2 class="slds-text-heading_small SupplierPE_class15">Sorry, No Records Available.</h2>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        <aura:set attribute="else">
                                    <aura:iteration items="{!v.ExpenseList}" var="exp">
                                        
                                        <tr class="slds-hint-parent">
                                            <!--<td class="slds-cell-shrink" data-label="Select Row">
                                            <label class="slds-checkbox">
                                                <input type="checkbox" name="options" value="on" />
                                                <span class="slds-checkbox_faux"></span>
                                                <span class="slds-assistive-text">Select Row</span>
                                            </label>
                                        </td>-->
                                            
                                            <th scope="row" data-label="Expense Name">
                                                <div class="slds-truncate2" title="{!exp.Name}"><a href="javascript:void(0);"   data-record="{!exp.Id}" data-name="{!exp.Name}" onclick="{!c.getRecord}" target="_blank">{!exp.Name}</a></div>
                                            </th>
                                            
                                            <td data-label="Project Name">
                                                <div class="slds-truncate2" title="{!exp.ERP7__Project__r.Name}"><lightning:formattedText value="{!exp.ERP7__Project__r.Name}"/>
                                                    <!--<a href="javascript:void(0);"   data-record="{!exp.ERP7__Project__r.Id}" data-name="{!exp.ERP7__Project__r.Name}" onclick="{!c.getRecord}" target="_blank">{!exp.ERP7__Project__r.Name}</a>-->
                                                </div>
                                            </td>
                                            <td data-label="Status">
                                                <div class="slds-truncate2" title="{!exp.ERP7__Status__c}">{!exp.ERP7__Status__c}</div>
                                            </td>
                                             <td data-label="Date">
                                                <div class="slds-truncate2" title="{!exp.ERP7__Date__c}"><lightning:formattedText value="{!exp.ERP7__Date__c}"/></div>
                                            </td>
                                            <td data-label="Submitted Amount">
                                                <div class="slds-truncate2" title="{!exp.ERP7__Amount_Submitted__c	}"><lightning:formattedNumber style="currency" value="{!exp.ERP7__Amount_Submitted__c}"/></div>
                                                
                                            </td>
                                            <td data-label="Vat">
                                                <div class="slds-truncate2" title="{!exp.ERP7__VAT_Amount__c}"><lightning:formattedNumber style="currency" value="{!exp.ERP7__VAT_Amount__c}"/></div>
                                            </td>
                                            <td data-label="Claimed Amount">
                                                <div class="slds-truncate2" title="{!exp.ERP7__Amount__c}"><lightning:formattedNumber style="currency" value="{!exp.ERP7__Amount__c}"/></div>
                                            </td>
                                        </tr>
                                    </aura:iteration> 
                                        </aura:set>
                                    </aura:if>
                                </table>
                                <aura:if isTrue="{!(v.ExpenseList.length>0)}">
                                <aura:if isTrue="{!and(v.NoSlotsMessage!=undefined, v.NoSlotsMessage!='')}"><!--(v.NoSlotsMessage!=undefined, v.NoSlotsMessage!='')-->
                                    <div class="slds-notify_container slds-is-relative" aura:id="criteriaMsgId">
                                        <div class="slds-notify slds-notify_toast slds-theme_warning SupplierPE_class17" role="alert">
                                            <span class="slds-assistive-text">warning</span>
                                            <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                            <div class="slds-notify__content SupplierPE_class16">
                                                <h2 class="slds-text-heading_small SupplierPE_class18">
                                                    {!v.NoSlotsMessage}
                                                </h2>
                                            </div>
                                        </div>
                                    </div>     
                                </aura:if>
                                </aura:if>
                            </div>
                        </div>
                    </div>
                </div>
                
                <aura:if isTrue="{!v.showMmainSpin}">
                    <span class="SupplierPE_class19">
                        <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
                    </span>
                </aura:if> 
            </div>
            <aura:if isTrue="{!v.revert}">
                <div class="epr_Mark7">
                    <div class="row SupplierPE_class20">
                        <aura:if isTrue="{!v.ExpenseList.length>0}">
                            <div class="col-md-2" >
                                <div class="slds-grid" >
                                    <div class="slds-col SupplierPE_class22">
                                        Show&nbsp;&nbsp;
                                    </div>  
                                    <div class="slds-col SupplierPE_class21"> 
                                        <lightning:select class="slds-show_inline-block"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                            <option value="5">5</option>
                                            <option value="10">10</option>
                                            <option value="25">25</option>
                                            <option value="50">50</option>
                                        </lightning:select>
                                    </div>
                                </div>
                            </div>
                        </aura:if>
                        <aura:if isTrue="{!v.ExpenseList.length>0}">
                            
                            <div class="col-md-3 SupplierPE_class23">
                                Showing <span class="text-lightblue">{!v.startCount}-{!v.endCount}</span> of total <span class="text-lightblue"> {!v.recSize} </span> Records
                            </div>
                            
                        </aura:if> 
                        
                        <aura:if isTrue="{!v.ExpenseList.length>0}">
                            
                            <div class="col-md-3" >
                                <div class="pb-3 ">
                                    <nav aria-label="Page navigation example" >
                                        <ul class="pagination" >
                                            <li class="SupplierPE_class24">
                                                <a class="{!if(1 >= v.startCount,'SupplierPE_class25','SupplierPE_class26')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                            </li>
                                            <li class="SupplierPE_class24">
                                                <a class="{!if(1 >= v.startCount,'SupplierPE_class25','SupplierPE_class26')}"  onclick="{!c.Previous}"> Previous</a> <!-- -->
                                            </li>
                                            
                                            <li class="SupplierPE_class24">
                                                <a class="{!if(v.endCount == v.recSize,'SupplierPE_class25','SupplierPE_class26')}" onclick="{!c.Next}">Next </a> <!--  -->
                                            </li>
                                            <li class="SupplierPE_class24">
                                                <a class="{!if(v.endCount == v.recSize,'SupplierPE_class25','SupplierPE_class26')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                        </aura:if> 
                        <aura:if isTrue="{!v.ExpenseList.length>0}">
                            
                            <div class="col-md-3" >
                                <div class="mb-1" >
                                    <div class="slds-grid">
                                        <div class="slds-col SupplierPE_class23">
                                            Page 
                                        </div>
                                        <div class="slds-col">
                                            <lightning:input type="number" variant="label-hidden" aura:id="ik" value="{!v.PageNum}" oncommit="{!c.OfsetChange}" class="width100p"/> 
                                        </div>
                                        <div class="slds-col SupplierPE_class23"><span class="text-lightblue"> of &nbsp;&nbsp;{!v.PNS.length}</span>
                                        </div>
                                    </div>
                                </div>
                            </div> 
                        </aura:if>
                    </div>
                </div></aura:if>
            
        </div>
    </div>
    <!--Pagination End-->
</aura:component>