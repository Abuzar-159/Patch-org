<aura:component controller="ProductListComm" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductListComm.css"/>
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/bootstrap.custom.min.css', 
                          $Resource.ProductListComm + '/ProductListComm/css/custom.css',
                          $Resource.ProductListComm + '/ProductListComm/css/fonts_googleapis.css',
                          $Resource.ProductListComm + '/ProductListComm/css/listing.css',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css',
                          $Resource.ProductListComm + '/ProductListComm/css/product_page.css'
                          )}"/> 
    <!--<ltng:require scripts="{!join(',',
                           $Resource.ProductListComm + '/ProductListComm/script/common_scripts.min.js',                           
                           $Resource.ProductListComm + '/ProductListComm/script/main.js',
                           $Resource.ProductListComm + '/ProductListComm/script/carousel_with_thumbs.js'
                          )}"/>-->
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductListCommProductDetails.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <aura:attribute name="AccId" type="String"/>
    <aura:attribute name="ProductId" type="String"/>
    <aura:attribute name="prodDetail" type="Object"/>
    <aura:attribute name="attFile" type="Object"/>
    <aura:attribute name="conDocFile" type="Object"/>
    <aura:attribute name="relProd" type="Object[]"/>
    <!--========Product Configurator============-->
    <!--<aura:attribute Name="RId" type="String"/>
    <aura:attribute name="NewRouting" type="Object"/>
 <aura:attribute name="NewVersion" type="Object"/>
    <aura:attribute Name="RoutingConfigure" type="Boolean" default="true"/>
    <aura:attribute name="SelectedRouting" type="Object"/>
    <aura:attribute name="SelectedVersion" type="Object"/>
    <aura:attribute name="BOMS" type="Object"/>
 <aura:attribute name="BOMWrapperList" type="Object"/>
    <aura:attribute Name="errorMsg" type="String" default=""/>
    <aura:attribute Name="prodConfig" type="boolean" default="false"/>
    <aura:attribute Name="newVId" type="String"/>-->
    
    <!--<aura:attribute name="allConfProd" type="Object"/>
    <aura:attribute name="prodCon" type="boolean" default="false"/>
    <aura:attribute name="proName" type="String"/>-->
    <aura:attribute Name="prodConfig" type="boolean" default="false"/>
    <aura:attribute name="proOptions" type="Object"/>
    <aura:attribute name="optionRules" type="Object"/>
    <aura:attribute Name="newVId" type="String"/>
    <!--<aura:attribute name="allParentIds" type="String[]"/>-->
    <!--<aura:attribute name="proforConfig" type="String"/>-->
    <!--========/Product Configurator============-->
    
    <aura:attribute Name="openConModal" type="boolean" default="true"/>
    
    <aura:registerEvent name="ProductListCommEvent" type="c:ProductListCommEvent"/>
    <aura:registerEvent name="ProductListCommEventBody1" type="c:ProductListComm_BodyToHeader"/>
    <aura:handler name="init" value="{!this}" action="{!c.initial}"/>
    <div class="erp_mark7">
        <div class="main">
            <div class="container margin_20">
                <!--<div class="countdown_inner">-20% This offer ends in <div data-countdown="2019/05/15" class="countdown"></div>-->
            </div>
            <div class="row m-0">
                <!--============================-->
                <div class="{!if((v.conDocFile.length > 0),'ProductListCPD-newClass2 col-md-6 pt-3','slds-carousel__content col-md-6 pt-3')}">
                    <lightning:carousel disableAutoRefresh="false" disableAutoScroll="false">
                        <aura:if isTrue="{!v.conDocFile.length > 0 }">                        
                            <aura:iteration items="{!v.conDocFile}" var="conFile">
                                <lightning:carouselImage
                                                         src = "{!'https://'+$Label.c.Host_PathCustomerPortal+'/sfc/servlet.shepherd/document/download/'+conFile.ContentDocumentId}" >                            
                                </lightning:carouselImage>
                            </aura:iteration>                   
                        </aura:if>                    
                    </lightning:carousel>
                </div>
                <div class="{!if((v.conDocFile.length == 0),'col-md-6 pt-3 ProductListCPD-newClass2','col-md-6 pt-3 slds-carousel__content')}">
                    <lightning:carousel disableAutoRefresh="false" disableAutoScroll="false">
                        <aura:if isTrue="{!v.conDocFile.length == 0 }">
                            <lightning:carouselImage
                                                     src = "../resource/ERP7__ProductListComm/ProductListComm/img/products/shoes/6.jpg" >                            
                            </lightning:carouselImage>   
                        </aura:if>                    
                    </lightning:carousel>
                </div>
                <!--<div class="col-md-6">
                    <div class="all"> 
                        <div class="slider">
                            <div class="owl-carousel owl-theme main">                               
                                <aura:iteration items="{!v.attFile}" var="att"> 
                                    <img src="{!'https://'+$Label.c.Host_PathCustomerPortal+'/servlet/servlet.FileDownload?file='+att.Id}" class="item-box"/>                                   
                                </aura:iteration>                                
                            </div>
                            <div class="left nonl"><i class="ti-angle-left"></i></div>
                            <div class="right"><i class="ti-angle-right"></i></div>
                        </div>
                        <div class="slider-two">
                            <div class="owl-carousel owl-theme thumbs">                                
                                <aura:iteration items="{!v.attFile}" var="att">
                                    <img src="{!'https://'+$Label.c.Host_PathCustomerPortal+'/servlet/servlet.FileDownload?file='+att.Id}" class="item active"/>                                    
                                </aura:iteration>	                            
                            </div>
                            <div class="left-t nonl-t"></div>
                            <div class="right-t"></div>
                        </div>
                    </div>
                </div>-->
                <!--============================-->
                <div class="col-md-6 pt-3">
                    <div class="breadcrumbs">
                        <ul>
                            <li><a onclick="{!c.home}">Home</a></li>
                            <li><a onclick="{!c.home}">Category</a></li>
                            <!--<li><a href="#">Category</a></li>
                         <li>Page active</li>-->
                        </ul>
                    </div>
                    <!-- /page_header -->
                    <div class="prod_info">
                        <aura:iteration items="{!v.prodDetail}" var="pd">
                            <h1>{!pd.pbe.Product2.Name}</h1> 
                            <!--<span class="rating"><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star"></i><em>4 reviews</em></span>-->
                            <p><small>SKU: {!pd.pbe.Product2.ERP7__SKU__c}&nbsp;&nbsp;&nbsp;{!pd.pbe.Product2.Description}</small></p>
                            <div class="prod_options"> 
                                
                                
                                <aura:if isTrue="{!pd.pbe.Product2.ERP7__Configure__c}">
                                    <div class="row">                      
                                        <aura:iteration var="po" items="{!v.proOptions}">                                           
                                            <div class="row m-0 mb-2 ProductListCPD-newClass3">
                                                <div class="col-md-4">
                                                    <aura:if isTrue="{!(po.feature.Name != undefined)}">
                                                        <label class="pt-0"><strong>{!po.feature.Name} </strong> </label>
                                                       
                                                    </aura:if>
                                                </div>
                                                <aura:if isTrue="{!po.featOpt.length > 0}">
                                                    <aura:iteration items="{!po.featOpt}" var="fo">
                                                        <div class="col-md-8">
                                                            <div class="slds-grid">
                                                                <div class="slds-checkbox_button-group p-1 mr-2">                                                               
                                                                    <div class="slds-form-element__control" >
                                                                        <label class="slds-checkbox">
                                                                            <input type="checkbox" id="{!fo.Id}" onchange="{!c.handleChange}" data-value="{!fo.Id}" text="{!po.feature.Id}"/>
                                                                            <span class="slds-checkbox--faux"></span>
                                                                            <span class="slds-form-element__label text"></span>
                                                                        </label>
                                                                    </div>
                                                                    {!fo.ERP7__Optional_SKU__r.Name}
                                                                    
                                                                    <aura:if isTrue="{!(fo.ERP7__Optional_SKU__r.ERP7__Picture__c != undefined)}">
                                                                        <div>
                                                                            <img src="{!fo.ERP7__Optional_SKU__r.ERP7__Picture__c}" class="ProductListCPD-newClass1" title="" />
                                                                        </div>
                                                                    </aura:if>                                                               
                                                                </div>                                                              
                                                            </div>
                                                        </div>
                                                    </aura:iteration>
                                                   
                                                </aura:if>                                                
                                            </div>                                                                                     
                                        </aura:iteration>                                       
                                    </div>
                                </aura:if>
                                <!--========/Product Configurator============-->
                                <div class="row">
                                    <label class="col-xl-4 col-lg-4  col-md-6 col-6 pt-0"><strong>Availability</strong></label>
                                    <div class="col-xl-4 col-lg-5 col-md-6 col-6 colors"> 
                                        <aura:if isTrue="{!pd.stock == 0}">
                                            Not Available<!--error color(In red)--> 
                                            <aura:set attribute="else">
                                                In Stock <!--success color(In green)--> 
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                </div>
                                <!--=================Version=========================-->
                                <!--<div class="row">
                                    <label class="col-xl-5 col-lg-5  col-md-6 col-6 pt-0"><strong>Color</strong></label>
                                    <div class="col-xl-4 col-lg-5 col-md-6 col-6 colors">
                                        <ul>
                                            <li><a href="#0" class="color color_1 active"></a></li>
                                            <li><a href="#0" class="color color_2"></a></li>
                                            <li><a href="#0" class="color color_3"></a></li>
                                            <li><a href="#0" class="color color_4"></a></li>
                                        </ul>
                                    </div>
                                </div>-->
                                <!--=================Size=========================-->
                                <!--<div class="row">
                                    <label class="col-xl-5 col-lg-5 col-md-6 col-6"><strong>Size</strong> - Size Guide <a href="#0" data-toggle="modal" data-target="#size-modal"><i class="ti-help-alt"></i></a></label>
                                    <div class="col-xl-4 col-lg-5 col-md-6 col-6">
                                        <div class="custom-select-form">
                                            <select class="wide">
                                                <option value="">Small (S)</option>
                                                <option value="">M</option>
                                                <option value=" ">L</option>
                                                <option value=" ">XL</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>-->
                                <div class="row">
                                    <label class="col-xl-4 col-lg-4  col-md-6 col-6"><strong>Quantity</strong></label>
                                    <div class="col-xl-4 col-lg-5 col-md-6 col-6">
                                        <div class="numbers-row">
                                            <!--<input type="number" value="1" id="quantity_1" class="qty2" name="quantity_1"/>-->
                                            <lightning:input type="number" value="1" aura:id="quant"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-lg-5 col-md-6">
                                    <div class="price_main"><span class="new_price"><lightning:formattedNumber style="currency" value="{!pd.pbe.UnitPrice}"/></span><!--<span class="percentage">-20%</span> <span class="old_price">$160.00</span>--></div>
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <aura:if isTrue="{!pd.stock == 0}">
                                        <div class="btn_add_to_cart ProductListCPD-newClass4" onclick="{!c.addTocart1}"><a class="btn_1">Add to Cart</a></div>
                                        <aura:set attribute="else">
                                            <div class="btn_add_to_cart" onclick="{!c.addTocart1}"><a class="btn_1">Add to Cart</a></div>
                                        </aura:set>
                                    </aura:if>
                                </div>
                            </div>
                        </aura:iteration>
                        
                    </div>
                    <!-- /prod_info -->
                    
                    <!-- /product_actions -->
                </div>
            </div>
            <!-- /row -->
        </div>
        <!-- /container -->
        
        <div class="tabs_product">
            <div class="container">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a id="tab-A" href="#pane-A" class="nav-link active" data-toggle="tab" role="tab">Description</a>
                    </li>
                    <!--<li class="nav-item">
                     <a id="tab-B" href="#pane-B" class="nav-link" data-toggle="tab" role="tab">Reviews</a>
                 </li>-->
                </ul>
            </div>
        </div>
        <!-- /tabs_product -->
        <div class="tab_content_wrapper">
            <div class="container">
                <div class="tab-content" role="tablist">
                    <div id="pane-A" class="card tab-pane fade active show" role="tabpanel" aria-labelledby="tab-A">
                        <div class="card-header" role="tab" id="heading-A">
                            <h5 class="mb-0">
                                <a class="collapsed" data-toggle="collapse" href="#collapse-A" aria-expanded="false" aria-controls="collapse-A">
                                    Description 
                                </a>
                            </h5>
                        </div>
                        <div id="collapse-A" class="collapse" role="tabpanel" aria-labelledby="heading-A">
                            <div class="card-body">
                                <div class="row justify-content-between">
                                    <div class="col-lg-6">
                                        <h3>Details</h3>
                                        <aura:iteration items="{!v.prodDetail}" var="pd">
                                            <p>{!pd.pbe.Product2.Description}</p>
                                        </aura:iteration>
                                    </div>
                                    <!-- <div class="col-lg-5">
                                     <h3>Specifications</h3>
                                     <div class="table-responsive">
                                         <table class="table table-sm table-striped">
                                             <tbody>
                                                 <tr>
                                                     <td><strong>Color</strong></td>
                                                     <td>Blue, Purple</td>
                                                 </tr>
                                                 <tr>
                                                     <td><strong>Size</strong></td>
                                                     <td>150x100x100</td>
                                                 </tr>
                                                 <tr>
                                                     <td><strong>Weight</strong></td>
                                                     <td>0.6kg</td>
                                                 </tr>
                                                 <tr>
                                                     <td><strong>Manifacturer</strong></td>
                                                     <td>Manifacturer</td>
                                                 </tr>
                                             </tbody>
                                         </table>
                                     </div>
                                     
                                 </div>-->
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /TAB A -->
                    <!--<div id="pane-B" class="card tab-pane fade" role="tabpanel" aria-labelledby="tab-B">
                     <div class="card-header" role="tab" id="heading-B">
                         <h5 class="mb-0">
                             <a class="collapsed" data-toggle="collapse" href="#collapse-B" aria-expanded="false" aria-controls="collapse-B">
                                 Reviews
                             </a>
                         </h5>
                     </div>
                     <div id="collapse-B" class="collapse" role="tabpanel" aria-labelledby="heading-B">
                         <div class="card-body">
                             <div class="row justify-content-between">
                                 <div class="col-lg-6">
                                     <div class="review_content">
                                         <div class="clearfix add_bottom_10">
                                             <span class="rating"><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><em>5.0/5.0</em></span>
                                             <em>Published 54 minutes ago</em>
                                         </div>
                                         <h4>"Commpletely satisfied"</h4>
                                         <p>Eos tollit ancillae ea, lorem consulatu qui ne, eu eros eirmod scaevola sea. Et nec tantas accusamus salutatus, sit commodo veritus te, erat legere fabulas has ut. Rebum laudem cum ea, ius essent fuisset ut. Viderer petentium cu his.</p>
                                     </div>
                                 </div>
                                 <div class="col-lg-6">
                                     <div class="review_content">
                                         <div class="clearfix add_bottom_10">
                                             <span class="rating"><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star empty"></i><i class="icon-star empty"></i><em>4.0/5.0</em></span>
                                             <em>Published 1 day ago</em>
                                         </div>
                                         <h4>"Always the best"</h4>
                                         <p>Et nec tantas accusamus salutatus, sit commodo veritus te, erat legere fabulas has ut. Rebum laudem cum ea, ius essent fuisset ut. Viderer petentium cu his.</p>
                                     </div>
                                 </div>
                             </div>
                             
                             <div class="row justify-content-between">
                                 <div class="col-lg-6">
                                     <div class="review_content">
                                         <div class="clearfix add_bottom_10">
                                             <span class="rating"><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star empty"></i><em>4.5/5.0</em></span>
                                             <em>Published 3 days ago</em>
                                         </div>
                                         <h4>"Outstanding"</h4>
                                         <p>Eos tollit ancillae ea, lorem consulatu qui ne, eu eros eirmod scaevola sea. Et nec tantas accusamus salutatus, sit commodo veritus te, erat legere fabulas has ut. Rebum laudem cum ea, ius essent fuisset ut. Viderer petentium cu his.</p>
                                     </div>
                                 </div>
                                 <div class="col-lg-6">
                                     <div class="review_content">
                                         <div class="clearfix add_bottom_10">
                                             <span class="rating"><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><i class="icon-star"></i><em>5.0/5.0</em></span>
                                             <em>Published 4 days ago</em>
                                         </div>
                                         <h4>"Excellent"</h4>
                                         <p>Sit commodo veritus te, erat legere fabulas has ut. Rebum laudem cum ea, ius essent fuisset ut. Viderer petentium cu his.</p>
                                     </div>
                                 </div>
                             </div>
                             
                             <p class="text-right"><a href="leave-review.html" class="btn_1">Leave a review</a></p>
                         </div>
                        
                     </div>
                 </div>-->
                    <!-- /tab B -->
                </div>
                <!-- /tab-content -->
            </div>
            <!-- /container -->
        </div>
        <!-- /tab_content_wrapper -->
        
        <div class="container margin_60_35 erp_mark7">
            <aura:if isTrue="{!v.relProd.length > 0}">
                <div class="main_title">
                    <h2>Related</h2>
                    <span>Products</span>
                    <p>People also search for</p>
                </div></aura:if>
            <!--<div class="owl-carousel owl-theme products_carousel">-->
            <div class="row small-gutters">	 
                <aura:if isTrue="{!v.relProd.length > 0}">
                    
                    <aura:iteration items="{!v.relProd}" var="rel">  
                        <div class="col-6 col-md-3">
                            <div class="grid_item">
                                <aura:if isTrue="{!rel.stock == 0}">
                                    <span class="ribbon off">Out of stock</span>
                                    <aura:set attribute="else">
                                        <span class="ribbon new">New</span>
                                    </aura:set>
                                </aura:if>                            
                                <figure>
                                    <aura:If isTrue="{!(rel.ContentDoc.ContentDocumentId != undefined)}">
                                        <a onclick="{!c.detailPage}" data-value="{!rel.pbe.Product2.Id}">
                                            <img class="owl-lazy imgsizepd" src="{!'https://'+$Label.c.Host_PathCustomerPortal+'/sfc/servlet.shepherd/document/download/'+rel.ContentDoc.ContentDocumentId}" data-src="{!'https://'+$Label.c.Host_PathCustomerPortal+'/sfc/servlet.shepherd/document/download/'+rel.ContentDoc.ContentDocumentId}" alt=""/>
                                        </a>
                                        <aura:set attribute="else">
                                            <a onclick="{!c.detailPage}" data-value="{!rel.pbe.Product2.Id}">
                                            	<img class="img-fluid lazy" src="../resource/ERP7__ProductListComm/ProductListComm/img/products/shoes/6.jpg" data-src="../resource/ERP7__ProductListComm/ProductListComm/img/products/shoes/6.jpg" alt=""/>
                                            </a>
                                        </aura:set>
                                    </aura:If>
                                </figure>
                                <!--<div class="rating"><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star voted"></i><i class="icon-star"></i></div>-->
                                <a onclick="{!c.detailPage}" data-value="{!rel.pbe.Product2.Id}">
                                    <h3>{!rel.pbe.Product2.Name}</h3>
                                </a>
                                <div class="price_box">
                                    <span class="new_price"><lightning:formattedNumber style="currency" value="{!rel.pbe.UnitPrice}"/></span>
                                </div>
                                <ul>
                                    <aura:if isTrue="{!rel.stock == 0}">
                                        
                                        <aura:set attribute="else">
                                            <!--<li><a href="#0" class="tooltip-1" data-toggle="tooltip" data-placement="left" title="Add to favorites"><i class="ti-heart"></i><span>Add to favorites</span></a></li>
                                        <li><a href="#0" class="tooltip-1" data-toggle="tooltip" data-placement="left" title="Add to compare"><i class="ti-control-shuffle"></i><span>Add to compare</span></a></li>-->
                                            <li data-value="{!rel.pbe.Product2.Id}"  onclick="{!c.addToCart2}"><a class="tooltip-1" data-toggle="tooltip" data-placement="left" title="Add to cart"><i class="ti-shopping-cart"></i><span>Add to cart</span></a></li>
                                        </aura:set>
                                    </aura:if>
                                    
                                </ul>
                            </div>
                        </div> 
                    </aura:iteration>
                    
                    <!-- /grid_item -->	 
                </aura:if>
            </div>
            <!-- /item -->
            <!-- </div>-->
            <!-- /products_carousel -->
            
        </div>
    </div>
    <!-- /container -->
    <!--/feat-->
    
    <section aura:id="EditModal" role="dialog" tabindex="-1" aria-labelledby="EditModalHeading" aria-modal="true" aria-describedby="EditModalBody" class="slds-modal">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <lightning:buttonIcon class="slds-modal__close" alternativeText="Close" iconName="utility:close" onclick="{!c.no1}" variant="bare-inverse" size="large"></lightning:buttonIcon>
                <h2 id="EditModalHeading" class="slds-text-heading_medium slds-hyphenate">More configuration available</h2>
            </header>
            <div class="slds-modal__content slds-p-around_xx-small">               
                <div class="row justify-content-center">
				<div class="box_account shadow-sm ProductListCPD-newClass5">					
						Do you want to configure this product?
				</div>
		</div>
            </div>
            <footer class="slds-modal__footer">
                <div class="offset-md-2 col-md-8 text-center pl-3 pr-3 ProductListCPD-newClass6">
                    <input type="submit" onclick="{!c.yes}" value="yes" class="btn_1 half-width mr-2"/>
                    <input type="submit" value="No" onclick="{!c.no}" class="btn_1 gray half-width"/>
				</div>                
            </footer>
        </div>
    </section>  
    <div aura:id="EditModalBackdrop" class="slds-backdrop"></div>
</aura:component>