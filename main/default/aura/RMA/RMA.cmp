<aura:component controller="RMA" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction,lightning:actionOverride" access="global">
    <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js" afterScriptsLoaded="{!c.focusTOscan}"/>
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-ltng.css"/>     
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css" />
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__fontawesome5/fontawesome5/css/all.css" />
    <ltng:require styles="/resource/ERP7__TablesSort/TablesSort/css/dataTables.bootstrap.min.css" />
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/RMA.css"/>
    <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>  
    
    <aura:handler name="init" value="{!this}" action="{!c.doinit}"/>    
    <aura:handler name="change" value="{!v.RMA.ERP7__Account__c}" action="{!c.fetchCustomerInfo}"/> 
    <aura:handler name="change" value="{!v.RMA.ERP7__Order__c}" action="{!c.fetchCustomerInfo}"/> 
    <aura:method name="fetchCustomerInfo" action="{!c.fetchCustomerInfo}"></aura:method>
    <aura:handler name="change" value="{!v.RMA.ERP7__Invoice__c}" action="{!c.fetchRMALIByInvId}"/>
    <!--aura:handler name="change" value="{!v.scanValue}" action="{!c.searchSOli}"/-->
    <aura:handler name="change" value="{!v.RMA.ERP7__Address__c}" action="{!c.fetchAddress}"/>
    <!--aura:handler name="change" value="{!v.RMA.ERP7__Return_Contact__c}" action="{!c.dummy}"/-->
    <aura:handler name="change" value="{!v.RMA_lookup.Id}" action="{!c.fetchRMALI}"/>
    <aura:handler name="change" value="{!v.site.Id}" action="{!c.fetchSiteDetails}"/> 
    <aura:handler name="change" value="{!v.SiteAddressId}" action="{!c.fetchSiteAddress}"/>
    <aura:handler name="change" value="{!v.DistributeChannel.Id}" action="{!c.fetchSiteDetailsByDC}"/>    
    <aura:attribute name="exceptionError" type="String" default=""/>
    <aura:attribute name="qry" type="String"/>
    <aura:attribute name="RMA" type="MAP" access="Global" default="{Id:'',Name:'',ERP7__Authorize__c: false, ERP7__Status__c : '',
                                                                   ERP7__Distribution_Channel__c:'',ERP7__Site__c: '',ERP7__Address__c: '',
                                                                   ERP7__Channel__c: '',ERP7__SO__c: '',ERP7__Return_Contact__c:'',ERP7__Account__c:'',
                                                                   Name:'',ERP7__Frieght_Type__c:'',ERP7__Expected_Date__c: '',ERP7__Is_Closed__c : false,
                                                                   ERP7__Refund_Amount__c : '',ERP7__Invoice__c : '',ERP7__Special_Instructions__c : ''}"/>
    <aura:attribute name="RMA_lookup" type="MAP" default="{Id:'',Name:''}"/>
    <aura:attribute name="DistributeChannel"  type="sObject" default="{'Id':'','Name':''}"/>
    <aura:attribute name="savehide" type="Boolean" default='true'/>
    <aura:attribute name="expectedDate" type="Date"/>
    <aura:attribute name="RMALI" type="Object"/>
    <aura:attribute name="RMAId" type="String" access="Global"/>
    <aura:attribute name="SOId" type="String" access="Global"  default="" />
    <aura:attribute name="OrdId" type="String" access="Global"  default="" />
    <aura:attribute name="freightType" type="String"/>
    <aura:attribute name="RMAStatus" type="String"/>
    <aura:attribute name="site" type="MAP" default="{'Id':'','Name':''}"/>
    <aura:attribute name="Customer" type="MAP" default="{'Id':'','Name':''}"/>
    <aura:attribute name="ContactId" type="String"/>
    <aura:attribute name="Address" type="MAP" default="{'Id':'','Name':''}"/>
    <aura:attribute name="CustContact" type="MAP" default="{'Id':'','Name':''}"/>
    <aura:attribute name="AddressId" type="String"/>
    <aura:attribute name="SiteAddress" type="Object"/>
    <aura:attribute name="SiteAddressId" type="String" default=""/>
    <aura:attribute name="channelId" type="String" default=""/>
    <aura:attribute name="scanValue" type="String" default=''/>
    <aura:attribute name="CustomerAddress" type="Object"/>
    <aura:attribute name="CustomerContact" type="Object"/>
    <aura:attribute name="solis" type="Object[]"/>
    <aura:attribute name="unfilteredsolis" type="Object[]"/>
    <aura:attribute name="SelectRMALI" type="Object[]"/>
    <aura:attribute name="offSet" type="Integer" default='0'/>
    <aura:attribute name="refundTaxPer" type="Decimal" default="0.00"/>
    <aura:attribute name="shippingTaxPer" type="Decimal" default="0.00"/>
    <aura:attribute name="EditIndex" type="Decimal"/>
    <aura:attribute name="EditTaxPer" type="Decimal" default="0.00"/>
    <aura:attribute name="refundAmount" type="Decimal" default="0.00"/>
    <aura:attribute name="EditRMA" type="Boolean" default='true'/>
    <aura:attribute name="navigateToRecord" type="Boolean" default='false'/>
    <aura:attribute name="priorCloseValue" type="Boolean" default='false'/>
    <aura:attribute name="disableSave" type="Boolean" default='false'/>
    <aura:attribute name="errMsg" type="String" default="No Items Select"/>
    <aura:attribute name="searcherrMsg" type="String" default="No Items Found"/>
    <aura:attribute name="isDoneRendering" type="Boolean" default="false"/>
    <aura:attribute name="DelObj" type="Object"/> 
    <aura:attribute name="showbackBtn" type="Boolean" default="false"/>
    <aura:attribute name="crudValues" type="Map" default="{}" />
    <aura:attribute name="returnRMA" type="String"/>  
    <aura:attribute name="RerenderPanel" type="Boolean" default="true"/>
    <aura:attribute name="FrieghtTypeList" type="String[]" default=""/>
    <aura:attribute name="StatusList" type="String[]" default=""/>
    <aura:attribute name="RerenderContact" type="Boolean" default="true"/>
    <aura:attribute name="isSOAccess" type="Boolean" default="false"/>
    <aura:attribute name="isOrderAcc" type="Boolean" default="false"/>
    <aura:attribute name="InputSelectDynamicOptions" type="List"/>    
    <aura:attribute name="RMALIsearchtext" type="String" default=""/>
    <aura:attribute name="disaAddbutton" type="Boolean" default="false"/>
    <aura:attribute name="disaeditdelete" type="Boolean" default="false"/>
    <aura:attribute name="totalamt" type="Decimal" default="0.00"/>
    <aura:attribute name="totalamtli" type="Decimal" default="0.00"/>
    <aura:attribute name="totalamtWOtax" type="Decimal" default="0.00"/>
    <aura:handler name="change" value="{!v.totalamtli}" action="{!c.restockhandler}"/>
    <aura:attribute name="RMAObjectLabel" type="String" default="Return Goods Authorization (RGA)"/>
    <aura:attribute name="preventChanges" type="Boolean" default="false"/>
    <div class="erp_mark7 RMA-class1 bg-white" aura:id="sldshide">
        <lightning:spinner variant="brand" size="large" aura:id="spinner" class="slds-hide"/>
        <!--Error Message-->
        <aura:if isTrue="{!not(empty(v.exceptionError))}">
            <div class="slds-notify_container slds-is-absolute top15" >
                <div class="slds-notify slds-notify_toast slds-theme_error" role="status" >
                    <span class="slds-assistive-text">{!$Label.c.Error_UsersShiftMatch}</span>
                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:error" variant="inverse" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" size="x-small"/>
                    </span>
                    <div class="slds-notify__content">
                        <p class="slds-text-heading_x-small mb-0">
                            <lightning:formattedText value="{!v.exceptionError}"/>
                        </p>
                    </div>
                    <div class="slds-notify__close" >
                        <a onclick="{!c.closeError}" class="textdeccolor">
                            <lightning:icon iconName="utility:close" variant="inverse" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" size="x-small"/>
                        </a>
                    </div>
                </div>
            </div>
        </aura:if>
        <!--Error Message End-->
        <div class="slds-page-header">
            <div class="slds-grid">
                <div class="slds-col slds-has-flexi-truncate">
                    <div class="slds-media slds-no-space slds-grow">
                        <div class="slds-media__figure">
                            <lightning:icon iconName="standard:orders"  size="large"  /> 
                        </div>
                        <div class="slds-media__bod RMA-class2-1">
                            <p class="slds-text-title--caps slds-line-height--reset"></p>
                            <a href="" class="slds-context-bar__label-action RMA-class3 pointernone" title="Menu Item" >
                                <span class="">
                                    <h1 class="slds-page-header__title slds-truncate" title="Return Merchandise Authorisation">{!v.RMAObjectLabel}</h1>
                                </span>
                            </a>
                            <!-- <ERP7:CustomInputLookUp objectAPIName="ERP7__Return_Merchandise_Authorisation__c" IconName="standard:drafts" selectedRecord="{!v.RMA_lookup}" qry="{!if(empty(v.Customer.Id),'','AND ERP7__Account__c =\''+v.Customer.Id+'\'')}" aura:Id="RMA"/> -->
                            <aura:if isTrue="{!v.isSOAccess}">
                                <c:CustomInputLookUp objectAPIName="ERP7__Return_Merchandise_Authorisation__c" IconName="standard:drafts"
                                                        selectedRecordId="{!v.RMA_lookup.Id}" aura:Id="RMA"/>   <!-- qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__SO__r.ERP7__Is_Closed__c=true',' AND ERP7__SO__r.ERP7__Is_Closed__c=true AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\'')}" -->
                            </aura:if>
                            <aura:if isTrue="{!v.isOrderAcc}">
                                <c:CustomInputLookUp objectAPIName="ERP7__Return_Merchandise_Authorisation__c" IconName="standard:drafts"
                                                        selectedRecordId="{!v.RMA_lookup.Id}" aura:Id="RMA"/>   <!-- qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__Order__r.ERP7__Is_Closed__c=true',' AND ERP7__Order__r.ERP7__Is_Closed__c=true AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\'')}" -->
                            </aura:if>
                            
                            <!-- selectedRecordId="{!v.RMAId}" 
                             ' AND ERP7__SO__r.ERP7__Is_Closed__c=true AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\''
                              (if(empty(v.RMA.ERP7__Account__c),'','AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\'')  -->
                        </div>
                    </div> 
                </div>
                <div class="slds-col slds-no-flex slds-grid slds-align-top">
                    <div class="slds-grid" >
                        <div class="slds-col slds-m-right--xx-small">
                            <div class="RMA-class4">
                                <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Receiving_Center_RMA}<span class="redclass">*</span></label>
                                <c:CustomInputLookUp objectAPIName="ERP7__Distribution_Channel__c" IconName="custom:custom24" selectedRecordId="{!v.DistributeChannel.Id}"/>
                            </div>
                        </div>
                        <div class="slds-col">
                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                <div class="RMA-class4"> 
                                    <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Receiving_Site_RMA}<span class="redclass">*</span></label>
                                    <c:CustomInputLookUp objectAPIName="ERP7__Site__c" IconName="custom:custom32" selectedRecordId="{!v.site.Id}" dontshowList='true' hideRemove='true'/>
                                </div>
                            </div>
                        </div>
                    </div>      
                </div>
            </div>
        </div>
        <div class="epr_Mark7 " >
            <div class="row slds-p-top_small RMA-class6">
                <div class="col-md-3 col-xs-3">
                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                        <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.AddSubscription_Customer}<span class="redclass">*</span></label>
                        <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.RMA.ERP7__Account__c}"  qry="{!'AND ERP7__Account_Type__c =\'Customer\''}"/>
                    </div>
                </div> 
                <div class="col-md-3 col-xs-3">
                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                        <!-- <ERP7:CustomInputLookUp aura:id="InvoiceId" objectAPIName="ERP7__Invoice__c" IconName="custom:custom62" selectedRecordId="{!v.RMA.ERP7__Invoice__c}" label="Invoice" qry="{!if(empty(v.Customer.Id),'',' AND ERP7__Account__c  =\''+v.Customer.Id+'\'')}"/> -->
                        <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Invoice}<!--span class="redclass">*</span--></label>
                        <aura:if isTrue="{!v.isSOAccess}">
                            <c:CustomInputLookUp aura:id="InvoiceId" objectAPIName="ERP7__Invoice__c" selectedRecordId="{!v.RMA.ERP7__Invoice__c}" IconName="custom:custom62" qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__Order__c != null AND ERP7__Order__r.ERP7__Is_Closed__c=true ',' AND ERP7__Order__c != null AND ERP7__Order__r.ERP7__Is_Closed__c=true AND ERP7__Account__c  =\''+v.RMA.ERP7__Account__c+'\'')}"/>
                        </aura:if>
                        <aura:if isTrue="{!v.isOrderAcc}">
                            <c:CustomInputLookUp aura:id="InvoiceId1" objectAPIName="ERP7__Invoice__c" selectedRecordId="{!v.RMA.ERP7__Invoice__c}" IconName="custom:custom62" qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__Order_S__c != null AND ERP7__Order_S__r.ERP7__Is_Closed__c=true ',' AND ERP7__Order_S__c != null AND ERP7__Order_S__r.ERP7__Is_Closed__c=true AND ERP7__Account__c  =\''+v.RMA.ERP7__Account__c+'\'')}"/>
                        </aura:if>
                    </div>                               <!-- selectedRecordId="{!v.RMA.ERP7__Invoice__c}"   -->
                </div>
                <div class="col-md-3 col-xs-3">
                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                        <!-- <c:CustomInputLookUp aura:id="OrderId" objectAPIName="ERP7__Sales_Order__c" IconName="standard:orders" selectedRecordId="{!v.RMA.ERP7__SO__c}" label="SalesOrderConsole_Sales_Order" qry="{!if(empty(v.Customer.Id),'AND ERP7__Order_Status__c =\'Closed\'','AND ERP7__Order_Status__c =\'Closed\' AND ERP7__Account__c =\''+v.Customer.Id+'\'')}"/> -->
                        <aura:if isTrue="{!v.isSOAccess}">
                            <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Order_Console_Sales_Order}<!--span class="redclass">*</span--></label>
                            <c:CustomInputLookUp aura:id="OrderId" objectAPIName="ERP7__Sales_Order__c" IconName="standard:orders" selectedRecordId="{!v.RMA.ERP7__SO__c}" hideRemove='true' 
                                                    qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__Is_Closed__c=true',' AND ERP7__Is_Closed__c=true AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\'')}"/>       
                        </aura:if>
                        <aura:if isTrue="{!v.isOrderAcc}">
                            <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Order_RMA}<!--span class="redclass">*</span--></label>
                            <c:CustomInputLookUp aura:id="SOrderId" objectAPIName="Order" IconName="standard:orders" selectedRecordId="{!v.RMA.ERP7__Order__c}" 
                                                    qry="{!if(empty(v.RMA.ERP7__Account__c),' AND ERP7__Is_Closed__c=true',' AND ERP7__Is_Closed__c=true AND AccountId =\''+v.RMA.ERP7__Account__c+'\'')}"/>   
                        </aura:if>
                        
                    </div>
                    <!--  AND ERP7__Order__r.ERP7__Is_Closed__c=true   -->
                    
                    <!-- if(empty(v.RMA.ERP7__Account__c),'AND ERP7__Order_Status__c =\'Closed\'','AND ERP7__Order_Status__c =\'Closed\' AND ERP7__Account__c =\''+v.RMA.ERP7__Account__c+'\'')  -->
                </div>
                <div class="col-md-3 col-xs-3">
                    <label class="slds-form-element__label">{!$Label.c.Return_Location_RMA}</label><br/>
                    <!--<aura:if isTrue="{!not(empty(v.SiteAddressId))}">-->
                    {!v.SiteAddress.ERP7__Address_Line1__c }&nbsp;{!v.SiteAddress.ERP7__Address_Line2__c}<br/>
                    {!v.SiteAddress.ERP7__City__c}&nbsp;
                    {!v.SiteAddress.ERP7__State__c}&nbsp;{!v.SiteAddress.ERP7__Postal_Code__c}&nbsp;
                    {!v.SiteAddress.ERP7__Country__c}
                    <!-- </aura:if>-->
                </div>
            </div>
            <div class="row RMA-class12" id="swapper-first" >
                <div class="col-md-3">
                    <lightning:select label="{!$Label.c.Freight_Type_RMA}" aura:id="InputSelectFreight" value="{!v.RMA.ERP7__Frieght_Type__c}">
                        <aura:iteration items="{!v.FrieghtTypeList}" var="option">
                            <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.RMA.ERP7__Frieght_Type__c, option.value)}"/>
                        </aura:iteration>
                    </lightning:select>
                </div>
                <div class="col-md-3">
                    <div class="">
                        <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.DoPayment_Address}<span class="redclass"></span></label>
                        <!-- <ERP7:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.RMA.ERP7__Address__c}" label="" qry="{!if(empty(v.Customer.Id),'','AND ERP7__Customer__c  =\''+v.Customer.Id+'\'')}"/> -->
                        <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.RMA.ERP7__Address__c}" label="" qry="{!if(empty(v.RMA.ERP7__Account__c),'','AND ERP7__Customer__c  =\''+v.RMA.ERP7__Account__c+'\'')}"/>
                    </div>    
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <label  class="slds-form-element__label" for="input-unique-id">Contact<span class="redclass">*</span></label>
                        <!-- <ERP7:CustomInputLookUp objectAPIName="Contact" IconName="standard:contact" selectedRecord="{!v.CustContact}" label="" qry="{!if(empty(v.Customer.Id),'','AND AccountId =\''+v.Customer.Id+'\'')}"/> -->
                            <c:CustomInputLookUp objectAPIName="Contact" IconName="standard:contact" selectedRecordId="{!v.RMA.ERP7__Return_Contact__c}" qry="{!if(empty(v.RMA.ERP7__Account__c),' AND Email != null ',' AND Email != null AND AccountId =\''+v.RMA.ERP7__Account__c+'\'')}"
                                                    aura:id="CustContactId"/> <!-- {!v.RMA.ERP7__Return_Contact__c} selectedRecord="{!v.CustContact}"   -->
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="slds-form-element__label">{!$Label.c.From_Location_Customer_RMA}</label><br/>
                    <!-- <aura:if isTrue="{!not(empty(v.Address.Id))}"> -->
                    <aura:if isTrue="{!not(empty(v.RMA.ERP7__Address__c))}">
                        {!v.CustomerAddress.ERP7__Address_Line1__c}<br/>
                        {!v.CustomerAddress.ERP7__Address_Line2__c}&nbsp;{!v.CustomerAddress.ERP7__City__c}&nbsp;
                        {!v.CustomerAddress.ERP7__State__c}&nbsp;{!v.CustomerAddress.ERP7__Postal_Code__c}&nbsp;
                        {!v.CustomerAddress.ERP7__Country__c} &nbsp;
                    </aura:if> 
                </div> 
            </div>
            <div class="row RMA-class12">
                <div class="col-md-3">
                    <div class="">
                        <lightning:select label="{!$Label.c.CreateClubcard_Status}" aura:id="RMAStatus" value="{!v.RMA.ERP7__Status__c}" >
                            <aura:iteration items="{!v.StatusList}" var="option">
                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.RMA.ERP7__Status__c, option.value)}"/>
                            </aura:iteration>
                        </lightning:select>
                    </div>
                </div>
                <div class="col-md-3">
                    <fieldset class="slds-form-element">
                        <div class="slds-form-element__control">
                            <lightning:input type="date" aura:id="expectedDate" label="{!$Label.c.RMA_Expected_Date}" value="{!v.RMA.ERP7__Expected_Date__c}" />
                        </div>
                    </fieldset>
                </div>
                <div class="col-md-3">
                    <div class="slds-grid"> 
                        <div class="slds-col">
                            <div class="slds-form-element slds-m-top--small">
                                <div class="slds-form-element__control">
                                    <lightning:input type="checkbox" label="{!$Label.c.Authorize_RMA}" checked="{!v.RMA.ERP7__Authorize__c}" aura:id="Authorize"/>
                                </div>
                            </div>
                        </div>
                        <div class="slds-col">
                            <div class="slds-form-element slds-m-top--small">
                                <aura:If isTrue="{!v.crudValues.ERP7__Is_Closed__c}">
                                    <lightning:input type="checkbox" label="{!$Label.c.Is_Closed_RMA}" checked="{!v.RMA.ERP7__Is_Closed__c}" disabled="{!and(v.RMA.ERP7__Is_Closed__c,v.RMA.Id != undefined)}" aura:id="isClosed"/>
                                </aura:If>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-m-top--small">
                        <label class="slds-form-element__label" for="RefundAmount">{!$Label.c.Refund_Amount_RMA}:&nbsp;
                            <lightning:formattedNumber style="currency" value="{!v.RMA.ERP7__Refund_Amount__c}" aura:id="RefundAmount"  />
                        </label>
                    </div>   
                    <div class="slds-form-element">
                        <label class="slds-form-element__label">{!$Label.c.Total_Line_Item_Amount_RMA}:&nbsp;
                            <lightning:formattedNumber style="currency" value="{!v.totalamt}" />
                        </label>
                    </div>
                </div>
            </div>
            <div class="row RMA-class12">
                <div class="col-md-3">
                    <fieldset class="slds-form-element">
                        <div class="slds-form-element__control">
                            <lightning:textarea name="description" value="{!v.RMA.ERP7__Special_Instructions__c}" label="{!$Label.c.Add_Subscriptions_Special_Instructions}" placeholder="{!$Label.c.Enter_Description}" maxlength="32768" messageWhenTooLong="A maximum of 32768 characters are allowed."/>
                        </div>
                    </fieldset>
                </div>
            </div>
            <div class="row RMA-class12"><div class="col-md-12 bg-grey"><h1>{!$Label.c.ReStock_RMA}</h1></div></div>
            <div class="row RMA-class12">
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Restock_Fee_RMA}" value="{!v.RMA.ERP7__Restock_Fee__c}" formatter="currency" step="0.01" onchange="{!c.calculateRestockper}"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Restock_Percent_RMA}" value="{!v.RMA.ERP7__Restock_percentage__c}" onchange="{!c.calculateRestockfee}" step="0.01"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Tax_Amount}" value="{!v.RMA.ERP7__ReStock_Tax__c}" formatter="currency" step="0.01" onchange="{!c.calculateRestockTaxPercentage}"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Tax_Percent}" value="{!v.refundTaxPer}" onchange="{!c.calculateRestockTax}" step="0.01"/>
                    </div>
                </div>
            </div> 
            <div class="row RMA-class12"><div class="col-md-12 bg-grey"><h1>{!$Label.c.Shipping_RMA}</h1> </div></div>
            <div class="row RMA-class12">
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Cash_Payment_Amount}" value="{!v.RMA.ERP7__Shipping_Amount__c}" step="0.000001" onchange="{!c.totalamthandler}"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Tax_Amount}" value="{!v.RMA.ERP7__Shipping_Tax__c}" formatter="currency" step="0.01" onchange="{!c.calculateShippingTaxPercentage}"/>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="{!$Label.c.Tax_Percent}" value="{!v.shippingTaxPer}" onchange="{!c.calculateShippingTax}" step="0.01"/>
                    </div>
                </div>
                
                <div class="col-md-3 RMA-class13">
                    <aura:if isTrue="{!and(not(empty(v.RMA.Id)),v.RMA.Id != undefined)}"> 
                        <div class="maqdropdown">
                            <aura:if isTrue="{!not(empty(v.RMA.ERP7__Return_Contact__c))}"> 
                                <a class="slds-button slds-button--brand dropdown-toggle" href="{!'/apex/'+$Label.c.RMA_Doc+'?Id='+v.RMA.Id+'&amp;CustId='+v.RMA.ERP7__Return_Contact__c+'&amp;name='+v.RMA.ERP7__Invoice__r.Name}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                    <i class="fa fa-file-pdf-o" aria-hidden="true"></i> &nbsp;<div class="slds-truncate-rma" title="{!$Label.c.RMA_Document}">{!$Label.c.RMA_Document} </div><span class="caret"></span>
                                </a>
                                <aura:set attribute="else">
                                    <a class="slds-button slds-button--brand dropdown-toggle" onclick="{!c.showDocval}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                        <i class="fa fa-file-pdf-o" aria-hidden="true"></i> &nbsp;<div class="slds-truncate-rma" title="{!$Label.c.RMA_Document}">{!$Label.c.RMA_Document}</div> <span class="caret"></span>
                                    </a>
                                </aura:set>
                            </aura:if>
                            <aura:if isTrue="{!not(or(v.RMA.ERP7__Authorize__c,v.RMA.ERP7__Is_Closed__c))}">
                                <div class="maqdropdown-content">
                                    <a href="" onclick="{!c.createPackageRMA}">
                                        <span><i class="fa fa-truck" aria-hidden="true"></i> &nbsp;{!$Label.c.Return_Shipment}</span>
                                    </a>
                                </div>
                            </aura:if>
                        </div>
                    </aura:if>
                </div>
                
            </div>
            <table id="example" class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover RMA-class14" > 
                <thead>
                    <tr class="slds-text-heading--label">
                        <th class="" scope="col">                            
                            <lightning:button label="{!$Label.c.ContractConsole_ADD}" iconName="utility:add" onclick="{!c.showModal}" />
                        </th>                                    
                        <!--<th class="slds-is-sortable" scope="col">Name</th>-->
                        <th class="slds-is-sortable" scope="col">{!$Label.c.RMA_Asset}</th>
                        <!--<th class="slds-is-sortable" scope="col">Code</th>-->
                        <th >{!$Label.c.Serial_Lot_No_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.QTY_Return_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Sale_Price_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Tax_Unit_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Total_Price_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Reason_ManageLeave}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Acceptance_Type_RMA}</th>
                        <th class="slds-is-sortable" scope="col">{!$Label.c.CreateClubcard_Status}</th>   
                        <th class="slds-is-sortable" scope="col">{!$Label.c.Warranty_RMA}</th>
                        <th class="slds-is-sortable" scope="col">&nbsp;</th>
                    </tr>    
                </thead>  
                <tbody>
                    <aura:iteration items="{!v.SelectRMALI}" var="item" indexVar="index">
                        <tr id ="{!index}">
                            <th scope="row" data-label="Action" class="RMA-class16">
                                <div class="slds-grid">
                                    <aura:if isTrue="{!item.RMALI.Id != null}">
                                        <lightning:input type="checkbox" checked="true" disabled="true"/>
                                        <aura:set attribute="else">
                                            <lightning:input type="checkbox" checked="{!item.isfinalSelect}"/>
                                        </aura:set>
                                    </aura:if>
                                    <aura:if isTrue="{!v.disaeditdelete == false}">
                                        &nbsp;
                                        <img src="{!$Resource.SLDS0121 + '/assets/icons/action/edit_60_green.png'}" width="18" height="18" class="h18" title="Edit" data-recordId="{!item.RMALI.Id}" data-SoLIID="{!if(empty(item.RMALI.ERP7__SOLI__c),item.RMALI.ERP7__Ord_Item__c ,item.RMALI.ERP7__SOLI__c)}" onclick="{!c.showEditModal}" data-row-index="{!index}"/>
                                        &nbsp;
                                        <img src="{!$Resource.SLDS0121 + '/assets/icons/action/delete_60_red.png'}" width="18" height="18" class="h18" title="Delete" data-recordId="{!item.RMALI.Id}" data-SoLIID="{!if(empty(item.RMALI.ERP7__SOLI__c),item.RMALI.ERP7__Ord_Item__c ,item.RMALI.ERP7__SOLI__c)}" onclick="{!c.deleteRMALI}"/>
                                    </aura:if>
                                </div>
                            </th>
                            <!--<td data-label="Serial No">
                                <div class="slds-truncate2" title="">{!item.RMALI.Name}</div>
                            </td>-->
                            <td data-label="Product Code">
                                <!-- <aura:if isTrue="{!not(empty(item.RMALI.ERP7__Product__c))}">--><!--SOLI-->
                                <div class="slds-truncate2" title="">{!if(empty(item.SOLI.ERP7__Product__r.Name),item.OrdItem.Product2.Name,item.SOLI.ERP7__Product__r.Name)}<!--{!item.SOLI.ERP7__Product__r.Name}--></div>
                                <!-- </aura:if>    -->
                            </td>
                            <!--<td data-label="Product Code">-->
                            <!-- <aura:if isTrue="{!not(empty(item.RMALI.ERP7__Product__c))}">--><!--SOLI-->
                            <!--<div class="slds-truncate2" title="">{!item.SOLI.ERP7__Product__r.ProductCode}</div>-->
                            <!-- </aura:if>    -->  
                            <!--</td>-->
                            <td data-label="Serial/Batch">
                                <aura:if isTrue="{!not(empty(item.RMALI.ERP7__Serial_Number__c))}">
                                    <div class="slds-truncate2" title="">{!item.RMALI.ERP7__Serial_Number__r.ERP7__Serial_No__c}</div>
                                    <aura:set attribute="else">
                                        <aura:if isTrue="{!not(empty(item.RMALI.ERP7__Batch_Lot__c))}">
                                            <div class="slds-truncate2" title="">{!item.RMALI.ERP7__Batch_Lot__r.Name}</div>
                                        </aura:if>
                                    </aura:set>
                                </aura:if>
                            </td>
                            <td data-label="{!$Label.c.QTY_Return_RMA}">
                                <div class="slds-truncate2" title="">
                                    <lightning:formattedNumber value="{!item.returnQty}" style="decimal"/><!-- {!item.RMALI.ERP7__Quantity_Return__c} -->
                                </div>
                            </td>
                            <td data-label="Base Price">
                                <div class="slds-truncate2" title="">
                                    <lightning:formattedNumber style="currency" value="{!item.RMALI.ERP7__Sale_Price__c}"/>
                                </div> 
                            </td>
                            <td data-label="Tax Unit">
                                <div class="slds-truncate2" title="">
                                    <lightning:formattedNumber style="currency" value="{!item.RMALI.ERP7__Tax__c}"/>
                                </div> 
                            </td>
                            <td data-label="{!$Label.c.Total_Price_RMA}">
                                <div class="slds-truncate2" title="">
                                    <lightning:formattedNumber style="currency" value="{!item.RMALI.ERP7__Total_Deduction__c}"/>
                                </div>
                            </td>
                            <td data-label="Symptoms">
                                <div class="slds-truncate2" title="">{!item.reasonReason}</div><!-- {!item.RMALI.ERP7__Return_Reason__c} -->
                            </td>
                            <td data-label="{!$Label.c.Acceptance_Type_RMA}">
                                <div class="slds-truncate2" title="">{!item.accepType}</div><!-- {!item.RMALI.ERP7__Acceptance_Type__c} -->
                            </td>
                            <td data-label="Send to Company ">
                                <div class="slds-truncate2" title="">{!item.RMALI.ERP7__Return_Status__c}</div>
                            </td>
                            <td data-label="{!$Label.c.Warranty_RMA}">
                                <div class="slds-truncate2" title="">
                                    <aura:if isTrue="{!item.RMALI.ERP7__Is_Warranty_Exists__c}">
                                        <span class="slds-button--success">{!$Label.c.Yes_UserAvailabilities}</span>
                                        <aura:set attribute="else">
                                            <span class="slds-button--destructive">{!$Label.c.No}</span>
                                        </aura:set>
                                    </aura:if>
                                    <!--<button class="slds-button slds-button-destructive">No</button>-->
                                </div>
                            </td>
                            <td data-label="">
                                <div class="epr_Mark7 slds-no-flex RMA-class19" >
                                    <aura:if isTrue="false"> <!--{!and(v.RMA.Id != '',v.RMA.Id != undefined)}-->
                                        <aura:If isTrue="{!or(item.RMALI.Id !='', item.RMALI.Id !=undefined, item.RMALI.ERP7__Return_Merchandise_Authorisation__r.ERP7__Authorize__c, or(item.RMALI.ERP7__Product__r.ERP7__Issue_Purchase_Order__c, item.RMALI.ERP7__Product__r.ERP7__Issue_Work_Order__c))}">
                                            <div class="dropdown">
                                                <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" menuAlignment="right" iconSize="small" variant="border-filled" onselect="{! c.handlemenu }">
                                                    <lightning:menuItem value="{!item.RMALI.Id}" label="{!$Label.c.Create_PO_Return_to_Vendor}" title="PO"/>
                                                    <!--lightning:menuItem value="{!item.RMALI.Id}" label="Creat Work Order" title="WO"/-->
                                                </lightning:buttonMenu>
                                            </div>
                                        </aura:If>
                                    </aura:if>
                                </div>
                            </td>
                        </tr>
                    </aura:iteration>
                </tbody>    
            </table>
        </div>        
        <aura:if isTrue="{!or(and(not(v.savehide),empty(v.RMAId)),v.EditRMA)}">
            <div class="slds-text-align--center slds-p-around--medium RMA-class21" >                             
                <aura:if isTrue="{!true}"><!--empty(v.RMA.Id)? not(v.priorCloseValue):not(equals(v.priorCloseValue,v.RMA.ERP7__Is_Closed__c))-->
                    <lightning:button variant="neutral" aura:id="cancel" onclick="{!c.cancelRMA}" label="{!$Label.c.RequisitionToPurchaseOrder_Reset}"/>
                    <lightning:button class="brand" onclick="{!c.commitRMA}" label="{!$Label.c.ContractConsole_Save}"  variant="brand"/>
                </aura:if>
            </div>
        </aura:if>
    </div>
    <div class="erp_mark7 epr_Mark7">
        <div class="demo-only slds-hide slds-fade-in-open RMA-class22" aura:id="showModal">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open RMA-class23">
                <div class="modal-container slds-modal__container">
                    <header class="slds-modal__header ">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.hideModal}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />	 
                            <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Add_RMA_Line_Item_RMA}</h2>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" aura:id="modalcontent" scrollTop="" offsetHeight="" scrollHeight="" ><!--onscroll="{!c.updatetransform}"-->
                        <div class="slds-lookup" data-select="single" data-scope="single" data-typeahead="false">
                            <div class="slds-form-element slds-m-bottom_small">
                                <lightning:input type="search" value="{!v.RMALIsearchtext}" variant="label-hidden" maxlength="150" aura:id="searchInput" placeholder="{!$Label.c.Search_by_Product_or_Order}" onchange="{!c.doSearch}"/>
                            </div>
                        </div>
                        <div class="rma">  
                            <section class="">
                                <div class="container-fluid">
                                    <table id="example" class=" ">
                                        <thead aura:id="tableHead" >
                                            <tr class="slds-text-heading--label header">
                                                <th class="slds-cell-shrink" scope="col">&nbsp;</th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Product_Name_StockTake}
                                                    <div>{!$Label.c.Product_Name_StockTake}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Product_Code}
                                                    <div>{!$Label.c.Product_Code}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Serial_Batch_NO}
                                                    <div>{!$Label.c.Serial_Batch_NO}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Qty_Pick}
                                                    <div>{!$Label.c.Qty_Pick}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Acceptance_Type_RMA}
                                                    <div>{!$Label.c.Acceptance_Type_RMA}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Reason_ManageLeave}
                                                    <div>{!$Label.c.Reason_ManageLeave}</div>
                                                </th>
                                                <th class="slds-is-sortable" scope="col">{!$Label.c.Order}
                                                    <div>{!$Label.c.Order}</div>
                                                </th>   
                                            </tr>    
                                        </thead>
                                        <aura:if isTrue="{!v.RerenderPanel}">    
                                            <tbody>
                                                <tr class="{!if(empty(v.solis),'RMA-class24','RMA-class25')}" >
                                                    <td colspan="8" class="RMA-class26 bggrey">
                                                        <div class="slds-notify_container slds-is-relative">
                                                            <div class="slds-notify slds-notify_toast slds-theme_warning RMA-class27" role="alert" >
                                                                <span class="slds-assistive-text">{!$Label.c.warning_ManageLeave}</span>
                                                                <lightning:icon iconName="utility:warning" size="small" alternativeText="{!$Label.c.warning_ManageLeave}"/>
                                                                <div class="slds-notify__content RMA-class29">
                                                                    <h2 class="slds-text-heading_small RMA-class28">{!v.searcherrMsg}</h2>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <aura:iteration items="{!v.solis}" var="li">
                                                    <aura:if isTrue="{!v.isSOAccess}">
                                                        <tr>
                                                            <td data-label="CheckBox">
                                                                <lightning:input type="checkbox-button" value="{!li.SOLI.Id}" aura:id="checkbox" checked="{!li.isSelect}"/> <!--onchange ="{!c.changevalue}"-->
                                                            </td>
                                                            <td data-label="{!li.SOLI.ERP7__Product__r.Name}"  >
                                                                <div class="slds-truncate2" title="">{!li.SOLI.ERP7__Product__r.Name}</div>
                                                            </td>
                                                            <td data-label="Product Code "  >
                                                                <div class="slds-truncate2" title="">{!li.SOLI.ERP7__Product__r.ProductCode}</div>
                                                            </td>
                                                            <td data-label="Serial NO" align="left" >
                                                                <aura:if isTrue="{!not(empty(li.RMALI.ERP7__Serial_Number__r.ERP7__Serial_No__c))}">
                                                                    <div class="slds-truncate2" title="">{!li.RMALI.ERP7__Serial_Number__r.ERP7__Serial_No__c}</div>
                                                                    <aura:set attribute="else">
                                                                        <aura:if isTrue="{!not(empty(li.RMALI.ERP7__Batch_Lot__r.Name))}">
                                                                            <div class="slds-truncate2" title="">{!li.RMALI.ERP7__Batch_Lot__r.Name}</div>
                                                                        </aura:if>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </td>
                                                            <c:RMALI qty="{!li.returnQty}" max="{!li.RMALI.ERP7__Quantity_Return__c}"/>
                                                            
                                                            <td data-label="Quantity To Ret "  >
                                                                <div class="slds-truncate2 RMA-class30" title="">
                                                                    <lightning:select name="selectItem" label="" value="{!li.accepType}">
                                                                        <option value="Return">{!$Label.c.Return}</option>
                                                                        <option value="Repair">{!$Label.c.Repair}</option>
                                                                        <option value="Replacement">{!$Label.c.Replacement}</option>
                                                                    </lightning:select>
                                                                </div>
                                                            </td>
                                                            <td data-label="Reason" >
                                                                <div class="slds-truncate2" title="">
                                                                    <lightning:textarea  variant="label-hidden" aura:id="reason" maxlength="200" value="{!li.reasonReason}"/></div>
                                                            </td>
                                                            <td data-label="Order#">
                                                                <div class="slds-truncate2" title="">{!li.SOLI.ERP7__Sales_Order__r.Name}</div>
                                                            </td>
                                                        </tr>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.isOrderAcc}">
                                                        <tr>
                                                            <td data-label="CheckBox">
                                                                <lightning:input type="checkbox-button" checked="{!li.isSelect}" /> <!--value="{!li.OrdItem.Id}" onchange ="{!c.changevalue}"-->
                                                            </td>
                                                            <td data-label="{!li.OrdItem.Product2.Name}"  >
                                                                <div class="slds-truncate2" title="">{!li.OrdItem.Product2.Name}</div>
                                                            </td>
                                                            <td data-label="Product Code "  >
                                                                <div class="slds-truncate2" title="">{!li.OrdItem.Product2.ProductCode}</div>
                                                            </td>
                                                            <td data-label="Serial NO" align="left" >
                                                                <aura:if isTrue="{!not(empty(li.RMALI.ERP7__Serial_Number__r.ERP7__Serial_No__c))}">
                                                                    <div class="slds-truncate2" title="">{!li.RMALI.ERP7__Serial_Number__r.ERP7__Serial_No__c}</div>
                                                                    <aura:set attribute="else">
                                                                        <aura:if isTrue="{!not(empty(li.RMALI.ERP7__Batch_Lot__r.Name))}">
                                                                            <div class="slds-truncate2" title="">{!li.RMALI.ERP7__Batch_Lot__r.Name}</div>
                                                                        </aura:if>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </td>
                                                            <c:RMALI qty="{!li.returnQty}" max="{!li.RMALI.ERP7__Quantity_Return__c}"/>
                                                            
                                                            <td data-label="Quantity To Ret "  >
                                                                <div class="slds-truncate2 RMA-class30" title="">
                                                                    <lightning:select name="selectItem" label="" value="{!li.accepType}">
                                                                        <option value="Return">{!$Label.c.Return}</option>
                                                                        <option value="Repair">{!$Label.c.Repair}</option>
                                                                        <option value="Replacement">{!$Label.c.Replacement}</option>
                                                                    </lightning:select>
                                                                </div>
                                                            </td>
                                                            <td data-label="Reason" >
                                                                <div class="slds-truncate2" title="">
                                                                    <lightning:textarea  variant="label-hidden" aura:id="reason" value="{!li.reasonReason}" maxlength="200"/>
                                                                </div>
                                                            </td>
                                                            <td data-label="Order#">
                                                                <div class="slds-truncate2" title="">{!li.OrdItem.Order.Name}</div>
                                                            </td>
                                                        </tr>
                                                    </aura:if>
                                                </aura:iteration>
                                            </tbody>
                                        </aura:if>  
                                    </table>
                                </div>
                            </section> 
                        </div> 
                    </div>
                    <footer class="slds-modal__footer RMA-class26" >
                        <lightning:button variant="neutral" onclick="{!c.hideModal}" label="{!$Label.c.Cancel_ManageLeave}"/>
                        <lightning:button variant="brand" onclick="{!c.AddRMALI}" label="{!$Label.c.ContractConsole_ADD}"/>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div> 
        <div class="demo-only slds-hide slds-fade-in-open RMA-class22" aura:id="editModal">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <div class="slds-modal__header" >
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.hideEditModal}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />	
                            
                            <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate RMA-class31">{!$Label.c.Edit_Line_Item}</h2>
                    </div>
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <aura:if isTrue="{!not(v.RMALI == null)}">
                            <div class="slds-grid slds-wrap">
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <label class="slds-form-element__label" for="input-03">{!$Label.c.Name_ManageLeave}</label><br/>
                                        <lightning:formattedText value="{!v.RMALI.RMALI.Name}"/>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <!--value="{!v.RMALI.ERP7__Quantity_Return__c}"-->
                                        <lightning:input type="number" label="{!$Label.c.Return_QTY}" aura:id="editqty2ret" value="{!v.RMALI.returnQty}" onchange="{!c.QtyCheck}" disabled="{!not(empty(v.RMALI.ERP7__Serial_Number__c))}"/><!--maxlength="{!v.SOLI.ERP7__Quantity__c}"-->
                                    </div>
                                </div>
                                
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:select label="{!$Label.c.Acceptance_Type_RMA}" value="{!v.RMALI.accepType}" onchange="{!c.handleSelectChange}"> <!--value="{!v.RMALI.ERP7__Acceptance_Type__c}"-->
                                            <option value="Return">{!$Label.c.Return}</option>
                                            <option value="Repair">{!$Label.c.Repair}</option>
                                            <option value="Replacement">{!$Label.c.Replacement}</option>
                                        </lightning:select>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:select  aura:id="InputSelectDynamic" label="{!$Label.c.Return_Status}" value="{!v.RMALI.RMALI.ERP7__Return_Status__c}">
                                            <aura:iteration items="{!v.InputSelectDynamicOptions}" var="option">
                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.RMALI.RMALI.ERP7__Return_Status__c, option.value)}"/>
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </div>
                                
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:input type="number" label="{!$Label.c.Sale_Price_RMA}" disabled="true" aura:id="editqtyBasePrice" value="{!v.RMALI.RMALI.ERP7__Sale_Price__c}" onchange="{!c.QtyCheck}" formatter="currency" step="0.01"/>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:input type="number" label="{!$Label.c.Tax_percentage}" value="{!v.EditTaxPer}" onchange="{!c.updateEditTax}" formatter="currency" step="0.01"/>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:input type="number" label="{!$Label.c.Tax_price_Unit}" aura:id="rmalitax" value="{!v.RMALI.RMALI.ERP7__Tax__c}" onchange="{!c.QtyCheck}" formatter="currency" step="0.01"/>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:input type="number" label="{!$Label.c.Total_Tax_RMA}" value="{!(v.RMALI.RMALI.ERP7__Tax__c * v.RMALI.returnQty)}"  formatter="currency" step="0.01" disabled="true"/>
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:textarea label="{!$Label.c.Reason_ManageLeave}" aura:id="editreason" maxlength="200" value="{!v.RMALI.reasonReason}" /> <!--value="{!v.RMALI.ERP7__Return_Reason__c}" -->
                                    </div>
                                </div>
                                <div class="col-md-6 slds-p-top--xx-small">
                                    <div class="slds-form-element">        
                                        <lightning:input type="number" label="{!$Label.c.Total_Price_Inc_Tax}" disabled="true"  aura:id="editqtyTotalPrice" value="{!v.RMALI.RMALI.ERP7__Total_Deduction__c}" formatter="currency" step="0.01"/>
                                    </div>
                                </div>
                            </div>
                        </aura:if>
                    </div>
                    <footer class="slds-modal__footer RMA-class26" >
                        <lightning:button variant="neutral" onclick="{!c.hideEditModal}" label="{!$Label.c.Cancel_ManageLeave}"/>
                        <lightning:button variant="brand" onclick="{!c.saveRMALI}" label="{!$Label.c.ContractConsole_Save}"/>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
        <div class="demo-only slds-hide slds-fade-in-open RMA-class22" aura:id="deleteModal">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.hideDeletePopup}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" />	
                            <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate RMA-class32" >{!$Label.c.Delete_UserAvailabilities} {!v.DelObj.RMALI.Name}</h2>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <p class="RMA-class26">{!'Are you sure you want to delete this '+v.DelObj.RMALI.Name+'?'}</p>
                    </div>
                    <footer class="slds-modal__footer RMA-class26">
                        <lightning:button variant="neutral" onclick="{!c.hideDeletePopup}" label="{!$Label.c.Cancel_ManageLeave}"/>
                        <lightning:button variant="brand" onclick="{!c.DeleteRecordById}" label="{!$Label.c.Delete_UserAvailabilities}"/>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div> 
    </div>  
</aura:component>