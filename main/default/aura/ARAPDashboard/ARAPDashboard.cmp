<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <!-- Attribute to control the visibility of the iframe -->
    <aura:attribute name="isIframeVisible" type="Boolean" default="true"/>
    <aura:attribute name="fromAP" type="Boolean" default="false"/>
    <aura:attribute name="vfPageUrl" type="String" default="{!$Label.c.ARDashboard}"/>
    <aura:attribute name="vfPageUrlAP" type="String" default="{!$Label.c.APDashboard}"/>

    <!-- Toggle the iframe visibility based on the attribute -->
    <aura:if isTrue="{!v.isIframeVisible}">
        <aura:if isTrue="{!v.fromAP}">
            <div>
                <iframe src="{!v.vfPageUrlAP}" width="100%" height="700px" frameborder="0" scrolling="no"></iframe>
                <div class="slds-docked-form-footer">
                <lightning:button label="Close" onclick="{!c.closeIframe}" variant="neutral"/>
                </div>
            </div>
            <aura:set attribute="else">
                <div>
                    <iframe src="{!v.vfPageUrl}" width="100%" height="700px" frameborder="0" scrolling="no"></iframe>
                     <div class="slds-docked-form-footer">
                    <lightning:button label="Back" onclick="{!c.closeIframe}" variant="neutral"/>
                    </div>
                </div>
            </aura:set>
        </aura:if>
    </aura:if>
</aura:component>