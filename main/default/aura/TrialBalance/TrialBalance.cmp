                                                                )
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </td>
                                        </tr>        
                                    </aura:iteration> 
                                </tbody>
                                <tfoot class="newClass19">
                                    <tr class="slds-hint-parent">
                                        <td  data-label="" align="right" class="newClass20"><b>TOTAL</b></td>
                                        <td  data-label="" class="newClass20"></td>  
                                        <td  data-label="" class="newClass20"></td>
                                        <td data-label="" class="newClass20"><b>
                                            
                                            {!v.Instance.userIsoCode}&nbsp;<lightning:formattedNumber value="{!(v.Instance.totaldebit_cur_type.ERP7__Opening_Balance__c*v.Instance.currencyRate)}" class="decimal" maximumFractionDigits="2"/>
                                            </b> </td>
                                        <td  data-label="" class="newClass20"><b>
                                            
                                            {!v.Instance.userIsoCode}&nbsp;<lightning:formattedNumber value="{!(v.Instance.totalcredit_cur_type.ERP7__Opening_Balance__c*v.Instance.currencyRate)}" class="decimal" maximumFractionDigits="2"/>
                                            </b></td>
                                        <td></td>
