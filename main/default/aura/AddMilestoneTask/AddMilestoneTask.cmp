                                                                                <a data-target="#myModal" data-record="Add" class="AddMilestoneTask-newClass15" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                    <i class="fa fa-plus AddMilestoneTask-newClass18" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                    &nbsp;New
                                                                                </a>
                                                                                <aura:set attribute="else">
                                                                                    <a data-target="#myModal" onclick="{!c.navPR}" data-record="Add" class="AddMilestoneTask-newClass16" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                        <i class="fa fa-plus AddMilestoneTask-newClass17" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                        &nbsp;New
                                                                                    </a>
                                                                                </aura:set>
                                                                            </aura:if>
                                                                        </th>
                                                                        <th scope="col" data-aura-rendered-by="787:0">
                                                                            <div>Name
                                                                            </div>
                                                                        </th>
                                                                        <th scope="col" data-aura-rendered-by="790:0">
                                                                            <div >Channel
                                                                            </div>
                                                                        </th>
                                                                        <th scope="col" data-aura-rendered-by="793:0">
                                                                            <div >Distribution Channel
                                                                            </div>
                                                                        </th>
                                                                        <th scope="col" data-aura-rendered-by="796:0">
                                                                            <div>Requisition By
                                                                            </div>
                                                                        </th>
                                                                        <th scope="col" data-aura-rendered-by="805:0">
                                                                            <div>Status
                                                                            </div>
                                                                        </th>
                                                                    </tr>
                                                                </thead>
                                                                <aura:if isTrue="{!not(empty(v.purchaseRequisitions))}">
                                                                    <tbody data-aura-rendered-by="820:0">
                                                                        <aura:iteration items = "{!v.purchaseRequisitions}" var = "PR" indexVar="prIndex">
                                                                            <tr class="slds-hint-parent">
                                                                                <td class="text-center">
                                                                                    <lightning:formattedText value = "{!prIndex + 1 + '.'}"/>
                                                                                </td>
                                                                                <td data-label="" scope="row">
                                                                                    <div class="AddMilestoneTask-newClass19"><lightning:formattedText value="{!PR.Name}" onclick="{!c.NavPRRecord}" title="{!PR.Id}"/></div>
                                                                                </td>
                                                                                <td data-label="" scope="row">
                                                                                    <div class=""><lightning:formattedText value="{!PR.ERP7__Channel__r.Name}"/></div>
                                                                                </td>
                                                                                <td data-label="">
                                                                                    <div class=""><lightning:formattedText value="{!PR.ERP7__Distribution_Channel__r.Name}"/></div>
                                                                                </td>
                                                                                <td>
                                                                                    <div class=""><lightning:formattedText value="{!PR.ERP7__Requisitioned_By__r.Name}"/></div>
                                                                                </td>
                                                                                <td>
                                                                                    <div class=""><lightning:formattedText value="{!PR.ERP7__Status__c}"/></div>
                                                                                </td>
                                                                            </tr>
                                                                        </aura:iteration>
                                                                    </tbody>
                                                                </aura:if>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <aura:set attribute="else">
                                            	<aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Purchase Requisition'), v.ChatterTab)}">
                                                    <aura:if isTrue="{!not(equals(v.newTask.Id,null))}">
                                                        <forceChatter:publisher context="RECORD"  recordId="{!v.newTask.Id}"/>
                                                        <forceChatter:feed type="Record" feedDesign="DEFAULT" subjectId="{!v.newTask.Id}"/>
                                                    </aura:if>
                                                </aura:if>
                                            </aura:set>
                                        </aura:if>
                                        <!--tab PR end-->
                                    </div>
                                    
                                    
                                </aura:if>
                    </div>
                         </div>
                </div>
            </div>
            <div class="slds-docked-form-footer AddMilestoneTask-newClass22">
                <lightning:button label="Back" class="slds-button slds-button--neutral" onclick="{!c.goBack}"/> &nbsp;
                <lightning:button label="Save" variant="brand" class="slds-button slds-button--brand white" onclick="{!c.saveTask}"/>
            </div>
            
            
            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Transfer Order'), not(equals(v.newTask,null)))}">
                <div>
                    <section aura:id="NewTransferOrder" role="dialog" tabindex="-1" class="slds-modal slds-modal_small" aria-labelledby="contactModalHeading" aria-modal="true" aria-describedby="contactModalBody1">
                        <div class="slds-modal__container">
                            <header class="slds-modal__header">
                                <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closeTOModal}" variant="bare-inverse" size="large"/> 
                                <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate AddMilestoneTask-newClass24">Transfer Order</h2>
                            </header>
                            <div class="slds-grid slds-wrap AddMilestoneTask-newClass23">
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <label class="slds-form-element__label" for="unique-id-of-input">Name<span class="AddMilestoneTask-newClass11">*</span></label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="newTOName"  required="true"  value="{!v.newTransferOrder.Name}" placeholder = "Transfer Order Name.." />
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <lightning:select  aura:id="newTOType"  value="{!v.newTransferOrder.RecordTypeId}" label="Record Type">
                                            <aura:iteration items="{!v.newTOTypeOptions}" var="option">
                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.newTransferOrder.RecordTypeId, option.value)}"/>
                                            </aura:iteration>
                                        </lightning:select>
=                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="date" label="Requested Date" aura:id="newTORequestDate"  value="{!v.newTransferOrder.ERP7__Requested_Date__c}" />
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="date" label="Expected Date"  value="{!v.newTransferOrder.ERP7__Expected_Date__c	}"/>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOFchannel" objectAPIName="ERP7__Channel__c" required="true" label="From Channel" IconName="standard:product" placeholder="Search Channel .." selectedRecordId="{!v.newTransferOrder.ERP7__Channel__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOTchannel" objectAPIName="ERP7__Channel__c" required="true" label="To Channel" IconName="standard:product" placeholder="Search Channel.." selectedRecordId="{!v.newTransferOrder.ERP7__To_Channel__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOFsite" objectAPIName="ERP7__Site__c" label="From Site" IconName="standard:product" placeholder="Search Site.." selectedRecordId="{!v.newTransferOrder.ERP7__From_Site__c}"/>                           
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOTsite" objectAPIName="ERP7__Site__c" label="To Site" IconName="standard:product" placeholder="Search Site.." selectedRecordId="{!v.newTransferOrder.ERP7__To_Site__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOFDC" objectAPIName="ERP7__Distribution_Channel__c" label="From Distribution Channel" IconName="standard:product" placeholder="Search DC.." selectedRecordId="{!v.newTransferOrder.ERP7__Distribution_Channel__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOTDC" objectAPIName="ERP7__Distribution_Channel__c" label="To Distribution Channel" IconName="standard:product" placeholder="Search DC.." selectedRecordId="{!v.newTransferOrder.ERP7__To_Distribution_Channel__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOFaddress" objectAPIName="ERP7__Address__c" label="From Address" IconName="standard:product" placeholder="Search Address.." selectedRecordId="{!v.newTransferOrder.ERP7__From_Address__c}"/>                            
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp aura:id="newTOTaddress" objectAPIName="ERP7__Address__c" label="To Address" IconName="standard:product" placeholder="Search Address.." selectedRecordId="{!v.newTransferOrder.ERP7__To_Address__c}"/>                           
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <lightning:select  aura:id="newTOStatus"  value="{!v.newTransferOrder.ERP7__Status__c}" label="Status">
                                            <aura:iteration items="{!v.newTOStatusOptions}" var="option">
                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.newTransferOrder.ERP7__Status__c, option.value)}"/>
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="checkbox" label="Active" checked="{!v.newTransferOrder.ERP7__Active__c}"/>
                                    </div> 
                                </div>
                            </div>
                            <footer class="slds-modal__footer">
                                <lightning:button  label="Cancel" onclick="{!c.closeTOModal}" variant="neutral"/>
                                <lightning:button onclick="{!c.addTO}" label="Save" variant="brand"/>
                            </footer>
                        </div>
                    </section>
                    <div class="slds-backdrop" aura:id="NewTransferOrderBackdrop"></div>
                </div>
            </aura:if>
            
            
        </div>
    </body>
</aura:component>