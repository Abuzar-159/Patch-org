<aura:component implements="force:appHostable" controller="ManageProjects"> 
    <head>
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/csspw/bootstrap.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/AddMilestoneTask.css"/>
    </head>
    
    <aura:attribute name = "exceptionError" type = "String" default = ""/>
    <aura:attribute name = "isresetTask" type = "boolean" default = "false"/>
    <aura:attribute name = "taskM" type = "Actions_Tasks__c"/>
    <aura:attribute name = "manufacturingOrders" type = "Manufacturing_Order__c[]"/>
    <aura:attribute name = "workOrders" type = "WO__c[]"/>
    <aura:attribute name = "transferOrders" type = "Transfer_Order__c[]"/>
    <aura:attribute name = "newTransferOrder" type = "Transfer_Order__c" default="{'sObjectType':'ERP7__Transfer_Order__c'}"/>
    <aura:attribute name = "salesOrders" type = "Sales_Order__c[]"/>
    <aura:attribute name = "purchaseOrders" type = "PO__c[]"/>
    <aura:attribute name = "purchaseRequisitions" type = "Requisition__c[]"/>
    <aura:attribute name = "newTask" type = "Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c',}"/>
    <aura:attribute name = "mstResourceGroup" type = "String" default=""/>
    <aura:attribute name = "ChatterTab" type = "Boolean" default="false"/>
    <aura:attribute name = "projectId" type = "Id" />
    <aura:attribute name = "taskId" type = "Id"/>
    <aura:attribute name = "milestoneId" type = "Id"/>
    <aura:attribute name = "currentMilestones" type = "object"/>
    <aura:attribute name = "currentProject" type = "Project__c"/>
    
    <aura:handler name = "init" value = "{!this}" action = "{!c.doInit}"/>
    <aura:handler name = "change" value = "{!v.taskId}" action = "{!c.fetchTask}"/>
    
    <aura:attribute name="taskTypeOptions" type="List"/>
    <aura:attribute name="taskStatusOptions" type="List"/>
    <aura:attribute name="newTOTypeOptions" type="List"/>
    <aura:attribute name="newTOStatusOptions" type="List"/>
    
    
    <body aura:id="body">
        <div class="erp_mark7 AddMilestoneTask-newClass1">
            
            <span class="AddMilestoneTask-newClass2">
                <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading..." aura:id="mainSpin" class="mainSpinClass"/>
            </span>
            
            <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed AddMilestoneTask-newClass3','slds-notify_container slds-is-fixed AddMilestoneTask-newClass4')}">
                <div class="slds-notify slds-notify_toast slds-theme_error AddMilestoneTask-newClass5" role="status">
                    <span class="slds-assistive-text">error</span>
                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="Error!" title="Error" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_x-small AddMilestoneTask-newClass6">{!v.exceptionError}
                        </h2>
                    </div>
                    <div class="slds-notify__close AddMilestoneTask-newClass7">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />
                            <span class="slds-assistive-text">Close</span>
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="slds-page-header">
                <div class="slds-page-header__row">
                    <div class="slds-page-header__col-title">
                        <div class="slds-media">
                            <div class="slds-media__figure">
                                <span class="slds-icon_container slds-icon-standard-user">
                                    <lightning:icon iconName="standard:entity_milestone" size="large" alternativeText="entity_milestone!" title="entity_milestone" />
                                    
                                </span>
                            </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <div class="slds-truncate AddMilestoneTask-newClass8"><!--slds-page-header__title -->
                                                Task
                                            </div>
                                        </h1>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="maqsood erp_Mark7">
                <div class="container-fluid mt-2 AddMilestoneTask-newClass9">
                     <div class="container-fluid mt-3 pb-1">	 
                            <div class="card shadow-custom AddMilestoneTask-newClass10">
                    <div class="slds-grid slds-wrap">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <label class="slds-form-element__label" for="unique-id-of-input">Name<span class="AddMilestoneTask-newClass11">*</span></label>
                                <lightning:input type="text" variant="label-hidden"   required="true" value="{!v.newTask.Name}" maxlength="30" />
                            </div>
                        </div>
                        
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="date" label="Start Date" aura:id="taskStartdate" value="{!v.newTask.ERP7__Start_Date__c}"/> 
                            </div> 
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="date" label="End Date" aura:id="taskEnddate" value="{!v.newTask.ERP7__End_Date__c}"/> 
                            </div> 
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <label class="slds-form-element__label" for="form-element-01">Type<span class="AddMilestoneTask-newClass11">*</span></label>
                                <lightning:select aura:id = "taskType" disabled="{!v.newTask.Id}" variant="label-hidden" value="{!v.newTask.ERP7__Type__c}"  class="display-lable">
                                    <aura:iteration items="{!v.taskTypeOptions}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.newTask.ERP7__Type__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                                
                            </div> 
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <lightning:select aura:id = "taskStatus" value="{!v.newTask.ERP7__Status__c}" label="Status">
                                    <aura:iteration items="{!v.taskStatusOptions}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.newTask.ERP7__Status__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div> 
                        </div>
                        
                        <aura:if isTrue="{!not(v.isresetTask)}">
                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                <div class="slds-form-element__control">
                                    <c:CustomInputLookUp aura:id="taskMilestone" objectAPIName="ERP7__Milestone__c" required="true" label="Milestone" IconName="standard:product" placeholder="Search Milestone.." selectedRecordId="{!v.newTask.ERP7__Milestone__c}" qry="{!'AND ERP7__Project__c = \''+v.projectId+'\''}"/>
                                </div> 
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                <div class="slds-form-element__control">
                                    <c:CustomInputLookUp aura:id="taskOwner" objectAPIName="User" required="true" IconName="standard:user" selectedRecordId="{!v.newTask.ERP7__Owner__c}" label="Owner" /><!--qry="{!'AND ERP7__Resource_Group__c = \'v.mstResourceGroup\''}"-->
                                </div> 
                            </div>
                        </aura:if>
                    </div>
                    <!--<aura:if isTrue="{!not(equals(v.newTask.ERP7__Type__c, '-None-'))}">-->
                                <aura:if isTrue="{!not(equals(v.newTask.ERP7__Type__c, '--None--'))}">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between">
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Manufacturing Order'),not(empty(v.manufacturingOrders.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Manufacturing Orders</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Manufacturing Orders" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                    	<aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.manufacturingOrders))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Work Order'), not(empty(v.workOrders.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Work Orders</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Work Orders" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                        <aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.workOrders))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Transfer Order'), not(empty(v.transferOrders.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Transfer Orders</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Transfer Orders" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                        <aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.transferOrders))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Sales Order'), not(empty(v.salesOrders.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Sales Orders</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Sales Orders" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                        <aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.salesOrders))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Purchase Order'), not(empty(v.purchaseOrders.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Purchase Orders</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Purchase Orders" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                        <aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.purchaseOrders))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}" >
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Purchase Requisition'), not(empty(v.purchaseRequisitions.length,0)))}">
                                                <aura:if isTrue="{!v.ChatterTab}">
                                                    <h6 class="card-title">Chatter</h6>
                                                    <aura:set attribute="else">
                                                        <h6 class="card-title">Purchase Requisitions</h6>
                                                    </aura:set>
                                                </aura:if>
                                                <div>
                                                    <aura:if isTrue="{!v.ChatterTab}">
                                                        <a title="Purchase Requisitions" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.hideChatter}">
                                                            <i class="fa fa-file-text-o AddMilestoneTask-newClass13"></i>
                                                        </a>
                                                        <aura:set attribute="else">
                                                            <a title="Chatter" href="" class="mr-3 AddMilestoneTask-newClass12" onclick = "{!c.showChatter}">
                                                                <i class="fa fa-comments-o AddMilestoneTask-newClass13"></i>
                                                            </a>
                                                            <aura:if isTrue="{!not(empty(v.purchaseRequisitions))}">
                                                                <a title="Refresh" href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                                    <i class="fa fa-refresh"></i>
                                                                </a>
                                                            </aura:if>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </aura:if>
                                            <aura:if isTrue="{!equals(v.newTask.ERP7__Type__c, 'Regular')||equals(v.newTask.ERP7__Type__c, 'Issue')||equals(v.newTask.ERP7__Type__c, 'Story')||equals(v.newTask.ERP7__Type__c, 'Task')||equals(v.newTask.ERP7__Type__c, 'Health and Safety')||equals(v.newTask.ERP7__Type__c, 'Upgrade')||equals(v.newTask.ERP7__Type__c, 'Quality Control')}">
                                                <h6 class="card-title">Chatter</h6>
                                                <div>
                                                    <a href="" class="mr-3 AddMilestoneTask-newClass12" aura:id="refreshMilestone" onclick = "{!c.getTypeRelatedVal}">
                                                        <i class="fa fa-refresh"></i>
                                                    </a>
                                                </div>
                                            </aura:if>
                                        </div>
                                        <!-- Chatter -->
                                        <aura:if isTrue="{!equals(v.newTask.ERP7__Type__c, 'Regular')||equals(v.newTask.ERP7__Type__c, 'Issue')||equals(v.newTask.ERP7__Type__c, 'Story')||equals(v.newTask.ERP7__Type__c, 'Task')||equals(v.newTask.ERP7__Type__c, 'Health and Safety')||equals(v.newTask.ERP7__Type__c, 'Upgrade')||equals(v.newTask.ERP7__Type__c, 'Quality Control')}">
                                            <aura:if isTrue="{!not(equals(v.newTask.Id,null))}">
                                                <forceChatter:publisher context="RECORD"  recordId="{!v.newTask.Id}"/><!---->
                                                <forceChatter:feed type="Record" feedDesign="DEFAULT" subjectId="{!v.newTask.Id}"/>
                                            </aura:if>
                                        </aura:if>
                                        <!-- Chatter End -->
                                        <!--tab MO -->
                                        <aura:if isTrue="{!and(equals(v.newTask.ERP7__Type__c, 'Manufacturing Order'), not(v.ChatterTab))}">
                                            <div class="container-fluid mb-5 p-0" data-aura-rendered-by="782:0">
                                                <div class="table-responsive AddMilestoneTask-newClass14" tabindex="1">
                                                    <table class="table">
                                                        <thead data-aura-rendered-by="785:0">
                                                            <tr class="slds-text-title--caps" data-aura-rendered-by="786:0">
                                                                <th class="text-center">
                                                                    <aura:if isTrue="{!or(equals(v.newTask.Id, null),equals(v.newTask.Id, undefined))}">
                                                                        <a data-target="#myModal" data-record="Add" class="AddMilestoneTask-newClass15" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                            <i class="fa fa-plus AddMilestoneTask-newClass18" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                            &nbsp;New
                                                                        </a>
                                                                        <aura:set attribute="else">
                                                                            <a data-target="#myModal" onclick="{!c.navMO}" data-record="Add" class="AddMilestoneTask-newClass16" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                <i class="fa fa-plus AddMilestoneTask-newClass17" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                &nbsp;New
                                                                            </a>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="787:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="788:0">Name
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="790:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="791:0">Product
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="793:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="794:0">Version
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="796:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="797:0">Routing
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="805:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="806:0">Status
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="808:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="809:0">Progress
                                                                    </div>
                                                                </th>
                                                                <th scope="col" data-aura-rendered-by="817:0">
                                                                    <div class="slds-truncate2" title="" data-aura-rendered-by="818:0">Quantity
                                                                    </div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <aura:if isTrue="{!not(empty(v.manufacturingOrders))}">
                                                            <tbody data-aura-rendered-by="820:0">
                                                                <aura:iteration items = "{!v.manufacturingOrders}" var = "MO" indexVar="moIndex">
                                                                    <tr class="slds-hint-parent" data-aura-rendered-by="4281:1760;a">
                                                                        <td class="text-center">
                                                                            <lightning:formattedText value = "{!moIndex + 1 + '.'}"/>
                                                                        </td>
                                                                        <td data-label="" scope="row" data-aura-rendered-by="4282:1760;a">
                                                                            <div class="slds-truncate2 AddMilestoneTask-newClass19" data-aura-rendered-by="4283:1760;a"><lightning:formattedText value="{!MO.Name}" onclick="{!c.NavMORecord}" title="{!MO.Id}"/></div>
                                                                        </td>
                                                                        <td data-label="" scope="row" data-aura-rendered-by="4289:1760;a">
                                                                            <div class="slds-truncate2"><lightning:formattedText value="{!MO.ERP7__Product__r.Name}" onclick="{!c.NavRecord}" title="{!MO.ERP7__Product__c}"/></div>
                                                                        </td>
                                                                        <td data-label="" data-aura-rendered-by="4294:1760;a">
                                                                            <div class="slds-truncate2"><lightning:formattedText value="{!MO.ERP7__Version__r.Name}" onclick="{!c.NavRecord}" title="{!MO.ERP7__Version__c}"/></div>
                                                                        </td>
