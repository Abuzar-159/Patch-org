<aura:component controller="LeaveManagementLC" implements="force:appHostable">
    <ltng:require styles="/resource/ERP7__SLDS0122/assets/styles/salesforce-lightning-design-system.css" />
    <ltng:require styles="/resource/ERP7__SLDS0121/assets/styles/salesforce-lightning-design-system.min.css" />
    <ltng:require styles="/resource/ERP7__jQueries/jQueries/jquery-ui.css, /resource/ERP7__Accordions/Src/style.css" 
                  scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js" afterScriptsLoaded="{!c.datePicker}"/>
    <ltng:require styles="/resource/ERP7__SLDS0121/assets/styles/salesforce-lightning-design-system.css" />
    <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js"/>

    <aura:attribute name="Holidays" type="Leave_Entitlements_Holidays__c[]" />
    <aura:attribute name="newLeave" type="Leave_Request__c" />
    <aura:attribute name="Allowance" type="Employees__c[]" />
    <aura:attribute name="objNew" type="Employees__c" default="{'sobjectType':'Employees__c',  
                                                                     'Id':null}" />
    <aura:attribute name="date" type="String" default="" />
    <aura:attribute name="LeaveReqs" type="Leave_Request__c" default="{ 'sobjectType': 'Leave_Request__c',
                                                                            'Name': '',
                                                                            'ERP7__Leave_Start_Date__c': '',
                                                                            'ERP7__Leave_End_Date__c': '',
                                                                            'ERP7__Reason__c': '',
                                                                            'ERP7__Number_of_Days__c': '',
                                                                            'ERP7__Leave_Type__c': '',
                                                                            'ERP7__Approvers__c':''}" /> 
    <aura:attribute name="emp" type="Employees__c" default="{sobjectType : 'Employees__c'}" />
    <aura:attribute name="leaveType" type="String"/>
    <aura:attribute name="errorMessage" type="String"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="leaveOptions" type="List"/>
    
    <div class="slds-container--fluid" aura:id="sldshide">
        <div onmouseover="{!c.populateDate}">
            <fieldset class="slds-form--compound">
                <div class="form-element__group">
                    <div class="slds-form-element__row">
                        <label class="slds-form-element__control slds-size--1-of-2" for="input-01"><span class="slds-form-element__label">Leave Request Description</span>
                            <lightning:input type="text" value="{!v.LeaveReqs.Name}" required="true" aura:id="name" maxlength="30" />
                        </label>
                        <label class="slds-form-element__control slds-size--1-of-2" for="input-01"><span class="slds-form-element__label">Approver</span>
                            <c:inputLookup type="User" value="{!v.LeaveReqs.ERP7__Approvers__c}" className="slds-input" aura:id="appr"/>
                        </label>
                    </div>
                </div>
            </fieldset>
            <fieldset class="slds-form--compound">
                <div class="form-element__group">
                    <div class="slds-form-element__row">
                        <label class="slds-form-element__control slds-size--1-of-2" for="input-03">
                            <span class="slds-form-element__label">Start Date</span>
                            <input value="{!v.LeaveReqs.ERP7__Leave_Start_Date__c}" class="slds-input" aura:id="StrDate" type="text" />
                        </label>
                        <label class="slds-form-element__control slds-size--1-of-2" for="input-03">
                            <span class="slds-form-element__label">End Date</span>
                            <input value="{!v.LeaveReqs.ERP7__Leave_End_Date__c}" class="slds-input" aura:id="EndDate" type="text" />
                        </label>
                    </div>
                    <div class="slds-form-element__row">
                        <div class="slds-form-element__control slds-size--1-of-2 lr-class1">
                            <lightning:select  value="{!v.LeaveReqs.ERP7__Leave_Type__c}" aura:id="leave" label="Leave Type">
                                <aura:iteration items="{!v.leaveOptions}" var="option">
                                    <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.LeaveReqs.ERP7__Leave_Type__c, option.value)}"/>
                                </aura:iteration>
                            </lightning:select>
                        </div>
                        <label class="slds-form-element__control slds-size--1-of-2">
                            <span class="slds-form-element__label">Number Of Days Applied</span>
                            <lightning:input type="number" variant="label-hidden" class="display-lable"  value="{!v.LeaveReqs.ERP7__Number_of_Days__c}" aura:id="totalValue"/>
                            <lightning:formattedText value="{!v.errorMessage}" class="red"/>
                        </label>
                    </div>
                    <div class="slds-form-element__row">
                        <div class="slds-form-element slds-size--2-of-2">
                            <label class="slds-form-element__label" for="input-06">Reason</label>
                            <lightning:textarea value="{!v.LeaveReqs.ERP7__Reason__c}" maxlength="200" />
                        </div>
                    </div>
                </div>
            </fieldset>
            <div class="slds-grid slds-grid--align-end">
                
                <div class="slds-p-around--small">
                    <button class="slds-button slds-button--brand" type="button" onclick="{!c.Save}">Save</button>
                </div>
                <div class="slds-p-around--small">
                    <button class="slds-button slds-button--neutral" type="button" onclick="{!c.Submit}">Submit</button>
                </div>
                <div class="slds-p-around--small">
                    <button class="slds-button slds-button--neutral" type="button" onclick="{!c.Back}">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</aura:component>