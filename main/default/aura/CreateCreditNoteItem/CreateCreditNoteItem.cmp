<aura:component access='global' implements="force:appHostable" controller="CreateBill">
    <aura:attribute name="Item" type="Map" default="{ERP7__Product__r:{Id:'',Name:''},ERP7__Discount__c:0.00,ERP7__Tax_Amount__c:0.00,ERP7__Quantity__c:1,ERP7__Item_Type__c:'Item',ERP7__Total_Amount__c:0.00}"/>
    <aura:attribute name="index" type="Integer" />
    <aura:attribute name="deleteIndex" type="Integer" />
    <aura:attribute name="typeOpts" type="List" />
    <aura:attribute name="ExpenseTypeOpts" type="List" /> 
    <aura:attribute name="TotalPrice" type="Currency"/>
    <aura:attribute name="TDS_Amount" type="Currency" default="0.00"/>
    <aura:attribute name="Update_TDS_Amount" type="Currency"/>
    <aura:attribute name="Tax_Amount" type="Currency" default="0.00"/>
    <aura:attribute name="Other_Tax_Amount" type="Currency"/>
    <aura:attribute name="TDS_Rate" type="Currency"/>
    <aura:attribute name="Discount" type="Currency" default="0.00"/>
    <aura:attribute name="Tax" type="Currency"/>
    <aura:attribute name="hideRemove" type="Boolean"/>
    <aura:attribute name="disabledEditing" type="Boolean"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:method name="callValidate" action="{!c.validate}"/>
    <aura:attribute name="showExpenseAccount" type="Boolean"/>
    <aura:attribute name="RT" type="String"/>
    <aura:method name="UpdateTax" action="{!c.UpdateTax}"/>
    <aura:method name="UpdateTDS" action="{!c.UpdateTDS}"/>
    <aura:attribute name="Access" type="String"/>
    <aura:attribute name="TDSAccess" type="String"/>
    <aura:attribute name="Field_Display" type="Boolean"/>
    <aura:attribute name="TDS_Display" type="Boolean"/>
    <aura:attribute name="Discount_Display" type="Boolean"/>
    <aura:registerEvent name="RequisitionToPurchaseOrderEvent" type="c:RequisitionToPurchaseOrderEvent"/> 
    <aura:attribute name="fromPortal" type="Boolean" default="false" access="global"/>
    <aura:method name="updateTaxonQuantityChange" action="{!c.UpdateTax}"  />
     <aura:method name="updateACTaxAmountChange" action="{!c.updateACTaxAmount}"  />
    <aura:attribute name="orglineItems" type="List" default="[]"/>
    
    <aura:attribute name="AutoAccountAllocation" type="Boolean" default="false"/>
    <aura:attribute name="showAllocation" type="Boolean" default="false"/>
    <aura:attribute name="TotalAAPercentage" type="Decimal" default="0"/>
    <aura:attribute name="displayAccount" type="Boolean" default="true"/>
    <aura:attribute name="billItems" type="Object" default="[]"/>
    <aura:attribute name="coaId" type="String"/>
    <aura:attribute name="projId" type="String"/>
    <aura:attribute name="PoliCategoryList" type="List" /> 
    
    <tr>
        <td data-label="Action" class="createbillitem-class1" width="100" >
            <aura:if isTrue="{!!v.disabledEditing}">
            <a onclick="{!c.DeleteRecord}"> 
                <lightning:icon size="small" iconName="utility:delete" variant="error" alternativeText="{!$Label.c.Delete_UserAvailabilities}" title="{!$Label.c.Delete_UserAvailabilities}" onclick="{!c.DeleteRecord}" disabled="{!v.disabledEditing}"/>
            </a>
            </aura:if>
        </td>
        <aura:if isTrue="{!or(v.RT=='PO Bill',v.RT=='Advance to vendor')}">
            <td data-label="Account Name" >
                <c:CustomInputLookUp objectAPIName="product2" IconName="standard:product" selectedRecordId="{!v.Item.ERP7__Product__c}" aura:id="product" hideRemove="{#v.hideRemove}"/>
            </td>
        </aura:if> 
        <aura:if isTrue="{!v.RT=='Expense Bill'}">
            <td data-label="" width="20%">
                <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:product_item" selectedRecordId="{!v.Item.ERP7__Chart_Of_Account__c}"  aura:id="chartOfAccount"/>
            </td>
        </aura:if>
        <td data-label="">
            <lightning:input aura:id="currency" type="number"  value="{!v.Item.ERP7__Quantity__c}" onkeyup="{!c.updateTotalPrice}" step="0.0001" variant="label-hidden" disabled="{!v.disabledEditing}"/>
        </td> 
        <td data-label="">
            <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.Item.ERP7__Amount__c}" onchange="{!c.updateTotalPrice}"  variant="label-hidden" step="0.00001" disabled="{!v.disabledEditing}"/>
        </td>
        <aura:if isTrue="{!v.Discount_Display}">
            <td data-label="">
                <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.Item.ERP7__Discount__c}" onchange="{!c.UpdateDiscount}"  step="0.00000000000000000000000000000000001" variant="label-hidden" disabled="{!v.disabledEditing}"/>
            </td>
        </aura:if>
        <td data-label="">
            <lightning:input aura:id="currency"  formatter="percent" value="{!v.Item.ERP7__Tax_Rate__c}" onchange="{!c.UpdateTax}"  variant="label-hidden" step="0.00000000000000000000000000000000001" disabled="{!v.disabledEditing}"/>
        </td>
        <td data-label="">
            <lightning:input aura:id="currency" type="currency" value="{!v.Item.ERP7__Tax_Amount__c}" onchange="{!c.UpdateTaxPercentage2}" variant="label-hidden" step="0.00000000000000000000000000000000001" disabled="{!v.disabledEditing}"/>
        </td>
        <aura:if isTrue="{!v.Field_Display}">
            <td data-label="">
                <lightning:input aura:id="currency"  formatter="percent" value="{!v.Item.ERP7__Other_Tax_Rate__c}" onchange="{!c.UpdateTax}" step="0.00000000000000000000000000000000001"  variant="label-hidden" disabled="{!v.disabledEditing}"/>
            </td>
        </aura:if>
        <aura:if isTrue="{!v.Field_Display}">
            <td data-label="">
                <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.Other_Tax_Amount}" onchange="{!c.UpdateTaxPercentage1}" step="0.00000000000000000000000000000000001" variant="label-hidden" disabled="{!v.disabledEditing}"/>
            </td>
        </aura:if>
        <aura:if isTrue="{!or(v.RT=='PO Bill',v.RT=='Advance to vendor')}">
            <td data-label="">
                <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:product_item" selectedRecordId="{!v.Item.ERP7__Chart_Of_Account__c}"  aura:id="chartOfAccount"/>
            </td>
        </aura:if>
        <aura:if isTrue="{!v.TDS_Display}">
            <aura:if isTrue="{!v.RT=='Expense Bill'}">
                <td data-label="">
                    <lightning:input aura:id="currency"  formatter="percent" value="{!v.Item.ERP7__TDS_Rate__c}" onchange="{!c.UpdateTDS}" step="0.00000000000000000000000000000000001" variant="label-hidden"/>
                </td>
                <td data-label="">
                    <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.Update_TDS_Amount}" onchange="{!c.UpdateTaxPercentage}" step="0.00000000000000000000000000000000001" variant="label-hidden"/>
                </td>
            </aura:if>
            <aura:if isTrue="{!v.RT=='Expense Bill'}">
                <td data-label="">
                    <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:product_item" selectedRecordId="{!v.Item.ERP7__TDS_Account__c}"  aura:id="chartOfAccount" qry=" AND RecordType.DeveloperName = 'Liability' AND ERP7__Sub_Account_Type__c='TDS'"/>
                </td>
            </aura:if>
        </aura:if>
        <td data-label="TotalAmount">
            <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.Item.ERP7__Total_Amount__c}" disabled="true"/>
        </td>
        <td data-label="Description">
            <lightning:textarea aura:id="description" value="{!v.Item.ERP7__Description__c}" maxlength="100" class="width150" />
        </td>
        <aura:if isTrue="{!or(v.RT=='PO Bill',v.RT=='Advance to vendor')}">
            <aura:if isTrue="{!and(v.Item.ERP7__Total_Amount__c>0.00,v.showAllocation)}">
                <aura:if isTrue="{!(100 - v.TotalAAPercentage) > 0}">
                    <i class="fa fa-cogs createbill-class3 createbill-class4" title="Add Analytical Account" onclick="{!c.displayAccounts}"/>  
                    <aura:set attribute="else">
                        <i class="fa fa-cogs AAnotallowed createbill-class4" title="Add Analytical Account" />   
                    </aura:set>
                </aura:if>
            </aura:if>
        </aura:if>
    </tr>
    <aura:if isTrue="{!or(v.RT=='PO Bill',v.RT=='Advance to vendor')}">
        <aura:if isTrue="{!and(v.Item.ERP7__Product__c != '',v.Item.ERP7__Product__c != null)}">
            <aura:if isTrue="{!and(v.displayAccount, v.Item.Accounts.length>0)}">
                <tr>
                    <td colspan="10">
                        <div class="erp_Mark7">
                            <div class="row m-0">
                                <div class="col-md-2">
                                </div>
                                <div class="col-md-3">
                                    <lightning:select name="poStatus"  label="Account Category" aura:id="poStatus" value="{!v.Item.ERP7__Account_Category__c}" onchange="{!c.resetAA}">
                                        <aura:iteration items="{!v.PoliCategoryList}" var="item">
                                            <option text="{!item}" value="{!item}" selected="{!v.Item.ERP7__Account_Category__c == item}"/>
                                        </aura:iteration>
                                    </lightning:select> 
                                </div>
                                <div class="col-md-3">
                                    <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" selectedRecordId="{!v.Item.ERP7__Chart_Of_Account__c}"  IconName="standard:product" label="Accounting Account" placeholder="Search Account.." qry="{!'And ERP7__Account_Category__c = \''+v.Item.ERP7__Account_Category__c+'\''}"/>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
                <aura:iteration items="{!v.Item.Accounts}" var="pitem" indexVar="ind">
                    <tr>
                        <td colspan="10">
                            <div class="erp_Mark7">
                                <div class="row m-0">
                                    <div class="col-md-1">
                                    </div>
                                    <div class="col-md-1 text-right">
                                        <div >
                                            <lightning:buttonIcon alternativeText="{!$Label.c.Delete_UserAvailabilities}" onclick='{!c.deleteAnalyAcc}' iconName="utility:delete" variant="destructive" name="{!ind}" title="{!pitem.Id}" class="delete-icon" />
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="slds-grid">
                                            <div class="slds-col slds-size_1-of-1 slds-large-size_11-of-12">
                                                <lightning:input variant="label-hidden" placeholder="Analytical Account Percent" formatter="percent" aura:id="Taxrate" value="{!pitem.ERP7__Allocation_Percentage__c}"  step="{!$Label.c.DecimalplacesinPOScreen}" onchange="{!c.updateACTaxAmount}"/>
                                            </div>
                                            <div class="slds-col slds-size_1-of-1 slds-large-size_1-of-12 slds-p-top_xx-small">
                                                &nbsp;<lightning:icon iconName="utility:percent" size="xx-small"></lightning:icon>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <lightning:input type="number" placeholder="Analytical Account Amount"  variant="label-hidden" formatter="currency" value="{!pitem.ERP7__Allocation_Amount__c}"  aura:id="Taxamount" step="{!$Label.c.DecimalplacesinPOScreen}" onchange="{!c.updateACTaxPerentage}"/>
                                    </div>
                                    <!--aura:if isTrue="{!and(and(v.item.ERP7__Account_Category__c != undefined,v.item.ERP7__Account_Category__c != null),v.item.ERP7__Account_Category__c != '')}"-->
                                    <div class="col-md-3">
                                        <c:CustomInputLookUp objectAPIName="ERP7__Project__c" selectedRecordId="{!pitem.ERP7__Project__c}"  IconName="standard:product" aura:id="product" placeholder="Analytical Account" qry="{!'And ERP7__Account_Category__c = \''+v.Item.ERP7__Account_Category__c+'\''}"/>
                                    </div>
                                    <!--/aura:if-->
                                </div>
                            </div>
                        </td>
                    </tr>
                </aura:iteration>
            </aura:if>
        </aura:if>
    </aura:if>
</aura:component>