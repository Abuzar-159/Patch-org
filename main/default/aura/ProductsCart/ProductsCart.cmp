<aura:component controller="ProductList" implements="flexipage:availableForAllPageTypes,force:appHostable,forceCommunity:availableForAllPageTypes" access="Global">
    <aura:attribute name="accID" type="String" default="0011o00001Sq3Xm"/><!--default="0011o00001Sq3Xm" -->
    <aura:attribute name="profileID" type="String"  default="a381o000000gA1X"/><!--default="a381o000000gA1X"-->
    <!--<aura:attribute name="channelID" type="String" default="a2Q1o000001IcQ9" />-->
    <aura:attribute name="cartProducts" type="List" default=""/>
    <aura:attribute name="totalPrice" type="Decimal"/>
    <aura:Attribute name="couponIssued" type="List"/>
    <aura:Attribute name="CouponRedemption" type="List"/>
    <aura:attribute name="so" type="Object"/>
    <aura:attribute name="Spinner" type="boolean" default="false"/>
    <aura:attribute name="coupon" type="String"/>
    <!-- create 2 aura handler with waiting and donewaiting events--> 
    <aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/>
  <!--create a component attributs -->
    <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js, /resource/ProductList/script/jquery-ui.js, /resource/ERP7__bootStrap/js/bootstrap.min.js" />
    <ltng:require styles="/resource/ProductList/css/bootstrap.css, /resource/ProductList/css/font-awesome.css, /resource/ProductList/css/flaticon.css, /resource/ProductList/css/style.css, /resource/ProductList/css/color.css, /resource/ProductList/css/responsive.css" />
    <html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
     <title>Aqxolt ERP Product</title>
    
        
        </head>
    <body>
     
     <!--// Main Wrapper \\-->
     <div aura:id="sldshide">
     <div class="erpmark7">
     <div class="erpmark7-main-wrapper">

    <!--// Header \\-->

        <header id="erpmark7-header" class="erpmark7-header-one">
        <div class="erpmark7-main-header">
            <div class="container">
                <div class="row">
                    <aside class="col-md-3">
                        <a href="#" class="erpmark7-simple-btn erpmark7-bgcolor" onclick="{!c.back}"><i class="fa fa-chevron-left"></i> Back    </a>
                    </aside>
<aside class="col-md-3">                        
                        <a href="#" class=""><i class="fa fa-shopping-cart"></i>&nbsp;CART DETAILS  </a>
                    </aside>
                </div>
            </div>
        </div>
    </header>

    <!--// Header \\-->

    

    <!--// Main Content \\-->
    <div class="erpmark7-main-content">

        <!--// Main Section \\-->
        <div class="container">
            <h5 class="ProductCart-newClass1">Draft Order</h5>
         <table class="table table-bordered">
              <tr>
                <td>&nbsp;</td>
                <td class="label1">SKU</td>
                <td class="label1">NAME</td>
                <td class="label1">PRICE</td>
                <td class="label1">QUANTITY</td>
                <td class="label1">TOTAL</td>
                <td>&nbsp;</td>
              </tr>
             <aura:if isTrue="{!v.Spinner}">
                <div aura:id="spinnerId" class="slds-spinner_container">
                   <div class="slds-spinner--brand  slds-spinner slds-spinner--large slds-is-relative" role="alert">
                     <span class="slds-assistive-text">Loading</span>
                     <div class="slds-spinner__dot-a"></div>
                     <div class="slds-spinner__dot-b"></div>
                   </div>
                </div>
             </aura:if>
         <!-- Loading spinner end-->
             <aura:iteration items="{!v.cartProducts}" var="cp">
              <tr bgcolor="#f3f3f3">
                <td><i class="fa fa-camera"></i></td>
                <td>{!cp.pbe.Product2.ERP7__SKU__c}</td>
                <td>{!cp.pbe.Product2.Name}</td>
                  <td><lightning:formattedNumber style="currency" value="{!cp.pbe.UnitPrice}"/></td>
                  <td>
                  <lightning:formattedText value="{!cp.pbe.Product2.ERP7__MOQ__c}" aura:id="qty" />
                  </td>
                <td><lightning:formattedNumber style="currency" value="{!cp.pbe.UnitPrice * cp.pbe.Product2.ERP7__MOQ__c}"/></td>
                <td><a onclick="{!c.deleteSoli}"><i class="fa fa-close"></i></a></td>
              </tr>
              </aura:iteration>
          </table>

            <table class="table">
              <tr>
                <td width="83%" class="label1">&nbsp;</td>
                
                <td width="7%" class="label1">TOTAL</td>
                <td><lightning:formattedNumber style="currency" value="{!v.totalPrice}"/></td>
              </tr>
        </table>
            
            <div class="ProductCart-newClass2">
                <div class="container-fluid">
                    <div class="row">
                    <div class="col-md-6">
                <div class="row ProductCart-newClass3">
                    <div class="col-md-4 slds-m-bottom--x-small slds-m-top--x-small">
                        <h3 class="ProductCart-newClass5"><strong>Coupon Codes</strong></h3>
                     </div>
                    <div class="col-md-5 slds-m-bottom--x-small">
                        <lightning:input type="text" variant="label-hidden" aura:id="coupon" class="fifty" value="{!v.coupon}"/>
                    </div>
                    <div class="col-md-3 slds-m-bottom--x-small">
                        <button type="button" class="erpmark7-simple-btn erpmark7-bgcolor" onclick="{!c.ApplyCoupon}"> Apply</button>
                    </div>
                </div>
                </div>
                <div class="col-md-6">  
                <table class="slds-table slds-table--bordered">
                    <tr class="slds-text-heading--label">
                        <th class="label1">NAME</th>
                        <th class="label1">COUPON</th>
                        <th class="label1">APPLIED DATE</th>
                        <th class="label1">AMOUNT</th>
                        <th></th>
                    </tr>
                </table>
                </div>  
                </div>
               </div>     
            </div>   
        
        <div class="row ProductCart-newClass6">
            <div class="col-md-12 ProductCart-newClass7">
            <button type="button" class="erpmark7-simple-btn erpmark7-bgcolor" onclick="{!c.saveSalesOrder}"> Confirm Order</button>&nbsp;
            <button type="button" class="erpmark7-simple-btn erpmark7-bgcolor" onclick="{!c.saveSalesOrders}"> Pay Now</button>
            <p class="ProductCart-newClass8">Please note that you are required to confirm this order</p>
            <p class="ProductCart-newClass9">Unconfirmed orders will remain in “draft” status, and can be accessed from <a href="#" class="ProductCart-newClass10">order history</a></p>
            </div>
        </div>
        <!--// Main Section \\-->
		
    </div>
    <!--// Main Content \\-->

    <div class="clearfix"></div>

    </div>
 </div>   
    <!--// Main Wrapper \\-->

        </div> 
         </div>
</body>
</html>
</aura:component>