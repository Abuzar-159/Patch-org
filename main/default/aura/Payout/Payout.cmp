<aura:component controller="Payout" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickActionWithoutHeader" access="global" >
    <aura:attribute name="payAmount" type="Decimal" default="0.00"/>
    <aura:attribute name="vouchers" type="Voucher__c[]" default=""/>
    <aura:attribute name="SelVouchers" type="String[]" default=""/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="criteriaMsgInv" type="String" default=""/> 
    <aura:attribute name="vId" type="String" default=""/>
    <aura:attribute name="showModal" type="boolean" default="false" />
    <aura:handler name="change" value="{!v.vId}" action="{!c.fetchDetails}"/> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    <aura:attribute name="voucher" type="Voucher__c" default="{'sObjectType':'ERP7__Voucher__c'}"/>
    <div class="slds-m-around_small">
    <div class="slds-page-header">
        <div class="slds-page-header__row">
            <div class="slds-page-header__col-title">
                <div class="slds-media">
                    <div class="slds-media__figure">
                        <span class="slds-icon_container slds-icon-standard-opportunity">
                            <lightning:icon iconName="utility:opportunity"></lightning:icon>
                            
                        </span>
                    </div>
                    <div class="slds-media__body">
                        <div class="slds-page-header__name">
                            <div class="slds-page-header__name-title">
                                <h1>
                                    <span>Vendor</span>
                                   
                                     <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.vId}"  IconName="standard:environment_hub" aura:id="ven"/>
                                    
                                </h1>
                            </div>
                            <div class="slds-page-header__name-switcher">
                                
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-page-header__col-actions">
            <div class="slds-page-header__controls">
                <div class="slds-page-header__control">
                    <ul class="slds-button-group-list">
                        <li>
                            <aura:if isTrue="{!v.SelVouchers.length>0}">
                            <lightning:button label="Schedule Payment" class="slds-button slds-button__brand" variant="brand" onclick="{!c.openConfirmDialog}"/><!-- onclick="{!c.recordPayment}" -->
                            </aura:if>
                        </li>
                        <li>
                            
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        </div>
        
    </div>
    
    
    
    <div class="slds-table slds-table_bordered slds-table_fixed-layout slds-table_resizable-cols slds-m-top_small" tabindex="1" style="margin-bottom:100px; outline: none;">
        <table class="table">
            <thead>
                <tr>
                    <th>
                        <aura:if isTrue="{!v.vouchers.length > 0}">
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <label class="slds-checkbox">
                                        <!-- <ui:inputCheckbox aura:id="AllBox" change="{!c.AllCheckboxSelect}"/>change="{!c.AllCheckboxSelect}" -->
                                        
                                    </label>
                                </div>
                            </div>  
                        </aura:if>
                    </th>
                    <th>
                        Voucher
                    </th>
                    <th>
                        Bill
                    </th>
                    <th>
                        Bill Date
                    </th>
                    <th>
                        Bill Due Date
                    </th>
                    <th>
                        Purchase Order
                    </th>
                    <th>
                        Amount
                    </th>
                 </tr>                     
            </thead>
            <tbody>
                
                <aura:iteration items="{!v.vouchers}" var="vou" indexVar="indx">
                    <tr>
                        <td>
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <label class="slds-checkbox">
                                        <lightning:input type="checkbox" value="" aura:id="cusCBId" onchange="{!c.checkboxSelect}" name="{!vou.Id}" /> 
                                    </label>
                                </div>
                            </div>
                        </td>
                        <td>
                            <a href="{!'/'+vou.Id}" target="_blank">{!vou.Name}</a>
                        </td>
                        <td>
                            <a href="{!'/'+vou.ERP7__Vendor_invoice_Bill__c}" target="_blank">{!vou.ERP7__Vendor_invoice_Bill__r.Name}</a>
                        </td>
                        <td>
                            {!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Bill_Date__c}
                        </td>
                        <td>
                            {!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Due_Date__c}
                        </td>
                        <td>
                            <a href="{!'/'+vou.ERP7__Purchase_Orders__c}" target="_blank">{!vou.ERP7__Purchase_Orders__r.Name}</a>
                        </td>
                        <td>
                            <lightning:formattedNumber value="{!vou.ERP7__Amount__c}" style="currency"/>
                        </td>
                        
                    </tr>
                </aura:iteration>                         
            </tbody>
            
        </table>
        
    </div>
    
    <aura:if isTrue="{!v.showMmainSpin}">
        <span class="AccountsPayable-newClass33">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if>
    <aura:renderIf isTrue="{!v.criteriaMsgInv !=''}">                                   
                    <div class="slds-notify_container slds-is-relative AccountsReceivable-newClass12">
                        <div class="slds-notify slds-notify_toast slds-theme_warning AccountsReceivable-newClass27" role="alert">
                            <span class="slds-assistive-text">warning</span>
                            <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                            <div class="slds-notify__content">
                                <h2 class="slds-text-heading_small slds-p-left_small">{!v.criteriaMsgInv}</h2>
                            </div>
                        </div>
                    </div> 
                </aura:renderIf> 
        <aura:if isTrue="{!v.showModal}">
            <div style="height:640px">
                <section role="dialog" tabindex="-1" class="slds-modal slds-modal_x-small slds-fade-in-open" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
                    <div class="slds-modal__container">
                        <header class="slds-modal__header">
                            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Confirmation</h2>
                        </header>
                        <div class="slds-modal__content slds-p-around_medium slds-p-left_large" id="modal-content-id-1">
                            <p style='margin-left:18%'>Are you sure you want to schedule this Payment?</p>
                        </div>
                        <footer class="slds-modal__footer">
                            <lightning:button class="slds-button slds-button_brand" name='Yes' label='Yes' onclick='{!c.schedulePay}'/>
                            <lightning:button class="slds-button slds-button_brand" name='No' label='No' onclick='{!c.closeModal}'/>
                        </footer>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
        </aura:if>
    </div>
</aura:component>