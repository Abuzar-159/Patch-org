<aura:component access="global">
<ltng:require scripts="{!$Resource.Chart}"  afterScriptsLoaded="{!c.createGraph}"/>
    <aura:attribute  name="keys"        type="list" access="global" /> 
    <aura:attribute  name="values" 		type="list" access="global"/>
    <aura:attribute  name="values2"     type="list" access="global"/>
    <aura:attribute  name="values3"     type="list" access="global"/>
    <aura:attribute  name="xLabel" 		type="String" access="global"/>
    <aura:attribute  name="yLabel" 		type="String" access="global"/>
    <aura:attribute  name="bgColor" 	type="String" access="global"/>
    <aura:attribute  name="bgColor2" 	type="String" access="global"/>
    <aura:attribute  name="bgColor3" 	type="String" access="global"/>
    <aura:attribute  name="chartType" 	type="String" access="global"/>
    <aura:attribute  name="label" 		type="String" access="global"/>
    <aura:attribute  name="label2" 		type="String" access="global"/>
    <aura:attribute  name="label3" 		type="String" access="global"/>
    
  
    <div class="slds-col slds-size--1-of-1 slds-small-size--1-of-2 slds-medium-size--2-of-4">
        <canvas aura:id="barChart" id="barChart" />
    </div>
    
</aura:component>