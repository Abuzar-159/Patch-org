<aura:component Controller="ERP7.InboundLogisticsLightning" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
	<aura:attribute name="currentEmployee" type="Employees__c" default="{sobjectType : 'Employees__c','Name': ''}" />
    <aura:attribute name="logisticId" type="String" default=""/>
    <aura:attribute name="Container" type="object"/>
    <aura:attribute name="Logistics" type="object[]"/>
    <aura:attribute name="selectedSite" type="String" default=""/>
    <aura:attribute name="searchText" type="String" default=""/>
    <aura:attribute name="show" type="String" default="25"/>
    <aura:attribute name="checkAll" type="Boolean" default="false"/>
    <aura:attribute name="PreventChange" type="Boolean" default="false"/>
    <aura:attribute name="exceptionError" type="String"/>
    <aura:attribute name="scanValue" type="String" default=''/>
    <aura:attribute name="FileList" type="object[]"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="getAllDetails" action="{!c.getAllDetails}"></aura:method>
    <aura:method name="Back2Inbound" action="{!c.Back2Inbound}"></aura:method>
    <aura:method name="Receive" action="{!c.Receive}"></aura:method>
    <aura:method name="Putaway" action="{!c.Putaway}"></aura:method>
    <aura:handler name="change" value="{!v.scanValue}" action="{!c.verifyScanCode}"/>
    <aura:method name="LoadNow" action="{!c.LoadNow}"></aura:method>
    <aura:handler name="change" value="{!v.currentEmployee.ERP7__Channel__c}" action="{!c.LoadChannelChange}"/>
    <aura:attribute name="SiteOptions" type="List"/>
    <aura:attribute name="SyncSalesforce" type="boolean" default='false'/>
    <aura:attribute name="SyncGDrive" type="boolean" default='false'/>
    <aura:attribute name="isGDrive" type="boolean" default='false'/>
    
    <head>  
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css', $Resource.PickPackShipResource + '/assets/styles/main-scrollers.css')}"  />
        <ltng:require styles="{!join(',',$Resource.Order_Console + '/assets/styles/custom.css', $Resource.Order_Console + '/assets/styles/font-awesome.css')}"  />
        <ltng:require styles="{!join(',',$Resource.SLDS213 + '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
        <!--<apex:includeScript value="{!URLFOR($Resource.Barcode_Scanner_JS)}" />-->
        <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js" afterScriptsLoaded="{!c.focusTOscan}"/>
        
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/InboundLogistic.css"/>
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css" />
        <!--<ltng:require styles="/resource/ERP7__maqcustom/css/maqmain.css" /> -->
        <ltng:require styles="/resource/ERP7__maqcustom/css/maqmain-min.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        
        
    </head> 
    <span class="InboundLog-class3"> 
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" onfocus="{!c.reRender}" onblur="{!c.reRender}" onclick="{!c.reRender}"/>
            </span>
    <body aura:id="body" class="InboundLog-class1" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" onfocus="{!c.reRender}" onblur="{!c.reRender}" onclick="{!c.reRender}">
    	<div class="erp_mark7 InboundLog-class2" id="er7" >
            
            <div class="slds-page-header slds-page-header--object-home" role="banner">
                <div class="slds-grid">
                    <div class="slds-col slds-has-flexi-truncate">
                        <div class="slds-media slds-no-space slds-grow"> 
                            <div class="slds-media__figure">                                
                                <span class="slds-icon_container">
                                    <span aria-hidden="true" class="slds-icon slds-icon-action-back  slds-icon--large InboundLog-class4" > 
                                        <img src="/resource/erp7__SLDS213/assets/icons/custom/Stock_receiving.png" width="58"/>
                                    </span>
                                </span>
                            </div>
                            <div class="slds-media__bod InboundLog-class5">
                                <nav class="slds-context-bar__secondary" role="navigation">
                                    <ul class="slds-grid">
                                        <h1 class="slds-page-header__title slds-truncate InboundLog-class6" title="Refresh Inbound Logistics" onclick="{!c.Back2Inbound}">{!$Label.c.Inbound_Logistics}</h1>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                    <div class="slds-col slds-no-flex slds-grid slds-align-top slds-p-bottom--xx-small maqheadernavbuttons">
                        <div class="slds-button-group InboundLog-class7" role="group">
                           <c:CustomInputLookUp objectAPIName="ERP7__Channel__c" aura:id="emp" IconName="standard:user" selectedRecordId="{!v.currentEmployee.ERP7__Channel__c}" />
                        </div>
                        <ul class="slds-grid--vertical-align-left InboundLog-class8" > 
                            <div class="slds-button-group InboundLog-class9" role="group">
                                <a href="javascript:void(0);" class="slds-button slds-button--neutral nuetral-f InboundLog-class10" ><i class="fa fa-filter InboundLog-class11" aria-hidden="true"></i></a>
                                <li> 
                                    <lightning:select aura:id="Site" value="{!v.selectedSite}" onchange="{!c.Load}" variant="label-hidden" class="display-lable width200" label="Site">
                                        <aura:iteration items="{!v.SiteOptions}" var="option">
                                            <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.selectedSite, option.value)}"/>
                                        </aura:iteration>
                                    </lightning:select>
                                </li> 
                            </div>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="epr_Mark7 erp_mark7" >
                <div  class="panel-collapse collapse in">
                    <div class="panel-body InboundLog-class12">
                        <!-- Nav tabs --> 
                        <ul class="nav nav-tabs " role="tablist">
                            <li class="nav-item active"><!-- /lightning/n/ERP7__Outbound_Logistic -->
                                <a class="nav-link InboundLog-class13" data-toggle="tab" href="javascript:void(0);" role="tab" onclick="{!c.Back2Inbound}">
                                <i class="fa fa-list InboundLog-class14" aria-hidden="true" data-logisticId=""></i>&nbsp;{!$Label.c.List_Outbound_logistics}</a>
                            </li>    
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="tab" href="javascript:void(0);" role="tab" onclick="{!c.Receive}">
                                <i class="fa fa-level-down InboundLog-class14" aria-hidden="true" data-logisticId=""></i>&nbsp;{!$Label.c.Inbound_Receive}</a>
                                
                            </li>    
                            <li class="nav-item"> 
                                <a class="nav-link" data-toggle="tab" href="javascript:void(0);" role="tab" onclick="{!c.Putaway}">
                                <i class="fa fa-level-up InboundLog-class14" aria-hidden="true"  data-logisticId=""></i>&nbsp;{!$Label.c.Putaway} </a>
                            </li>
                        </ul>
                        
                    </div>
                </div>
            <div class="slds-p-around--small InboundLog-class15 nolabel">
                 <table border="0" width="100%" cellpadding="0" cellspacing="0" >
                        <tr>
                            <td align="left" valign="middle" width="100%">
                                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                    <tr>
                                        <td width="25%" class="scanMN "><lightning:input  value="{!v.searchText}" aura:id="ikt" placeholder="{!$Label.c.Search_UsersShiftMatch}"  class="scanMN mr-0" maxlength="80" oncommit="{!c.Load}"/></td>
                                        <td width="15%"><lightning:button variant="brand" onclick="{!c.Load}" class="slds-button slds-button--brand2 slds-m-left--xx-small fieldswidth100" aura:id="fnd" label="{!$Label.c.Find_StockTake}"/></td>
                                        <td width="55%"> 
                                            <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed InboundLog-class49','slds-notify_container slds-is-fixed InboundLog-class48')}">
                                                <div class="slds-notify slds-notify_toast slds-theme_error InboundLog-class16" role="status">
                                                    <span class="slds-assistive-text">{!$Label.c.error}</span>
                                                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                                                        <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" />
                                                    </span>
                                                    <div class="slds-notify__content">
                                                        <h2 class="slds-text-heading_x-small InboundLog-class17" >{!v.exceptionError}
                                                        </h2>
                                                    </div>
                                                    <div class="slds-notify__close InboundLog-class18" >
                                                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                                                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" />	
                                                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>                            
                    </table>
             </div>
        </div> 
            
        	<div class="epr_Mark7">
               <div class="InboundLog-class19">                                    
                   <table id="example" class="table table-bordered  slds-no-row-hover InboundLog-class20" > 
                       <thead>
                           <tr class="slds-text-heading--label" bgcolor="#f3f3f3">
                               <th class="slds-cell-shrink" scope="col">
                                   <lightning:input type="checkbox" checked="{!v.checkAll}" onchange="{!c.checkAll}"/>
                               </th>                                    
                               <th class="slds-is-sortable" scope="col"> {!$Label.c.Name_ManageLeave} </th>
                               <th class="slds-is-sortable mobiledisplaynone mobiledisplaynone-landscape" scope="col"> {!$Label.c.Order_RMA} </th>
                               <th class="slds-is-sortable mobiledisplaynone mobiledisplaynone-landscape" scope="col">{!$Label.c.Expected_Date}</th> 
                               <th class="slds-is-sortable mobiledisplaynone mobiledisplaynone-landscape" scope="col">{!$Label.c.Barcode_Outbound_logistics}</th>
                               <aura:renderIf isTrue="{!!$Label.c.Show_receving_bill}">
                               		<th class="slds-is-sortable mobiledisplaynone mobiledisplaynone-landscape" scope="col"> {!$Label.c.CreateAddress_Customer} </th>
                               </aura:renderIf>
                               <th class="slds-is-sortable no-sort mobiledisplaynone mobiledisplaynone-landscape" scope="col">{!$Label.c.ACCOUNT}</th>                                 
                               <th class="slds-is-sortable no-sort" scope="col">Action</th> 
                               <th class="slds-is-sortable no-sort" scope="col"></th> 
                               <aura:renderIf isTrue="{!$Label.c.Show_receving_bill}">
                                   <th class="slds-is-sortable no-sort" scope="col">{!$Label.c.Label}</th>
                               </aura:renderIf>
                           </tr>    
                       </thead>  
                       
                       <tbody>  
                           <aura:iteration var="sos" indexVar="SOCounter" items="{!v.Container.LogisticWrapperList}">
                               <tr class="slds-hint-parent" id="{!sos.Logistic.Id}">
                                   <td class="slds-cell-shrink" data-label="Action" role="row"> 
                                       <lightning:input type="checkbox" checked="{!sos.isSelected}" />
                                   </td>
                                   <td data-label="Name" scope="row">
                                      <div class="slds-truncate InboundLog-class21" title="SLN" id="{!sos.Logistic.Id}">
                                          <lightning:formattedText value="{!sos.Logistic.Name}" onclick="{!c.NavRecord}" title="{!sos.Logistic.Id}" /> 
                                       </div>
                                   </td>
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Order">
                                       <div class="slds-truncate InboundLog-class22">
                                       <aura:iteration var="orderWrap" indexVar="orderCounter" items="{!sos.orderWrapperList}">
                                          <aura:if isTrue="{!orderCounter>0}">,&nbsp;</aura:if>
                                          <lightning:formattedUrl value="{!'/'+orderWrap.OrderId}" label="{!orderWrap.OrderName}" tooltip="{!orderWrap.OrderName}" target="_blank" />
                                       </aura:iteration>
                                       </div>
                                   </td>
                                   <!--
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Order">
                                       <aura:if isTrue="{!and(sos.Logistic.ERP7__Sales_Order__c == undefined, sos.Logistic.ERP7__Order__c != undefined)}">
                                           <div class="slds-truncate InboundLog-class22" title="SLN" id="{!sos.Logistic.ERP7__Order__c}">
                                               <lightning:formattedRichText value="{!sos.Logistic.ERP7__Order__c}" /> 
                                           </div>
                                       </aura:if>
                                   </td>-->
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Expected Date">
                                       <div class="slds-truncate">
                                           <aura:if isTrue="{!and(sos.Logistic.ERP7__Logistic_Expected_Date__c != '',sos.Logistic.ERP7__Logistic_Expected_Date__c != null)}">
                                          <lightning:formattedDateTime value="{!sos.Logistic.ERP7__Logistic_Expected_Date__c}" /> 
                                           <aura:set attribute="else">
                                                <aura:if isTrue="{!sos.Logistic.ERP7__Sales_Order__c || sos.Logistic.ERP7__Purchase_Order__c || sos.Logistic.ERP7__Transfer_Order__c}">
                                               <lightning:formattedDateTime value="{!sos.Logistic.ERP7__Expected_Date__c}" />
                                               <aura:set attribute="else">
                                               <lightning:formattedDateTime value="{!sos.Logistic.ERP7__Expected_Date_S__c}" />
                                               </aura:set>
                                               </aura:if>
                                               
                                               
                                           </aura:set>
                                       </aura:if>
                                       		<!--<lightning:formattedDateTime value="{!sos.Logistic.ERP7__Expected_Date__c}" />-->
                                       </div>
                                   </td>
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Barcode">
                                       <div class="slds-truncate">
                                           <aura:if isTrue="{!and(sos.Logistic.ERP7__Barcode__c != '',sos.Logistic.ERP7__Barcode__c != null)}">
                                                    <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Barcode__c}"/>
                                           <aura:set attribute="else">
                                                <aura:if isTrue="{!sos.Logistic.ERP7__Barcode_S__c}">
                                                    <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Barcode_S__c}"/>
                                               <aura:set attribute="else">
                                           <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Logistic_Barcode__c}"/>
                                               </aura:set>
                                               </aura:if>
                                               
                                               
                                           </aura:set>
                                       </aura:if>
                                           <!--<aura:if isTrue="{!(sos.Logistic.ERP7__Barcode__c != null)}">   
                                           	<ERP7:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Barcode__c}"/>
                                               <aura:set attribute="else">
                                               		<ERP7:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Barcode_S__c}"/>
                                               </aura:set>
                                       	   </aura:if>-->
                                           <!--<aura:renderIf isTrue="{!(sos.Logistic.ERP7__Barcode_S__c != null)}">   
                                           	<c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!sos.Logistic.ERP7__Barcode_S__c}"/>
                                       	   </aura:renderIf>-->
                                       </div>
                                   </td>
                                   <aura:renderIf isTrue="{!!$Label.c.Show_receving_bill}">
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Account">
                                       <div class="slds-truncate InboundLog-class22" title="SLN" id="{!sos.Logistic.ERP7__Purchase_Order__r.ERP7__Customer__c}">
                                           <lightning:formattedText value="{!sos.Logistic.ERP7__Purchase_Order__r.ERP7__Customer__r.Name}" onclick="{!c.NavRecord}" title="{!sos.Logistic.ERP7__Purchase_Order__r.ERP7__Customer__c}" />
                                       </div> 
                                   </td> 
                                   </aura:renderIf>
                                   <td class="mobiledisplaynone mobiledisplaynone-landscape" data-label="Track No">
                                       <div class="slds-truncate InboundLog-class22" title="SLN" id="{!sos.Logistic.ERP7__Account__c}">
                                           <lightning:formattedText value="{!sos.Logistic.ERP7__Account__r.Name}" onclick="{!c.NavRecord}" title="{!sos.Logistic.ERP7__Account__c}" /> 
                                       </div> 
                                   </td>
                                   
                                   <td data-label="Action" class="InboundLog-class23">
                                       <div class="slds-truncate"> 
                                           <table class="InboundLog-class20">
                                               <tr>
                                                   <td width="50%" class="p-0">
                                                       <div class="erp_Mark7 maqsood">
                                                       <div class="card folder m-1 mb-0 border-custom-m">
                                                           <div class="card-body p-2">
                                                               <div class="folder-icon">
                                                                    <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Received_Quantity__c == 0, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-down InboundLog-class25" aria-hidden="true" ></i></aura:renderIf>
                                                          		 	<aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Received_Quantity__c > 0, sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Received_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-down InboundLog-class27" aria-hidden="true" ></i></aura:renderIf>
                                                           			<aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Total_Quantity__c == sos.Logistic.ERP7__Received_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-down InboundLog-class26" aria-hidden="true" ></i></aura:renderIf>
                                                          		 &nbsp;
                                                               </div>
                                                               <div class="folder-info">
                                                                  <a class="InboundLog-class28" onclick="{!c.Receive}" data-logisticId="{!sos.Logistic.Id}">{!$Label.c.Inbound_Receive}</a>
                                                                   <span><div class="InboundLog-class29" title="{!(sos.Logistic.ERP7__Received_Quantity__c) + ' /' + (sos.Logistic.ERP7__Total_Quantity__c)}">{!sos.Logistic.ERP7__Received_Quantity__c}/{!sos.Logistic.ERP7__Total_Quantity__c}</div></span>
                                                               </div>
                                                           </div>
                                                       </div>
                                                       </div>
                                                       
                                                   </td> 
                                                   <td width="50%" class="p-0">
                                                        <div class="erp_Mark7 maqsood">
                                                       <div class="card folder m-1 mb-0 border-custom-m">
                                                           <div class="card-body p-2">
                                                               <div class="folder-icon">
                                                                   <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Putaway_Quantity__c == 0, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-up InboundLog-class25" aria-hidden="true" ></i></aura:renderIf>
                                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Putaway_Quantity__c > 0, sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-up InboundLog-class27" aria-hidden="true" ></i></aura:renderIf>
                                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Total_Quantity__c == sos.Logistic.ERP7__Putaway_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-upInboundLog-class26" aria-hidden="true" ></i></aura:renderIf>
                                                           &nbsp;
                                                               </div>
                                                               <div class="folder-info">
                                                                   <aura:renderIf isTrue="{!(sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c)}">
                                                                       <a class="InboundLog-class28" onclick="{!c.Putaway}" data-logisticId="{!sos.Logistic.Id}">{!$Label.c.Putaway}</a>
                                                                   </aura:renderIf>
                                                                   <aura:renderIf isTrue="{!!(sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c)}">
                                                                       {!$Label.c.Putaway}
                                                                   </aura:renderIf>
                                                                   <span><div class="InboundLog-class30" title="{!(sos.Logistic.ERP7__Putaway_Quantity__c) + ' /' + (sos.Logistic.ERP7__Total_Quantity__c)}">{!sos.Logistic.ERP7__Putaway_Quantity__c}/{!sos.Logistic.ERP7__Total_Quantity__c}</div></span>
                                                               </div>
                                                           </div>
                                                       </div>
                                                       </div>
                                                       <!--<div class="InboundLog-class24">
                                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Putaway_Quantity__c == 0, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-up InboundLog-class25" aria-hidden="true" ></i></aura:renderIf>
                                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Putaway_Quantity__c > 0, sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-up InboundLog-class27" aria-hidden="true" ></i></aura:renderIf>
                                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Total_Quantity__c == sos.Logistic.ERP7__Putaway_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}"> <i class="fa fa-level-upInboundLog-class26" aria-hidden="true" ></i></aura:renderIf>
                                                           &nbsp;
                                                           <aura:renderIf isTrue="{!(sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c)}">
                                                               <a class="InboundLog-class28" onclick="{!c.Putaway}" data-logisticId="{!sos.Logistic.Id}">Putaway</a>
                                                           </aura:renderIf>
                                                           <aura:renderIf isTrue="{!!(sos.Logistic.ERP7__Total_Quantity__c > sos.Logistic.ERP7__Putaway_Quantity__c)}">
                                                               Putaway
                                                           </aura:renderIf>
                                                          
                                                           <br/><div class="InboundLog-class30" title="{!(sos.Logistic.ERP7__Putaway_Quantity__c) + ' /' + (sos.Logistic.ERP7__Total_Quantity__c)}">{!sos.Logistic.ERP7__Putaway_Quantity__c}/{!sos.Logistic.ERP7__Total_Quantity__c}</div>
                                                       </div> -->
                                                       
                                                   </td>
                                               </tr>
                                           </table>
                                          
                                       </div>
                                   </td> 
                                   <td data-label="" class="InboundLog-class23" >
                                       <aura:if isTrue="{!and(and(sos.Attach.Id == undefined,sos.GDrive.Id == undefined),sos.conAttach.Id == undefined)}">
                                           <div class="slds-col">
                                               <lightning:fileUpload multiple="false" recordId="{!sos.Logistic.Id}" disabled="{!sos.showUpload}" onuploadfinished="{!c.uploadFile}" />
                                               <!-- <lightning:input aura:id="fileik" type="file" files="{!v.FileList}" name="{!sos.Logistic.Id}" onchange="{!c.onFileUploaded}" onfocus="{!c.reRender}" oncomplete="{!c.reRender}" onblur="{!c.reRender}" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" multiple="true" class="InboundLog-class31"/> -->
                                               <aura:if isTrue="{!v.isGDrive}">
                                                    <lightning:input aura:id="SyncSalesforce" type="checkbox" label="Sync to Salesforce" name="{!sos.Logistic.Id}" checked="{!sos.isSales}" title="Sync to Salesforce" onchange="{!c.handleCheckSalesforce}"/>
                                                    <lightning:input aura:id="SyncDrive" type="checkbox" label="Sync to Google Drive" name="{!sos.Logistic.Id}" title="Sync to Google Drive" checked="{!sos.isGDrive}" onchange="{!c.handleCheckGDrive}"/>
                                                </aura:if>
                                           </div>
                                       </aura:if>
                                       <aura:renderIf isTrue="{!(sos.Attach.Id != undefined)}">
                                           <div class="slds-grid">
                                               <div class="slds-col">
                                                   <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!sos.Attach.Id}" title="Attachment">
                                                       <a href="javascript:void(0)" title="delete" class="InboundLog-class32">
                                                           <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="InboundLog-class33" />  
                                                       </a>
                                                   </lightning:button>
                                                   &nbsp;
                                                   <lightning:formattedUrl value="{!'/'+sos.Attach.Id}" label="{!sos.Attach.Name}" tooltip="{!sos.Attach.Name}" target="_blank" class="fcolor"/>
                                               </div>
                                               <div class="slds-col">
                                                   <img src="{!'/servlet/servlet.FileDownload?file='+sos.Attach.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                               </div>
                                           </div>
                                           <aura:set attribute="else">
                                               <aura:renderIf isTrue="{!(sos.conAttach.Id != undefined)}">
                                                   <div class="slds-grid">
                                                       <div class="slds-col">
                                                           <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!sos.conAttach.ContentDocumentId}" title="ContentDocument">
                                                               <a href="javascript:void(0)" title="delete" class="InboundLog-class32">
                                                                   <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="InboundLog-class33" />  
                                                               </a>
                                                           </lightning:button>
                                                           &nbsp;
                                                           <lightning:formattedUrl value="{!'/'+sos.conAttach.Id}" label="{!sos.conAttach.Title}" tooltip="{!sos.conAttach.Title}" target="_blank" class="fcolor"/>
                                                       </div>
                                                       <div class="slds-col">
                                                           <img src="{!'/servlet/servlet.FileDownload?file='+sos.conAttach.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                                       </div>
                                                   </div>
                                                   
                                                   <aura:set attribute="else">
                                                       <aura:renderIf isTrue="{!(sos.GDrive.Id != undefined)}">
                                                           <div class="slds-grid">
                                                               <div class="slds-col">
                                                                   <a href="{!sos.GDrive.ERP7__File_Link__c}" target="_blank" title="{!sos.GDrive.Name}" class="InboundLog-class32">
                                                                       <img src="/resource/1681827408000/ERP7__PickPackShipResource/assets/images/googledrive.png" class="InboundLog-class32 imgh"/>
                                                                   </a>
                                                                   &nbsp;
                                                                   <lightning:formattedUrl value="{!'/'+sos.GDrive.Id}" label="{!sos.GDrive.Name}" tooltip="{!sos.GDrive.Name}" target="_blank" class="fcolor"/>
                                                                   
                                                               </div>
                                                           </div>
                                                       </aura:renderIf>
                                                   </aura:set>
                                               </aura:renderIf>
                                           </aura:set>
                                       </aura:renderIf>
                                       
                                      
                                   </td>
                                   <aura:renderIf isTrue="{!$Label.c.Show_receving_bill}">
                                       <td>
                                           
                                           <aura:renderIf isTrue="{!and(sos.Logistic.ERP7__Total_Quantity__c == sos.Logistic.ERP7__Putaway_Quantity__c, sos.Logistic.ERP7__Total_Quantity__c > 0)}">
                                               <a href="{!'/apex/ERP7__ReceivingLabel?loIds='+sos.Logistic.Id}"  target="_blank" title="Receiving Label">
                                                   <i title="Traveller" class="fa fa-file-pdf-o InboundLog-class35" aria-hidden="true" ></i>
                                               </a>&nbsp;
                                           </aura:renderIf>
                                           
                                       </td>
                                   </aura:renderIf>
                               </tr>                
                           </aura:iteration>
                       </tbody>                             
                   </table>
            	</div> 
             </div>
             <div class="epr_Mark7 InboundLog-class36">
                <div class="row InboundLog-class37">
                    <aura:renderIf isTrue="{!(v.Container.LogisticWrapperList.length>0)}">
                        <div class="col-lg-2 InboundLog-class38">
                            <div class="slds-grid" >
                                <div class="slds-col InboundLog-class39">
                                    {!$Label.c.Acc_Recev_Show}&nbsp;&nbsp;
                                </div>
                                <div class="slds-col" >
                                    <lightning:select value="{!v.show}" onchange="{!c.SetShow}" variant="label-hidden" class="display-lable" label="Site">
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                    </lightning:select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 InboundLog-class40" >
                            {!$Label.c.Acc_Recev_Showing} <span class="text-lightblue">{!v.Container.startCount}-{!v.Container.endCount}</span> of total <span class="text-lightblue"> {!v.Container.recSize} </span> {!$Label.c.Acc_Recev_Records}
                        </div>
                       
                            <div class="col-lg-5 InboundLog-class41">
                                <nav aria-label="Page navigation example">
                                    <ul class="pagination InboundLog-class42">
                                        <li class="InboundLog-class43" >
                                            <a class="{!if(1 >= v.Container.startCount,'InboundLog-class44','InboundLog-class45')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> 
                                        </li>
                                        <li class="InboundLog-class50" >
                                            <a class="{!if(1 >= v.Container.startCount,'InboundLog-class44','InboundLog-class45')}"  onclick="{!c.Previous}">  {!$Label.c.Previous}</a> 
                                        </li>
                                        
                                        <li class="InboundLog-class50" >
                                            <a class="{!if(v.Container.endCount == v.Container.recSize,'InboundLog-class46','InboundLog-class47')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> 
                                        </li>
                                        <li class="InboundLog-class51" >
                                            <a class="{!if(v.Container.endCount == v.Container.recSize,'InboundLog-class46','InboundLog-class47')}" onclick="{!c.NextLast}">&gt;&gt; </a> 
                                        </li>
                                    </ul>
                                </nav> 
                            </div>
                     
                            <div class="col-lg-2 InboundLog-class38" >
                                <div class="slds-grid">
                                    <div class="slds-col InboundLog-class52">
                                        Page 
                                    </div>
                                    <div class="slds-col InboundLog-class53">
                                        <lightning:input type="number" value="{!v.Container.PageNum}" variant="label-hidden" class="display-lable width100" oncommit="{!c.OfsetChange}"/>
                                    </div>
                                    <div class="slds-col InboundLog-class52" ><span class="text-lightblue"> of {!v.Container.PNS.length}</span>
                                    </div>
                                </div>
                            </div> 
                       
                    </aura:renderIf>
                </div> 
            </div> 
        </div>
    </body>
</aura:component>