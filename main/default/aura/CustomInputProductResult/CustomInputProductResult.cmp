<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="change" value="{!v.oRecord}" action="{!c.doInit}"/>
    
    <aura:attribute name="oRecord" type="sObject" />
    <aura:attribute name="IconName" type="string" access="global"/>
    <aura:attribute name="IconPath" type="string"/>
    <aura:attribute name="SearchField" type="String" default="Name"/> 
    <aura:attribute name="NameValue" type="string"/> 
     <aura:attribute name="prodcode" type="string"  access="global"/>
     <aura:attribute name="Family" type="string"  access="global"/>
  <aura:registerEvent name="oSelectedRecordEvent" type="c:selectedsObjectRecordEvent"/>
 
    <li role="presentation" class="slds-listbox__item" onclick="{!c.selectRecord}">
        <span id="listbox-option-unique-id-01" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
            <aura:if isTrue="{!or(not(empty(v.IconPath)),not(empty(v.IconName)))}">  
             <span class="slds-media__figure">
                  <span class="slds-icon_container customIcon" title="Description of icon when needed">
                      <aura:if isTrue="{!not(empty(v.IconName))}">
                          <lightning:icon iconName="{!v.IconName}" class="slds-icon slds-icon_small slds-icon-text-default customIcon" size="small" alternativeText="icon"/>
                          <aura:set attribute="else">
                              <img src="{!v.IconPath}" class="custominputresult-class1"/>
                          </aura:set>
                      </aura:if>
                        <span class="slds-assistive-text">Description of icon</span>
                  </span>
              </span>    
            </aura:if>
              <span class="slds-media__body">  
                  <span class="slds-listbox__option-text slds-listbox__option-text_entity">{!v.NameValue}</span>
                  <span class="">{!v.prodcode} 
                      <aura:if isTrue="{!(not(empty(v.Family)))}">
                          - {!v.Family}
                      </aura:if>
                  </span>
              </span>
        </span>
    </li>
</aura:component>