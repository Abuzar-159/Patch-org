<aura:component controller="CreateDebitNote" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <ltng:require styles="{!join(',',$Resource.SLDS + 'assets/styles/salesforce-lightning-design-system-vf.css',$Resource.SLDS + 'assets/styles/salesforce-lightning-design-system-vf.min.css',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css',$Resource.PickPackShipResource + '/assets/styles/font-awesome.css' )}"/>    
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/createbill.css"/> 
    <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>
    
    <!--<aura:attribute name="Bill" type="Map" />-->
    <aura:attribute name="CreditNote" type="Credit_Note__c" default="{sobjectType:'Credit_Note__c','ERP7__Account__c':''}"/>
    <aura:attribute name="invoice" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}"/>
    <aura:attribute name="lineItems" type="List" default="[]"/>
    <aura:attribute name="orglineItems" type="List" default="[]"/><!--//ASRA changed-->
    <aura:attribute name="fillList" type="String[]" default="[]"/>
    <aura:attribute name="Itemtype" type="List" default="[]"/>
    <aura:attribute name="advBillList" type="Object"/>
    <aura:attribute name="invId" type="String"/>
    <aura:attribute name="credId" type="String"/>
    <aura:attribute name="vId" type="String"/>
    <aura:attribute name="fromAP" type="boolean" default='false'/>
    <aura:attribute name="disabledEdit" type="boolean" default='false'/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="recordPage" type="boolean" default='false'/>
    
    <aura:attribute name="Expensetype" type="List" default="[]"/>
    <aura:attribute name="Index2Delete" type="Integer" />
    <aura:attribute name="isAttRequired" type="Boolean" default="false"/>
     <aura:attribute name="isUpdate" type="boolean" default='false'/>
    <aura:attribute name="isStdOrder" type="boolean" default='false'/>
    <aura:attribute name="navigateToRecord" type="Boolean" default="true"/>
    <aura:attribute name="cancelclick" type="Aura.Action" default="{!c.goBack}"/>
    <aura:attribute name="TotalPrice" type="Currency"/>
    <aura:attribute name="SchInvoiceAmount" type="Currency"/>
    <aura:attribute name="AdvanceAmount" type="Currency"/>
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:attribute name="Discount" type="Currency"/>
    <aura:attribute name="TDS_Amount" type="Currency"/>
    <aura:attribute name="TDS_Rate" type="Currency" />
    <aura:attribute name="supplier" type="Boolean" default="false"/>
    <!--<aura:handler name="change" value="{!v.TDS_Amount}" action="{!c.updateTDS}"/>
    <aura:handler name="change" value="{!v.TDS_Rate}" action="{!c.updateTDS}"/>
    <aura:handler name="change" value="{!v.DebitNote.ERP7__Amount__c}" action="{!c.updateTDS}"/>-->
    <aura:attribute name="Tax" type="Currency"/> 
    <aura:attribute name="saveclick" type="Aura.Action" default="{!c.saveBill}"/>
    <aura:method name="BillSave" action="{!c.saveBill}" access="PUBLIC">
        <aura:attribute name="callback" type="Function" />
    </aura:method> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="change" value="{!v.Index2del}" action="{!c.delete_Item}"/>
    <aura:handler name="change" value="{!v.TotalPrice}" action="{!c.updateTotalPrice}"/>
    <aura:handler name="change" value="{!v.Discount}" action="{!c.updateTotalDiscount}"/>
    <aura:handler name="change" value="{!v.Tax}" action="{!c.updateTotalTax}"/>
    <aura:handler name="change" value="{!v.CreditNote.ERP7__Invoice__c}" action="{!c.fetchinvli}"/>
    <aura:handler name="change" value="{!v.CreditNote.ERP7__Return_Merchandise_Authorisation__c}" action="{!c.fetchrmali}"/>
    <!--<aura:handler name="change" value="{!v.DebitNote.ERP7__Account__c}" action="{!c.fetchVendorDetails}"/>-->
    <aura:attribute name="deleteIndex" type="Integer"/>
    <aura:handler event="c:RequisitionToPurchaseOrderEvent" action="{!c.deleteLineItem}"/>
    <aura:attribute name="showExpenseAccount" type="Boolean" default="true"/>
    <aura:attribute name="ShowBillType" type="Boolean" default="false"/>
    <aura:attribute name="showPage" type="Boolean" default="false"/>
    <aura:attribute name="showDelete" type="Boolean" default="false"/>
    <aura:attribute name="setRT" type="String" default="PO Bill"/>
    <aura:attribute name="invRT" type="String" default="PO Bill"/>
    <aura:attribute name="setBillPost" type="Boolean" default="false"/>
    <aura:attribute name="Attachments"          type="object[]"/>
    <aura:attribute name="Attach"          type="Attachment"/>
    <aura:attribute name="BillId" type="Id" default="" />
    <aura:attribute name="parentId" type="Id" default="" />
    <aura:attribute name="showLoadingSpinner" type="boolean" default="false" />
    <aura:attribute name="duplicate" type="boolean" default="false" />
    <aura:attribute name="fileName" type="String" default="No File Selected.." />
    <aura:attribute name="CreateBillFLSCheck" type="object" default="{'sObjectType' : 'CreateBillFLSCheck'}"/>
    <aura:attribute name="FieldAccess" type="Boolean" default="true"/>
    <aura:attribute name="Compare" type="String" default="True"/>
    <aura:attribute name="advPayment" type="Decimal" default="0.00"/>
    <aura:attribute name="totalSchAmount" type="Decimal" default="0.00"/>
    <aura:attribute name="FileList" type="object"/>
    <aura:if isTrue="{!v.showPage}">       
        <div class="erp_mark7 erp_Mark7 createbill-class1">
            <lightning:spinner variant="brand" size="small" aura:id="spinner" class="slds-hide"/>
            <div class="slds-page-header">
                <div class="slds-grid slds-wrap">
                    <div class="slds-col slds-has-flexi-truncate">
                        <div class="slds-media slds-no-space slds-grow">
                            <div class="slds-media__figure">
                                <lightning:icon iconName="standard:work_plan" variant="inverse" size="x-large" alternativeText="work_plan" title="" />
                            </div>
                            <div class="slds-media__body">
                                <p class="slds-text-title--caps slds-line-height--reset">{!$Label.c.Transfer_Order_Create}</p>
                                <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate" title="">{!$Label.c.Credit_Note}</h1>
                                
                            </div>
                        </div>
                    </div>
                    <div class="slds-col slds-no-flex slds-grid slds-align-top">
                    </div>
                </div>
            </div>
            
            
            <div class="slds-grid slds-wrap slds-m-top--small">
                
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="input-unique-id"> {!$Label.c.RMA}<span class="createbill-class4"></span></label>
                        <c:CustomInputLookUp objectAPIName="ERP7__Return_Merchandise_Authorisation__c" IconName="standard:account" selectedRecordId="{!v.CreditNote.ERP7__Return_Merchandise_Authorisation__c}" />
                    </div> 
                </div>
                
                <aura:if isTrue="{!v.isStdOrder}">
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="input-unique-id"> {!$Label.c.Order_RMA} <span class="createbill-class4"></span></label>
                        <c:CustomInputLookUp objectAPIName="Order" IconName="standard:account" selectedRecordId="{!v.CreditNote.ERP7__Order__c}" />
                    </div> 
                </div>
                <aura:set attribute="else">
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="input-unique-id"> {!$Label.c.Order_Console_Sales_Order}   <span class="createbill-class4"></span></label>
                        <c:CustomInputLookUp objectAPIName="ERP7__Sales_Order__c" IconName="standard:account" selectedRecordId="{!v.CreditNote.ERP7__Sales_Order__c}" />
                    </div> 
                </div>
                </aura:set>
                </aura:if>
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id"> {!$Label.c.Invoice} <span class="createbill-class4">*</span></label>
                                    <c:CustomInputLookUp objectAPIName="ERP7__Invoice__c" IconName="standard:address" selectedRecordId="{!v.CreditNote.ERP7__Invoice__c}" required="true"/>
                        </div>
                    </div>
                
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="input-unique-id"> {!$Label.c.CreateAddress_Customer} <span class="createbill-class4">*</span></label>
                        <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.CreditNote.ERP7__Account__c}" qry=" AND ERP7__Account_Type__c = 'Customer'"  required="true" />
                    </div> 
                </div>
                <!--
                <div class="slds-col slds-p-horizontal-/-medium slds-size-/-1-of-4">
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <label class="slds-form-element__label" for="input-unique-id">Vendor Contact</label>
                            
                            <ERP7:CustomInputLookUp objectAPIName="Contact" IconName="standard:contact" selectedRecordId="{!v.DebitNote.ERP7__Vendor_Contact__c}" NameValue="{!v.DebitNote.ERP7__Vendor_Contact__r.Name}"   aura:Id="vendorContact" qry="{!' AND AccountId = \''+v.DebitNote.ERP7__Vendor__c+'\''}"/>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-p-horizontal-/-medium slds-size-/-1-of-4">
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <ERP7:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.DebitNote.ERP7__Vendor_Address__c}" NameValue="{!v.DebitNote.ERP7__Vendor_Address__r.Name}" label="Vendor Address"  aura:Id="vendorAddress" qry="{!' AND ERP7__Customer__c   = \''+v.DebitNote.ERP7__Vendor__c+'\''}"/>  
                        </div>
                    </div>
                </div>
				-->
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Reference_Number}<span class="createbill-class4">*</span></label>
                            <lightning:input type="text" variant="label-hidden" value="{!v.CreditNote.ERP7__Reference_Number__c}" />
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element custommoin">
                        <div class="slds-form-element__control">
                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Credit_Note_Date}</label>
                            <lightning:input type="date"  value="{!v.CreditNote.ERP7__Date__c}" variant="label-hidden"/>
                        </div>
                    </div>
                </div>
                <!--<div class="slds-col slds-p-horizontal-/-medium slds-size-/-1-of-4">
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <lightning:input type="date" label="Due Date" value="{!v.DebitNote.ERP7__Due_Date__c}"/>
                        </div>
                    </div>
                </div>
                -->
                
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    <div class="slds-form-element">
                        <c:CustomInputLookUp objectAPIName="Account" IconName="standard:address" selectedRecordId="{!v.CreditNote.ERP7__Organisation__c}" label="{!$Label.c.EmployeeReview_Organisation}"  aura:Id="Org" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/> 
                    </div>
                </div>
            </div>
            
            
            <div class="slds-grid slds-wrap  slds-m-top--small">
                
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4">
                    
                    <div class="slds-grid"><span >{!$Label.c.Attachment}</span><aura:if isTrue="{!and(v.isAttRequired,v.setRT != 'Advance to vendor')}"></aura:if></div>
                    <lightning:input aura:id="fileId" type="file" files="{!v.FileList}" onchange="{!c.handleFilesChange}" multiple="true" label="{!$Label.c.Upload_Attachment}" value="{!v.fillList}"/>
                    <aura:if isTrue="{!v.showDelete}">
                        <a onclick="{!c.removeAttachment}" title="Remove Attachment" class="createbill-class6">
                            <i class="fa fa-minus-circle" aria-hidden="true"></i>
                        </a>                        
                    </aura:if>
                    <aura:iteration items="{!v.fillList}" var="file" indexVar='count'>
                        <div class="slds-text-body_small slds-text-color_error">{!file}&nbsp;&nbsp;&nbsp;
                        </div>
                    </aura:iteration>
                    <aura:if isTrue="{!v.showLoadingSpinner}">
                        <div class="slds-text-body_small slds-text-color_error">{!$Label.c.Uploading}... 
                            <img src="/auraFW/resources/aura/images/spinner.gif" class="spinner-img" alt="Loading"/>'
                        </div>
                    </aura:if>
                    <br/>
                </div>
                
            </div>            
            <aura:if isTrue="{!v.CreditNote.ERP7__Invoice__c!=''}">
                <div class="slds-p-left_large">

                <h3>{!$Label.c.SupplierInvoice_Invoice_Details}</h3><br/>
                <aura:if isTrue="{!v.invoice.ERP7__Down_Payment__c>0}">
                    {!$Label.c.SalesOrderConsole_Invoice}&nbsp;{!$Label.c.Type_ManageLeave} : {!v.invRT} &nbsp; {!$Label.c.Down_Payment_Percentage} : {!v.invoice.ERP7__Down_Payment__c}% &nbsp; {!$Label.c.Down_Payment} : {!v.invoice.ERP7__Total_Down_Payment_Amount__c} &nbsp; {!$Label.c.Order_RMA}&nbsp;{!$Label.c.UPS_Amount} : {!v.invoice.ERP7__Sales_Order_Amount__c}
                <!--Invoice of Type {!v.invRT} of total down percentage {!v.invoice.ERP7__Down_Payment__c}% and Down Payment Amount {!v.invoice.ERP7__Total_Down_Payment_Amount__c} of Order Amount {!v.invoice.ERP7__Sales_Order_Amount__c}-->
                </aura:if>
                <aura:if isTrue="{!v.invRT == 'Schedule_Invoice'}">
                    <a href="{!'/'+v.invoice.Id}" target="_blank">{!$Label.c.Schedule_UsersShiftMatch}&nbsp;{!$Label.c.Invoice} - {!v.invoice.Name}&nbsp;</a>&nbsp; {!$Label.c.SalesOrderConsole_Invoice}% :  {!v.invoice.ERP7__Sales_Invoice_Percentage__c}% &nbsp; {!$Label.c.Tax_Label} : {!v.invoice.ERP7__Sales_Invoice_Tax_Percentage__c}% &nbsp;{!$Label.c.Order_RMA}&nbsp;{!$Label.c.UPS_Amount} : {!v.invoice.ERP7__Sales_Order_Amount__c}
                        <!--Schedule Invoice - {!v.invoice.Name}&nbsp;</a>with {!v.invoice.ERP7__Sales_Invoice_Percentage__c}% of Sub Total with {!v.invoice.ERP7__Sales_Invoice_Tax_Percentage__c}% Tax Amount of Order Amount {!v.invoice.ERP7__Sales_Order_Amount__c}-->
                    
                </aura:if>
                </div>
            </aura:if>
            
            <div class="slds-grid slds-wrap  slds-m-top--small">
                
                <div class="slds-col slds-p-horizontal--medium slds-size--1-of-1">
                    <div class="slds-grid slds-wrap">
                        <aura:if isTrue="{!v.invRT == 'Schedule_Invoice'}">
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Order_RMA}&nbsp;{!$Label.c.UPS_Amount}<lightning:helptext content="{!$Label.c.With_VAT}" /></strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.invoice.ERP7__Sales_Order_Amount__c}"  step="any" variant="label-hidden" disabled="true"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                            
                        </div>
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Credit_Net_Amount}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.CreditNote.ERP7__Amount__c}"  step="any" variant="label-hidden" onchange="{!c.checkCreditAmount}"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                            
                        </div>
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Credit_Tax_Amount}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.CreditNote.ERP7__Tax_Amount__c}"  step="any" variant="label-hidden" onchange="{!c.checkCreditTax}"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                        </div>
                        
                       	<aura:if isTrue="{!v.AdvanceAmount>0}">
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Advance}&nbsp;{!$Label.c.RequisitionToPurchaseOrder_PRLI_Amount}&nbsp;{!$Label.c.Applied}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.CreditNote.ERP7__Advance_Amount_Applied__c}"  step="any" variant="label-hidden" onchange="{!c.checkAdvance}"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                        </div>
                        </aura:if>
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Acc_Pay_Balance}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!(v.totalSchAmount)}"  step="any" variant="label-hidden" disabled="true"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                        </div>
                        </aura:if>
                        
                        <aura:if isTrue="{!v.invoice.ERP7__Down_Payment__c>0}">
                            <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                                <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Order_RMA}&nbsp;{!$Label.c.UPS_Amount}<lightning:helptext content="{!$Label.c.With_VAT}" /></strong></label>
                                <div class="slds-form-element__control">
                                    <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.invoice.ERP7__Sales_Order_Amount__c}"  step="any" variant="label-hidden" disabled="true"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                </div>
                                
                            </div>
                            <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                                <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Credit_Net_Amount}</strong></label>
                                <div class="slds-form-element__control">
                                    <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.CreditNote.ERP7__Amount__c}"  step="any" variant="label-hidden" onchange="{!c.checkCreditAmount}"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                </div>
                                
                            </div>
                            <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                                <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Acc_Pay_Balance}</strong></label>
                                <div class="slds-form-element__control">
                                    <lightning:input aura:id="currency" type="number" formatter="currency" value="{!(v.totalSchAmount)}"  step="any" variant="label-hidden" disabled="true"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                </div>
                            </div>
                        </aura:if>
                        <aura:if isTrue="{!v.invRT == 'Sale'}">
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Cash_Payment_Amount}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:formattedNumber value="{!(v.CreditNote.ERP7__Amount__c + v.CreditNote.ERP7__Fees__c + v.CreditNote.ERP7__Shipping_Amount__c)}" />
                                    </div>
                        </div>
                        </aura:if>
                        <aura:if isTrue="{!v.CreditNote.ERP7__Return_Merchandise_Authorisation__c!=null}">
                        <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.ReStock_Fees}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Fees__c}"  step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Fees__c}" class="currency" />
                            </div>
                        </div>
                            
                        <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.ReStock_Tax}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Restock_Tax__c}"  step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Restock_Tax__c}" class="currency" />
                            </div>
                        </div>
                          
                         <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Shipping_Amount_Label}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Shipping_Amount__c}" step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Shipping_Amount__c}" class="currency" />
                            </div>
                        </div>
                            
                         <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Shipping_Tax}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Shipping_Tax__c}" step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Shipping_Tax__c}" class="currency" />
                            </div>
                        </div>
                        </aura:if>
                        <aura:if isTrue="{!v.invRT == 'Sale'}">
                            <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Shipping_Amount_Label}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Shipping_Amount__c}" step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Shipping_Amount__c}" class="currency" />
                            </div>
                        </div>
                        <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Total_Tax_Amount}</strong></label>
                            <div class="slds-form-element__control">
                                <lightning:formattedNumber value="{!(v.CreditNote.ERP7__Tax_Amount__c + v.CreditNote.ERP7__Restock_Tax__c + v.CreditNote.ERP7__Shipping_Tax__c)}" class="currency" />
                            </div>
                        </div>
                            <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Add_Subscription_Discount}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Shipping_Tax__c}" step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Discount_Amount__c}" class="currency" />
                            </div>
                        </div>                            
                            
                         <div class="slds-col slds-p-horizontal--medium  slds-form-element slds-size--1-of-6">
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Shipping_Tax}</strong></label>
                            <div class="slds-form-element__control">
                                <!--<lightning:input aura:id="currency" type="currency"  value="{!v.CreditNote.ERP7__Shipping_Tax__c}" step="0.0001" variant="label-hidden"/>-->
                                <lightning:formattedNumber value="{!v.CreditNote.ERP7__Shipping_Tax__c}" class="currency" />
                            </div>
                        </div>
                             
                        <aura:if isTrue="{!v.AdvanceAmount>0}">
                        <div class="slds-col slds-p-horizontal--medium slds-form-element slds-size--1-of-6">                     
                            <label class="slds-form-element__label" for="input-unique-id"><strong>{!$Label.c.Advance}&nbsp;{!$Label.c.RequisitionToPurchaseOrder_PRLI_Amount}&nbsp;{!$Label.c.Applied}</strong></label>
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="currency" type="number" formatter="currency" value="{!v.CreditNote.ERP7__Advance_Amount_Applied__c}"  step="any" variant="label-hidden" onchange="{!c.checkAdvance}"/><!-- onchange="{!c.UpdateTaxPercentage}" -->
                                    </div>
                        </div>
                        </aura:if>
                        
                        </aura:if>
                    </div>
                </div>
            </div>
            
            
            
            
            <div class="slds-grid slds-wrap  slds-m-top--small">
            </div>
            <div class="slds-tabs--card slds-tabs--default slds-m-top--small">
                    <ul class="slds-tabs--default__nav" role="tablist">
                        <li class="slds-tabs--default__item slds-is-active"  title="{!$Label.c.PO_Items_Total}" role="presentation">
                            <a class="slds-tabs--default__link"   role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-default-1__item">
                                <aura:if isTrue="{!v.invRT == 'Sale'}">
                                <i class="fa fa-tasks" aria-hidden="true"></i>&nbsp;{!$Label.c.PO_Items_Total}&nbsp; <lightning:formattedNumber style="currency" value="{!(v.CreditNote.ERP7__Amount__c + v.CreditNote.ERP7__Fees__c + v.CreditNote.ERP7__Shipping_Amount__c + v.CreditNote.ERP7__Tax_Amount__c + v.CreditNote.ERP7__Restock_Tax__c + v.CreditNote.ERP7__Shipping_Tax__c)}" />
                                <aura:set attribute="else">
                                    <i class="fa fa-tasks" aria-hidden="true"></i>&nbsp;{!$Label.c.PO_Items_Total}&nbsp; <lightning:formattedNumber style="currency" value="{!(v.invoice.ERP7__Sales_Order_Amount__c)}" />
                                 </aura:set>
                                </aura:if>
                            </a>
                        </li>
                    </ul>
                </div>
            <div>
                <table class="slds-table slds-table--bordered slds-table_cell-buffer">
                    <thead>
                        <tr class="slds-text-title--caps">
                            <th scope="col" > &nbsp;
                                <lightning:button label="{!$Label.c.Add_ManageLeave}" class="slds-button slds-button--neutral" onclick="{!c.addNew}"/>
                            </th>
                            <th scope="col" >
                                <div class="slds-truncate" title="">{!$Label.c.AddSubscription_Product}</div>
                            </th>
                            
                            <th scope="col">
                                <div class="slds-truncate" title="">{!$Label.c.Qty_Pick}</div>
                            </th>
                            
                            <th scope="col">
                                <div class="slds-truncate" title="Amount">{!$Label.c.Cash_Payment_Amount}</div>
                            </th>
                            <aura:if isTrue="{!v.CreateBillFLSCheck.DiscountAccess}">
                                <th scope="col">
                                    <div class="slds-truncate" title="Amount">{!$Label.c.Add_Subscription_Discount}</div>
                                </th>
                            </aura:if>
                            <th scope="col">
                                <div class="slds-truncate" title="Amount">{!$Label.c.Tax_Label}</div>
                            </th>
                            <th scope="col">
                                <div class="slds-truncate" title="Amount">{!$Label.c.Tax_Amount}</div>
                            </th>
                            <aura:if isTrue="{!v.CreateBillFLSCheck.OtherTaxAccess}">
                                <th scope="col">
                                    <div class="slds-truncate" title="Amount">{!$Label.c.Other_Tax_Percentage}</div>
                                </th>
                            </aura:if>
                            <aura:if isTrue="{!v.CreateBillFLSCheck.OtherTaxAccess}">
                                <th scope="col">
                                    <div class="slds-truncate" title="Amount">{!$Label.c.Other_Tax_Amount}</div>
                                </th>
                            </aura:if>
                            <th scope="col" width="150">
                                    <div class="slds-truncate" title="Contact">{!$Label.c.SalesOrderToPurchaseOrder_Customer_Organisation}</div>
                                </th>
                            <aura:if isTrue="{!v.CreateBillFLSCheck.TDSAccess}">
                                <th scope="col">
                                        <div class="slds-truncate" title="Contact">{!$Label.c.TDS}</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Contact">{!$Label.c.TDS_Amount}</div>
                                    </th> 
                                <th scope="col">
                                        <div class="slds-truncate" title="Contact">{!$Label.c.TDS_Account}</div>
                                    </th>
                            </aura:if>
                            <th scope="col">
                                <div class="slds-truncate" title="Sub Total">{!$Label.c.QuotationPDF_Sub_Total}</div>
                            </th>
                            <th scope="col">
                                <div class="slds-truncate" title="Description">{!$Label.c.ContractConsole_Description}</div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <aura:if isTrue="{!v.lineItems}">
                        <aura:iteration items="{!v.lineItems}" var="item" indexVar="ind">
                            <c:CreateCreditNoteItem disabledEditing="{!v.disabledEdit}" RT="{!v.setRT}" showExpenseAccount="{!v.showExpenseAccount}" aura:id="billItems" Item="{!item}" typeOpts="{!v.Itemtype}" ExpenseTypeOpts="{!v.Expensetype}" index="{!ind}" deleteIndex="{!v.deleteIndex}" TDS_Amount="{!v.TDS_Amount}" Field_Display="{!v.CreateBillFLSCheck.OtherTaxAccess}" TDS_Display="{!v.CreateBillFLSCheck.TDSAccess}" Discount_Display="{!v.CreateBillFLSCheck.DiscountAccess}" TDS_Rate="{!v.TDS_Rate}" TotalPrice="{!v.TotalPrice}" Discount="{!v.Discount}" Tax="{!v.Tax}" aura:Id="bill_Items" orglineItems="{!v.orglineItems}"/><!--//ASRA changed-->
                        </aura:iteration>
                        </aura:if>
                        
                    </tbody>
                </table>   
                
            </div>
            
            
            <div class="slds-p-top--small"></div>
            <div class="slds-grid slds-grid_align-center slds-p-around--small">
                <div class="slds-docked-form-footer">
                    
                    <div class="slds-col-1">
                        <span>       
                            <lightning:button label="{!$Label.c.Cancel_ManageLeave}" class="slds-button slds-button--neutral" onclick="{!v.cancelclick}" variant="neutral" />&nbsp;
                        </span>
                    </div>
                    
                    <div class="slds-col-1">
                        <span>
                            <div>
                                <lightning:button label="{!$Label.c.ContractConsole_Save}" class="slds-button slds-button__brand" onclick="{!c.saveBill}" variant="brand" disabled="{!v.showMmainSpin}"/>
                            </div>
                        </span>
                    </div>
                </div>
            </div>
        </div>
     </aura:if>
     <aura:if isTrue="{!v.showMmainSpin}">
        <span class="spincls">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if>    
    
</aura:component>