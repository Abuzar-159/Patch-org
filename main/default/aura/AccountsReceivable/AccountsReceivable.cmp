                                            <li>
                                                <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                            </li>
                                            <li>
                                                <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}"  onclick="{!c.Previous}"> &lt; {!$Label.c.Previous}</a> <!-- -->
                                            </li>
                                            
                                            <li>
                                                <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.Next}">{!$Label.c.RequisitionToPurchaseOrder_Next} &gt;</a> <!--  -->
                                            </li>
                                            <li>
                                                <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                                
                            </aura:if> 
