                                                                    {!$Label.c.Acc_Pay_Due_Amount} <!--Acc_Pay_Due_Amount Due <br/>{!$Label.c.PaySlip_Amount}-->
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
