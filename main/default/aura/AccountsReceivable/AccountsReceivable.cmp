                                        <div id="tab-default-1" class="slds-tabs--default__content slds-show AccountsReceivable-newClass15" role="tabpanel" aria-labelledby="tab-default-1__item">             
                                            <aura:if isTrue="{!v.standardOrder}">
                                                <table id="example" class="slds-table">
                                                    <thead>
                                                        <tr class="slds-text-title--caps"> 
                                                            <th class="slds-cell-shrink" scope="col">                          
                                                            </th>
                                                            
                                                            <th scope="col" class="toggle slds-th__action slds-text-link--reset ">
                                                                <div class="slds-truncate2 " title="">   
                                                                    
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="Name" title="Sort" class="AccountsReceivable-newClass47;">
                                                                        {!$Label.c.Name_ManageLeave}
                                                                        <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                            <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Name_ManageLeave}" title="sort" /> 
                                                                            <aura:set attribute="else">
                                                                                <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Name_ManageLeave}" title="sort"/> 
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </span> 
                                                                    
                                                                </div>                    
                                                                
                                                            </th>
                                                            
                                                            <th scope="col" class="slds-is-sortable">
