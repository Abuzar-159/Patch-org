                                                                                <span class="slds-button--destructive">{!$Label.c.No}</span>
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </div>                                                        
                                                                </div>
                                                            </td>
                                                            <td class="slds-cell-shrink" data-label="">
