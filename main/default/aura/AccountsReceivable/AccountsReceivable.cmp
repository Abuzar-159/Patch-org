                                                                    {!$Label.c.Aging_Days} <!--Aging<br/>(Days)-->
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
                                                                        <aura:set attribute="else">
                                                                            <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/> 
                                                                        </aura:set>
                                                                    </aura:if>                                  
                                                                </span>
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="Status"> 
                                                                <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Order__r.ERP7__Status__c" title="{!$Label.c.Acc_Recev_Status_Entered}" class="AccountsReceivable-newClass47">
                                                                    {!$Label.c.Acc_Recev_Status_Entered}
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
                                                                        <aura:set attribute="else">
                                                                            <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/> 
                                                                        </aura:set>
                                                                    </aura:if>                                        
                                                                </span> 
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="Status"> 
                                                                <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Order__r.ERP7__Status__c" title="{!$Label.c.Type_ManageLeave}" class="AccountsReceivable-newClass47">
                                                                    {!$Label.c.Type_ManageLeave}
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
                                                                        <aura:set attribute="else">
                                                                            <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/> 
                                                                        </aura:set>
                                                                    </aura:if>                                      
                                                                </span> 
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="Posted">
                                                                <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Posted__c" title="{!$Label.c.Acc_Recev_Posted}" class="AccountsReceivable-newClass47">
                                                                    {!$Label.c.Acc_Recev_Posted}
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
                                                                        <aura:set attribute="else">
                                                                            <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/> 
                                                                        </aura:set>
                                                                    </aura:if>                                     
                                                                </span> 
                                                                
                                                                
                                                            </div>
                                                        </th>                   
                                                        <th class="slds-cell-shrink" scope="col">
                                                            {!$Label.c.AddSubscription_Action}
                                                        </th>  
                                                        
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    
                                                    <aura:iteration items="{!v.InvoiceList}" var="inv" indexVar="Index">      
                                                        <tr class="{!inv.ERP7__Due_Date__c>v.TODAY?'slds-hint-parent':'slds-hint-parent redClass'}">    
                                                            <aura:if isTrue="{!or(inv.ERP7__Status__c=='Approved', !approvalProcess)}">
                                                                <td><div class="pt-2">
                                                                    <lightning:input type="checkbox" variant="label-hidden" aura:id="cbox_bill" name="{!inv.Id}" onchange="{!c.selectedPO}"/>&nbsp;
                                                                    </div>
                                                                </td>
                                                                <aura:set attribute="else">
                                                                    <td><div class="pt-2">
                                                                        </div></td>
                                                                </aura:set>
                                                            </aura:if>
                                                            <td scope="row" data-label="">
                                                                <div class="slds-truncate2" title="{!inv.Name}"> {!Index+1}. &nbsp; 
                                                                    <a href="{!'/'+inv.Id}" target="_blank">{!inv.Name}</a>
                                                                </div>
                                                                
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="">
                                                                    <!--<a href="{!'/'+inv.ERP7__Order__r.Id}" target="_blank">{!inv.ERP7__Order__r.Name}</a>-->
                                                                    <a href="{!inv.ERP7__Order__r.Name !=undefined?'/'+inv.ERP7__Order__r.Id:'/'+inv.ERP7__Order_S__r.Id}" target="_blank">{!inv.ERP7__Order__r.Name !=undefined?inv.ERP7__Order__r.Name:inv.ERP7__Order_S__r.Name}</a>
                                                                </div>
                                                                
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Account__r.Name}">
                                                                    <a href="{!'/'+inv.ERP7__Account__r.Id}" target="_blank">{!inv.ERP7__Account__r.Name}</a>
                                                                </div>
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Invoice_Amount__c}">
                                                                    <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!inv.ERP7__Invoice_Amount__c}" />    
                                                                </div> 
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Amount_Paid__c}">
                                                                    <lightning:formattedNumber currencyDisplayAs="code" style="currency" value="{!inv.ERP7__Amount_Paid__c}" /> 
                                                                </div>
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Total_Due__c}">
                                                                    <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!inv.ERP7__Total_Due__c}" />     
                                                                </div>
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Invoice_Date__c}">
                                                                    <lightning:formattedDateTime value="{!inv.ERP7__Invoice_Date__c}" year="numeric" month="numeric" day="numeric" timeZone="{!$Locale.timezone}"/> 
                                                                </div> <!-- ERP7__Order__r.ERP7__Order_Date__c -->
                                                            </td> 
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Due_date_days__c}">
                                                                    <!--<lightning:formattedDateTime value="{!inv.ERP7__Due_Date__c}" /> -->
                                                                    {!inv.ERP7__Due_date_days__c}
                                                                </div>
                                                            </td> 
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.ERP7__Status__c}">
                                                                    <lightning:formattedText value="{!inv.ERP7__Status__c}" /> <!-- ERP7__Order__r.ERP7__Status__c ERP7__Status__c -->     
                                                                </div>  
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!inv.RecordType.Name}">
                                                                    <aura:if isTrue="{!inv.RecordType.Name == 'Advance'}">
                                                                        {!$Label.c.AdvanceInvoice}
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!inv.RecordType.Name == 'Sales'}">
                                                                                {!$Label.c.Sales_Invoice}
                                                                                <aura:set attribute="else">
                                                                                    <aura:if isTrue="{!inv.RecordType.Name == 'Schedule Invoice'}">
                                                                                        {!$Label.c.Schedule_UsersShiftMatch}&nbsp;{!$Label.c.Invoice}
                                                                                        <aura:set attribute="else">
                                                                                            <lightning:formattedText value="{!inv.RecordType.Name}" /> <!-- ERP7__Order__r.ERP7__Status__c ERP7__Status__c -->     
                                                                                        </aura:set>
                                                                                    </aura:if>
                                                                                </aura:set>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                    
                                                                </div>  
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="">                        
                                                                    <div class="slds-truncate2" title="">
                                                                        <aura:if isTrue="{!(inv.RecordType.Name == 'Advance')}">
                                                                            <span class="slds-button_destructive" disabled="true">NA</span>
                                                                            <aura:set attribute="else">
                                                                                <aura:if isTrue="{!inv.ERP7__Posted__c}">
                                                                                    <span class="slds-button--success">{!$Label.c.Yes_UserAvailabilities}</span>
                                                                                    <aura:set attribute="else">
                                                                                        <span class="slds-button--destructive">{!$Label.c.No}</span>
                                                                                    </aura:set>
                                                                                </aura:if>
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </div>                                                        
                                                                </div>
                                                            </td> 
                                                            
                                                            <td class="slds-cell-shrink" data-label="">
                                                                <aura:if isTrue="{!or(inv.ERP7__Status__c=='Approved', !approvalProcess)}">
                                                                    <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" iconSize="small" variant="border-filled" onselect="{! c.handleinvoicemenu }" menuAlignment="right">
                                                                        <aura:if isTrue="{!and(inv.RecordType.Name!='Advance', inv.RecordType.Name!='On Account Payment')}">
                                                                            <aura:if isTrue="{!inv.ERP7__Posted__c==false}">
                                                                                <lightning:menuItem label="{!$Label.c.Acc_Recev_Post}" value="{!inv.Id}" title="{!Index}"/>
                                                                                <aura:set Attribute="else">
                                                                                    <lightning:menuItem label="{!$Label.c.Acc_Recev_Unpost}" value="{!inv.Id}" title="{!Index}"/>
                                                                                </aura:set>
                                                                            </aura:if>
                                                                        </aura:if>
                                                                        <aura:if isTrue="{!(inv.ERP7__Posted__c?true:or(inv.RecordType.Name=='Advance', inv.RecordType.Name=='On Account Payment')?true:false)}"> 
                                                                            <lightning:menuItem label="{!$Label.c.Acc_Recev_Record_Payment}" value="{!inv.Id}"/>
                                                                        </aura:if>
                                                                    </lightning:buttonMenu>
                                                                </aura:if>
                                                            </td>
                                                            
                                                        </tr>
                                                    </aura:iteration> 
                                                    
                                                </tbody>
                                            </table>
                                            <div class="epr_Mark7">
                                                <div class=" slds-docked-form-footer">
                                                    <aura:if isTrue="{!or(v.CustomerList.length>0,v.InvoiceList.length>0,v.PaymentList.length>0)}">
                                                        <div class="col-md-2" >
                                                            <div class="slds-grid" >
                                                                <div class="slds-col AccountsReceivable-newClass18">
                                                                    {!$Label.c.Acc_Recev_Show}&nbsp;
                                                                </div>  
                                                                <div class="slds-col  AccountsReceivable-newClass19"> 
                                                                    <lightning:select class=" slds-show_inline-block "  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                                        <option value="10">10</option>
                                                                        <option value="25">25</option>
                                                                        <option value="50">50</option>
                                                                        <option value="100">100</option>
                                                                        <option value="150">150</option>
                                                                    </lightning:select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.InvoiceList.length>0}">
                                                        <div class="col-md-3">
                                                            {!$Label.c.Acc_Recev_Showing}&nbsp; <span class="text-lightblue">{!v.startCount}-{!v.endCount}</span> &nbsp;{!$Label.c.Acc_Recev_of_total}&nbsp; <span class="text-lightblue"> {!v.recSize} </span> &nbsp;{!$Label.c.Acc_Recev_Records}
                                                        </div>
                                                    </aura:if> 
                                                    <aura:if isTrue="{!v.InvoiceList.length>0}">
                                                        
                                                        <div class="col-md-5">
                                                            <nav aria-label="Page navigation example">
                                                                <ul class="pagination AccountsReceivable-newClass22">
                                                                    <li>
                                                                        <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                                                    </li>
                                                                    <li>
                                                                        <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}"  onclick="{!c.Previous}"> &lt; {!$Label.c.Previous}</a> <!-- -->
                                                                    </li>
                                                                    
                                                                    <li>
                                                                        <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.Next}">{!$Label.c.RequisitionToPurchaseOrder_Next} &gt;</a> <!--  -->
                                                                    </li>
                                                                    <li>
                                                                        <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                                                    </li>
                                                                </ul>
                                                            </nav>
                                                        </div>
                                                        
                                                    </aura:if> 
                                                    <aura:if isTrue="{!v.InvoiceList.length>0}">
                                                        
                                                        <div class="col-md-2">
                                                            <div class="slds-grid">
                                                                <div class="slds-col AccountsReceivable-newClass25">
                                                                    {!$Label.c.page}
                                                                </div>
                                                                <div class="slds-col">
                                                                    <lightning:input type="number" variant="label-hidden" aura:id="ikINV" value="{!v.PageNum}" oncommit="{!c.OfsetChange}" class="width100p"/> 
                                                                </div>
                                                                <div class="slds-col AccountsReceivable-newClass26"><span class="text-lightblue"> {!$Label.c.page_of}&nbsp; {!v.PNS.length}</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                    </aura:if>
                                                </div>
                                            </div>
                                            <aura:renderIf isTrue="{!v.criteriaMsgInv !=''}">                                   
                                                <div class="slds-notify_container slds-is-absolute AccountsReceivable-newClass12">
                                                    <div class="slds-notify slds-notify_toast slds-theme_warning AccountsReceivable-newClass27" role="alert">
                                                        <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>
                                                        <lightning:icon iconName="utility:warning" size="small" alternativeText="{!$Label.c.warning_UsersShiftMatch}"/>
                                                        <div class="slds-notify__content AccountsReceivable-newClass28">
                                                            <h2 class="slds-text-heading_small AccountsReceivable-newClass29">{!v.criteriaMsgInv}</h2>
                                                        </div>
                                                    </div>
                                                </div>  
                                                
                                            </aura:renderIf>  
                                        </div> 
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>  
                </aura:if>
                
                <!-- </aura:if> -->   
                
                <aura:if isTrue="{!and(equals(v.showTabs,'inv'),v.grid)}">
                    <div class="maqsood erp_Mark7">
                        <div class="slds-grid">
                            <div class="slds-col">
                                <h6 class="slim-card-title">
                                    <c:StockTakeSearch searchString="{!v.setSearch}"/>
                                </h6>
                            </div>
                            <div class="slds-col">
                                
                                
                            </div>
                            <div class="col-8 text-right">
                                <div class="slds-grid float-right">
                                    <div class="AccountsPayable-newClass4  slds-m-right_small">
                                        <lightning:select name="controllerFld"
                                                          value="{!v.DueFilter}"
                                                          label="{!$Label.c.Acc_Recev_Invoice_Due}" onchange="{!c.onControllerFieldChange}" class="laebel-overide"><!-- onchange="{!c.onControllerFieldChange}" -->
                                            <option value="-1">{!$Label.c.Acc_Recev_All_Invoices}</option>
                                            <option value="0">{!$Label.c.Acc_Recev_Overdue_Invoices}</option>
                                            <option value="30">0-30 days</option>
                                            <option value="60">31-60 days</option>
                                            <option value="90">61-90 days</option>
                                            <option value="2000">90+ days</option>
                                        </lightning:select>
                                    </div>
                                    <div class="AccountsPayable-newClass4" >
                                        <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" />
                                    </div>
                                    <div class="maqdropdown">                                                                
                                        <aura:if isTrue="{!v.showTabs=='cus'}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.getCustomerPopup}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Customer} <span class="caret"></span>
                                            </a>
                                        </aura:if>
                                        <aura:if isTrue="{!v.showTabs=='inv'}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createInvoice}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Invoice} <span class="caret"></span>
                                            </a>
                                        </aura:if>
                                        <aura:if isTrue="{!v.showTabs=='pay'}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.getPaymentPopup}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Payment} <span class="caret"></span>
                                            </a>
                                        </aura:if>
                                        
                                        <aura:if isTrue="{!equals(v.showTabs,'cre')}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createCredit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Credit_Note} <span class="caret"></span>
                                            </a>
                                        </aura:if>  
                                        <aura:if isTrue="{!equals(v.showTabs,'deb')}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createDebit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Debit_Note} <span class="caret"></span>
                                            </a>
                                        </aura:if> 
                                        <aura:if isTrue="{!v.showTabs=='dun'}">
                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createDunning}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Dunning} <span class="caret"></span>
                                            </a>
                                        </aura:if>
                                    </div>
                                </div>
                            </div>
                            <div class="slds-p-right_small">
                                    <a title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.navigateToDashboard}">
                                        <img src="/resource/ERP7__ERPCustomIcons/erpicons/research.png" style="width:30px"></img>
                                    </a>
                                    </div>
                            <div class="slds-col">
                                <div class="grid-list-icon"> 
                                    
                                    <div class="AccountsReceivable-newClass5">
                                        <a class="{!(v.grid)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8'}" title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.gridView}">
                                            <i class="fa fa-th-large"></i>
                                        </a>
                                        <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
                                            <i class="fa fa-list"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row m-0 pb-5 bg-gp">
                            
                            <aura:iteration items="{!v.InvoiceList}" var="inv" indexVar="Index">
                                
                                <div class="col-md-3 mt-2">
                                    
                                    <div class="card-contact p-3">
                                        <div class="slds-grid text-left pb-2">
                                            <div class="col-1 pl-0">
                                                <lightning:input type="checkbox" variant="label-hidden" aura:id="cbox_bill" name="{!inv.Id}" onchange="{!c.selectedPO}" />
                                            </div>
                                            <div class="col-9 pl-0">
                                                <h5 class="">
                                                    <a href="{!'/'+inv.Id}" target="_blank"   class="contact-name"><p>{!Index+1}.&nbsp;{!inv.Name}</p></a>
                                                </h5>
                                            </div>
                                            <div class="col-2 pr-0 text-right">
                                                <p>
                                                    <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" iconSize="small" variant="border-filled" onselect="{! c.handleinvoicemenu }" menuAlignment="right">
                                                        <aura:if isTrue="{!and(inv.RecordType.Name!='Advance', inv.RecordType.Name!='On Account Payment')}">
                                                            <aura:if isTrue="{!inv.ERP7__Posted__c==false}">
                                                                <lightning:menuItem label="{!$Label.c.Acc_Recev_Post}" value="{!inv.Id}" title="{!Index}"/>
                                                                <aura:set Attribute="else">
                                                                    <lightning:menuItem label="{!$Label.c.Acc_Recev_Unpost}" value="{!inv.Id}" title="{!Index}"/>
                                                                </aura:set>
                                                            </aura:if>
                                                        </aura:if>
                                                        <aura:if isTrue="{!(inv.ERP7__Posted__c?true:or(inv.RecordType.Name=='Advance', inv.RecordType.Name=='On Account Payment')?true:false)}"> 
                                                            <lightning:menuItem label="{!$Label.c.Acc_Recev_Record_Payment}" value="{!inv.Id}"/>
                                                        </aura:if>
                                                    </lightning:buttonMenu>
                                                </p>
                                            </div>
                                        </div>
                                        
                                        <p class="contact-item">
                                            <span>{!$Label.c.Acc_Recev_Order_Number}:</span>
                                            <span>
                                                <a href="{!inv.ERP7__Order__r.Name !=undefined?'/'+inv.ERP7__Order__r.Id:'/'+inv.ERP7__Order_S__r.Id}" target="_blank">{!inv.ERP7__Order__r.Name !=undefined?inv.ERP7__Order__r.Name:inv.ERP7__Order_S__r.Name}</a>
                                            </span>
                                        </p>
                                        <p class="contact-item">
                                            <span>{!$Label.c.SalesOrderToPurchaseOrder_Customer_Organisation}:</span>
                                            <a href="{!'/'+inv.ERP7__Account__r.Id}" target="_blank">{!inv.ERP7__Account__r.Name}</a>
                                        </p>
                                        <p class="contact-item">
                                            <span>{!$Label.c.UPS_Setup_Invoice_Amount} :</span>
                                            <a href="javascript:void(0);">{!$Locale.currency}&nbsp;{!inv.ERP7__Invoice_Amount__c}</a>
                                            
                                        </p>
                                        
                                        <p class="contact-item">
                                            <span>{!$Label.c.Invoice_Amount_Paid} :</span>
