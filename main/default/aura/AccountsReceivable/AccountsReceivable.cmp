                                                                <div class="slds-truncate2" title="{!Index+1}"> {!Index+1}. &nbsp;
                                                                </div>
                                                                
                                                            </td>
                                                            <td scope="row" data-label=""> 
                                                                <!-- {!Index+1}. &nbsp; -->
                                                                <div class="slds-truncate2" title="{!deb.Name}"><a href="{!'/'+deb.Id}" target="_blank">{!deb.Name}</a></div>
                                                                
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!deb.ERP7__Account__r.Name}">
                                                                    <a href="{!'/'+deb.ERP7__Account__r.Id}" target="_blank">{!deb.ERP7__Account__r.Name}</a>
                                                                    
                                                                </div>
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!deb.ERP7__Credit__c}">
                                                                    <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!deb.ERP7__Credit__c}" /> 
                                                                </div>
                                                            </td>
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!deb.ERP7__Debit__c}">
                                                                    <lightning:formattedNumber currencyDisplayAs="code" style="currency" value="{!deb.ERP7__Debit__c}" />     
                                                                </div>
                                                            </td>
                                                            
                                                            <td data-label="">
                                                                <div class="slds-truncate2" title="{!deb.ERP7__Amount__c}">
