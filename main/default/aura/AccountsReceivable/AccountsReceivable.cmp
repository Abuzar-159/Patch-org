                                                                    {!$Label.c.Order_RMA} <br/> {!$Label.c.Number}
                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
                                                                        <aura:set attribute="else">
                                                                            <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/> 
