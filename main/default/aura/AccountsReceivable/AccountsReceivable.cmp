                                                                        </aura:if>
                                                                    </span> 
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate2" title="">
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Due_Amount__c" title="Sort" class="AccountsReceivable-newClass47;">
                                                                        {!$Label.c.Acc_Pay_Due_Amount}
                                                                        <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                            <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Acc_Pay_Due_Amount}" title="sort" /> 
                                                                            <aura:set attribute="else">
                                                                                <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Acc_Pay_Due_Amount}" title="sort"/> 
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </span>
                                                                </div>
                                                            </th>
                                                            
                                                            <th class="slds-cell-shrink" scope="col">
                                                                Action
                                                            </th>
                                                        </tr>
                                                    </thead>
