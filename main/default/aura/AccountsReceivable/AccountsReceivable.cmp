                                                                    <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                        <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}" /> 
