<aura:component controller="SupplierInvoice" access="global" implements="flexipage:availableForAllPageTypes,force:appHostable,forceCommunity:availableForAllPageTypes">
    <head> 
        <meta charset="utf-8"/>   
        <meta name="viewport" content="width=device-width,initial-scale=1"/>   
        <ltng:require styles="{!join(',',
                              $Resource.TablesSort+'/TablesSort/TablesSort/css/dataTables.bootstrap.min.css',$Resource.SLDS+'/assets/styles/salesforce-lightning-design-system-vf.css',$Resource.SLDS+'/assets/styles/salesforce-lightning-design-system-vf.min.css',
                              $Resource.PickPackShipResource+'/assets/styles/erp_mark7_bootstrap.css',$Resource.PickPackShipResource+'/assets/styles/font-awesome.css')}" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>  
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/AccountsReceivable.css"/> 
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        
    </head>  
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchEventHandler}"/> 
    <!--<aura:handler name="change" value="{!v.Organisation}" action="{!c.getOrganisedRecords}"/>-->
    <aura:handler name="change" value="{!v.Organisation.Id}" action="{!c.getOrganisedRecords}"/>   
    <aura:attribute name="Organisation" type="Map" default="{}"/>    
    <aura:attribute name="showTabs" type="String" default="cus"/> 
    <aura:attribute name="CustomerList" type="String[]" default=""/> 
    <aura:attribute name="SelectedPOS" type="String[]" default=""/> 
    <aura:attribute name="fromAccRec" type="Boolean" default="false" />
    <aura:attribute name="debitList"    type="String[]" default=""/>
    <aura:attribute name="InvoiceList" type="String[]" default=""/> 
    <aura:attribute name="PaymentList" type="String[]" default=""/> 
    <aura:attribute name="CouponList" type="String[]" default=""/> 
    <aura:attribute name="CreditList" type="String[]" default=""/> 
    <aura:attribute name="AEList" type="String[]" default=""/> 
    <aura:attribute name="DunningList" type="String[]" default=""/>    
    <aura:attribute name="CustomerListD" type="String[]" default=""/> 
    <aura:attribute name="InvoiceListD" type="String[]" default=""/> 
    <aura:attribute name="PaymentListD" type="String[]" default=""/> 
    <aura:attribute name="CouponListD" type="String[]" default=""/> 
    <aura:attribute name="CreditListD" type="String[]" default=""/>
    <aura:attribute name="DebitListD" type="String[]" default=""/>
    <aura:attribute name="AEListD" type="String[]" default=""/> 
    <aura:attribute name="DunningListD" type="String[]" default=""/> 
    <aura:attribute name="SaveErrorMsg" type="String" default=""/>   
    <aura:attribute name="RecordTypeId" type="String" default=""/>    
    <aura:attribute name="CustomerRTList" type="String[]" default=""/>
    <aura:attribute name="showCP" type="Boolean" default="false"/> 
    <aura:attribute name="PaymentRTList" type="String[]" default=""/>
    <aura:attribute name="showPP" type="Boolean" default="false"/> 
    <aura:attribute name="CouponRTList" type="String[]" default=""/>
    <aura:attribute name="showCouP" type="Boolean" default="false"/>
    <aura:attribute name="approvalProcess" type="Boolean" default="false"/>
    <aura:attribute name="tabular" type="Boolean" default="true"/>
    <aura:attribute name="displayDebitNote" type="Boolean" default="false"/>
    <aura:attribute name="grid" type="Boolean" default="false"/>    
    <aura:attribute name="Id" type="String" default=""/>  
    <aura:attribute name="InvId" type="String" default=""/>   
    <aura:attribute name="DueFilter" type="Integer" default="-1"/> 
    <aura:attribute name="showMainSpin" type="Boolean" default="false"/> 
    <aura:attribute name="fetchRecordsBool" type="Boolean" default="true"/> 
    <aura:attribute name="Account" type="Map" default="{}"/>
    <aura:handler name="SortRecord" event="c:SortRecord" action="{!c.SortRecodEventHandler}"/>  
    <aura:attribute name="OrderBy" type="String" default="Name"/> 
    <aura:attribute name="Order" type="String" default="DESC"/> 
    <aura:attribute name="LoaderControll" type="Boolean" default="true"/> 
    <aura:attribute name="CreditFields" type="String" default=""/> 
    <aura:attribute name="DunningFields" type="String" default=""/> 
    <aura:attribute name="criteriaMsgCus" type="String" default=""/> 
    <aura:attribute name="criteriaMsgInv" type="String" default=""/> 
    <aura:attribute name="criteriaMsgPay" type="String" default=""/> 
    <aura:attribute name="criteriaMsgCre" type="String" default=""/> 
    <aura:attribute name="criteriaMsgDun" type="String" default=""/>    
    <aura:attribute name="criteriaMsgDebit" type="String" default=""/>
    <aura:attribute name="InvoicesId" type="String[]" default=""/>
    <aura:attribute name="TODAY" type="Date"/>
    <aura:attribute name="selectedCustomersId" type="String[]" default=""/> 
    <aura:attribute name="SCIds" type="List"/> 
    <aura:attribute name="selectedCustomers" type="String[]" default=""/> 
    <aura:attribute name="AccountStatementURL" type="String"/> 
    
    <aura:attribute name="PNS" type="Object"/>
    <aura:attribute name="startCount" type="Integer" default="0"/>
    <aura:attribute name="endCount" type="Integer" default="0"/>
    <aura:attribute name="Offset" type="Integer" default="0"/>
    <aura:attribute name="recSize" type="Integer" default="0"/>
    <aura:attribute name="PageNum" type="Integer" default="0"/>
    <aura:attribute name="show" type="Integer" default="{!$Label.c.Pagination_Default_Limit}"/>
    <aura:attribute name="CheckOffset" type="Boolean" default="false"/>
    
    <aura:attribute name="CustomerListForSearch" type="String[]" default=""/> 
    <aura:attribute name="InvoiceListForSearch" type="String[]" default=""/> 
    <aura:attribute name="PaymentListForSearch" type="String[]" default=""/> 
    <aura:attribute name="CouponListForSearch" type="String[]" default=""/> 
    <aura:attribute name="CreditListForSearch" type="String[]" default=""/> 
    <aura:attribute name="DebitListForSearch" type="String[]" default=""/> 
    <aura:attribute name="setSearch" type="String" />
    <aura:attribute name="spinnerContent" type="String" default="{!$Label.c.Please_wait_while_loading_UserAvailabilities}"/>
    
    <!-- start Atrribute used for MultiOrderSingleInvoice -->
    <aura:attribute name="OrderList" type="String[]" default=""/> 
    <aura:attribute name="SalesOrderList" type="String[]" default=""/> 
    <aura:attribute name="criteriaMsgOrd" type="String" default=""/>
    <aura:attribute name="standardOrder" type="Boolean" default="false"/>
    <aura:attribute name="SelectedSalOrd" type="List"/>
    <aura:attribute name="SelectedOrd" type="List"/>
    <aura:attribute name="displayMultipleSalOrd" type="Boolean" default="false"/>
    <aura:attribute name="displayMultipleOrd" type="Boolean" default="false"/>
    <aura:attribute name="MultiOrderAgainstSingleInv" type="Boolean" default="false"/>
    <aura:attribute name="AccountId" type="String" default=""/> 
    <!-- end -->
    
    <div class="erp_mark7 AccountsReceivable-newClass1 erp bg-tb" aura:Id="body">
        <div class="slim-pageheader slds-p-around_small bg-white slds-hide">
            <ol class="breadcrumb slim-breadcrumb">
                <li class="breadcrumb-item">
                    <div class="slds-button-group" role="group"> 
                        
                        <div class="AccountsPayable-newClass4" >
                            
                            <div class="AccountsReceivable-newClass3" >
                                <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}"
                                                     IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>                               
                            </div>
                            
                        </div>
                        
                        <div class="maqdropdown">
                            
                        </div>
                    </div>
                    
                </li>
                
            </ol>
            <h6 class="slim-pagetitle">{!$Label.c.Accounts_Receivable}</h6>
        </div>
        
        <div class="slim-navbar">
            <div class="container-fluid">
                
                <ul class="nav">
                    <li class="{!v.showTabs == 'cus' ? 'nav-item  active' : 'nav-item '}" label="{!$Label.c.CreateAddress_Customer}" name="cus" onclick="{!c.calledCustomer}">
                        <a class="nav-link" href="javascript:void(0);"  >
                            <i class="icon fa fa-user"></i>
                            <span>{!$Label.c.CreateAddress_Customer}</span>
                        </a>
                        
                        
                    </li>
                    <aura:if isTrue="{!v.MultiOrderAgainstSingleInv}">
                        <li class="{!v.showTabs == 'ord' ? 'nav-item active' : 'nav-item '}" label="{!$Label.c.Acc_Recev_Orders}" name="ord" onclick="{!c.calledOrders}">
                            <a class="nav-link" href="javascript:void(0);">
                                <i class="icon fa fa-file-text-o"></i>
                                <span>{!$Label.c.Acc_Recev_Orders}</span>
                            </a>
                            
                            
                            
                        </li>
                    </aura:if>
                    <li class="{!v.showTabs == 'inv' ? 'nav-item active' : 'nav-item '}" label="{!$Label.c.Acc_Recev_Invoices}" name="inv" onclick="{!c.calledInvoices}">
                        <a class="nav-link" href="javascript:void(0);">
                            <i class="icon fa fa-file-text-o"></i>
                            <span>{!$Label.c.Acc_Recev_Invoices}</span>
                        </a>
                        
                        
                        
                    </li>
                    
                    <li class="{!v.showTabs == 'pay' ? 'nav-item active' : 'nav-item '}" name="pay" onclick="{!c.calledPayments}">
                        <a class="nav-link" href="javascript:void(0);">
                            <i class="icon fa fa-credit-card"></i>
                            <span>{!$Label.c.Acc_Recev_Payments}</span>
                        </a>
                        
                        
                    </li>
                    
                    
                    <li class="{!v.showTabs == 'cre' ? 'nav-item  active' : 'nav-item'}" name="cre" onclick="{!c.calledCreditNotes}">
                        <a class="nav-link" href="javascript:void(0);" data-toggle="dropdown">
                            <i class="icon fa fa-credit-card-alt"></i>
                            <span>{!$Label.c.Acc_Recev_Credit_Notes}</span>
                        </a>
                        
                    </li>
                    
                    
                    
                </ul>
            </div><!-- container -->
        </div>
        <aura:if isTrue="{!v.showMainSpin}">  
            <div class="custom-spinner slds-spinner_container ">
                <div role="status" class="slds-spinner slds-spinner_large slds-spinner_brand">
                    <span class="slds-assistive-text">Loading</span>
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                    
                </div>
                <div class="custom-loading-text">
                    {!v.spinnerContent}
                </div>
            </div>
            <!--span class="AccountsReceivable-newClass2">
                <lightning:spinner variant="brand" size="large" aura:id="mainSpin" class="mainSpinClass"/>
            </span-->
        </aura:if>
        <div class="slds-container--fluid ">
            <div class="slds-page-header slds-hide">
                <div class="slds-media">
                    <div class="slds-media__figure">
                        <span class="slds-icon_container  slds-icon--large slds-icon-standard-contact slds-p-left_x-small slds-p-top_x-small" title="" aria-hidden="true">
                            <div class="slds-col slds-no-flex slds-grid slds-align-center ">
                                <lightning:icon iconName="utility:description" size="medium" alternativeText="description!" title="description" variant="bare"  /> 
                            </div> 
                        </span>
                    </div>
                    <div class="slds-media__body">
                        <span class="slds-page-header__title slds-truncate slds-align-middle" title="{!$Label.c.Accounts_Receivable}">{!$Label.c.Accounts_Receivable} </span>
                        <!-- <div class="slds-is-sortable">  </div> -->
                        
                        <p class="slds-text-body_small slds-line-height--reset">
                            <aura:iteration items="{!v.selectedCustomers}" var="sitem" indexVar="index"><!--end="2"-->
                                <lightning:pill label="{!sitem.Name}" name="{!sitem.Id}" onremove="{! c.removeCustomer }" title="{!index}"/>                              
                            </aura:iteration>
                        </p>
                        
                        &nbsp; &nbsp;
                        
                        
                    </div> 
                    
                    <div class="slds-col slds-no-flex slds-grid slds-align-top slds-p-bottom_xx-small">
                        <div class="slds-button-group" role="group">
                            
                            <div class="AccountsReceivable-newClass3" >
                                <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}"
                                                     IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>                               
                            </div>
                            &nbsp;
                            
                            <div class="maqdropdown">                                                                
                                
                                
                            </div>
                        </div>
                    </div>  
                    
                </div>
            </div>
            <!-- ______________________-->
            <div class="slds-tabs--default ">
                
                
                <!--_______________________________-->
                <aura:if isTrue="{!and(equals(v.showTabs,'deb'),v.tabular)}">
                    <div class="{!v.showTabs=='deb'?'slds-show':'slds-hide'}">
                        <div class="maqsood erp_Mark7">
                            
                            <div class="card shadow-custom AccountsReceivable-newClass9">
                                <div class="card-body AccountsReceivable-newClass10">
                                    <div class="slds-grid">
                                        <div class="slds-col">
                                            <h6 class="slim-card-title">
                                                <c:StockTakeSearch searchString="{!v.setSearch}"/>
                                            </h6>
                                        </div>
                                        <div class="slds-col">
                                            
                                            
                                        </div>
                                        <div class="col-8 text-right">
                                            <div class="slds-grid float-right">
                                                <div class="AccountsPayable-newClass4" >
                                                    <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" />
                                                </div>
                                                <div class="maqdropdown">                                                                
                                                    <aura:if isTrue="{!v.showTabs=='cus'}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.getCustomerPopup}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Customer}<span class="caret"></span>
                                                        </a>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.showTabs=='inv'}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.createInvoice}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Invoice} <span class="caret"></span>
                                                        </a>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.showTabs=='pay'}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.getPaymentPopup}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Payment} <span class="caret"></span>
                                                        </a>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!equals(v.showTabs,'cre')}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.createCredit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Credit_Note} <span class="caret"></span>
                                                        </a>
                                                    </aura:if>  
                                                    <aura:if isTrue="{!equals(v.showTabs,'deb')}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.createDebit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Debit_Note} <span class="caret"></span>
                                                        </a>
                                                    </aura:if> 
                                                    <aura:if isTrue="{!v.showTabs=='dun'}">
                                                        <a class="addNewBTN dropdown-toggle" onclick="{!c.createDunning}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Dunning} <span class="caret"></span>
                                                        </a>
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="slds-p-right_small">
                                    <a title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.navigateToDashboard}">
                                        <img src="/resource/ERP7__ERPCustomIcons/erpicons/research.png" style="width:30px"></img>
                                    </a>
                                    </div>
                                        <div class="slds-col">
                                            <div class="grid-list-icon"> 
                                                
                                                <div class="AccountsReceivable-newClass5">
                                                    <a class="{!(v.grid)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8'}" title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.gridView}">
                                                        <i class="fa fa-th-large"></i>
                                                    </a>
                                                    <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
                                                        <i class="fa fa-list"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                    
                                    <div class="epr_Mark7">             
                                        <div class="container-fluid">
                                            <div class="row AccountsReceivable-newClass11">
                                                
                                                
                                                <aura:if isTrue="{!v.SaveErrorMsg!=''}">                       
                                                    <div class="maq-only">
                                                        <div class="slds-notify_container slds-is-absolute AccountsReceivable-newClass12">
                                                            <div class="slds-notify slds-notify_toast slds-theme--success" role="alert">                                   
                                                                <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                                                                    <lightning:icon iconName="action:approval" size="x-small" alternativeText="{!$Label.c.Success}" title="Success" />
                                                                    
                                                                </span>
                                                                <div class="slds-notify__content AccountsReceivable-newClass13">
                                                                    <h2 class="slds-text-heading_small ">{!v.SaveErrorMsg}</h2>
                                                                </div>
                                                                
                                                                <div class="slds-notify__content AccountsReceivable-newClass14">
                                                                    <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" 
                                                                            onclick="{!c.getNotificationHide}">
                                                                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="{!$Label.c.Close_Timesheets}" />		
                                                                        <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                                    </button>
                                                                    
                                                                </div>
                                                                
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                </aura:if>    
                                            </div>
                                        </div>
                                    </div>
                                    <div id="tab-default-1" class="slds-tabs--default__content slds-show AccountsReceivable-newClass15" role="tabpanel" aria-labelledby="tab-default-1__item">             
                                        <div class="table-responsive AccountsReceivable-newClass16" tabindex="1">
                                            <table id="example" class="slds-table">  
                                                <thead>
                                                    <tr class="slds-text-title--caps"> 
                                                        <th class="slds-cell-shrink" scope="col">                          
                                                        </th>
                                                        
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="">                     
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="ERP7__Debit_Note__c" OrderBy="Name" Label="{!$Label.c.Name_Timesheets}"  >
                                                                        
                                                                    </c:SortRecords>  
                                                                    
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="ERP7__Debit_Note__c"  OrderBy="Name" Label="{!$Label.c.Name_Timesheets}" />  
                                                                    </aura:set>    
                                                                </aura:if>   
                                                                
                                                            </div>                    
                                                            <!-- qry="{! 'AND ERP7__Sales_Order__c = \''+v.Invoice.ERP7__Order__c.Id+'\''}"  -->                           
                                                        </th>
                                                        
                                                        <th scope="col" class="slds-is-sortable">
                                                            <div class="slds-truncate2" title=""> 
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="Account" OrderBy="AccountNumber" Label="{!$Label.c.SalesOrderToPurchaseOrder_Customer_Organisation}"
                                                                                   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}"/>  
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="Account" OrderBy="AccountNumber"  Label="{!$Label.c.Select_Bank_Payment_Method_Account_Number}"
                                                                                       Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                    </aura:set>    
                                                                </aura:if> 
                                                            </div>
                                                        </th>
                                                        
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="">
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Payment_Terms__c" Label="{!$Label.c.Acc_Recev_Credit}" 
                                                                                   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}"/>  
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Payment_Terms__c" Label="{!$Label.c.Acc_Recev_Opening_Balance}" 
                                                                                       Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                    </aura:set>    
                                                                </aura:if> 
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="">
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Paid_Amount__c" Label="{!$Label.c.Acc_Recev_Debit}" 
                                                                                   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}"/>  
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Paid_Amount__c" Label="{!$Label.c.Acc_Recev_Paid_Amount}" 
                                                                                       Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                    </aura:set>    
                                                                </aura:if> 
                                                            </div>
                                                        </th>
                                                        
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="">
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Total_Due__c" Label="{!$Label.c.Invoice_Amount_Paid}"
                                                                                   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}"/>  
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Total_Due__c" Label="{!$Label.c.Invoice_Total_Due}"
                                                                                       Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                    </aura:set>    
                                                                </aura:if>
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate2" title="">
                                                                <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                    <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Available_Credit_Balance__c" Label="{!$Label.c.Acc_Recev_Posted}" 
                                                                                   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}"/>  
                                                                    <aura:set Attribute="else">
                                                                        <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Available_Credit_Balance__c" Label="{!$Label.c.Acc_Recev_Available_Credit_Balance}"
                                                                                       Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                    </aura:set>    
                                                                </aura:if> 
                                                            </div>
                                                        </th>
                                                        
                                                        <th class="slds-cell-shrink" scope="col">
                                                            Action
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    
                                                    <aura:iteration items="{!v.debitList}" var="deb" indexVar="Index">      
                                                        <tr class="slds-hint-parent">                      
