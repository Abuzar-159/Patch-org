                    <div aria-hidden="true" class="slds" aura:id="ticketPopupId"> <!-- slds-hide  -->
                        <div aria-hidden="false" role="dialog" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header">
                                    <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.getRecordTypePopupClose}">
                                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" />	
                                        
                                        <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                    </button>
                                    <h2 class="title slds-text-heading--medium">{!$Label.c.Acc_Recev_New_Payment}:&nbsp;{!$Label.c.Select_a_record_type}</h2> 
                                </header>
                                
                                
                                <div class="tabbable">               
                                    <div class="slds-modal__content">          
                                        <div class="slds-form--compound">  
                                            <div class="epr_Mark7 slds-p-around--small"> 
                                                <div class="row slds-p-around--small">
                                                    <aura:iteration items="{!v.PaymentRTList}" var="prt" indexVar="Index">
                                                        <div class="col-md-6">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <lightning:input type="radio" text="{!prt.value}" labelClass="{!Index}" label="{!prt.label}" onclick="{!c.onPaymetRadio}" aura:id="PRadioId"/>
                                                                </div> 
                                                            </div>
                                                        </div>
                                                        
                                                    </aura:iteration>     
                                                </div>
                                                
                                            </div> 
                                            
                                            <div class="slds-modal__footer AccountsReceivable-newClass11">
                                                <button class="slds-button slds-button--neutral" onclick="{!c.getRecordTypePopupClose}">{!$Label.c.QuotationConsole_Cancel}</button> 
                                                <button class="slds-button slds-button--brand" onclick="{!c.createPayment}">{!$Label.c.RequisitionToPurchaseOrder_Next}</button>
                                                
                                            </div> 
                                        </div> 
                                    </div> 
                                </div> 
                            </div>                    
                        </div>           
                        <div class="slds-backdrop slds-backdrop--open"></div>         
                    </div>   
                </aura:if>   
                
                <aura:if isTrue="{!v.showCouP==true}">  <!-- and(v.showCouP==true,v.showTabs=='cou')  -->                                     
                    <div aria-hidden="true" class="slds" aura:id="ticketPopupId"> <!-- slds-hide  -->
                        <div aria-hidden="false" role="dialog" class="slds-modal slds-fade-in-open">
                            <div class="slds-modal__container">
                                <div class="slds-modal__header AccountsReceivable-newClass44">
                                    <h2 class="title slds-text-heading--medium">{!$Label.c.New_Coupon}:{!$Label.c.Select_a_record_type}</h2>
                                    <button type="button" class="slds-button slds-modal__close closeIcon slds-button--icon-bare slds-button--icon-inverse" data-dismiss="modal"  onclick="{!c.getRecordTypePopupClose}">X</button> 
                                    
                                </div>
                                
                                <div class="tabbable">               
                                    <div class="slds-modal__content">          
                                        <div class="slds-form--compound">  
                                            <div class="epr_Mark7 "> 
                                                <div class="container-fluid">
                                                    <div class="row"> 
                                                        <aura:iteration items="{!v.CouponRTList}" var="prt" indexVar="Index">
                                                            
                                                            <div class="col-md-4 slds-p-top--small slds-p-bottom--small">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <lightning:input type="radio" text="{!prt.value}" labelClass="{!Index}" label="{!prt.label}" onclick="{!c.onCouponRadio}" aura:Id="CouRadioId"/>
                                                                    </div>                                                       
                                                                </div>
                                                            </div>                     
                                                        </aura:iteration>
                                                    </div>                            
                                                </div>                  
                                            </div> 
                                            
                                            <div class="slds-modal__footer AccountsReceivable-newClass11">
                                                <button class="slds-button slds-button--neutral" onclick="{!c.getRecordTypePopupClose}">{!$Label.c.QuotationConsole_Cancel}</button> 
                                                <button class="slds-button slds-button--brand" onclick="{!c.createCoupon}">{!$Label.c.RequisitionToPurchaseOrder_Next}</button>                 
                                            </div> 
                                        </div> 
                                    </div> 
                                </div> 
                            </div>                    
                        </div>           
                        <div class="slds-backdrop slds-backdrop--open"></div>         
                    </div>   
                </aura:if>
            </div>
        </div>
    </div>
</aura:component>