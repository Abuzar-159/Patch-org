                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </span> 
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate2" title="">
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Amount_Paid__c" title="Sort" class="AccountsReceivable-newClass47;">
                                                                        {!$Label.c.Invoice_Amount_Paid}
                                                                        <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                            <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Invoice_Amount_Paid}" title="sort" /> 
                                                                            <aura:set attribute="else">
