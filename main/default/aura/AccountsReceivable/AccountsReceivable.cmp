                                                <p class="contact-item">
                                                    <span>{!$Label.c.Status}:</span>
                                                    <a href="javascript:void(0);">{!cu.Status}</a>
                                                    
                                                </p>
                                                
                                                <p class="contact-item">
                                                    <span>{!$Label.c.Invoice_Amount_Paid}:</span>
                                                    <a href="javascript:void(0);"> {!$Locale.currency}{!cu.ERP7__Amount_Paid__c}  </a>
                                                    
                                                </p>
                                                
                                                <p class="contact-item">
                                                    
                                                    <span>{!$Label.c.Acc_Pay_Due_Amount}:</span>
                                                    <a href="javascript:void(0);">{!$Locale.currency}{!cu.ERP7__Due_Amount__c}</a>
                                                    
                                                </p>
                                                
                                            </div>
                                            
                                        </div> 
                                    </aura:iteration>
                                    <aura:set Attribute="else">
                                        <aura:iteration items="{!v.SalesOrderList}" var="cu" indexVar="Index">
                                            <div class="col-md-3 mt-2">
                                                <div class="card-contact p-3">
                                                    <div class="slds-grid text-left pb-2">
                                                        <div class="col-1 pl-0">
                                                            <lightning:input type="checkbox" value="{!cu.ERP7__Account__r.Id}" aura:id="SalOrdId" onchange="{!c.selectedSalOrd}" name="{!cu.Id}" /> 
                                                        </div>
                                                        <div class="col-9 pl-0">
                                                            <h5 class="">
                                                                <a href="{!'/'+cu.Id}" target="_blank" class="contact-name"><p> &nbsp;{!Index+1}.&nbsp;{!cu.Name}</p></a>
                                                                
                                                            </h5>
                                                        </div>
                                                        <div class="col-2 pr-0 text-right">
                                                            <p>
                                                                <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" iconSize="small" variant="border-filled" onselect="{! c.handleordmenu }" menuAlignment="right">
                                                                    <lightning:menuItem value="{!cu.Id}" label="{!$Label.c.Acc_Recev_New_Invoice}" />
                                                                </lightning:buttonMenu>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    
                                                    <p class="contact-item">
                                                        <span>{!$Label.c.SupplierRegistration_Account_Name}:</span>
                                                        <span>
                                                            <a href="javascript:void(0);">{!cu.ERP7__Account__r.Name}</a></span>
                                                    </p>
                                                    <p class="contact-item">
                                                        <span>{!$Label.c.Effective_Date} :</span>
                                                        <lightning:formattedDateTime value="{!cu.ERP7__Order_Date__c}" />
                                                    </p>
                                                    <p class="contact-item">
                                                        <span>{!$Label.c.Status}:</span>
                                                        <a href="javascript:void(0);">{!cu.ERP7__Status__c}</a>
                                                        
                                                    </p>
                                                    
                                                    <p class="contact-item">
                                                        <span>{!$Label.c.Invoice_Amount_Paid}:</span>
                                                        <a href="javascript:void(0);"> {!$Locale.currency}{!cu.ERP7__Amount_Paid__c}  </a>
                                                        
                                                    </p>
                                                    
                                                    <p class="contact-item">
                                                        
                                                        <span>{!$Label.c.Acc_Pay_Due_Amount}:</span>
                                                        <a href="javascript:void(0);">{!$Locale.currency}{!cu.ERP7__Due_Amount__c}</a>
                                                        
                                                    </p>
                                                    
                                                </div>
                                                
                                            </div> 
                                        </aura:iteration>
                                    </aura:set>
                                </aura:if>                                
                            </div>
                        </div>    
                        <div class="epr_Mark7">
                            <div class="row slds-docked-form-footer">
                                <aura:if isTrue="{!or(v.OrderList.length>0,v.SalesOrderList.length>0,v.PaymentList.length>0)}">
                                    <div class="col-md-2">
                                        <div class="slds-grid" >
                                            <div class="slds-col AccountsReceivable-newClass18">
                                                {!$Label.c.Acc_Recev_Show}&nbsp;
                                            </div>  
                                            <div class="slds-col AccountsReceivable-newClass19"> 
                                                <lightning:select class="slds-show_inline-block "  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                    <option value="10">10</option>
                                                    <option value="25">25</option>
                                                    <option value="50">50</option>
                                                    <option value="100">100</option>
                                                    <option value="150">150</option>
                                                </lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!or(v.OrderList.length>0,v.SalesOrderList.length>0)}">
                                    
                                    <div class="col-md-3">
                                        {!$Label.c.Acc_Recev_Showing} <span class="text-lightblue">{!v.startCount}-{!v.endCount}</span> {!$Label.c.Acc_Recev_of_total} <span class="text-lightblue"> {!v.recSize} </span> {!$Label.c.Acc_Recev_Records}
                                    </div>
                                    
                                </aura:if> 
                                
                                <aura:if isTrue="{!or(v.OrderList.length>0,v.SalesOrderList.length>0)}">
                                    
                                    <div class="col-md-5">
                                        <nav aria-label="Page navigation example">
                                            <ul class="pagination">
                                                <li >
                                                    <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                                </li>
                                                <li>
                                                    <a class="{!if(1 >= v.startCount,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.Previous}"> &lt; {!$Label.c.Previous}</a> <!-- -->
                                                </li>
                                                
                                                <li>
                                                    <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.Next}">{!$Label.c.RequisitionToPurchaseOrder_Next} &gt;</a> <!--  -->
                                                </li>
                                                <li>
                                                    <a class="{!if(v.endCount == v.recSize,'AccountsReceivable-newClass23','AccountsReceivable-newClass24')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                                </li>
                                            </ul>
                                        </nav>
                                    </div>
                                    
                                </aura:if> 
                                <aura:if isTrue="{!or(v.OrderList.length>0,v.SalesOrderList.length>0)}">
                                    
                                    <div class="col-md-2">
                                        <div class="slds-grid">
                                            <div class="slds-col AccountsReceivable-newClass25">
                                                Page 
                                            </div>
                                            <div class="slds-col">
                                                
                                                <lightning:input type="number" variant="label-hidden" aura:id="ikgOrd" value="{!v.PageNum}" oncommit="{!c.OfsetChange}" class="width100p"/> 
                                            </div>
                                            <div class="slds-col AccountsReceivable-newClass26"><span class="text-lightblue"> of {!v.PNS.length}</span>
                                            </div>
                                            
                                            
                                        </div>
                                    </div>
                                    
                                </aura:if>
                            </div>
                        </div>
