                                        <table id="example" class="slds-table">
                                            <thead>
                                                <tr class="slds-text-title--caps"> 
                                                    <th class="slds-cell-shrink" scope="col">                          
                                                    </th>
                                                    
                                                    <th scope="col" class="toggle slds-th__action slds-text-link--reset ">
                                                        <div class="slds-truncate2 " title="">   
                                                            
                                                            <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="Name" Label="{!$Label.c.Name_ManageLeave}"   Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Account_Type__c=\'Customer\'  AND ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\''}">
                                                                    
                                                                </c:SortRecords>  
                                                                
                                                                <aura:set Attribute="else">
                                                                    <c:SortRecords ObjectAPIName="Account"  OrderBy="Name" Label="{!$Label.c.Name_ManageLeave}"  Query="{!' AND ERP7__Account_Type__c=\'Customer\'  AND (ERP7__Organisation__r.ERP7__Account_Type__c=\'Organisation\' OR ERP7__Organisation__r.ERP7__Account_Type__c=Null)'}"/>  
                                                                </aura:set>    
                                                            </aura:if>   
                                                            
                                                        </div>                    
                                                        
                                                    </th>
                                                    
                                                    <th scope="col" class="slds-is-sortable">
                                                        <div class="slds-truncate2" title=""> 
