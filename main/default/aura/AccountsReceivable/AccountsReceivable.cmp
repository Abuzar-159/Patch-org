                                                                        </aura:set>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!(deb.ERP7__Posted__c?true:false)}">
                                                                        <lightning:menuItem label="{!$Label.c.Acc_Recev_Record_Payment}" value="{!deb.Id}"/>
                                                                    </aura:if>
                                                                </lightning:buttonMenu>
                                                            </td>
                                                        </tr>
                                                    </aura:iteration> 
