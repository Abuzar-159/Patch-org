                                                                <lightning:menuItem value="{!cu.Id}" label="{!$Label.c.Acc_Recev_New_Credit_Note}" />
                                                                <!--<lightning:menuItem value="{!cu.Id}" label="{!$Label.c.Acc_Recev_New_Debit_Note}" />-->
                                                                <lightning:menuItem value="{!cu.Id}" label="{!$Label.c.Acc_Recev_New_Invoice}" />
