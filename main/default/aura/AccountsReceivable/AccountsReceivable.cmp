                                                            <div class="slds-col AccountsReceivable-newClass26"><span class="text-lightblue"> {!$Label.c.page_of}&nbsp; {!v.PNS.length}</span>
                                                            </div>
                                                            
                                                            
                                                        </div>
                                                    </div>
                                                    
                                                </aura:if>
                                            </div>
                                        </div>
