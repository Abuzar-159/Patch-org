                                                                        {!$Label.c.SupplierRegistration_Account_Name}
                                                                        <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                            <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.SupplierRegistration_Account_Name}" title="sort" /> 
                                                                            <aura:set attribute="else">
                                                                                <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.SupplierRegistration_Account_Name}" title="sort"/> 
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </span>  
                                                                </div>
                                                            </th>
                                                            
                                                            <th scope="col">
                                                                <div class="slds-truncate2" title="">
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="EffectiveDate" title="Sort" class="AccountsReceivable-newClass47;">
                                                                        {!$Label.c.Effective_Date}
                                                                        <aura:if isTrue="{!equals(v.Order,'DESC')}">
                                                                            <lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Effective_Date}" title="sort" /> 
                                                                            <aura:set attribute="else">
                                                                                <lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Effective_Date}" title="sort"/> 
                                                                            </aura:set>
                                                                        </aura:if>
                                                                    </span> 
                                                                </div>
                                                            </th>
                                                            <th scope="col">
