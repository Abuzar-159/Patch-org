                                        <lightning:select  aura:id="shipType" value="{!v.shipment[0].ERP7__Shipment_Type__c}" label="{!$Label.c.PO_Shipment_Type}"	 >
                                            <aura:iteration items="{!v.shiptype}" var="shpopt"  >
                                                <option value="{!shpopt.value}">{!shpopt.value}</option>   
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[11]}">
