<aura:component controller="InternalShipmentLightning" implements="force:hasSObjectName,force:hasRecordId,force:appHostable,forceCommunity:availableForAllPageTypes,flexipage:availableForRecordHome,force:appHostable,force:lightningQuickActionWithoutHeader" access="global">
    <head>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__Order_Console/assets/styles/font-awesome.css,
                              /resource/ERP7__SLDS214/assets/styles/salesforce-lightning-design-system-vf.css, /resource/ERP7__SLDS214/assets/styles/salesforce-lightning-design.css
                              "/>
        <ltng:require scripts="{!$Resource.esignature + '/signature_pad.min.js'}" />
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/InternalShipment.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    </head>
    
    <aura:attribute name="WeightUnit" type="object"/>
    <aura:attribute name="Dimension" type="object"/>    
    <aura:attribute name="showPackDimension"  type="Boolean" default="false"/>
    <aura:attribute name="shipidexists"  type="Boolean" default="false"/>
    <aura:attribute name="showAttachSpin"  type="Boolean" default="false"/>
    <aura:attribute name="checkedAll"  type="Boolean" default="true"/>
    <aura:attribute name="showcreatePO"   type="Boolean" default="false"/> 
    <aura:attribute name="recordPOexists"  type="Boolean" default="false"/> 
    <aura:attribute name="hideDelTab"    type="Boolean" default="false"/> 
    <aura:attribute name="dis"  type="Boolean" default="false"/> 
    <aura:attribute name="errorMsgPop" type="String" />
    <aura:attribute name="updateFiles"   type="Boolean" default="true"/>
    <aura:attribute name="getCheckCount" type="list" default="[]"/>
    <aura:attribute name="allPackageList" type="List" />
    <aura:attribute name="allquantityvalues" type="List" />
    <aura:attribute name="chklistopt" type="List" />
    <aura:attribute name="render" type="List" />
    <aura:attribute name="packageID" type="String" />
    <aura:attribute name="packageIDS" type="List" />
    <aura:attribute name="c.getSign" type="String"/> 
    <aura:attribute name="en" type="String" default="slds-button slds-button--brand "/>
    <aura:attribute name="disbutton" type="String" default="slds-brand--disabled"/>
    <aura:attribute name="active1" type="String" default="slds-tabs--default__item slds-is-active"/>
    <aura:attribute name="active2" type="String" default="slds-tabs--default__item"/>
    <aura:attribute name="active3" type="String" default="slds-tabs--default__item"/>
    <aura:attribute name="active4" type="String" default="slds-tabs--default__item"/>
    <aura:attribute name="shipmentID" type="String" />
    <aura:attribute name="showRightTwoCheckList"            type="Boolean" default="false"/>
    <aura:attribute name="showRightTwo"            type="Boolean" default="false"/>  
    <aura:attribute name="showRightOne"            type="Boolean" default="True"/>
    <aura:attribute name="showRightTwoPickUP"      type="Boolean" default="False"/>
    <aura:attribute name="showRightTwoDropOff"     type="Boolean" default="False"/>
    <aura:attribute name="showRightTwoDelivery"    type="Boolean" default="False"/>
    <aura:attribute name="showSpinner"             type="Boolean" default="False"/>
    <aura:attribute name="callSigInit"             type="Boolean" default="True"/>
    <aura:attribute name="showSF"                  type="Boolean" default="False"/>
    <aura:attribute name="call"                    type="Boolean" default="True"/>
    <aura:attribute name="showPDSection"           type="Boolean" default="False"/>
    <aura:attribute name="Delivered"               type="Boolean" default="True"/>
    <aura:attribute name="fromAddress"             type="Object"  />
    <aura:attribute name="toAddress"               type="List"/>
    <aura:attribute name="ShipmentFlows"           type="List"/>
    <aura:attribute name="packageList"             type="List"/>  
    <aura:attribute name="shipment"                type="List"/>
    <aura:attribute name="pickupShipment"          type="object[]"/>
    <aura:attribute name="dropoffShipment"         type="object[]"/>
    <aura:attribute name="deliveryShipment"        type="object[]"/>
    <aura:attribute name="shipmentTypePCKLST"      type="List"/>
    <aura:attribute name="pckTypePCKLST"           type="List"/>
    <aura:attribute name="productunitTypePCKLST"   type="List"/>
    <aura:attribute name="SSPKL"				   type="List"/>
    <aura:attribute name="SFSPCKLST" 			   type="List"/>
    <aura:attribute name="SSpicklist"           type="Object"/>
    <aura:attribute name="SFOption"             type="Object"/>
    <aura:attribute name="pckListStatusOptns"   type="Object"/>
    <aura:attribute name="Attachments"          type="object[]"/>
    <aura:attribute name="id"            type="String" default=""/>
    <aura:attribute name="minWidth"      type="double" default="0.5"/>
    <aura:attribute name="maxWidth"      type="double" default="2"/>
    <aura:attribute name="penColor"      type="string" default="rgb(0,0,0)"/>
    <aura:attribute name="signatureData" type="string" default=""/>
    <aura:attribute name="readOnly"      type="Boolean" default="false"/>
    <aura:attribute name="style"         type="string" access="private"/>
    <aura:attribute name="signaturePad"  type="object" />
    <aura:attribute name="partialDel" type="Boolean" default="false"/>
    <aura:attribute name="HideCheckList" type="Boolean" default="True"/> 
    <aura:attribute name="SelectedAttachments" type="object[]"/>
    <aura:attribute name="SelectedNotes" type="object[]"/>
    <aura:attribute name="FileList" type="object[]"/>
    <aura:attribute name="NewNote" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="NewNoteTemp" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="message" type="String" default=""/>
    <aura:attribute name="exceptionError" type="String" default=""/>
    <aura:attribute name="recordExist" type="Boolean" default="False"/>
    <aura:attribute name="DT" type="DateTime"/>
    <aura:attribute name="showHeader" type="Boolean" default="true"/>
    <aura:attribute name="deliverystage" type="List" />
    <aura:attribute name="shipflostatus" type="List" />
    <aura:attribute name="shiptype" type="List" />
    <aura:attribute name="ShiptoContact" type="object"/>
    <aura:attribute name="pckLstStsOptions" type="List"/>
    
    <aura:handler   name="init" value="{!this}"    action="{!c.init}" /> 
    <aura:method    name="capture" action="{!c.onCapture}"  description="call this method to capture signature"/>
    <aura:method    name="clear" action="{!c.onClear}" description="clear the signature"/>
    <aura:handler   name="change" value="{!v.toAddress[0].Id}"   action="{!c.changeToAddress}"/>
    <aura:handler   name="change" value="{!v.fromAddress[0].Id}" action="{!c.changeFromAddress}"/>
    <aura:attribute name="DeliveryFN" type="String" default=""/>
    <aura:attribute name="refreshnow" type="Boolean" default="true"/>
    <aura:attribute name="hideShipment"  type="Boolean" default="false"/><!--Asra 10/4/24-->
    
    <div aura:id="body" class="InternalShipment-class1">
        <div class="erp_mark7 epr_Mark7 white-bg InternalShipment-class2">
            <span class="InternalShipment-class3">
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
            
            <div class="maq-only">
                <aura:if isTrue="{!not(empty(v.exceptionError))}">
                    <div class="slds-notify_container slds-is-fixed " >
                        <div class="slds-notify slds-notify_toast slds-theme_error" role="status" >
                            <span class="slds-assistive-text">{!$Label.c.error}</span>
                            <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                                <lightning:icon iconName="utility:error" variant="inverse" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" size="x-small"/>
                            </span>
                            <div class="slds-notify__content">
                                <p class="slds-text-heading_x-small mb-0">
                                    <lightning:formattedText value="{!v.exceptionError}"/>
                                </p>
                            </div>
                            <div class="slds-notify__close" >
                                <a onclick="{!c.closeError}" class="textdeccolor">
                                    <lightning:icon iconName="utility:close" variant="inverse" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" size="x-small"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </aura:if>
                <aura:if isTrue="{!not(empty(v.message))}">
                    <div class="slds-notify_container slds-is-fixed">
                        <div class="slds-notify slds-notify_toast slds-theme--success" role="alert">                                   
                            <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                                <lightning:icon iconName="standard:approval" size="small" alternativeText="{!$Label.c.approval}" title="approval" />
                            </span>
                            <div class="slds-notify__content InternalShipment-class4">
                                <h2 class="slds-text-heading_small mt-0 mb-0">{!v.message}</h2>
                            </div>
                            
                            <div class="slds-notify__content InternalShipment-class5" >
                                <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" 
                                        onclick="{!c.hideNotification}">
                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" />	
                                    <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span> 
                                </button> 
                            </div>
                        </div>
                    </div>
                </aura:if>
            </div>
            
            <aura:if isTrue="{!v.showHeader}">
                <div class="slds-page-header slds-page-header--object-home">
                    <div class="slds-grid">
                        <div class="slds-col slds-has-flexi-truncate">
                            <div class="slds-media slds-no-space slds-grow">
                                <div class="slds-media__figure">
                                    <span class="slds-icon_container">
                                        <div class="slds-icon slds-icon-standard-lead InternalShipment-class6" aria-hidden="true">
                                            <i aria-hidden="true" class="fa fa-truck InternalShipment-class"></i>
                                        </div>
                                    </span>
                                </div>                            
                                <div class="slds-media__body">          
                                    <h1 class="slds-page-header__title slds-p-right--x-small InternalShipment-class8"> 
                                        <span class="slds-grid slds-has-flexi-truncate slds-grid--vertical-align-center">
                                            <h1 class="InternalShipment-class9">{!$Label.c.InternalShipment_Shipment_Tab}</h1>                            
                                        </span>
                                    </h1>
                                </div>
                            </div>
                        </div>
                        
                        <div class="slds-col slds-no-flex slds-grid slds-align-top slds-p-bottom--xx-small">
                            <div class="slds-button-group" role="group">
                                <a href="#" onclick="{!c.gotoOutbound}" class="slds-button slds-button--neutral InternalShipment-class12">
                                    <i aria-hidden="true" class="fa fa-chevron-left InternalShipment-class10" ></i> {!$Label.c.EmployeeReviewV2_Back}</a>        
                            </div>
                        </div>
                    </div>
                </div>
            </aura:if>
            
            <div class="row InternalShipment-class13">
                <!-- left section -->
                <div class="col-xs-12 col-sm-12 col-md-6 slds-m-top--small">
                    <!--Start of Accor 1-->
                    <div>
                        <div class="maqbg-change InternalShipment-class11" onclick="{!c.sectionOne}">
                            <section class="slds-clearfix">
                                <div class="slds-float--left ">
                                    <div class="slds-hide" aura:id="articleOne"><i class="fa fa-chevron-right" aria-hidden="true" ></i></div>
                                    <div class="slds-show" aura:id="articleOne"><i class="fa fa-chevron-down" aria-hidden="true"></i></div>
                                </div>
                                <div class="slds-m-left--large" >{!$Label.c.X1_Where_is_this_shipment_going} </div>
                            </section>
                        </div>
                        
                        <div aura:id="articleOne">
                            <div class="epr_Mark7 InternalShipment-class14" >
                                <div class="row slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label"> {!$Label.c.To_Address}:</label><div onclick="{!c.toaddss}"><c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.toAddress[0].Id}" hideRemove="true"/></div> 
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <aura:if isTrue="{!and(v.toAddress[0].ERP7__Contact__r.ERP7__Company__c !=null,v.toAddress[0].ERP7__Contact__r.ERP7__Company__c !='')}">
                                                     <lightning:input type="Text" label="{!$Label.c.CompanyLabel}"  value="{!v.toAddress[0].ERP7__Contact__r.ERP7__Company__c}"/>
                                                    <aura:set attribute="else">
                                                        <aura:if isTrue="{!and(v.toAddress[0].ERP7__Customer__r.ERP7__Company__c !=null,v.toAddress[0].ERP7__Customer__r.ERP7__Company__c !='')}">
                                                        <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.toAddress[0].ERP7__Customer__r.ERP7__Company__c}"/>
                                                            <aura:set attribute="else">
                                                                <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.toAddress[0].ERP7__Customer__r.Name}"/>
                                                            </aura:set>
                                                        </aura:if>
                                                    </aura:set>
                                                </aura:if>
                                           
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <aura:if isTrue="{!and(v.ShiptoContact != null,v.ShiptoContact != '')}">
                                                <lightning:input type="text" label="Contact" value="{!v.ShiptoContact.Name}"/>
                                                <aura:set attribute="else">
                                                    <lightning:input type="text" label="Contact" value="{!v.toAddress[0].ERP7__Contact__r.Name}"/>
                                                </aura:set>
                                            </aura:if>
                                            <!--<lightning:input type="Text" label="Contact :"  value="{!v.toAddress[0].ERP7__Contact__r.Name}"/>-->
                                            
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="email" label="Email :" value="{!v.toAddress[0].ERP7__Contact__r.Email}"/>
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="tel" label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.toAddress[0].ERP7__Contact__r.Phone}"/>
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text" label="{!$Label.c.Address_line_1}" value="{!v.toAddress[0].ERP7__Address_Line1__c}"/>
                                            
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.Address_line_2}" value="{!v.toAddress[0].ERP7__Address_Line2__c}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.City_town}" value="{!v.toAddress[0].ERP7__City__c}"/>
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.State_country}" value="{!v.toAddress[0].ERP7__State__c}"/>
                                            
                                        </div>
                                    </div>
                                </div>
                                <div class="row  slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text" label="{!$Label.c.Zip_post_code}" value="{!v.toAddress[0].ERP7__Postal_Code__c}"/>
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text" label="{!$Label.c.Cash_Payment_Country}" value="{!v.toAddress[0].ERP7__Country__c}"/>
                                        </div>
                                    </div>
                                </div> 
                            </div>
                        </div>
                    </div>
                    <!--End of Accor 1-->
                    
                    <!--Start of Accor 2-->
                    <div>
                        <div class="maqbg-change InternalShipment-class11" onclick="{!c.sectionTwo}">
                            <section class="slds-clearfix">
                                <div class="slds-float--left ">
                                    <div class="slds-hide" aura:id="articleTwo"><i class="fa fa-chevron-right" aria-hidden="true" ></i></div>
                                    <div class="slds-show" aura:id="articleTwo"><i class="fa fa-chevron-down" aria-hidden="true"></i></div>
                                    
                                </div>
                                <div class="slds-m-left--large" >{!$Label.c.shipment_originating_from} </div>
                            </section>
                        </div>
                        
                        <div aura:id="articleTwo">
                            <div class="epr_Mark7 InternalShipment-class17" >
                                <div class="row slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label">{!$Label.c.From_Address}</label>
                                            <div onclick="{!c.toaddss}"> <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" label="" selectedRecordId="{!v.fromAddress[0].Id}" hideRemove="true"/></div>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                             <aura:if isTrue="{!and(v.fromAddress[0].ERP7__Contact__r.ERP7__Company__c !=null,v.fromAddress[0].ERP7__Contact__r.ERP7__Company__c !='')}">
                                                      <lightning:input type="Text"  label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress[0].ERP7__Contact__r.ERP7__Company__c}"/>
                                                    <aura:set attribute="else">
                                                        <aura:if isTrue="{!and(v.fromAddress[0].ERP7__Customer__r.ERP7__Company__c !=null,v.fromAddress[0].ERP7__Customer__r.ERP7__Company__c !='')}">
                                                        <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress[0].ERP7__Customer__r.ERP7__Company__c}"/>
                                                            <aura:set attribute="else">
                                                                <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress[0].ERP7__Customer__r.Name}"/>
                                                            </aura:set>
                                                        </aura:if>
                                                    </aura:set>
                                                </aura:if>
                                           
                                            
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="Contact :" value="{!v.fromAddress[0].ERP7__Contact__r.Name}"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-around--small InternalShipment-class15" >
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="email"  label="Email :" value="{!v.fromAddress[0].ERP7__Contact__r.Email}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="tel"  label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.fromAddress[0].ERP7__Contact__r.Phone}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.Address_line_1}" value="{!v.fromAddress[0].ERP7__Address_Line1__c}"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="row  slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.Address_line_2}" value="{!v.fromAddress[0].ERP7__Address_Line2__c}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.City_town}" value="{!v.fromAddress[0].ERP7__City__c}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.State_country}" value="{!v.fromAddress[0].ERP7__State__c}"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-around--small InternalShipment-class15">
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.Zip_post_code}" value="{!v.fromAddress[0].ERP7__Postal_Code__c}"/>
                                        </div>
                                    </div>
                                    <div class="col-xs-12 col-sm-4 col-md-4">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="Text"  label="{!$Label.c.Cash_Payment_Country}" value="{!v.fromAddress[0].ERP7__Country__c}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!--End of Accor 2-->
                    
                    <!--Start of Accor 3-->
                    <aura:if isTrue="{!!v.hideShipment}"><!--Asra 10/4/24-->
                        <div>
                            <div class="maqbg-change InternalShipment-class11" onclick="{!c.sectionThree}">
                                <section class="slds-clearfix">
                                    <div class="slds-float--left ">
                                        <div class="slds-hide" aura:id="articleThree"><i class="fa fa-chevron-right" aria-hidden="true" ></i></div>
                                        <div class="slds-show" aura:id="articleThree"><i class="fa fa-chevron-down" aria-hidden="true"></i></div>
                                        
                                    </div>
                                    <div class="slds-m-left--large" >{!$Label.c.What_are_you_shipping}</div>
                                </section>
                            </div>
                            
                            <div aura:id="articleThree">
                                <div class="row InternalShipment-class18"> 
                                    
                                </div>
                                <div class="slds-m-top--large"></div>
                                <div class="row">
                                    <div class="col-xs-12 InternalShipment-class19">
                                        <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                                            <thead>
                                                <tr class="slds-text-title--caps">
                                                    <th scope="col"> <div class="slds-truncate2" title="Package">{!$Label.c.PackageSlip_List_Package}</div> </th>
                                                    <th scope="col"> <div class="slds-truncate2" title="Order">{!$Label.c.Order_RMA}</div> </th>
                                                    <th class="mobiledisplaynone mobiledisplaynone-landscape" scope="col"> <div class="slds-truncate2" title="Weight">{!$Label.c.PackageSlip_List_Weight}</div> </th>
                                                    <th class="mobiledisplaynone mobiledisplaynone-landscape" scope="col"> <div class="slds-truncate2" title="Length">{!$Label.c.ShipmentManagement_Package_Length}</div> </th>
                                                    <th class="mobiledisplaynone mobiledisplaynone-landscape" scope="col"> <div class="slds-truncate2" title="Width">{!$Label.c.ShipmentManagement_Package_Width}</div> </th>
                                                    <th class="mobiledisplaynone mobiledisplaynone-landscape" scope="col"> <div class="slds-truncate2" title="Height">{!$Label.c.Height_Pack}</div> </th>
                                                    <aura:if isTrue="{!v.render[13]}">
                                                        <th scope="col"> <div class="slds-truncate2" title="Declared Value">{!$Label.c.Pack_Declared_Value}</div> </th>
                                                    </aura:if>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <aura:iteration items="{!v.packageList}" var="package">				
                                                    <tr class="slds-hint-parent">
                                                        <td class="greyheadlabel">
                                                            <div class="slds-truncate1">
                                                                <a href="{!'/'+ package.Id}" target="_blank">
                                                                    <lightning:formattedText value="{!package.Name}"/>
                                                                    
                                                                </a>
                                                            </div>
                                                        </td>
                                                        <td class="greyheadlabel">
                                                            <div class="slds-truncate1"> 
                                                                <aura:if isTrue="{!package.ERP7__Sales_Order__c != Null}">
                                                                    <a href="{!'/'+ package.ERP7__Sales_Order__c}" target="_blank">
                                                                        <lightning:formattedText value="{!package.ERP7__Sales_Order__r.Name}"/>
                                                                    </a>
                                                                </aura:if>
                                                                
                                                                <aura:if isTrue="{!package.ERP7__Order__r.Name != Null}">
                                                                    <a href="{!'/'+ package.ERP7__Order__c}" target="_blank">
                                                                        <lightning:formattedText value="{!package.ERP7__Order__r.Name}"/>
                                                                    </a>
                                                                    <aura:set attribute="else">
                                                                        <a href="{!'/'+ package.ERP7__Order__c}" target="_blank">
                                                                            <lightning:formattedText value="{!package.ERP7__Order__r.OrderNumber}"/>
                                                                        </a>
                                                                    </aura:set>
                                                                </aura:if>
                                                                <aura:if isTrue="{!package.ERP7__Transfer_Order__c != Null}">
                                                                    <a href="{!'/'+ package.ERP7__Transfer_Order__c}" target="_blank">
                                                                        <lightning:formattedText value="{!package.ERP7__Transfer_Order__r.Name}"/>
                                                                    </a>
                                                                </aura:if>
                                                                
                                                            </div>
                                                        </td> 
                                                        <td class="greyheadlabel mobiledisplaynone mobiledisplaynone-landscape">
                                                            <div class="slds-truncate1"> {!package.ERP7__Weight__c}</div>
                                                        </td>
                                                        <td class="greyheadlabel mobiledisplaynone mobiledisplaynone-landscape">
                                                            <div class="slds-truncate1">  {!package.ERP7__Length__c} </div> 
                                                        </td>
                                                        <td class="greyheadlabel mobiledisplaynone mobiledisplaynone-landscape">
                                                            <div class="slds-truncate1"> {!package.ERP7__Width__c} </div>
                                                        </td>                                    
                                                        <td class="greyheadlabel mobiledisplaynone mobiledisplaynone-landscape">
                                                            <div class="slds-truncate1">  {!package.ERP7__Height__c}</div>
                                                        </td>
                                                        <aura:if isTrue="{!v.render[13]}">
                                                            <td class="greyheadlabel">
                                                                <lightning:input  type="number" formatter="currency" value="{!package.ERP7__Declared_Value__c}" step="0.0001"/>
                                                            </td>
                                                        </aura:if>    
                                                    </tr>
                                                </aura:iteration>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="slds-m-top--large"></div>
                            </div>
                        </div>
                    </aura:if>
                    <!--End of Accor 3-->
                </div>
                <!-- End of left section -->
                
                <!-- right section -->
                <div class="col-xs-12 col-sm-12 col-md-6 slds-m-top--small">
                    <div class="slds-tabs--default slds-p-around--xx-small">
                        <ul class="slds-tabs--default__nav InternalShipment-class20" role="tablist">
                            <div class="InternalShipment-class11"  onclick="{!c.rightSectionOne}">
                                <li class="{!v.active1 + ' InternalShipment-class21'}" >
                                    <div class="slds-grid">
                                        <div class="slds-col slds-m-right--xx-small">
                                            <i class="fa fa-file-text"></i>
                                        </div>
                                        <div class="slds-col text-responsive">
                                            {!$Label.c.InternalShipment_Shipment_Tab}
                                        </div>
                                    </div>
                                </li>
                            </div>
                            
                            <div class="InternalShipment-class11" onclick="{!c.cancelSF}">
                                <li class="{!v.active2 + ' InternalShipment-class21'}">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-m-right--small">
                                            <img class="slds-button__icon slds-button__icon--right InternalShipment-class22" src="/resource/1482140524000/ERP7__ERPCustomIcons/erpicons/ERPicon-pickcart48x48.png" />
                                        </div>
                                        <div class="slds-col text-responsive">
                                            {!$Label.c.Pickup_DropOff}
                                        </div>
                                    </div>
                                </li>
                            </div>
                            
                            <aura:if isTrue="{!v.HideCheckList}">  
                                <div  class="InternalShipment-class11" onclick="{!c.showrightSectionCheckList}">
                                    <li class="{!v.active4 + ' InternalShipment-class21'}"> 
                                        <div class="slds-grid">
                                            <div class="slds-col slds-m-right--xx-small">
                                                <i class="fa fa-list-alt" aria-hidden="true"></i>
                                            </div>
                                            <div class="slds-col text-responsive">
                                                {!$Label.c.CheckList}
                                            </div>
                                        </div>
                                    </li>
                                </div>
                            </aura:if>
                            
                            <!--<aura:if isTrue="{!v.hideDelTab}">-->
                            <div  class="InternalShipment-class11" onclick="{!c.showrightSectionTwoDelivery}">
                                <li class="{!v.active3 + ' InternalShipment-class21'}"> 
                                    <div class="slds-grid">
                                        <div class="slds-col slds-m-right--xx-small">
                                            <i class="fa fa-truck InternalShipment-class23" aria-hidden="true"></i>
                                        </div>
                                        <div class="slds-col text-responsive">
                                            {!$Label.c.InternalShipment_Delivery_Tab}
                                        </div>
                                    </div>
                                    
                                </li>
                            </div>
                            <!--</aura:if>-->
                            
                            <li>
                                <aura:if isTrue="{!v.showSpinner}">
                                    <span class="InternalShipment-class3">
                                        <lightning:spinner variant="brand" size="large" aura:id="mainSpin" class="mainSpinClass"/>
                                    </span>  
                                </aura:if>
                            </li>
                        </ul>
                    </div>
                    
                    <aura:if isTrue="{!v.refreshnow}">
                        <aura:if isTrue="{!v.showRightOne}">
                            <!-- Row 1 -->
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label">{!$Label.c.Delivery_Name}</label>
                                        <lightning:input type="text"  value="{!v.shipment[0].Name}" maxlength='80'/>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label">{!$Label.c.Created_Date}</label>
                                        <lightning:input type="date" value="{!v.shipment[0].ERP7__Shipment_Date__c}" /><!--displayDatePicker="true"-->
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <div class="col-md-6">
                                    <div class="slds-form-element__control">
                                        <div class="">
                                            <label class="slds-form-element__label">{!$Label.c.Delivery_Stage}</label>
                                            <lightning:select  aura:id="pkgTyp" value="{!v.shipment[0].ERP7__Status__c}"  class="labelnone2" >
                                                <aura:iteration items="{!v.deliverystage}" var="option">
                                                    <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.shipment[0].ERP7__Status__c, option.value)}"/>
                                                </aura:iteration>
                                            </lightning:select> 
                                        </div>    
                                    </div>  
                                </div>
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label">{!$Label.c.Delivery_Date}</label>
                                        <lightning:input  type="date"  value="{!v.shipment[0].ERP7__Shipment_Delivery_Date__c}" /><!--displayDatePicker="true"-->
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <aura:if isTrue="{!v.render[0]}"> 
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="text"  label="{!$Label.c.Ship_Tracking_Number}" value="{!v.shipment[0].ERP7__TrackingNumber__c}" maxlength='80'/>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[1]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="text"  label="{!$Label.c.Shipment_Identification_Number}" value="{!v.shipment[0].ERP7__Shipment_Identification_Number__c}" maxlength='155'/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                            <!-- @end of Row 1 -->
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <aura:if isTrue="{!v.render[17]}"> 
                                    <div class="col-md-6">
                                        <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.shipment[0].ERP7__Carrier_Forwarder__c}"  label="{!$Label.c.Carrier_Forwarder}"  aura:Id="Carrier" qry=" AND ( ERP7__Account_Type__c = 'Vendor') "/> <!-- selectedRecordId="{!v.PO.ERP7__Organisation__c}"-->
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[18]}">
                                    <div class="col-md-6">
                                        <c:CustomInputLookUp objectAPIName="ERP7__PO__c" IconName="standard:orders" selectedRecordId="{!v.shipment[0].ERP7__Purchase_Orders__c}"  label="{!$Label.c.purchase_Order1}"  aura:Id="PO" />
                                    </div>
                                </aura:if>
                            </div>
                            
                            <!-- Row 2-->
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                
                                <aura:if isTrue="{!v.render[2]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number" formatter="currency"  label="{!$Label.c.Shipping_Amount}" value="{!v.shipment[0].ERP7__Shipping_Amount__c}" step="0.0001"/>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[3]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number" formatter="currency"   label="{!$Label.c.Admin_Shipping_Amount}" value="{!v.shipment[0].ERP7__Admin_Shipping_Amount__c}" step="0.0001"/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                            <!-- Dimension section -->
                            <aura:if isTrue="{!v.showPackDimension}">
                                <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                     <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number"  label="{!$Label.c.ShipmentManagement_Package_Length}" value="{!v.shipment[0].ERP7__Length__c}" maxlength='10' step="0.01"/>
                                        </div>
                                    </div>
                                     <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number"  label="{!$Label.c.ShipmentManagement_Package_Width}" value="{!v.shipment[0].ERP7__Width__c}" maxlength='10' step="0.01"/>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number"  label="{!$Label.c.Height_Pack}" value="{!v.shipment[0].ERP7__Height__c}" maxlength='10' step="0.01"/>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                             <p class="greyhead Pack-newClass25">{!$Label.c.Dimension}  </p>
                                                    <div class="slds-form-element">
                                                        <lightning:select value="{!v.shipment[0].ERP7__Dimension__c}" variant="label-hidden" class="display-lable" label="Weight Unit">
                                                            <aura:iteration items="{!v.Dimension}" var="option">
                                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.shipment[0].ERP7__Dimension__c, option.value)}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number"  label="{!$Label.c.PackageSlip_List_Weight}" value="{!v.shipment[0].ERP7__Package_Weight__c}" maxlength='10' step="0.01"/>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <p class="greyhead Pack-newClass25">{!$Label.c.ShipmentManagement_Package_Weight_Unit}  </p>
                                                    <div class="slds-form-element">
                                                        <lightning:select value="{!v.shipment[0].ERP7__Package_Weight_Unit__c}" variant="label-hidden" class="display-lable" label="Weight Unit">
                                                            <aura:iteration items="{!v.WeightUnit}" var="option">
                                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.shipment[0].ERP7__Package_Weight_Unit__c, option.value)}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                        </div>
                                    </div>
                                </div>
                            </aura:if>
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15" >
                                <aura:if isTrue="{!v.render[4]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="number"  label="{!$Label.c.Shipment_Declared_Value}" value="{!v.shipment[0].ERP7__Declared_Value__c}" maxlength='10' step="0.0001"/>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[5]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:textarea   label="{!$Label.c.Ship_Description}" value="{!v.shipment[0].ERP7__Description__c}" maxlength='32768'/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15" >
                                <aura:if isTrue="{!v.render[14]}">  
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="text"  label="{!$Label.c.Invoice_Number}" value="{!v.shipment[0].ERP7__Invoice_Number__c}" maxlength='255'/>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[15]}">
                                    <div class="col-md-6 labelnone ">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label">{!$Label.c.Internal_Shipment_Tax_Number}</label>
                                            <lightning:input type="text"  value="{!v.shipment[0].ERP7__Tax_Number__c}" maxlength='80'/>
                                        </div>
                                    </div>
                                </aura:if>    
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                
                                <aura:if isTrue="{!v.render[10]}">
