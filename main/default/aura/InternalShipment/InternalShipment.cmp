                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:select  aura:id="pkgTyp" value="{!v.shipment[0].ERP7__UPS_Package_Type__c}" label="{!$Label.c.UPS_Package_Type}"	 >
                                                        <aura:iteration items="{!v.pckTypePCKLST}" var="pckopt"  >
                                                            <option value="{!pckopt}">{!pckopt}</option>   
                                                        </aura:iteration>
                                                    </lightning:select>  
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </aura:if> 
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <aura:if isTrue="{!v.render[16]}">  
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:input type="text"  label="{!$Label.c.Internal_Shipment_Bill_Label}" value="{!v.shipment[0].ERP7__Bill_Number__c}" maxlength='80'/>
                                        </div>
                                    </div>
                                </aura:if> 
                                
                                <aura:if isTrue="{!v.render[12]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:select  aura:id="unitCode" value="{!v.shipment[0].ERP7__Product_Unit_Code__c}" label="{!$Label.c.Product_Unit_Code}">
                                                        <aura:iteration items="{!v.productunitTypePCKLST}" var="pucopt"  >
                                                            <option value="{!pucopt.value}">{!pucopt}</option>   
                                                        </aura:iteration>
                                                    </lightning:select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </aura:if>  
                                
                            </div>
                            
                            <aura:if isTrue="{!v.Delivered}">
                                <div class="slds-m-around--small InternalShipment-class16">
                                    <aura:if isTrue="{!v.showcreatePO}">
                                        <aura:if isTrue="{!and(v.recordPOexists,v.shipidexists)}">
                                            <lightning:button aura:id="button1"  label="{!$Label.c.Create_PO}" name="" value="" variant="brand" disabled=""  onclick="{!c.createPOmodal}"/><!--onclick="{!c.populateRecord}"-->
                                        </aura:if>
                                    </aura:if>
                                    <lightning:button aura:id="button1"  label="{!$Label.c.ContractConsole_Save}" name="" value="" variant="brand" disabled=""  onclick="{!c.saveShipment}"/><!--onclick="{!c.populateRecord}"-->
                                </div>
                            </aura:if>
                            <!-- @end of Row 2 -->
                            
                            <!-- Row 3 -->
                            
                            <!-- @end of Row 3 -->
                            <div class="row">&nbsp;</div>
                            
                        </aura:if>
                    </aura:if>
                    
                    <aura:if isTrue="{!v.showRightTwoPickUP}">
                        <div>                   
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15">
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <lightning:input type="text" label="{!$Label.c.Shipment_Flow_Name}"  value="{!v.pickupShipment[0].Name}" maxlength="80" messageWhenTooLong="A maximum of 80 characters are allowed."/>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label">{!$Label.c.Shipment_Flow_Status}</label>
                                        <lightning:select  aura:id="SFSPick" value="{!v.pickupShipment[0].ERP7__Shipment_Flow_Status__c}" class="labelnone2" >
                                            <aura:iteration items="{!v.shipflostatus}" var="opt">
                                                <option value="{!opt.value}">{!opt.value}</option>
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row slds-grid slds-m-bottom--small labelnone InternalShipment-class15" >
                                <div class="col-md-6">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <lightning:input type="DateTime" label="" value="{!v.pickupShipment[0].ERP7__Time__c}" /><!--displayDatePicker="true"-->
                                    </div>
                                </div>
                                <aura:if isTrue="{!v.render[6]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label">{!$Label.c.Transportation_Allocation}</label>
                                            <c:CustomInputLookUp objectAPIName="ERP7__Transportation_Allocation__c" IconName="standard:address" selectedRecordId="{!v.pickupShipment[0].ERP7__Transportation_Allocation__c}"/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                            
                            <div class="row slds-grid slds-m-around--small InternalShipment-class15" >
                                <aura:if isTrue="{!v.render[7]}">   
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label">{!$Label.c.Shipping_point}</label>
                                            <c:CustomInputLookUp objectAPIName="ERP7__Shipping_point__c" IconName="standard:address" selectedRecordId="{!v.pickupShipment[0].ERP7__Shipping_point__c}"/>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.render[8]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <label class="slds-form-element__label">{!$Label.c.Loading_Dropping_point}</label>
                                            <c:CustomInputLookUp objectAPIName="ERP7__Loading_Dropping_point__c" IconName="standard:address" selectedRecordId="{!v.pickupShipment[0].ERP7__Loading_point__c}"/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                            
                            <div class="row slds-grid slds-m-around--small InternalShipment-class15" >
                                <aura:if isTrue="{!v.render[9]}">
                                    <div class="col-md-6">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                            <lightning:textarea  label="Description :" value="{!v.pickupShipment[0].ERP7__Description__c}" maxlength="32768" messageWhenTooLong="A maximum of 32768 characters are allowed."/>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>     
                            
                            <div class="slds-m-around--small InternalShipment-class16">
                                <lightning:button aura:id="button1"  label="{!$Label.c.ContractConsole_Save}" name="" value=""  variant="brand" disabled="{!(and(v.shipment[0].Id != null,v.shipment[0].Id != undefined)?false:true)}"  onclick="{!c.savePickUP}"/><!--onclick="{!c.populateRecord}"-->
                                <aura:if isTrue="{!v.ShipmentFlows.length>0}">
                                    <lightning:button aura:id="button2"  label="{!$Label.c.Cancel_ManageLeave}" name="" value="" variant="neutral" disabled=""  onclick="{!c.cancelSF}"/><!--onclick="{!c.populateRecord}"-->
                                </aura:if>
                            </div>
                        </div> 
                    </aura:if>
                    
                    <aura:if isTrue="{!v.showRightTwoCheckList}">
                        
                        <table class="slds-table slds-table--bordered slds-table--cell-buffer  slds-m-top--small">
                            <thead>
                                <tr class="slds-text-title--caps">
                                    <th scope="col"> <div class="slds-truncate" title="">{!$Label.c.Product_Name_StockTake}</div> </th>
                                    <th scope="col"> <div class="slds-truncate" title="">{!$Label.c.PackageSlip_List_Quantity} </div> </th>
                                    <th scope="col"> <div class="slds-truncate" title="">{!$Label.c.Delivered} </div> </th>
                                    <th scope="col"> <div class="slds-truncate" title="">{!$Label.c.Acc_Recev_Status_Entered}</div> </th>  
                                    <th scope="col" class="text-center"> 
                                        <div class="slds-truncate" title="">
                                            <aura:if isTrue="{!v.checkedAll}">
                                                <lightning:input type="checkbox" onchange="{!c.checkAllList}" aura:id="checkbox-all"  />
                                            </aura:if>
                                        </div> 
                                    </th>
                                </tr>
                            </thead> 
                            <tbody>
                                <aura:iteration items="{!v.allPackageList}" var="pckList" indexVar="key">
                                    <!-- SO Items Starts -->
                                    <tr aria-selected="false" class="slds-hint-parent">
                                        <td role="gridcell">
                                            <div class="slds-truncate1" title="">
                                                
                                                <aura:if isTrue="{!pckList.pack.ERP7__MRP_Material_Requirement_Planning__r.ERP7__MRP_Product__c != null}">
                                                    {!pckList.pack.ERP7__MRP_Material_Requirement_Planning__r.ERP7__MRP_Product__r.Name}
                                                    <aura:set attribute="else">
                                                        <aura:if isTrue="{!pckList.pack.ERP7__Sales_Order_Line_Item__c != Null}">
                                                            {!pckList.pack.ERP7__Sales_Order_Line_Item__r.ERP7__Product__r.Name}
                                                        </aura:if>
                                                        <aura:if isTrue="{!pckList.pack.ERP7__Order_Product__c != Null}">
                                                            {!pckList.pack.ERP7__Order_Product__r.Product2.Name}
                                                        </aura:if>
                                                        <aura:if isTrue="{!pckList.pack.ERP7__Transfer_Order_Line_Item__c != Null}">
                                                            {!pckList.pack.ERP7__Transfer_Order_Line_Item__r.ERP7__Products__r.Name}
                                                        </aura:if>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                        </td>
                                        <td role="gridcell">
                                            <div class="slds-truncate" title="">{!pckList.pack.ERP7__Quantity__c}/{!(or(pckList.pack.ERP7__Delivered_Quantity__c=='',pckList.pack.ERP7__Delivered_Quantity__c==null,pckList.pack.ERP7__Delivered_Quantity__c=='undefined')?'0':pckList.pack.ERP7__Delivered_Quantity__c)}</div>
                                        </td>
                                        <td role="gridcell">
                                            <div class="slds-truncate InternalShipment-class24" title=""><lightning:input type="number" value="{!pckList.pack.ERP7__RemaingQuantity__c}" variant="label-hidden" aura:id="EnterQuantity" disabled="{!(pckList.pack.ERP7__Quantity__c==pckList.pack.ERP7__Delivered_Quantity__c)}"/></div>
                                        </td>
                                        <td role="gridcell">
                                            <div class="slds-truncate" title="">
                                                <lightning:select  variant="label-hidden"  class="display-lable" aura:id="pckoption" value="{!pckList.pack.ERP7__Status__c}" disabled="{!(pckList.pack.ERP7__Quantity__c==pckList.pack.ERP7__Delivered_Quantity__c)}">
                                                    <aura:if isTrue="{!and(pckList.pack.ERP7__Status__c != '',pckList.pack.ERP7__Status__c != undefined)}"> 
                                                        <aura:iteration items="{!v.pckLstStsOptions}" var="option">
                                                            <option text="{!option.label}" value="{!option.value}" selected="{!equals(pckList.pack.ERP7__Status__c, option.value)}"/>
                                                        </aura:iteration>
                                                        <aura:set attribute="else">
                                                            <aura:iteration items="{!v.chklistopt}" var="opt">
                                                                <option value="{!opt}" selected="{!equals(pckList.pack.ERP7__Status__c, opt)}">{!opt}</option>
                                                            </aura:iteration> 
                                                        </aura:set>
                                                    </aura:if>
                                                </lightning:select>
                                                <!--lightning:select aura:id="pckoption" value="{!pckList.ERP7__Status__c}" variant="label-hidden" class="display-lable">
                                                    <aura:if isTrue="{!pckList.ERP7__Status__c!=null}">    
                                                        <option value="{!pckList.ERP7__Status__c}">{!pckList.ERP7__Status__c}</option>  
                                                    </aura:if>  
                                                    <aura:iteration items="{!v.chklistopt}" var="opt">
                                                        <aura:if isTrue="{!(pckList.ERP7__Status__c!=opt)}" >   
                                                            <option value="{!pckList.ERP7__Status__c}">{!opt}</option>
                                                        </aura:if>
                                                    </aura:iteration>
                                                </lightning:select-->
                                            </div>
                                        </td>
                                        <td  class="slds-text-align_center InternalShipment-class25" role="gridcell" >
                                            <aura:if isTrue="{!(pckList.pack.ERP7__Quantity__c==pckList.pack.ERP7__Delivered_Quantity__c)?False:True}">
                                                <lightning:input type="checkbox" onchange="{!c.checkCurrentList}" aura:id="checkbox-01" name="{!(pckList.pack.ERP7__Quantity__c+','+key)}" value="{!(pckList.pack.ERP7__RemaingQuantity__c+','+pckList.pack.ERP7__Delivered_Quantity__c)}" checked="{!pckList.selected}" />
                                            </aura:if> 
                                        </td>
                                    </tr>
                                </aura:iteration>
                            </tbody>
                        </table>
                        
                        <aura:if isTrue="{!v.Delivered}">
                            <!-- <aura:if isTrue="{!v.hideDelTab==false?True:false}">-->
                            <div class="slds-m-around--small InternalShipment-class16"> 
                                <aura:if isTrue="{!and(v.shipment[0].Id != null,v.shipment[0].Id != undefined)}">
                                    <lightning:button aura:id="checkListButton" variant="brand" label="{!$Label.c.Verify}"  disabled="{!lessthanorequal(v.getCheckCount.length, 0)}" onclick="{!c.saveCheckList}"/>
                                </aura:if>
                            </div>
                            <!--</aura:if>-->
                        </aura:if>
                        
                    </aura:if>
                    
                    <aura:if isTrue="{!v.showRightTwoDelivery}">
                        <div class="row"> 
                            <div class="col-md-12 shadow-sm">
                                <div class="container-fluid" onmouseover="{!c.getSign}" > 
                                    <div class="mb-signature-container" 
                                         ontouchmove="{!c.handleTouchMove}"
                                         ontouchstart="{!c.onTouch}">
                                        <aura:if isTrue="{!!v.Delivered}">
                                            <div class="mb-signature-pad-readonly">
                                                <!-- <img alt="User Signature" src="{!v.signatureData}"/> -->
                                                <img src="{!'/servlet/servlet.FileDownload?file='+v.Attachments[0].Id}" class="InternalShipment-class36" alt=""/>
                                            </div>
                                            <aura:set attribute="else">
                                                <input type="text" aura:id="signature" id="signature" value="{!v.signatureData}" readonly="true" class="esignature-hide"/>
                                                <div class="mb-signature-pad" id="{!'signatureWrapper' + v.id}">
                                                    <div class="mb-signature-pad-body InternalShipment-class37" >
                                                        <canvas></canvas>
                                                    </div>
                                                </div>
                                            </aura:set>
                                        </aura:if>
                                        <aura:if isTrue="{!v.Delivered}">
                                            <button onclick="{!c.onClear1}" class="slds-button slds-button--brand slds-m-bottom--small InternalShipment-class38">{!$Label.c.Clear}</button> 
                                        </aura:if>
                                    </div>
                                </div>
                            </div> 
                            <div class="col-md-12 shadow-sm InternalShipment-class26" >
                                <div class="col-md-12 InternalShipment-class27">
                                    <div class="card p-2 InternalShipment-class28 mb-1">
                                        <div class="slds-grid mb-1">
                                            <div class="slds-col">
                                                <h6 class="InternalShipment-class29">{!$Label.c.WONotesAndAttachment}</h6> 
                                            </div>
                                        </div>
                                        &nbsp;
                                        <div class="slds-grid mb-1 InternalShipment-class30">
                                            <div class="slds-col InternalShipment-class31">
                                                <a href="javascript:void(0);" class="{!and(and(v.Delivered ,v.shipment[0].Id != null),v.shipment[0].Id != undefined) ? (v.Delivered) ? 'slds-button slds-button--brand InternalShipment-class48' : 'slds-button slds-button--brand InternalShipment-class49' : (v.Delivered) ? 'slds-button slds-button--brand-dis InternalShipment-class48' : 'slds-button slds-button--brand-dis InternalShipment-class49'}" data-toggle="modal" data-target="#myModalNote"  onclick="{!(and(and(v.Delivered , v.shipment[0].Id != null),v.shipment[0].Id != undefined)?c.NewNote:c.newNoteDis)}"><i class="fa fa-pencil-square-o"></i></a>&nbsp;
                                            </div>
                                            <div class="slds-col">
                                                <lightning:input aura:id="fileik"  disabled="{!and(and(v.Delivered ,v.shipment[0].Id != null),v.shipment[0].Id != undefined) ? false : true}" type="file" files="{!v.FileList}" name="file" multiple="true" onchange="{!c.onFileUploaded}" class="InternalShipment-class32"/>
                                                <aura:if isTrue="{!v.showAttachSpin}">
                                                    <lightning:spinner alternativeText="{!$Label.c.Loading}" size="small" />
                                                </aura:if>
                                            </div>
                                        </div>
                                        &nbsp;
                                        <aura:if isTrue="{!v.updateFiles}">
                                            <div class="InternalShipment-class33">
                                                <aura:iteration var="AT" indexVar="ATC" items="{!v.SelectedNotes}"> 
                                                    <div class="card-body p-1">
                                                        <div class="slds-grid">
                                                            <aura:if isTrue="{!v.Delivered}">
                                                                <div class="slds-col slds-size_1-of-1 slds-medium-size_1-of-12 slds-large-size_1-of-12 slds-m-bottom--xx-small">
                                                                    <img class="InternalShipment-class34" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20"  title="Note" onclick="{!c.DeleteRecordAT}" value="Note" name="{!ATC}" id="{!AT.Id}" data-name="{!AT.Id}"  /> 
                                                                </div> 
                                                            </aura:if> 
                                                            <div class="slds-col  slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-m-bottom--xx-small text-left">
                                                                <a  href="{!'/one/one.app?#/sObject/'+ AT.Id + '/view'}" target="_blank">
                                                                    <!-- <a href="{!'/'+ AT.Id}" target="_blank"> -->
                                                                    <lightning:formattedText value="{!AT.Title}" />
                                                                </a>
                                                            </div>
                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-m-bottom--xx-small">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </aura:iteration>
                                                
                                                <aura:iteration var="AT" indexVar="ATC" items="{!v.SelectedAttachments}" > 
                                                    <div class="card-body p-1">
                                                        <div class="slds-grid">
                                                            <aura:if isTrue="{!v.Delivered}">
                                                                <div class="slds-col slds-size_1-of-1 slds-medium-size_1-of-12 slds-large-size_1-of-12 slds-m-bottom--xx-small">
                                                                    <img class="InternalShipment-class34" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20"  title="Attachment"  onclick="{!c.DeleteRecordAT}"  name="{!ATC}" id="{!AT.Id}"  data-name="{!AT.Id}" value="Attachment"/>
                                                                </div> 
                                                            </aura:if>
                                                            <div class="slds-col  slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-m-bottom--xx-small text-left">
                                                                <a  href="{!'/servlet/servlet.FileDownload?file='+AT.Id}"  target="_blank">
                                                                    <!-- <a href="{!'/'+ AT.Id}" target="_blank">-->
                                                                    <lightning:formattedText value="{!AT.Name}" />
                                                                </a>
                                                            </div>
                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-m-bottom--xx-small">
                                                                <aura:if isTrue="{!'/servlet/servlet.FileDownload?file='+AT.Id!=null}" > 
                                                                    <img src="{!'/servlet/servlet.FileDownload?file='+AT.Id}" class="InternalShipment-class35" alt=""/>
                                                                </aura:if> 
                                                            </div>
                                                        </div>
                                                    </div>
                                                </aura:iteration>
                                                
                                                <div class="row slds-grid slds-m-around--small InternalShipment-class15">
                                                    <div class="col-md-6 InternalShipment-class39">
                                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                            <strong>{!$Label.c.Full_Name}</strong>
                                                            <aura:if isTrue="{!v.Delivered==True?False:True}">  
                                                                {!v.shipment[0].ERP7__Received_By__c} 
                                                                <aura:set attribute="else">
                                                                    <lightning:input type="text"  value="{!v.shipment[0].ERP7__Received_By__c}" class="labelnone"/>
                                                                </aura:set>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="col-md-6">
                                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                            <aura:if isTrue="{!v.Delivered==True?False:True}"> 
                                                                <lightning:formattedDateTime value="{!v.deliveryShipment[0].ERP7__Time__c}" label="{!$Label.c.Date_Time}"  format=" dd-MM-YYYY HH:mm"   />
                                                                <aura:set attribute="else">
                                                                    <lightning:input type="DateTime"   value="{!v.deliveryShipment[0].ERP7__Time__c}" />
                                                                </aura:set>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                        &nbsp;&nbsp;
                                        <aura:if isTrue="{!v.Delivered}">
                                            <div class="slds-m-around--small InternalShipment-class16">
                                                <lightning:button aura:id="button1"  label="{!$Label.c.ContractConsole_Save}" name="" value="" variant="brand"  disabled="{!(v.shipment[0].Id != null?false:true)}"  onclick="{!c.saveDSF}"/> <!--class="{!(v.shipment[0].Id != null?v.en:'slds-button slds-brand-disabled')}"--> <!--onclick="{!c.populateRecord}"-->
                                                <lightning:button aura:id="button2"  label="{!$Label.c.Cancel_ManageLeave}" name="" value="" variant="neutral" disabled=""  onclick="{!c.cancelSF}"/><!--onclick="{!c.populateRecord}"-->
                                            </div>
                                        </aura:if>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row slds-grid slds-m-around--small InternalShipment-class15">
                                <div class="col-md-12 col-xs-12" >
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                    </div>
                                </div>
                            </div>
                        </div> 
                    </aura:if>
                    
                    <aura:if isTrue="{!v.showPDSection}">
                        <aura:if isTrue="{!v.Delivered}">
                            <div class="slds-m-top--small"></div>
                            <a href="javascript:void(0)" onclick="{!c.NewSF}" data-target="#myModal" class="InternalShipment-class40" data-toggle="modal" title="Add Product" data-aura-rendered-by="1159:309;a">
                                {!$Label.c.New_AddTimeCardEntry} 
                            </a> 
                        </aura:if>
                        <!--aura:if isTrue="{!v.showSF}"-->
                            <div class="col-sm-12 InternalShipment-class41" >
                                <table class="slds-table slds-table--bordered slds-table--cell-buffer  slds-m-top--small">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <aura:if isTrue="{!v.Delivered}">   <th scope="col"> <div class="slds-truncate" title="Action">{!$Label.c.AddSubscription_Action}</div> </th></aura:if>
                                            <th scope="col"> <div class="slds-truncate" title="Sl.No">{!$Label.c.Sl_No}</div> </th>
                                            <th scope="col"> <div class="slds-truncate" title="Location">{!$Label.c.Name_ManageLeave}</div> </th>
                                            <!--<th scope="col"> <div class="slds-truncate" title="Pickup point">Location</div> </th>-->
                                            <th scope="col"> <div class="slds-truncate" title="Date/Time">{!$Label.c.Date_Time1}</div> </th>
                                            <th scope="col"> <div class="slds-truncate" title="Activity">{!$Label.c.Activity_AddTimeCardEntry}</div> </th>                                                                
                                        </tr>
                                    </thead> 
                                    <tbody>
                                        <aura:if isTrue="{!v.ShipmentFlows.length>0}">
                                        <aura:iteration items="{!v.ShipmentFlows}" var="opt" indexVar="key" >
                                            <tr>  
                                                <aura:if isTrue="{!v.Delivered}"> 
                                                    <td data-label="Sl.No" class="InternalShipment-class42">
                                                        <div class="slds-truncate" title="Delete">
                                                            <div class=" slds-grid " > <!--slds-m-around-/-small InternalShipment-class15-->
                                                                <div>
                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" id="{!opt.Id}" onclick="{!c.EditSF}" class="InternalShipment-class43" />
                                                                </div>
                                                                <div>
                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" onclick="{!c.DeleteSF}" id="{!opt.Id}" class="InternalShipment-class43"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </aura:if>
                                                <td data-label="Sl.No">
                                                    <div class="slds-truncate1" title="Sl.No">
                                                        {!key+1}
                                                    </div>
                                                </td>
                                                <td data-label="Name">
                                                    <div class="slds-truncate1" title="Name"> 
                                                        {!opt.Name}
                                                    </div>
                                                </td>  
                                                <td data-label="Date">
                                                    <div class="slds-truncate1" title="Date/Time">
                                                        <lightning:formattedDateTime value="{!opt.ERP7__Time__c}" format=" dd-MM-YYYY HH:mm:ss"   year="numeric" month="numeric" day="numeric" hour="2-digit" minute="2-digit"/>
                                                    </div>
                                                </td>
                                                <td data-label="Activity">
                                                    <div class="slds-truncate1" title="Activity"> 
                                                        <aura:if isTrue="{!opt.ERP7__Shipment_Flow_Status__c!='--None--'}">{!opt.ERP7__Shipment_Flow_Status__c}</aura:if>
                                                    </div>
                                                </td>                                                                     
                                            </tr>
                                        </aura:iteration>
                                        </aura:if>
                                    </tbody> 
                                </table>
                            </div> 
                            
                        <!--/aura:if-->
                    </aura:if>
                </div>
                <!-- End of right section -->
            </div>
            
            <div role="dialog" tabindex="-1" aria-labelledby="header43" aura:id="Modalbox" class="slds-modal InternalShipment-class44">
                <div class="slds-modal__container">
                    <div class="slds-modal__header InternalShipment-class45" >
                        <h2 id="header43" class="slds-text-heading--medium">Note</h2>
                    </div>
                    <div class="slds-modal__content">
                        <div class="modal-body"> 
                            <fieldset class="slds-form--compound">
                                <div class="slds-form-element__group">
                                    <div class="row">
                                        <div class="col-md-9">
                                            <lightning:input type="Text" aura:id="name" label="Title" value="{!v.NewNote.Title}" required="True" />
                                            <aura:if isTrue="{!v.errorMsgPop != null}"><span class="InternalShipment-class46">{!v.errorMsgPop}</span></aura:if>
                                        </div>
                                        <div class="col-md-3 slds-m-top--xx-small">
                                            <label class="slds-form-element__label" for="input-06">{!$Label.c.Private}</label>
                                            <div class="slds-form-element__control">
                                                <span class="">
                                                    <lightning:input type="Checkbox"  aura:id="checkbox3"   name="options"  value="{!v.NewNote.isPrivate}" checked="{!v.NewNote.isPrivate}" />
                                                    <label class="slds-checkbox__label" for="checkbox">
                                                        <span class="slds-checkbox"></span>
                                                    </label>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12 slds-m-top--xx-small">
                                            <!--  <label class="slds-form-element__label" for="input-05">Body</label>-->
                                            <lightning:TextArea aura:id="details"  label="Body"  maxlength="255" messageWhenTooLong="A maximum of 255 characters are allowed." value="{!v.NewNote.Body}" />
                                        </div>
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                    <div class="slds-modal__footer InternalShipment-class47" >
                        <div class=" slds-text-align--center">
                            <button class="slds-button slds-button--brand" onclick="{!c.SaveNote}">{!$Label.c.ContractConsole_Save}</button>
                            <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal" onclick="{!c.closeModal}">{!$Label.c.Close_Timesheets}</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</aura:component>