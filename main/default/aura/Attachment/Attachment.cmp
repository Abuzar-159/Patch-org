<aura:component controller="UploadFile">
     <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <!--<html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink"/> Commented in Security Review-->
        <ltng:require styles="/resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.css, /resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.min.css,
                              /resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css"/>
     </head>  
    
   <aura:attribute name="parentId" type="Id" default="" />
   <aura:attribute name="showLoadingSpinner" type="boolean" default="false" />  
   <aura:attribute name="fileName" type="String" default="No File Selected" />    
   <aura:attribute name="Application" type="String" default=""/>
   <aura:registerEvent name="Attachment" type="c:AttachmentEvnet"/>  
	<aura:attribute name="AttachmentBody" type="Object" default="" />  <!-- String  --> 
    
    <lightning:input aura:id="fileId" class="slds-button" onchange="{!c.handleFilesChange}" label="" type="file" multiple="false" value=""  body="" files=""/> 
    {!v.fileName}  &nbsp; &nbsp;&nbsp; &nbsp;
    <aura:if isTrue="{!v.showLoadingSpinner}">
      Uploading... 
        <img aura:id="mainSpinId" id="mainSpin" src="/resource/ERP7__SLDS213/assets/images/spinners/slds_spinner_brand.gif"
                            class="attachment-class1"/>
        
    </aura:if>                        
                            
</aura:component>