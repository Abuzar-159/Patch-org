                                                        </th>
                                                        </aura:renderIf>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Price">Price</div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Quantity">Charge/Qty</div>
                                                        </th>
                                                        <!--<aura:renderIf isTrue="{!pro.product.ERP7__Is_Asset__c}">
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="End Time">End Time</div>
                                                            </th>
                                                        </aura:renderIf>-->
                                                        <th scope="col">
