                                                                <aura:renderIf isTrue="{!(pro.product.ERP7__Picture__c != undefined)}">
                                                                    &nbsp;<img src="{!pro.product.ERP7__Picture__c}" class="POS-newClass69" />
                                                                </aura:renderIf>
                                                            </div>
                                                        </td>
														<aura:renderIf isTrue="{!!(pro.Version == '')}">
                                                        <td>
                                                            <div class="row">
                                                                <div class="col-md-10 POS-newClass90" title=" version" name="{!count}" id="{!pro.product.Id}">
                                                                    <!--:inputSelect  aura:id=" ver" value="{!pro.Version}" onchange="{!c.VersionChanged}" >
                                                                        <aura:iteration items="{!pro.Versions}" var="po">
                                                                            <:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.Version,true,false)}"/>
                                                                        </aura:iteration>
                                                                    </:inputSelect-->
                                                                </div>
                                                            </div>
                                                        </td>
                                                        </aura:renderIf>
                                                        <td>
