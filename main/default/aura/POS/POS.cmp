                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="slds-truncate" title="Charge/Qty" name="{!count}" id="{!pro.product.Id}">
                                                                <lightning:input type="text" variant="label-hidden" value="{!pro.quantity_s}" aura:id="quan"  change="{!c.addDiscountEdit}" /><!-- addDiscountEdit -->
                                                            </div>
                                                        </td>
                                                        
                                                        <td>
                                                            <div class="slds-truncate" title="Rental Unit" name="{!count}" id="{!pro.product.Id}">
                                                                <lightning:formattedText value="{!pro.product.QuantityUnitOfMeasure}"/>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="row">
                                                                <div class="col-md-4 POS-newClass90" title="Discount Plan" name="{!count}" id="{!pro.product.Id}">
                                                                    <!--:inputSelect  aura:id="dis" value="{!pro.discountName}" onchange="{!c.discountPercentsEdit}" >
                                                                        <aura:iteration items="{!pro.CurrentDiscounts}" var="po">
                                                                            <:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.discountName,true,false)}"/>
                                                                        </aura:iteration>
                                                                    </:inputSelect-->
                                                                </div>
                                                                <div class="slds-truncate col-md-3 POS-newClass139" title="Discount/Unit" name="{!count}" id="{!pro.product.Id}">
                                                                    <lightning:input type="text" variant="label-hidden" aura:id="editDiscountper" value="{!pro.discountPercent}" keyup="{!c.editvalidatevalue}" updateOn="keyup"  placeholder="{!if(pro.isPercent == true,'Percentage','Value')}" />
                                                                    
                                                                    <!--keyup="{!c.validatevalue}"-->
                                                                </div>
                                                                <div class="slds-truncate col-md-4 POS-newClass91">
                                                                    [<lightning:formattedNumber value="{!pro.minDiscountPercent}"/>-<lightning:formattedNumber value="{!pro.maxDiscountPercent}"/>]
                                                                    <aura:renderIf isTrue="{!(pro.isPercent == true)}">%</aura:renderIf>
                                                                </div>
                                                            </div>
                                                        </td>
                                                       
                                                        <aura:renderIf isTrue="{!!(v.IsRental)}">
                                                        <td>
                                                            <div class="slds-truncate" title="Availability">
                                                                <lightning:formattedNumber value="{!pro.stock}"/>
                                                            </div>
                                                        </td>
                                                        </aura:renderIf>
                                                        
                                                    </tr>
                                                </tbody>
                                            </table>
                                            
                                            <!--Ends Here -->
                                            <aura:renderIf isTrue="{!(v.SerialPopup)}">
                                                <div class="col-md-12 POS-newClass131">
