                                                                                        </aura:renderIf>    
                                                                                    </div>
                                                                                </td>
                                                                                <td>
                                                                                    <div class="slds-truncate" title="Availability">
                                                                                        <lightning:formattedText value="{!SLN.Batch.ERP7__Available_Quantity__c}" />	
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        </tbody>
                                                                    </aura:iteration>
                                                                </table>
                                                            </div>
                                                            
                                                        </article>
                                                    </div>
                                                </div>
                                            </aura:renderIf>
                                        </div>
                                    </div>
                                </aura:iteration>
                                <div class="modal-footer">
                                    
                                    <lightning:button variant="brand" onclick="{!c.updateItem}">Update</lightning:button>
                                    
