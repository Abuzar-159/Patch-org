            <!-- Modal Edit Product Line Item -->
            <div id="myModale" class="modal fade" role="dialog">
                <div class="modal-dialog modal-lg POS-newClass76">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-body">
                            
                            <!-- Table -->
                            <article class="slds-card slds-m-top--small POS-newClass109">
                                <header class="slds-card__header slds-grid">
                                    <div class="slds-media slds-media--center slds-has-flexi-truncate">
                                        <div class="slds-media__figure">
                                        </div>
                                        
                                        <div class="slds-media__body POS-newClass110">
                                            <h4 class="POS-newClass111">
                                                <span>Edit Sales Order Line Item</span>
                                            </h4>
                                        </div>
                                        <span class="POS-newClass75">
