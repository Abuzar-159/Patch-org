                                     <lightning:button variant="brand" onclick="{!c.assignEdit}">Assign</lightning:button>
                                    </aura:renderIf>-->
                                    <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Close</button>
                                </div>
                            </article>
                            
                        </div>
                    </div>
