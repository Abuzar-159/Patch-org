                                            <tr class="slds-text-heading--label POS-newClass26" bgcolor="#f4f6f9">
                                                <th class="POS-newClass127">Select</th>
                                                <th class="POS-newClass127">Service Code</th>
                                                <th class="POS-newClass127">Service Type</th>
                                                <th class="POS-newClass127">Total</th>
                                                <th class="POS-newClass127">Currency</th>
                                                <th class="POS-newClass127">Delivery Date</th>
                                                <th class="POS-newClass127;">Days To Deliver</th>
                                                <th class="POS-newClass127">Time To Deliver</th>
                                            </tr>
                                            <aura:iteration var="twl" indexVar="pcount" items="{!v.UPS_Services.Services}">
                                                <tr class="POS-newClass28">
                                                    <td class="POS-newClass134">
                                                        <div class="slds-truncate POS-newClass135">
                                                           
                                                            <lightning:input type="radio" aura:id="r0" name="others" value="{!twl.Selected}"/>
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass137">
                                                            <lightning:formattedText value="{!twl.ServiceCode}" title="{!twl.ServiceCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass140">
                                                            <lightning:formattedText value="{!twl.ServiceManual}" title="{!twl.ServiceManual}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <aura:renderIf isTrue="{!(twl.negotiatedCharges == '')}">
                                                            <div class="slds-truncate POS-newClass138">
                                                                <lightning:formattedText value="{!twl.totalCharges}" title="{!twl.totalCharges}" />
                                                            </div>
                                                        </aura:renderIf>
                                                        <aura:renderIf isTrue="{!(twl.negotiatedCharges != '')}">
                                                            <div class="slds-truncate POS-newClass138">
                                                                <lightning:formattedText value="{!twl.negotiatedCharges}" title="{!twl.negotiatedCharges}" />
                                                            </div>
                                                        </aura:renderIf>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass138">
                                                            <lightning:formattedText value="{!twl.currencyCode}" title="{!twl.currencyCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <aura:renderIf isTrue="{!(twl.DeliveryDate != null)}">
                                                            <div class="slds-truncate POS-newClass138">
                                                                <lightning:formattedDateTime value="{!twl.DeliveryDate}" />
                                                            </div>
                                                        </aura:renderIf>
                                                        <aura:renderIf isTrue="{!(twl.DeliveryDate == null)}">
                                                            <div class="slds-truncate POS-newClass138">
                                                                <lightning:formattedText value="{!twl.DeliveryDateS}" title="{!twl.DeliveryDateS}" />
                                                            </div>
                                                        </aura:renderIf>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass137">
                                                            <lightning:formattedText value="{!twl.GuaranteedDaysToDelivery}" title="{!twl.GuaranteedDaysToDelivery}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass137">
                                                            <lightning:formattedText value="{!twl.ScheduledDeliveryTime}" title="{!twl.ScheduledDeliveryTime}" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <lightning:button variant="brand" onclick="{!c.Services}">Get Services</lightning:button>
