<aura:component Controller="ERP7.POSLightning" implements="flexipage:availableForAllPageTypes,force:appHostable,forceCommunity:availableForAllPageTypes" access="global"> 
     
    <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css', $Resource.PickPackShipResource + '/assets/styles/main-scrollers.css')}"  />
    <ltng:require styles="{!join(',',$Resource.Order_Console + '/assets/styles/custom.css', $Resource.Order_Console + '/assets/styles/font-awesome.css')}"  />
    <ltng:require styles="{!join(',',$Resource.SLDS213 + '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/POS.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:attribute name="Customer" type="Object" default="{sobjectType : 'Account','unknown_custom_field':'','ERP7__VAT__c':''}" />
    <aura:attribute name="CustomerTemp" type="Object" default="{sobjectType : 'Account','unknown_custom_field':'','ERP7__VAT__c':''}" />
    <aura:attribute name="Custo" type="Account" default="{sobjectType : 'Account','ERP7__VAT__c':''}" />
    <aura:attribute name="Contact" type="Contact" default="{sobjectType  : 'Contact'}" />
    <aura:attribute name="SalesOrder" type="Object" />
    <aura:attribute name="SOLI" type="Object" />
    <aura:attribute name="AccProfile1" type="Object" />
    <aura:attribute name="AccProfile2" type="Object" />
    <aura:attribute name="NewCust" type="Object" />
    <aura:attribute name="NewCon" type="Object" />
    <aura:attribute name="AccTax1" type="Object" />
    <aura:attribute name="AccTax2" type="Object" />
    <aura:attribute name="Payment" type="Object" />
    <aura:attribute name="PaymentMethod" type="Object" />
    <aura:attribute name="UPS_Services" type="Object" />
    <aura:attribute name="FEDEX_Services" type="Object" />
    <aura:attribute name="DHL_Services" type="Object" />
    <aura:attribute name="lineItemTOdelete" type="Integer"/>
    <aura:attribute name="CountHolder" type="Integer"/>
    <aura:attribute name="CVV" type="String" />
    <aura:attribute name="qry" type="String" />
    <aura:attribute name="CardError" type="String"/>
    <aura:attribute name="CashError" type="String"/>
    <aura:attribute name="BankError" type="String"/>
    <aura:attribute name="UPSError" type="String"/>
    <aura:attribute name="NewAccountError" type="String"/>
    <aura:attribute name="NewContactError" type="String"/>
    <aura:attribute name="NewAddressError" type="String"/>
    <aura:attribute name="FedExError" type="String"/>
    <aura:attribute name="DHLError" type="String"/>
    <aura:attribute name="shipError" type="String"/>
    <aura:attribute name="Coupon" type="String"/>
    <aura:attribute name="accType" type="String"/>
    <aura:attribute name="Points_Per_Unit_Amount" type="Decimal" default="0.000"/>
    <aura:attribute name="LoyaltyError" type="String"/>
    <aura:attribute name="CreditError" type="String"/>
    <aura:attribute name="LoyaltyPoint2Use" type="Integer"/>
    <aura:attribute name="productLimit" type="Integer" default="200"/>
    <aura:attribute name="CreditAmount2Use" type="Integer"/>
    <aura:attribute name="TaxRate" type="Decimal" default="0.000"/>
    <aura:attribute name="accTaxRate" type="Decimal" default="0.000"/>
    <aura:attribute name="custInvoiceTest" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}"/>
    <aura:attribute name="addAddress" type="Address__c" default="{sobjectType:'Address__c','ERP7__Contact__c': ''}"/>
    <aura:attribute name="NewCustomer" type="Account" default="{sobjectType : 'Account','unknown_custom_field':'','ERP7__VAT__c':''}" />
    <aura:attribute name="NewContact" type="Contact" default="{sobjectType:'Contact','LastName' : '','AccountId': ''}" />
    <aura:attribute name="NewAddress" type="Address__c" default="{sobjectType:'Address__c','ERP7__Customer__c': '','ERP7__Contact__c': ''}"/>
    <aura:attribute name="com" type="Commission__c" default="{sobjectType : 'Commission__c'}"/>
    <aura:attribute name="currentSalepoint" type="Channel__c" default="{sobjectType : 'Channel__c'}" />
    <aura:attribute name="currentEmployee" type="Employees__c" default="{sobjectType : 'Employees__c','Name': ''}" />
    <aura:attribute name="Invoice" type="Invoice__c" default="{sobjectType : 'Invoice__c','ERP7__Account__c':''}" />
    <aura:attribute name="pageSubscription" type="Subscription__c" default="{sobjectType : 'Subscription__c'}" />
    <aura:attribute name="fieldError" type="String" default=""/>
    <aura:attribute name="SON" type="String"/>
    <aura:attribute name="SOP" type="String"/>
    <aura:attribute name="bAdd" type="String"/>
    <aura:attribute name="sAdd" type="String"/>
    <aura:attribute name="lockProfile" type="Boolean" default="false"/>
    <aura:attribute name="isClosed" type="Boolean" default="false"/>
    <aura:attribute name="orderStatus" type="String"/>
    <aura:attribute name="Country" type="String"/>
    <aura:attribute name="County" type="String"/>
    <aura:attribute name="itemName" type="String" default=""/>
    <aura:attribute name="exceptionError" type="String"/>
    <aura:attribute name="subTotal" type="Decimal" default="0"/>
    <aura:attribute name="discounts" type="Decimal" default="0"/>
    <aura:attribute name="taxes" type="Decimal" default="0.000"/>
    <aura:attribute name="totalDue" type="Decimal" default="0"/>
    <aura:attribute name="amountPaid" type="Decimal" default="0"/>
    <aura:attribute name="loyaltyPoints" type="Decimal" default="0"/>
    <aura:attribute name="loyaltyAmount" type="Decimal" default="0"/>
    <aura:attribute name="shippingAmount" type="Decimal" default="0"/>
    <aura:attribute name="finalDue" type="Decimal" default="0"/>
    <aura:attribute name="itemWrapperListt" type="object[]"/>
    <aura:attribute name="Payments" type="object[]"/>
    <aura:attribute name="CreditNotes" type="object[]"/>
    <aura:attribute name="Shipments" type="object[]"/>
    <aura:attribute name="ProductsAndDiscountsWrapperListt" type="object[]"/>
    <aura:attribute name="pdLists" type="object[]"/>
    <aura:attribute name="Serials2Delete" type="String[]"/>
    <aura:attribute name="SerialCount" type="Integer"/>
    <aura:attribute name="SelectedProduct" type="object" default=""/>
    <aura:attribute name="mySerialNos" type="object[]"/>
    <aura:attribute name="myBatchNos" type="object[]"/>
    <aura:attribute name="ProductsAndDiscountsWrapperListtEdit" type="object[]"/>
    <aura:attribute name="prod_Family_Type" type="Product2" default="{sobjectType : 'Product2'}"/>
    <aura:attribute name="prodFam" type="String"/>
    <aura:attribute name="prodCat" type="String"/>
    <aura:attribute name="prodSubCat" type="String"/>
    <aura:attribute name="prodDescription" type="String"/>
    <aura:attribute name="invoiceName" type="String"/>
    <aura:attribute name="CUST" type="String"/>
    <aura:attribute name="CON" type="String"/>
    <aura:attribute name="preCon" type="String"/>
    <aura:attribute name="proceed" type="Boolean" default="false"/>
    <aura:attribute name="popup1Spinner" type="Boolean" default="true"/>
    <aura:attribute name="popup2Spinner" type="Boolean"/>
    <aura:attribute name="serialShow" type="Boolean" default="false"/>
    <aura:attribute name="lineItem2delete" type="String[]"/>
    <aura:attribute name="customerCreditLimit" type="String"/>
    <aura:attribute name="editCount" type="Integer"/>
    <aura:attribute name="RecentlyViewedList" type="object[]"/>
    <aura:attribute name="RentalUnit" type="object[]"/>
    <aura:attribute name="IsRental" type="Boolean" default="false"/>
    <aura:attribute name="showAvailable" type="Boolean" default="true"/>
    <aura:attribute name="SerialNumber" type="String"/>
    <aura:attribute name="BatchNumber" type="String"/>
    <aura:attribute name="SerialPopup" type="Boolean" default="false"/>
    <aura:attribute name="BatchPopup" type="Boolean" default="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <aura:method name="saveMethod" action="{!c.draftSave}"></aura:method>
    <aura:method name="fetchProductNew" action="{!c.fetchProduct}"></aura:method>
    <aura:handler name="change" value="{!v.Customer.Id}" action="{!c.lookupChangeAccount}"/>
    <aura:handler name="change" value="{!v.Contact.Id}" action="{!c.lookupChangeContact}"/>
    <aura:handler name="change" value="{!v.SalesOrder.Id}" action="{!c.lookupChangeOrder}"/>
    <!--<aura:handler name="change" value="{!v.custInvoiceTest.Id}" action="{!c.lookupChangeAccountNumber}"/>-->
    <aura:handler event="force:refreshView" action="{!c.getAllDetails}" />
    <!--<aura:registerEvent name="SetQRYParam" type="c:SetQRYParam" />-->
    <aura:attribute name="num" type="integer" default="100000"/>
    <aura:attribute name="crudValues" type="Map" default="{}" />
    
    
        
    
    <div class="slds erp_mark7 bgwhiteerp" aura:id="body">
        <span class="POS-newClass13">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
        <div class="epr_Mark7">
            <div class="container-fluid">
                <div class="row">
                    <!--:message title="" severity="error" class="{!empty(v.exceptionError)?'slds-hide':'errmsgclass slds-show'}">
                        <div class="slds-notify slds-notify-alert slds-theme-alert-texture slds-theme-error" role="alert">
                            <p class="POS-newClass1">{!v.exceptionError}</p>  
                        </div>
                    </:message-->
                    <div class="col-sm-5 col-md-5 POS-newClass2">
                        
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name"><span class="POS-newClass3">*</span> Account Name</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control lookupik"><!-- onclick="{!c.lookupClickAccount}" -->
                                     	<c:CustomInputLookUp objectAPIName="Account" aura:id="OrgName" IconName="standard:account" selectedRecord="{!v.Customer}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Account Number</label>
                                <div class="slds-form-element">
                                    
                                    <div class="slds-form-element__control">
                                        <c:CustomInputLookUp objectAPIName="Account" aura:id="cc" selectedRecord="{!v.Customer}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}" SearchField="AccountNumber"/>
                                    </div>
                                    
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Title</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="text" variant="label-hidden" aura:id="titl" 
                                                      value="{!v.Contact.Title}"
                                                      />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Contact Name</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control" onclick="{!c.lookupClickContact}"><!-- onclick="{!c.lookupClickContact}" -->
                                        <c:CustomInputLookUp objectAPIName="Contact" aura:id="conN" IconName="standard:contact" selectedRecord="{!v.Contact}" qry="{!v.qry}"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Contact Email</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="text" variant="label-hidden" aura:id="conE" 
                                                      value="{!v.Contact.Email}"
                                                      />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Contact Phone</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="text" variant="label-hidden" aura:id="num" 
                                                      value="{!v.Contact.Phone}"
                                                      />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-6">
                                <label class="slds-form-element__label" for="name"><span class="POS-newClass3">*</span> Bill to</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <!--:inputSelect  aura:id="bAdd" value="{!v.bAdd}" change="{!c.onSelectBA}"/-->
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control POS-newClass4">
                                        <!-- disabled="true" -->
                                        <lightning:textarea aura:id="ba" disabled="true"
                                                          class="slds-textarea" 
                                                          rows="4" cols="20"
                                                          value="{!v.pageSubscription.ERP7__Bill_To_Address__c}"
                                                          />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="slds-form-element__label" for="name"><span class="POS-newClass3">*</span> Ship to</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <!--:inputSelect  aura:id="sAdd" value="{!v.sAdd}" onchange="{!c.onSelectSA}"/-->
                                    </div>
                                </div>
                                <div class="slds-form-element POS-newClass4">
                                    <div class="slds-form-element__control">
                                        <!-- disabled="true" -->                                       
                                        <lightning:textarea aura:id="sa" disabled="true"
                                                          class="slds-textarea" 
                                                          rows="4" cols="20"
                                                          value="{!v.pageSubscription.ERP7__Ship_To_Address__c}"
                                                          />
                                    </div>
                                </div>
                            </div>
                            <table>
                                <tr class="POS-newClass5">
                                    <td>
                                        <input></input> 
                                    </td>
                                    <td>
                                        <input></input> 
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="col-sm-7 col-md-7 POS-newClass6">
                        <!-- Nav tabs -->
                        <ul class="nav nav-tabs " role="tablist">
                            <li class="nav-item active"> <a class="nav-link" data-toggle="tab" href="#home" role="tab"><i class="fa fa-file-text-o" aria-hidden="true"></i> Sales Order</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" href="#payment" role="tab"><i class="fa fa-qrcode fa-1x"></i> Payment</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" href="#delivery" role="tab"><i class="fa fa-truck fa-1x"></i> Delivery</a> </li>
                            <!--<li class="nav-item"> <a class="nav-link" data-toggle="tab" href="#return" role="tab"><i class="fa fa-share-square-o fa-1x"></i> Return</a> </li>-->
                            <li class="nav-item"> <a class="nav-link active" data-toggle="tab" href="#chatter" role="tab"><i class="fa fa-users fa-1x"></i> Chatter</a> </li>
                            <li class="nav-item"> <a class="nav-link active" data-toggle="tab" href="#account" role="tab"><i class="fa fa-user fa-1x"></i> Account</a> </li>
                        </ul>
                        <!-- Tab panes -->
                        <div class="tab-content">
                            <div class="tab-pane active" id="home" role="tabpanel">
                                <div class="col-md-6">
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Sales Order</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control" onclick="{!c.lookupClickOrder}">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Sales_Order__c" aura:id="so" IconName="standard:orders" selectedRecord="{!v.SalesOrder}" qry="{!v.qry}"/>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">
                                                <span class="POS-newClass3">*</span> Order Profile</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <!--:inputSelect  aura:id="InputSelectDynamic" value="{!v.SOP}" disabled="{!if(v.itemWrapperListt.length > 0,true,false)}"/-->
                                                    <!--disabled="{!if(v.itemWrapperListt.length > 0,true,false)}"-->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small POS-newClass7">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Invoice No.</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <!-- disabled="true"  --> 
                                                    <lightning:input type="text" variant="label-hidden" aura:id="sio" disabled="true"
                                                                  value="{!v.invoiceName}"
                                                                  />
                                                    <!--<force:inputField  aura:id="sio" value="{!v.Invoice.Name}"/>-->
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Payment Status</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="so" 
                                                                  disabled="true"
                                                                  value="{!v.SalesOrder.ERP7__Payments_Status__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small POS-newClass8">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label POS-newClass9" for="name">PO Reference</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="so" 
                                                                  value="{!v.SalesOrder.ERP7__Purchase_Order_Number__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">{!$Label.c.OrderConsole_Expected_Date}</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control POS-newClass10">
                                                    <lightning:input type="date" variant="label-hidden" class="display-lable" aura:id="so" 
                                                                  
                                                                  value="{!v.SalesOrder.ERP7__Expected_Date__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small POS-newClass11">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Status</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">

                                                    <!--:inputSelect  aura:id="orderStatus" value="{!v.orderStatus}" onchange="{!c.SOStatus}"/-->
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Special Instructions</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:textarea aura:id="sa" 
                                                                      class="slds-textarea slds-textareaa"
                                                                      rows="3" cols="20"
                                                                      value="{!v.SalesOrder.ERP7__Special_Instructions__c}"
                                                                      />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="row slds-m-top--x-small">
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name"><span class="POS-newClass3">*</span> Employee</label><br/>
                                                <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" aura:id="emp" IconName="standard:user" selectedRecord="{!v.currentEmployee}"/>
                                            </div>
                                            
                                        </div>
                                        
                                        <div class="col-md-12 slds-m-top--x-small">
                                            
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Shipment Type</label><br/>
                                                <div class="slds-form-element__control">
                                                    <!--:inputSelect  aura:id="STP" value="{!v.SalesOrder.ERP7__Shipment_Type__c}"/-->
                                                </div>
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-12 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                        <lightning:input type="checkbox" checked="{!v.SalesOrder.ERP7__Is_Back_Order__c}"  disabled="true"/>
                                                        <label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Back Order</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                        <lightning:input type="checkbox" checked="{!v.SalesOrder.ERP7__Is_Pre_Order__c}"  disabled="true"/><!--click="{!c.POrder}"-->
                                                        <label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Pre Order</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>
                                            
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <aura:If isTrue="{!v.crudValues.ERP7__Authorised__c}">
                                    			<lightning:input type="checkbox" checked="{!v.SalesOrder.ERP7__Authorised__c}" class="chekbox"/> 
                                                <label class="slds-checkbox__label" for="checkbox-1">
                                                    <span class="slds-checkbox_faux"></span>
                                                    <span class="slds-form-element__label POS-newClass12">Authorised</span>
                                                </label>
                                                </aura:If>
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                        <lightning:input type="checkbox" checked="{!v.SalesOrder.ERP7__Is_Closed__c}" disabled="{!(v.SalesOrder.Id == undefined)}"/>
                                                        <label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Closed</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12 POS-newClass5">
                                        	<c:ProjectLookups type="Account" aura:id="OrgName" value="{!v.custInvoiceTest.ERP7__Account__c}" className="slds-input" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="row">
                                      
                                       <div class="col-md-11">
                                            <aura:If isTrue="{!(v.SalesOrder.Name != undefined )}">
                                                <lightning:button variant="brand" onclick="{!c.OpenOrder}" >
                                                    <i class="fa fa-list" aria-hidden="true"></i> Order Document
                                                </lightning:button>
                                            </aura:If>
                                        </div>
                                        <div class="col-md-11">
                                            <aura:renderIf isTrue="{!(v.Invoice.Name != undefined )}">
                                                <lightning:button variant="brand" onclick="{!c.OpenInvoice}" >
                                                    <i class="fa fa-list" aria-hidden="true"></i>&nbsp;Invoice Document
                                                </lightning:button>
                                            </aura:renderIf>
                                        </div>
                                        <div class="col-md-11">
                                            <aura:renderIf isTrue="{!(v.SalesOrder.ERP7__Is_Closed__c  == true)}">
                                                <lightning:button variant="brand" onclick="{!c.RMA}">
                                                    <i class="fa fa-external-link" aria-hidden="true"></i>&nbsp;RMA
                                                </lightning:button>
                                            </aura:renderIf>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane slds-p-top--xx-small" id="chatter" role="tabpanel" >
                                <div class="col-md-12">
                                    <!--<ERP7:Chatter />-->
                                    <iframe src="{!'/apex/ERP7__ChatterLC?core.apexpages.devmode.url=1'}" width="100%" height="300px;" frameBorder="0" align="top"/>
                                </div>
                            </div>
                            <div class="tab-pane" id="account" role="tabpanel">
                                <div class="col-md-7">
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label POS-newClass9" for="name">Company</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="comp" value="{!v.Customer.ERP7__Company__c}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Website</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="comp" value="{!v.Customer.Website}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Phone</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                   <lightning:input type="text" variant="label-hidden" aura:id="num" value="{!v.Customer.Phone}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Fax</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="comp" value="{!v.Customer.Fax}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Profile</label>
                                            <div class="slds-form-element"> <!-- onclick="{!c.lookupClickProfile}" -->
                                                <div class="slds-form-element__control">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Profiling__c" aura:id="profl" IconName="standard:client" selectedRecord="{!v.AccProfile1}" qry="{!'AND ERP7__Record_Type_Name__c =\'Customer\''}"/>
                                                </div>
                                            </div> 
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Account No.</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control" >
                                                    <lightning:input type="text" variant="label-hidden" aura:id="comp" value="{!v.Customer.AccountNumber}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Tax</label>
                                            <div class="slds-form-element" onclick="{!c.lookupClickBlank}">
                                                <div class="slds-form-element__control">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Tax__c" aura:id="cvat2" IconName="standard:entity" selectedRecord="{!v.AccTax1}" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Tax Regn.No.</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id=" vatregis" value="{!v.Customer.ERP7__VAT_registration_number__c}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5 POS-newClass14">
                                    <div class="col-md-12">
                                        <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalAcc" title="Add Account" class="POS-newClass15">
                                            <lightning:button>
                                                <i class="fa fa-plus" aria-hidden="true"></i> Account
                                            </lightning:button>
                                        </a>
                                    </div>
                                    <aura:renderIf isTrue="{!!(v.Customer.ERP7__Is_Person_Account__c == true)}">
                                        <div class="col-md-12">
                                            <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalCon" title="Add Contact"  class="POS-newClass15">
                                                <lightning:button>
                                                    <i class="fa fa-plus" aria-hidden="true"></i> Contact
                                                </lightning:button>
                                            </a>
                                        </div>
                                    </aura:renderIf>
                                    <div class="col-md-12">
                                        <a href="javascript:void(0)"  data-toggle="modal" data-target="#myModalAdr" title="Add Address" class="POS-newClass15">
                                            <lightning:button>
                                                <i class="fa fa-plus" aria-hidden="true"></i> Address
                                            </lightning:button>
                                        </a>
                                    </div>
                                    <div class="col-md-12 slds-m-top--x-small">
                                        <article class="slds-card slds-card--narrow">
                                            <div class="slds-card__header slds-grid POS-newClass16">
                                                <header class="slds-media slds-media--center slds-has-flexi-truncate">
                                                    <div class="slds-media__body slds-truncate POS-newClass17">
                                                        <h2 class="POS-newClass18">
                                                            <a href="javascript:void(0);" class="slds-text-link--reset">
                                                                <span class="slds-text-heading--small POS-newClass19">Recent Items</span>
                                                            </a>
                                                           
                                                        </h2>
                                                    </div>
                                                </header>
                                            </div>
                                            <div class="slds-card__body POS-newClass20">
                                                <div class="slds-card__body--inner POS-newClass21">
                                                    <aura:iteration var="recentItem" indexVar="counts" items="{!v.RecentlyViewedList}">
                                                        <div class="slds-tile slds-truncate1 POS-newClass22">
                                                            <aura:renderIf isTrue="{!(recentItem.Type == 'Account')}">
                                                                <i class="fa fa-file POS-newClass23" aria-hidden="true"></i>
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!(recentItem.Type == 'Contact')}">
                                                                <i class="fa fa-user POS-newClass23" aria-hidden="true"></i>
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!(recentItem.Type == 'ERP7__Sales_Order__c')}">
                                                                <i class="fa fa-suitcase POS-newClass24" aria-hidden="true"></i>
                                                            </aura:renderIf>
                                                            <!--<a href="{!recentItem.Id}" target="_blank" >{!recentItem.Name}</a>-->
                                                            &nbsp;
                                                            <span  id="{!recentItem.Id}" name="{!recentItem.Type}" class="POS-newClass25">
                                                                <lightning:formattedText value="{!recentItem.Name}" title="{!recentItem.Id}" class="{!recentItem.Type}" onclick="{!c.Navigat}" />
                                                            </span>
                                                        </div>
                                                    </aura:iteration>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                </div>
                            </div>
                            <div class="tab-pane slds-p-top--xx-small" id="delivery" role="tabpanel">
                                <div class="col-md-9">
                                   
                                    <div class="POS-newClass26">
                                        <table class="slds-table slds-table--bordered" >
                                            <tr class="slds-text-heading--label POS-newClass26" bgcolor="#f4f6f9">
                                                <th class="POS-newClass27">Type</th>
                                                <th class="POS-newClass27">Name</th>
                                                <th class="POS-newClass27">Tracking No.</th>
                                                <th class="POS-newClass27">Delivery Date</th>
                                                <th class="POS-newClass27">Status</th>
                                            </tr>
                                            <aura:iteration var="shipment" indexVar="pcount" items="{!v.Shipments}">
                                                <tr class="POS-newClass28">
                                                    <td class="POS-newClass29">
                                                        <div class="slds-truncate POS-newClass30" title="{!shipment.RecordType.Name}">
                                                            <i class="fa fa-plane POS-newClass31" aria-hidden="true"/>&nbsp;
                                                            <aura:renderIf isTrue="{!(shipment.RecordType.Name == 'Internal Shipping')}">
                                                                Internal
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!(shipment.RecordType.Name == 'UPS Shipping')}">
                                                                UPS 
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!(shipment.RecordType.Name == 'Fedex Shipping')}">
                                                                Fedex 
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!(shipment.RecordType.Name == 'DHL Shipping')}">
                                                                DHL 
                                                            </aura:renderIf>
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass29">
                                                        <div class="slds-truncate POS-newClass32" id="{!shipment.Id}">
                                                            <lightning:formattedText value="{!shipment.Name}" onclick="{!c.NavRecord}" title="{!shipment.Id}"/>
                                                        </div>
                                                    </td>
                                                    <!--  -->
                                                    <td class="POS-newClass29">
                                                        <div class="slds-truncate POS-newClass32" >
                                                            <lightning:formattedText aura:id="paymethod" class="" value="{!shipment.ERP7__TrackingNumber__c }"/>
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass29">
                                                        <div class="slds-truncate POS-newClass32" title="{!shipment.ERP7__Shipment_Delivery_Date__c}">
                                                            <lightning:formattedDateTime aura:id="paymethod" class="" value="{!shipment.ERP7__Shipment_Delivery_Date__c}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass29">
                                                        <div class="slds-truncate POS-newClass32" title="{!shipment.ERP7__Status__c}">
                                                            <lightning:formattedText aura:id="payamt" class="" value="{!shipment.ERP7__Status__c}"/>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="row">
                                        <div class="col-md-10">
                                            <aura:renderIf isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'UPS' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalUPS" title="UPS"  class="POS-newClass15">
                                                     <lightning:button variant="brand" onclick="{!c.Services}">
                                                        <img class="slds-button__icon slds-button__icon--right POS-newClass37" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/glo_ups_brandmark.gif"/>
                                                    </lightning:button>
                                                </a>
                                            </aura:renderIf>
                                        </div>
                                        <div class="col-md-10">     
                                            <aura:renderIf isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'FedEx' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalFedEx" title="FedEx"  class="POS-newClass15">
                                                    <lightning:button variant="brand" onclick="{!c.FedExServices}">
                                                        <img class="slds-button__icon slds-button__icon--right POS-newClass38" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/FedEx.png"/> 
                                                    </lightning:button>
                                                </a>
                                            </aura:renderIf>
                                        </div>
                                        <div class="col-md-10">     
                                            <aura:renderIf isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'DHL' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalDHL" title="DHL" class="POS-newClass15">
                                                    <lightning:button variant="brand" onclick="{!c.DHL_Services}">
                                                        <img class="slds-button__icon slds-button__icon--right POS-newClass38" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/dhl.png" /> 
                                                    </lightning:button>
                                                </a>
                                            </aura:renderIf>
                                        </div>
                                        <div class="col-md-10">
                                            <aura:renderIf isTrue="{!!(v.SalesOrder.ERP7__Shipment_Type__c == 'FedEx' || v.SalesOrder.ERP7__Shipment_Type__c == 'UPS' || v.SalesOrder.ERP7__Shipment_Type__c == 'DHL')}">
                                                <a href="javascript:void(0)" data-toggle="modal" data-target="#myModalSOShipment" title="Shipment"  class="POS-newClass15">
                                                    <lightning:button>
                                                        <i class="fa fa-truck" aria-hidden="true"></i> Shipment
                                                    </lightning:button> 
                                                </a>
                                            </aura:renderIf>
                                        </div>
                                    </div> 
                                </div>
                            </div>
                            <div class="tab-pane" id="payment" role="tabpanel">
                                <div class="col-md-9">
                                    
                                    <h3 class="POS-newClass33">
                                        <span class="POS-newClass34">
                                            <strong>Invoice Amount : </strong>
                                            <lightning:formattedText aura:id="lop" class="" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp; 
                                        <span>
                                            <strong>Paid : </strong>
                                            <lightning:formattedText aura:id="lop" class="" value="{!v.SalesOrder.ERP7__Amount_Paid__c}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp;
                                        <span class="POS-newClass34">
                                            <strong>Total Due : </strong>
                                            <lightning:formattedNumber aura:id="lop" class="" value="{!v.finalDue}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp;
                                        <span class="POS-newClass35">
                                            <strong>Credit : </strong>
                                            <lightning:formattedNumber aura:id="lop" class="" value="{!v.Customer.ERP7__Available_Credit_Balance__c}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp;
                                       
                                    </h3>
                                    <aura:renderIf isTrue="{!(v.SalesOrder.Name != undefined)}">
                                        <div class="POS-newClass36">
                                            <table class="slds-table slds-table--bordered">
                                                <tr class="slds-text-heading--label" bgcolor="#f4f6f9">
                                                    <th class="POS-newClass46">Type</th>
                                                    <th class="POS-newClass46">Name</th>
                                                    <th class="POS-newClass46">Date</th>
                                                    <th class="POS-newClass46">Amount</th>
                                                </tr>
                                                <aura:iteration var="pay" indexVar="pcount" items="{!v.Payments}">
                                                    <tr class="POS-newClass48">
                                                        <td class="POS-newClass49">
                                                            <div class="slds-truncate POS-newClass50" title="{!pay.RecordType.Name}">
                                                                <aura:renderIf isTrue="{!(pay.RecordType.Name == 'Cash Payments')}">
                                                                    <i class="fa fa-money POS-newClass51" aria-hidden="true"></i> {!pay.ERP7__Payment_Type__c}  
                                                                </aura:renderIf>
                                                                <aura:renderIf isTrue="{!(pay.RecordType.Name == 'Bank Payments')}">
                                                                    <i class="fa fa-building-o POS-newClass51" aria-hidden="true"></i> {!pay.ERP7__Payment_Type__c}
                                                                </aura:renderIf>
                                                                <aura:renderIf isTrue="{!(pay.RecordType.Name == 'Card Payments')}">
                                                                    <i class="fa fa-credit-card POS-newClass51" aria-hidden="true"></i> {!pay.ERP7__Payment_Type__c}
                                                                </aura:renderIf>
                                                                <aura:renderIf isTrue="{!(pay.RecordType.Name == 'Credit Note Payments')}">
                                                                    <i class="fa fa-credit-card POS-newClass51" aria-hidden="true"></i> {!pay.ERP7__Payment_Type__c} 
                                                                </aura:renderIf>
                                                            </div>
                                                        </td>
                                                        <td class="POS-newClass52">
                                                            <div class="slds-truncate POS-newClass53" id="{!pay.Id}">
                                                                <lightning:formattedText value="{!pay.Name}" onclick="{!c.NavRecord}" title="{!pay.Id}"/>
                                                            </div>
                                                        </td>
                                                        <!--  -->
                                                        <td class="POS-newClass54">
                                                            <div class="slds-truncate POS-newClass55" title="{!pay.CreatedDate}">
                                                                <lightning:formattedDateTime aura:id="paymethod" class="" value="{!pay.CreatedDate}"/>
                                                            </div>
                                                        </td>
                                                        <td class="POS-newClass52">
                                                            <div class="slds-truncate POS-newClass56" title="{!pay.ERP7__Amount__c}">
                                                                <lightning:formattedText aura:id="payamt" class="" value="{!pay.ERP7__Amount__c}"/>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </aura:iteration>
                                            </table>
                                        </div>
                                        <div class="POS-newClass57">
                                            <lightning:spinner variant="brand" size="small" aura:id="couponSpins" class="slds-hide"/>
                                    		 <div class="row POS-newClass58">
                                                <div class="col-md-3 slds-m-bottom--x-small slds-m-top--x-small">
                                                    <h3><strong>Coupon Codes</strong></h3>
                                                </div>
                                                <div class="col-md-8 slds-m-bottom--x-small POS-newClass58">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="coupon" 
                                                                  class="fifty"
                                                                  value="{!v.Coupon}"
                                                                  />
                                                    &nbsp;&nbsp;&nbsp;
                                                    <lightning:button variant="brand" onclick="{!c.ApplyCoupon}"  >Apply</lightning:button>
                                                </div>
                                            </div>
                                            <table class="slds-table slds-table--bordered">
                                                <tr class="slds-text-heading--label POS-newClass26" bgcolor="#f4f6f9">
                                                    <th class="POS-newClass59">Name</th>
                                                    <th class="POS-newClass59">Coupon</th>
                                                    <th class="POS-newClass59">Applied Date</th>
                                                    <th class="POS-newClass59">Amount</th>
                                                    <th></th>
                                                </tr>
                                                <aura:iteration var="CN" indexVar="cncount" items="{!v.CreditNotes}">
                                                    <tr>
                                                        <td class="POS-newClass60">
                                                            <div class="slds-truncate POS-newClass61" id="{!CN.Id}">
                                                                <lightning:formattedText value="{!CN.Name}" onclick="{!c.NavRecord}" title="{!CN.Id}"/>
                                                            </div>
                                                        </td>
                                                        <td class="POS-newClass60">
                                                            <div class="slds-truncate POS-newClass61" id="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__c}">
                                                                <lightning:formattedText value="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__r.Name}" onclick="{!c.NavRecord}" title="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__c}"/>
                                                            </div>
                                                        </td>
                                                        <td class="POS-newClass60">
                                                            <div class="slds-truncate">
                                                                <div class="slds-truncate POS-newClass55" title="{!CN.ERP7__Applied_Date__c}">
                                                                    <lightning:formattedDateTime aura:id="appDate" class="" value="{!CN.ERP7__Applied_Date__c}" />
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="POS-newClass60">
                                                            <div class="slds-truncate">{!CN.ERP7__Amount__c}</div>
                                                        </td>
                                                        <td class="POS-newClass52">
                                                            <lightning:button onclick="{!c.DeleteCoupon}"  name="{!CN.Id}" ><a title="Cancel" ><img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="POS-newClass62" /> </a></lightning:button>
                                                        </td>
                                                    </tr>
                                                </aura:iteration>
                                            </table>
                                        </div>
                                    </aura:renderIf>
                                </div>
                                <div class="col-md-3">
                                    <div class="row">
                                        <div class="col-md-10">
                                            <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalCard" title="Card Payment"  class="POS-newClass15">
                                                <lightning:button>
                                                    <i class="fa fa-credit-card" aria-hidden="true"></i> Credit / Debit
                                                </lightning:button>
                                            </a>
                                        </div>
                                        <div class="col-md-10">   
                                            <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalBank" title="Bank Payment"  class="POS-newClass15">
                                                <lightning:button>
                                                    <i class="fa fa-building-o" aria-hidden="true"></i> Bank / Cheque
                                                </lightning:button>
                                            </a>
                                        </div>
                                        <div class="col-md-10">
                                            <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalCash" title="Cash Payment"  class="POS-newClass15">
                                                <lightning:button>
                                                    <i class="fa fa-money" aria-hidden="true"></i> Cash
                                                </lightning:button>
                                            </a>
                                        </div>
                                        <div class="col-md-10">
                                            <aura:renderIf isTrue="{!(v.Customer.ERP7__No_of_Loyalty_Cards__c > 0)}">
                                                <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalLoyalty" title="Loyalty Payment"  class="POS-newClass15">
                                                    <lightning:button>
                                                        <i class="fa fa-ellipsis-h" aria-hidden="true"></i> Loyalty 
                                                        <aura:renderIf isTrue="{!(v.customerCreditLimit != null)}">
                                                            <span>
                                                                (
                                                                <lightning:formattedText aura:id="lop" class="" value="{!v.customerCreditLimit}"/>
                                                                )
                                                            </span>
                                                        </aura:renderIf>
                                                    </lightning:button>
                                                </a>
                                            </aura:renderIf>
                                        </div>
                                        <div class="col-md-10">
                                            <a href="javascript:void(0)"   data-toggle="modal" data-target="#myModalapplycredit" title="Cash Payment"  class="POS-newClass15">
                                                <lightning:button>
                                                    <i class="fa fa-ticket" aria-hidden="true"></i> Apply Credits
                                                </lightning:button>
                                            </a>
                                        </div>
                                        <div class="col-md-10">
                                            <aura:renderIf isTrue="{!(v.Invoice.Name != undefined)}">
                                                <lightning:button variant="brand" onclick="{!c.OpenInvoice}" class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100 margin-left-0">
                                                    <i class="fa fa-list" aria-hidden="true"></i> Invoice Document
                                                </lightning:button>
                                            </aura:renderIf>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <aura:renderIf isTrue="false"><!-- {!(v.SalesOrder.ERP7__Status__c == 'Cancelled')} -->
                        <div class="row">
                            <div class="col-sm-12 col-md-12 POS-newClass39">
                                
                                <label class="slds-form-element__label" for="name">Cancelled Reason : </label>
                                <!--<lightning:textarea aura:id="lop" 
                                      class="slds-textarea"
                                      rows="4" cols="20"
                                      value="{!v.SalesOrder.ERP7__Cancelled_Reason__c}"/>-->
                                <lightning:formattedText aura:id="lop" value="{!v.SalesOrder.ERP7__Cancelled_Reason__c}"/>    
                                
                            </div>
                        </div> 
                    </aura:renderIf>
                </div> 
                <div class="row">
                    <div class="col-sm-12 col-md-12 POS-newClass40">
                        
                    </div>
                </div>
                <div class="POS-newClass41">
                    <table class="slds-table slds-table--condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                        <thead>
                            <tr class="header-fixed slds-text-heading--label POS-newClass42">
                                <!-- onclick="popUpitem1();" -->
                                <th class="slds-is-sortable" scope="col"> 
                                    <aura:renderIf isTrue="{!!(v.SalesOrder.ERP7__Is_Closed__c == true || v.SOP == '' || v.SOP == undefined)}">
                                        <a href="javascript:void(0)" onclick="{!c.NewProductPopup}"  data-toggle="modal" data-target="#myModal" title="Add Product" class="POS-newClass63">
                                            Add 
                                        </a> 
                                    </aura:renderIf>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43">Code</div>
                                </th>
                                <th scope="col" class="slds-size--2-of-8">
                                    <div class="slds-truncate POS-newClass44">Product</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43">Charge/Qty</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43" >UoM</div>
                                </th>
                                <!--<th scope="col" class="slds-size_-1-of-8"> <div class="slds-truncate">Points</div> </th>-->
                                <th scope="col" class="slds-size--1-of-8" >
                                    <div class="slds-truncate POS-newClass43">Base Price</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43">Discount</div>
                                </th>
           						<th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43">Coupon</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass43">VAT/Tax</div>
                                </th>
                                <!--<th scope="col" class="slds-size_-1-of-8"> <div class="slds-truncate">Tax</div> </th>-->
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate POS-newClass45">Total Price</div>
                                </th>
                                <th>&nbsp;</th>
                            </tr>
                        </thead>
                       
                        <aura:iteration var="item" indexVar="count" items="{!v.itemWrapperListt}">
                            <tbody>
                                <tr  bgcolor="#FFFFFF">
                                    <td align="center" valign="middle">
                                        <table width="100%" border="0" bgcolor="">
                                            <tr>
                                                <td width="33%" align="center" valign="middle" class="POS-newClass17" id="{!item.product.Id}" name="{!count}">
                                                    <lightning:button aura:id="assignButton"  name="{!count}" onclick="{!c.descriptionGet}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                                        <a data-toggle="modal" data-target="#myModal1" title="Add Product Description">
                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_discription.png" class="POS-newClass64" />
                                                        </a>
                                                    </lightning:button>
                                                </td>
                                                <td width="33%" align="center" valign="bottom" class="POS-newClass65" id="{!item.product.Id}" name="{!count}">
                                                    <lightning:button aura:id="assignButton"  name="{!count}" onclick="{!c.removeItem}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                                        <a title="Remove Item" >
                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="POS-newClass62"/>
                                                        </a>
                                                    </lightning:button>
                                                </td>
                                                <td width="34%" align="center" valign="top" class="POS-newClass17" id="{!item.product.Id}" name="{!count}">
                                                    <lightning:button aura:id="assignButton"  name="{!count}" onclick="{!c.editItem}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                                        <a data-toggle="modal" data-target="#myModale" title="Edit Product" class="POS-newClass66">
                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" class="POS-newClass62" />
                                                        </a>
                                                    </lightning:button>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                    <td align="center" valign="middle"  >
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedText value="{!item.product.ProductCode}" />
                                        </div>
                                    </td>
                                    <td align="center" valign="middle" class="POS-newClass25" id="{!item.product.Id}">
                                        <div class="slds-truncate POS-newClass67">
                                            <aura:renderIf isTrue="{!(item.SerialNos.length > 0)}">
                                                <lightning:button aura:id="assignButton" class="borderzero" name="{!count}" onclick="{!c.CurrentSerialNumbers}" ><a data-toggle="modal" data-target="#myModalSerial" title="Serial Numbers"><i class="fa fa-info-circle POS-newClass80" aria-hidden="true" name="{!count}"></i></a></lightning:button>
                                            </aura:renderIf>
                                            <aura:renderIf isTrue="{!(item.Batches.length > 0)}">
                                                <lightning:button aura:id="assignButton" class="borderzero" name="{!count}" onclick="{!c.CurrentBatchNumbers}" ><a data-toggle="modal" data-target="#myModalSerial" title="Batch Numbers"><i class="fa fa-info-circle POS-newClass80" aria-hidden="true" name="{!count}"></i></a></lightning:button>
                                            </aura:renderIf>
                                            <a href="{!'/'+ item.product.Id}" target="_blank" class="Name POS-newClass68">
                                                <lightning:formattedText value="{!item.product.Name}"/>
                                            </a>
                                            <aura:renderIf isTrue="{!(item.product.ERP7__Picture__c != undefined)}">
                                                &nbsp;<img src="{!item.product.ERP7__Picture__c}" class="POS-newClass69" />
                                            </aura:renderIf>
                                        </div>
                                        <!-- click="{!c.NavRecord}"-->
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.quantity_s}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedText value="{!item.product.QuantityUnitOfMeasure}"/>  
                                        </div>
                                    </td>
                                    <!--<td align="center" valign="middle">
       								 <lightning:formattedNumber value="{!item.rewardPoints}"/>  </td>-->
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.price}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.discount}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.couponDiscount}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle" >
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.vat+item.tax}" />
                                        </div>
                                    </td>
                                    <!--<td align="center" valign="middle">
       								 <lightning:formattedNumber value="{!item.tax}"/>  </td>-->
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate POS-newClass43">
                                            <lightning:formattedNumber value="{!item.priceWithVat}"/>&nbsp;
                                        </div>          
                                    </td>
                                    <aura:If isTrue="{!and(item.lineitm.Id !='', item.lineitm.Id !=undefined, item.lineitm.ERP7__Sales_Order__r.ERP7__Authorised__c, or(item.product.ERP7__Issue_Purchase_Order__c , item.product.ERP7__Issue_Work_Order__c , item.product.ERP7__Issue_Manufacturing_Order__c))}">
                                    <td>
                                        <div class="epr_Mark7 slds-no-flex POS-newClass70">
                                            <div class="dropdown">
                                                
                                                <button class="slds-button slds-button--icon-border-filled slds-button--icon-x-small dropdown-toggle" aria-haspopup="true" data-toggle="dropdown"> 
                                                    <span class="caret"></span>
                                                </button>
                                                
                                                <ul class="dropdown-menu POS-newClass71">
                                                    <aura:If isTrue="{!and(item.product.ERP7__Issue_Purchase_Order__c, v.crudValues.ERP7__PO__c)}">
                                                    <li><a href="javascript:void(0);" onclick="{!c.CreatePO}" data-recordId="{!item.lineitm.Id}" data-toggle="modal" data-target="#myModal2"><span class="slds-form-element__label" >Create Purchase Order</span></a></li>
                                                    </aura:If>
                                                    <aura:If isTrue="{!and(item.product.ERP7__Issue_Work_Order__c, v.crudValues.ERP7__WO__c)}">
                                                        <li ><a href="javascript:void(0);" onclick="{!c.CreateWO}" data-soliId="{!item.lineitm.Id}"><span class="slds-form-element__label" >Create Work Order</span></a></li>
                                                    </aura:If>
                                                    <aura:If isTrue="{!and(item.product.ERP7__Issue_Manufacturing_Order__c, v.crudValues.ERP7__Issue_Manufacturing_Order__c)}">
                                                        <li><a href="javascript:void(0);" onclick="{!c.CreateMO}" data-mosoliId="{!item.lineitm.Id}"><span class="slds-form-element__label" >Create Manufacturing Order</span></a></li>
                                                    </aura:If>
                                                </ul>
                                               
                                                <span class="slds-assistive-text">More Options</span>
                                            </div>
                                        </div>
                                    </td>
                                        </aura:If>
                                </tr>
                            </tbody>
                        </aura:iteration>
                        <tr>
                            <td colspan="10" height="100" bgcolor="#FFFFFF">&nbsp;</td>
                        </tr>
                    </table>
                </div>
                <table class="slds-table slds-table--condensed slds-max-medium-table--stacked-horizontal slds-m-top--medium slds-no-row-hover">
                    <tbody>
                        <tr class="rtext POS-newClass72">
                            <td align="left">Sub Total: </td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"  value="{!v.subTotal}" disabled="true"/>
                            </td>
                            <td align="left">Taxes:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"   value="{!v.taxes}" disabled="true" />
                            </td>
                            <td align="left">Shipping Amount:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"   value="{!v.SalesOrder.ERP7__Total_Shipping_Amount__c}" disabled="true"/>
                            </td>
                            <td align="left">Discounts:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"   value="{!v.discounts + v.SalesOrder.ERP7__Coupon_Discount__c + v.SalesOrder.ERP7__Product_Coupon_Discount__c}" disabled="true"/>
                            </td>					
                        </tr>
                        <tr class="rtext">
                            <td align="left">Shipping Discount:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"   value="{!v.SalesOrder.ERP7__Shipping_Discount__c}" disabled="true"/>
                            </td>
                            <td align="left">Total Amount:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"   value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}" disabled="true"/>
                            </td>
                            <!-- totalDue -->
                            <td align="left">Amount Paid:</td>
                            <td align="left">
                                <lightning:input type="number" variant="label-hidden"  value="{!v.SalesOrder.ERP7__Amount_Paid__c }" disabled="true"/>
                            </td>
                            <!--<td align="left">Loyalty Points:</td>
                              <td align="left"><lightning:input type="number" variant="label-hidden"  value="{!v.loyaltyPoints}" disabled="true"/> </td>
                              <td align="left">Loyalty Amount:</td
                              <td align="left"><lightning:input type="number" variant="label-hidden"   value="{!v.loyaltyAmount}" disabled="true"/> </td>-->
                            <td align="left" class="POS-newClass26">Total Due:</td>
                            <td align="left" width="13%">
                                <lightning:input type="number" variant="label-hidden"  value="{!v.finalDue}" disabled="true"/>
                            </td>
                        </tr>
                        <tr class="rtext POS-newClass73">
                            <td align="left" class="POS-newClass26">&nbsp;</td>
                            <td align="left" width="13%">&nbsp;</td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="slds-clearfix"></div>
            <div class="slds">
                <div class="">
                    <div class="row slds-m-top--large footerbuttons POS-newClass74">
                        <div class="col-md-12 slds-m-bottom--small" >
                            <span class="POS-newClass75">
                                <lightning:spinner variant="brand" size="small" aura:id="blueSpins" class="slds-hide"/>
                            </span>
                            <a href="javascript:void(0);" onclick="{!c.getAllDetailsInit}"><button class="slds-button slds-button--neutral slds-m-right--small">Reset</button></a>   
                            <aura:renderIf isTrue="{!!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                <lightning:button variant="brand" onclick="{!c.draftSave}" class="slds-button slds-button--brand ">Save</lightning:button>
                            </aura:renderIf>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Modal Product Line Items -->
            <div id="myModal" class="modal fade" role="dialog">
                <div class="modal-dialog modal-lg POS-newClass76">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header POS-newClass77">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title POS-newClass78">Add Sales Order Line Items</h4>
                            
                        </div>
                        <span >
                            <lightning:spinner variant="brand" size="small" aura:id="addSpin"/>
                        </span>
                        <div class="modal-body POS-newClass79">
                            
                            <div class="slds-form--inline">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="name">Name</label><br/>
                                    <div class="slds-form-element__control">
                                        <lightning:input type="text" variant="label-hidden" aura:id="so" 
                                                      
                                                      value="{!v.itemName}"
                                                      />
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <!-- <label class="slds-form-element__label" for="prodFam">Family</label> -->
                                    <label class="slds-form-element__label" for="prodFam">{!$Label.c.EPOS_Product_Family}</label><br/> 
                                    <div class="slds-form-element__control">
                                        <!--:inputSelect class="" aura:id="prodFam" value="{!v.prodFam}"/-->  
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="prodCat">Category</label><br/>
                                    <div class="slds-form-element__control">
                                        <!--:inputSelect class="" aura:id="prodCat" value="{!v.prodCat}"/-->
                                    </div>
                                </div>
                                <div class="slds-form-element POS-newClass81">
                                    <label class="slds-form-element__label" for="prodCat">Sub Category</label><br/>
                                    <div class="slds-form-element__control">
                                        <!--:inputSelect class="" aura:id="prodSubCat" value="{!v.prodSubCat}"/-->
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="prodCat">Available Only</label><br/>
                                    <div class="slds-form-element__control POS-newClass82">
                                        <lightning:input type="checkbox" aura:id="availablecbox" checked="{!v.showAvailable}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element POS-newClass83">
                                    <lightning:button variant="brand" onclick="{!c.fetchProduct}"><i class="fa fa-search" aria-hidden="true"></i> Find</lightning:button>
                                	
                                </div>
                                 
                            </div>
                            <!-- Table -->
                            <div class="row POS-newClass84">
                                <aura:renderIf isTrue="true">
                                    
                                    <div id="maindv" class="{!'POS-newClass85 '+ v.SerialPopup || v.BatchPopup}"><!-- class="{!if(v.SerialPopup,'col-md-8','col-md-12')}" -->
                                        <article class="slds-card slds-m-top--small" >
                                            
                                            <div class="slds-card__body" >
                                                
                                                <div class="maquiScroller POS-newClass87">
                                                    <table class="slds-table slds-table--bordered slds-no-row-hover slds-table--cell-buffer">
                                                        <thead >
                                                            <tr class="slds-text-heading--label">
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Action">&nbsp;</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Code">Code</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Product">Product</div>
                                                                </th>
                                                                <aura:renderIf isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=" version">Version</div>
                                                                </th>
                                                                </aura:renderIf>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Price">Price</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Quantity">Charge/Qty</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="UoM">UoM</div>
                                                                </th>
                                                            	<aura:renderIf isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Discount">Discount</div>
                                                                </th>
                                                                
                                                                </aura:renderIf>
                                                                <!--<th scope="col" align="center">
                                                                   <div class="slds-truncate" title="Is Rental">Is Rental</div>
                                                                   </th>-->
                                                                <th scope="col" class="POS-newClass43">
                                                                    <div class="slds-truncate" title="Availability">Availability</div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <aura:iteration var="pro" indexVar="count" items="{!v.ProductsAndDiscountsWrapperListt}">
                                                                <aura:if isTrue="{!(v.showAvailable)?equals(pro.showcbox,v.showAvailable):true}">
                                                                    <tr class="slds-hint-parent">
                                                                        <td align="center">
                                                                            <div class="slds-truncate POS-newClass88" title="Action">
                                                                               <lightning:input type="checkbox" aura:id="sel" checked="{!pro.selected}" disabled="{!not(pro.showcbox)}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td align="center">
                                                                            <div class="slds-truncate" title="Code">
                                                                                <lightning:formattedText aura:id="code" value="{!pro.product.ProductCode}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate POS-newClass25" title="Product" id="{!pro.product.Id}">
                                                                                <lightning:formattedText value="{!pro.product.Name}" onclick="{!c.NavRecord}" title="{!pro.product.Id}"/>
                                                                                <aura:renderIf isTrue="{!(pro.product.ERP7__Picture__c != undefined)}">
                                                                                    &nbsp;<img src="{!pro.product.ERP7__Picture__c}" class="POS-newClass69" />
                                                                                </aura:renderIf>
                                                                            </div>
                                                                        </td>
                                                                        <aura:renderIf isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                        <td>
                                                                            <div class="row">
                                                                                <div class="col-md-10 POS-newClass89" title=" version" name="{!count}" id="{!pro.product.Id}">
                                                                                    <!--:inputSelect  aura:id=" ver" value="{!pro.Version}" onchange="{!c.VersionChanged}" >
                                                                                        <aura:iteration items="{!pro.Versions}" var="po">
                                                                                            <:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.Version,true,false)}"/>
                                                                                        </aura:iteration>
                                                                                    </:inputSelect-->
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                        </aura:renderIf>
                                                                        <td>
                                                                            <div class="slds-truncate" title="Price">
                                                                                <lightning:formattedNumber value="{!pro.pricebookEntry.ERP7__Selling_Price__c}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate" title="Charge/Qty" name="{!count}" id="{!pro.product.Id}">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!pro.quantity_s}" aura:id="quan" class="slds-input charge" onchange="{!c.addDiscount}" /> <!-- addDiscount-->
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate" title="UoM" name="{!count}" id="{!pro.product.Id}">
                                                                                <lightning:formattedText value="{!pro.product.QuantityUnitOfMeasure}"/>
                                                                               </div>
                                                                        </td>
                                                                        <aura:renderIf isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                        <td>
                                                                            <div class="row">
                                                                                <div class="col-md-4 POS-newClass89" title="Discount" name="{!count}" id="{!pro.product.Id}">
                                                                                    <!--:inputSelect  aura:id="dis" value="{!pro.discountName}" onchange="{!c.discountPercents}" >
                                                                                        <aura:iteration items="{!pro.CurrentDiscounts}" var="po">
                                                                                            <:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.discountName,true,false)}"/>
                                                                                        </aura:iteration>
                                                                                    </:inputSelect-->
                                                                                </div>
                                                                                <div class="slds-truncate col-md-3 POS-newClass90" title="Discount/Unit" name="{!count}" id="{!pro.product.Id}">
                                                                                    <lightning:input type="text" variant="label-hidden" aura:id="discountPer"  value="{!pro.discountPercent}"  keyup="{!c.addvalidatevalue}" updateOn="keyup"  placeholder="{!if(pro.isPercent == true,'Percentage','Value')}"/>
                                                                                    <!--keyup="{!c.validatevalue}"-->
                                                                                </div>
                                                                                <div class="slds-truncate col-md-5 POS-newClass91">
                                                                                    [<lightning:formattedNumber value="{!pro.minDiscountPercent}"/>-<lightning:formattedNumber value="{!pro.maxDiscountPercent}"/>]
                                                                                    <aura:renderIf isTrue="{!(pro.isPercent == true)}">%</aura:renderIf>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                        
                                                                        </aura:renderIf>
                                                                        <td>
                                                                            <div class="slds-truncate POS-newClass43" title="Availability">
                                                                                <lightning:button aura:id="assignButton" class="{!(pro.showcbox)? (and(equals(pro.stock,0),or(pro.product.ERP7__Allow_Pre_Orders__c,pro.product.ERP7__Allow_Back_Orders__c)))? 'slds-button slds-button--brand orange':'slds-button slds-button--brand green':'slds-button slds-button--brand grey'}" name="{!count}" onclick="{!(pro.product.ERP7__Serialise__c)?c.getSerials:(pro.product.ERP7__Lot_Tracked__c)?c.getBatches:c.NewProduct}">
                                                                                    {!pro.product_Type}
                                                                                    <aura:renderIf isTrue="{!and(pro.stock > 0,(pro.product.ERP7__Serialise__c || pro.product.ERP7__Lot_Tracked__c))}">
                                                                                        <i class="fa fa-chevron-circle-right POS-newClass92" aria-hidden="true"></i>
                                                                                    </aura:renderIf>
                                                                                </lightning:button>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    
                                                                    <tr class="POS-newClass93">
                                                                       <td class="POS-newClass94"></td>
                                                                        <aura:renderIf isTrue="{!(v.showAvailable)?equals(pro.showcbox,v.showAvailable,(pro.SerialNos.length > 0 || pro.Batches.length > 0)):equals(!v.showAvailable,(pro.SerialNos.length > 0 || pro.Batches.length > 0))}">
                                                                        <td colspan="6" class="POS-newClass95">
                                                                            <aura:renderIf isTrue="{!pro.SerialNos.length > 0}">
                                                                            <aura:iteration var="Serial" indexVar="serialCounts" items="{!pro.SerialNos}">
                                                                                <a href="{!'/'+ Serial.Id}" target="_blank" >
                                                                                    <span class="POS-newClass96"> {!Serial.Name} </span>
                                                                                </a>
                                                                                <lightning:buttonIcon iconName="utility:close" variant="close" onclick="{!c.removeSerialNew}" alternativeText="Remove Serial" title="{!count}" name="{!serialCounts}" class="RemoveSerial"/>
                                                                                &nbsp;
                                                                            </aura:iteration> 
                                                                            </aura:renderIf>
                                                                            <aura:renderIf isTrue="{!pro.Batches.length > 0}">
                                                                            <aura:iteration var="batch" indexVar="batchCounts" items="{!pro.Batches}">
                                                                                <a href="{!'/'+ batch.Id}" target="_blank" >
                                                                                    <span class="POS-newClass96"> {!batch.Name} </span>
                                                                                </a>
                                                                                <lightning:buttonIcon iconName="utility:close" variant="close" onclick="{!c.removeBatchNew}" alternativeText="Remove Batch" title="{!count}" name="{!batchCounts}" class="RemoveSerial"/>
                                                                                &nbsp;
                                                                            </aura:iteration> 
                                                                            </aura:renderIf>
                                                                        </td>
                                                                        </aura:renderIf>
                                                                    </tr>                                           
                                                                    
                                                                </aura:if>
                                                            </aura:iteration>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            
                                        </article>
                                    </div>
                                </aura:renderIf>
                                <aura:renderIf isTrue="{!(v.BatchPopup)}">
