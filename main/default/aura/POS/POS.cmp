                                                            <lightning:input type="radio" aura:id="Fr0" name="others" value="{!twl.Selected}"/>
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass142">
                                                            <lightning:formattedText value="{!twl.ServiceName}" title="{!twl.Service}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass138">
                                                            <lightning:formattedText value="{!twl.totalCharges}" title="{!twl.totalCharges}" />
                                                        </div>
                                                      
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass138">
                                                            <lightning:formattedText value="{!twl.currencyCode}" title="{!twl.currencyCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="POS-newClass136">
                                                        <div class="slds-truncate POS-newClass138">
                                                            <lightning:formattedText value="{!twl.CommitmentDate}" title="{!twl.CommitmentDate}" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <lightning:button variant="brand" onclick="{!c.DHL_Services}">Get Services</lightning:button>
                            <aura:renderIf isTrue="{!(v.DHL_Services.Services.length > 0)}">
                                <lightning:button variant="brand" onclick="{!c.saveDHLEstimateToOrder}">Save</lightning:button>
                            </aura:renderIf>
                            <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- popup DHL ends here --> 


            <!-- Modal popup 13 Loyalty -->
            <div id="myModalLoyalty" class="modal fade" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header POS-newClass104">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title POS-newClass78">Loyalty Payment
                                <span class="POS-newClass75">
                                    <lightning:spinner variant="brand" size="small" aura:id="loyaltyPayments"/>
                                </span>
                                
                            </h4>
                        </div>
                        <div class="modal-body POS-newClass143">
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="POS-newClass113">
                                            <lightning:formattedText aura:id="paymentError" value="{!v.LoyaltyError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-6 col-sm-6 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Invoice Amount:</label>
                                                <lightning:formattedText aura:id="pAmt"  class="outputTextOR" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01"> Total Due:</label>
                                                <lightning:formattedText aura:id="fdue" class="outputTextOR" value="{!v.finalDue}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12 slds-m-top--xx-small">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control font-size1rem">
                                                <label class="slds-form-element__label" for="text-input-01">Available Points:</label>
                                                <lightning:formattedText aura:id="pAmt" 
                                                               class="outputTextOR"
                                                               value="{!v.customerCreditLimit}"
                                                               />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12 slds-m-top--xx-small">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Loyalty Value:</label>
                                                <lightning:formattedText aura:id="pAmt" 
                                                               class="outputTextOR"
                                                               value="{!v.Points_Per_Unit_Amount}"
                                                               />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 ">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Redeem Points<span class="POS-newClass115">* </span></label>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" variant="label-hidden" aura:id="pAmt" 
                                                                  value="{!v.LoyaltyPoint2Use}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <lightning:button variant="brand" onclick="{!c.ProcessLoyalty}">Pay Now</lightning:button>
                            <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- popup 13 Loyalty ends here -->
            <!-- Modal popup 14 Applycredit -->
            <div id="myModalapplycredit" class="modal fade" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header POS-newClass104">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title POS-newClass78">Apply Credits
                                <span class="POS-newClass75">
                                    <lightning:spinner variant="brand" size="small" aura:id="creditPayments"/>
                                </span>
                            </h4>
                        </div>
                        <div class="modal-body POS-newClass143">
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="POS-newClass113">
                                            <lightning:formattedText aura:id="paymentError" value="{!v.CreditError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Invoice Amount:</label>
                                                <lightning:formattedText aura:id="pAmt"  class="outputTextOR" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01"> Total Due:</label>
                                                <lightning:formattedText aura:id="fdue" class="outputTextOR" value="{!v.finalDue}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control font-size1rem">
                                                <label class="slds-form-element__label" for="text-input-01">Available Credit:</label>
                                                <lightning:formattedText aura:id="pAmt" 
                                                               class="outputTextOR"
                                                               value="{!v.Customer.ERP7__Available_Credit_Balance__c}"
                                                               />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 ">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Redeem Credit<span class="POS-newClass115">* </span></label>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="slds-form-element__control">
                                                   <lightning:input type="text" variant="label-hidden" aura:id="pAmt" 
                                                                  value="{!v.CreditAmount2Use}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <lightning:button variant="brand" onclick="{!c.ProcessCredit}">Pay Now</lightning:button>
                            <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Applycredit 14 Loyalty ends here -->
            <!-- popup 15 Start here -->
            <!-- Modal Comment Edit Line Items -->
            <div id="myModalSerial" class="modal fade" role="dialog">
                <div class="modal-dialog modal-lg POS-newClass144">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header POS-newClass104">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <div class="row">
                                <div class="col-md-12">
                                    <h4 class="modal-title POS-newClass78">
                                        
                                        <aura:renderIf isTrue="{!(v.SelectedProduct.product.ERP7__Is_Asset__c == true)}">
                                            
                                            <strong>Start Time :</strong> &nbsp;<lightning:formattedDateTime aura:id="paymethod" class="" value="{!v.SelectedProduct.lineitm.ERP7__Start_Time__c}"/>
                                            &nbsp;&nbsp;&nbsp;
                                            <strong>End Time :</strong> &nbsp;<lightning:formattedDateTime aura:id="paymethod" class="" value="{!v.SelectedProduct.lineitm.ERP7__End_Time__c}"/> 
                                            
                                        </aura:renderIf>
                                    </h4> 
                                </div>
                                    
                            </div>   
                            
                        </div>
                        <div class="modal-body POS-newClass145">
                            <table class="slds-table slds-no-row-hover slds-table_cell-buffer">
                                <aura:renderIf isTrue="{!(v.mySerialNos.length > 0)}">
                                <thead>
                                    <tr class=" POS-newClass146">
                                        <th scope="col">
                                            <div class="slds-truncate" title="Name">Name</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Serial Number ">Serial Number</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Fixed Asset">Fixed Asset</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Date of Manufacture">Date of Manufacture</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Availability date">Availability date</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Shelf Life Expiration Date">Shelf Life Exp. Date</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title=" vendor Serial Number">Vendor SLN</div>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="POS-newClass146">
                                    <aura:iteration var="Serial" indexVar="serialCounts" items="{!v.mySerialNos}">
                                        
                                        <tr>
                                            <td scope="row" data-label="Name">
                                                <div class="slds-truncate" title="{!Serial.Name}">
                                                    <a href="{!'/'+ Serial.Id}" target="_blank" class="Name">
                                                        <lightning:formattedText value="{!Serial.Name}"/>
                                                    </a>
                                                </div>
                                            </td>
                                            <td data-label="Serial Number">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Serial_Number__c}">
                                                    <lightning:formattedText value="{!Serial.ERP7__Serial_Number__c}"/>
                                                </div>
                                            </td>
                                            <td data-label="Fixed Asset">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Asset__r.Name}">
                                                    <a href="{!'/'+ Serial.ERP7__Asset__c}" target="_blank" class="Name">
                                                        <lightning:formattedText value="{!Serial.ERP7__Asset__r.Name}"/>
                                                    </a>
                                                </div>
                                            </td>
                                            <td data-label="Date of Manufacture">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Date_of_Manufacture__c}">
                                                    <lightning:formattedDateTime value="{!Serial.ERP7__Date_of_Manufacture__c}"/>
                                                </div>
                                            </td>
                                            <td data-label="Availability date">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Availability_date__c}">
                                                    <lightning:formattedDateTime value="{!Serial.ERP7__Availability_date__c}"/>
                                                </div>
                                            </td>
                                            <td data-label="Shelf Life Exp. Date">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Shelf_Life_Expiration_Date__c}">
                                                    <lightning:formattedDateTime value="{!Serial.ERP7__Shelf_Life_Expiration_Date__c}"/>
                                                </div>
                                            </td>
                                            <td data-label=" vendor SLN">
                                                <div class="slds-truncate" title="{!Serial.ERP7__Vendor_Serial_Number__c}">
                                                    <lightning:formattedText value="{!Serial.ERP7__Vendor_Serial_Number__c}"/>
                                                </div>
                                            </td>
                                        </tr>
                                        
                                    </aura:iteration>
                                </tbody>
                                </aura:renderIf>
                                
                                <aura:renderIf isTrue="{!(v.myBatchNos.length > 0)}">
                                <thead >
                                    <tr class="slds-text-heading--label POS-newClass146">
                                        <th scope="col">
                                            <div class="slds-truncate" title="Batch Number">Batch.No</div>
                                        </th>
                                        <th scope="col">
                                            <div class="slds-truncate" title="Product">Product</div>
                                        </th>
                                        
                                        <th scope="col">
                                            <div class="slds-truncate" title="Availability">Availability</div>
                                        </th> 
                                        
                                    </tr>
                                    </thead>
                                    <aura:iteration var="SLN" indexVar="counts" items="{!v.myBatchNos}">
                                        <tbody>
                                            <tr class="slds-hint-parentPOS-newClass146">
                                                <td>
                                                    <div class="slds-truncate POS-newClass25" title="SLN" id="{!SLN.Id}">
                                                        <lightning:formattedText value="{!SLN.Name}" onclick="{!c.NavRecord}" title="{!SLN.Id}"/>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-truncate POS-newClass25" title="Product" id="{!SLN.ERP7__Product__c}">
                                                        <lightning:formattedText value="{!SLN.ERP7__Product__r.Name}" onclick="{!c.NavRecord}" title="{!SLN.ERP7__Product__c}"/>
                                                        <aura:renderIf isTrue="{!(SLN.ERP7__Product__r.ERP7__Picture__c != undefined)}">
                                                            &nbsp;&nbsp;<img src="{!SLN.ERP7__Product__r.ERP7__Picture__c}" class="POS-newClass69" />
                                                        </aura:renderIf>    
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-truncate" title="Availability">
                                                        <lightning:formattedText value="{!SLN.ERP7__Available_Quantity__c}" />	
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </aura:iteration>
                                </aura:renderIf>
                            </table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
                
            </div>
            <!-- popup15 ends here -->
            
            <!-- Modal Comment Edit Line Items -->
            <div id="myModalCancelled" class="modal fade" role="dialog">
                <div class="modal-dialog POS-newClass103">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header POS-newClass104">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title POS-newClass78">Cancellation Reason</h4>
                        </div>
                        <div class="modal-body">
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <lightning:textarea aura:id="pdes" 
                                                      class="slds-textarea"
                                                      rows="4" cols="20"
                                                      value="{!v.SalesOrder.ERP7__Cancelled_Reason__c}"
                                                      />
                                </div>
                            </div>
                            
                            <div class="slds">
                                <div class="row slds-m-top--medium POS-newClass105">
                                    <div class="col-md-12 slds-m-bottom--small POS-newClass1">
                                        <button type="button"  data-dismiss="modal">Done</button>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
            <!-- popup3 ends here -->
        </div>
        <!--Delete Modal Starts Here-->
        
        <div role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-hide slds-modal slds-fade-in-open POS-newClass147" aura:id="deleteModal">
            <div class="slds-modal__container">
                <div class="slds-modal__header">
                    <button class="slds-button slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.hideDeletePopup}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                        <span class="slds-assistive-text">Close</span>
                    </button>
                    
                    <h2 id="header43" class="slds-text-heading--medium"><span class="POS-newClass148">Delete Sales Order Line Item</span></h2>
                </div>
                <div class="slds-modal__content slds-p-around_medium">
                    <p class="POS-newClass43">Are you sure you want to delete this Line Item?</p>
                </div>
                <div class="slds-modal__footer">
                    <button class="slds-button slds-button--neutral" onclick="{!c.hideDeletePopup}">Cancel</button>
                    <button  onclick="{!c.DeleteRecordById}">Delete</button>
                </div>
            </div>
        </div>
        <div class="slds-backdrop slds-backdrop_open"></div>
        
        <!--Delete Modal Ends Here-->
    </div>
</aura:component>