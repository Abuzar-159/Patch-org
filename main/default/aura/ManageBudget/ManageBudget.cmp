                                                                                    </a>
                                                                                    </lightning:button></td>
                                                                                <td>{!Indexed+1}</td>
                                                                                <td><div class="slds-truncate-custom" data-index="{!Index}" data-indexe="{!DepIndex}" data-indexed="{!Indexed}" data-value="{!budget.ERP7__Chart_of_Account__c}" onmouseleave="{!c.lookupClickProduct}" ><c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="custom:custom57" selectedRecordId="{!budget.ERP7__Chart_of_Account__c}" qry=" AND ERP7__Available_for_Budgeting_Process__c = true"/></div></td>
                                                                                <td>{!budget.ERP7__Account_Number__c}</td>
