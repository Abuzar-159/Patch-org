                                                    <table class="slds-table slds-table_bordered slds-no-row-hover" style="border-right: 1px solid #ddd;">
                                                        <thead>
                                                            
                                                            <tr>
                                                                
                                                                <th scope="col" width="10%">
                                                                    <lightning:button class="slds-button slds-button_neutral " onclick="{!c.addBudgetAccount}" name="{!DepIndex}" value="{!Index}"><i class="fa fa-plus"></i>&nbsp;New</lightning:button>
                                                                    <!--a data-record="{!Index}" onclick="{!c.addBudgetAccount}">Add Budget Subcategory</a-->
                                                                </th>
                                                                <th>SI No</th>
                                                                <th scope="col">Budget Sub Category</th>
                                                                <th scope="col">Account Number</th>
                                                                <th scope="col">Account Type</th>
                                                                <th scope="col" width="100">Jan&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Feb&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Mar&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Apr&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">May&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Jun&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Jul&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Aug&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Sep&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Oct&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Nov&nbsp;{!v.selectedYear}</th>
                                                                <th scope="col" width="100">Dec&nbsp;{!v.selectedYear}</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <aura:iteration var="budget" items="{!depwrap.budgetAccount}" indexVar="Indexed">
                                                                <tr>
                                                                    <td><lightning:button class="slds-button slds-button_neutral neutralC" name="{!Index}" value="{!DepIndex}" title="{!Indexed}" onclick="{!c.removeItem}"><!-- onclick="{!c.removeItem}" -->
                                                                        <a title="Remove Item">
                                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="mbr-class12" data-aura-rendered-by="19:1393;a"/>
                                                                        </a>
                                                                        </lightning:button></td>
                                                                    <td>{!Indexed+1}</td>
                                                                    <td><div class="slds-truncate-custom" data-index="{!Index}" data-indexe="{!DepIndex}" data-indexed="{!Indexed}" data-value="{!budget.ERP7__Chart_of_Account__c}" onmouseleave="{!c.lookupClickProduct}" ><c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="custom:custom57" selectedRecordId="{!budget.ERP7__Chart_of_Account__c}" qry=" AND ERP7__Available_for_Budgeting_Process__c = true"/></div></td>
                                                                    <td>{!budget.ERP7__Account_Number__c}</td>
                                                                    <td>{!budget.ERP7__Budget_Account_Category__c}</td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__January_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__February_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__March_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__April_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__May_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__June_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__July_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__August_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__September_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__October_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__November_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                    <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__December_Budget__c}" formatter="currency" onchange="{!c.updateProjectYearTotal}"/></td>
                                                                </tr>
                                                            </aura:iteration>
                                                        </tbody>
                                                    </table> 
                                                </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </aura:iteration>
                           
                            </div>
                        </div>
                    </aura:iteration>
                    
                </div>
                <div class="slds-docked-form-footer">
                    <lightning:button label="{!$Label.c.Cancel_ManageLeave}" class="slds-button slds-button--neutral" onclick="{!c.cancelclick}" variant="neutral" />&nbsp;
                    <lightning:button label="{!$Label.c.ContractConsole_Save}" class="slds-button slds-button__brand" onclick="{!c.saveBudgetUpdate}" variant="brand" disabled="{!v.showMmainSpin}"/>
                </div>
            </aura:if>
        </aura:if>
        
        <aura:if isTrue="{!v.showMmainSpin}">
            <span class="mbr-class37">
                <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
        </aura:if>
    </body>
</aura:component>