<aura:component controller="BudgetPlanner" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <head>
        <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/manageleave.css"/>
        <!--ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/-->
        <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>
        <ltng:require styles="/resource/ERP7__ERPTheme/css/main-leavemanagement.css"/>
    </head>
    <aura:attribute name="ShowBudgetType" type="Boolean" default="true"/>
    <aura:attribute name="isMonthlyManage" type="Boolean" default="false"/>
    <aura:attribute name="BudgetId" type="String"/>
    <aura:attribute name="setRT" type="String"/>
    <aura:attribute name="budgetType" type="String"/>
    <aura:attribute name="totalBudget" type="Integer" default="0"/>
    <aura:attribute name="thresholdvalue" type="Integer" default="100"/>
    <aura:attribute name="selectedMonth" type="String" default="January"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="Organisation" type="Map" default="{}"/> 
    <aura:attribute name="Project" type="Map" default="{}"/> 
    <aura:attribute name="ProjectWrapperList" type="list" default="{'sObjectType' : 'programmeWrapper'}"/> 
    <aura:attribute name="fetchRecordsBool" type="Boolean" default="true"/>
    <aura:attribute name="years" type="String[]" />
    <aura:attribute name="options" type="List" default="[
                                                        {'label': 'Posted Actual Expenditures', 'value': 'Posted Actual Expenditures'},
                                                        {'label': 'UnPosted Actual Expenditures', 'value': 'UnPosted Actual Expenditures'}
                                                        ]"/>
    <aura:attribute name="selectedYear" type="String" />
    <aura:attribute name="selectedOption" type="String" default="Posted Actual Expenditures"/>
    <aura:attribute name="MonthlyBudgetAccount" type="list" default="{'sObjectType' : 'budgetWrapper'}"/>
    <body  style="background-color: #f3f4f7;min-height:100vh;">
        
        <aura:if isTrue="{!v.ShowBudgetType}"> 
            <div class="erp_Mark7 ">
                <section role="dialog" tabindex="-2" aria-labelledby="modal-heading-02" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-modal_medium slds-fade-in-open">
                    <div class="slds-modal__container">
                        <header class="slds-modal__header">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="{!$Label.c.Close_Timesheets}" onclick="{!c.cancelclick}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="small" alternativeText="{!$Label.c.Close_Timesheets}" title="{!$Label.c.Close_Timesheets}" />
                                
                                <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                            </button>
                            <p id="modal-heading-01" class="createbill-class8">Select Budget Allocation Type</p>
                        </header>
                        <div class="slds-modal__content" id="modal-content-id-1">
                            
                            <div class="epr_Mark7">
                                <div class="container-fluid ">
                                    <div class="row slds-p-around--small createbill-class9">
                                        
                                        <div class="col-md-4">
                                            <div class="card cursor-pointer card-extra-po" aura:id="pOcheckbox" data-billType='Monthly Budget' onclick="{!c.onCheck}">
                                                <div class="card-content">
                                                    <div class="card-body">
                                                        <div class="media d-flex">
                                                            <div class="align-self-center">
                                                                <lightning:icon iconName="standard:bill_of_materials" size="medium"></lightning:icon>
                                                            </div>
                                                            <div class="media-body text-center pt-1">
                                                                
                                                                <span class="pofsize-16">Monthly Budget</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!--div class="card maqbutton-ns cursor-pointer border-0" aura:id="pOcheckbox" data-billType='PO Bill' onclick="{!c.onCheck}">
                                                <div class="slds-grid pt-2 pl-3 pb-2 cslabel slds-button slds-button_neutral p-100">
                                                    <i class="fa fa-file-text" aria-hidden="true" data-aura-rendered-by="971:0"></i>
                                                    &nbsp;<label class="slds-form-element__label slds-p-left-/-small cursor-pointer">{!$Label.c.PO_Bill}</label>
                                                </div>
                                            </div-->
                                        </div>
                                        <div class="col-md-4">
                                            <div class="card cursor-pointer card-extra-eb"  aura:id="billcheckbox" data-billType="Quarterly Budget" onclick="{!c.onCheck}">
                                                <div class="card-content">
                                                    <div class="card-body">
                                                        <div class="media d-flex">
                                                            <div class="align-self-center">
                                                                <lightning:icon iconName="standard:expense" size="medium"></lightning:icon>
                                                            </div>
                                                            <div class="media-body text-center pt-1">
                                                                <span class="pofsize-16">Quarterly Budget</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!--div class="card maqbutton-ns cursor-pointer border-0" aura:id="billcheckbox" data-billType="Expense Bill" onclick="{!c.onCheck}">
                                                <div class="slds-grid pt-2 pl-3 pb-2 cslabel slds-button slds-button_neutral p-100">
                                                    <i class="fa fa-file-text-o" aria-hidden="true" data-aura-rendered-by="971:0"></i>
                                                    &nbsp;<label class="slds-form-element__label slds-p-left-/-small cursor-pointer">{!$Label.c.Expense_Bill}</label>
                                                </div>
                                            </div-->
                                        </div>
                                        <div class="col-md-4">
                                            <div class="card cursor-pointer card-extra-atv"  aura:id="Advcheckbox" data-billType="Yearly Budget" onclick="{!c.onCheck}">
                                                <div class="card-content">
                                                    <div class="card-body">
                                                        <div class="media d-flex">
                                                            <div class="align-self-center">
                                                                <lightning:icon iconName="standard:currency" size="medium"></lightning:icon>
                                                                
                                                            </div>
                                                            <div class="media-body text-center pt-1">
                                                                <span class="pofsize-16">Yearly Budget</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!--div class="card maqbutton-ns cursor-pointer border-0" aura:id="Advcheckbox" data-billType="Advance to vendor" onclick="{!c.onCheck}">
                                                <div class="slds-grid pt-2 pl-3 pb-2 cslabel slds-button slds-button_neutral p-100">
                                                    <i class="fa fa-file" aria-hidden="true" data-aura-rendered-by="971:0"></i>
                                                    &nbsp;<label class="slds-form-element__label slds-p-left-/-small cursor-pointer">{!$Label.c.Advance_to_Vendor}</label>
                                                </div>
                                            </div-->
                                        </div>
                                    </div> 
                                    
                                </div>
                                <footer class="slds-modal__footer createbill-class10">
                                    <lightning:button label="{!$Label.c.Cancel_ManageLeave}" class="slds-button slds-button--neutral" onclick="{!c.cancelclick}" variant="neutral" />&nbsp;
                                </footer>
                            </div>
                            
                        </div> 
                    </div>
                    
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
        </aura:if>
        <aura:if isTrue="{!!v.ShowBudgetType}">
            <aura:if isTrue="{!v.setRT=='Monthly Budget'}">
                <div class="card3-header">
                    <div class="card3-header slds-page-header__row slds-p-around_small">
                        <div class="slds-page-header__col-title slds-media">
                            <div class="slds-media__figure">
                                <span class="slds-icon_container slds-icon-standard-budget" title="">
                                    <lightning:icon iconName="standard:budget" size="medium"></lightning:icon>
                                    
                                    <span class="slds-assistive-text"></span>
                                </span>
                            </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title slds-truncate" title="">Monthly Budget Allocation</span>
                                        </h1>
                                    </div>
                                </div>
                                <p class="slds-page-header__name-meta">{!v.selectedMonth} &nbsp;{!v.selectedYear}</p>
                            </div>
                            <div class="slds-p-right_small" style="display: flex;">
                                <lightning:select name="selectYear" label="Select Year" aura:id="yearPicklist" value="{!v.selectedYear}">
                                    <aura:iteration items="{!v.years}" var="year">
                                        <option value="{!year}">{!year}</option>
                                    </aura:iteration>
                                </lightning:select>
                                <lightning:select name="selectMonth" label="Select Month" aura:id="monthPicklist" value="{!v.selectedMonth}">
                                    <option value="January">January</option>
                                    <option value="February">February</option>
                                    <option value="March">March</option>
                                    <option value="April">April</option>
                                    <option value="May">May</option>
                                    <option value="June">June</option>
                                    <option value="July">July</option>
                                    <option value="August">August</option>
                                    <option value="September">September</option>
                                    <option value="October">October</option>
                                    <option value="November">November</option>
                                    <option value="December">December</option>
                                </lightning:select>
                                <div style="margin-left: 10px;">
                                    <c:CustomInputLookUp label="Organisation" objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}"
                                                            IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                </div>
                                <div style="margin-left: 10px;">
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slds-p-left_small slds-p-right_small slds-p-top_small">
                    <div class="slds-grid slds-wrap">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <i class="fa fa-file-text"></i>&nbsp;Budget Configurations</label>
                                            <lightning:helptext content="The user will receive the Warning message on reaching threshold limit.">
                                            </lightning:helptext>
                                        </span>
                                        
                                        <p><lightning:input formatter="percentage" label="Set Threshold Limit(%)" value="{!v.thresholdvalue}" placeholder="Amount" /></p>
                                        
                                    </div>
                                </div>
                            </div>
                            
                            
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_5-of-12 slds-large-size_5-of-12 slds-p-left_medium">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <i class="fa fa-calculator"></i>&nbsp;Available Budget Funds Calculation
                                            </label>
                                        </span>
                                        
                                        <lightning:radioGroup name="radioGroup"
                                                              label="Select an Option"
                                                              value="{!v.selectedOption}"
                                                              options="{!v.options}"
                                                              onchange="{!c.handleOptionChange}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-left_medium">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <lightning:icon iconName="utility:budget_category_value" size="small"></lightning:icon>&nbsp;&nbsp;Budget Amount
                                            </label>
                                        </span><br/>
                                        <h4 class="pt-3">
                                            <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!v.totalBudget}" /> 
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
     
                <div class="erp_Mark7 slds-m-left_small slds-m-right_small">
                 <div class="erp_Mark7 table-responsive mb-pb100">
                     <aura:iteration var="wrapper" items="{!v.ProjectWrapperList}" indexVar="Indexing">
                         <div class="card-body p-2">
                             <div class="d-flex align-items-center justify-content-between"> 
                                 <h5 class="mb-3">Programme overview</h5>
                                 <div class="dropdown">
                                     <div class="slds-grid">
                                         <!--a data-record="{!Index}" onclick="{!c.addProject}">Add Project</a-->
                                         <div class="slds-truncate-custom" data-index="{!Indexing}" data-value="{!wrapper.Programme}" >
                                             <c:CustomInputLookUp label="Programme" objectAPIName="ERP7__Programme__c" selectedRecordId="{!wrapper.Programme}"
                                                                     IconName="standard:account" placeholder="Search Programme...." /> 
                                         </div>
                                         
                                         <div class="slds-m-top_large-mb">
                                             <lightning:button class="slds-button slds-button_icon slds-button_icon-border-filled" title="Add Programme" onclick="{!c.addProgramme}">
                                                 <lightning:icon iconName="utility:add" size="x-small"></lightning:icon>
                                                 
                                                 <span class="slds-assistive-text">Add Programme</span>
                                             </lightning:button>
                                             <lightning:button class="slds-button slds-button_icon slds-button_icon-border-filled deleteClass" title="Delete Programme" onclick="{!c.deleteProgramme}" value="{!Indexing}">
                                                 <lightning:icon iconName="utility:delete" size="x-small" variant="inverse"></lightning:icon>
                                                 
                                                 <span class="slds-assistive-text">Delete Programme</span>
                                             </lightning:button>
                                         </div>
                                     </div>
                                     <!--lightning:button class="slds-button slds-button_brand float-right" onclick="{!c.addProject}" ><i class="fa fa-plus"></i>&nbsp;Project</lightning:button-->
                                 </div>
                             </div>
                         </div>
                         <aura:iteration var="wrap" items="{!wrapper.projWrapList}" indexVar="Index">
                             <div class="card2 mt-3">
                                 <div class="card-body">
                                     <div class="d-flex align-items-center justify-content-between"> 
                                         <h5 class="mb-3">Project overview</h5>
                                         <div class="dropdown">
                                             <div class="slds-grid">
                                                 <!--a data-record="{!Index}" onclick="{!c.addProject}">Add Project</a-->
                                                 <div class="slds-truncate-custom" data-index="{!Index}" data-value="{!wrap.Project}"  >
                                                     <c:CustomInputLookUp label="Project" objectAPIName="ERP7__Project__c" selectedRecordId="{!wrap.Project}"
                                                                             IconName="standard:account" placeholder="Search Project...." /> 
                                                 </div>
                                                 
                                                 <div class="slds-m-top_large-mb">
                                                     <lightning:button class="slds-button slds-button_icon slds-button_icon-border-filled" title="Add Project" onclick="{!c.addProject}" value="{!Indexing}">
                                                         <lightning:icon iconName="utility:add" size="x-small"></lightning:icon>
                                                         
                                                         <span class="slds-assistive-text">Add Project</span>
                                                     </lightning:button>
                                                     <lightning:button  class="slds-button slds-button_icon slds-button_icon-border-filled deleteClass" title="Delete Project" onclick="{!c.deleteProject}" name="{!Index}" value="{!Indexing}">
                                                         <lightning:icon iconName="utility:delete" size="x-small" variant="inverse"></lightning:icon>
                                                         
                                                         <span class="slds-assistive-text">Delete Project</span>
                                                     </lightning:button >
                                                 </div>
                                             </div>
                                             <!--lightning:button class="slds-button slds-button_brand float-right" onclick="{!c.addProject}" ><i class="fa fa-plus"></i>&nbsp;Project</lightning:button-->
                                         </div>
                                     </div>
                                     
                                     
                                     <aura:iteration var="depwrap" items="{!wrap.depWrapList}" indexVar="DepIndex">
                                         
                                        
                                         <div class="slds-grid slds-wrap slds-p-bottom_small">
                                             <div class="slds-col slds-size_1-of-1 slds-medium-size_11-of-12 slds-large-size_11-of-12">
                                                 <div class="card m-2"> 
                                                     <div class="card-body p-2">
                                                         <div class="slds-grid slds-wrap slds-p-bottom_small">
                                                             <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12">
                                                                 <!--a data-record="{!Index}" onclick="{!c.addProject}">Add Project</a-->
                                                                 
                                                                 <div class="slds-truncate-custom">
                                                                     
                                                                     <c:CustomInputLookUp label="Department" objectAPIName="ERP7__Business_Unit__c " selectedRecordId="{!depwrap.DepartmentId}"
                                                                                             IconName="standard:account" placeholder="Search Department...." /> 
                                                                 </div>
                                                             </div>
                                                             
                                                             <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small slds-m-top_small">
                                                                 <div class="bg-body p-2 rounded bg-mbui">
                                                                     <div class="d-flex align-items-center mb-2">
                                                                         <div class="flex-shrink-0">
                                                                             
                                                                         </div>
                                                                         <div class="flex-grow-1 ms-2">
                                                                             <p class="mb-0">&nbsp;Project Budget Amount</p>
                                                                         </div>
                                                                     </div>
                                                                     <h6 class="mb-0"><lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!wrap.ProjectBudgetAmount}" /><small class="text-muted"></small></h6>
                                                                 </div>
                                                             </div>
                                                             
                                                             <aura:if isTrue="{!and(depwrap.DepartmentId!=null, depwrap.DepartmentId!='')}">
                                                                 <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-m-top_small">
                                                                     
                                                                     <div class="bg-body p-2 rounded bg-mbui">
                                                                         <div class="d-flex align-items-center mb-2">
                                                                             <div class="flex-shrink-0">
                                                                                 
                                                                             </div>
                                                                             <div class="flex-grow-1 ms-2">
                                                                                 <p class="mb-0">&nbsp;Department Budget Amount</p>
                                                                             </div>
                                                                         </div>
                                                                         <h6 class="mb-0"><lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!depwrap.DepartmentBudgetAmount}" /> </h6>
                                                                     </div>
                                                                     
                                                                 </div>
                                                                 <aura:set attribute="else">
                                                                     <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12">
                                                                     </div>
                                                                 </aura:set>
                                                             </aura:if>
                                                             <aura:if isTrue="{!DepIndex==0}">
                                                                 <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-m-top_large-mb">
                                                                     <lightning:button class="slds-button slds-button_brand float-right" onclick="{!c.addDepartment}" value="{!Index}" name="{!Indexing}"><i class="fa fa-plus"></i>&nbsp;Department</lightning:button>
                                                                 </div>
                                                                 
                                                             </aura:if>
                                                             
                                                             <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-m-top_small">
                                                                 <table class="slds-table table_bordered   slds-no-row-hover">
                                                                     <thead>
                                                                         
                                                                         <tr>
                                                                             
                                                                             <th scope="col" width="10%">
                                                                                 <lightning:button class="slds-button slds-button_neutral " onclick="{!c.addBudgetAccount}" title="{!Indexing}" name="{!DepIndex}" value="{!Index}"><i class="fa fa-plus"></i>&nbsp;New</lightning:button>
                                                                                 <!--a data-record="{!Index}" onclick="{!c.addBudgetAccount}">Add Budget Subcategory</a-->
                                                                             </th>
                                                                             <th>SI No</th>
                                                                             <th scope="col" width="15%">Budget Sub Category</th>
                                                                             <th scope="col">Account Number</th>
                                                                             <th scope="col">Account Type</th>
                                                                             <th scope="col" width="15%">Budget&nbsp;{!v.selectedMonth} &nbsp;{!v.selectedYear}</th>
                                                                         </tr>
                                                                     </thead>
                                                                     <tbody>
                                                                         <aura:iteration var="budget" items="{!depwrap.budgetAccount}" indexVar="Indexed">
                                                                             <tr>
                                                                                 <td><lightning:button class="slds-button slds-button_neutral neutralC" name="{!Index}" value="{!DepIndex}" title="{!Indexed}" onclick="{!c.removeItem}"><!-- onclick="{!c.removeItem}" -->
                                                                                     <a title="Remove Item">
                                                                                         <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="mbr-class12" data-aura-rendered-by="19:1393;a"/>
                                                                                     </a>
                                                                                     </lightning:button></td>
                                                                                 <td>{!Indexed+1}</td>
                                                                                 <td><div class="slds-truncate-custom" data-index="{!Index}" data-indexing="{!Indexing}" data-indexe="{!DepIndex}" data-indexed="{!Indexed}" data-value="{!budget.ERP7__Chart_of_Account__c}" onmouseleave="{!c.lookupClickProduct}" ><c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="custom:custom57" selectedRecordId="{!budget.ERP7__Chart_of_Account__c}" qry=" AND ERP7__Available_for_Budgeting_Process__c = true"/></div></td>
                                                                                 <td>{!budget.ERP7__Account_Number__c}</td>
                                                                                 <td>{!budget.ERP7__Budget_Account_Category__c}</td>
                                                                                 <td><lightning:input type="currency" name="{!Index}"  value="{!budget.ERP7__Amount__c}" formatter="currency" onchange="{!c.updateProjectTotal}"/></td>
                                                                             </tr>
                                                                         </aura:iteration>
                                                                     </tbody>
                                                                 </table> 
                                                             </div>
                                                         </div>
                                                     </div>
                                                 </div>
                                             </div>
                                             <div class="slds-col slds-size_1-of-1 slds-medium-size_1-of-12 slds-large-size_1-of-12 pcusmb01">
                                                 
                                                 <lightning:button  class="slds-button slds-button_icon slds-button_icon-border-filled deleteClass" onclick="{!c.deleteDepartment}" name="{!Index}" value="{!Indexing}" title="{!DepIndex}">
                                                     <lightning:icon iconName="utility:delete" size="x-small" variant="inverse"></lightning:icon>
                                                     
                                                     <span class="slds-assistive-text">Delete Department</span>
                                                 </lightning:button>
                                                 <!--a onclick="{!c.deleteDepartment}" name="{!Index}" value="{!Indexing}" title="{!DepIndex}">
                                                     <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="mbr-class12" data-aura-rendered-by="19:1393;a"/>
                                                 </a-->
                                             </div>
                                         </div>
                                     </aura:iteration>
                                     
                                     
                                     
                                     
                                 </div>
                             </div>
                             
                         </aura:iteration>
