                                                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.ERP7__Fourth_Quarter_Amount__c }" formatter="currency" onchange="{!c.updateProjectQuarterTotal}"/></td>
                                                                            </tr>
                                                                        </aura:iteration>
                                                                    </tbody>
                                                                </table> 
                                                            <!--/div-->
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:iteration>
                                               
