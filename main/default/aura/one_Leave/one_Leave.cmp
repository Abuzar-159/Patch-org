<aura:component controller="LeaveManagementLC" implements="force:appHostable">
    <ltng:require styles="/resource/ERP7__SLDS0121/assets/styles/salesforce-lightning-design-system-ltng.css" />
    <ltng:require styles="/resource/ERP7__SLDS0121/assets/styles/salesforce-lightning-design-system.css" />
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/one_Leave.css"/>
    <aura:handler event="c:editForm" action="{!c.testToggle}" />
    
    <div aura:id="header">
        <div class="slds-grid fright">
            <div class="slds-p-around--small wh-180-40" >
                <button class="slds-button slds-button--brand mar-top2" type="button" onclick="{!c.toggle}">Book time off</button>
            </div>
        </div>
    </div> 
    <aura:attribute name="accountId" type="Id" />
    <aura:attribute name="accounts" type="Employee_Leave__c[]" />
    <!-- Event handlers -->
    <aura:handler name="init" value="{!this}" action="{!c.handleInit}" />
    <div aura:id="hide">
        <!-- UI components -->
        <!--ERP7:manageLeave items="{!v.accounts}" delete="{!c.handleAccountDelete}" edit="{!c.handleAccountEdit}" /-->
    </div>
    {!v.body}
</aura:component>