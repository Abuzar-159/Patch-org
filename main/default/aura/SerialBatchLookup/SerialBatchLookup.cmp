<aura:component controller="SerialBatchLookup" access="global">
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SerialBatchLookup.css"/>
    <aura:attribute name="LocId" type="String" />
    <aura:attribute name="SiteId" type="String" />
    <aura:attribute name="selectedRecord" type="Map" default="{Id:'',Name:''}" description="Used to store SELECTED sObject Record"/>
    <aura:attribute name="listOfSearchRecords" type="List" description="Use,for store the list of search records which returns from apex class"/>
    <aura:attribute name="SearchKeyWord" type="string"/>
    <aura:attribute name="IconName" type="string" default=""/>
    <aura:attribute name="IconPath" type="string" default=""/>
    <aura:attribute name="showList" type="Boolean" default='false'/>
    <aura:attribute name="disabled" type="Boolean" default='false'/>
    <aura:attribute name="Message" type="String" default=""/>
    <aura:attribute name="qry" type="String" default=""/>
     <aura:attribute name="AllowNew" type="Boolean"/>
     <aura:handler name="SelectedSerialBatchEvent" event="c:SerialBatchRecordEvent" action="{!c.handleComponentEvent}"/>
     <div aura:id="searchRes" class="slds-form-element slds-lookup slds-is-close" data-select="single">
         <div class="slds-form-element__control">
             <div class="slds-input-has-icon slds-input-has-icon--right">
                 <lightning:icon class="slds-input__icon slds-show" iconName="utility:search" size="x-small" alternativeText="search"/>
                 <div aura:id="lookup-pill" class="{!and(empty(v.selectedRecord.ERP7__Inventory_Stock__c))?'slds-pill-container slds-hide':'slds-pill-container'}">
                    <span class="slds-pill width100p" >
                        <aura:if isTrue="{!or(not(empty(v.IconPath)),not(empty(v.IconName)))}">
                            <span class="slds-icon_container  slds-combobox__input-entity-icon" title="record">
                                <aura:if isTrue="{!not(empty(v.IconName))}">
                                    <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="{!v.IconName}" size="x-small" alternativeText="icon" />
                                    <aura:set attribute="else">
                                        <img src="{!v.IconPath}" class="serialBatchLookup-imgsize"/>
                                    </aura:set>
                                </aura:if>
                                
                                <span class="slds-assistive-text"></span>
                            </span>
                        </aura:if>
                        <span class="{!(or(not(empty(v.IconPath)),not(empty(v.IconName))))?'slds-pill__label slds-p-left_x-large':'slds-pill__label'}">
                            <aura:if isTrue="{!not(empty(v.selectedRecord.ERP7__Serial_Number__c))}">
                                {!v.selectedRecord.ERP7__Serial_Number__r.Name}
                            </aura:if>
                            <aura:if isTrue="{!not(empty(v.selectedRecord.ERP7__Batch_Lot__c))}">
                                {!v.selectedRecord.ERP7__Batch_Lot__r.Name}
                            </aura:if> 
                        </span>    
                    </span>
                </div>
                 <div aura:id="lookupField" class="{!not(and(empty(v.selectedRecord.ERP7__Inventory_Stock__c)))?'slds-hide':'slds-show'}">
                    <aura:if isTrue="{!or(not(empty(v.IconPath)),not(empty(v.IconName)))}">
                    <span class="slds-icon_container  slds-combobox__input-entity-icon" title="record">
                        <aura:if isTrue="{!not(empty(v.IconName))}">
                            <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="{!v.IconName}" size="x-small" alternativeText="icon"/>
                            <aura:set attribute="else">
                                <img src="{!v.IconPath}" class="serialBatchLookup-imgsize"/>
                            </aura:set>
                        </aura:if>
                        <span class="slds-assistive-text"></span>
                    </span>
                    </aura:if>
                    <lightning:input type="text" variant="label-hidden" onclick="{!c.onfocus}" onchange="{!c.keyPressController}" class="{!(or(not(empty(v.IconPath)),not(empty(v.IconName))))?'slds-lookup__search-input leftPaddingClass':'slds-lookup__search-input'}" value="{!v.SearchKeyWord}" placeholder="Search.." onblur="{!c.onblur}" disabled="{!v.disabled}"/>
                </div> 
             </div>
         </div>
      <!--This part is for Display typehead lookup result List-->  
        <ul class="slds-listbox slds-listbox_vertical slds-dropdown slds-dropdown_fluid slds-lookup__menu slds z-index1001" role="listbox" onmouseover="{!c.showList}" onmouseout="{!c.hideList}"  >
            <center> <lightning:spinner variant="brand" size="small" aura:id="iconspinner" class="slds-hide"/></center>
            <center> {!v.Message}</center>
            <aura:iteration items="{!v.listOfSearchRecords}" var="singleRec">
               
               <c:SerialBatchLookupResult oRecord="{!singleRec}" IconName="{!v.IconName}" IconPath="{!v.IconPath}" />
                
            </aura:iteration>
        </ul>
    </div>
</aura:component>