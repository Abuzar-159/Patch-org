<aura:component controller="BankReconciliationLightning" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
	<aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute type="Date" name="startDate"/>
    <aura:attribute type="Date" name="endDate"/>
    <aura:attribute name="bankAccid" type="String"/>
    <aura:attribute name="transactionList" type="List" />
    <aura:if isTrue="{!v.showMmainSpin}">
        <span class="createinvoice-class17">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if> 
    <div class="erp_Mark7 BankReconciliation-newClass4"> 
        
                <div class="slds-grid slds-wrap slds-p-around_small">
                    <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-around--xx-small ">
                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                            <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Bank_Reconcilation_Bank_Account}</label>
                            <c:CustomInputLookUp objectAPIName="ERP7__Bank_details__c" selectedRecordId="{!v.bankAccid}" 
                                                    IconName="standard:account" placeholder="{!$Label.c.Bank_Reconcilation_Search_Bank_Account}" qry="AND ERP7__Active__c = true"/><!-- NameValue="{!v.BankRecon_obj.ERP7__Bank_Account__r.Name}" -->
                        </div>
                    </div>
                    <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-around--xx-small">
                    <lightning:input type="date" aura:id="StartDate" label="{!$Label.c.AddSubscription_Start_Date}" value="{!v.startDate}" />
                    </div>
                    <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-around--xx-small">
                        <lightning:input type="date" aura:id="EndDate" label="{!$Label.c.CreateClubcard_End_Date}" value="{!v.endDate}" />
                    </div>
                    <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-left--small slds-p-top_largw ">
                    <lightning:button label="{!$Label.c.Import_Online_Bank_Statement}" variant="brand" class="slds-button slds-button_brand slds-button-yodlee" onclick="{!c.fetchTransaction}"/>
                    </div>
                </div>
          
        <aura:if isTrue="{!v.transactionList.length>0}">
            <div class="slds-m-around_small">
                <div class="slds-card list-of-bank-statement"> 
                    <table class="slds-table slds-table_bordered slds-table_fixed-layout">
                        <thead>
                            <tr class="slds-text-title--caps">
                                <th class="stickyth">SI NO</th>
                                <th class="stickyth">Account Id</th>
                                <th class="stickyth">Type</th>
                                <th class="stickyth">Reference</th>
                                <th class="stickyth">Transaction Date</th>
                                <th class="stickyth">Transaction Amount</th>
                                <th class="stickyth">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.transactionList}" var="trans" indexVar="Index">
                                <tr>
                                    <td>
                                        {!Index+1}</td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.AccountId}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.subType}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.Reference}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.TransDate}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.TransAmount}
                                        </div>
                                    </td>
                                    <td>
                                        <div class="slds-truncate">
                                            {!trans.decsription}
                                        </div>
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>
                </div>
            </div>
        <aura:set attribute="else">
            <div class="slds-notify_container slds-is-relative z-index-0" aura:id="criteriaMsgId" >
                <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                    <span class="slds-assistive-text">warning</span>
                     <lightning:icon iconName="utility:warning" size="small" alternativeText="{!$Label.c.warning}"/>
                    
                    <div class="slds-notify__content slds-m-left_small">
                        <p class="slds-text-heading_small slds-p-left_small slds-m-bottom_xxx-small"> No Transaction Found
                          </p>
                    </div>
                    
                </div>
            </div>
            
        </aura:set>
        </aura:if>
    </div>
    <div class="slds-docked-form-footer">
    <input type="button" value="{!$Label.c.Cancel_ManageLeave}" class="slds-button slds-button_neutral createinvoice-class16" onclick="{!c.cancelCalled}"/>
    </div>
</aura:component>