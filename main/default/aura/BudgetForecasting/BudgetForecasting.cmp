                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.decbudgetAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.decconsumedAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!(budget.decbudgetAmount-budget.decconsumedAmount)}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input formatter="percentage" value="{!budget.decbudgetUsed}" disabled="true"/></td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>   
                               </div>
                            </div>
                        </div>
                    </aura:iteration>
                    
                </div>
                <div class="slds-docked-form-footer">
                    <lightning:button label="Back" class="slds-button slds-button--neutral" onclick="{!c.cancelclick}" variant="neutral" />&nbsp;
                </div>
            </aura:if>
        </aura:if>
        
        <aura:if isTrue="{!v.showMmainSpin}">
            <span class="mbr-class37">
                <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
        </aura:if>
        </div>
    </body>
</aura:component>