                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q2consumedAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!(budget.Q2budgetAmount-budget.Q2consumedAmount)}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input formatter="percentage" value="{!budget.Q2budgetUsed}" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q3budgetAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q3consumedAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!(budget.Q3budgetAmount-budget.Q3consumedAmount)}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input formatter="percentage" value="{!budget.Q3budgetUsed}" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q4budgetAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q4consumedAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!(budget.Q4budgetAmount-budget.Q4consumedAmount)}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input formatter="percentage" value="{!budget.Q4budgetUsed}" disabled="true"/></td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>   
                               </div>
                            </div>
                        </div>
                    </aura:iteration>
                    
                </div>
                <div class="slds-docked-form-footer">
                    <lightning:button label="Back" class="slds-button slds-button--neutral" onclick="{!c.cancelclick}" variant="neutral" />&nbsp;
                </div>
            </aura:if>
            <aura:if isTrue="{!v.setRT=='Yearly Budget'}">
                
                <div class="card3-header slds-p-around_small">
                    <div class="card3-header slds-page-header__row">
                        <div class="slds-page-header__col-title slds-media">
                            <div class="slds-media__figure">
                                <span class="slds-icon_container slds-icon-standard-budget" title="">
                                    <lightning:icon iconName="standard:budget" size="medium"></lightning:icon>
                                    
                                    <span class="slds-assistive-text"></span>
                                </span>
                            </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title slds-truncate" title="">Year Budget Forecasting</span>
                                        </h1>
                                    </div>
                                </div>
                                <p class="slds-page-header__name-meta">{!v.selectedYear}</p>
                            </div>
                            <div class="slds-p-right_small" style="display: flex;">
                                
                                <div style="margin-left: 10px;">
                                    <c:CustomInputLookUp label="Organisation" objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}"
                                                            IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" hideRemove="true"/>  
                                </div>
                                <div style="margin-left: 10px;">
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="slds-p-left_small slds-p-right_small slds-p-top_small">
                    <div class="slds-grid slds-wrap">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <i class="fa fa-file-text"></i>&nbsp;Budget Configurations</label>
                                            <lightning:helptext content="The user will receive the Warning message on reaching threshold limit.">
                                            </lightning:helptext>
                                        </span>
                                        
                                        <p><lightning:input formatter="percentage" label="Set Threshold Limit(%)" value="{!v.thresholdvalue}" placeholder="Amount" disabled="true"/></p>
                                        
                                    </div>
                                </div>
                            </div>
                            
                            
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-left_medium">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <i class="fa fa-calculator"></i>&nbsp;Budget Amount
                                            </label>
                                        </span><br/>
                                        <h4 class="pt-3">
                                            <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!v.totalBudget}" /> 
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-left_medium">
                            <div class="erp_Mark7">
                                <div class="card2 stat-widget">
                                    <div class="card-body">
                                        <span class="card-title">
                                            <label class="slds-form-element__label mb-fsize14" for="unique-id-of-input">
                                                <i class="fa fa-calculator"></i>&nbsp;Consumed
                                            </label>
                                        </span><br/>
                                        <h4 class="pt-3">
                                            <lightning:formattedNumber currencyDisplayAs="code" style="currency"  value="{!v.consumeBudget}" /> 
