                                                <td><lightning:input type="currency" name="{!Index}" value="{!budget.Q1consumedAmount}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input type="currency" name="{!Index}" value="{!(budget.Q1budgetAmount-budget.Q1consumedAmount)}" formatter="currency" disabled="true"/></td>
                                                <td><lightning:input formatter="percentage" value="{!budget.Q1budgetUsed}" disabled="true"/></td>
