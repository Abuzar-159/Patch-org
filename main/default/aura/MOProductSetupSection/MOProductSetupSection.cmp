                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:input type="checkbox" aura:id="action"  checked="{!v.EditChklst.ERP7__Is_Mandatory__c}" label="Required" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:select aura:id="check"  value="{!v.EditChklst.ERP7__Comply__c}" label="{!$Label.c.Checklist_Operation}"   onchange="{!c.onControllerFieldChange}">
                                                <aura:iteration items="{!v.listControllingValues}" var="ck">
                                                    <option text="{!ck}"></option>
                                                </aura:iteration>
                                            </lightning:select>                                    </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:select aura:id="result"  value="{!v.EditChklst.ERP7__Result__c}" label="{!$Label.c.checklist_Value}" disabled="{!v.bDisabledDependentFld}" >
                                                <aura:iteration items="{!v.listDependingValues}" var="rs">
                                                    <option text="{!rs}"></option>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                           
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeeditchecklistModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                             <button class="slds-button slds-button--brand" onclick="{!c.SaveEditchecks}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                    
                </div>
            </div>
            
            <div class="slds-backdrop" aura:id="editChecklistModalBackdrop"></div>
            <aura:if isTrue="{!!v.showsiteSelect}">
                <div class="">
                    
                    <div class="slds-docked-form-footer m-0" >
                        <lightning:button label="{!$Label.c.PackageSlip_Back}"  class="slds-button slds-button-nneutral" onclick="{!c.backTOMOProducts}" disabled="{!(v.showsiteSelect== true)}"/>
                        <lightning:button label="{!if(v.Action == 'clone','Save',$Label.c.Complete_Set_Up)}" variant="brand" class="slds-button slds-button-bbrand white" onclick="{!c.CompletesetUp}" disabled="{!v.ProcessCycles.length == 0}"/>
                    </div>
                    
                </div>
            </aura:if>
        </aura:if>
        <aura:if isTrue="{!v.showAddProducts}">
            <div class="slds-page-header">
                <div class="slds-page-header__row">
                    <div class="slds-page-header__col-title">
                        <div class="slds-media">
                            <div class="slds-media__figure">
                                <span class="slds-icon_container slds-icon-standard-opportunity" title="Products">
                                    <lightning:icon iconName="standard:products" size="large" ></lightning:icon>
                                    <span class="slds-assistive-text">{!$Label.c.CreatePOProduct}</span>
                                </span>
                            </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title">
                                        <h1>
                                            <span class="slds-page-header__title slds-truncate" >{!$Label.c.add_for_mo_product}&nbsp;{!v.Header}</span>
                                        </h1>
                                    </div>
                                    
                                </div>
                                <p class="slds-page-header__name-meta">
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right--small">  
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <label for="4909:0" class="slds-form-element__label">
                                                        <strong>{!$Label.c.RequisitionToPurchaseOrder_Search}&nbsp;{!$Label.c.CreatePOProduct}</strong>
                                                    </label>
                                                    <lightning:input type="text" variant="label-hidden" value="{!v.searchItem}" oncommit="{!c.fetchProducts}" class="no-input-lable" placeholder="{!$Label.c.Search_Product_by_Name_and_code}" maxlength="200" ></lightning:input>
                                                </div>
                                            </div> 
                                        </div>
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right--small">
                                            <div class="slds-form-element__control">
                                                <label for="4909:0" class="slds-form-element__label">
                                                    <strong> {!$Label.c.Select}&nbsp;{!$Label.c.Family}</strong>
                                                </label>
                                                <lightning:select name="parentField" aura:id="parentField"     value="{!v.seachItemFmily}" class="no-label-cust2"  onchange="{!c.fetchFamilyProducts}"     > 
                                                    <aura:iteration items="{!v.listControllingValues1}" var="value" >
                                                        <option value="{!value}">{!value}</option>
                                                    </aura:iteration>
                                                </lightning:select>
                                                <!--<lightning:select  aura:id="family" value="{!v.seachItemFmily}"  class="no-label-cust2" onchange="{!c.fetchFamilyProducts}" >
                                                    <aura:iteration items="{!v.familylst}" var="item">
                                                        <option text="{!item}" value="{!item}" selected="{!v.seachItemFmily == item}"/>
                                                    </aura:iteration>
                                                </lightning:select>-->
                                            </div>
                                        </div> 
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right--small">
                                            <div class="slds-form-element__control">
                                                <label for="4909:0" class="slds-form-element__label">
                                                    <strong> {!$Label.c.Select}&nbsp;{!$Label.c.Sub_Family}</strong>
                                                </label>
                                                <lightning:select name="childField"
                                                                  value="{!v.subItemFmily}"
                                                                  class="no-label-cust2"
                                                                  disabled="{!v.bDisabledDependentFld1}" onchange="{!c.fetchSubFamilyProducts}" >
                                                    <aura:iteration items="{!v.listDependingValues1}" var="value">
                                                        <option value="{!value}">{!value}</option>
                                                    </aura:iteration>
                                                </lightning:select>
                                                <!-- <lightning:select  aura:id="Subfamily" value="{!v.subItemFmily}"  class="no-label-cust2" onchange="{!c.fetchSubFamilyProducts}" disabled="{!v.disableSubFamily}">
                                                    <aura:iteration items="{!v.subfamilylst}" var="item">
                                                        <option text="{!item}" value="{!item}" selected="{!v.subItemFmily == item}"/>
                                                    </aura:iteration>
                                                </lightning:select>-->
                                            </div>
                                        </div> 
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right--small slds-m-top_x-largecus">
                                            <div class="slds-form-element__control">
                                                <a class="addNewBTN AccountsPayable-newClass5" onclick="{!c.createProduct}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                    <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.New_Product} <span class="caret"></span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="{!if(and(v.addProductsMsg != '', v.addProductsMsg != undefined),'slds-notify_container slds-is-fixed cpo-class-position30','slds-notify_container slds-is-fixed cpo-class9')}">
                <div class="slds-notify slds-notify_toast slds-theme_warning cpo-class11" role="status">
                    <span class="slds-assistive-text">{!$Label.c.error}&nbsp;</span>
                    <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:warning" variant="inverse" size="x-small" alternativeText="{!$Label.c.error}" title="Warning" />
                    </span>
                    <div class="slds-notify__content">
                        <p class="slds-text-heading_x-small cpo-class12">{!v.addProductsMsg}&nbsp;
                        </p>
                    </div>
                    <div class="slds-notify__close cpo-class13">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeaddProductsMsg}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="close" />
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}&nbsp;</span>
                        </button>
                    </div>
                </div>
            </div>
            <div>
                <div class="card shadow-mrr ">                    
                    <table class="table slds-table_bordered slds-table_fixed-layout slds-table_resizable-cols pb-50" role="grid">
                        <thead>
                            <tr class="slds-text-title--caps">
                                <th width="5%">
                                </th>
                                <th>
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.Product_Code}">{!$Label.c.Product_Code}</div> 
                                </th>
                                <aura:if isTrue="{!v.showVenCodeandProdCode}">
                                    <th>
                                        <div class="slds-truncate slds-truncate-override" title="{!$Label.c.PO_Vendor_part_no}">{!$Label.c.PO_Vendor_part_no}</div>  
                                    </th>
                                </aura:if>
                                <th width="20%">
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.CreatePOProduct}">{!$Label.c.CreatePOProduct}</div> 
                                </th>
                                <th>
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.Stock}">{!$Label.c.Stock}</div> 
                                </th>
                                <th>
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.AddSubscription_Quantity}">{!$Label.c.AddSubscription_Quantity}</div> 
                                </th> 
                                <th>
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.UOM}">{!$Label.c.UOM}</div> 
                                </th>
                                <aura:if isTrue="{!v.BOMCreation}">
                                    <th>
                                        <div class="slds-truncate slds-truncate-override" title="{!$Label.c.Maximum_Variance}">{!$Label.c.Maximum_Variance}</div> 
                                    </th>
                                    <th>
                                        <div class="slds-truncate slds-truncate-override" title="{!$Label.c.Minimum_Variance}">{!$Label.c.Minimum_Variance}</div> 
                                    </th>
                                    <th>
                                        <div class="slds-truncate slds-truncate-override" title="Multiples">{!$Label.c.Multiple}</div> 
                                    </th>
                                </aura:if>
                                <th>
                                    <div class="slds-truncate slds-truncate-override" title="{!$Label.c.MOsetupProductName}">{!$Label.c.MOsetupProductName}</div> 
                                </th>
                            </tr>            
                        </thead>
                        <aura:iteration items="{!v.listOfProducts}" var="prod1" indexVar="index">
                            <tr >
                                <td scope="row" class="slds-text-align--right">                                            
                                    <div class="slds-form-element">
                                        <div class="slds-form-element__control">
                                            <lightning:input type="checkbox" variant="label-hidden" onchange="{!c.handleCheckbox}" name="{!prod1.prod.Id}" checked="{!prod1.isChecked}"></lightning:input> <!--checked="{!prod1.checkSelected}" -->
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="slds-truncate">
                                        <lightning:formattedText value="{!prod1.prod.ProductCode}"></lightning:formattedText>
                                    </div>                                            
                                </td>
                                <aura:if isTrue="{!v.showVenCodeandProdCode}">
                                    <td>
                                        <div class="slds-truncate">
                                            <lightning:formattedText value="{!prod1.prod.ERP7__Vendor_product_Name__c}"></lightning:formattedText>
                                        </div>                                            
                                    </td>
                                </aura:if>
                                <td width="20%">
                                    <div class="slds-truncate white-space-normal">
                                        <lightning:formattedUrl label="{!prod1.prod.Name}" value="{!'/'+prod1.prod.Id}" target="_blank" title="{!prod1.prod.Name}" class="line-height20"/>
                                    </div>   
                                    
                                </td>
                                <td>
                                    <div class="stock-pill">
                                        {!prod1.stock}                                               
                                    </div>
                                </td>
                                <td>
                                    <lightning:input type="number" value="{!prod1.quantity}"  name="{!index}"  step="{!$Label.c.DecimalplacesinPOScreen}" variant="label-hidden" maxlength="5" ></lightning:input>                        
                                </td> 
                                <td>
                                    <lightning:select aura:id="UOM"  value="{!prod1.UOM}" label="UOM"  variant="label-hidden" class="no-label-cust2">
                                        <aura:iteration items="{!v.BomUom}" var="uomval">
                                            <option text="{!uomval.label}" value="{!uomval.value}" selected="{!prod1.UOM == uomval.value}"></option>
                                        </aura:iteration>
                                    </lightning:select>
                                </td> 
                                <aura:if isTrue="{!v.BOMCreation}">
                                    <td>
                                        <lightning:input type="Number" aura:id="max"  value="{!prod1.MaxVariance}" label="Max. variance" variant="label-hidden" maxlength="5" />
                                    </td>
                                    <td>
                                        <lightning:input type="Number" aura:id="min"  value="{!prod1.MinVariance}" label="Min. variance" variant="label-hidden" maxlength="5" />
                                    </td>
                                    <td>
                                        <lightning:input type="Number" aura:id="multiple"  value="{!prod1.Multiples}" label="Multiples" variant="label-hidden" maxlength="5" />
                                    </td>
                                </aura:if>
                                <td width="15%">
                                    <div class="slds-truncate slds-truncate-override">
                                        <div class="slds-scrollable_y" style="height:40px;" title="{!prod1.prod.Description}">
                                        <lightning:formattedText value="{!prod1.prod.Description}"   ></lightning:formattedText>
                                        </div>
                                    </div> 
                                </td>
                            </tr>
                        </aura:iteration>
                        <aura:if isTrue="{!(v.listOfProducts.length == 0)}">
                            
                            <tr>
                                <td colspan="10">
                                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                                        <i class="mdi mdi-alert-circle-check icon-size-warning mr-2"></i>
                                        <div>{!$Label.c.No_Products_Available} </div>
                                    </div>
                                </td>
                            </tr>
                        </aura:if> 
                    </table>
                     <!-- pagination in showAddProducts -->
                    <div class="slds-grid slds-grid_align-spread slds-p-around_small border-top" style="margin-bottom: 80px;">
                            
                            <div class="slds-col slds-align-middle">
                                <div class="slds-grid slds-grid_vertical-align-center">
                                    <span class="slds-m-right_x-small text-muted">Show</span>
                                    <lightning:select name="pageSize" value="{!v.pageSize}" onchange="{!c.handlePageSizeChange}" variant="label-hidden" class="no-label-cust2 pagination-select">
                                        <option value="5">5</option>
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                    </lightning:select>
                                    <span class="slds-m-left_x-small text-muted"> ({!v.totalRecords} Total Records)</span>
                                </div>
                            </div>

                            <div class="slds-col slds-align-middle">
                                <lightning:buttonGroup>
                                    <lightning:button iconName="utility:jump_to_left" title="First Page" disabled="{!v.currentPage == 1}" onclick="{!c.firstProdPage}" />
                                    <lightning:button iconName="utility:chevronleft" label="{!$Label.c.Previous}" title="Previous Page" disabled="{!v.currentPage == 1}" onclick="{!c.prevProdPage}" />
                                    <lightning:button iconName="utility:chevronright" iconPosition="right" label="{!$Label.c.WorkOrderConsole_Next}" title="Next Page" disabled="{!v.currentPage == v.totalPages || v.totalPages == 0}" onclick="{!c.nextProdPage}" />
                                    <lightning:button iconName="utility:jump_to_right" title="Last Page" disabled="{!v.currentPage == v.totalPages || v.totalPages == 0}" onclick="{!c.lastProdPage}" />
                                </lightning:buttonGroup>
                            </div>

                            <div class="slds-col slds-align-middle">
                                <div class="slds-grid slds-grid_vertical-align-center">
                                    <span class="slds-m-right_x-small text-muted">Page</span>
                                    <lightning:input type="number" value="{!v.currentPage}" oncommit="{!c.handlePageJump}" variant="label-hidden" class="label-hidden pagination-input" min="1" max="{!v.totalPages}"/>
                                    <span class="slds-m-left_x-small text-muted">of {!v.totalPages}</span>
                                </div>
                            </div>

                        </div>
                </div>
            </div>
            <div class="slds-docked-form-footer">
                <lightning:button label="{!$Label.c.ShipmentManagement_Cancel}" onclick="{!c.backToMainPage}"></lightning:button>&nbsp;&nbsp;
                <lightning:button label="{!$Label.c.Add_Products}" onclick="{!c.addProducts}" variant="brand" disabled="{!v.disableAddProductsButton}"></lightning:button>
            </div>
        </aura:if>
    </div>
</aura:component>