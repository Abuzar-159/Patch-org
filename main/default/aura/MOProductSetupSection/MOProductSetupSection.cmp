                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                           <button class="slds-button slds-button_neutral" onclick="{!c.closeModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.updateProcsscycle}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                </div>
                
            </div>
            <div class="slds-backdrop" aura:id="myeditModalBackdrop"></div>
            <!--New Operation creation modal -->
            <section class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="NewOPModalshow" role="dialog">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closeOPModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.New_Operation}</h4>
                        
                    </header>
                    <div class="slds-modal__content" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small">
                                            <lightning:input type="text" aura:id="name"  value="{!v.NewOperation.Name}" label="{!$Label.c.Name_ManageLeave}" required="true" maxlength="80"/>
                                        </div>
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 ">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Process_Cycle__c" aura:id="wc" label="{!$Label.c.Process_Cycle}" IconName="standard:flow" selectedRecordId="{!v.NewOperation.ERP7__Process_Cycle__c}" required="true" hideRemove="true"/>
                                        </div>
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-top_small"> 
                                            <p>
                                                <lightning:input type="checkbox" aura:id="name"  checked="{!v.NewOperation.ERP7__Auto_Clock_In__c}" label="{!$Label.c.Auto_Clock_In}" />
                                            </p>
                                            <p>
                                                <lightning:input type="checkbox" aura:id="name"  checked="{!v.NewOperation.ERP7__Is_Signature_Required__c}" label="{!$Label.c.Signature_Required}" />
                                            </p>
                                            <p>
                                                <lightning:input type="checkbox" aura:id="name"  checked="{!v.NewOperation.ERP7__Timer__c}" label="{!$Label.c.Timer}" />
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                            
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeOPModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.createNewoperation}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                </div>
            </section>
            <div class="slds-backdrop" aura:id="NewOPModalBackdrop"></div>
            
            <!--Edit Operation creation modal -->
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="EditOPModalshow" role="dialog">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closeOPeditModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.EditLabel}&nbsp;{!$Label.c.Operation}</h4>
                        
                    </header>
                    
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                   <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small">
                                        <lightning:input type="text" aura:id="name"  value="{!v.EditOperation.Name}" label="{!$Label.c.Name_ManageLeave}" required="true" maxlength="80"/>
                                       </div>
                                     <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12">
                                    
                                        <c:CustomInputLookUp objectAPIName="ERP7__Process_Cycle__c" aura:id="wc" label="{!$Label.c.Process_Cycle}" IconName="standard:flow" selectedRecordId="{!v.EditOperation.ERP7__Process_Cycle__c}" required="true" hideRemove="true"/>
                                       </div>
                                       
                                       <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-right_small slds-p-top_small">
                                           <p>
                                               <lightning:input type="checkbox" aura:id="name"  checked="{!v.EditOperation.ERP7__Auto_Clock_In__c}" label="{!$Label.c.Auto_Clock_In}" />
                                           </p>
                                           
                                           <p>
                                               <lightning:input type="checkbox" aura:id="name"  checked="{!v.EditOperation.ERP7__Is_Signature_Required__c}" label="{!$Label.c.Signature_Required}" />
                                           </p>
                                           <p>
                                               <lightning:input type="checkbox" aura:id="name"  checked="{!v.EditOperation.ERP7__Timer__c}" label="{!$Label.c.Timer}" />
                                           </p>
                                       </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeOPeditModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.updateoperation}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                </div>
                
            </div>
            <div class="slds-backdrop" aura:id="EditOPModalBackdrop"></div>
            <!--Edit Operation creation modal -->
            <!--Edit BOM  modal -->
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="EditBOMModalshow" role="dialog">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closeBOMeditModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.EditLabel}&nbsp;{!$Label.c.Bill_of_Materials_BOM}</h4>
                        
                    </header>
                    
                    
                    <div class="slds-modal__content" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 slds-p-right_small">
                                            <lightning:input type="text" aura:id="name"  value="{!v.EditBOM.Name}" label="{!$Label.c.Name_ManageLeave}" required="true"/>
                                            
                                        </div>
                                        <aura:if isTrue="{!v.allowNonInventoryItems}">
                                            <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12  slds-p-right_small">
                                                <c:CustomInputProduct objectAPIName="Product2" aura:id="wc" label="{!$Label.c.CreatePOProduct}" IconName="standard:flow" selectedRecordId="{!v.EditBOM.ERP7__BOM_Component__c}" required="true" qry='And IsActive = true'/>
                                            </div>
                                            <aura:set attribute="else">
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 slds-p-right_small">
                                                    <c:CustomInputProduct objectAPIName="Product2" aura:id="wc" label="{!$Label.c.CreatePOProduct}" IconName="standard:flow" selectedRecordId="{!v.EditBOM.ERP7__BOM_Component__c}" required="true" qry='And IsActive = true and ERP7__Track_Inventory__c = true'/>
                                                </div>
                                            </aura:set>
                                        </aura:if>
