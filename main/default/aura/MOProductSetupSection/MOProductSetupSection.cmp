                                                                            <h6 class="card-title">{!$Label.c.Design_Drawing_Document}</h6>
                                                                            <div class="slds-grid"></div>
                                                                        </div>
                                                                        <table class="slds-table slds-table_bordered slds-table_fixed-layout slds-no-row-hover">
                                                                            <thead class="">
                                                                                <tr>
                                                                                    <th width="10%" class="text-left">
                                                                                        <aura:if isTrue="{!(v.Action != 'clone')}">
                                                                                            <a data-target="#myModal" onclick="{!c.openAttachmentModal}" data-record-id="{!pcs.prcscycl.Id}" data-record="Add" class="Milestones-class18" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                                <i class="fa fa-plus Milestones-class19" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                                &nbsp;{!$Label.c.New_AddTimeCardEntry}
                                                                                            </a>
                                                                                        </aura:if>
                                                                                        
                                                                                    </th>
                                                                                    <th class="text-left">{!$Label.c.Name_ManageLeave}</th>
                                                                                    <th class="text-left">{!$Label.c.Operation}</th>
                                                                                    <th class="text-left">{!$Label.c.Attachment}</th>
                                                                                    
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <aura:iteration items="{!pcs.allRelateddetails.med}" var="media" indexVar="medcount">
                                                                                    <tr>
                                                                                        <td>
                                                                                            <!--<a class="svg Milestones-class22" onclick="{!c.editmedia}" data-record-id="{!media.Id}" data-index="{!medcount}">
                                                                        <lightning:icon iconName="action:edit" size="xx-small" alternativeText="Edit!" title="Edit" />
                                                                    </a>&nbsp;-->
                                                                                            <aura:if isTrue="{!(v.Action != 'clone')}">
                                                                                                <a class="svg Milestones-class22 customcactionedit"  onclick="{!c.deletemedia}" data-record-id="{!media.Id}" data-index="{!medcount}">
                                                                                                    <lightning:icon iconName="action:delete" size="xx-small" alternativeText="delete!" title="delete" />
                                                                                                </a>
                                                                                            </aura:if>
                                                                                            <aura:if isTrue="{!(v.Action == 'clone')}">
                                                                                                <lightning:input type="checkbox" checked="{!media.selected}" title="{!media.Id}" disabled="{!!pcs.prcscycl.selected}"></lightning:input>
                                                                                            </aura:if>
                                                                                        </td>
                                                                                        <td>
                                                                                            <a href="{!'/'+ media.Id}" target="_blank">
                                                                                                <div class="slds-truncate"><lightning:formattedText value="{!media.Name}"/></div>
                                                                                            </a>
                                                                                        </td>
                                                                                        <td>
                                                                                            <a href="{!'/'+ media.ERP7__Operation__c}" target="_blank">
                                                                                                <div class="slds-truncate"> <lightning:formattedText value="{!media.ERP7__Operation__r.Name}"/></div>
                                                                                            </a>
                                                                                        </td>
                                                                                        <td>
                                                                                            <aura:iteration items="{!pcs.allRelateddetails.attchment}" var="attch">
                                                                                                <aura:if isTrue="{!(attch.ParentId == media.Id)}">
                                                                                                    <div class="slds-grid">
                                                                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_9-of-12">
                                                                                                            <div class="slds-truncate">
                                                                                                                <lightning:formattedUrl value="{!'/'+attch.Id}" label="{!attch.Name}" target="_blank" class="fcolor"/>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12">
                                                                                                            <img src="{!'/servlet/servlet.FileDownload?file='+attch.Id}" class="MOs_class111"/>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </aura:if>
                                                                                            </aura:iteration>
                                                                                        </td>
                                                                                        
                                                                                        
                                                                                    </tr> 
                                                                                </aura:iteration>
                                                                            </tbody>
                                                                        </table>                                                
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </aura:if>
                                                    </aura:If>
                                                    <!-- </aura:if>-->
                                                </aura:iteration>
                                            </aura:If>
                                       
                                    </tbody>
                                </table>
                                
                            </div>
                        </div>
                        
                    </div>
                </div>
                
                
            </aura:if>
            <aura:if isTrue="{!v.showsiteSelect}">
                <aura:if isTrue="{!!v.routingexits}">
                    <section>
                        <div class="slds-page-header">
                            <div class="slds-page-header__row">
                                <div class="slds-page-header__col-title">
                                    <div class="slds-media">
                                        <div class="slds-media__figure">
                                           
                                                <lightning:icon iconName="standard:code_set" size="small"></lightning:icon>
                                            
                                        </div>
                                        <div class="slds-media__body">
                                            <div class="slds-page-header__name">
                                                <div class="slds-page-header__name-title">
                                                    <h1>
                                                        <span class="slds-page-header__title slds-truncate" title="">{!$Label.c.Select_site_and_Version_Details}</span>
                                                    </h1>
                                                </div>
                                            </div>
                                            <p class="slds-page-header__name-meta"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="container-fluid mt-2">
                            <header class="card">
                                <div class="card-body p-2">
                                    
                                    <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate  MOs_class10">
                                        {!v.siteErr}
                                    </h2>
                                    
                                 
                                        <div class="slds-grid slds-wrap slds-p-bottom_small">
                                            <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" label="{!$Label.c.Please_Select_Raw_Material_site}" IconName="standard:flow" selectedRecord="{!v.RawMaterialsite}"  qry=" And ERP7__Active__c=true " required="true"/>                                        
                                            </div>
                                            <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" label="{!$Label.c.Please_Select_Finished_Product_site}" IconName="standard:flow" selectedRecord="{!v.FinishedProductsite}"  qry=" And ERP7__Active__c=true " required="true"/>
                                            </div>
                                        </div>
                                        
                                        <aura:If isTrue="{!(v.SelectedVersion.Id == null || v.SelectedVersion.Id == '')}">
                                            <h4><strong> {!$Label.c.Version_Details}:</strong></h4>
                                            
                                            <div class="slds-grid slds-wrap slds-p-top_small"> 
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                                    <lightning:input type="Text" aura:id="VerName"  value="{!v.NewVersion.Name}" label="{!$Label.c.Version_Name}"  />
                                                </div>
                                                
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                                    <label lightning-input_input="" for="input-284" class="slds-form-element__label slds-no-flex">{!$Label.c.Default}</label>
                                                    <lightning:input type="checkbox" aura:id="min"  checked="{!v.NewVersion.ERP7__Default__c}"  />
                                                </div>
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small slds-p-top_small">
                                                    <lightning:input type="Date" aura:id="Start date"  value="{!v.NewVersion.ERP7__Start_Date__c}" label="{!$Label.c.MyTimesheets_Start_Date}" />
                                                </div>
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                                    <lightning:input type="Date" aura:id="To date"  value="{!v.NewVersion.ERP7__To_Date__c}" label="{!$Label.c.To_Date}" />
                                                </div>
                                            </div>   
                                        </aura:If>
                                        
                                        <!-- <p>
                                            <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" label="Please Select Raw Material site" IconName="standard:flow" selectedRecord="{!v.RawMaterialsite}"  qry=" And ERP7__Active__c=true " required="true"/>
                                        </p>
                                        <br/>
                                        <p>
                                            <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" label="Please Select Finished Product site" IconName="standard:flow" selectedRecord="{!v.FinishedProductsite}"  qry=" And ERP7__Active__c=true " required="true"/>
                                        </p>
                                        <p> Version Details </p>
                                        <br/>
                                        <p>
                                            Version Name: {!v.NewVersion.Name}
                                        </p>-->
                                        
                                 
                                </div>
                            </header>
                            
                            <footer class="slds-docked-form-footer slds-text-align_center">
                                <button onclick="{!c.backTOMOProducts}" class="slds-button slds-button_neutral" > {!$Label.c.PackageSlip_Back}</button>
                                <button class="slds-button slds-button_brand" onclick="{!c.getSites}">{!$Label.c.Next_UsersShiftMatch}</button>
                            </footer>
                        </div>
                    </section>
                </aura:if>
                
            </aura:if>
            
            <aura:if isTrue="{!v.ShowNewPr}">
                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container">
                        <!-- Modal/Popup Box Header Starts here-->
                        <header class="slds-modal__header">
                            <lightning:buttonIcon iconName="utility:close"
                                                  onclick="{!c.cancelNewPr }"
                                                  alternativeText="{!$Label.c.Close_Timesheets}"
                                                  variant="bare-inverse"
                                                  class="slds-modal__close" size="large"/>
                            
                            <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Create_Process_Cycle}</h4>
                            <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate  MOs_class10">{!v.ProcessErr}</h4>
                        </header>
                        <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1" style="min-height:200px;">
                            <div class="slds-grid">
                           		<div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small">
                                <lightning:input type="text" aura:id="name"  value="{!v.NewProcessCycles.Name}" label="{!$Label.c.Name_ManageLeave}" required="true"/>
                            </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12">
                                <c:CustomInputLookUp objectAPIName="ERP7__Work_Center__c" aura:id="wc" label="{!$Label.c.Please_Select_Work_center}" IconName="standard:flow" selectedRecordId="{!v.NewProcessCycles.ERP7__Work_Center__c}"  qry="{!v.WorkQry}" required="true" selectedRecord="{!v.NewProcessCycles.ERP7__Work_Center__r}"/>
                                </div>
                            </div>
                        </div>
                        <footer class="slds-modal__footer">
                            <button onclick="{!c.cancelNewPr}" class="slds-button slds-button_neutral" >{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button_brand" onclick="{!c.createNewPr}">{!$Label.c.Save_UserAvailabilities}</button>
                            
                            
                        </footer>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </aura:if>
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="editProcssModal" role="dialog">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closeModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.EditLabel}&nbsp;{!$Label.c.Process_Cycle}</h4>
                        
                    </header>
                    
                    
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <p>
                                        <lightning:input type="text" aura:id="name"  value="{!v.EditProcessCycles.Name}" label="{!$Label.c.Name_ManageLeave}" required="true" />
                                    </p>
                                    <br/>
                                    <p>
                                        <c:CustomInputLookUp objectAPIName="ERP7__Work_Center__c" aura:id="wc" label="{!$Label.c.Please_Select_Work_center}" IconName="standard:flow" selectedRecordId="{!v.EditProcessCycles.ERP7__Work_Center__c}"  qry="{!v.WorkQry}" required="true" selectedRecord="{!v.EditProcessCycles.ERP7__Work_Center__r}"/>
                                    </p>
