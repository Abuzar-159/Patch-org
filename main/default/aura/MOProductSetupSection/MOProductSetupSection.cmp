<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes" access="global" controller="MOProductConfiguaration">
    <head>
        <!--ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" /-->
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/MOProductSetupSection.css"/>
    </head>
    
    <aura:attribute name="allowWIPValidation" type="Boolean" default="false" />
    <aura:attribute name="NewVersion" type="Version__c" default="{'sObjectType':'ERP7__Version__c',ERP7__Default__c : false,Name : '',Id:'',ERP7__Start_Date__c:'',ERP7__To_Date__c : ''}" />
    <aura:attribute name="ShowNewPr" type="Boolean" default="false" />
    <aura:attribute name="WorkQry" type="String" default="" />
    <aura:attribute name="createWCerrMsg" type="String" default="" />
    <aura:attribute name="ChannelId" type="String" default="" />
    <aura:attribute name="siteErr" type="String" default=""/>
    <aura:attribute name="editErrorMsg" type="String" default=""/>
    <aura:attribute name="ProcessErr" type="String" default=""/>
    <aura:attribute name="Productdetails" type="Object" />
    <aura:attribute name="AllProcsdetails" type="Object" />
    <aura:attribute name="ProcessCycles" type="Object" default="{}"/>
    <aura:attribute name="NewProcessCycles" type="Process_Cycle__c" default=" {'sObjectType':'ERP7__Process_Cycle__c',Name : '',ERP7__Work_Center__c : '',ERP7__Work_Center__r : {'Id':'', 'Name': ''},ERP7__Process__c : ''}"/>
    <aura:attribute name="EditProcessCycles" type="Process_Cycle__c" default=" {'sObjectType':'ERP7__Process_Cycle__c',Name : '',ERP7__Work_Center__c : '',ERP7__Work_Center__r : {'Id':'', 'Name': ''},ERP7__Process__c : '',ERP7__Sort__c: 0}"/>
    <aura:attribute name="exceptionError" type="String" />
    <aura:attribute name="showsiteSelect" type="Boolean" default="false" />
    <aura:attribute name="routingexits" type="Boolean" default="false" />
    <aura:attribute name="showspinner" type="Boolean" default="false" />
    <aura:attribute name="RawMaterialsite" type="Site__c" default="{'sObjectType':'ERP7__Site__c',Name : '',Id:''}" />
    <aura:attribute name="FinishedProductsite" type="Site__c" default="{'sObjectType':'ERP7__Site__c',Name : '',Id:''}" />
    <aura:attribute name="selectedProcess" type="List" />
    <aura:attribute name="BomUom" type="List" />
    <aura:attribute name="WIPUom" type="List" />
    <aura:attribute name="resultVal" type="List" />
    <aura:attribute name="cheklstval" type="List" />
    <aura:attribute name="NewOperation" type="Operation__c" default=" {'sObjectType':'ERP7__Process_Cycle__c',Name:'',ERP7__Process_Cycle__c: '',ERP7__Is_Signature_Required__c:false,ERP7__Timer__c: false,ERP7__Auto_Clock_In__c :false}"/>
    <aura:attribute name="EditOperation" type="Operation__c" default=" {'sObjectType':'ERP7__Process_Cycle__c',Name:'',ERP7__Process_Cycle__c: '',ERP7__Is_Signature_Required__c:false,ERP7__Timer__c: false,ERP7__Auto_Clock_In__c :false}"/>
    <aura:attribute name="NewBOM" type="BOM__c" default=" {'sObjectType':'ERP7__BOM__c',Name:'',ERP7__BOM_Component__c: '',ERP7__Quantity__c:0.0,ERP7__Maximum_Variance__c:0.0,ERP7__Minimum_Variance__c:  0.0,ERP7__For_Multiples__c : 0.0}"/>
    <aura:attribute name="EditBOM" type="BOM__c" default=" {'sObjectType':'ERP7__BOM__c',Name:'',ERP7__BOM_Component__c: '',ERP7__Quantity__c:0.0}"/>
    <aura:attribute name="NewWIP" type="WIP_Link__c" default=" {'sObjectType':'ERP7__WIP_Link__c',Name:'',ERP7__Process_Cycle__c: '',ERP7__Process_Output_Product__c:'',ERP7__Quantity_Unit_Of_Measure__c: '',ERP7__Quantity_Unit__c :0.0}"/>
    <aura:attribute name="EditWIP" type="WIP_Link__c" default=" {'sObjectType':'ERP7__WIP_Link__c',Name:'',ERP7__Process_Cycle__c: '',ERP7__Process_Output_Product__c:'',ERP7__Quantity_Unit_Of_Measure__c: '',ERP7__Quantity_Unit__c :0.0}"/>
    <aura:attribute name="Newmedia" type="Media__c" default="{'sObjectType' : 'ERP7__Media__c',Name:'',ERP7__Operation__c :''}" />
    <aura:attribute name="editMedia" type="Media__c" default="{'sObjectType' : 'ERP7__Media__c',Name:''}" />
    <aura:attribute name="FileList" type="object"/>
    <aura:attribute name="filleList" type="String[]" default="[]"/>
    <aura:attribute name="SelectedAttachments" type="object[]"/>
    <aura:attribute name="showDelete" type="Boolean" default="false"/>
    <aura:attribute name="showConfirmDialog" type="Boolean" default="false"/>
    <aura:attribute name="fileName" type="String" default="No File Selected.." />
    <aura:attribute name="oppQry" type="String" />
    <aura:attribute name="ProcessCycleId" type="String" />
    <aura:attribute name="Action" type="String" />
    <aura:attribute name="RRGroupId" type="Resource_Group__c" default="{'sObjectType' : 'ERP7__Resource_Group__c',Name:'',Id:''}"/>
    <aura:attribute name="Process" type="Object" />
    <aura:attribute name="DragIndex" type="integer" />
    <aura:attribute name="SelectedVersion" type="Object" />
    <aura:attribute name="NewChklst" type="Checklist__c" default="{'sObjectType' : 'ERP7__Checklist__c',Name:'',ERP7__Action_Detail__c :'',ERP7__Result__c:'',ERP7__Comply__c:'',ERP7__Process_Cycle__c:'',ERP7__Operation__c : '',ERP7__Operation__r : { Id: '',Name :''},ERP7__Is_Mandatory__c:false}" />
    <aura:attribute name="EditChklst" type="Checklist__c" default="{'sObjectType' : 'ERP7__Checklist__c',Name:'',ERP7__Action_Detail__c :'',ERP7__Result__c:'',ERP7__Comply__c:'',ERP7__Process_Cycle__c:'',ERP7__Operation__c : '',ERP7__Operation__r : { Id: '',Name :''}}" />
    <aura:attribute name="allowNew" type="boolean" default="true" />
    <aura:attribute name="showVenCodeandProdCode" type="boolean" default="true" />
    <!-- To get dependent picklist -->
    <aura:attribute name="listControllingValues" type="list" default="[]" description="to store controller field values"/>
    <aura:attribute name="listDependingValues" type="list" default="['--- None ---']" description="to store dependent field values"/>
    <aura:attribute name="depnedentFieldMap" type="map" description="map to store dependent values with controlling value"/>
    <aura:attribute name="bDisabledDependentFld" type="boolean" default="true"/>
    
    <aura:attribute name="objDetail" type="Checklist__c" default="{'sobjectType' : 'Checklist__c'}"/>
    <aura:attribute name="controllingFieldAPI" type="string" default="ERP7__Comply__c" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI" type="string" default="ERP7__Result__c" description="store field API name of dependent field"/>
    <aura:attribute name="allowNonInventoryItems" type="boolean" default="false"/>
    <aura:attribute name="oldSort" type="Integer" default="0"/>  
    <aura:attribute name="sortedlist" type="list" default="[]"/>  
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:method name="popInit"  action="{!c.doInit}"/>
    
    <!-- New BOM/WIP creation Page -->
    <aura:attribute name="Header" type="String" default="" />
    <aura:attribute name="addProductsMsg" type="String" default="" />
    <aura:attribute name="searchItem" type="String" default="" />
    <aura:attribute name="seachItemFmily" type="String" default="" />
    <aura:attribute name="subItemFmily" type="String" default="" />
    <aura:attribute name="familylst" type="List" /> 
    <aura:attribute name="subfamilylst" type="List" /> 
    <aura:attribute name="listOfProducts" type="String[]" default="[]"/>
    <aura:attribute name="selectedListOfProducts" type="String[]" default="[]"/>
    <aura:attribute name="showAddProducts" type="boolean" default="false"/>
    <aura:attribute name="BOMCreation" type="boolean" default="false"/>
    <aura:attribute name="disableAddProductsButton" type="boolean" default="false"/>
    
    <!-- For Product family and sub family Picklists -->
    <aura:attribute name="objDetail1" type="string" default="Product2" />
    <aura:attribute name="controllingFieldAPI1" type="string" default="Family" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI1" type="string" default="ERP7__Product_Service_Family__c" description="store field API name of dependent field"/>
    <aura:attribute name="listDependingValues1" type="list" default="" description="to store dependent field values"/>
    <aura:attribute name="listControllingValues1" type="String" default="" description="to store controller field values"/>
    <aura:attribute name="bDisabledDependentFld1" type="boolean" default="false"/> 
    <aura:attribute name="depnedentFieldMap1" type="object" description="map to store dependent values with controlling value"/>
    <aura:attribute name="showchecklistvalue1" type="boolean" default="false"/>
    <aura:attribute name="ControllingValue1" type="String" default="" description="to store controller field values"/>
    
    <aura:attribute name="SelectedVersionToClone" type="Object" />
    <aura:attribute name="ProcessToClone" type="Object" />

    <aura:attribute name="currentPage" type="Integer" default="1"/>
    <aura:attribute name="pageSize" type="Integer" default="10"/>
    <aura:attribute name="totalRecords" type="Integer" default="0"/>
    <aura:attribute name="totalPages" type="Integer" default="1"/>
    
    <div class="maqsood erp_Mark7" aura:id="body">
        <aura:if isTrue="{!v.showspinner}">
            <span class="ProjectWorkbench-newClass7">
                <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading..." aura:id="mainSpin" class="mainSpinClass"/>
            </span>
        </aura:if>
        <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'ProjectWorkbench-newClass3 slds-notify_container slds-is-fixed','ProjectWorkbench-newClass2 slds-notify_container slds-is-fixed')}">
            <div class="slds-notify slds-notify_toast slds-theme_error ProjectWorkbench-newClass4" role="status">
                <span class="slds-assistive-text">error</span>
                <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                    <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="Error!" title="Error" />
                </span>
                <div class="slds-notify__content">
                    <p class="slds-text-heading_x-small ProjectWorkbench-newClass5">{!v.exceptionError}
                    </p>
                </div>
                <div class="slds-notify__close ProjectWorkbench-newClass6">
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />	
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        
        <aura:if isTrue="{!!v.showAddProducts}">
            <aura:if isTrue="{!!v.showsiteSelect}">
                
                <div class="slds-page-header">
                    <div class="slds-page-header__row">
                        <div class="slds-page-header__col-title">
                            <div class="slds-media">
                                <div class="slds-media__figure">
                                    <span class="slds-icon_container slds-icon-standard-procedure">
                                        <lightning:icon iconName="standard:procedure" size="medium"></lightning:icon>
                                        
                                    </span>
                                </div>
                                <div class="slds-media__body">
                                    <div class="slds-page-header__name">
                                        <div class="slds-page-header__name-title">
                                            <h6>
                                               
                                                <span class="slds-page-header__title slds-truncate" title="">
                                                    <aura:if isTrue="{!v.Action == 'Edit'}">
                                                        <h6 class="card-title mb-1">
                                                            {!$Label.c.EditLabel}&nbsp;{!$Label.c.Process}
                                                        </h6>      
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.Action == 'clone'}">
                                                        <h6 class="card-title mb-1">
                                                           {!$Label.c.New_AddTimeCardEntry}&nbsp;{!$Label.c.Process} 
                                                        </h6>
                                                    </aura:if>
                                                    <aura:if isTrue="{!v.Action == 'New'}">
                                                        <h6 class="card-title mb-1">
                                                            {!$Label.c.Transfer_Order_Create}&nbsp;{!$Label.c.Process}
                                                        </h6>
                                                    </aura:if>
                                                
                                                </span>
                                                 <span>
                                                    <a href="{!'/'+ v.Productdetails.Id}" target="_blank">
                                                        <lightning:formattedText value="{!v.Productdetails.Name}"/>
                                                    </a>
                                                </span>
                                            </h6>
                                        </div>
                                        <div class="slds-page-header__name-switcher">
                                            <div class="slds-dropdown-trigger slds-dropdown-trigger_click">
                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="slds-page-header__col-actions">
                            <div class="slds-page-header__controls">
                                <div class="slds-page-header__control">
                                    <ul class="slds-button-group-list">
                                        <li>
                                            <div class="slds-grid">
                                                
                                                <div class="slds-m-right--xx-small slds-truncate slds-truncate-pw-grid"> <i class="fa fa-arrow-right Pick-newClass6"></i>&nbsp;
                                                    <lightning:formattedUrl label="{!v.SelectedVersion.Name}" value="{!'/'+v.SelectedVersion.Id}" target="_blank"/>
                                                </div>
                                                <div class="slds-m-right--xx-small slds-truncate slds-truncate-pw-grid">  <i class="fa fa-filter Pick-newClass6" ></i>&nbsp;<lightning:formattedUrl label="{!v.Process.Name}" value="{!'/'+v.Process.Id}" target="_blank"/></div>
                                                
                                            </div>
                                        </li>
                                        <li>
                                            
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="container-fluid pb-1 pl-2 pt-1 ProjectWorkbench-newClass8  theme-bg min-height520">
                    <div class="card shadow-mrr ProjectWorkbench-newClass49 mt-100">
                        <div class="card-body">
                            <div class=" justify-content-between slds-hide"> 
                                
                                <h6 class="card-title">
                                    <a href="{!'/'+ v.Productdetails.Id}" target="_blank">
                                        <lightning:formattedText value="{!v.Productdetails.Name}"/>
                                    </a>
                                </h6>
                                <aura:if isTrue="{!v.Action == 'Edit'}">
                                    <h6 class="card-title">
                                        <Center>{!$Label.c.EditLabel}&nbsp;{!$Label.c.Process}</Center> 
                                    </h6>      
                                </aura:if>
                                <aura:if isTrue="{!v.Action == 'clone'}">
                                    <h6 class="card-title">
                                        <Center>{!$Label.c.New_AddTimeCardEntry}&nbsp;{!$Label.c.Process}</Center> 
                                    </h6>
                                </aura:if>
                                <aura:if isTrue="{!v.Action == 'New'}">
                                    <h6 class="card-title">
                                        <Center>{!$Label.c.Transfer_Order_Create}&nbsp;{!$Label.c.Process}</Center> 
                                    </h6>
                                </aura:if>
                                <div class="slds-grid">
                                    
                                    <div class="slds-m-right--xx-small slds-truncate2"> <i class="fa fa-arrow-right Pick-newClass6"></i>&nbsp;
                                        <lightning:formattedUrl label="{!v.SelectedVersion.Name}" value="{!'/'+v.SelectedVersion.Id}" target="_blank"/>
                                    </div>
                                    <div class="slds-m-right--xx-small slds-truncate2">  <i class="fa fa-filter Pick-newClass6" ></i>&nbsp;<lightning:formattedUrl label="{!v.Process.Name}" value="{!'/'+v.Process.Id}" target="_blank"/></div>
                                    
                                </div>
                                
                            </div>
                            
                            <div class="table-responsive ProjectWorkbench-newClass50" tabindex="1">
                                <table class="slds-table slds-table_striped slds-table_fixed-layout slds-no-row-hover">
                                    <thead class="">
                                        <tr>
                                            <th width="10%" class="text-left">
                                                <aura:if isTrue="{!(v.Action != 'clone')}">
                                                    <a data-target="#myModal" onclick="{!c.NewProcesscylce}" data-record="Add" class="Milestones-class18" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                        <i class="fa fa-plus Milestones-class19" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                        &nbsp;{!$Label.c.New_AddTimeCardEntry}
                                                    </a>
                                                </aura:if>
                                            </th>
                                            <th class="text-left">{!$Label.c.Process_cycle_Manufacturing_Step}</th>
                                            <th class="text-left">{!$Label.c.Assigned_Work_Center}</th>
                                            <th class="text-left">{!$Label.c.Sort}</th>
                                            <th>&nbsp;</th>
                                        </tr>
                                    </thead>
                                    <tbody >
                                        
                                            <aura:If isTrue="{!v.allowNew}">
                                                <aura:iteration items="{!v.ProcessCycles}" var="pcs" indexVar="count">
                                                    <aura:If isTrue="{!and(pcs.prcscycl.Id != null,pcs.prcscycl.Id != '')}">
                                                        <aura:if isTrue="{!(v.Action != 'clone')}">
                                                            <tr draggable="true" ondragstart="{!c.handleDrag}" ondrop="{!c.handleProcessDrop}" ondragover="{!c.allowDrop}" data-index="{!count}" data-record-id="{!pcs.prcscycl.Id}">
                                                                <td>
                                                                    <lightning:buttonIcon value="{!count}" title="{!pcs.expanded}" onclick="{!c.toggle}" iconName="{!pcs.expanded?'utility:chevrondown':'utility:chevronright'}" class="white-bg"/>&nbsp;
                                                                    <a class="svg Milestones-class22 customcactionedit" data-record-id="{!pcs.prcscycl.Id}" data-index="{!count}" onclick="{!c.editProcesscycl}">
                                                                        <lightning:icon iconName="action:edit" size="xx-small" alternativeText="Edit!" title="Edit" />
                                                                    </a>&nbsp;
                                                                    <a class="svg Milestones-class22 customcactionedit" data-record-id="{!pcs.prcscycl.Id}" data-index="{!count}" onclick="{!c.deleteProcesscycl}">
                                                                        <lightning:icon iconName="action:delete" size="xx-small" alternativeText="delete!" title="delete" />
                                                                    </a>&nbsp;
                                                                    
                                                                </td>
                                                                <td><a  data-record-id="{!pcs.prcscycl.Id}" data-index="{!count}" href="{!'/'+ pcs.prcscycl.Id}" target="_blank">{!pcs.prcscycl.Name}</a></td>
                                                                
                                                                <td> 
                                                                    <a href="{!'/'+ pcs.prcscycl.ERP7__Work_Center__c}" target="_blank">
                                                                        <div class="slds-truncate"><lightning:formattedText value="{!pcs.prcscycl.ERP7__Work_Center__r.Name}"/></div>
                                                                    </a>
                                                                </td>
                                                                <td><div class="slds-truncate ">{!pcs.prcscycl.ERP7__Sort__c}</div>
                                                                </td>
                                                                <td>&nbsp;
                                                                </td>
                                                            </tr>
                                                        </aura:if>
                                                        <aura:if isTrue="{!(v.Action == 'clone')}">
                                                            <tr>
                                                                <td>
                                                                    <lightning:input type="checkbox" checked="{!pcs.prcscycl.selected}" title="{!pcs.prcscycl.Id}" onchange="{!c.setPcsSelected}"></lightning:input>
                                                                </td>
                                                                <td><a  data-record-id="{!pcs.prcscycl.Id}" data-index="{!count}" href="{!'/'+ pcs.prcscycl.Id}" target="_blank">{!pcs.prcscycl.Name}</a></td>
                                                                
                                                                <td> 
                                                                    <a href="{!'/'+ pcs.prcscycl.ERP7__Work_Center__c}" target="_blank">
                                                                        <div class="slds-truncate"><lightning:formattedText value="{!pcs.prcscycl.ERP7__Work_Center__r.Name}"/></div>
                                                                    </a>
                                                                </td>
                                                                <td><div class="slds-truncate ">{!pcs.prcscycl.ERP7__Sort__c}</div>
                                                                </td>
                                                                <td>&nbsp;
                                                                </td>
                                                            </tr>
                                                            
                                                        </aura:if>
                                                        <aura:if isTrue="{!pcs.expanded}">
                                                            <!--<aura:if isTrue="{!pcs.isselected}"> -->
                                                            <tr >
                                                                <td colspan="5">
                                                                    <div class="card card-extra-c1-maq mb-1">
                                                                        <div class="d-flex justify-content-between">
                                                                            <h6 class="card-title">{!$Label.c.Operations_Tasks_recorded_at_the_workcenter}</h6>
                                                                            <div class="slds-grid">
                                                                                
                                                                                
                                                                            </div>
                                                                        </div>
                                                                        <table class="slds-table slds-table_bordered slds-table_fixed-layout slds-no-row-hover">
                                                                            <thead class="">
                                                                                <tr>
                                                                                    <th width="10%" class="text-left">
                                                                                        <aura:if isTrue="{!(v.Action != 'clone')}">
                                                                                            <a onclick="{!c.openModal}" data-record-id="{!pcs.prcscycl.Id}" class="Milestones-class18" data-toggle="modal" title="Add" data-aura-rendered-by="907:0" href="javascript:void(0);">
                                                                                                <i class="fa fa-plus Milestones-class19" aria-hidden="true" data-aura-rendered-by="908:0"></i>
                                                                                                &nbsp;{!$Label.c.New_AddTimeCardEntry}
                                                                                            </a>
                                                                                        </aura:if>
                                                                                    </th>
                                                                                    <th width="40%" class="text-left">
                                                                                        <div class="slds-truncate">
                                                                                            {!$Label.c.Operation}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="text-left">
                                                                                        <div class="slds-truncate">
                                                                                            {!$Label.c.Auto_Clock_In}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="text-left">
                                                                                        <div class="slds-truncate">
                                                                                            {!$Label.c.Timer}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="text-left">
                                                                                        <div class="slds-truncate">
                                                                                            {!$Label.c.Signature_Required}
                                                                                        </div>
                                                                                    </th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <aura:iteration items="{!pcs.allRelateddetails.oprlst}" indexVar="oppcount" var="opr">
                                                                                    <aura:if isTrue="{!(v.Action != 'clone')}">
                                                                                        <tr draggable="true" ondragstart="{!c.handleDrag}" ondrop="{!c.handleOpDrop}" ondragover="{!c.allowDrop}" data-index="{!oppcount}" data-record-id="{!pcs.prcscycl.Id}">
                                                                                            <td>
                                                                                                <a class="svg Milestones-class22 customcactionedit" onclick="{!c.editoperation}" data-record-id="{!opr.Id}" data-index="{!pcs.prcscycl.Id}">
                                                                                                    <lightning:icon iconName="action:edit" size="xx-small" alternativeText="Edit!" title="Edit" />
                                                                                                </a>&nbsp;
                                                                                                <a class="svg Milestones-class22 customcactionedit"  onclick="{!c.deleteoperation}" data-record-id="{!opr.Id}" data-index="{!oppcount}">
                                                                                                    <lightning:icon iconName="action:delete" size="xx-small" alternativeText="delete!" title="delete" />
                                                                                                </a>
                                                                                            </td>
                                                                                            <td>
                                                                                                <a href="{!'/'+ opr.Id}" target="_blank">
                                                                                                    <div class="slds-truncate"><lightning:formattedText value="{!opr.Name}"/></div>
                                                                                                </a>
                                                                                            </td>
                                                                                            <td>
                                                                                                <lightning:input type="checkbox" checked="{!opr.ERP7__Auto_Clock_In__c}" disabled="true" />
                                                                                            </td>
                                                                                            <td> 
                                                                                                <lightning:input type="checkbox" checked="{!opr.ERP7__Timer__c}" disabled="true"/>
                                                                                            </td>
                                                                                            <td> 
