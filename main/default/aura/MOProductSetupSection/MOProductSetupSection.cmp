            <!-- Edit WIP Modal-->
            
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="EditWIPModalshow" role="dialog">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closeEditWIPModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.EditLabel}&nbsp;{!$Label.c.Work_in_Progress_WIPs}</h4>
                        
                    </header>                    
                    
                    
                    <div class="slds-modal__content" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <div class="slds-modal__content slds-p-around_small" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                            <lightning:input type="text" aura:id="name"  value="{!v.EditWIP.Name}" label="{!$Label.c.Name_ManageLeave}" required="true"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            
                                            <c:CustomInputProduct objectAPIName="Product2" aura:id="wc" label="{!$Label.c.CreatePOProduct}" IconName="standard:flow" selectedRecordId="{!v.EditWIP.ERP7__Process_Output_Product__c}" required="true" qry='And IsActive = true and ERP7__Track_Inventory__c = true'/>
                                        </div>
                                        
                                        
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:input type="Number" aura:id="qty"  value="{!v.EditWIP.ERP7__Quantity_Unit__c}" label="{!$Label.c.AddSubscription_Quantity}" required="true" step="0.0001"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:select aura:id="UOM"  value="{!v.EditWIP.ERP7__Quantity_Unit_Of_Measure__c}" label="{!$Label.c.UOM}" required="true" >
                                                <aura:iteration items="{!v.WIPUom}" var="uom">
                                                    <option text="{!uom.label}" value="{!uom.value}" selected="{!v.EditWIP.ERP7__Quantity_Unit_Of_Measure__c == uom.value}"></option>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeEditWIPModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.SaveEditWIP}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                    
                </div>
            </div>
            
            <div class="slds-backdrop" aura:id="NewWIPModalBackdrop"></div>
            <!-- Create design/Drawing Doc -->
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="NewattchModalshow" role="dialog">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closemediaModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.add_for_mo_product}&nbsp;{!$Label.c.Attachment}</h4>
                        
                    </header>
                    
                    
                    <div class="slds-modal__content " id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                            <lightning:input type="text" aura:id="name"  value="{!v.Newmedia.Name}" label="{!$Label.c.Name_ManageLeave}" required="true"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 ">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Operation__c" aura:id="wc" label="{!$Label.c.Operation}" IconName="standard:flow" selectedRecordId="{!v.Newmedia.ERP7__Operation__c}" required="true" qry="{!v.oppQry}"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                            <lightning:input aura:id="fileId" type="file" files="{!v.FileList}" onchange="{!c.handleFilesChange}" multiple="true" label="{!$Label.c.Upload_Attachment}" value="{!v.filleList}" />
                                            <aura:if isTrue="{!v.showDelete}">
                                                <a onclick="{!c.removeAttachment}" title="{!$Label.c.NewCase_Remove_Attachment}" class="createbill-class6">
                                                    <i class="fa fa-minus-circle" aria-hidden="true"></i>
                                                </a>                        
                                            </aura:if>
                                            <aura:iteration items="{!v.filleList}" var="file" indexVar='count'>
                                                <div class="slds-text-body_small slds-text-color_error">{!file}&nbsp;&nbsp;&nbsp;
                                                </div>
                                            </aura:iteration>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                            
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closemediaModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.SaveNewMedia}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                </div>
                
            </div>
            
            <div class="slds-backdrop" aura:id="NewattchModalBackdrop"></div>
            <!-- New chceklists-->
            <div class="slds-modal BuildSchedule_M-newClass115" id="myModal9" aura:id="newChecklistModal" role="dialog">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{!c.closechecklistModal }"
                                              alternativeText="{!$Label.c.Close_Timesheets}"
                                              variant="bare-inverse"
                                              class="slds-modal__close" size="large"/>
                        
                        <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Transfer_Order_Create}&nbsp;{!$Label.c.CheckList}</h4>
                        
                    </header>
                    <div class="slds-modal__content" id="modal-content-id-1">
                        <fieldset class="slds-form--compound">
                            <div class="slds-form-element__group">
                                
                                <div class="slds-modal__content slds-p-around_small" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap">
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12 slds-p-right_small">
                                            <lightning:input type="text" aura:id="name"  value="{!v.NewChklst.Name}" label="{!$Label.c.Name_ManageLeave}" required="true"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:input type="text" aura:id="action"  value="{!v.NewChklst.ERP7__Action_Detail__c}" label="{!$Label.c.Instructions}" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Operation__c" aura:id="newop" label="{!$Label.c.Operation}" IconName="standard:flow" selectedRecordId="{!v.NewChklst.ERP7__Operation__c}"  qry="{!v.oppQry}" required="true"/>                                        
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small slds-m-top_large">
                                            <lightning:input type="checkbox" aura:id="action"  checked="{!v.NewChklst.ERP7__Is_Mandatory__c}" label="Required" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:select aura:id="check"  value="{!v.NewChklst.ERP7__Comply__c}" label="{!$Label.c.Checklist_Operation}"  onchange="{!c.onControllerFieldChange}">
                                                <aura:iteration items="{!v.listControllingValues}" var="ck">
                                                    <option text="{!ck}"></option>
                                                </aura:iteration>
                                            </lightning:select>                                    </div>
                                        <div class="slds-col slds-size_1-of-1 slds-large-size_6-of-12  slds-p-right_small">
                                            <lightning:select aura:id="result"  value="{!v.NewChklst.ERP7__Result__c}" label="{!$Label.c.checklist_Value}"  disabled="{!v.bDisabledDependentFld}">
                                                <aura:iteration items="{!v.listDependingValues}" var="rs">
                                                    <option text="{!rs}"></option>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </fieldset>
                        
                        <div class="modal-footer slds-text-align--center BuildSchedule_M-newClass117">
                             <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closechecklistModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            <button class="slds-button slds-button--brand" onclick="{!c.Newchecklist}">{!$Label.c.Save_UserAvailabilities}</button>
                        </div>
                    </div>
                    
                </div>
            </div>
            
            
            <div class="slds-backdrop" aura:id="newChecklistModalBackdrop"></div>
            
