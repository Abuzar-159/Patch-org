<aura:component controller="ProductList" access="Global" implements="flexipage:availableForAllPageTypes,force:appHostable,forceCommunity:availableForAllPageTypes">
    <aura:attribute name="accID" type="String" default="0011o00001Sq3Xm"/>
    <aura:attribute name="profileID" type="String" default="a381o000000gA1X"/>
    <aura:attribute name="productWrapperList" type="Object"/>
    <aura:attribute name="cartItems" type="List"/>
    <aura:attribute name="totalPrice" type="Decimal" default="0.0"/>
    <aura:attribute name="cartbtn" type="boolean" default="false"/>
    <aura:attribute name="calculateQty" type="Integer" default="10"/>
    <aura:attribute name="cartSaveRecord" type="Object" default=""/>
    <aura:handler name="init" value="{!this}" action="{!c.loadData}"/>
    <aura:handler name="family" event="c:filterPickList" action="{!c.handleFamilyEvent}"/>
    <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js, /resource/ProductList/script/jquery-ui.js, /resource/ERP7__bootStrap/js/bootstrap.min.js" />
    <ltng:require styles="/resource/ProductList/css/bootstrap.css, /resource/ProductList/css/font-awesome.css, /resource/ProductList/css/flaticon.css, /resource/ProductList/css/style.css, /resource/ProductList/css/color.css, /resource/ProductList/css/responsive.css" />
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductList.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <html lang="en">

    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Aqxolt ERP Product</title>

        
    </head>
	
    <body>
        {!v.body}
        <div aura:id="sldshide">
            <!--// Main Wrapper \\-->
            <div class="erpmark7">
                <div class="erpmark7-main-wrapper">

                    <!--// Main Content \\-->
                    <div class="erpmark7-main-content">

                        <!--// Main Section \\-->
                        <div class="erpmark7-main-section">
                            <div class="container">
                                <div class="row">

                                    <!--// Sidebar \\-->
                                    <aside class="col-md-3">

                                        <!--// Widget Search \\-->
                                        <div class="widget widget_search">
                                            <form>
                                                <input value="Search" onblur="if(this.value == '') { this.value ='Search'; }" onfocus="if(this.value =='Search') { this.value = ''; }" tabindex="0" type="text" />
                                                <label><input type="submit" value=""/></label>
                                            </form>
                                        </div>
                                        <c:Categories />
                                        <!--// Widget Cetagories \\-->





                                    </aside>
                                    <!--// Sidebar \\-->

                                    <div class="col-md-9">
                                        <div class="erpmark7-product-filter">
                                            <span>Showing the Products </span>
                                            <!-- Nav tabs -->
                                            <ul class="nav-tabs" role="tablist">
                                                <li role="presentation"><a href="#home" aria-controls="home" role="tab" data-toggle="tab"><i class="icon erpmark7-list-interface-symbol"></i> <span>List</span></a></li>
                                                <li role="presentation" class="active"><a href="#profile" aria-controls="profile" role="tab" data-toggle="tab"><i class="icon erpmark7-3x3-grid"></i> <span>Grid</span></a></li>
                                            </ul>
                                            <!-- Tab panes -->
                                            <form>
                                                
                                                <aura:if isTrue="{!v.cartItems.length>0}">
                                                <lightning:button variant="brand" label="Add To Cart" onclick="{!c.productCart}" class="erpmark7-simple-btn erpmark7-bgcolor"><i class="fa fa-shopping-cart"></i>&nbsp;&nbsp;{!v.cartItems.length} items&nbsp;&nbsp;&nbsp;&nbsp;  <lightning:formattedNumber style="currency" value="{!v.totalPrice}"/></lightning:button>
                                                <aura:set attribute="else">
                                                   <lightning:button variant="brand" label="Add To Cart" onclick="{!c.productCart}" class="erpmark7-simple-btn erpmark7-bgcolor" disabled="true"><i class="fa fa-shopping-cart"></i>&nbsp;&nbsp;{!v.cartItems.length} items&nbsp;&nbsp;&nbsp;&nbsp;  <lightning:formattedNumber style="currency" value="{!v.totalPrice}"/></lightning:button> 
                                                </aura:set>
                                                </aura:if>
                                            </form>
                                        </div>
                                        <div class="tab-content">
                                            <div role="tabpanel" class="tab-pane" id="home">

                                                <aura:iteration items="{!v.productWrapperList.pbeList}" var="pro">
                                                    <div class="erpmark7-product erpmark7-product-list">
                                                        <ul class="row">
                                                            <li class="col-md-12">
                                                                <figure>
                                                                    <aura:if isTrue="{!pro.stock>0}">
                                                                        <span>{!pro.stock}</span>
                                                                        <aura:set attribute="else">
                                                                            <span class="outofstock"> Out of Stock</span>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                    <a><img src="{!pro.pbe.Product2.ERP7__Picture__c}" alt=""/></a>

                                                                </figure>
                                                                <div class="erpmark7-product-list-text">
                                                                    <div class="row">
                                                                        <div class="col-md-6">
                                                                            <h2><a data-record="{!pro.pbe.Product2Id}">{!pro.pbe.Product2.Name}</a></h2>
                                                                            <div><span><lightning:formattedNumber style="currency" value="{!pro.pbe.UnitPrice}"/> </span></div>
                                                                            <p>{!pro.pbe.Product2.Description} </p>
                                                                            
                                                                            <p>
                                                                                <lightning:input type="number" formatter="currency" step="0.01" value="{!pro.pbe.Product2.ERP7__MOQ__c}" aura:id="moQty" /> </p><br/>
                                                                            <!--<aura:iteration items="{!pro.versionList}" var="ver">
                                                                                <div class="row">
                                                                                    <div class="col-md-12">
                                                                                        <table class="table table-condensed"> 
                                                                                            <tr bgcolor="f7f8f9">
                                                                                                <td width="15%"><br/>{!ver.Name}</td>
                                                                                                <td width="10%">
                                                                                                   <lightning:input type="text" variant="label-hidden" value="{!ver.ERP7__Quantity__c}" />
                                                                                                </td>
                                                                                            </tr>
                                                                                        </table>
                                                                                    </div>
                                                                                </div>
                                                                            </aura:iteration>-->
                                                                        </div>
                                                                        
                                                                        <div class="col-md-3">
                                                                            <aura:if isTrue="{!pro.stock>0}">
                                                                            <lightning:button variant="brand" label="Add To Cart" onclick="{!c.calculateProducts}" name="{!pro.pbe.Product2Id}" class="erpmark7-simple-btn erpmark7-bgcolor"></lightning:button>
                                                                                <aura:set attribute="else">
                                                                                <lightning:button variant="brand" label="Add To Cart" onclick="{!c.calculateProducts}" name="{!pro.pbe.Product2Id}" class="erpmark7-simple-btn erpmark7-bgcolor" disabled="true"></lightning:button>
                                                                            	</aura:set>
                                                                            </aura:if>

                                                                        </div>
                                                                       
                                                                    </div>

                                                                </div>
                                                            </li>

                                                        </ul>
                                                    </div>
                                                </aura:iteration>
											</div>
                                            <div role="tabpanel" class="tab-pane active" id="profile">
                                                <div class="erpmark7-product erpmark7-product-grid">
                                                    <ul class="row">
                                                        <aura:iteration items="{!v.productWrapperList.pbeList}" var="pro">
                                                            	   
                                                            <li class="col-md-3">
                                                                <figure>
                                                                    <span class="ProductList-newClass1">{!pro.stock}</span>
																	<a><img src="{!pro.pbe.Product2.ERP7__Picture__c}" alt=""/></a>

                                                                </figure>
                                                                <div class="erpmark7-product-grid-text">
                                                                    <h2>
                                                                        <a>
                                                                            <lightning:formattedText value="{!pro.pbe.Product2.Name}" />
                                                                        </a>
                                                                    </h2>
                                                                    <span><lightning:formattedNumber style="currency" value="{!pro.pbe.UnitPrice}"/></span>
                                                                    <div class="ProductList-newClass2"><lightning:button onclick="{!c.calculateIndividualProducts}" name="{!pro.pbe.Product2Id}"><i class="fa fa-shopping-cart"></i></lightning:button></div>
                                                                </div>
                                                            </li>
                                                        </aura:iteration>
                                                    </ul>
                                                </div>     
                                                
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        <!--// Main Section \\-->

                    </div>
                    <!--// Main Content \\-->

                    <!--// Footer \\-->
                    <footer id="erpmark7-footer" class="erpmark7-footer-one">
					</footer>
                    <!--// Footer \\-->

                    <div class="clearfix"></div>

                </div>
            </div>
            <!--// Main Wrapper \\-->
        </div>
        
    </body>

    </html>
</aura:component>