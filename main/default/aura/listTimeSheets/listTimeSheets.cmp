                                                <a href="{!'/'+item.Id}" target="__blank">{!item.Name}</a>
                                            </td>
                                            <td data-label="">
                                                {!item.ERP7__Posted__c}
                                            </td>
                                            <td data-label="">
                                                <lightning:formattedDateTime value="{!item.CreatedDate}" year="numeric" month="numeric" day="numeric" hour="2-digit" minute="2-digit" hour12="True" timeZone="{!$Locale.timezone}"/>
