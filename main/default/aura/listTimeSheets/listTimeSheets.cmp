                                <thead>
                                    <tr class="slds-text-title--caps">
                                        <th scope="col" >
                                            <div class="slds-truncate" title="">Invoice Name</div>
                                        </th>
                                        <th scope="col" >
                                            <div class="slds-truncate" title="">Posted</div>
                                        </th>
                                        <th scope="col" >
