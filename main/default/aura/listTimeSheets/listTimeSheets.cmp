                                        <h5 class="mb-1 text-gradient gradient-red">
                                            <a href="javascript:;">Invoices without Transaction</a>
                                        </h5>
                                    </div>
                                    <div class="col-3 text-end">
                                        <div class="dropstart">
                                            <a href="javascript:;" class="text-secondary" id="dropdownMarketingCard" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="fas fa-ellipsis-v" aria-hidden="true"></i>
                                            </a>
                                            <h5 class="mb-1 text-gradient gradient-red">{!v.TransactionWrapper.noTransInvoices.length}</h5>
                                        </div>
                                    </div>
                                </div>
                            	<!--<div class="slds-page-header divClass1">Invoices without Transaction <div class="floating">{!v.TransactionWrapper.noTransInvoices.length}</div></div>-->
