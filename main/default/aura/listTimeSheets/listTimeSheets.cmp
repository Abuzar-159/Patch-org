<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction"  controller="TransactionManagement" access="global"><!-- controller="TransactionMeasurement" -->
    
    <ltng:require styles="/resource/ERP7__axoltmain/Assets/css/axolt-dashboard.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="StartDate" type="Date"/>
    <aura:attribute name="EndDate" type="Date"/>
    <aura:attribute name="invList" type="Invoice__c[]"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="billList" type="Bill__c[]"/>
    <aura:attribute name="payList" type="Payment__c[]"/>
    <aura:attribute name="expList" type="Expense__c[]"/>
    <aura:attribute name="cnList" type="Credit_Note__c[]"/>
    <aura:attribute name="Organisation" type="Map" default="{}"/>
    <aura:attribute name="selectedTab" type="String" default="Invoices"/>
    <aura:handler name="change" value="{!v.selectedTab}" action="{!c.switchTab}"/>
    <aura:attribute name="creditnoteList" type="Credit_Note__c[]"/>
    <aura:attribute name="TransactionWrapper" type="object" default="{'sObjectType' : 'TransactionWrapper'}"/>
    <div aura:id="body">
        <div class="slds-container ">
            <div class="slds-page-header bg-theme">
                
                <div class="card pb-4 mb-2">
                    <div class="card-header pb-0 p-3">
                        <div class="d-flex align-items-center">
                            <h6 class="mb-0">User Details</h6>
                            
                        </div>
                        <div class="slds-grid slds-wrap">
                        
                        <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12 slds-p-right_small">
                            <c:CustomInputLookUp objectAPIName="Account" label="Organisation" required="true" selectedRecord="{!v.Organisation}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="Search Organisation" qry="AND ERP7__Account_Type__C = 'Organisation'" />
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="date" name="input1" label="Start Date" value="{!v.StartDate}" required="true"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-large-size_3-of-12 slds-p-right_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="date" name="input1" label="End Date" value="{!v.EndDate}" required="true"/>
                            </div>
                        </div>
                        
                        
                        <div class="prMes1 slds-col slds-size_1-of-1 slds-large-size_2-of-12 slds-p-top_medium">
                            <lightning:button variant="brand" label="Find" onclick="{!c.switchTab}"/>
                        </div>
                        
                    </div>
                    </div>
                
              </div>
                
                
                
                <div class="card">
                    <div class="card-header d-flex pb-0 p-3">
                        <h6 class="my-auto">Transactions</h6>
                        <div class="nav-wrapper position-relative ms-auto w-50">
                          <!-- <ul class="nav nav-pills nav-fill p-1" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1 active" data-bs-toggle="tab" href="#cam1" role="tab" aria-controls="cam1" aria-selected="true">
                                        Invoices
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#cam2" role="tab" aria-controls="cam2" aria-selected="false">
                                        Bills
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#cam3" role="tab" aria-controls="cam3" aria-selected="false">
                                        Payments
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#cam3" role="tab" aria-controls="cam3" aria-selected="false">
                                        Credit Notes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#cam3" role="tab" aria-controls="cam3" aria-selected="false">
                                        Debit Notes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#cam3" role="tab" aria-controls="cam3" aria-selected="false">
                                        Expenses
                                    </a>
                                </li>
                                <div class="moving-tab position-absolute nav-link" >
                                    <a class="nav-link mb-0 px-0 py-1 active" data-bs-toggle="tab" href="#cam1" role="tab" aria-controls="cam1" aria-selected="true">-</a>
                                </div>
                            </ul> -->
                            <ul class="nav nav-pills nav-fill p-1 " role="tablist">
                            <c:Tab label="Invoices" name="Invoices" selectedTab="{!v.selectedTab}" iconclass="fa fa-list-ol"  /> 
                            <c:Tab label="Bills"  name="Bills" selectedTab="{!v.selectedTab}" iconclass="fa fa-file-text"/>
                            <c:Tab label="Payments" name="Payments" selectedTab="{!v.selectedTab}" iconclass="fa fa-credit-card-alt"/> 
                            <c:Tab label="Credit Notes" name="Credit_notes" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                            <c:Tab label="Debit Notes" name="Credit_Debit_notes" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                            <c:Tab label="Expenses" name="Expenses" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                        </ul>
                        </div>
                        
                        </div>
                                         
                    <div class="slds-tabs--default theme-bg ">
                        
                        <aura:if isTrue="{!and(equals(v.selectedTab,'Invoices'),true)}">
                            <div class="cardmaq red-left">
