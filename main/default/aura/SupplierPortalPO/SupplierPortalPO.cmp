<aura:component controller="SupplierPortalPO" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global">
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/SupplierPortalComm/CSS/SupplierportalComm.css'}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require scripts="{!join(',',
                           $Resource.ProductListComm + '/ProductListComm/script/common_scripts.min.js',                           
                           $Resource.ProductListComm + '/ProductListComm/script/main.js',
                           $Resource.ProductListComm + '/ProductListComm/script/carousel_with_thumbs.js'
                           )}"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierPortalPO.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="POList" type="PO__c[]"/>
    <aura:attribute name="POListDup" type="PO__c[]"/>
    <aura:attribute name="SelectedPOS" type="List"/>
    <aura:attribute name="PNS" type="Object"/>
    <aura:attribute Name="searchPOStr" type="String"/>
    <aura:attribute name="purchaseorderTab" type="Boolean" default="true"/>
    <aura:attribute name="OrderBy" type="String" default="Name"/> 
    <aura:attribute name="Order" type="String" default="DESC"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUserRecord}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUser}"/>
    <aura:handler name="SortRecord" event="c:SortRecord" action="{!c.SortRecodEventHandler}"/>
    <aura:attribute name="NoSlotsMessage" type="String"/>
    <aura:attribute name="selectedTab" type="String" default="Vendor"/>
    <aura:attribute name="SearchString" type="String" default=""/>
    <aura:attribute name="show" type="Integer" default="10"/>
    <aura:attribute name="startCount" type="Integer" default="0"/>
    <aura:attribute name="endCount" type="Integer" default="0"/>
    <aura:attribute name="Offset" type="Integer" default="0"/>
    <aura:attribute name="recSize" type="Integer" default="0"/>
    <aura:attribute name="RecordId" type="String"></aura:attribute>
    <aura:attribute name="PageNum" type="Integer" default="0"/>
    <aura:attribute name="revert" type="Boolean" default="true"/>
    <aura:method name="doInit" action="{!c.doInit}"/>
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:handler event="c:SupplierPortalCommEvent" action="{!c.doInit}"/>
    <aura:attribute name="columns" type="Integer" default="3"/>
    <aura:attribute name = "filterStartDate" type = "Date"/>
    <aura:attribute name = "filterEndDate" type = "Date"/>
    <aura:attribute name = "filterProject" type = "String"/>
    <aura:attribute name = "filterTeam" type = "String"/>
    <aura:attribute name="FilterShow" type="Boolean" default="false"/>
    <aura:handler name = "change" value = "{!v.filterStartDate}" action = "{!c.loadFilterDetails}"/>
    <aura:handler name = "change" value = "{!v.filterEndDate}" action = "{!c.loadFilterDetails}"/>
    <aura:handler name = "change" value = "{!v.filterProject}" action = "{!c.loadFilterDetails}"/>
    <aura:handler name = "change" value = "{!v.filterTeam}" action = "{!c.loadFilterDetails}"/>
     <aura:attribute name="fields" type="Map"/>
     <aura:handler event="c:ProductListCommEvent" action="{!c.eventHandle1}"/>
    <aura:registerEvent name="SupplierPortalCommEvent" type="c:SupplierPortalCommEvent"/>
    <aura:handler event="force:navigateToSObject" action="{!c.navigate}"/> 
    <aura:attribute name="CheckOffset" type="Boolean" default="false"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="showData" type="Boolean" default="true"/>
    <aura:attribute name="defaultValues" type="Object" />
    
    <aura:attribute name="sortVar" type="Boolean" default="true" />
    
    <aura:if isTrue="{!v.showData}">
    <div aura:id="sldshide"> 
        <div class="maqsood erp_Mark7 erp_mark7 SupplierPPo-class1" aura:Id="body" >
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="spinner" class="slds-hide"/>
            
            <div>
                <div class="container-fluid SupplierPPo-class2" >
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPo-class3" onclick="{!c.getWO}" href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-files SupplierPPo-class4" ></i>
                                    </div> 
                                    <div class="slds-col col-9 pt-3 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Work Orders</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPo-class5" onclick="{!c.getBills}" href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-book SupplierPPo-class6"></i>
                                    </div> 
                                    <div class="slds-col col-9 pt-3 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Bills</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPo-class7" onclick="{!c.getPayments}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-wallet SupplierPPo-class8" ></i>
                                    </div> 
                                    <div class="slds-col col-9 pt-3 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a" >Payments Received</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPo-class9" onclick="{!c.getRFPs}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-agenda SupplierPPo-class10"></i>
                                        
                                    </div> 
                                    <div class="slds-col  pt-2 pr-0 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">RFP ( Request for Proposal)</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        
                    </div>
                    
                    <div class="card shadow-custom SupplierPPo-class11">
                        <div class="card-body">  
                            <div class="card-body pb-0  pl-2 pt-2">
                                <div class="d-flex justify-content-between pb-2">
                                    <div class="breadcrumbs">
                                        <h6 class="card-title mb-1">
                                            <a class="" onclick="{!c.home}" href="">
                                                Home&nbsp;
                                            </a>
                                            >&nbsp;Purchase Orders
                                        </h6>
                                    </div>
                                    
                                </div>
                                
                                <div class="container-fluid pl-0">
                                    <div class="col-md-3 pl-0">
                                        <c:SearchRecord searchString="{!v.SearchString}" Placeholder="Purchase Order.." aura:id="Purchase_Order_Id"/>
                                    </div>
                                </div>
                                
                            </div>
                            
                            <div class="table-responsive SupplierPPo-class15" tabindex="1" >
                                <table class="table">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                           <th scope="col">
                                                <div class="slds-truncate2" title="purchaseorders"> NAME
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="Name" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                      
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}"  title="Ascending Order" class="arrowColor">      
                                                       <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            
                                            <th scope="col">
                                                <div class="slds-truncate2" title="expected date"> Date
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Order_Date__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                          
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            
                                            <th scope="col">
                                                <div class="slds-truncate2" title="QTY">QTY 
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Total_Quantity__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                         
                                                    </span> 
                                                 <!--   <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                         
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Status">Stage 
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Stage__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                      
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Paid Amount">Paid Amount 
                                                    
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Amount_Paid__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Total Due">Total Due 
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Total_Due__c" title="Descending Order" class="arrowColor">
                                                       <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                      
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                              
                                                    </span>-->
                                                </div>
                                            </th>
                                            
                                            <th class="slds-cell-shrink" scope="col"></th>
                                        </tr>
                                    </thead>
                                    <aura:if isTrue="{!not(greaterthan(v.POList.length, 0))}">
                                        <tr>
                                            <td colspan="8">
                                                <div class="no projects">
                                                    <div class="slds-notify_container slds-is-relative">
                                                        <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                            <div>
                                                                <span class="slds-assistive-text">warning</span>
                                                                <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No PO">
                                                                    <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                </span>
                                                            </div>
                                                            <div class="slds-notify__content">
                                                                <h2 class="slds-text-heading_small SupplierPPo-class16">Sorry, No Records Available.</h2>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        <aura:set attribute="else">
                                    <aura:iteration items="{!v.POList}" var="po">
                                        
                                        <tr class="slds-hint-parent">
                                            <!--<td class="slds-cell-shrink" data-label="Select Row">
                                            <label class="slds-checkbox">
                                                <input type="checkbox" name="options" value="on" />
                                                <span class="slds-checkbox_faux"></span>
                                                <span class="slds-assistive-text">Select Row</span>
                                            </label>
                                        </td>-->
                                            <!--<td class="slds-cell-shrink" data-label="Select Row">
                                                <lightning:input type="checkbox" aura:id="cbox" name="{!po.PO.Id}" checked="{!po.selected}" />
                                            </td>-->
                                            <th scope="row" data-label="PO Name">
                                                <div class="slds-truncate2" title="{!po.Name}"><a href="javascript:void(0);"   data-record-Id="{!po.Id}"  data-record="ERP7__PO__c" onclick="{!c.getRecord}" target="_blank">{!po.Name}</a></div>
                                            </th>
                                            
                                            <td data-label="Due Date">
                                               <!-- <div class="slds-truncate2" title="{!po.ERP7__Expected_Date__c}"><lightning:formattedText value="{!po.ERP7__Expected_Date__c}"/></div>-->
                                                <div class="slds-truncate2" title="{!po.ERP7__Order_Date__c}"><lightning:formattedText value="{!po.ERP7__Order_Date__c}"/></div>
                                            </td>
                                            
                                            <td data-label="Phone">
                                                <div class="slds-truncate2" title="{!po.ERP7__Total_Quantity__c}"><lightning:formattedNumber style="decimal" value="{!po.ERP7__Total_Quantity__c}"/></div>
                                            </td>
                                            <td data-label="PaymentTerms">
                                                <div class="slds-truncate2" title="{!po.ERP7__Status__c}">
                                                    <!--
                                                    <aura:if isTrue="{!and(po.ERP7__Inbound_Total_Quantity__c==po.ERP7__Inbound_Received_Quantity__c,po.ERP7__Inbound_Total_Quantity__c>0)}">
                                                        <div >Received
                                                        </div>
                                                    </aura:if>
                                                    <aura:if isTrue="{!and(po.ERP7__Inbound_Received_Quantity__c>0,po.ERP7__Inbound_Received_Quantity__c!=po.ERP7__Inbound_Total_Quantity__c)}">
                                                        <div>Partially Received 
                                                        </div>
                                                    </aura:if>
                                                    <aura:if isTrue="{!(po.ERP7__Inbound_Received_Quantity__c==0)}">
                                                        <div >Not Yet Received
                                                        </div>
                                                    </aura:if>
                                                    -->
                                                    {!po.ERP7__Stage__c}
                                                    <!--{#po.ERP7__Status__c}--></div>
                                            </td>
                                            <td data-label="Paid Amount">
                                                <div class="slds-truncate2" title="{!po.ERP7__Amount_Paid__c}"><lightning:formattedNumber style="currency" value="{!po.ERP7__Amount_Paid__c}"/></div>
                                            </td>
                                            <td data-label="Balance Due">
                                               <!-- <div class="slds-truncate2" title="{!po.ERP7__Total_Amount__c}"><lightning:formattedNumber style="currency" value="{#po.ERP7__Total_Amount__c}"/></div>-->
                                                <div class="slds-truncate2" title="{!po.ERP7__Total_Due__c}"><lightning:formattedNumber style="currency" value="{#po.ERP7__Total_Due__c}"/></div>
                                            </td>
                                            <!-- <td data-label="Request for Proposal">
                                            <div class="slds-truncate2" title="{!po.ERP7__Request__c}"><a href="{!'/'+po.Id}" target="_blank">{!po.ERP7__Request__c}</a></div>
                                        </td>-->
                                            <td class="slds-cell-shrink" data-label="Actions">
                                                <aura:if isTrue="{!po.ERP7__Total_Due__c > 0}">
                                                <lightning:buttonMenu alternativeText="Show menu" menuAlignment="right" iconSize="small" variant="border-filled" onselect="{! c.handlemenu }">
                                                    <lightning:menuItem value="{!po.Id}" label="Create Bill" />
                                                </lightning:buttonMenu>
                                                </aura:if>
                                            </td>
                                        </tr>
                                    </aura:iteration> 
                                        </aura:set>
                                    </aura:if>
                                </table>
                                <aura:if isTrue="{!(v.POList.length>0)}">
                                <aura:if isTrue="{!and(v.NoSlotsMessage!=undefined,v.NoSlotsMessage!='')}"><!--(v.NoSlotsMessage!=undefined, v.NoSlotsMessage!='')-->
                                    <div class="slds-notify_container slds-is-relative SupplierPPo-class31"  aura:id="criteriaMsgId">
                                        <div class="slds-notify slds-notify_toast slds-theme_warning SupplierPPo-class17" role="alert" >
                                            <span class="slds-assistive-text">warning</span>
                                            <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                            <div class="slds-notify__content SupplierPPo-class18">
                                                <h2 class="slds-text-heading_small SupplierPPo-class32" >
                                                    {!v.NoSlotsMessage}
                                                </h2>
                                            </div>
                                        </div>
                                    </div>     
                                </aura:if>
                                    </aura:if>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <aura:if isTrue="{!v.showMmainSpin}">
                <span class="SupplierPPo-class20">
                    <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
                </span>
            </aura:if> 
            
                          <!-- === Popover Filter == -->
       		<aura:renderIf isTrue="{!v.FilterShow}"> 
               
       			<section aria-labelledby="panel-heading-id" class="erp_mark7  slds-popover_panel  slds-popover_large slds-popover" role="dialog" id="mypopover"><!--slds-nubbin_top-->
                <button class="slds-button slds-button_icon slds-button_icon slds-button_icon-small slds-float_right slds-popover__close" title="Close dialog" onclick="{!c.FilterSet}">
                    	<lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />
                    
                 <span class="slds-assistive-text">Close dialog</span>
                </button>
               <div class="row epr_Mark7">
                <div class="slds-popover__body col-md-12" >
                	<aura:renderIf isTrue="{!(v.FilterShow)}"> 
               <div class="col-md-4 col-xs-4">
                  <div class="slds-col">
                     <label class="slds-form-element__label" for="input-unique-id">Plant </label>
                  </div>
                  <div class="slds-col">
                     <div class="slds-form-element">
                        <div class="slds-form-element__control">
                           <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" IconName="standard:flow" selectedRecordId="{!v.WCCP.WC.ERP7__Plant__c}" inputStyleclass="slds-input"/>
                        </div>
                     </div>
                  </div>
               </div>
               <div class="col-md-4 col-xs-4">
                  <div class="slds-col">
                     <label class="slds-form-element__label" for="input-unique-id">Start Date</label>
                  </div>
                  <div class="slds-col">
                     <div class="slds-form-element">
                        <div class="slds-form-element__control">
                           <lightning:input type="date" variant="label-hidden" class="display-lable" aura:id="st" value="{!v.PNS.StartDate}" onchange="{!c.loadAllDetails}"/>
                        </div>
                     </div>
                  </div>
               </div>
               <div class="col-md-4 col-xs-4">
                  <div class="slds-col">
                     <label class="slds-form-element__label" for="input-unique-id">End Date</label>
                  </div>
                  <div class="slds-col">
                     <div class="slds-form-element">
                        <div class="slds-form-element__control">
                           <lightning:input type="date" variant="label-hidden" class="display-lable" aura:id="st" value="{!v.PNS.EndDate}" onchange="{!c.loadAllDetails}"/>
                        </div>
                     </div>
                  </div>
               </div>
               <div class="col-md-4 col-xs-4">
                  <div class="slds-col">
                     <label class="slds-form-element__label" for="input-unique-id">Days</label>
                  </div>
                  <div class="slds-col">
                     <div class="slds-form-element">
                        <div class="slds-form-element__control">
                           <lightning:input type="text" variant="label-hidden" aura:id="str" value="{!v.PNS.Days}" oncommit="{!c.loadAllDetails}"/>
                        </div>
                     </div>
                  </div>
               </div>
               
               </aura:renderIf>
                
                </div>
                </div>
                </section>
                
       </aura:renderIf>
       <!-- === Filter Ends here == -->
            
        </div>
        
                              
        <aura:if isTrue="{!v.revert}">
            <div class="epr_Mark7">
                <div class="row SupplierPPo-class33" >
                    <aura:if isTrue="{!v.POList.length>0}">
                        <div class="col-md-2 SupplierPPo-class29">
                            <div class="slds-grid" >
                                <div class="slds-col SupplierPPo-class22">
                                    Show&nbsp;&nbsp;
                                </div>  
                                <div class="slds-col SupplierPPo-class34"> 
                                    <lightning:select class="slds-show_inline-block"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                        <option value="5">5</option>
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                    </lightning:select>
                                </div>
                            </div>
                        </div>
                    </aura:if>
                    <aura:if isTrue="{!v.POList.length>0}">
                        
                        <div class="col-md-3 SupplierPPo-class24">
                            Showing <span class="text-lightblue">{!v.startCount}-{!v.endCount}</span> of total <span class="text-lightblue"> {!v.recSize} </span> Records
                        </div>
                        
                    </aura:if> 
                    
                    <aura:if isTrue="{!v.POList.length>0}">
                        
                        <div class="col-md-5 SupplierPPo-class25">
                            <div class="pb-3">
                                <nav aria-label="Page navigation example" >
                                    <ul class="pagination SupplierPPo-class26" >
                                        <li class="SupplierPPo-class29">
                                            <a class="{!if(1 >= v.startCount,'SupplierPPo-class27','SupplierPPo-class28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                        </li>
                                        <li class="SupplierPPo-class29">
                                            <a class="{!if(1 >= v.startCount,'SupplierPPo-class27','SupplierPPo-class28')}"  onclick="{!c.Previous}"> Previous</a> <!-- -->
                                        </li>
                                       
                                        <li class="SupplierPPo-class29">
                                            <a class="{!if(v.endCount == v.recSize,'SupplierPPo-class27','SupplierPPo-class28')}" onclick="{!c.Next}">Next </a> <!--  -->
                                        </li>
                                        <li class="SupplierPPo-class29">
                                            <a class="{!if(v.endCount == v.recSize,'SupplierPPo-class27','')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </aura:if> 
                    <aura:if isTrue="{!v.POList.length>0}">
                        
                        <div class="col-md-2">
                            <div class="mb-1" >
                                <div class="slds-grid">
                                    <div class="slds-col SupplierPPo-class24" >
                                        Page 
                                    </div>
                                    <div class="slds-col">
                                        <lightning:input type="number" variant="label-hidden" aura:id="ik" value="{!v.PageNum}" oncommit="{!c.OfsetChange}" class="width100p"/> 
                                    </div>
                                    <div class="slds-col SupplierPPo-class24"><span class="text-lightblue"> of {!v.PNS.length}</span>
                                    </div>
                                </div>
                            </div>
                        </div> 
                    </aura:if>
                </div>
            </div></aura:if>
        <!--Pagination End-->
    </div>
    <aura:set attribute="else">
        <!--<lightning:recordForm
        recordId="{!v.RecordId}"
        objectApiName="ERP7__PO__c"
        layoutType="Full"
        columns="2"
        mode="view">

        </lightning:recordForm>-->
        <div class="col-md-8">
        <force:recordView recordId="{!v.RecordId}" />
        </div>
       <div class="slds-text-align--center slds-p-around--medium SupplierPPo-class35" >
                        
                        <input type="button" value="Cancel" class="slds-button slds-button_neutral SupplierPPo-class36" onclick="{!c.GoBack}"/>
                        <!--<lightning:button label="Cancel" variant="brand" class="slds-button slds-button_neutral_btn" onclick="{!c.cancelCreateInvoiceAndLineItem}"/>--> &nbsp;
                        <lightning:button label="Save" disabled="{!and(empty(v.SOId),v.INVLIList.length eq 0)}" variant="brand" class="slds-button slds-button_brand" onclick="{!c.CreateInvoiceAndLineItem}"/>
                    </div>
        </aura:set>
     </aura:if>
</aura:component>