<aura:component controller="SupplierPortalPO" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
       <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/SupplierPortalComm/CSS/overiding-standard.css'}"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierFieldSet.css"/>
    
    <aura:attribute name="PageLayoutName" type="String"/>
    <aura:attribute name="PageAPI" type="String" />
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:attribute name="Section" type="String"/>
    <aura:attribute name="selectedTab" type="String" default="Vendor"/>
    <aura:attribute name="PurchaseOrder" type="Boolean" default="false"/>
    <aura:attribute name="PageLayout" type="Object" access="private" />
    <aura:attribute name="recordIds" type="Boolean" default="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="RecordId" type="String"/>
    <aura:attribute name="RelatedId" type="List" default=""></aura:attribute>
    <aura:attribute name="PortalUser" type="Boolean" default="false"/>
    <aura:attribute name="ObName" type="String"/>
    <aura:attribute name="ObListName" type="String"/>
    <aura:attribute name="opptyColumns" type="List" />
    <aura:attribute name="caseColumns" type="List" />
    <aura:attribute name="contactColumns" type="List" />
    <aura:attribute name="length" type="Integer"/>
	<aura:attribute name="poFields" type="List" default=""/>
    <aura:attribute name="woFields" type="List" default=""/>
     <aura:attribute name="POList" type="Purchase_Line_Items__c[]"/>
    <div class="sld-hide">
    <div  aura:Id="body" class="maqsood"> <!--class="slds-box slds-theme_default"-->
       <div class="{!(v.PageLayoutName=='ERP7__PO__c')?'display:block':'display:none'}">
        <div class="d-flex justify-content-between pb-2 cl1">

            <div class="breadcrumbs">

                <h6 class="card-title mb-1">
                <ul class="cl2">
                    <li><a onclick="{!c.home}" href="">
                        Home ></a></li>
                    <li><a onclick="{!c.navigateBack}" href="">
                        &nbsp; {!v.ObName} >&nbsp; </a> </li>
                    <li>Detail</li>
                </ul>
                    </h6>
            </div>
            <aura:if isTrue="{!(v.ObName=='Purchase Orders')}">
                <div>
                    <a href="javascript:void(0);" target="_blank"  data-record="{!Id}" data-name="{po.Name}"  onclick="{!c.DownloadPdf}" class="cl3" data-aura-rendered-by="121:945;a"><i class="fa fa-download cl4" aria-hidden="true" data-aura-rendered-by="122:945;a"></i> &nbsp;Purchase Order Document </a>
                    </div>
                </aura:if>
              </div>
            
        </div>
       
        <lightning:tabset>
        <lightning:tab label="Related List">
            <div class="slds-media__body">
                
                <h2 class="slds-card__header-title">

                    <lightning:card title="{!v.ObListName}" iconName="standard:action_list_component">
 
            <p class="slds-p-horizontal_small cl5">
                
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__PO__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Purchase_Line_Items__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>
                </aura:if>
                
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__WO__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Work_Order_Line_Items__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>     
                </aura:if>
                
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__Bill__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Bill_Line_Item__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration> 
                </aura:if>
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__Payment__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Transaction__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>  
                </aura:if>
            
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__Request__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Request_Supplier__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration> 
                </aura:if>
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__Expense__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Expense_Line_Item__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>
                </aura:if>
                <aura:if isTrue="{!(v.PageLayoutName=='ERP7__Timesheet__c')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Time_Card_Entry__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>
                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>
                </aura:if>
                <aura:if isTrue="{!(v.PageLayoutName=='Contract')}">
                    <aura:iteration items="{!v.RelatedId}" var="related" end="4">
                        <lightning:recordViewForm recordId="{!related}" objectApiName="ERP7__Contract_Terms__c">
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.poFields}" var="item" end="4">
                                    <lightning:layoutItem size="{!12 / v.poFields.length}" padding="horizontal--small">
                                        <lightning:outputField fieldName="{!item}"/>                                    </lightning:layoutItem>
                                </aura:iteration> 
                            </lightning:layout>
                        </lightning:recordViewForm>
                    </aura:iteration>
                </aura:if>
            </p>
            
        </lightning:card>
            </h2>
            </div>
        </lightning:tab>
        <lightning:tab label="Details" title="">
            <aura:if isTrue="{!v.recordIds}">
            <force:recordView recordId="{!v.RecordId}">
                <aura:iteration items="{!v.PageLayout.Sections}" var="section">
                    <c:CollapsibleSection title="{!section.Label}">
                        <aura:iteration items="{!section.Columns}" var="column">
                            <div class="slds-col">
                                <aura:iteration items="{!column.Fields}" var="field">
                                    <lightning:outputField fieldName="{!field.APIName}" />
                                </aura:iteration>
                            </div>
                        </aura:iteration>
                    </c:CollapsibleSection>
                </aura:iteration>
            </force:recordView>
        </aura:if>
        </lightning:tab>
    </lightning:tabset>
        
      
    </div>
     
</div>
</aura:component>