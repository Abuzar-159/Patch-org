                                                                <lightning:formattedNumber currencyDisplayAs="code" style="currency" value="{!item.ERP7__Debit__c}"/>
                                                            </td>
                                                            <td data-label="">
                                                                <lightning:formattedNumber currencyDisplayAs="code" style="currency" value="{!item.ERP7__Remaining_Amount__c}"/>
                                                            </td>
                                                            <td data-label="">
                                                                <lightning:formattedDateTime value="{!item.ERP7__Credit_Note_Date__c}" year="numeric" month="numeric" day="numeric"  timeZone="{!$Locale.timezone}"/>
                                                            </td>
                                                            <td data-label="">
                                                                {!item.ERP7__Organisation__r.Name}
                                                            </td>
                                                        </tr>
                                                    </aura:iteration>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </aura:if>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
            <aura:if isTrue="{!v.fromAP}">
                <div class="slds-docked-form-footer">
                <lightning:button class="slds-button slds-button--neutral" label="Back" onclick="{!c.hideModal}" variant="neutral"/>
                </div>
            </aura:if>
            <aura:if isTrue="{!v.fromAR}">
                <div class="slds-docked-form-footer">
                <lightning:button class="slds-button slds-button--neutral" label="Back" onclick="{!c.hideModalReceivable}" variant="neutral"/>
                </div>
            </aura:if>
            <aura:if isTrue="{!v.fromCash}">
                <div class="slds-docked-form-footer">
                <lightning:button class="slds-button slds-button--neutral" label="Back" onclick="{!c.hideModalCash}" variant="neutral"/>
                </div>
            </aura:if>
        </div>
        
        <aura:if isTrue="{!v.showMmainSpin}">
            <span class="spincls">
                <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
        </aura:if>
    </div>
</aura:component>