<aura:component controller="ProductList" implements="forceCommunity:availableForAllPageTypes" access="global">
    <aura:attribute name="picklist" type="List"/>
    <aura:registerEvent name="family" type="c:filterPickList"/>
    <aura:handler name="init" value="{!this}" action="{!c.loadPickList}"/>
	<div class="widget widget_cetagories widget_border">
              <h2 class="erpmark7-widget-title">Categories</h2>
                  <ul>
                      <aura:iteration items="{!v.picklist}" var="pi">
                      <li><a onclick="{!c.filterMethod}" data-record="{!(empty(pi.type))?'Others':pi.type}">
                          <aura:if isTrue="{!empty(pi.type)}">
                              Others
                          	<aura:set attribute="else">
                              {#pi.type}
                              </aura:set>
                          </aura:if>
                          <span>{#pi.total}</span></a></li>
                      </aura:iteration>
                  </ul>
         </div>
</aura:component>