<aura:component controller="TimeSheetManagerLC" access="global">
    <ltng:require scripts="/resource/ERP7__RequireJS" afterScriptsLoaded="{!c.initTypeahead}" />
    <ltng:require styles="/resource/ERP7__Lgt_InputLookup/css/typeahead.css" />
    <aura:attribute name="SearchField" type="String" description="Sobject Field" default=""/>
    <aura:attribute name="type" type="String" description="Sobject Type" required="true" access="global" />
    <aura:attribute name="value" type="String" description="Source / Destination value" access="global"/>
    <aura:attribute name="className" type="String" description="class name of the input object" access="global"/>
    <aura:attribute name="qry" type="String" description="query param" access="global" default=""/>
    <!-- PRIVATE ATTRS -->
    <aura:attribute name="nameValue" type="String" description="Name of the current lookup 'name' field: loaded by controller" access="global" />
    <aura:attribute name="isLoading" type="Boolean" description="Loading component" default="true" access="global" />
    <div class="has-feedback">
        <input aura:id="projectlkp" type="text" value="{!v.nameValue}" class="{!v.className + ' newClass123'}" readonly="{!v.isLoading}"/>
        <span class="glyphicon glyphicon-search form-control-feedback">
        </span>
    </div>
</aura:component>