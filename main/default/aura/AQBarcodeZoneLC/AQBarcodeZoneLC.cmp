<aura:component controller="AQBarcodeControllerLC" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <aura:attribute name="Width" description="Barcode Width" type="String" access="global" />
    <aura:attribute name="Height" description="Barcode Height" type="String" access="global" />
    <aura:attribute name="Value" description="Barcode value" type="String" required="required" access="global" />
    <aura:attribute name="BrcdType" description="Barcode Type" type="String" required="required"  access="global" />
    <aura:attribute name="BrcdHeight" description="Barcode Height" type="String" required="required" access="global" />
    <aura:attribute name="BrcodeImage" description="Brcode Image" type="String" access="global" />
    <aura:attribute name="Id" description="Unique Id" type="String" access="global" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>    
    <div id="BrcdId"><lightning:formattedRichText value="{!v.BrcodeImage}"/></div>
</aura:component>