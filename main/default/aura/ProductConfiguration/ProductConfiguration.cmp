                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="text-input-01">Order Profile</label>
                                    <div class="slds-form-element__control">
                                        <c:ProjectLookups type="Profiling__c" value="{!v.tda2.ERP7__Order_Profile__c}" className="slds-input" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="text-input-01">Tier</label>
                                    <div class="slds-form-element__control">
                                        <c:ProjectLookups aura:id="Tier" type="Tier__c" value="{!v.tda2.ERP7__Tier__c}" className="slds-input" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="text-input-01">Default</label>
                                    <div class="slds-form-element__control">
                                        <lightning:input type="checkbox" checked="{!v.tda2.ERP7__Default__c}" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="text-input-01">Active</label>
                                    <div class="slds-form-element__control">
                                        <lightning:input type="checkbox" checked="{!v.tda2.ERP7__Active__c}" />
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                    <div class="row ProductConfiguration-newClass3">
                        <div class="col-md-12 align-center">
                            <button class="slds-button slds-button--neutral" onclick="{!c.CancelDiscounts}">Cancel</button>
                            <button type="button" class="slds-button slds-button--brand" onclick="{!c.Tda2insert}">Save</button>
                            
                        </div>
                    </div>
                    <!--TDA Section Ends here-->
                </aura:if>
            </aura:renderIf>
            <!--Tab5 Ends here-->
            <!--Tab6 Starts here-->
            <aura:renderIf isTrue="{!v.ShowTab6}">
                <div class="slds-tabs--path" role="application tablist">
                    <div class="epr_Mark7 slds-m-bottom--small">
                        <ul class="nav nav-tabs " role="tablist">
                            <li onclick="{!c.onclickTab2}" class="nav-item "> <a class="nav-link" data-toggle="tab" href="#pricebook" role="tab"><i class="fa fa-book fa-1x"></i>&nbsp;Price Book Entry</a> </li>
                            <li onclick="{!c.onclickTab3}" class="nav-item" > <a class="nav-link" data-toggle="tab" href="#BOM" role="tab"><i class="fa fa-list-ol fa-1x"></i>&nbsp;BOM Version </a> </li>  
                            <li onclick="{!c.onclickTab4}" class="nav-item "> <a class="nav-link active" data-toggle="tab" href="#routing" role="tab"><i class="fa fa-pencil-square-o fa-1x"></i>&nbsp;Routing</a> </li>
                            <li onclick="{!c.onclickTab5}" class="nav-item"> <a class="nav-link active" data-toggle="tab" href="#discount" role="tab"><i class="fa fa-strikethrough"></i>&nbsp;Discount Allocations</a> </li>
                            <li class="nav-item active"> <a class="nav-link" data-toggle="tab" href="#return" role="tab"><i class="fa fa-share-square-o fa-1x"></i>&nbsp;Warranty and Return Policies</a> </li>
                        </ul>
                    </div>
                 </div>
                
                <aura:renderIf isTrue="{!v.BackToWarranty}">
                    <div class="container ProductConfiguration-newClass2">
                        <div class="col-md-1 slds-m-bottom--x-small slds-m-top--x-small">
                            <a onclick="{!c.WarrantyComponent}" data-record="newWarranty" data-target="#myModal" class="ProductConfiguration-newClass7" data-toggle="modal" title="Add Warranty">
                                New 
                                <i class="fa fa-plus ProductConfiguration-newClass8" aria-hidden="true" data-aura-rendered-by="8620:0">
                                </i>
                            </a>
                        </div>
                        <!--Warranty and Return Table Starts here-->
                        <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                            <thead>
                                <tr class="slds-text-title--caps">
                                    <th scope="col">
                                        <span class="slds-truncate">Action</span>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Opportunity Name">Name</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Close Date">Days of Warranty</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Confidence">Active</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Close Date">Number Days From Trans Return Accepted</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Confidence">Exchange</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Confidence">Standard Manufacturing Warranty</div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.warranties}" var="warranty" indexVar="index">
                                    <tr>
                                        <td data-label="Action">
                                            <a class="svg" onclick="{!c.editWarranty}" data-target="{!warranty.Id}" data-index="{!index}">
                                                <lightning:icon iconName="action:edit" variant="inverse" size="x-small" alternativeText="edit" title="edit" />
                                            </a> |
                                            <a class="svg" onclick="{!c.deleteWarranty}" data-target="{!warranty.Id}" data-index="{!index}">
                                                <lightning:icon iconName="action:delete" variant="inverse" size="x-small" alternativeText="delete" title="delete" />
                                            </a>
                                        </td>
                                        <th scope="row" data-label="Name">
                                            <div class="slds-truncate" title="Cloudhub">{!warranty.Name}</div>
                                        </th>
                                        <td data-label="Days Of Warranty">
                                            <div class="slds-truncate" title="4/14/2015">{!warranty.ERP7__Days_of_Warranty__c}</div>
                                        </td>
                                        <td data-label="Active">
                                            <lightning:input type="checkbox" checked="{!warranty.ERP7__Active__c}" readonly="true"/>
                                        </td>
                                        <td data-label="Days Of Warranty">
                                            <div class="slds-truncate" title="4/14/2015">{!warranty.ERP7__Number_Days_From_Trans_Return_Accepted__c}</div>
                                        </td>
                                        <td data-label="Exchange">
                                            <lightning:input type="checkbox" checked="{!warranty.ERP7__Exchange__c}" readonly="true"/>
                                        </td>
                                        <td data-label="Standard Manufacturing Warranty">
                                            <lightning:input type="checkbox" checked="{!warranty.ERP7__Standard_Manufacturing_Warranty__c}" readonly="true"/>
                                        </td>
                                        
                                    </tr>
                                </aura:iteration>
                            </tbody>
                        </table>
                        <!--Warranty and return Table ends Here-->
                        <div class="row ProductConfiguration-newClass3">
                        <div class="col-md-12 ProductConfiguration-newClass4">
                            <button class="slds-button slds-button--neutral" onclick="{!c.Reset}">Cancel</button>
                            <button type="button" class="slds-button slds-button--brand" onclick="{!c.SaveAll}">Save</button>
                        </div>
                    </div>
                    </div>
                  </aura:renderIf>
                <aura:if isTrue="{!v.WarrantyComponent}">
                    
                    <!--warranty name Toast starts here-->
                    <aura:renderIf isTrue="{!v.WarrantyName}">
                        <div class="slds-notify_container ProductConfiguration-newClass5">
                            <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert">
                                <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                    <span class="slds-assistive-text">Close</span>
                                </button>
                                <span class="slds-assistive-text">Error</span>
                                <h2 class="ProductConfiguration-newClass6">
                                    <lightning:icon iconName="utility:warning" variant="inverse" size="x-small" alternativeText="warning" title="warning" /> Please enter Name</h2>
                            </div>
                        </div>
                    </aura:renderIf>
                    <!--Warranty name Toast ends here-->
                    <!--model text-->
                    <div id="content-path-1" class="slds-tabs--path__content slds-show" role="tabpanel" aria-labelledby="tab-path-1">
                        <div class="epr_Mark7">
                            <div class="row slds-m-top--small">
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Name</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" variant="label-hidden" aura:id="wName" value="{!v.war.Name}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Days Of Warranty</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="number" variant="label-hidden" value="{!v.war.ERP7__Days_of_Warranty__c}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">No Days From Trans Return Accepted</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="number" variant="label-hidden" value="{!v.war.ERP7__Number_Days_From_Trans_Return_Accepted__c}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Active</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="checkbox" checked="{!v.war.ERP7__Active__c}" />
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Exchange</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="checkbox" checked="{!v.war.ERP7__Exchange__c}" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Standard Manufacturing Warranty</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="checkbox" checked="{!v.war.ERP7__Standard_Manufacturing_Warranty__c}" />
                                        </div>
                                    </div>
                                </div>
                                
                                
                            </div>
                        </div>
                    </div>
                    <!--model text ends here-->
                    <div class="row ProductConfiguration-newClass3">
                        <div class="col-md-12 align-center">
                            <button type="button" class="slds-button slds-button--brand" onclick="{!c.Warranty2insert}">Save</button>
                            <button class="slds-button slds-button--neutral" onclick="{!c.CancelWarranty}">Cancel</button>
                        </div>
                    </div>
                </aura:if>
            </aura:renderIf>
            <!--Tab6 Ends here-->
        </div>
    </body>
</aura:component>