                                        <c:ProjectLookups type="Site__c" value="{!v.rout.ERP7__Site__c}" className="slds-input" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="email">Planner</label>
                                    <div class="slds-form-element__control">
                                        <c:ProjectLookups type="Employees__c" value="{!v.rout.ERP7__Planner__c}" className="slds-input" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="email">Bom Version</label>
                                    <div class="slds-form-element__control">
                                        <c:ProjectLookups type="Version__c" value="{!v.rout.unknown_custom_field}" className="slds-input" aura:id="bomVersion"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="email">Engineer</label>
                                    <div class="slds-form-element__control">
                                        <c:ProjectLookups type="Employees__c" value="{!v.rout.ERP7__Engineer__c}" className="slds-input" />
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                    <!--operation table starts here-->
                    <!--Operations Row starts here-->
                    <div class="epr_Mark7 row productconfiq slds-m-around--xx-small">
                        <div class="col-md-2 ProductConfiguration-newClass9" onclick="{!c.operationsAdd}"><!--onclick="{!c.AddOprs}"-->
                            <a href="javascript:void(0)" data-target="#myModal" class="ProductConfiguration-newClass7" data-toggle="modal" title="Add Product" data-aura-rendered-by="8618:0">New <i class="fa fa-plus ProductConfiguration-newClass8" aria-hidden="true" data-aura-rendered-by="8620:0"></i></a>
                        </div>
                        <div class="col-md-8 ProductConfiguration-newClass10">Operations</div>
                    </div>
                    <!--Operations Row Starts here-->
                    <aura:iteration items="{!v.operations}" var="opr" indexVar="i">
                        <c:Operations routeOperations="{!opr}"/>
                    </aura:iteration>    
                    
                    <!--operation table ends here-->
                    <div class="row ProductConfiguration-newClass3">
                        <div class="col-md-12 align-center">
                            <button class="slds-button slds-button--neutral" onclick="{!c.CancelRoutings}">Cancel</button>
                            <button type="button" class="slds-button slds-button--brand" onclick="{!c.Routing2insert}">Save</button>
                            
                        </div>
                    </div>
                </aura:if>
            </aura:renderIf>
            <!--Tab4 ends here-->
            <!--Tab5 Starts here-->
            <aura:renderIf isTrue="{!v.ShowTab5}">
                <div class="slds-tabs--path" role="application tablist">
                    <div class="epr_Mark7 slds-m-bottom--small">
                        <ul class="nav nav-tabs " role="tablist">
                            <li onclick="{!c.onclickTab2}" class="nav-item "> <a class="nav-link" data-toggle="tab" href="#pricebook" role="tab"><i class="fa fa-book fa-1x"></i>&nbsp;Price Book Entry</a> </li>
                            <li onclick="{!c.onclickTab3}" class="nav-item" > <a class="nav-link" data-toggle="tab" href="#BOM" role="tab"><i class="fa fa-list-ol fa-1x"></i>&nbsp;BOM Version </a> </li>  
                            <li onclick="{!c.onclickTab4}" class="nav-item "> <a class="nav-link active" data-toggle="tab" href="#routing" role="tab"><i class="fa fa-pencil-square-o fa-1x"></i>&nbsp;Routing</a> </li>
                            <li class="nav-item active"> <a class="nav-link active" data-toggle="tab" href="#discount" role="tab"><i class="fa fa-strikethrough"></i>&nbsp;Discount Allocations</a> </li>
                            <li onclick="{!c.onclickTab6}" class="nav-item"> <a class="nav-link" data-toggle="tab" href="#return" role="tab"><i class="fa fa-share-square-o fa-1x"></i>&nbsp;Warranty and Return Policies</a> </li>
                        </ul>
                    </div>
                </div>
                <aura:renderIf isTrue="{!v.BackToDiscount}">
                    <div class="container ProductConfiguration-newClass2">
                        <div class="col-md-1 slds-m-bottom--x-small slds-m-top--x-small">
                            <a data-record="newTda" onclick="{!c.DiscountComponent}" data-target="#myModal" class="ProductConfiguration-newClass7" data-toggle="modal" title="Add Discount">
                                New 
                                <i class="fa fa-plus ProductConfiguration-newClass8" aria-hidden="true" data-aura-rendered-by="8620:0">
                                </i>
                            </a>
                        </div>
                       <!--Discount Allocation Table Starts here-->
                        <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                            <thead>
                                <tr class="slds-text-title--caps">
                                    <th scope="col">
                                        <span class="slds-truncate">Action</span>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Name">Name</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Discount Plan">Discount Plan</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Order Profile</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Tier</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Default</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Active">Active</div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.tdiscounts}" var="tdisc" indexVar="index">
                                    <tr>
                                        <td data-label="Action">
                                            <a class="svg" href="#" onclick="{!c.editTDARecord}" data-target="{!tdisc.Id}" data-index="{!index}">
                                                <lightning:icon iconName="action:edit" variant="inverse" size="x-small" alternativeText="edit" title="edit" />
                                            </a> |
                                            <a class="svg" onclick="{!c.deleteTDA}"  data-target="{!tdisc.Id}" data-index="{!index}">
                                                <lightning:icon iconName="action:delete" variant="inverse" size="x-small" alternativeText="delete" title="delete" />
                                            </a>
                                        </td>
                                        <th scope="row" data-label="Name">
                                            <div class="slds-truncate" title="Cloudhub">{!tdisc.Name}</div>
                                        </th>
                                        <td data-label="Discount Plan">
                                            <div class="slds-truncate" title="4/14/2015">{!tdisc.ERP7__Discount_Plan__r.Name}</div>
                                        </td>
                                        <td data-label="Tier">
                                            <div class="slds-truncate" title="Prospecting">{!tdisc.ERP7__Order_Profile__r.Name}</div>
                                        </td>
                                        <td data-label="Tier">
                                            <div class="slds-truncate" title="Prospecting">{!tdisc.ERP7__Tier__r.Name}</div>
                                        </td>
                                        <td data-label="Default">
                                            <lightning:input type="checkbox" checked="{!tdisc.ERP7__Default__c}" readonly="true"/>
                                        </td>
                                        <td data-label="Active">
                                            <lightning:input type="checkbox" checked="{!tdisc.ERP7__Active__c}" readonly="true"/>
                                        </td>
                                    </tr>
                                </aura:iteration>
                            </tbody>
                        </table>
                        <!--Discount Allocation Table ends Here-->
                        
                    </div>
                  </aura:renderIf>
                <aura:if isTrue="{!v.DiscountComponent}">
                    
                    <!--Discount Name Toast starts here-->
                    <aura:renderIf isTrue="{!v.DiscountName}">
                        <div class="slds-notify_container ProductConfiguration-newClass5">
                            <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert">
                                <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                    <span class="slds-assistive-text">Close</span>
                                </button>
                                <span class="slds-assistive-text">Error</span>
