<aura:component controller="ProductConfig" implements="force:appHostable,force:lightningQuickAction">
    <ltng:require styles="/resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.css" />
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css" />
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__TablesSort/ERP7__TablesSort/css/font-awesome.min.css" />
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductConfiguration.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <!--Save Event Start-->
    
    <!--Save Event End-->

    <aura:attribute name="newProduct" type="Product2" default="{ 'sobjectType': 'Product2','Name': '',}" />
    <aura:attribute name="pbe" type="priceBookEntry" default="{'sobjectType': 'priceBookEntry',
                                                               'Name':        '',
                                                               'Pricebook2Id':'',
                                                               'UnitPrice':   '',
                                                               'ERP7__Barcode__c':'',
                                                               'IsActive':'',
                                                               'ERP7__Purchase_Price__c':'',
                                                               'ERP7__Selling_Price__c':'',
                                                               'unknown_custom_field':'',
                                                               'unknown_custom_field':'',
                                                               'ERP7__Warranty_Return_Policy__c':'',
                                                               'unknown_custom_field':'',
                                                               'ERP7__Admin_Shipping_Price__c':'',
                                                               'ERP7__Shipping_Price__c':'',
                                                               'ERP7__Tax_Exempt__c':'',
                                                               'ERP7__Discount_Plan__c':''}" />
    <!--priceBookEntry-->
    
    <!--New Attirbutes-->
    <aura:attribute name="tda2" type="Tier_Discount_Allocation__c" default="{ 'sobjectType': 'Tier_Discount_Allocation__c','Name': '',}" />
    <aura:attribute name="pl" type="Product_Location__c" default="{'sobjectType': 'Product_Location__c','Name': ''}" />
    <aura:attribute name="lpa" type="Loyalty_Point_Allocation__c" default="{'sobjectType': 'Loyalty_Point_Allocation__c','Name': ''}" />
    <aura:attribute name="war" type="Warranty_Return_Policy__c" default="{'sobjectType': 'Warranty_Return_Policy__c','Name': '',
                                                                                'ERP7__Days_of_Warranty__c':'',
                                                                                'ERP7__Number_Days_From_Trans_Return_Accepted__c':'',
                                                                                'ERP7__Active__c':'',
                                                                                'ERP7__Standard_Manufacturing_Warranty__c':'',
                                                                                'ERP7__Exchange__c':''}" />
    <aura:attribute name="spa" type="Product_Subscription_Plan_Allocation__c" default="{'sobjectType': 'Product_Subscription_Plan_Allocation__c','Name': ''}" />
    <aura:attribute name="bom" type="BOM__c" default="{ 'sobjectType': 'BOM__c','Name': '',}" />
    <aura:attribute name="opr" type="Operation__c" default="{ 'sobjectType': 'Operation__c','Name': '',}" />
    <aura:attribute name="Vbom" type="Version__c" default="{ 'sobjectType': 'Version__c',
                                                                   'Name': '',
                                                                   'ERP7__Barcode__c':'',
                                                                   'ERP7__Status__c':'',
                                                                   'ERP7__Unit_of_Measure__c':'',
                                                                   'ERP7__Start_Date__c':'',
                                                                   'ERP7__To_Date__c':'',
                                                                   'ERP7__Type__c':'',
                                                                   'ERP7__Category__c':'',
                                                                   'ERP7__Description__c':'',
                                                                   'ERP7__Process__c':''}"/>
    <aura:attribute name="versionComp" type="Version__c"/>
    <aura:attribute name="rout" type="Routing__c" default="{'sobjectType': 'Routing__c','Name': '', 'ERP7__Status__c':'','ERP7__Type__c':'','ERP7__Description__c':'','ERP7__Process__c':'','ERP7__Site__c':'','ERP7__Planner__c':'','unknown_custom_field':'','ERP7__Engineer__c':''}" />
    <aura:attribute name="Version" type="Version__c[]"/>
    <aura:attribute name="routing" type="Routing__c[]"/>    
    <aura:attribute name="productId" type="String" />
    <aura:attribute name="priceBookId" type="String" />
    <aura:attribute name="pName" type="String" />
    <aura:attribute name="prId" type="String"/><!--default="01t240000060XpG"-->
    
    <!--Attributes for Edit Function-->
    <aura:attribute name="pbIndex" type="String" />
    <aura:attribute name="recordIndex" type="String" />
    <aura:attribute name="LocIndex" type="String" />
    <aura:attribute name="WarIndex" type="String" />
    <aura:attribute name="RoutingIndex" type="String" />
    <aura:attribute name="BomIndex" type="String" />
    
    <aura:attribute name="tdaId" type="String" />
    <aura:attribute name="lpaId" type="String" />
    <aura:attribute name="warId" type="String" />
    <aura:attribute name="spaId" type="String" />
    <aura:attribute name="bomId" type="String" />
    <aura:attribute name="bomVId" type="String" />
    <aura:attribute name="vId" type="String"/>
    <aura:attribute name="rId" type="String"/>
    
    
    
    <!--Component and Modal Attiributes-->
    <aura:attribute name="PriceBookComponent" type="boolean" default="false" />
    <aura:attribute name="BackToPriceBook" type="boolean" default="true" />
    
    <aura:attribute name="VersionComponent" type="boolean" default="false" />
    <aura:attribute name="ShowMainComponent" type="boolean" default="true" />
    
    <aura:attribute name="RoutingComponent" type="boolean" default="false" />
    <aura:attribute name="BackToRouting" type="boolean" default="true" />
    
    <aura:attribute name="DiscountComponent" type="boolean" default="false" />
    <aura:attribute name="BackToDiscount" type="boolean" default="true" />
    
    <aura:attribute name="LocationComponent" type="boolean" default="false" />
    <aura:attribute name="BackToLocation" type="boolean" default="true" />
    
    <aura:attribute name="WarrantyComponent" type="boolean" default="false" />
    <aura:attribute name="BackToWarranty" type="boolean" default="true" />
    
    <aura:attribute name="ShowTab2" type="Boolean" default="true"/>
    <aura:attribute name="ShowTab3" type="Boolean" />
    <aura:attribute name="ShowTab4" type="Boolean" />
    <aura:attribute name="ShowTab5" type="Boolean" />
    <aura:attribute name="ShowTab6" type="Boolean" />
    <aura:attribute name="ShowTab7" type="Boolean" />
    <aura:attribute name="ShowTab8" type="Boolean" />
    
    <!--Toast Attributes-->
    <aura:attribute name="ProductNameError" type="Boolean" default="false" />
    <aura:attribute name="PbNameError" type="Boolean" default="false" />
    <aura:attribute name="ShowToast" type="Boolean" default="false" />
    <aura:attribute name="ShowErrorToast" type="Boolean" default="false" />
    <aura:attribute name="ShowErrorToast2" type="Boolean" default="false" />
    <aura:attribute name="VersionCodeError" type="Boolean" default="false" />
    <aura:attribute name="RoutingCode" type="Boolean" default="false" />
    <aura:attribute name="DiscountName" type="Boolean" default="false" />
    <aura:attribute name="WarrantyName" type="Boolean" default="false" />
    <aura:attribute name="WarehouseName" type="Boolean" default="false" />
    
    <aura:attribute name="product" type="Product_Service__c" default="{ 'sobjectType': 'Product_Service__c'}" />
    
    <!--Fetch Record Attributes-->
    <aura:attribute name="pbEntries" type="priceBookEntry[]" />
    <aura:attribute name="tdiscounts" type="Tier_Discount_Allocation__c[]" />
    <aura:attribute name="locations" type="Product_Location__c[]" />
    <aura:attribute name="warranties" type="Warranty_Return_Policy__c[]" />
    <aura:attribute name="boms" type="BOM__c[]"/>
    <aura:attribute name="Vboms" type="Version__c[]" />
    <aura:attribute name="routs" type="Routing__c[]" />
    <aura:attribute name="operations" type="Operation__c[]" />
    
    <aura:attribute name="options1" type="String" />
    <aura:attribute name="options2" type="String" />
    <!--Start -->
    <aura:registerEvent name="delete" type="c:billofmaterialDelete" />
    <aura:handler name="delete" action="{!c.handleVersionDelete}" />
    <!--End-->
    <aura:attribute name="cardTypeOptions" type="List"/>
    <aura:attribute name="RoutingTypeOptions" type="List"/>
    
    <aura:attribute name="RoutingStatusOptions" type="List"/>
    <aura:attribute name="InputSelectCategoryOptions" type="List"/>
    
    <aura:attribute name="InputSelectTypeOptions" type="List"/>
    <aura:attribute name="InputSelectUoMOptions" type="List"/>
    
    <aura:attribute name="InputSelectStatusOptions" type="List"/>
    
    <body>
        <div class="erp_mark7">
            <!--Toast-->
            <aura:renderIf isTrue="{!v.ShowToast}">
                <div class="slds-notify_container">
                    <div class="slds-notify slds-notify--toast slds-theme--success" role="alert">
                        <span class="slds-assistive-text">Success</span>
                        <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                            <span class="slds-assistive-text">Close</span>
                        </button>
                        <div class="slds-notify__content slds-grid">
                            <lightning:icon iconName="utility:notification" variant="inverse" size="small" alternativeText="notification" title="notification" />
                            
                            <div class="slds-col slds-align-middle">
                                <h2 class="slds-text-heading--small ">Your new <a href="javascript:void(0);">Product</a> was successfully created.</h2>
                            </div>
                        </div>
                    </div>
                </div>
            </aura:renderIf>
            <div class="slds-page-header">
                <div class="slds-grid">
                    <div class="slds-col slds-has-flexi-truncate">
                        <div class="slds-media slds-no-space slds-grow">
                            
                            <div class="slds-media__body">
                                <h1 class="slds-page-header__title  slds-line-height--reset"> {!v.newProduct.Name} &nbsp; <img src="{!v.newProduct.ERP7__Picture__c}" class="ProductConfiguration-newClass1" /></h1>
                                
                            </div>
                            
                            
                            
                        </div>
                    </div>
                    <div class="slds-col slds-no-flex slds-grid slds-align-top">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="text-input-01">Product Family</label>
                            <div class="slds-form-element__control">
                                <strong><lightning:input type="text" variant="label-hidden" value="{!v.newProduct.Family}" class=""/></strong>
                             </div>
                        </div>&nbsp;&nbsp;
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="text-input-01">Product Code</label>
                            <div class="slds-form-element__control">
                               <strong><lightning:input type="text" variant="label-hidden" value="{!v.newProduct.ProductCode}" class=""/></strong>
                            </div>
                        </div>
                        
                    </div>
                </div>
                
            </div>
            <!--Toast Ends-->
            
            <!--Tab1 Ends here-->
            <!--Tab2 Starts here-->
            <aura:renderIf isTrue="{!v.ShowTab2}">
                
                <div class="slds-tabs--path" role="application tablist">
                    <div class="epr_Mark7 slds-m-bottom--small">
                        <ul class="nav nav-tabs " role="tablist">
                            <li class="nav-item active"> <a class="nav-link" data-toggle="tab" href="#pricebook" role="tab"><i class="fa fa-book fa-1x"></i>&nbsp;Price Book Entries</a> </li>
                            <li onclick="{!c.onclickTab3}" class="nav-item"> <a class="nav-link" data-toggle="tab" href="#BOM" role="tab"><i class="fa fa-list-ol fa-1x"></i>&nbsp;BOM Versions </a> </li>  
                            <li onclick="{!c.onclickTab4}" class="nav-item"> <a class="nav-link active" data-toggle="tab" href="#routing" role="tab"><i class="fa fa-pencil-square-o fa-1x"></i>&nbsp;Routings</a> </li>
                            <li onclick="{!c.onclickTab5}" class="nav-item"> <a class="nav-link active" data-toggle="tab" href="#discount" role="tab"><i class="fa fa-strikethrough  fa-1x"></i>&nbsp;Discount Allocations</a> </li>
                            <li onclick="{!c.onclickTab6}" class="nav-item"> <a class="nav-link" data-toggle="tab" href="#return" role="tab"><i class="fa fa-share-square-o fa-1x"></i>&nbsp;Warranty and Return Policies</a> </li>
                         </ul>
                    </div>
                </div>
                
                
                <aura:renderIf isTrue="{!v.BackToPriceBook}">
                    <div class="container ProductConfiguration-newClass2">
                        <div class="col-md-1 slds-m-bottom--x-small slds-m-top--x-small">
                            <a data-record="newPbe" onclick="{!c.PriceBookEntryComponent}" data-target="#myModal" class="ProductConfiguration-newClass7" data-toggle="modal" title="Add Price Book Entries">
                                New 
                                <i class="fa fa-plus ProductConfiguration-newClass8" aria-hidden="true" data-aura-rendered-by="8620:0">
                                </i>
                            </a>
                        </div>
                        
                        <!--Pricebook Enrties Table Starts here-->
                        <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                            <thead>
                                <tr class="slds-text-title--caps">
                                    <th scope="col">
                                        <span class="slds-truncate">Action</span>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Name">Price Book</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Discount Plan">List Price</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Active</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Barcode</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Tier">Purchase Price</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Active">Selling Price</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-truncate" title="Active">Track Inventory</div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.pbEntries}" var="pbes" indexVar="i">
                                    <tr>
                                        <td data-label="Action">
                                            <a class="svg" href="#" onclick="{!c.editPbe}" data-target="{!pbes.Id}" data-index="{!i}">
                                                <lightning:icon iconName="action:edit" variant="inverse" size="x-small" alternativeText="edit" title="edit" />
                                            </a> |
                                            <a class="svg" onclick="{!c.deletePbe}" data-target="{!pbes.Id}" data-index="{!i}" >
                                                <lightning:icon iconName="action:delete" variant="inverse" size="x-small" alternativeText="delete" title="delete" />
                                            </a>
                                        </td>
                                        <th scope="row" data-label="Name">
                                            <div class="slds-truncate" title="Cloudhub">{!pbes.Pricebook2.Name}</div>
                                        </th>
                                        <td data-label="Discount Plan">
                                            <div class="slds-truncate" title="4/14/2015">{!pbes.UnitPrice}</div>
                                        </td>
                                        <td data-label="Active">
                                            <lightning:input type="checkbox" checked="{!pbes.IsActive}" readonly="true"/>
                                        </td>
                                        <td data-label="Tier">
                                            <div class="slds-truncate" title="Prospecting">{!pbes.ERP7__Barcode__c}</div>
                                        </td>
                                        <td data-label="Tier">
                                            <div class="slds-truncate" title="Prospecting">{!pbes.ERP7__Purchase_Price__c}</div>
                                        </td>
                                        <td data-label="Tier">
                                            <div class="slds-truncate" title="Prospecting">{!pbes.ERP7__Selling_Price__c}</div>
                                        </td>
                                        <td data-label="Active">
                                            <lightning:input type="checkbox" checked="{!pbes.ERP7__Track_Inventory__c}" readonly="true"/>
                                        </td>
                                        
                                    </tr>
                                </aura:iteration>
                            </tbody>
                        </table>
                        <!--Pricebook Enrties Table ends Here-->
                        
                    </div>
                   </aura:renderIf>
                <aura:if isTrue="{!v.PriceBookComponent}">
                    
                    <!--this is tab2 content-->
                    <!--component2 AddPriceBook-->
                    <div id="content-path-1" class="slds-tabs--path__content slds-show" role="tabpanel" aria-labelledby="tab-path-1">
                        <div class="epr_Mark7">
                            <!--Warning toast starts here-->
                            
                            <aura:renderIf isTrue="{!v.PbNameError}">
                                <div class="slds-notify_container ProductConfiguration-newClass5">
                                    <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert">
                                        <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                            <span class="slds-assistive-text">Close</span>
                                        </button>
                                        <span class="slds-assistive-text">Error</span>
                                        <h2 class="ProductConfiguration-newClass6">
                                                    <lightning:icon iconName="utility:warning" variant="inverse" size="x-small" alternativeText="warning" title="warning" /> Please select Price book</h2>
                                    </div>
                                </div>
                                
                            </aura:renderIf>
                            
                            <aura:renderIf isTrue="{!v.ShowErrorToast}">
                                <div class="slds-notify_container ProductConfiguration-newClass5">
                                    <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert">
                                        <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                            <span class="slds-assistive-text">Close</span>
                                        </button>
                                        <span class="slds-assistive-text">Error</span>
                                        <h2 class="ProductConfiguration-newClass6">
                                                   <lightning:icon iconName="utility:warning" variant="inverse" size="x-small" alternativeText="warning" title="warning" /> Please select Standard price book</h2>
                                    </div>
                                </div>
                                
                            </aura:renderIf>
                            <aura:renderIf isTrue="{!v.ShowErrorToast2}">
                                <div class="slds-notify_container ProductConfiguration-newClass5">
                                    <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert">
                                        <button class="slds-button slds-notify__close slds-button--icon-inverse" title="Close" onclick="{!c.closeToast}">
                                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                            <span class="slds-assistive-text">Close</span>
                                        </button>
                                        <span class="slds-assistive-text">Error</span>
                                        <h2 class="ProductConfiguration-newClass6">
                                                    <lightning:icon iconName="utility:warning" variant="inverse" size="x-small" alternativeText="warning" title="warning" /> This price definition already exists in this price book</h2>
                                    </div>
                                </div>
                                
                            </aura:renderIf>
                            <!--Warning toast ends here-->
                            
                            <div class="row slds-m-top--small">
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="email">Price Book</label>
                                        <div class="slds-form-element__control" aura:id="PbLookup" id="message">
                                            <c:ProjectLookups type="Pricebook2" value="{!v.pbe.Pricebook2Id}" className="slds-input" aura:id="price"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">List Price</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" variant="label-hidden" aura:id="name" value="{!v.pbe.UnitPrice}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Barcode</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" variant="label-hidden" aura:id="name" value="{!v.pbe.ERP7__Barcode__c}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Active</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="checkbox" aura:id="checkbox" checked="{!v.pbe.IsActive}" />
                                        </div>
                                    </div>
                                </div>
                                
                            </div>
                            <div class="row slds-m-top--small">
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Purchase Price</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" variant="label-hidden" aura:id="name" value="{!v.pbe.ERP7__Purchase_Price__c}" maxlength="30" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Selling Price</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" variant="label-hidden" aura:id="name" value="{!v.pbe.ERP7__Selling_Price__c}" maxlength="30" />
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Minimum Order Quantity</label>
                                        <div class="slds-form-element__control">
                                            <lightning:input type="number" variant="label-hidden" aura:id="name" value="{!v.pbe.unknown_custom_field}" maxlength="30" />
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Version</label>
                                        <div class="slds-form-element__control">
                                            <c:ProjectLookups type="Version__c" value="{!v.pbe.unknown_custom_field}" className="slds-input" aura:id="price"/>
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Discount Plan</label>
                                        <div class="slds-form-element__control">
                                            <c:ProjectLookups type="Discount_Plan__c" value="{!v.pbe.ERP7__Discount_Plan__c}" className="slds-input" aura:id="price"/>
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Warranty and Return Policy</label>
                                        <div class="slds-form-element__control">
                                            <c:ProjectLookups type="Warranty_Return_Policy__c" value="{!v.pbe.ERP7__Warranty_Return_Policy__c}" className="slds-input" aura:id="price"/>
                                        </div>
                                    </div>
                                    
                                </div>
                                <div class="col-md-3">
                                    <div class="slds-form-element">
                                        <label class="slds-form-element__label" for="text-input-01">Tax Plan</label>
                                        <div class="slds-form-element__control">
                                            <c:ProjectLookups type="Tax_Plan__c" value="{!v.pbe.ERP7__Tax_Plan__c}" className="slds-input" aura:id="price"/>
                                        </div>
                                    </div>
                                    
