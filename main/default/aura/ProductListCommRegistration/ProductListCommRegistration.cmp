<aura:component controller="ProductListCommRegistration" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/bootstrap.custom.min.css',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
     <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
   
    <aura:registerEvent name="ProductListCommEvent" type="c:ProductListCommEvent"/>
    <aura:attribute name="errMsg" type="String" default="" access="global"/>    
    <aura:attribute name="firstNameInfo" type="String" default="" access="global"/>
    <aura:attribute name="middleNameInfo" type="String" default="" access = "global"/>
    <aura:attribute name="lastNameInfo" type="String" default="" access="global"/>
    <aura:attribute name="emailInfo" type="String" default="" access="global"/>  
    <aura:attribute name="newsLetter" type="Boolean" default="false" />
    <aura:attribute name="registerSuccess" type="Boolean" default="false" />
     <aura:attribute name="UserName1" type="String" default=""/>
    <aura:attribute name="PortalUser" type="Boolean" default="false"/>
    <aura:attribute name="UserRegProfName" type="String" default="" />
    <!--<aura:attribute name="UserRegProf" type="String" default="" />-->
    <aura:handler name="init" value="{!this}" action="{!c.initial}" />
  <div class="erp_mark7">  
    <aura:if isTrue="{!!v.registerSuccess}"> 
        <div > 
            <aura:renderIf isTrue="{!(v.errMsg != '')}"> 
                <div class="PL1-newClass5"> 
                    {!v.errMsg}
                </div>
            </aura:renderIf> 
            <div class="form-group pt-2">
                <!--<label>First Name</label>-->
                <lightning:input type="text" required="true" value="{!v.firstNameInfo}" aura:id="firstName" label="First Name"/>
                <!--<lightning:input aura:id="firstName" value="{!v.firstNameInfo}" messageWhenValueMissing="Please enter first name" required="true" label="First Name"/>-->
            </div>
            <div class="form-group">
                <!--<label>Last Name</label>-->
                <lightning:input type="text" required="true" value="{!v.lastNameInfo}" aura:id="lastName" label="Last Name"/>
                <!--<lightning:input aura:id="lastName" value="{!v.lastNameInfo}" messageWhenValueMissing="Please enter last name" required="true" label="Last Name"/>-->
            </div>
            <div class="form-group">
                <!--<label> Email Address (Username for Aqxolt ERP account) </label>-->
                <lightning:input type="text" required="true" value="{!v.emailInfo}" aura:id="emailAddress" label="Email Address (Username for Aqxolt ERP account)"/>
                <!--<lightning:input aura:id="emailAddress" value="{!v.emailInfo}" messageWhenValueMissing="Please enter a valid email address" required="true" label="Email Address (Username for Aqxolt ERP account)"/>-->
            </div>
            <div class="form-group">
                <span class="slds-checkbox">
                    <input id="acceptTerms" type="checkbox" value="true"></input>
                    <label class="slds-checkbox__label" for="acceptTerms">
                        <span class="slds-checkbox_faux"></span>
                        <span class="slds-form-element__label">
                            &nbsp; I accept the ERP's <a target="_blank"  href="https://support.aqxolt.com/privacy-policy/">Terms and Service</a>
                        </span>
                    </label>                             
                </span>
            </div>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-xl-12 col-lg-12 col-md-12">
                <div class="box_account">
                    <div class="text-center PL1-newClass1"> 
                        <input type="submit" value="Register" onclick="{!c.registerUser}" class="btn_1 full-width mr-2"/>
                        <!--<input type="submit" value="Cancel" onclick="{!c.hideRegister}" class="btn_1 gray half-width"/>-->
                    </div>
                </div>
            </div>
            <div class="text-center pb-2">Already Registered? <a onclick="{!c.SignInAction}" data-Action="SignIn" class="PL1-newClass2">Sign In</a></div>
        </div>
        <aura:set attribute="else">
            <div class="event-rok">
                <div class="container">
                    <div class="col-md-12 mb-4 mt-3 text-center">
                        <div dir="ltr" data-aura-rendered-by="27:2;a" class="uiOutputRichText mt-5" data-aura-class="uiOutputRichText">
                            <br data-aura-rendered-by="28:2;a"/> 
                            <br data-aura-rendered-by="28:2;a"/> 
                            <p class="tempStyle PL1-newClass3" data-aura-rendered-by="28:2;a" >
                                <i class="fa fa-check-circle chevronright-confirmed1"></i><br/> 
                                You have successfully registered!
                            </p>
                            <p>Please check your email and complete the registration process</p> 
                        </div>
                    </div>
                </div>
                
            </div>
            <lightning:layout class = "slds-container slds-grid getSomeMoreSpace">
                
                <div class="slds-col slds-m-left--small width: 100%;  text-align: center;">
                    <lightning:layoutitem class = "getSomSpace2">    
                        <lightning:button label="OK"  class="slds-m-top--medium btn btn-primary"  onclick="{!c.hideRegister}"/>
                    </lightning:layoutitem>
                </div>
                
            </lightning:layout>
        </aura:set>
    </aura:if>
    </div>
</aura:component>