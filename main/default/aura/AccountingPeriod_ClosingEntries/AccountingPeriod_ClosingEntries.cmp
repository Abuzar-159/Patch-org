<aura:component implements="force:lightningQuickActionWithoutHeader,force:hasRecordId" controller="AccountingPeriod">
    <ltng:require styles="{!join(',',$Resource.SLDS + '/assets/styles/customizeSlds.css',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.css',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.min.css',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css',$Resource.PickPackShipResource + '/assets/styles/font-awesome.css' )}"/>
    <aura:attribute name="IncomeClosingEntries" type="List" />
    <aura:attribute name="ExpenseClosingEntries" type="List" />
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="RE_COA" type="Map" default="{}"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="errmsg" type="String" />
    
    <div class="erp_mark7" aura:Id="body">
       <aura:if isTrue="{!(v.errmsg!=null?v.errmsg!=''?true:false:false)}">
        <div class="AccountPeriodClosing-newClass1">
        {!v.errmsg}    
        </div>
       </aura:if>
        <table class="slds-table slds-table_bordered slds-table_cell-buffer">
            <thead>
                <tr class="slds-text-title_caps">
                    <th scope="col">
                        <div class="slds-truncate" title="Opportunity Name">Chart Of Account</div>
                    </th>
                    <th scope="col">
                        <div class="slds-truncate" title="Account Name">Credit</div>
                    </th>
                    <th scope="col">
                        <div class="slds-truncate" title="Close Date">Debit</div>
                    </th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td data-label="Account Name" colspan="3">
                        <div class="slds-truncate" title="Cloudhub">
                            <b>Income/Revenue</b></div>
                    </td>
                </tr>
				<aura:iteration items="{!v.IncomeClosingEntries}" var="item">
                   <tr>
                        <td data-label="Account Name">
                            <div class="slds-truncate" title="Cloudhub">{!item.AccountName}</div>
                        </td>
                        <td data-label="Close Date">
                            <div class="slds-truncate" title="5000.00"><lightning:formattedNumber style="currency"  value="{!item.Credit}"/></div>
                        </td>
                        <td data-label="Prospecting">
                            <div class="slds-truncate" title="0.00"><lightning:formattedNumber style="currency" value="{!item.Debit}"/></div>
                        </td>
                    </tr>
                </aura:iteration>

				<tr>
                    <td data-label="Account Name" colspan="3">
                        <div class="slds-truncate" title="Cloudhub">
                            <b>Expense</b></div>
                    </td>
                </tr>
            	<aura:iteration items="{!v.ExpenseClosingEntries}" var="eitem">
                    <tr>
                        <td data-label="Account Name">
                            <div class="slds-truncate" title="Cloudhub">{!eitem.AccountName}</div>
                        </td>
                        <td data-label="Close Date">
                            <div class="slds-truncate" title="5000.00"><lightning:formattedNumber style="currency" value="{!eitem.Credit}"/></div>
                        </td>
                        <td data-label="Prospecting">
                            <div class="slds-truncate" title="0.00"><lightning:formattedNumber style="currency" value="{!eitem.Debit}"/></div>
                        </td>
                    </tr>
                </aura:iteration><!---->
            </tbody>
        </table>
        <div class="AccountPeriodClosing-newClass2">
            <Lightning:button label="Cancel" variant="inverse" onclick="{!c.cancel}"/>
            <Lightning:button label="Save" variant="brand" onclick="{!c.createTransaction}" />
        </div> 
    </div>    
</aura:component>