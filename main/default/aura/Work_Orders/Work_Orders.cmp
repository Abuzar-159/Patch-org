                                        <!-- New Notes Modal END--><!--Finish Modal-->
                                        <div class="slds-modal newcls64" id="myModal1"  aura:id="finishModal" role="dialog" aria-modal="true"  >
                                            <div class="modal-dialog">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    <div class="modal-body">
                                                        <div class="row">
