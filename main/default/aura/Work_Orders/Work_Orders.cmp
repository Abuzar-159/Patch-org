                                                                                    <img src="{!'/servlet/servlet.FileDownload?file='+AT.Id}" class="newcls62"/>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </aura:renderIf>
                                                            </aura:iteration>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="slds-docked-form-footer">
                                            <button type="button" onclick="{!c.goBack}" class="slds-button slds-button_neutral">Cancel</button>
                                        </div>
                                        <!-- new Task Modal -->
                                        <div class="slds-modal newcls64" id="myModal2" aura:id="newTaskModal" role="dialog" >
                                            <div class="modal-dialog modal-lg">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    
                                                    
                                                    <div class="modal-body  newcls65">
                                                        <fieldset class="slds-form--compound">
