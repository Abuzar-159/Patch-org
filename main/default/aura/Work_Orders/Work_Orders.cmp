                                                            <div class="col-md-6">
                                                                <label class="slds-form-element__label" for="input-02">Quantity Built<span class="newcls68"> *</span></label>
                                                                <lightning:input type="text" variant="label-hidden" value="{!v.WO2Fin.ERP7__Quantity_Built__c}"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="modal-footer newcls70">
                                                        <button type="button" onclick="{!c.FinishWO}" class="slds-button slds-button--brand">Save</button>
                                                        <button type="button" class="slds-button slds-button--neutral newcls71" onclick="closeFinishModal" >Close</button>
                                                    </div>
                                                </div>
                                                
                                            </div>
                                        </div>
                                        <!--Finish Modal END-->
                                        <div class="slds-backdrop" aura:id="newTaskModalBackdrop"></div>
                                    </div>
                                    <!-- tab 1 --><!-- Tab 2 -->
                                    <div class="{!(v.timeTrackingTab)?'slds-show':'slds-hide'}" id="timetracking" role="tabpanel">
                                        <div class="panel-body newcls72">
                                            <div class="card shadow-sm newcls9">
                                                <div class="card-body">
                                                    <div class="row slds-p-around--xx-small">
                                                        <div class="col-md-6">
                                                            <div class="slds-form--inline">
                                                                <div class="slds-form-element">
                                                                    <label class="slds-form-element__label pt-0" for="text-input-01" >
                                                                        <strong>Planned Date:</strong>
                                                                    </label>
                                                                    <div class="slds-form-element__control">
                                                                        From 
                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Planned_Date_From__c}" />
                                                                        to 
                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Planned_Date_To__c}" />
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="slds-form--inline">
                                                                <div class="slds-form-element">
                                                                    <label class="slds-form-element__label" for="text-input-01">
                                                                        <strong>
                                                                            Expected Duration:
                                                                        </strong>
                                                                    </label>
                                                                    <div class="slds-form-element__control">
                                                                        {!v.ExpectedDuration}
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="slds-form--inline">
                                                                <div class="slds-form-element">
                                                                    <label class="slds-form-element__label pt-0" for="text-input-01">
                                                                        <strong>Effective Date:</strong>
                                                                        </label>
                                                                    <div class="slds-form-element__control">
                                                                        From 
                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Start_Date__c}" />
                                                                        to 
                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__End_Date__c}" />
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="slds-form--inline">
                                                                <div class="slds-form-element">
                                                                    <label class="slds-form-element__label newcls74" for="text-input-01" >
                                                                        <strong>Real Duration:</strong>
                                                                        </label>
                                                                    <div class="slds-form-element__control newcls75">
                                                                        {!v.RealDuration}
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="table-responsive newcls76" tabindex="1" >
                                                        <table class="table"> 
                                                            <thead>
                                                                <tr class="slds-text-title--caps">
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" >Name</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" >Start Time</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" >End Time</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" >Duration(Hrs)</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2">Employee</div>
                                                                    </th>
                                                                </tr>
                                                            </thead>
                                                            <aura:iteration var="TCE" indexVar="TCEC" items="{!v.TimeCardEntries}">
                                                                <tbody>
                                                                    <tr>
                                                                        <td scope="row" data-label="Name">
                                                                            <div class="slds-truncate2" title="">{!TCE.Name}</div>
                                                                        </td>
                                                                        <td scope="row" data-label="Start Date">
                                                                            <div class="slds-truncate2" title="">
                                                                                <lightning:formattedDateTime value="{!TCE.ERP7__Start_Time__c}" />
                                                                            </div>
                                                                        </td>
                                                                        <td data-label="End Date">
                                                                            <div class="slds-truncate2" title="">
                                                                                <lightning:formattedDateTime value="{!TCE.ERP7__End_Time__c}" />
                                                                            </div>
                                                                        </td>
                                                                        <td data-label="Total Hours">
                                                                            <div class="slds-truncate2" title="">{!TCE.ERP7__Hours__c}</div>
                                                                        </td>
                                                                        <td data-label="Employee">
                                                                            <div class="slds-truncate2" title="">{!TCE.ERP7__Timesheet__r.ERP7__Employees__r.Name}</div>
                                                                        </td>
                                                                    </tr>
                                                                </tbody>
                                                            </aura:iteration>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- @end of Tab 2 --><!-- Tab 3 -->
                                    <div class="{!(v.currentProductionTab)?'slds-show':'slds-hide'}" id="currentproduction" role="tabpanel">
                                        <div class="panel-body newcls72">
                                            
                                            <div class="row">
                                                
                                                <div class="col-md-6">
                                                    <div class="card shadow-sm newcls9">
                                                        <div class="card-body">
                                                            <h4 class="slds-p-bottom--x-small"><strong>Products to Produce</strong></h4>
                                                            <div class="table-responsive newcls76" tabindex="1" >
                                                                <table class="table">
                                                                    <thead>
                                                                        <tr class="slds-text-title--caps">
                                                                            <th class="slds-is-sortable " scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    Product
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    QNTY
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    UOM
                                                                                </div>
                                                                            </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        <tr class="slds-hint-parent">
                                                                            <td scope="row" data-label="Products">
                                                                                <div class="slds-truncate2" title=""> {!v.ManuOrder.ERP7__Product__r.Name} </div>
                                                                            </td>
                                                                            <td data-label="Quantity">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Quantity__c} 
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="UOM">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Product__r.ERP7__UoM__c}(s)
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>     
                                                <div class="col-md-6">
                                                    <div class="card shadow-sm newcls9">
                                                        <div class="card-body">
                                                            <h4 class="slds-p-bottom--x-small"><strong>Finished Products</strong></h4>
                                                            <div class="table-responsive newcls76" tabindex="1" >
                                                                <table class="table">
                                                                    <thead>
                                                                        <tr class="slds-text-title--caps">
                                                                            <th class="slds-is-sortable " scope="col">
                                                                                <div class="slds-truncate2">
                                                                                    Product
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    QNTY
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    UOM
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    Destination
                                                                                </div>
                                                                            </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        <tr class="slds-hint-parent">
                                                                            <td scope="row" data-label="Products">
                                                                                <div class="slds-truncate2" title="">
                                                                                    {!v.ManuOrder.ERP7__Product__r.Name}
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Quantity">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Manufactured_Quantity__c} 
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="UOM">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Product__r.ERP7__UoM__c}(s)
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Destination">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Routing__r.ERP7__Finished_Products_Site__r.Name}
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            <h4 class="slds-p-bottom--x-small slds-p-top--x-small"><strong>Scrapped Products</strong></h4>
                                                            <div class="table-responsive newcls76" tabindex="1" >
                                                                <table class="table">
                                                                    <thead>
                                                                        <tr class="slds-text-title--caps">
                                                                            <th class="slds-is-sortable " scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    Product
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    QNTY
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    UOM
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    Destination
                                                                                </div>
                                                                            </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        <tr class="slds-hint-parent">
                                                                            <td scope="row" data-label="Products">
                                                                                <div class="slds-truncate2" title="">
                                                                                    {!v.ManuOrder.ERP7__Product__r.Name}
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Quantity">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Scrapped_Quantity__c} 
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="UOM">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Product__r.ERP7__UoM__c}(s)
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Destination">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!v.ManuOrder.ERP7__Routing__r.ERP7__Finished_Products_Site__r.Name}
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <!-- @end of Tab 3 --><!-- Tab 4 -->
                                    <div class="{!(v.serialorBatchesTab)?'slds-show':'slds-hide'}" id="SB" role="tabpanel">
                                        <div class="panel-body row">
                                            
                                            <div class="col-md-6 slds-m-bottom--large">
                                                <div class="card shadow-sm newcls9">
                                                    <div class="card-body">
                                                        <h4 class="newcls77">Serial Numbers</h4>
                                                        <table class="table table-condensed slds-max-medium-table--stacked-horizontal">
                                                            <thead>
                                                                <tr class="slds-text-heading--label newcls78">
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" title="Serial Number ">Serial No.</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" title="Date of Manufacture">DOM.</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2 slds-p-left--medium" title="pdf">Label</div>
                                                                    </th>
                                                                </tr>
                                                            </thead>
                                                            <aura:renderIf isTrue="{!(v.moSerialNos.length > 0)}">
                                                                <tbody class="newcls78">
                                                                    <aura:iteration var="Serial" indexVar="serialCounts" items="{!v.moSerialNos}">
                                                                        <tr>
                                                                            <td data-label="Serial Number">
                                                                                <div class="slds-truncate2" title="{!Serial.ERP7__Serial_Number__c}">
                                                                                    <lightning:formattedText value="{!Serial.ERP7__Serial_Number__c}" />
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Date of Manufacture">
                                                                                <div class="slds-truncate2" title="{!Serial.ERP7__Date_of_Manufacture__c}">
                                                                                    <lightning:formattedDateTime value="{!Serial.ERP7__Date_of_Manufacture__c}" />
                                                                                </div>
                                                                            </td>
                                                                            <td>
                                                                                <div class="" title="pdf">
                                                                                    <table width="260" border="0">
                                                                                        <tr>
                                                                                            <td> <iframe src="{!'/apex/ERP7__MOLabel?core.apexpages.devmode.url=1&amp;RId=' + Serial.Id}" class="newcls79" frameBorder="0" /> </td>
                                                                                        </tr>
                                                                                    </table>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </aura:iteration>
                                                                </tbody>
                                                            </aura:renderIf>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6 slds-m-bottom--large">
                                                <div class="card shadow-sm newcls9">
                                                    <div class="card-body">
                                                        <h4 class="newcls77">Batches</h4>
                                                        <table class="table table-condensed slds-max-medium-table--stacked-horizontal">
                                                            <thead>
                                                                <tr class="slds-text-heading--label newcls78">
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" title="Batch Number">Batch No.</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2" title="Date of Manufacture">DOM.</div>
                                                                    </th>
                                                                    <th scope="col">
                                                                        <div class="slds-truncate2 slds-p-left--medium" title="pdf">Label</div>
                                                                    </th>
                                                                </tr>
                                                            </thead>
                                                            <aura:renderIf isTrue="{!(v.moBatchNos.length > 0)}">
                                                                <aura:iteration var="SLN" indexVar="counts" items="{!v.moBatchNos}">
                                                                    <tbody>
                                                                        <tr class="slds-hint-parent newcls78">
                                                                            <td>
                                                                                <div class="slds-truncate2 newcls80" title="SLN"  id="{!SLN.Id}">
                                                                                    <a href="{!'/'+ SLN.Id}" target="_blank" class="Name newcls81">
                                                                                        <lightning:formattedText value="{!SLN.Name}" />
                                                                                    </a>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Date of Manufacture">
                                                                                <div class="slds-truncate2" title="{!SLN.ERP7__Date_of_Manufacture__c}">
                                                                                    <lightning:formattedDateTime value="{!SLN.ERP7__Date_of_Manufacture__c}" />
                                                                                </div>
                                                                            </td>
                                                                            <td>
                                                                                <div class="" title="pdf">
                                                                                    <table width="260" border="0">
                                                                                        <tr>
                                                                                            <td> <iframe src="{!'/apex/ERP7__MOLabel?core.apexpages.devmode.url=1&amp;RId=' + SLN.Id}" class="newcls79" frameBorder="0" /> </td>
                                                                                        </tr>
                                                                                    </table>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </aura:iteration>
                                                            </aura:renderIf>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- @end of tab 4 -->
                                    <div class="{!(v.signatureTab)?'slds-show':'slds-hide'}" id="Signature" role="tabpanel" >
                                        <div class="panel-body newcls82" id="sigbody" >
                                            <aura:renderIf isTrue="{!v.WorkOrder.ERP7__Is_Signature_Required__c}">
                                                <div class="row m-0 mt-1">
                                                    <aura:renderIf isTrue="{!v.Signatures.length == 0}">
                                                        <div class="col-md-6 p-0">
                                                            <div class="shadow-sm" >
                                                                <c:ESignature aura:id="signatureEXs" parentID="{!v.WorkOrder.Id}" Name="Signature" minWidth="0.5" maxWidth="1.5" id="{!v.WorkOrder.Id}"/>
                                                            </div>
                                                        </div>
                                                    </aura:renderIf>
                                                    
                                                    <aura:renderIf isTrue="{!v.Signatures.length > 0}">    
                                                        <aura:iteration var="AT" indexVar="ATC" items="{!v.Signatures}">
                                                            <div class="card mb-2">
                                                                <div class="card-body">
                                                                    <div class="slds-grid">
                                                                        <div class="slds-col">
                                                                            
                                                                            <p class="slds-item_label slds-text-color_weak slds-truncate m-0 newcls83">
                                                                                <!--<strong >Signature</strong> <br/><br/>-->
                                                                                <img src="{!'/servlet/servlet.FileDownload?file='+AT.Id}" class="newcls84"/><br/><br/>
                                                                                (<lightning:formattedText value="{!AT.Owner.Name}"/>) &nbsp; &nbsp; <lightning:formattedDateTime value="{!AT.CreatedDate}"/>
                                                                            </p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </aura:iteration>
                                                    </aura:renderIf>
                                                </div>
                                            </aura:renderIf>
                                        </div>
                                    </div>
                                    <!-- Tab 5 -->
                                    <div class="{!(v.MRPSTab)?'slds-show':'slds-hide'}" id="mrps" role="tabpanel">
                                        <div class="panel-body newcls85">
                                            <div class="row slds-m-top--small">
                                                <div class="col-md-7">
                                                    <h1 class="newcls77">Bill of Materials (BOMs) to Consume &nbsp; &nbsp; &nbsp; &nbsp;
                                                        <aura:if isTrue="{!greaterthan(v.MRPs.length,0)}">
                                                            <div class="maqdropdown">
                                                                <a class="slds-button slds-button--brand dropdown-toggle" href="javascript:void(0)"  onclick="{!c.SelectMRP1}" data-toggle="modal" data-target="#WeightCapture" title="Weight Capture"> 
                                                                    <i class="fa fa-calculator" aria-hidden="true"></i> &nbsp; Stock Allocation <span class="caret"></span>
                                                                </a>
                                                                <div class="maqdropdown-content">
                                                                    <aura:renderIf isTrue="{!not(v.ReserveStock)}"> 
                                                                        <a  href="" target="_blank" aria-haspopup="true" data-toggle="dropdown" class="newcls86"> 
                                                                            &nbsp;Auto Stock Allocation
                                                                        </a>
                                                                    </aura:renderIf>
                                                                    <aura:renderIf isTrue="{!v.ReserveStock}"> 
                                                                        <a  href="" target="_blank" aria-haspopup="true" data-toggle="dropdown" onclick="{!c.ReserveMRPStocks}" class="newcls86"> 
                                                                            &nbsp;Auto Stock Allocation 
                                                                        </a>
                                                                    </aura:renderIf>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </h1>
                                                    <table class="slds-table slds-table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                        <thead>
                                                            <tr class="slds-text-title--caps">
                                                                <th class="slds-is-sortable  newcls70" scope="col" >
                                                                    <div class="newcls87" >
                                                                        <a href="javascript:void(0)" data-toggle="modal" data-target="#myModal9" onclick="{!c.NewMRP}" title="Add MRP" class="newcls88">
                                                                            <i class="fa fa-plus"></i>&nbsp;New 
                                                                        </a> 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable " scope="col">
                                                                    <div class="slds-truncate2" >
                                                                        Product
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2">
                                                                        Status
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2">
                                                                        QTY
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2">
                                                                        UOM
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2">
                                                                        Fulfilled
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2" >
                                                                        Stock 
                                                                    </div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                            <aura:renderIf isTrue="{!bo.Feature.Name != undefined}" >
                                                                
                                                                <tr class="newcls89"> 
                                                                    
                                                                    <td align="center" valign="middle" colspan="10" class="newcls90">
                                                                        <div class="newcls91">
                                                                            <aura:renderIf isTrue="{!bo.Feature.Id != undefined}" >
                                                                                <h1 class="slds-text-heading_small newcls92">{!bo.Feature.Name}</h1></aura:renderIf>
                                                                        </div>    
                                                                    </td>
                                                                    
                                                                </tr>
                                                                
                                                            </aura:renderIf> 
                                                            <tbody>
                                                                <tr class="slds-hint-parent" >
                                                                    <td class="slds-is-sortable newcls93" scope="col" >
                                                                        <div class="slds-grid slds-truncate2" name="{!i}">
                                                                            <div class="slds-col">
                                                                                <lightning:button onclick="{!c.EditMRP}" class="neutralC" name="{!i}" >
                                                                                    <a href="javascript:void(0)" title="Edit Product" class="newcls94">
                                                                                        <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" class="newcls95" />  
                                                                                    </a>
                                                                                </lightning:button>
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td  data-label="Purchase Order" valign="middle" class="newcls96">
                                                                        <div class="slds-truncate2" title="">
                                                                            
                                                                            <span class="newcls97">{!bo.MRP.ERP7__MRP_Product__r.Name}</span>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.MRP.ERP7__Status__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.MRP.ERP7__Total_Amount_Required__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                <a href="javascript:void(0)" data-mrpcount="{!i}" class="newcls99" onclick="{!c.SelectMRP}" data-toggle="modal" data-target="#WeightCapture" title="Weight Capture" >
                                                                                    {!bo.MRP.ERP7__Fulfilled_Amount__c} 
                                                                                </a> 
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock " valign="middle"  class="{!bo.bgColor}">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.Stock}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td valign="middle" class="newcls100">
                                                                        <aura:If isTrue="{!and(bo.MO.Id == undefined, bo.MRP.ERP7__MRP_Product__r.ERP7__Issue_Manufacturing_Order__c == true)}">
                                                                            <div class="erp_Mark7 slds-no-flex newcls101">
                                                                                <div class="dropdown">
                                                                                    <lightning:buttonMenu alternativeText="Show menu" iconSize="small" variant="border-filled" onselect="{! c.handlemenu }">
                                                                                        <lightning:menuItem value="{!bo.MRP.Id}" title="MO" label="Create Manufacturing Order" />
                                                                                    </lightning:buttonMenu>
                                                                                </div>
                                                                            </div>
                                                                        </aura:If>
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </aura:iteration>
                                                        <tr class="newcls103">
                                                            <td colspan="10" class="newcls70">
                                                                &nbsp;
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                                <div class="col-md-5">
                                                    <h1 class="newcls77">Consumed Bill of Materials (BOMs) &nbsp; &nbsp; &nbsp; &nbsp; 
                                                        <img id="spinss" src="/resource/ERP7__SLDS0121/assets/images/spinners/slds_spinner_brand.gif" class="newcls104" />
                                                    </h1>
                                                    <table class="slds-table slds-table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                        <thead>
                                                            <tr class="slds-text-title--caps">
                                                                <th class="slds-is-sortable " scope="col">
                                                                    <div class="slds-truncate2">
                                                                        Product
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2" >
                                                                        Consumed
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2" >
                                                                        Scrapped
                                                                    </div>
                                                                </th>
                                                            </tr>
                                                            <div class="newcls87" ></div>
                                                        </thead>
                                                        <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                            <aura:renderIf isTrue="{!bo.Feature.Name != undefined}" >
                                                                
                                                                <tr class="newcls89"> 
                                                                    
                                                                    <td align="center" valign="middle" colspan="10" class="newcls90">
                                                                        <div class=" newcls91">
                                                                            <aura:renderIf isTrue="{!bo.Feature.Id != undefined}" >
                                                                                <h1 class="slds-text-heading_small newcls92">{!bo.Feature.Name}</h1></aura:renderIf>
                                                                        </div>    
                                                                    </td>
                                                                    
                                                                </tr>
                                                                
                                                            </aura:renderIf> 
                                                            <tbody>
                                                                <tr class="slds-hint-parent">
                                                                    <td  data-label="Purchase Order" class="newcls105">
                                                                        <div class="slds-truncate2" title="">{!bo.MRP.ERP7__MRP_Product__r.Name}  </div>
                                                                    </td>
                                                                    <td data-label="Quantity" class="newcls98">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.MRP.ERP7__Consumed_Quantity__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls100">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control">
                                                                                {!bo.MRP.ERP7__Scrapped_Quantity__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </aura:iteration>
                                                        <tr class="newcls103">
                                                            <td colspan="10" class="newcls70">
                                                                &nbsp;
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- popup Weight Capture starts here-->
                                        <div id="WeightCapture" aura:id="stockAllocationModal" class="slds-modal" role="dialog">
                                            <div class="modal-dialog modal-lg">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    
                                                    <div class="modal-header ">
                                                        <div class="{!if(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c || v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c,'newcls106','newcls107')}">
                                                            <button type="button" class="close newcls109" onclick="{!c.closeStockAllocationModal}" >x</button>
                                                            
                                                            <aura:renderIf isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                <div class="slds-grid newcls108"> 
                                                                    <div class="slds-col slds-m-top--medium newcls110">
                                                                        <span class="slds-text-heading_xx-small"><strong class="newcls111">Serial (MO) </strong>
                                                                            <span class="newcls68">*</span></span> 
                                                                    </div>
                                                                    <div class="slds-col slds-m-top--x-small  newcls112"  onclick="{!c.lookupClickSerialFor}">
                                                                        <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisn" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Serial__c}"
                                                                                             qry="{!v.qry}" />
                                                                    </div>
                                                                </div>     
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!and(!v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c,v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}"> 
                                                                <div class="slds-grid newcls108">
                                                                    <div class="slds-col slds-m-top--medium newcls110">
                                                                        <span class="slds-text-heading_xx-small"> <strong class="newcls111">Batch (MO)</strong>
                                                                            <span class="newcls68">*</span></span> 
                                                                    </div>  
                                                                    
                                                                    <div class="slds-col slds-m-top--x-small newcls112" onclick="{!c.lookupClickBatchFor}">
                                                                        
                                                                        <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solibt" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c}"  qry="{!v.qry}" />
                                                                        
                                                                    </div>
                                                                </div>
                                                            </aura:renderIf>
                                                        </div>
                                                    </div>
                                                    <div class="modal-body newcls113">
                                                        <h2 class=" slds-m-right-small slds-align-middle newcls114">{!v.WeightPopupErrorMsg}</h2>
                                                        <div class=" slds-m-top--xx-small">
                                                            <div class="row">
                                                                <div class="col-md-4 slds-m-top--small newcls115">
                                                                    <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                                        <!--<aura:renderIf isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'gram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'kilogram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'milligram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'lbs')}">-->
                                                                        <article class="{!if(bo.isSelect,'slds-card card-hover active-card newcls36','slds-card card-hover newcls36')}"  data-mrpcount="{!i}" onclick="{!c.SelectMRP}">
                                                                            <div class="slds-card__header slds-grid" >
                                                                                <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                                                    <div class="slds-media__body">
                                                                                        <h2 class="slds-card__header-title"> 
                                                                                            <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" title="Accounts">
                                                                                                <span class="slds-text-heading_small">
                                                                                                    <div class="slds-truncate newcls80" title="Product" id="{!bo.MRP.ERP7__MRP_Product__c}">
                                                                                                        <lightning:formattedText value="{!bo.MRP.ERP7__MRP_Product__r.Name}" title="{!bo.MRP.ERP7__MRP_Product__c}"/>
                                                                                                        <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c != undefined)}">
                                                                                                            &nbsp;&nbsp;<img src="{!bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c}" class="newcls116" />
                                                                                                        </aura:renderIf>    
                                                                                                    </div>
                                                                                                </span>
                                                                                            </a> 
                                                                                        </h2>
                                                                                    </div>
                                                                                </header>
                                                                            </div>
                                                                            
                                                                            <div class="slds-card__body slds-card__body_inner newcls117"> 
                                                                                <div class="row">
                                                                                    <div class="col-md-5 slds-p-around--x-small"> <span class="slds-text-heading-small"><strong>Expected  :</strong></span><br/> </div>
                                                                                    <div class="col-md-7 slds-p-around--x-small"> 
                                                                                        <span class="slds-text-heading-small">
                                                                                            
                                                                                            {!bo.MRP.ERP7__Expected_Quantity__c} 
                                                                                            <aura:renderIf isTrue="{!(bo.MRP.ERP7__Minimum_Variance__c > 0 || bo.MRP.ERP7__Maximum_Variance__c > 0)}">
                                                                                                ({!bo.MRP.ERP7__Expected_Quantity__c-bo.MRP.ERP7__Minimum_Variance__c}-{!bo.MRP.ERP7__Expected_Quantity__c+bo.MRP.ERP7__Maximum_Variance__c})
                                                                                            </aura:renderIf>
                                                                                            &nbsp;{!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} 
                                                                                            <!--&nbsp;{!bo.MRP.ERP7__BOM__r.ERP7__Exact_Quantity__c}-->
                                                                                            
                                                                                        </span>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="row">
                                                                                    <div class="col-md-5 slds-p-around--x-small"> <span class="slds-text-heading-small">
                                                                                        <strong>Stock  :</strong></span><br/> </div>
                                                                                    <div class="col-md-7 slds-p-around--x-small"> 
                                                                                        <span class="slds-text-heading-small">
                                                                                            
                                                                                            {!bo.Stock} &nbsp;{!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} 
                                                                                            
                                                                                        </span>
                                                                                        <br/>
                                                                                    </div>
                                                                                </div>
                                                                                
                                                                            </div>
                                                                            
                                                                        </article>
                                                                        <!--</aura:renderIf>-->
                                                                    </aura:iteration>
                                                                </div>
                                                                <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                                    <aura:renderIf isTrue="{!(bo.isSelect)}">
                                                                        <div class="col-md-8 slds-m-top--small">
                                                                            <article class="slds-card">
                                                                                <div class="slds-card__header slds-grid">
                                                                                    <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                                                        <div class="row">
                                                                                            <div class="col-md-8">
                                                                                                <div class="slds-media__body slds-text-align--center">
                                                                                                    <h2 class="slds-text-heading_small digitalregular newcls118">
                                                                                                        <!--<lightning:input type="text" variant="label-hidden" class="digitalregular slds-text-align-center" value="{!v.WeightStr}" />-->
                                                                                                        <input type="text" id="WeightStr" class="digitalregular slds-text-align--center newcls119" value="{!v.WeightStr}" />
                                                                                                        <lightning:input type="number" variant="label-hidden" step="0.01" class="digitalregular slds-text-align--center invisi" value="{!v.Weight}"/>
                                                                                                    </h2>
                                                                                                </div>
                                                                                                
                                                                                                
                                                                                                <aura:if isTrue="{!(and(v.WCAP,bo.MRP.ERP7__Maximum_Variance__c > 0, (bo.MRP.ERP7__Maximum_Variance__c + bo.MRP.ERP7__Expected_Quantity__c) > bo.ActualWeight) || and(!(bo.MRP.ERP7__Maximum_Variance__c > 0), bo.MRP.ERP7__Expected_Quantity__c > bo.ActualWeight))}">
                                                                                                    <button class="slds-button slds-button--brand newcls50" onclick="{!c.CaptureWeight}">Capture</button>
                                                                                                    <aura:set attribute="else"> <button class="slds-button branddisabled newcls50" disabled="">Capture</button> </aura:set>
                                                                                                </aura:if>
                                                                                                
                                                                                            </div>
                                                                                            <div class="col-md-4 slds-m-top--small newcls18">
                                                                                                <aura:renderIf isTrue="{!and(!bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c, !bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                    <span class="slds-text-heading_xx-small"><strong>Batch/Serial </strong></span>  <br/> <div class="slds-m-top--x-small"><input class="" disabled="true"></input></div>
                                                                                                </aura:renderIf>
                                                                                                <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                                    <span class="slds-text-heading_xx-small"><strong>Batch/Serial </strong><span class="newcls68">*</span></span>  <br/> <div class="slds-m-top--x-small" onclick="{!c.lookupClickSerial}"><c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisn" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Serial__c}"  qry="{!v.qry}"/></div>
                                                                                                </aura:renderIf>
                                                                                                <aura:renderIf isTrue="{!and(!bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c,bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                    <span class="slds-text-heading_xx-small"> <strong>Batch/Serial</strong><span class="newcls68">*</span></span> <br/> <div class="slds-m-top--x-small" onclick="{!c.lookupClickBatch}"><c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solib" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Material_Batch_Lot__c}" qry="{!v.qry}"/></div>
                                                                                                </aura:renderIf>
                                                                                                <img id="weightspins" src="/resource/ERP7__SLDS0121/assets/images/spinners/slds_spinner_brand.gif" class="newcls120"/>
                                                                                                
                                                                                                
                                                                                            </div>
                                                                                        </div>
                                                                                    </header>
                                                                                    
                                                                                </div>
                                                                                
                                                                            </article>
                                                                            <div class="row">
                                                                                
                                                                                <div class="col-md-12 slds-p-top--xx-small">
                                                                                    
                                                                                    <article class="{!if(bo.isSelect,'slds-card newcls36','slds-card newcls36')}" data-mrpcount="{!i}" onclick="{!c.SelectMRP}">
                                                                                        <div class="slds-card__header slds-grid" >
                                                                                            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                                                                <div class="slds-media__body" >
                                                                                                    <h2 class="slds-card__header-title"> 
                                                                                                        <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" title="Accounts">
                                                                                                            <span class="slds-text-heading_small">
                                                                                                                <div class="slds-truncate newcls80" title="Product" id="{!bo.MRP.ERP7__MRP_Product__c}">
                                                                                                                    <lightning:formattedText value="{!bo.MRP.ERP7__MRP_Product__r.Name}" click="{!c.NavRecord}" title="{!bo.MRP.ERP7__MRP_Product__c}"/>
                                                                                                                    <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c != undefined)}">
                                                                                                                        &nbsp;&nbsp;<img src="{!bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c}" class="newcls116" />
                                                                                                                    </aura:renderIf> 
                                                                                                                </div>
                                                                                                            </span>
                                                                                                        </a> 
                                                                                                    </h2>
                                                                                                    
                                                                                                </div>
                                                                                                <div class="slds-col slds-no-flex slds-grid slds-align-middle  slds-p-bottom_xx-small">
                                                                                                    <div class="slds-m-right--x-small">
                                                                                                        <span class="slds-text-heading_xx-small slds-truncate1 "> 
                                                                                                            <aura:renderIf isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Exact_Quantity__c)}">
                                                                                                                <strong>BOM :</strong>&nbsp; {!bo.MRP.ERP7__BOM__r.ERP7__Quantity__c}
                                                                                                                <aura:renderIf isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Minimum_Variance__c > 0 || bo.MRP.ERP7__BOM__r.ERP7__Maximum_Variance__c > 0)}">
                                                                                                                    ({!bo.MRP.ERP7__BOM__r.ERP7__Quantity__c-bo.MRP.ERP7__BOM__r.ERP7__Minimum_Variance__c}-{!bo.MRP.ERP7__BOM__r.ERP7__Quantity__c+bo.MRP.ERP7__BOM__r.ERP7__Maximum_Variance__c})
                                                                                                                </aura:renderIf><br/>
                                                                                                            </aura:renderIf></span>
                                                                                                        <div class="slds-grid">
                                                                                                            <div class="slds-col slds-text-heading_xx-small slds-truncate1 newcls121">
                                                                                                                <strong>Actual :</strong>&nbsp; {!bo.MRP.ERP7__Total_Amount_Required__c}&nbsp;{!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}<br/>
                                                                                                            </div>
                                                                                                            <div class="slds-col slds-text-heading_xx-small slds-truncate1">
                                                                                                                <strong>Added :</strong>&nbsp; {!bo.ActualWeight}&nbsp;{!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                                                            </div>
                                                                                                        </div>		
                                                                                                    </div>
                                                                                                </div>
                                                                                            </header>
                                                                                        </div>
                                                                                        
                                                                                        <div class="slds-card__body slds-card__body_inner newcls122"> 
                                                                                            <div class="row">
                                                                                                <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                                                                    <thead>
                                                                                                        <tr class="slds-text-title--caps">
                                                                                                            <th class="slds-is-sortable " scope="col" height="30px">
                                                                                                                <div class="slds-truncate"> Action </div>
                                                                                                            </th>
                                                                                                            <th class="slds-is-sortable " scope="col">
                                                                                                                <div class="slds-truncate"> Name </div>
                                                                                                            </th>
                                                                                                            <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                                <th class="slds-is-sortable " scope="col">
                                                                                                                    <div class="slds-truncate"> Batch </div>
                                                                                                                </th>
                                                                                                            </aura:renderIf>
                                                                                                            <aura:renderIf isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                                <th class="slds-is-sortable " scope="col">
                                                                                                                    <div class="slds-truncate"> Batch(MO) </div>
                                                                                                                </th>
                                                                                                            </aura:renderIf>
                                                                                                            <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                                                <th class="slds-is-sortable" scope="col">
                                                                                                                    <div class="slds-truncate"> Serial</div>
                                                                                                                </th>
                                                                                                            </aura:renderIf>
                                                                                                            <aura:renderIf isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                                                <th class="slds-is-sortable" scope="col">
                                                                                                                    <div class="slds-truncate"> Serial(MO)</div>
                                                                                                                </th>
                                                                                                            </aura:renderIf>
                                                                                                            <th class="slds-is-sortable" scope="col">
                                                                                                                <div class="slds-truncate"> QTY </div>
                                                                                                            </th>
                                                                                                        </tr>
                                                                                                    </thead>
                                                                                                    <aura:iteration items="{!bo.SOLIs}" var="soli" indexVar="i">
                                                                                                        <tbody>
                                                                                                            <tr class="slds-hint-parent">
                                                                                                                <td class="slds-is-sortable " scope="col" height="30px">
                                                                                                                    <div class="slds-grid slds-truncate" name="{!i}">
                                                                                                                        <div class="slds-col">
                                                                                                                            <lightning:button onclick="{!c.DeleteRecordSOLI}" class="neutralC" name="{!soli.Id}"> <a href="javascript:void(0)" title="delete" class="newcls123">
                                                                                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="newcls95" />  
                                                                                                                                </a> </lightning:button>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </td>
                                                                                                                <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                                    <div class="slds-form-element">
                                                                                                                        <div class="slds-form-element__control"> {!soli.Name} </div>
                                                                                                                    </div>
                                                                                                                </td>
                                                                                                                <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                                        <div class="slds-form-element">
                                                                                                                            <div class="slds-form-element__control"> {!soli.ERP7__Material_Batch_Lot__r.Name} </div>
                                                                                                                        </div>
                                                                                                                    </td>
                                                                                                                </aura:renderIf>
                                                                                                                <aura:renderIf isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}">
                                                                                                                    <td data-label="Quantity" valign="middle" class="newcls98;">
                                                                                                                        <div class="slds-form-element">
                                                                                                                            <div class="slds-form-element__control"> {!soli.ERP7__MO_WO_Material_Batch_Lot__r.Name} </div>
                                                                                                                        </div>
                                                                                                                    </td>
                                                                                                                </aura:renderIf>
                                                                                                                <aura:renderIf isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                                        <div class="slds-form-element">
                                                                                                                            <div class="slds-form-element__control"> {!soli.ERP7__Serial__r.Name} </div>
                                                                                                                        </div>
                                                                                                                    </td>
                                                                                                                </aura:renderIf>
                                                                                                                <aura:renderIf isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                                        <div class="slds-form-element">
                                                                                                                            <div class="slds-form-element__control"> {!soli.ERP7__MO_WO_Serial__r.Name} </div>
                                                                                                                        </div>
                                                                                                                    </td>
                                                                                                                </aura:renderIf>
                                                                                                                <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                                    <div class="slds-form-element">
                                                                                                                        <div class="slds-form-element__control"> {!soli.ERP7__Quantity__c} </div>
                                                                                                                    </div>
                                                                                                                </td>
                                                                                                            </tr>
                                                                                                        </tbody>
                                                                                                    </aura:iteration>
                                                                                                </table>
                                                                                            </div>
                                                                                            
                                                                                        </div>
                                                                                        
                                                                                    </article>
                                                                                    
                                                                                </div>   
                                                                            </div> 
                                                                        </div>
                                                                    </aura:renderIf>
                                                                </aura:iteration>    
                                                                
                                                            </div>
                                                        </div>
                                                        
                                                    </div>
                                                    <div class="modal-footer newcls70">
                                                        <button class="slds-button slds-button--brand" onclick="{!c.upsertWeights}">Save</button>
                                                        <button class="slds-button slds-button--neutral" onclick="{!c.closeStockAllocationModal}">Cancel</button>
                                                        <aura:renderIf isTrue="{!and(v.WorkOrder.ERP7__MO__c != undefined, !or(and(v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != undefined, v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != ''), and(v.NewSOLI.ERP7__MO_WO_Serial__c != undefined, v.NewSOLI.ERP7__MO_WO_Serial__c != '')))}">
                                                            <button class="btn btn-default newcls124">
                                                                <a href="{!'/apex/ERP7__MOrderLabel?MId='+v.WorkOrder.ERP7__MO__c+'&amp;ra=pdf'}" target="_blank" > 
                                                                    <i class="fa fa-print print-icon1" aria-hidden="true"></i>
                                                                </a>
                                                            </button>
                                                        </aura:renderIf>
                                                        <aura:If isTrue="{!(v.PrintSB)}">
                                                            <aura:renderIf isTrue="{!and(v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != '', v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != undefined)}">
                                                                <button class="btn btn-default newcls124">
                                                                    <a href="{!'/apex/ERP7__MOLabel1?RId='+v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c+'&amp;ra=pdf'}" target="_blank" > 
                                                                        <i class="fa fa-print print-icon1" aria-hidden="true" ></i>
                                                                    </a>
                                                                </button>
                                                            </aura:renderIf>
                                                            <aura:renderIf isTrue="{!and(v.NewSOLI.ERP7__MO_WO_Serial__c != '', v.NewSOLI.ERP7__MO_WO_Serial__c != undefined)}">
                                                                <button class="btn btn-default newcls124;">
                                                                    <a href="{!'/apex/ERP7__MOLabel1?RId='+ v.NewSOLI.ERP7__MO_WO_Serial__c+'&amp;ra=pdf'}" target="_blank" > 
                                                                        <i class="fa fa-print print-icon1" aria-hidden="true"></i>
                                                                    </a>
                                                                </button>
                                                            </aura:renderIf> 
                                                        </aura:If>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div id="myModale" aura:id="myEditMRPModal" class="slds-modal" role="dialog">
                                            <div class="modal-dialog modal-medium">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    <div class="modal-body newcls126">
                                                        <h2 class=" slds-m-right-small slds-align-middle newcls125">{!v.editErrorMsg}</h2>
                                                        <div class="row slds-m-top--xx-small">
                                                            <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                <div class="slds-form-element" >
                                                                    <label class="slds-form-element__label" for="text-input-01" > Product </label>
                                                                    <div class="slds-form-element__control">
                                                                        <lightning:formattedText value="{!v.MRPEdit.MRP.ERP7__MRP_Product__r.Name}"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                <div class="slds-form-element" >
                                                                    <label class="slds-form-element__label" for="text-input-01" > Quantity <span class="newcls68">*</span></label>
                                                                    <div class="slds-form-element__control">
                                                                        <lightning:input type="number"  variant="label-hidden"  value="{!v.MRPEdit.MRP.ERP7__Total_Amount_Required__c}" disabled="{!v.MRPEdit.MRP.ERP7__BOM__r.ERP7__Is_Protected__c}"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                <div class="slds-form-element" >
                                                                    <label class="slds-form-element__label" for="text-input-01" > Stock</label>
                                                                    <div class="slds-form-element__control">
                                                                        <lightning:input type="number"  variant="label-hidden"  value="{!v.MRPEdit.Stock}" disabled="true"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row newcls127">
                                                            <div class="col-md-12">
                                                                <h1 class="newcls128">BOM Variances</h1>
                                                            </div>
                                                        </div>
                                                        <div class="newcls129">
                                                            <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-m-top--small">
                                                                <thead>
                                                                    <tr class="slds-text-title--caps">
                                                                        <th class="slds-is-sortable " scope="col">
                                                                            <div class="slds-truncate" >
                                                                                Action
                                                                            </div>
                                                                        </th>
                                                                        <th class="slds-is-sortable " scope="col">
                                                                            <div class="slds-truncate" >
                                                                                Product
                                                                            </div>
                                                                        </th>
                                                                        <th class="slds-is-sortable" scope="col">
                                                                            <div class="slds-truncate">
                                                                                QTY
                                                                            </div>
                                                                        </th>
                                                                        <th class="slds-is-sortable" scope="col">
                                                                            <div class="slds-truncate" >
                                                                                Stock 
                                                                            </div>
                                                                        </th>
                                                                    </tr>
                                                                </thead>
                                                                <aura:iteration items="{!v.NewMRPs.MRPSS}" var="do" indexVar="y">
                                                                    <tbody>
                                                                        <tr class="slds-hint-parent" >
                                                                            <th class="slds-is-sortable newcls98" scope="col" >
                                                                                <div class="slds-truncate newcls130" name="{!y}" >
                                                                                    <lightning:input type="checkbox" checked="{!do.isSelect}" onchange="{!c.Evaluate}"/>
                                                                                </div>
                                                                            </th>
                                                                            <th scope="row" data-label="Product" class="newcls98">
                                                                                <div class="slds-truncate" title="">
                                                                                    <lightning:formattedText value="{!do.MRP.Name}"/>
                                                                                </div>
                                                                            </th>
                                                                            <td data-label="Quantity" class="newcls98">
                                                                                <div class="slds-truncate" title="">
                                                                                    <lightning:input type="number"  variant="label-hidden"  value="{!do.Qnty}" disabled="{!v.MRPEdit.MRP.ERP7__BOM__r.ERP7__Is_Protected__c}"/>
                                                                                </div>
                                                                            </td>
                                                                            <td data-label="Stock " class="newcls98">
                                                                                <div class="slds-form-element">
                                                                                    <div class="slds-form-element__control">
                                                                                        {!do.Stock}
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </aura:iteration>
                                                            </table>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12 newcls107">
                                                        <c:ProjectLookups type="Account" aura:id="OrgName" value="{!v.custInvoiceTest.ERP7__Account__c}" className="" />
                                                    </div> 
                                                    <div class="modal-footer newcls70">
                                                        <button class="slds-button slds-button--brand" onclick="{!c.updateMRPNew}">Update</button>
                                                        <button class="slds-button slds-button--neutral" onclick="{!c.closeEditMRPModal}">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="slds-modal" id="myModal9" aura:id="myMRPModal" role="dialog">
                                            <div class="modal-dialog">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    <div class="modal-header newcls69"><!--modalbg-->
                                                        <h1 class="slds-text-heading_medium slds-hyphenate newcls70">MRPs (Material Requirement Plannings)</h1>
                                                    </div>
                                                    <div class="modal-body">
                                                        <fieldset class="slds-form--compound">
                                                            <div class="slds-form-element__group">
                                                                <div class="row">
                                                                    
                                                                    <div class="col-md-6">
                                                                        <label class="slds-form-element__label" for="input-01">Name<span class="newcls68"> *</span></label>
                                                                        <lightning:input type="text" variant="label-hidden" aura:id="name" class="" value="{!v.NewMRP.Name}"/> 
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <label class="slds-form-element__label" for="input-02">Product<span class="newcls68"> *</span></label>
                                                                        <c:CustomInputLookUp objectAPIName="Product2" aura:id="bom" IconName="standard:product" selectedRecordId="{!v.NewMRP.ERP7__MRP_Product__c}" />
                                                                        
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </fieldset>
                                                        <fieldset class="slds-form--compound">
                                                            <div class="slds-form-element__group">
                                                                <div class="row">
                                                                    <div class="col-md-6">
                                                                        <label class="slds-form-element__label" for="input-02">Bill Of Material<span class="newcls68"> *</span></label>
                                                                        <c:CustomInputLookUp objectAPIName="ERP7__BOM__c" aura:id="bom" IconName="standard:orders" selectedRecordId="{!v.NewMRP.ERP7__BOM__c}" />
                                                                        
                                                                    </div>
                                                                    <div class="col-md-6 slds-m-top--xx-small">
                                                                        <label class="slds-form-element__label" for="input-03">Quantity Required<span class="newcls68"> *</span></label>
                                                                        <lightning:input type="number"  variant="label-hidden" aura:id="num" value="{!v.NewMRP.ERP7__Total_Amount_Required__c}" class=""/> 
                                                                    </div>
                                                                    
                                                                </div>
                                                                
                                                            </div>
                                                            
                                                        </fieldset>
                                                        <fieldset class="slds-form--compound">
                                                            <div class="slds-form-element__group">
                                                                <div class="row">
                                                                    
                                                                    <div class="col-md-6 slds-m-top--xx-small">
                                                                        <label class="slds-form-element__label" for="input-06">Notes</label>
                                                                        <lightning:textarea variant="label-hidden" aura:id="notes" value="{!v.NewMRP.ERP7__Notes__c}" maxlength="150"/>
                                                                    </div>
                                                                </div>
                                                                
                                                            </div>
                                                            
                                                        </fieldset>
                                                        
                                                    </div>
                                                    <div class="modal-footer slds-text-align--center newcls69">
                                                        <button class="slds-button slds-button--brand" onclick="{!c.updateMRP}">Save</button>
                                                        <button type="button" class="slds-button slds-button--neutral"  onclick="{!c.closeMRPModal}">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="slds-backdrop" aura:id="myMRPModalBackdrop"></div>
                                        <!--popup Ends Here --> 
                                    </div>
                                    <!-- @end of Tab 5 -->
                                    <div class="{!(v.resourceTab)?'slds-show':'slds-hide'}" id="ResourceAllocation" role="tabpanel">
                                        <div class="panel-body newcls85">
                                            <div class="row slds-m-top--small">
                                                <div class="col-md-12">
                                                    <h1 class="newcls77">Allocated Resources &nbsp; &nbsp; &nbsp; &nbsp; 
                                                        <div class="maqdropdown">
                                                            <a class="slds-button slds-button--brand" href="javascript:void(0)"  onclick="{!c.openResourceAllocationModal}" data-toggle="modal" data-target="#ResourceAllocationPOPUP" title="Resource Allocation"> 
                                                                <i class="fa fa-server" aria-hidden="true"></i> &nbsp; Resource Allocation <!--<span class="caret"></span>-->
                                                            </a>   
                                                        </div>
                                                    </h1>
                                                    <!-- Resource Allocation table -->
                                                    <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover" >
                                                        <thead>
                                                            <tr class="slds-text-title--caps">
                                                                <th class="slds-is-sortable " scope="col">
                                                                    <div class="slds-truncate">
                                                                        Action
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable " scope="col">
                                                                    <div class="slds-truncate">
                                                                        Name
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Resource Group 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Employee 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Machine 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Type  
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Start Date 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        End Date 
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate" >
                                                                        Hours  
                                                                    </div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <tbody class="newcls131">
                                                            <aura:iteration items="{!v.RAS}" var="RA" indexVar="i">
                                                                
                                                                <tr class="slds-hint-parent">
                                                                    <td class="slds-is-sortable newcls98" scope="row" height="47px" >
                                                                        <div class="slds-grid slds-truncate" name="{!i}">
                                                                            <div class="slds-col">
                                                                                <lightning:button onclick="{!c.DeleteRecordRA}" class="neutralC" name="{!RA.Id}">
                                                                                    <a href="javascript:void(0)" title="delete newcls123">
                                                                                        <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="newcls95" />  
                                                                                    </a>
                                                                                </lightning:button>
                                                                            </div>
                                                                        </div>
                                                                    </td> 
                                                                    <td  data-label="Purchase Order" height="47px" class="newcls98">
                                                                        <div class="slds-truncate" title="">{!RA.Name}  </div>
                                                                    </td>
                                                                    <td data-label="Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                {!RA.ERP7__Resource_Group__r.Name}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                {!RA.ERP7__Employees__r.Name}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                {!RA.ERP7__Machine__r.Name}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                {!RA.ERP7__Type__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:formattedDateTime value="{!RA.ERP7__Start_Date__c}"  /><!-- format="MMM dd, yyyy hh:mm a z" timezone="America/Los_Angeles" -->
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:formattedDateTime value="{!RA.ERP7__End_Date__c}"/>
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Stock Quantity" class="newcls98">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                {!RA.ERP7__Hours__c}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                                
                                                            </aura:iteration>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- popup Resource Allocation starts here-->
                                        <div id="ResourceAllocationPOPUP" aura:id="myResourceAllocationModal" class="slds-modal" role="dialog">
                                            <div class="modal-dialog modal-lg">
                                                <!-- Modal content-->
                                                <div class="modal-content">
                                                    <div class="modal-header newcls69"> <!--modalbg-->
                                                        <button type="button" class="close newcls132" onclick="{!c.closeResourceAllocationModal}"  >x</button>
                                                        <h1 class="slds-text-heading_medium slds-hyphenate "> <!--headertextreset-->
                                                            <span class="newcls133">
                                                                
                                                                <aura:renderIf isTrue="{!!(v.CapacityPlanner.Id != undefined)}"> Capacity planner unavailable </aura:renderIf>
                                                                <aura:renderIf isTrue="{!(v.CapacityPlanner.Id != undefined)}"> {!v.CapacityPlanner.Name}</aura:renderIf>
                                                                
                                                            </span> 
                                                        </h1>
                                                    </div>
                                                    
                                                    <aura:renderIf isTrue="{!(v.CapacityPlanner.Id != undefined)}">
                                                        <div class="modal-body newcls134">
                                                            <h2 class=" slds-m-right-small slds-align-middle newcls114" title="" >{!v.ResourcePopupErrorMsg}</h2>
                                                            <div class=" slds-m-top--xx-small">
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-m-top--small">
                                                                        <span class="newcls135">Work Planner : </span>
                                                                        <lightning:select aura:id="wpList" value="{!v.SelectedWP}" variant="label-hidden"  class="display-lable">
                                                                            <aura:iteration items="{!v.wpListOptions}" var="option">
                                                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.SelectedWP, option.value)}"/>
                                                                            </aura:iteration>
                                                                        </lightning:select>
                                                                        <div class="scrollarea-boxes newcls126">
                                                                            <aura:iteration items="{!v.WorkPlanners}" var="bo" indexVar="i">
                                                                                <aura:renderIf isTrue="{!and(v.SelectedWP == bo.WorkPlanner.Id)}"> 
                                                                                    <aura:iteration items="{!bo.RRS}" var="RS" indexVar="k">
                                                                                        <article class="{!if(RS.Id == v.selectedRR,'slds-card card-hover active-card newcls136','slds-card card-hover newcls136')}"  data-mrpcount="{!i}" data-rr="{!RS.Id}" data-rrname="{!RS.ERP7__Resource_Group__r.Name}" onclick="{!c.SelectWP}">
                                                                                            <div class="slds-card__header slds-grid" >
                                                                                                <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                                                                    <div class="slds-media__body">
                                                                                                        <h2 class="slds-card__header-title"> 
                                                                                                            <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" >
                                                                                                                <span class="slds-text-heading_small">
                                                                                                                    <div class="slds-truncate newcls80" title="Product">
                                                                                                                        <lightning:formattedText value="{!RS.ERP7__Resource_Group__r.Name}" title="{!RS.ERP7__Resource_Group__r.Name}"/> {!selectedRR}
                                                                                                                    </div>
                                                                                                                </span>
                                                                                                            </a> 
                                                                                                        </h2>
                                                                                                    </div>
                                                                                                </header>                                                                    
                                                                                            </div>    
                                                                                            <div class="newcls137">Run Time : {!RS.ERP7__Runtime__c}</div>
                                                                                        </article>
                                                                                    </aura:iteration>
                                                                                </aura:renderIf>
                                                                            </aura:iteration>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-8  newcls115">
                                                                        
                                                                        <div class="slds-media__body slds-text-align--left">
                                                                            
                                                                            <div class="row">
                                                                                <div class="col-md-12">
                                                                                    <div class="slds-grid">
                                                                                        <div class="slds-col slds-m-right--x-small">
                                                                                            <strong>From<span class="newcls68">*</span></strong>
                                                                                            <lightning:input type="datetime" variant="label-hidden" class="display-lable"  value="{!v.StartTime}" onchange="{!c.GetResources}"/>
                                                                                        </div>
                                                                                        <div class="slds-col">
                                                                                            <strong>To<span class="newcls68">*</span></strong>
                                                                                            <lightning:input type="datetime" variant="label-hidden" class="display-lable"  value="{!v.EndTime}" onchange="{!c.GetResources}"/>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="col-md-12">
                                                                                    <div class="slds-grid">
                                                                                        <div class="slds-col slds-m-right--x-small slds-m-top--xx-small">
                                                                                            <strong>Name</strong>
                                                                                            <lightning:input type="text" variant="label-hidden" value="{!v.ResourceStr}" onchange="{!c.GetResources}" placeholder="Resources"/>
                                                                                        </div>
                                                                                        <div class="slds-col slds-m-top--large">
                                                                                            <button class="slds-button slds-button--brand" onclick="{!c.GetResources}">Find</button>
                                                                                        </div>    
                                                                                    </div>                         
                                                                                </div>
                                                                            </div>
                                                                        </div>                          
                                                                        <div class="slds-card__body slds-card__body_inner newcls138"> 
                                                                            <div class="row">
                                                                                <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                                                    <thead>
                                                                                        <tr class="slds-text-title--caps">
                                                                                            <th class="slds-is-sortable "  scope="col" height="40px">
                                                                                                <div class="slds-truncate" >
                                                                                                    Action
                                                                                                </div>
                                                                                            </th>
                                                                                            
                                                                                            <th class="slds-is-sortable " scope="col">
                                                                                                <div class="slds-truncate" >
                                                                                                    Resource
                                                                                                </div>
                                                                                            </th>
                                                                                            <th class="slds-is-sortable" scope="col">
                                                                                                <div class="slds-truncate">
                                                                                                    Group
                                                                                                </div>
                                                                                            </th>
                                                                                        </tr>
                                                                                    </thead>
                                                                                    <aura:iteration items="{!v.AvailableResources}" var="AR" indexVar="i">
                                                                                        <tbody>
                                                                                            <tr class="slds-hint-parent" >
                                                                                                <td class="slds-is-sortable " scope="col" height="40px">
                                                                                                    <div class="slds-grid slds-truncate" name="{!i}">
                                                                                                        <div class="slds-col">
                                                                                                            <lightning:input type="checkbox" aura:id="checkbox" checked="{!AR.isSelect}"/> 
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </td> 
                                                                                                
                                                                                                <aura:renderIf isTrue="{!(AR.Resource.ERP7__Employee__c != undefined)}">
                                                                                                    <td data-label="Quantity" valign="middle" class="newcls98">
                                                                                                        <div class="slds-form-element">
                                                                                                            <div class="slds-form-element__control">
                                                                                                                {!AR.Resource.ERP7__Employee__r.Name}
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </td>
                                                                                                </aura:renderIf>
                                                                                                <aura:renderIf isTrue="{!(AR.Resource.ERP7__Machine__c != undefined)}">
                                                                                                    <td data-label="Quantity" valign="middle"  class="newcls98">
                                                                                                        <div class="slds-form-element">
                                                                                                            <div class="slds-form-element__control">
                                                                                                                {!AR.Resource.ERP7__Machine__r.Name}
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </td>
                                                                                                </aura:renderIf>
                                                                                                <td data-label="Group" valign="middle"  class="newcls98">
                                                                                                    <div class="slds-form-element">
                                                                                                        <div class="slds-form-element__control">
                                                                                                            {!AR.Resource.ERP7__Resource_Group__r.Name}
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </td>
                                                                                            </tr>
                                                                                        </tbody>
                                                                                    </aura:iteration>
                                                                                </table>
                                                                            </div> 
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>                         
                                                            
                                                            
                                                        </div>
                                                        
                                                        <div class="modal-footer newcls70">
                                                            <button class="slds-button slds-button--brand" onclick="{!c.upsertResources}">Save</button>
                                                            <button class="slds-button slds-button--neutral" onclick="{!c.closeResourceAllocationModal}">Cancel</button>
                                                        </div>
                                                    </aura:renderIf>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="slds-backdrop" aura:id="myResourceAllocationModalBackdrop"></div>
                                        <!--popup Ends Here --> 
                                    </div>
                                    <!-- Drawing tab-->
                                    <div class="{!(v.drawingTab)?'slds-show':'slds-hide'}" id="drawing" role="tabpanel">
                                        <div class="panel-body newcls139">
                                            <div class="row">
                                                <div class="col-md-3 slds-m-top--small">
                                                    <table class="slds-table slds-table-bordered" width="100%">
                                                        <aura:iteration var="OAs" indexVar="OA_counts" items="{!v.OperationAttachments}">
                                                            <aura:renderIf isTrue="{!(OAs.Attachments.length > 0)}">
                                                                <tr class="operation-head ">
                                                                    <td  width="90%" class="operation-headtd1"> 
                                                                        {!OAs.Operation.Name}
                                                                    </td>
                                                                    <td width="10%" class="operation-headtd2"> 
                                                                        &nbsp;
                                                                    </td>
                                                                </tr>
                                                                <aura:iteration var="As" indexVar="A_counts" items="{!OAs.Attachments}">
                                                                    <tr class="{!if(As.Id == v.Attachment.Id,'actives','')}">
                                                                        <td width="90%" name="{!A_counts}" par="{!OA_counts}" class="{!if(As.Id == v.Attachment.Id,'operation-headtd11 actives','operation-headtd11')}">
                                                                            <lightning:formattedText onclick="{!c.SelectAttachment}" value="{!As.Name}" class="{!if(As.Id == v.Attachment.Id,'actives','inactives')}"/>
                                                                        </td>
                                                                        <td width="10%" name="{!A_counts}" par="{!OA_counts}" class="{!if(As.Id == v.Attachment.Id,'operation-headtd22 actives','operation-headtd22')}">
                                                                            <lightning:formattedUrl  value="{!'/servlet/servlet.FileDownload?file='+As.Id}" target="_blank" class="{!if(As.Id == v.Attachment.Id,'fa fa-download actives','fa fa-download inactives')}"/>
                                                                        </td>
                                                                    </tr>
                                                                </aura:iteration>
                                                                <br/>                 
                                                            </aura:renderIf>
                                                        </aura:iteration>
                                                    </table>
                                                </div>
                                                <div class="col-md-9 slds-m-top--small">
                                                    <div class="list-group">
                                                        <img src="{!'/servlet/servlet.FileDownload?file='+v.Attachment.Id}" class="{!if(v.Attachment.Id != undefined,'newcls106','newcls107')}"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
        </div>
	</div>
      
           
</aura:component>