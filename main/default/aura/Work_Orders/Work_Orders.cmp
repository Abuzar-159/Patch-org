                                                            <aura:iteration var="AT" indexVar="ATC" items="{!v.SelectedNotes}">
                                                                <aura:renderIf isTrue="{!(AT.ParentId == v.SelectedTask.Id)}">
                                                                    <div class="slds-col text-left pt-2" data-aura-rendered-by="371:633;a">
                                                                        <div class="slds-grid" data-aura-rendered-by="373:633;a">
                                                                            <div class="slds-col" data-aura-rendered-by="374:633;a">
                                                                                <div class="slds-grid" data-aura-rendered-by="375:633;a">
                                                                                    <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!AT.Id}" title="Note">
                                                                                        <a href="javascript:void(0)" title="delete" class="newcls59">
                                                                                            <i class="fa fa-minus-circle" aria-hidden="true" data-aura-rendered-by="377:633;a"></i>
                                                                                        </a>
                                                                                    </lightning:button>
                                                                                    &nbsp;
                                                                                    <div class="slds-truncate newcls60" data-aura-rendered-by="379:633;a">
                                                                                        &nbsp;
                                                                                        <lightning:formattedUrl  value="{!'/'+AT.Id}" label="{!AT.Title}" target="_blank" class="fcolor"/>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </aura:renderIf>
                                                            </aura:iteration>
                                                            <aura:iteration var="AT" indexVar="ATC" items="{!v.SelectedAttachments}">
                                                                <aura:renderIf isTrue="{!and(AT.ParentId == v.SelectedTask.Id, AT.Name != 'Signature')}">
                                                                    <div class="card mb-2">
                                                                        <div class="card-body newcls61">
                                                                            <div class="slds-grid">
                                                                                <div class="slds-col">
                                                                                    <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!AT.Id}" title="Attachment">
                                                                                        <a href="javascript:void(0)" title="delete" class="newcls59">
                                                                                            <i class="fa fa-minus-circle" aria-hidden="true" data-aura-rendered-by="377:633;a"></i> 
                                                                                        </a>
                                                                                    </lightning:button>
                                                                                    &nbsp;
                                                                                </div>
                                                                                <div class="slds-col">
                                                                                    <lightning:formattedUrl  value="{!'/'+AT.Id}" label="{!AT.Name}" target="_blank" class="fcolor"/>
                                                                                </div>
