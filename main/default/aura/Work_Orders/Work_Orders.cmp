<aura:component controller="BuildWorkOrder" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global">
    <head>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/Work_Orders.css"/>
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-ltng.css" />
        <ltng:require styles="/resource/ERP7__bootStrap/js/bootstrap.min.js"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="/resource/ERPCustomIcons/style/erp-play.css"/>
        <ltng:require styles="{!join(',',$Resource.ERPFonts + '/src/stylesheet.css')}"  />
    </head>
    <aura:attribute name="wpListOptions" type="List"/>
    <aura:attribute name="qry" type="String"/>
    <aura:attribute name="schedulerWO" type="Boolean" default="false" />
    <aura:attribute name="NWO" type="String" />
    <aura:attribute name="PWO" type="String" /> 
    <aura:attribute name="WCAP" type="Boolean" default="true" />
    <aura:attribute name="PrintSB" type="Boolean" default="false" />
    <aura:attribute name="WeightCapture" type="Boolean" default="false"/>
    <aura:attribute name="Weight" type="Decimal" default="0.00"/>
    <aura:attribute name="TotalWeight" type="Decimal" default="0.00"/>
    <aura:attribute name="WeightPopupErrorMsg" type="String"/>
    <aura:attribute name="WeightStr" type="String" default="0"/>
    <aura:attribute name="custInvoiceTest" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}"/>
    <aura:registerEvent name="SetQRYParam" type="c:SetQRYParam"/>
    <aura:attribute name="WorkOrder" type="WO__c" default="{'sObjectType':'ERP7__WO__c','ERP7__Status__c':'Issued', 'ERP7__Quantity_Ordered__c':'0'}"/>
    <aura:attribute name="ManuOrder" type="Manufacturing_Order__c" default="{'sObjectType':'ERP7__Manufacturing_Order__c'}"/>
    <aura:attribute name="WO2Fin" type="WO__c" default="{sobjectType : 'WO__c'}"/>
    <aura:attribute name="Tasks" type="object[]"/>
    <aura:attribute name="FileList" type="object[]"/>
    <aura:attribute name="TimeCardEntries" type="object[]"/>
    <aura:attribute name="SelectedTask" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c'}"/>
    <aura:attribute name="Employee" type="object"/>
    <aura:attribute name="SelectedTask_TimeCardEntry" type="object"/>
    <aura:attribute name="TimeSheet" type="object"/>
    <aura:attribute name="NewTask" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c'}"/>
    <aura:attribute name="NewMRP" type="object"/>
    <aura:attribute name="NewNote" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="NewNoteTemp" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="NewMRPs" type="object"/>
    <aura:attribute name="Task" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c'}"/>
    <aura:attribute name="OperationAttachments" type="object[]"/>
    <aura:attribute name="SelectedAttachments" type="object[]"/>
    <aura:attribute name="SelectedNotes" type="object[]"/>
    <aura:attribute name="Attachment" type="Attachment" default="{'sObjectType':'Attachment'}"/>
    <aura:attribute name="NewSOLI" type="Stock_Outward_Line_Item__c" default="{sobjectType : 'Stock_Outward_Line_Item__c','ERP7__Material_Batch_Lot__c':'','ERP7__Serial__c':'','ERP7__MO_WO_Material_Batch_Lot__c':'','ERP7__MO_WO_Serial__c':''}"/>
    <aura:attribute name="MRPSS" type="object[]"/>
    <aura:attribute name="MRPs" type="object[]"/>
    <aura:attribute name="MRPEdit" type="object"/>
    <aura:attribute name="ReserveStock" type="Boolean" default="false"/>
    <aura:attribute name="mySerialNos" type="object[]"/>
    <aura:attribute name="myBatchNos" type="object[]"/>
    <aura:attribute name="WO" type="String"/>
    <aura:attribute name="RD" type="String"/>
    <aura:attribute name="NAV" type="String"/>
    <aura:attribute name="PID" type="String"/>
    <aura:attribute name="RID" type="String"/>
    <aura:attribute name="VER" type="String"/>
    <aura:attribute name="QUAN" type="String"/>
    <aura:attribute name="rmarecordId" type="String"/>
    <aura:attribute name="Timer" type="String" default=""/>
    <aura:attribute name="errorMsg" type="String"/>
    <aura:attribute name="errorMsgPop" type="String"/>
    <aura:attribute name="editErrorMsg" type="String"/>
    <aura:attribute name="attUrl" type="String"/>
    <aura:attribute name="ToProduce" type="Decimal" default="0"/>
    <aura:attribute name="ExpectedDuration" type="String" default=""/>
    <aura:attribute name="RealDuration" type="String" default=""/>
    <aura:attribute name="Batch" type="Boolean" default="false"/>
    <aura:attribute name="Serial" type="Boolean" default="false"/>
    <aura:attribute name="Evaluate" type="Boolean" default="false"/>
    <aura:attribute name="Permit" type="Boolean" default="false"/>
    <aura:attribute name="Busy" type="Boolean" default="false"/>
    <aura:attribute name="moSerialNos" type="object[]" />
    <aura:attribute name="moBatchNos" type="object[]" />
    <aura:attribute name="Signatures" type="object[]"/>
    <aura:attribute name="IsSignatureTab" type="Boolean" default="false"/>
    <aura:attribute name="signatureExist" type="Boolean" default="false"/>
    <aura:attribute name="checkDrawings" type="Boolean" default="false"/>
    <aura:attribute name="soliID" type="Id" default=""/>
    <aura:attribute name="soID" type="Id" default=""/>
    
    <aura:attribute name="RAS" type="object[]"/>
    <aura:attribute name="ResourcePopupErrorMsg" type="String"/>
    <aura:attribute name="ResourceStr" type="String" default=""/>
    <aura:attribute name="WorkPlanners" type="object[]"/>
    <aura:attribute name="StartTime" type="DateTime"/>
    <aura:attribute name="EndTime" type="DateTime"/>
    <aura:attribute name="AvailableResources" type="object[]" />
    <aura:attribute name="CapacityPlanner" type="object" />
    <aura:attribute name="SelectedWP" type="String" default=""/>
    <aura:attribute name="selectedRR" type="String" default=""/>
    <aura:attribute name="selectedRRName" type="String" default=""/>
    <aura:attribute name="exceptionError" type="String" default=""/>
    <aura:attribute name="warningError" type="String" default=""/>
    
    <aura:attribute name="worksheetTab" type="Boolean" default="true"/>
    <aura:attribute name="drawingTab" type="Boolean" default="false"/>
    <aura:attribute name="timeTrackingTab" type="Boolean" default="false"/>
    <aura:attribute name="MRPSTab" type="Boolean" default="false"/>
    <aura:attribute name="resourceTab" type="Boolean" default="false"/>
    <aura:attribute name="currentProductionTab" type="Boolean" default="false"/>
    <aura:attribute name="serialorBatchesTab" type="Boolean" default="false"/>
    <aura:attribute name="signatureTab" type="Boolean" default="false"/>
    <aura:attribute name="openMenu" type="Boolean" default="false"/>
    <aura:attribute name="isWOcomplete" type="Boolean" default="true"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <aura:method name="FinishMethod" action="{!c.FinishTask}"></aura:method> 
    <aura:method name="PreFinishTasks" action="{!c.PreFinishTask}"></aura:method> 
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__MO_WO_Serial__c}" action="{!c.SerialBOMValidation}"/>
    <aura:handler event="force:refreshView" action="{!c.getAllDetails}" />
    <aura:handler name="cmpEvent" event="c:SignatureEvent" action="{!c.handleSignatureEvent}"/>

    <div class="maqsood erp_Mark7 theme-bg" >
        <!--Error Message-->
        <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),' slds-notify_container slds-is-fixed newcls2',' slds-notify_container slds-is-fixed newcls3')}">
            <div class="slds-notify slds-notify_toast slds-theme_error newcls3" role="status">
                <span class="slds-assistive-text">error</span>
                <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                    <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="Error!" title="Error" />
                </span>
                <div class="slds-notify__content">
                    <h2 class="slds-text-heading_x-small newcls5" >{!v.exceptionError}
                    </h2>
                </div>
                <div class="slds-notify__close newcls6" >
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <!--Error Message End--> <!--Warning Message-->
        <div class="{!if(and(v.warningError != '', v.warningError != undefined),'slds-notify_container slds-is-fixed newcls2','slds-notify_container slds-is-fixed newcls3')}">
            <div class="slds-notify slds-notify_toast slds-theme_warning newcls4" role="status" >
                <span class="slds-assistive-text">warning</span>
                <span class="slds-icon_container slds-icon-utility-warning slds-m-right_x-small" title="Description of icon when needed">
                    <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                </span>
                <div class="slds-notify__content">
                    <h2  class="slds-text-heading_x-small newcls5" >
                        &nbsp;{!v.warningError}&nbsp;
                    </h2>
                </div>
                <div class="slds-notify__close newcls6">
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeWarning}">
                        <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                        <span class="slds-assistive-text">Close</span>
                    </button>
                </div>
            </div>
        </div>
        <!--Warning Message End-->
        <span class="newcls7">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass slds-hide"/>
        </span>
        <div class="theme-bg">
                    <div class="container-fluid erp_mark7"> 
                        <div class="card shadow-mrr mb-2 mt-2" >
                            <div class="card-body newcls10">
                                <div class="d-flex justify-content-between">
                                    <div class="slds-grid slds-wrap newcls11">
                                        <div class="col-md-4">
                                            <div class="row m-0">
                                                <div class="col-md-12 pr-0 pl-0 text-left">
                                                    <p class="text m-b-0 pt-1 BuildSchedule_M-newClass23">Maintenance :&nbsp;</p>
                                                    <div class="text m-b-0 newcls12" data-aura-rendered-by="492:0">
                                                        <lightning:formattedUrl value="{!'/'+v.WorkOrder.Id}" label="{!v.WorkOrder.Name}" target="_blank" class="fcolor"/>
                                                        <lightning:helptext content="{!'Version : '+v.WorkOrder.ERP7__Version__r.Name+' ,    Routing : '+v.WorkOrder.ERP7__Routing__r.Name}"/>
                                                    </div>
                                                </div>
                                                
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-4 pl-0 pr-0"> 
                                            <div class="row m-0">
                                                <div class="col-md-12 pr-0 pl-0 text-left">
                                                    <p class="text m-b-0 pt-1 BuildSchedule_M-newClass23">Work Center :&nbsp;</p>
                                                    <div class="text m-b-0 newcls12" data-aura-rendered-by="492:0">
                                                        <lightning:formattedUrl  value="{!'/'+v.SelectedTask.ERP7__Work_Center__c}" label="{!v.WorkOrder.ERP7__Work_Center__r.Name}" target="_blank" class="fcolor"/>
                                                    </div>
                                                    
                                                </div>
                                                
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-4">
                                            <div class="row m-0">
                                                <div class="col-md-8 pr-0 pl-0 text-left">
                                                    <p class="text m-b-0 pt-1 BuildSchedule_M-newClass23">Serviced :&nbsp;</p>
                                                    <div class="text m-b-0 newcls12" data-aura-rendered-by="492:0">
                                                        {!v.WorkOrder.ERP7__Quantity_Built__c} / {!v.WorkOrder.ERP7__Quantity_Ordered__c} &nbsp; {!v.WorkOrder.ERP7__Product__r.QuantityUnitOfMeasure}(s)
                                                    </div>
                                                </div>
                                                
                                                <div class="col-md-4">
                                                    <a onclick="{!c.editOrder}" data-record="Add" class="addNewBTN" title="Add" href="javascript:void(0);">
                                                        &nbsp;<i class="fa fa-pencil newcls13" aria-hidden="true" ></i>
                                                        &nbsp;&nbsp;<strong>Add Order&nbsp;&nbsp;</strong>
                                                    </a>
                                                    
                                                    
                                                </div>
                                            </div>
                                            
                                            
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        </div>
               		 <div class="container-fluid erp_mark7"> 
                    <div class="card shadow-mrr mb-2" >
                        <div class="card-body newcls10">
                            <aura:renderIf isTrue="{!and(v.WorkOrder.Id != '', v.WorkOrder.Id != undefined)}">
                                <div class="panel-collapse ">
                                    <div class="panel-body" >
                                        <!-- Nav tabs -->
                                        <ul class="slds-tabs--default__nav" role="tablist" onclick="{!c.ReloadAll}">
                                            <li onclick="{!c.tab1}" class="{!(v.worksheetTab)?'slds-tabs--default__item slds-active newcls14':'slds-tabs--default__item newcls14'}" title="" role="presentation">
                                                <a class="slds-tabs--default__link newcls15" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                                    <i class="fa fa-list newcls16" aria-hidden="true" ></i>&nbsp;Worksheet
                                                </a>
                                            </li>
                                            <aura:if isTrue="{!v.checkDrawings}">
                                                <li onclick="{!c.tab2}" class="{!(v.drawingTab)?'slds-tabs--default__item slds-active newcls14':'slds-tabs--default__item newcls14'}" title="" role="presentation" >
                                                    <a class="slds-tabs--default__link newcls15" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                                        <i class="fa fa-pencil-square-o newcls16" aria-hidden="true" ></i>&nbsp;Drawing
                                                    </a>
                                                </li>
                                            </aura:if>
                                            <li onclick="{!c.tab3}" class="{!(v.timeTrackingTab)?'slds-tabs--default__item slds-active newcls14':'slds-tabs--default__item newcls14'}" title="" role="presentation" >
                                                <a class="slds-tabs--default__link newcls15" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                                    <i class="fa fa-clock-o newcls16" aria-hidden="true" ></i>&nbsp;Time Tracking
                                                </a>
                                            </li>
                                            <li onclick="{!c.tab4}" class="{!(v.MRPSTab)?'slds-tabs--default__item slds-active newcls14':'slds-tabs--default__item newcls14'}" title="" role="presentation" >
                                                <a class="slds-tabs--default__link newcls15" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                                    <i class="fa fa-outdent newcls16" aria-hidden="true"  ></i>&nbsp;MRPS
                                                </a>
                                            </li>
                                            <li onclick="{!c.tab5}" class="{!(v.resourceTab)?'slds-tabs--default__item slds-active newcls14':'slds-tabs--default__item newcls14'}" title="" role="presentation" >
                                                <a class="slds-tabs--default__link newcls15" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                                    <i class="fa fa-file-text-o newcls16" aria-hidden="true" ></i>&nbsp;Resources
                                                </a>
                                            </li>
                                            <aura:renderIf isTrue="{!(v.ManuOrder.Id != undefined)}">
                                                <li  onclick="{!c.tab6}" class="{!(v.currentProductionTab)?'slds-tabs--default__item slds-active newcls17':'slds-tabs--default__item newcls17'}" title="" role="presentation" >
                                                    <a class="nav-link newcls15" data-toggle="tab" role="tab" href="#currentproduction" >
                                                        <i class="fa fa-gears newcls16" aria-hidden="true"></i>&nbsp;Current Production</a>
                                                </li>
                                                <li onclick="{!c.tab7}"  class="{!(v.serialorBatchesTab)?'slds-tabs--default__item slds-active newcls17':'slds-tabs--default__item newcls17'}" title="" role="presentation" > 
                                                    <a class="nav-link newcls15" data-toggle="tab" href="#SB" role="tab" >
                                                        <i class="fa fa-tasks newcls16" aria-hidden="true"  ></i>&nbsp;Serial Numbers/Batches
                                                    </a>
                                                </li>
                                            </aura:renderIf> 
                                            <aura:renderIf isTrue="{!v.WorkOrder.ERP7__Is_Signature_Required__c == true}">
                                                <li onclick="{!c.tab8}"  class="{!(v.signatureTab)?'slds-tabs--default__item slds-active newcls17':'slds-tabs--default__item newcls17'}" title="" role="presentation" > 
                                                    <a class="nav-link newcls15" data-toggle="tab" href="#Signature" role="tab" >
                                                        <i class="fa fa-pencil newcls16" aria-hidden="true" ></i>&nbsp;Signature
                                                    </a> 
                                                </li>
                                            </aura:renderIf>
                                        </ul>
                                    </div>
                                </div>
                            </aura:renderIf>
                            <div class="erp_mark7">
                                <div class="tab-content">
                                    <!-- tab 1 -->
                                    <div class="{!(v.worksheetTab)?'slds-show':'slds-hide'}" id="home" role="tabpanel">
                                        <div class="row slds-m-bottom--small m-0">
                                            <div class="col-md-3  newcls18" data-aura-rendered-by="214:0">
                                                <div class="card-header newcls19" data-aura-rendered-by="215:0">
                                                    <a href="javascript:void(0);" class="slds-button slds-button--neutral lineheight-custom" onclick="{!c.NewTask}">
                                                        <i class="fa fa-plus newcls20" aria-hidden="true" data-aura-rendered-by="7:1158;a" ></i>
                                                        &nbsp;New
                                                    </a>
                                                    <aura:renderIf isTrue="{!and(v.WorkOrder.ERP7__Status__c != 'In Progress', v.WorkOrder.ERP7__Status__c != 'Complete')}">
                                                        <lightning:button name="{!v.WorkOrder.Id}" onclick="{!c.StartWO}" variant="brand" disabled="{!lessthan(v.WorkOrder.ERP7__Quantity_Ordered__c, 1)}" class="slds-button float-right mr-2" > 
                                                            <div id="pause" class=""><!--mb-1-->
                                                                <aura:if isTrue = "{!lessthan(v.WorkOrder.ERP7__Quantity_Ordered__c, 1)}">
                                                                    <span class="newcls21">
                                                                        <i class="fa fa-play" aria-hidden="true"></i>&nbsp;Start&nbsp;&nbsp;
                                                                    </span>
                                                                    <aura:set attribute="else">
                                                                        <span class="newcls22">
                                                                            <i class="fa fa-play" aria-hidden="true"></i>&nbsp;Start&nbsp;&nbsp;
                                                                        </span>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </lightning:button>
                                                    </aura:renderIf>
                                                    <aura:renderIf isTrue="{!(v.WorkOrder.ERP7__Status__c == 'In Progress')}">
                                                        <lightning:button name="{!v.WorkOrder.Id}" onclick="{!c.WO2Finish}" disabled="{!v.isWOcomplete}" variant="brand" class="float-right mr-2"><!--disabled="{!v.isWOcomplete}"-->
                                                            <div id="pause" class="" data-toggle="modal" data-target="#myModal1"><span class="newcls22"><i class="fa fa-stop" aria-hidden="true"></i>&nbsp;Finish</span></div>
                                                        </lightning:button>
                                                    </aura:renderIf>
                                                </div>
                                                <div class="scroll-bar-wrap">
                                                    <div class="scroll-box newcls23">
                                                        <div class="{!if(v.SelectedTask.ERP7__Operation__r.ERP7__Is_Signature_Required__c,'newcls24','newcls25')}">
                                                            <aura:iteration items="{!v.Tasks}" var="Task" indexVar="T">
                                                                <div onclick="{!c.SelectTask}" data-mosoliId="{!T}" class="{!'slds-hint-parent '+if(Task.Id == v.SelectedTask.Id,'card shadow-sm2 mt-1','card shadow-sm1 mt-1 newcls26')}" name="{!T}">
                                                                    <div class="card-body mt-1 p-1" data-aura-rendered-by="2:1658;a"> 
                                                                        <div class="slds-grid" data-aura-rendered-by="3:1658;a">
                                                                            <div class="slds-col" data-aura-rendered-by="4:1658;a">
                                                                                <h6 class="card-title" >
                                                                                    <lightning:formattedUrl  value="{!'/'+Task.Id}" label="{!Task.Name}" target="_blank" class="fcolor"/>
                                                                                </h6>
                                                                            </div>
                                                                            <aura:if isTrue="{!Task.Id == v.SelectedTask.Id}">
                                                                                <div class="slds-col newcls27">
                                                                                    <lightning:buttonMenu alternativeText="Show menu" variant="container" onselect="{!c.taskOperation}" class="" menuAlignment="right"><!--bgforico1-->
                                                                                        <lightning:menuItem value="Edit" label="Edit" prefixIconName="utility:edit"/>
                                                                                        <lightning:menuItem value="Delete" label="Delete" prefixIconName="utility:delete"/>
                                                                                    </lightning:buttonMenu>
                                                                                </div>    
                                                                            </aura:if>
                                                                        </div>
                                                                        <aura:if isTrue="{!and(Task.ERP7__Barcode__c != undefined, Task.ERP7__Barcode__c != '')}">
                                                                            <div class="slds-grid newcls">
                                                                                <div class="slds-col newcls28">
                                                                                    <p class="card-text">
                                                                                        <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!Task.ERP7__Barcode__c}"/>
                                                                                    </p>
                                                                                </div>
                                                                            </div>
                                                                        </aura:if>
                                                                        <div class="slds-grid">
                                                                            <div class="slds-col">
                                                                                <strong>Type</strong>
                                                                                <p class="card-text">{!Task.ERP7__Type__c}</p>
                                                                            </div>
                                                                            <div class="slds-col">
                                                                                <strong>Status</strong>
                                                                                <p class="card-text">{!Task.ERP7__Status__c}</p>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </aura:iteration>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="cover-bar"></div>
                                            </div>
                                            
                                            <div class="col-md-5 newcls29" data-aura-rendered-by="247:0">
                                                <div class="card newcls30" data-aura-rendered-by="248:0">
                                                    <div class="card-header border-bottom-0" data-aura-rendered-by="250:0">
                                                        <div class="epr_Mark7 slds-no-flex newcls31">
                                                            
                                                        </div>
                                                    </div>
                                                    <aura:iteration items="{!v.Tasks}" var="Task" indexVar="T">
                                                        <aura:renderIf isTrue="{!Task.Id == v.SelectedTask.Id}">
                                                            <div class="card-body pt-0 p-2 brbl-1" data-aura-rendered-by="226:1658;a">
                                                                <div class="container-fluid mt-0" >
                                                                    <div class="row mb-2 mt-1 newcls32" data-aura-rendered-by="269:1658;a">
                                                                        <div class="col-md-12 p-0 mt-1" data-aura-rendered-by="274:1658;a">
                                                                            <div class="slds-grid" data-aura-rendered-by="275:1658;a">
                                                                                <div class="slds-form-element" data-aura-rendered-by="276:1658;a">
                                                                                    <div class="sld-button-group" role="group" data-aura-rendered-by="277:1658;a">
                                                                                        <aura:renderIf isTrue="{!Task.ERP7__Operation__r.ERP7__Timer__c}">
                                                                                            <aura:renderIf isTrue="{!v.Permit}">
                                                                                                <aura:if isTrue = "{! v.WorkOrder.ERP7__Status__c != 'In Progress'}">
                                                                                                    <aura:renderIf isTrue="{!(Task.ERP7__Status__c == 'New' || Task.ERP7__Status__c == 'On-Hold' || Task.ERP7__Status__c == '' || Task.ERP7__Status__c == undefined)}">
                                                                                                        <aura:renderIf isTrue="{!(!(Task.ERP7__Auto_Clock_In__c == true) || !(v.Busy))}">
                                                                                                            <button class="slds-button slds-button--brand newcls33" disabled="true" data-mosoliId="{!T}" >
                                                                                                                <div id="pause"><span class="newcls34"><i class="fa fa-play" aria-hidden="true"></i></span></div>
                                                                                                            </button>
                                                                                                        </aura:renderIf>
                                                                                                    </aura:renderIf>
                                                                                                    <aura:set attribute="else">
                                                                                                        <aura:renderIf isTrue="{!(Task.ERP7__Status__c == 'New' || Task.ERP7__Status__c == 'On-Hold' || Task.ERP7__Status__c == '' || Task.ERP7__Status__c == undefined)}">
                                                                                                            <aura:renderIf isTrue="{!(!(Task.ERP7__Auto_Clock_In__c == true) || !(v.Busy))}">
                                                                                                                <button class="slds-button slds-button--brand newcls35" onclick="{!c.StartTask}" data-mosoliId="{!T}">
                                                                                                                    <div id="pause"><span class="newcls36"><i class="fa fa-play" aria-hidden="true"></i></span></div>
                                                                                                                </button>
                                                                                                            </aura:renderIf>
                                                                                                        </aura:renderIf>
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                                <aura:renderIf isTrue="{!(Task.ERP7__Status__c == 'In-Progress' || Task.ERP7__Status__c == 'On-Hold')}">
                                                                                                    <aura:renderIf isTrue="{!(Task.ERP7__Status__c == 'In-Progress')}">
                                                                                                        <button class="slds-button slds-button--brand newcls35" onclick="{!c.PauseTask}" data-mosoliId="{!T}" >
                                                                                                            <div id="play" ><span class="newcls36"><i class="fa fa-pause" aria-hidden="true"></i></span></div>
                                                                                                        </button>
                                                                                                    </aura:renderIf>
                                                                                                    <button class="slds-button slds-button--success-complete newcls35" onclick="{!c.PreFinishTask}" data-mosoliId="{!T}" >
                                                                                                        <!-- onclick="{!c.FinishTask}"  -->
                                                                                                        <a href="javascript:void(0);" class="newcls37"><span ><i class="fa fa-check newcls38" aria-hidden="true" ></i></span></a> 
                                                                                                    </button>
                                                                                                    <button class="slds-button slds-button--destructive slds-m-right--xx-small newcls35" onclick="{!c.StopTask}" data-mosoliId="{!T}" >
                                                                                                        <a href="javascript:void(0);"  class="newcls37"><span ><i class="fa fa-times" aria-hidden="true"></i></span></a> 
                                                                                                    </button>
                                                                                                </aura:renderIf>
                                                                                            </aura:renderIf>
                                                                                        </aura:renderIf>
                                                                                        <aura:renderIf isTrue="{!!Task.ERP7__Operation__r.ERP7__Timer__c}">
                                                                                            <aura:renderIf isTrue="{!and(v.Permit,Task.ERP7__Status__c != 'Completed')}">
                                                                                                <aura:if isTrue = "{! v.WorkOrder.ERP7__Status__c != 'In Progress'}">
                                                                                                    <button class="slds-button newcls39" data-mosoliId="{!T}" >
                                                                                                        <div id="play" ><span class="newcls40"><i class="fa fa-check newcls38" aria-hidden="true" ></i></span></div>
                                                                                                    </button>
                                                                                                    <aura:set attribute="else">
                                                                                                        <button class="slds-button slds-button--success-complete newcls35 " onclick="{!c.CompleteTask}" data-mosoliId="{!T}" >
                                                                                                            <div id="play" ><span class="newcls41"><i class="fa fa-check newcls38" aria-hidden="true" ></i></span></div>
                                                                                                        </button>
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                            </aura:renderIf>
                                                                                        </aura:renderIf>
                                                                                        <aura:renderIf isTrue="{!Task.ERP7__Operation__r.ERP7__Label_Generator__c}">
                                                                                            <a href="{!'/apex/ERP7__OperationLabel?WId='+ Task.ERP7__Work_Order__c+'&amp;ra=pdf'}" target="_blank" > 
                                                                                                <i class="fa fa-print newcls42" aria-hidden="true" ></i>
                                                                                            </a>
                                                                                        </aura:renderIf>
                                                                                        <aura:renderIf isTrue="{!!v.Busy}">
                                                                                            <aura:renderIf isTrue="{!(v.SelectedTask.ERP7__Auto_Clock_In__c == false)}">
                                                                                                <aura:renderIf isTrue="{!(v.SelectedTask.ERP7__Status__c == 'In-Progress')}">
                                                                                                    <aura:renderIf isTrue="{!(v.SelectedTask_TimeCardEntry.Id == undefined)}">
                                                                                                        <button class="slds-button slds-button--brand slds-m-right--xx-small newcls35" onclick="{!c.StartTimeCardEntry}">
                                                                                                            <div id="play" ><span class="newcls43"><i class="fa fa-clock-o newcls44" aria-hidden="true" ></i>&nbsp;&nbsp;Clock In</span></div>
                                                                                                        </button>
                                                                                                    </aura:renderIf>
                                                                                                </aura:renderIf>
                                                                                            </aura:renderIf>
                                                                                        </aura:renderIf>
                                                                                        <aura:renderIf isTrue="{!v.Busy}">
                                                                                            <aura:renderIf isTrue="{!(v.SelectedTask.ERP7__Auto_Clock_In__c == false)}">
                                                                                                <aura:renderIf isTrue="{!(v.SelectedTask_TimeCardEntry.Id != undefined)}">
                                                                                                    <button class="slds-button slds-button--brand newcls35" onclick="{!c.StopTimeCardEntry}" >
                                                                                                        <div id="play" ><span class="newcls43"><i class="fa fa-clock-o newcls44" aria-hidden="true" ></i>&nbsp;&nbsp;Clock Out</span></div>
                                                                                                    </button>
                                                                                                </aura:renderIf>
                                                                                            </aura:renderIf>
                                                                                        </aura:renderIf>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="container-fluid mt-1 newcls45">
                                                                    <div class="row m-0">
                                                                        <div class="col-md-6 p-0 mt-0">
                                                                            <p class="slds-item_label slds-text-color_weak slds-truncate m-0" data-aura-rendered-by="347:1658;a">
                                                                                <a href="javascript:void(0);" class="newcls46">
                                                                                    <strong>Employee</strong>
                                                                                </a>
                                                                            </p>
                                                                            <p class="slds-text-heading--xx-small m-0">
                                                                                <lightning:formattedText value="{!v.Employee.Name}"/>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-md-6 p-0 mt-0" data-aura-rendered-by="351:1658;a">
                                                                            <p class="slds-item_label slds-text-color_weak slds-truncate m-0" >
                                                                                <a href="javascript:void(0);" class="newcls46">
                                                                                    <strong>Supervisor</strong>
                                                                                </a>
                                                                            </p>
                                                                            <p class="slds-text-heading--xx-small  m-0" >
                                                                                <lightning:formattedText value="{!v.SelectedTask.ERP7__Work_Center__r.ERP7__Supervisor__r.Name}"/>
                                                                            </p>
                                                                        </div>
                                                                    </div>
                                                                    <div class="row m-0" data-aura-rendered-by="356:1658;a">
                                                                        <div class="col-md-6 p-0 mt-0">
                                                                            <p class="slds-item_label slds-text-color_weak slds-truncate m-0">
                                                                                <a href="javascript:void(0);" class="newcls46">
                                                                                    <strong>Start Time</strong>
                                                                                </a>
                                                                            </p>
                                                                            <p class="slds-text-heading--xx-small m-0" data-aura-rendered-by="387:1658;a">
                                                                                <lightning:formattedDateTime value="{!v.SelectedTask_TimeCardEntry.ERP7__Start_Time__c}"/>
                                                                            </p>
                                                                        </div>
                                                                        <div class="col-md-6 p-0 mt-0" data-aura-rendered-by="362:1658;a">
                                                                            <aura:renderIf isTrue="{!v.Timer != ''}">
                                                                                <div class="row m-0 mt-1">
                                                                                    <div class="col-12 p-0">
                                                                                        <div class="shadow-sm newcls47">
                                                                                            <p class="slds-text-heading--xx-small newcls48" id="demo">{!v.Timer}</p>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </aura:renderIf>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="container-fluid mt-1 newcls45" data-aura-rendered-by="398:1658;a">
                                                                    <aura:renderIf isTrue="{!and(Task.Id == v.SelectedTask.Id, v.SelectedTask.ERP7__Operation__r.ERP7__Is_Signature_Required__c)}">
                                                                        <div class="row m-0 mt-1">
                                                                            <div class="col-md-12 p-0">
                                                                                
                                                                                <aura:iteration var="AT" indexVar="ATC" items="{!v.SelectedAttachments}">
                                                                                    <aura:renderIf isTrue="{!and(AT.ParentId == v.SelectedTask.Id, AT.Name == 'Signature')}">
                                                                                        
                                                                                        <p class="slds-item_label slds-text-color_weak slds-truncate m-0" >
                                                                                            <strong >Signature</strong> <br/><br/>
                                                                                            <img src="{!'/servlet/servlet.FileDownload?file='+AT.Id}" class="newcls49"/><br/><br/>
                                                                                            (<lightning:formattedText value="{!AT.Owner.Name}"/>) &nbsp; &nbsp;<lightning:formattedDateTime value="{!AT.CreatedDate}"/>
                                                                                        </p>
                                                                                    </aura:renderIf>
                                                                                </aura:iteration>
                                                                                <aura:renderIf isTrue="{!!v.signatureExist}">
                                                                                    <div class="shadow-sm newcls50">
                                                                                        <aura:if isTrue="{!and(Task.Id == v.SelectedTask.Id, v.SelectedTask.Id != undefined,v.SelectedTask.Id != null,v.SelectedTask.Id != '')}">
                                                                                            <c:ESignature aura:id="{!v.SelectedTask.Id}" parentID="{!v.SelectedTask.Id}" Name="Signature" minWidth="0.5" maxWidth="1.5" id="{!v.SelectedTask.Id}"/>
                                                                                        </aura:if>
                                                                                    </div>
                                                                                </aura:renderIf>
                                                                            </div>
                                                                        </div>
                                                                    </aura:renderIf>
                                                                </div>
                                                            </div>
                                                        </aura:renderIf>
                                                    </aura:iteration>
                                                </div>
                                            </div>
                                            
                                            <div class="col-md-4">
                                                <div class="card p-2 newcls51" data-aura-rendered-by="294:0">
                                                    <div class="slds-grid mb-1"  data-aura-rendered-by="295:0">
                                                        <div class="slds-col" data-aura-rendered-by="296:0">
                                                            <h6 class="newcls52" data-aura-rendered-by="297:0">Notes &amp; Attachments</h6>
                                                        </div>
                                                    </div>
                                                    <div class="slds-grid slds-wrap mb-1 newcls53" data-aura-rendered-by="299:0">
                                                        <div class="slds-col" data-aura-rendered-by="300:0">
                                                            <lightning:input aura:id="fileik" type="file" files="{!v.FileList}" name="file" multiple="true" onchange="{!c.onFileUploaded}" class="newcls54"/>
                                                        </div>
                                                        <div class="slds-col newcls55" data-aura-rendered-by="302:0">
                                                            <a href="javascript:void(0);" class="slds-button slds-button_brand newIcon1  newcls56"  data-toggle="modal" data-target="#myModalNote" onclick="{!c.NewNote}" ><i class="fa fa-pencil-square-o"></i></a>&nbsp;
                                                        </div>
                                                        <div class="slds-col newcls55" data-aura-rendered-by="305:0"><!--margin-top:17px;-->
                                                            <a href="{!'/00T/e?what_id='+v.SelectedTask.Id}" target="_blank" class="slds-button slds-button--neutral newIcon "><i class="fa fa-tasks"></i></a>
                                                            <!-- <lightning:formattedUrl  value="{!'/00T/e?what_id='+v.SelectedTask.Id}" target="_blank"  class="slds-button slds-button-/-neutral newIcon fa fa-tasks"/> -->
