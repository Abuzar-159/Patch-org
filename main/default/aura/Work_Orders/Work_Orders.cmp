                                                                        <lightning:input type="datetime" variant="label-hidden" class="display-lable" aura:id="std" 
                                                                                         
                                                                                         value="{!v.Task.ERP7__Start_Date__c}"
                                                                                         />
                                                                    </div>
                                                                    <div class="col-md-6 slds-m-top--xx-small">
                                                                        <label class="slds-form-element__label" for="input-05">End Date</label>
