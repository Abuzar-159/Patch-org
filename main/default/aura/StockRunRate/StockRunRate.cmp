<aura:component Controller="ERP7.MPS_AT_Lightning" implements="force:appHostable" access="global">
   <!--<ltng:require styles="{!join(',',$Resource.ERP7__PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
   <ltng:require styles="{!join(',',$Resource.ERP7__Order_Console + '/assets/styles/custom.css', $Resource.ERP7__Order_Console + '/assets/styles/font-awesome.css', $Resource.ERP7__PickPackShipResource + '/assets/styles/font-awesome.css')}"/>-->

   <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/StockRunRate.css"/>
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>  
    <ltng:require styles="/resource/ERP7__axoltmain/Assets/css/axolt-main.css" /> 
    <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/> 
    <aura:attribute name="MPSId" type="String"/>
    <aura:attribute name="MPS" type="Object" />
    <aura:attribute name="MPSHolder" type="Object" />
    <aura:attribute name="exceptionError" type="String"/>
    <aura:attribute name="StartDate" type="Date" default=""/>
    <aura:attribute name="EndDate" type="Date" default=""/>
    <aura:attribute name="SearchStr" type="String" default=""/>
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <!--<aura:method name="loadInit" action="{!c.loadAllDetails}"></aura:method>
<aura:handler name="Search_Event" event="ERP7:SearchEvent" action="{!c.handleComponentEvent}"/>
-->
    <aura:attribute name="proceed" type="Boolean" default="true"/>
    <aura:handler event="force:refreshView" action="{!c.getAllDetails}" />
    
    <aura:handler name="change" value="{!v.siteId}" action="{!c.loadDetails}"/>
    
    <aura:attribute name="mpsStatusOptions" type="List"/>
    
    <aura:attribute name="siteId" type="String"/>
    <aura:attribute name="SchedulePeriod" type="String"/>
  
       <html>
      <head> 
         <meta charset="utf-8" /> 
         <meta name="viewport" content="width=device-width,initial-scale=1" />
       </head>
      <div class="erp_mark7 theme-bg maqsood erp cpq c11">
         <span class="cl2">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
          <div class="container-fluid">
              <div class="row">
                  <div class="col-12">
                      <div class="page-title-box">
                       <!--   <div class="page-title-right">
                              <ol class="breadcrumb m-0">
                                 
                                  <li class="breadcrumb-item">
                                      <nav class="nav">
                                          <a href="" class="nav-link active">{!$Label.c.Weekly}</a>
                                          <a href="" class="nav-link">{!$Label.c.Monthly}</a>
                                          <a href="" class="nav-link">{!$Label.c.Quarterly}</a>
                                      </nav>
                                  </li>
                              </ol>

                          </div>-->
                          <h4 class="page-title card-pricing headermt">
                              <i class="card-pricing-icon text-primary fa fa-line-chart"></i>&nbsp;{!$Label.c.Stock_Run_Rate}</h4>
                      </div>
                  </div>
              </div>
              
              
          </div> 
          <div class="row row-sm row-timeline m-0">
          <!--    <div class="col-lg-12">
                  <div class="slds-grid slds-wrap">
                      <div class="slds-col slds-m-right_small">
                          <div class="card mb-2">
                              <div class="card-body p-2 d-flex justify-content-between align-items-start">
                                  <div class="slds-grid">
                                      
                                      <span class="cl9"><lightning:icon iconName="action:record" size="small"></lightning:icon><strong>&nbsp;D&nbsp;=&nbsp;</strong>{!$Label.c.Demand_Forecast_Actual_Demand_StockRunRate}</span>
                                  </div>
                              </div>
                          </div>
                      </div>
                      <div class="slds-col slds-m-right_small">
                          <div class="card mb-2">
                              <div class="card-body p-2 d-flex justify-content-between align-items-start">
                                  <div class="slds-grid">
                                      <span class="cl9"><lightning:icon iconName="action:flow" size="small"></lightning:icon><strong>&nbsp;NI&nbsp;=&nbsp;</strong>{!$Label.c.Net_Inventory_Before_Supply_Produce_StockRunRate}</span>
                                  </div>
                              </div>
                          </div>
                      </div>
                      <div class="slds-col slds-m-right_small">
                          <div class="card mb-2"> 
                              <div class="card-body p-2 d-flex justify-content-between align-items-start">
                                  <div class="slds-grid">
                                      <span class="cl9"><lightning:icon iconName="action:change_record_type" size="small"></lightning:icon><strong>&nbsp;S/P&nbsp;=&nbsp;</strong>{!$Label.c.To_Supply_Produce_StockRunRate}</span>
                                  </div>
                              </div>
                          </div>
                      </div>
                      <div class="slds-col">
                          <div class="card mb-2">
                              <div class="card-body p-2 d-flex justify-content-between align-items-start">
                                  <div class="slds-grid">
                                      <span class="cl9"><lightning:icon iconName="action:share_poll" size="small"></lightning:icon><strong>&nbsp;PI&nbsp;=&nbsp;</strong>{!$Label.c.Projected_Inventory}</span>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div> -->
              
              <div class="col-lg-12">
                  <div class="card card-table">
                      <div class="card-header">
                            <div class="slds-grid slds-m-top--x-small">
                                <div class="slds-col slds-col slds-p-right--xx-small">
                                    <label class="slds-form-element__label" for="input-141">{!$Label.c.AddSubscription_Product}</label>
                                    <lightning:input type="text" label="{!$Label.c.From_StockRunRate}" aura:id="std"  class="field" value="{!v.SearchStr}" onchange="{!c.loadDetails}" variant="label-hidden"/>
                                   <!-- <ERP7:StockTakeSearch /> -->
                                </div>
                              <div class="slds-col slds-col slds-p-right--xx-small">
                                  <lightning:input type="date" label="{!$Label.c.From_StockRunRate}" aura:id="std"  class="field" value="{!v.StartDate}" onchange="{!c.loadDetails}"/>
                                  &nbsp; 
                              </div>
                              <div class="slds-col slds-col slds-p-right--xx-small">
                                  <lightning:input type="date" label="{!$Label.c.To_StockRunRate}"  aura:id="end"  class="field" value="{!v.EndDate}" onchange="{!c.loadDetails}"/>
                                  &nbsp; 
                              </div>
                              <div class="slds-col slds-p-right--xx-small">
                                  <label class="slds-form-element__label" for="unique-id-of-input">{!$Label.c.Distribution_Channel_StockRunRate}</label>
                                  <!--<ERP7:CustomInputLookUp objectAPIName="ERP7__Distribution_Channel__c" aura:id="mvr" IconName="standard:flow" selectedRecordId="{!v.MPS.MPS.ERP7__Distribution_Channel__c}" inputStyleclass="field"/> -->
                                  <c:CustomInputLookUp objectAPIName="ERP7__Site__c" aura:id="mvr" IconName="standard:flow" selectedRecordId="{!v.siteId}" inputStyleclass="field"/>
                                  &nbsp;
                              </div>
                            <!--  <div class="slds-col slds-p-right-xxx-small">
                                  <lightning:select  class="field" aura:id="mpsStatus" label="{!$Label.c.View_By}" value="{!v.SchedulePeriod}" onchange="{!c.loadAllDetails}">
                                      <aura:iteration items="{!v.mpsStatusOptions}" var="option">
                                          <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.SchedulePeriod, option.value)}"/>
                                      </aura:iteration>
                                  </lightning:select>
                                  &nbsp;
                              </div>-->
                              
                          </div>
                      </div>
                      
                      <div class="container-fluid">
                          <div class="row">
                              <div class="col-md-3 cl12">
                                  <table class="slds-table slds-table_condensed slds-table_cell-buffer">
                                      <tbody>
                                          <div class="slds-truncate slds-text-title_caps cl13" title="">
                                              <strong>
                                                  {!$Label.c.AddSubscription_Product}
                                              </strong>
                                          </div>
                                          <aura:iteration var="cMPS" indexVar="BOMCount" items="{!v.MPS.ProdList}">
                                              <tr class="slds-text-title">
                                                  <td scope="col" class="cl14" height="46">
                                                      <div class="slds-truncate cl15 srr-max-width" title="{!cMPS.Prod.Name}" id="{!cMPS.Prod.Id}">
                                                          {!BOMCount+1}. 
                                                          <lightning:formattedText value="{!cMPS.Prod.Name}" onclick="{!c.navigateToMyComponent}" title="{!cMPS.Prod.Id}"/>
                                                          <aura:if isTrue="{!(cMPS.Prod.ERP7__Picture__c != undefined)}">
                                                              &nbsp;&nbsp;<img src="{!cMPS.Prod.ERP7__Picture__c}" class="cl16" />
                                                          </aura:if>
                                                      </div>
                                                  </td>
                                              </tr>
                                          </aura:iteration>
                                      </tbody>
                                  </table>
                              </div>
                              <div class="col-md-9 hoverdiv cl17">
                                  
                                      <aura:iteration var="cMPS" indexVar="BOMCount" items="{!v.MPS.ProdList}">
                                          <div class="slds-grid slds-wrap cl18">
                                          <div class="slds-col col-md-12">
                                              <table class="slds-table slds-table_condensed slds-table_fixed-layout slds-no-row-hover " border="0">
                                                  <tbody data-aura-rendered-by="3:22;a" class="cl20">
                                                      <aura:renderIf isTrue="{!(BOMCount == 0)}">
                                                          <!--<tr>
                                                              <td class="cl17" colspan="10">
                                                                  <div class="slds-truncate slds-text-title_caps cl21" title="">
                                                                      <strong>
                                                                          
                                                                      </strong>
                                                                  </div>
                                                              </td>
                                                          </tr>-->
                                                          <tr>
                                                              <td data-label="" class="cl22">
                                                                  <table class="slds-table slds-table_condensed slds-table_fixed-layout slds-no-row-hover cl21">
                                                                      <tbody>
                                                                          <tr>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Demand from <br/>Sales</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Demand from <br/>Production</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Total <br/>Demand</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Current/<br/>Minimum Inventory</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Ordered <br/>Qty</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>To Supply/<br/>Produce</strong></td>
                                                                              <td width="" class="slds-truncate slds-text-title_caps cl23 srr-whitespace"><strong>Projected <br/>Inventory</strong></td>
                                                                          </tr>
                                                                      </tbody>
                                                                  </table>
                                                              </td>
                                                          </tr>
                                                      </aura:renderIf>
                                                      <tr class="slds-hint-parent">
                                                          <td data-label="" class="cl24">
                                                              <table class="slds-table slds-table_condensed slds-table_fixed-layout slds-no-row-hover cl25">
                                                                  <tbody>
                                                                      <tr>
                                                                          <td width="" class="cl26"><span class="slds-badge dmforder">{!cMPS.OrdDemand}</span></td>
                                                                          <td width="" class="cl26"><span class="slds-badge dmproducttion">{!cMPS.MRPDemand}</span></td>
                                                                              <td width="" class="cl26"><span class="slds-badge dmdemand">{!cMPS.OrdDemand + cMPS.MRPDemand}</span></td>
                                                                         <!-- <aura:renderIf isTrue="{!(cMPS.NetInventory >= cMPS.rrRule.ERP7__Minimum_Quantity__c)}">
                                                                              <td width="" class="cl26 cl19"><span class="slds-badge dmmimumcurrentinventory">{!cMPS.NetInventory}</span></td>
                                                                          </aura:renderIf>
                                                                          <aura:renderIf isTrue="{!!(cMPS.NetInventory >= cMPS.rrRule.ERP7__Minimum_Quantity__c)}">
                                                                              <td width="" class="cl27 cl19"><span class="slds-badge dmmimuminventory">{!cMPS.rrRule.ERP7__Minimum_Quantity__c}</span></td>
                                                                          </aura:renderIf>-->
                                                                          <td width="" class="cl26">
                                                                              <aura:if isTrue="{!((cMPS.OrdDemand + cMPS.MRPDemand) > cMPS.NetInventory)}">
                                                                                  <span class="slds-badge dm-inventorylow">{!cMPS.NetInventory}/{!cMPS.rrRule.ERP7__Minimum_Quantity__c}</span>
                                                                                  <aura:set attribute="else">
                                                                                      <span class="slds-badge dmmimumcurrentinventory">{!cMPS.NetInventory}/{!cMPS.rrRule.ERP7__Minimum_Quantity__c}</span>
                                                                                  </aura:set>
                                                                              </aura:if>
                                                                          </td>
                                                                              <td width="" class="cl26"><span class="slds-badge dmmimuminventory">{!cMPS.OrderedQty}</span></td>
                                                                          <td width="" class="cl26">
                                                                              <span class="slds-badge dmtosupply">{!cMPS.toProduce} </span>
                                                                              <!-- <aura:If isTrue="{!((cMPS.OrdDemand + cMPS.MRPDemand) <= (cMPS.NetInventory - cMPS.rrRule.ERP7__Minimum_Quantity__c))}">
                                                                                          0
                                                                                          <aura:set attribute="else">
                                                                                           {!((cMPS.OrdDemand + cMPS.MRPDemand) - (cMPS.NetInventory - cMPS.rrRule.ERP7__Minimum_Quantity__c))}
                                                                                          </aura:set>
                                                                                      </aura:If>-->
                                                                              
                                                                          </td>
                                                                              <td width="" class="cl26"><span class="slds-badge dmtoproduce">{!cMPS.ProjectedInventory}</span></td>
                                                                      </tr>
                                                                  </tbody>
                                                              </table>
                                                          </td>
                                                      </tr>
                                                  </tbody>
                                              </table>
                                          </div>
                                              </div>
                                      </aura:iteration>
                                  
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
              
          </div>
           
         
      </div>
   </html>
</aura:component>