<aura:component controller="SortRecords" access="global"> 
     <head> 
      <meta charset="utf-8"/>
      <meta name="viewport" content="width=device-width,initial-scale=1"/>  
	  <ltng:require styles="/resource/SLDS213/assets/styles/salesforce-lightning-design-system-vf.css, /resource/SLDS213/assets/styles/salesforce-lightning-design-system-vf.min.css,
                            /resource/PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/PickPackShipResource/assets/styles/font-awesome.css,
                            /resource/TablesSort/css/dataTables.bootstrap.min.css "/>
    </head>
    
    
    <aura:registerEvent name="SortRecord" type="c:SortRecord"/>
    
    <aura:attribute name="ObjectAPIName" type="object" default=""/>
    <aura:attribute name="OrderBy" type="String" default=""/> 
    <aura:attribute name="Order" type="String" default="DESC"/> 
    <aura:attribute name="Query" type="String" default=""/> 
    <aura:attribute name="currentVisId" type="String" default=""/>
    <aura:attribute name="RecordList" type="List" default=""/>
    <aura:attribute name="Fields" type="String" default=""/>
    <aura:attribute name="Label" type="String" default=""/>
    <aura:attribute name="show" type="Integer" default="{!$Label.c.Pagination_Default_Limit}"/>
    
     <aura:if isTrue="{!equals(v.Order,'DESC')}">
         <span onclick="{!c.fetchRecords}" data-service="{!v.Order}"  class="cu" onmouseover="{!c.mouseOver}" onmouseout="{!c.mouseOut}" data-record="{!v.OrderBy}"> {!v.Label}&nbsp;
             <a href="javascript:void(0)" id="{!v.OrderBy}" style="visibility: hidden;" ><lightning:icon iconName="utility:arrowdown" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/></a> <!--  class="edit_hover_class"  -->
         </span> 
         <aura:set attribute="else">
             <span onclick="{!c.fetchRecords}" data-service="{!v.Order}" class="cu" onmouseover="{!c.mouseOver}" onmouseout="{!c.mouseOut}" data-record="{!v.OrderBy}"> {!v.Label}&nbsp;
                 <a id="{!v.OrderBy}"  href="javascript:void(0)"  style="visibility: hidden;"><lightning:icon iconName="utility:arrowup" size="xx-small" alternativeText="{!$Label.c.Sort_Outbound_logistics}" title="{!$Label.c.Sort_Outbound_logistics}"/></a>  <!-- class="edit_hover_class"  -->
             </span> 
         </aura:set> 
    </aura:if>
    
    
    
    
    
    
    
    <!-- <a onclick="{!c.fetchRecords}" data-service="DESC" title="Descending Order">&#9660;</a>
    <a onclick="{!c.fetchRecords}" data-service="ASC" title="Ascending Order">&#9650;</a> -->  
   
   <!-- <span onclick="{!c.fetchRecords}" data-service="DESC" title="Descending Order">
      <lightning:icon iconName="utility:sort" size="x-small" alternativeText="sort!" title="sort" />                                     
    </span> 
   
    <span onclick="{!c.fetchRecords}" data-service="DESC" title="Descending Order">
      <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                    
    </span>  
    <span onclick="{!c.fetchRecords}" data-service="ASC" title="Ascending Order">      
     <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
    </span>  -->                 
    
</aura:component>