<aura:component controller="InputLookupAuraController" access="global"> 
 <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js,
                           /resource/ERP7__bootStrap/js/bootstrap.min.js, 
                          /resource/ERP7__typeahead" afterScriptsLoaded="{!c.initTypeahead}"/>  
   <!-- <ltng:require styles="/resource/ERP7__InputLookup/css/typeahead.css"/>-->
    <ltng:require styles="/resource/ERP7__Lgt_InputLookup/css/typeahead.css" />
    <aura:registerEvent name="inputLookupEvent" type="c:InputLookupEvt" />
    <aura:handler name="inputLookupEvent" action="{!c.handleInputLookupEvt}"/>
    <aura:attribute name="type" type="String" description="Sobject Type" required="true"/>
    <aura:attribute name="value" type="String" description="Source / Destination value" />
    <aura:attribute name="className" type="String" description="class name of the input object" />
    <aura:attribute name="qry" type="String" description="query param" access="global" default=""/>
    <aura:attribute name="disabled" type="Boolean" default="true"/>
    <aura:attribute name = "exceptionError" type = "String" default = ""/>
    <!-- PRIVATE ATTRS -->
    <aura:attribute name="nameValue" type="String" description="Name of the current lookup 'name' field: loaded by controller" 
                    />  <!-- access="PUBLIC" GLOBAL PRIVATE  GLOBAL -->
    <aura:attribute name="isLoading" type="Boolean" description="Loading component" default="false"
                    /> <!-- access="PUBLIC" PRIVATE GLOBAL -->    
    <div class="has-feedback">
     <input id="{!globalId+'_typeahead'}" type="text" value="{!v.nameValue}" class="InputLookup-class1" 
            readonly="{!v.isLoading}"/> <!--  onchange="{!c.checkNullValue}" -->
      <span class="glyphicon glyphicon-search form-control-feedback"></span>
   </div>
    
    <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed InputLookup-class3','slds-notify_container slds-is-fixed InputLookup-class2')}">
        <div class="slds-notify slds-notify_toast slds-theme_error InputLookup-class4" role="status" >
            <span class="slds-assistive-text">error</span>
            <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="Error!" title="Error" />
            </span>
            <div class="slds-notify__content">
                <h2 class="slds-text-heading_x-small InputLookup-class5" >{!v.exceptionError}
                </h2>
            </div>
            <div class="slds-notify__close InputLookup-class6">
                <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />		
                    <span class="slds-assistive-text">Close</span>
                </button>
            </div>
        </div>
    </div>
    
</aura:component>