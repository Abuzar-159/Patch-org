<aura:component controller="UtilClass">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="objectApiName" type="String" required="true"/>
    <aura:attribute name="fieldSetApiName" type="String" required="true"/>
    
    <aura:attribute name="fields" type="Map"/>
    <aura:attribute name="columns" type="Integer" default="3"/>
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="defaultValues" type="Object" />
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:method name="submit" action="{!c.submit}"/>
    <lightning:recordEditForm aura:id="recordViewForm"
                              onload="{!c.setDefaultValues}"
                              onsuccess="{!c.handleSuccess}"
                              objectApiName="{!v.objectApiName}">
        <lightning:messages />
        <lightning:layout multipleRows="true">
            
            <aura:iteration items="{!v.fields}" var="item" >
                <lightning:layoutItem size="{!12 / v.columns}" padding="horizontal-small">
                    <lightning:inputField fieldName="{!item}" aura:id="input_field"/>
                </lightning:layoutItem>
            </aura:iteration>
        </lightning:layout>
    </lightning:recordEditForm>
</aura:component>