<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" access="global">
    
    <aura:attribute name="Value" description="Barcode value" type="String"  required="required" access="global" />
    <aura:attribute name="BrcdType" description="Barcode Type" type="String" required="required" access="global" />    
    <aura:attribute name="BrcdHeight" description="height" type="String" required="false" access="global" default=''/>
    <aura:attribute name="BrcdWidth" description="width" type="String" required="false" access="global" default=''/>
    <aura:attribute name="hideText" description="Barcode Text Hide" type="boolean" required="false" access="global" default="false"/>  
    <aura:attribute name="response" type="String" access="global"/> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="D2BarcodeId" type="String" access="global"/>  
    
    <!--CSS-->
    <ltng:require styles="{!$Resource.BarcodeZoneLightning + '/css/Qrcode.css'}" afterScriptsLoaded="{!c.cssLoaded}"/>
    <!--jQuery-->
        
    <!--Barcode js-->    
    <ltng:require scripts="{!join(',',
                           $Resource.jQuery + '/js/jquery_3.5.0.min.js',
                           $Resource.BarcodeZoneLightning + '/qrcode/Qrcode.js',
                           $Resource.BarcodeZoneLightning + '/qrcode/jqueryQrcode.js',                           
                           $Resource.BarcodeZoneLightning + '/pdf417/pdf417min.js')}" afterScriptsLoaded="{!c.jsLoaded}"/>   
   
    <span id="{!v.D2BarcodeId}"> </span> <!-- brcode  -->
    
</aura:component>