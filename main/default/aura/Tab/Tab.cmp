<aura:component >
    <aura:attribute name="label" type="String" default="Tab1"/>
    <aura:attribute name="name" type="String" default="Tab1" required="true"/>
    <aura:attribute name="selectedTab" type="String" default="Tab1"/>
    <aura:attribute name="iconclass" type="String" default="fa fa-list-ol"/>
	<li class="{!(equals(v.selectedTab,v.name))?'slds-tabs--default__item slds-is-active':'slds-tabs--default__item'}"  title="" role="presentation">
        <a class="slds-tabs--default__link"  onclick="{!c.changeTab}" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-default-1__item">
            <i class="{!v.iconclass}" aria-hidden="true"></i>&nbsp;{!v.label}
        </a>
    </li><!--fa fa-list-ol-->
</aura:component>