                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Engineer</label>
                            <div class="slds-form-element__control">
                                 <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" selectedRecordId="{!v.Routing.ERP7__Engineer__c}" 
                                       placeholder="Search Engineers..." IconName="utility:user"/> 
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id"> Minimum Lot Size</label>
                            <div class="slds-form-element__control">
                                <lightning:input type="number" value="{!v.Routing.ERP7__Minimum_Lot_Size__c}" />
                            </div>

                        </div>
                    </div>
                <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">BOM Version</label>
                            <div class="slds-form-element__control">
                              <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.Routing.ERP7__BOM_Version__c}" 
                                       placeholder="Search BOM Versions..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                            </div>

                        </div>
                     </div>
                  
          </div>
        
         <div class="row">  
           <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Maximum Lot Size</label>
                            <div class="slds-form-element__control">
                                 <lightning:input type="number" value="{!v.Routing.ERP7__Maximum_Lot_Size__c}" />
                            </div>

                        </div>
                    </div>
         </div>  
          
          
       
      </div>
      <footer class="slds-modal__footer slds-text-align--center">
        <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
        <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
      </footer>
         
    </div>

  </div>   
  </section>
    </div>    
     <div class="slds-backdrop slds-backdrop--open"></div>
 </aura:if>
                  
                </aura:if>
              </div> 
              
                          
                          
                          
                          
                          
                          
                          
              
                          
                                   
    <div class="" id="bomTabId" aura:id="bomTabId">
              <aura:if isTrue="{!v.Tab=='bom'}">
                                 <div class="slds-page-header ProductDetails-newClass7">
                                                <div class="slds-grid">
                                                    <div class="slds-col slds-has-flexi-truncate">
                                                        <div class="slds-media slds-no-space slds-grow">
                                                            <div class="slds-media__body">
                                                                <nav>
                                                                    <ol class="slds-breadcrumb slds-line-height_reset">

                                                                    </ol>
                                                                </nav>
                                                                <h4 class="slds-m-right_small slds-align-middle" title="">BOMS ({!v.BOMList.length})</h4>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="slds-col slds-align-middle ">                                                    
                                                            <c:StockTakeSearch Placeholder="Search by Name or Quantity or Type"/>                                                               
                                                    </div>
                                                    <div class="slds-col slds-no-flex slds-grid slds-align-middle">

                                                        <div class="slds-button-group slds-m-top--small" role="group">
                                                            <button onclick="{!c.showNewPopup}" data-name="bom" data-service="new" class="slds-button slds-button--brand" data-toggle="modal" data-target="#myModal">
                                                                <i class="fa fa-plus"></i>&nbsp;New</button>
                                                        </div>
                                                    </div>
                                                </div>
                                     <div class="slds-card__body ProductDetails-newClass26">
                                         <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-top--small">
                                                    <thead>
                                                        <tr class="slds-text-title--caps">
                                                            <th class="slds-cell-shrink" scope="col">
                                                                &nbsp;
                                                            </th>
                                                                 
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="">  Actions                                                          
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="">Name
                                                                   
                                                                </div>
                                                            </th>
                                                          
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Bom Component
                                                                    
                                                                </div>
                                                            </th>
                                                             <th scope="col">
                                                                <div class="slds-truncate" title=""> Bom Version
                                                                    
                                                                </div>
                                                            </th>
                                                           
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Quantity

                                                                    
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Unit of Measure
                                                                    
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Status
                                                                    
                                                                </div>
                                                            </th>
                                                       <th scope="col">
                                                                <div class="slds-truncate" title=""> Process Cycle
                                                                    
                                                                </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Routing Link Code
                                                                    
                                                                </div>
                                                            </th>
                                                         </tr>
                                                    </thead>
                                                    <tbody>
                                                      <aura:iteration items="{!v.BOMList}" var="r" indexVar="index">
                                                        <tr class="slds-hint-parent">
                                                            <td scope="row" data-label="">
                                                             

                                                            </td>
                                                             <td data-label="Actions">
                                                              
                                                                            <img onclick="{!c.getRecord}" class="ProductDetails-newClass28" data-name="update" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" id="0" title="Edit" />&nbsp;
                                                                            <img onclick="{!c.getDelete}" class="ProductDetails-newClass28" data-name="delete" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" id="0" title="Delete" />
                                                            </td>
                                                            <td scope="row" data-label="Name">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!r.Name}"/> 
                                                                </div>
                                                            </td>
                                                          <td data-label="BOM Component">
                                                                <div class="slds-truncate">
                                                                 <lightning:formattedText value="{!r.ERP7__BOM_Component__r.Name}"/>
                                                                </div>
                                                            </td>
                                                            <td data-label="BOM Version">
                                                                <div class="slds-truncate">
                                                                 <lightning:formattedText value="{!r.ERP7__BOM_Version__r.Name}"/>
                                                                </div>
                                                            </td>
                                                            <td data-label="Quantity">
                                                                <div class="slds-truncate">
                                                                <lightning:formattedNumber value="{!r.ERP7__Quantity__c}"/> 
                                                                </div>
                                                            </td>
                                                            <td data-label="Unit of Measure">
                                                                <div class="slds-truncate">
                                                                <lightning:formattedText value="{!r.ERP7__Unit_of_Measure__c}"/> 
                                                                </div>
                                                            </td>
															<td data-label="Status">    
                                                               <div class="slds-truncate">
                                                                 <lightning:formattedText value="{!r.ERP7__Status__c}"/> 
                                                                </div>
                                                            </td>
															<td data-label="Quantity">
                                                               <div class="slds-truncate">
                                                                 <lightning:formattedText value="{!r.ERP7__Process_Cycle__r.Name}"/> 
                                                                </div>
                                                            </td>
															<td data-label="Quantity">
                                                               <div class="slds-truncate">
                                                                 <lightning:formattedText value="{!r.ERP7__Routing_Link__r.Name}"/> 
                                                                </div>
                                                            </td>
															
                                                        </tr>
                                                    </aura:iteration>      

                                                    </tbody>
                                                </table>
                                     </div>
                                    </div>
                  
 <aura:if isTrue="{!v.showPopup}"> 
  <div class="erp_mark7"> 
  <section id="ppId" role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1"
           class="slds-modal slds-fade-in-open slds-modal--medium"> 
   <div class="slds-modal__container">

    <div>
      <div class="slds-modal__header">
         <button onclick="{!c.HideNewPopup}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
          	 <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close" title="close" />

          <span class="slds-assistive-text">Close</span>
        </button>
          
        <h4 class="modal-title slds-align--absolute-center" >
		   <aura:if isTrue="{!v.Tab!='update'}"> New
             <aura:set Attribute="else">Update</aura:set>               
          </aura:if>
		  BOM
		</h4>
      </div>
      <div class="slds-modal__content slds-p-around_medium ProductDetails-newClass13">
          <div class="row slds-m-top--xx-small">
                           <div class="col-md-12">    
                              <span class="{!v.seBool==true?'red ProductDetails-newClass12':'slds-hide ProductDetails-newClass12'}"
                                   >
                                <i class="fa fa-window-close ProductDetails-newClass14" aria-hidden="true" ></i> &nbsp;{!v.sError}
                              </span>
                            </div>
          </div>
          
          <div class="row">
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Name</label>
                            <div class="slds-form-element__control">
                                <lightning:input type="text" variant="label-hidden" value="{!v.BOM.Name}" />
                            
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Quantity</label>
                            <div class="slds-form-element__control">
                                
								<lightning:input type="number" value="{!v.BOM.ERP7__Quantity__c}" />
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Type</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.BOM.ERP7__Type__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.BOMTypeList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.BOM.ERP7__Type__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div> 
                    </div>
					<div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Component Type</label>
                            <div class="slds-form-element__control">
                                 <lightning:select value="{!v.BOM.ERP7__Component_Type__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.BOMComponentTypeList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.BOM.ERP7__Component_Type__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div> 
                    </div>
                     <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">BOM (Assest)</label>
                            <div class="slds-form-element__control">
                              <c:CustomInputLookUp objectAPIName="ERP7__Asset__c" selectedRecordId="{!v.BOM.ERP7__BOM_Asset__c}" 
                                       placeholder="Search BOM (Assest)..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                            </div>

                        </div>
                    </div>
               <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">BOM Version</label>
                            <div class="slds-form-element__control">
                              <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.BOM.ERP7__BOM_Version__c}" 
                                       placeholder="Search Version..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                            </div>

                        </div>
                    </div>
              <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Bom Component </label>
                            <div class="slds-form-element__control">
                               <c:CustomInputLookUp objectAPIName="Product2" selectedRecordId="{!v.BOM.ERP7__BOM_Component__c}" 
                                       placeholder="Search Product..."/>
                            </div>

                        </div>
                    </div>
              <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Routing Link Code </label>
                            <div class="slds-form-element__control">
                               <c:CustomInputLookUp objectAPIName="ERP7__Routing_Link__c" selectedRecordId="{!v.BOM.ERP7__Routing_Link__c}" 
                                       placeholder="Search Routing Links..."/>
                            </div>

                        </div>
                    </div>
					 <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Status</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.BOM.ERP7__Status__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.BOMStatusList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.BOM.ERP7__Status__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div>
                    </div>
               <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Unit of measure</label>
                            <div class="slds-form-element__control">
                                 <lightning:select value="{!v.BOM.ERP7__Unit_of_Measure__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.BOMUoMList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.BOM.ERP7__Unit_of_Measure__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div>
                    </div>
					<div class="col-md-4 slds-p-top--xx-small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Sort</label>
                            <div class="slds-form-element__control">
                             <lightning:input type="number" value="{!v.BOM.ERP7__Sort__c}" aura:id="mid" /> 
                            </div>
                        </div>
                    </div>
                  
          </div>       
      </div>
	  
      <footer class="slds-modal__footer slds-text-align--center">
        <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
        <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
      </footer>
         
    </div>

  </div>   
  </section>
    </div>    
     <div class="slds-backdrop slds-backdrop--open"></div>
 </aura:if>
 </aura:if>
 </div> 
                          
                          
                          
           <!--  ====================================  DELETE RECORDS =========================================== -->                    
            <div aria-hidden="true" class="slds slds-hide" aura:id="deleteConfirmId"> 
                    <div aria-hidden="false" role="dialog" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container ProductDetails-newClass15">
                    <div class="slds-modal__content"> 
                      <div class="slds-modal__content slds-p-around--medium"> 
                      <div class="slds-form-element__control">
                          <label class="slds-radio">
                              <span class="slds-form-element__label"> <!--Record? --> </span> <br/>
                                <span class="ProductDetails-newClass16">Are you sure you want to delete this record?</span>
                          </label>
                      </div> 
                     </div>  
                      <div  class="modal-footer ProductDetails-newClass17" >  
                        <span >
                            <button type="button" class="slds-button slds-button--brand" data-dismiss="modal" data-record="Yes" value="Yes" 
                                    aura:id="yesId" onclick="{!c.saveRecord}">Yes</button> 
                            <button type="button" value="No" class="slds-button slds-button--neutral" data-record="NO"  aura:id="noId"
                                    onclick="{!c.cancelDelete}">No</button> 
                         
                        </span>   
                      </div>
                    </div> 
                    </div>                    
                    </div>       
                     <div class="slds-backdrop slds-backdrop--open"></div>         
            </div>            
                          
                          
                          
                          
                          
                          
                      </div>    
                      </div>
                    </div>    
                    
                    
                </div>
                </div>
         </div> 
         
    </div>               
</aura:component>