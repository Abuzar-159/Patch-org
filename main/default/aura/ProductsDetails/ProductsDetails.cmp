<aura:component controller="ProductLifecycleManagement" implements="force:appHostable,forceCommunity:availableForAllPageTypes" access="global">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink"/> 
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css, /resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.min.css,
                              /resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductsDetails.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    </head>   
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
	 <aura:handler name="onSaveSuccess" event="force:recordSaveSuccess" action="{!c.handleSaveSuccess}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchEventHandler}"/> 
    <aura:attribute name="ProductId" type="ID" default=""/> <!-- 01t24000007zGi7AAE  -->
    <aura:attribute name="Tab" type="String" default="ver"/>
    <aura:attribute name="action" type="String" default=""/>
    <aura:attribute name="showPopup" type="Boolean" default="false"/> <!-- true   -->
    <aura:attribute name="Product" type="Product2" default=""/>
    <aura:attribute name="Media" type="Media__c" default=""/>
    <aura:attribute name="MediaList" type="String[]"/>
     <aura:attribute name="MediaMap" type="String[]"/>
    <aura:attribute name="MediaMapD" type="String[]"/>
    <aura:attribute name="Routing" type="Routing__c" default=""/>
    <aura:attribute name="RoutingList" type="String[]"/>
    <aura:attribute name="Version" type="Version__c" default=""/>
    <aura:attribute name="VersionList" type="String[]"/>
   
    <aura:attribute name="WarrantyRP" type="Warranty_Return_Policy__c" default=""/>
    <aura:attribute name="WarrantyRPList" type="String[]"/>
    <aura:attribute name="ChangeOrder" type="Change_Order__c" default=""/>
    <aura:attribute name="ChangeOrderList" type="String[]"/>
    <aura:attribute name="QualityOrder" type="Quality_Order__c" default=""/>
    <aura:attribute name="QualityOrderList" type="String[]"/>
    <aura:attribute name="PBE" type="PricebookEntry"/>
    <aura:attribute name="PBEList" type="String[]"/>
    
    <aura:attribute name="ProductFamilyList" type="String[]"/>
    <aura:attribute name="ProductTypeList" type="String[]"/>
    <aura:attribute name="ProductCategoryList" type="String[]"/>
    <aura:attribute name="ProductTaxCodeList" type="String[]"/>
    <aura:attribute name="ProductSubCategoryList" type="String[]"/>
    <aura:attribute name="ProductUoMList" type="String[]"/>
    <aura:attribute name="ProductQuantityUnitOfMeasureList" type="String[]"/>
    <aura:attribute name="ProductStatusList" type="String[]"/>
    <aura:attribute name="ProductWeightDimensionsList" type="String[]"/>
    
    <aura:attribute name="RoutingStatusList" type="String[]"/>
    <aura:attribute name="RoutingTypeList" type="String[]"/>
    <aura:attribute name="VersionStatusList" type="String[]"/>
    <aura:attribute name="VersionTypeList" type="String[]"/>
    <aura:attribute name="VersionCategoryList" type="String[]"/>
    <aura:attribute name="ReturnPolicyRefundOptionList" type="String[]"/>
    
    <aura:attribute name="seBool" type="Boolean" default="false"/>
    <aura:attribute name="sError" type="String" default="All * Fields are mandatory"/>
    <aura:attribute name="priceBookMsg" type="String" default=""/>   
    <aura:attribute name="Index" type="ID" default=""/>
    <aura:attribute name="MediaTypeList" type="String[]"/>
    <aura:attribute name="COCategoryList" type="String[]"/>
    <aura:attribute name="COTypeList" type="String[]"/>
    <aura:attribute name="COStatusList" type="String[]"/>
    <aura:attribute name="COProjectList" type="String[]"/>
    <aura:attribute name="SaveMsg" type="String" default=""/> 
    <aura:attribute name="showMainSpin" type="Boolean" default="false"/> 
    <aura:attribute name="WarrantyRPRO" type="String[]"/>
    
    <aura:attribute name="BOMTypeList" type="String[]"/>
    <aura:attribute name="BOMComponentTypeList" type="String[]"/>
    <aura:attribute name="BOMStatusList" type="String[]"/>
    <aura:attribute name="BOMUoMList" type="String[]"/>
    
    <aura:attribute name="MediaListD" type="String[]"/> 
    <aura:attribute name="RoutingListD" type="String[]"/> 
    <aura:attribute name="VersionListD" type="String[]"/> 
    <aura:attribute name="WarrantyRPListD" type="String[]"/> 
    <aura:attribute name="ChangeOrderListD" type="String[]"/>
    <aura:attribute name="QualityOrderListD" type="String[]"/> 
    <aura:attribute name="PBEListD" type="String[]"/> 
    <aura:attribute name="CloneURL" type="String" default=""/> 
    <aura:attribute name="Clone" type="Boolean" default="false"/>  
    <aura:attribute name="VersionId" type="String" default="" access="global"/>  <!-- a0V1o00000bQnMeEAK  -->
   <!-- <aura:registerEvent name="AttachmentEvnet" type="c:AttachmentEvnet"/> -->
    
    <aura:attribute name="BOM" type="BOM__c"/> 
    <aura:attribute name="BOMList" type="String[]"/> 
    <aura:attribute name="BOMListD" type="String[]"/> 
    
     <aura:handler event="c:AttachmentEvnet" action="{!c.FetchAttachmentBody}"/>
     <aura:attribute name="AttachmentBody" type="String" default=""/>
     <aura:attribute name="ParentId" type="String" default=""/>
     <aura:attribute name="FileName" type="String" default=""/>
     <aura:attribute name="MediaBody" type="String" default=""/> 
     <aura:attribute name="ContentType" type="String" default=""/>
     <aura:attribute name="fileNameVal" type="String" default="" />  
     <aura:attribute name="attachId" type="String" default="" />  
     <aura:attribute name="VersionRTList" type="String[]"/>
     <aura:attribute name="RoutingRTList" type="String[]"/>
    <aura:attribute name="isRelatedRecordCreated" type="Boolean" default="true"/>
     <aura:attribute name="reRenderEventField" type="Boolean" default="true"/>
    
     <div class="erp_mark7 ProductDetails-newClass1" aura:id="body">
           <div class="slds-page-header slds-m-bottom--xx-small">
            <div class="slds-media">
                <div class="slds-media__figure">
                 <span class="slds-icon_container slds-icon-action-back slds-icon--large" title="">              
                         <lightning:icon iconName="standard:product" variant="inverse" size="x-medium" alternativeText="product" title="product" />
                </span>
                </div>
                <div class="slds-media__body">
                  
                   <h1 class="slds-page-header__title slds-truncate slds-align-middle slds-m-top--small" title="">
                     Product Versions   
                 	</h1>
                     
                </div>
                <div class="slds-col slds-grid slds-align-middle">
                     <h2 class="slds-page-header__title slds-truncate">
                    {!v.Version.Name}</h2></div>
                <div class="slds-col slds-no-flex slds-grid slds-align-top">
                     <button class="slds-button slds-button--neutral" 
                                                     onclick="{!c.cancelRecord}" aura:id="saveProductId">Back</button>
                </div> 
                
       <div class="slds-col slds-no-flex slds-grid slds-align-top" >
                    <lightning:formattedUrl aura:id="CloneId" label="Clone" target="_blank" class="{!v.VersionId==''?'DisaClass slds-button slds-button--brand CloneClass':'slds-button slds-button--brand CloneClass'}"
                                                                                   value="{!v.CloneURL}"/>
					 													   
                </div>
            </div>
        </div>
            <div class="epr_Mark7 slds-m-bottom--small">
            <div class="container-fluid">
                <div class="row ProductDetails-newClass2">
                    <div class="col-md-2 col-xs-2 ProductDetails-newClass3">

                        <!-- Tabs -->
                        <div class="tabbable tabs-left">
                            <ul class="nav nav-tabs">
                               <li class="active ProductDetails-newClass4" onclick="{!c.getTab}" data-name="ver" data-service="0" aura:id="TabId">
                                    <a data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-stack-overflow"></i></P><span class="slds-truncate ProductDetails-newClass18">Versions</span></a>
                                </li>
                                <li class="ProductDetails-newClass4" onclick="{!c.getTab}" data-name="med" data-service="1" aura:id="TabId"> 
                                    <a data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-image"></i></P>
                                        <span class="slds-truncate ProductDetails-newClass18">Media</span></a>
                                </li>                              
                                <li class="ProductDetails-newClass4" onclick="{!c.getTab}" data-name="rou" data-service="2" aura:id="TabId">
                                    <a data-toggle="tab"> 
                                        <P class="iconclass"><i class="fa fa-product-hunt"></i></P>
                                        <span class="slds-truncate ProductDetails-newClass18">Routing</span>
                                    </a>
                                </li>
                                 <li class="ProductDetails-newClass4" onclick="{!c.getTab}" data-name="bom" data-service="3" aura:id="TabId"> 
                                    <a data-toggle="tab"> 
                                        <P class="iconclass"><i class="fa fa-compress"></i></P><span class="slds-truncate ProductDetails-newClass18">BOM'S</span>
                                   </a>
                                </li>                             
                            </ul>
                        </div>
                    </div>
                    
                   
  <div class="col-md-10">
  <div>
  <div class="tab-content">
      
                        
  <div class="" id="versionTabId" aura:id="versionTabId">
   <aura:if isTrue="{!v.Tab=='ver'}">  
        
       
        <aura:if isTrue="{!v.SaveMsg!=''}">
                                    <div class="maq-only erp_mark7">
                                           <div class="slds-notify_container slds-is-relative">
                                        <div class="slds-notify slds-notify_toast slds-theme--success" role="alert">                                   
                                        <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                                            <lightning:icon iconName="utility:success" variant="inverse" size="x-medium" alternativeText="success" title="success" />
                                        </span>
                                       <div class="slds-notify__content ProductDetails-newClass19">
                                        <h2 class="slds-text-heading_small ">{!v.SaveMsg}</h2>
                                        </div>
                                      
                                        <div class="slds-notify__content ProductDetails-newClass20">
                                           <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" 
                                                   onclick="{!c.getNotificationHide}">
                                               <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close" title="close" />                                              
                                                <span class="slds-assistive-text">Close</span>
                                              </button>
                                            
                                        </div>
                                            
                                        </div>
                                        </div>
                                        </div>
                       
                   </aura:if>  
        
       
 
  <div class="erp_mark7">   
    <div>     
          <div class="row slds-m-top--small">
                           <div class="col-md-12">    
                              <span class="{!v.seBool==true?'red ProductDetails-newClass12':'slds-hide ProductDetails-newClass12'}"
                                  >
                                <i class="fa fa-window-close ProductDetails-newClass14" aria-hidden="true"></i> &nbsp; Code field is mandatory
                              </span>
                            </div>
          </div>
          
          <div class="row">
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Code</label>
                            <div class="slds-form-element__control">
                                <lightning:input type="text" variant="label-hidden" value="{!v.Version.Name}" />
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Start Date</label>
                            <div class="slds-form-element__control">
                              <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.Version.ERP7__Start_Date__c}"  />
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">To Date</label>
                            <div class="slds-form-element__control">
                                <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.Version.ERP7__To_Date__c}"  /> 
                            </div>

                        </div>
                    </div>
                     <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Category</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.Version.ERP7__Category__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.VersionCategoryList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Category__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div>
                    </div>
                   
                     
          </div>
          
          <div class="row">
                   <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Type</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.Version.ERP7__Type__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.VersionTypeList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Type__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Status</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.Version.ERP7__Status__c}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.VersionStatusList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Status__c, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Asset</label>
                            <div class="slds-form-element__control">
                               <c:CustomInputLookUp objectAPIName="ERP7__Asset__c" selectedRecordId="{!v.Version.ERP7__Asset__c}" 
                                       placeholder="Search Assets..." IconName="custom:custom24"/>
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Process</label>
                            <div class="slds-form-element__control">
                              <c:CustomInputLookUp objectAPIName="ERP7__Process__c" selectedRecordId="{!v.Version.ERP7__Process__c}" 
                                       placeholder="Search Process..." IconName="standard:orders"/> 
                            </div>

                        </div>
                    </div>
          </div>
          
             <div class="row">
                 <div class="col-md-3 slds-p-top--small">
                     <div class="slds-form-element">
                         <label class="slds-form-element__label" for="input-unique-id">Quantity</label>
                         <div class="slds-form-element__control">
                             <lightning:input type="number" value="{!v.Version.ERP7__Quantity__c}" /> 
                         </div>
                     </div>
                 </div>
                 
                 <div class="col-md-3 slds-p-top--small">
                     <div class="slds-form-element">
                         <label class="slds-form-element__label" for="input-unique-id">Price Book</label>
                         <div class="slds-form-element__control">
                             <c:CustomInputLookUp objectAPIName="PriceBook2" selectedRecordId="{!v.Version.ERP7__Price_Book__c}" placeholder="Search Price Books..." IconName="standard:orders"/>
                         </div>
                         
                     </div>
                 </div>
                 
                 
                 
                 
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Inventory / Stock</label>
                            <div class="slds-form-element__control">
                               <c:CustomInputLookUp objectAPIName="ERP7__Inventory_Stock__c" selectedRecordId="{!v.Version.ERP7__Inventory_Stock__c}" 
                                       placeholder="Search Inventory / Stocks..." IconName="custom:custom32"/>
                            </div>

                        </div>
                    </div>
          </div>
          
           <div class="row">
                   <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Picture</label>
                            <div class="slds-form-element__control">
                               <lightning:input type="text" variant="label-hidden" value="{!v.Version.ERP7__Picture__c}" />                            
                            </div>
                        </div>
                    </div>
               
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Record Type</label>
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.Version.RecordTypeId}" variant="label-hidden"  class="display-lable">
                                    <aura:iteration items="{!v.VersionRTList}" var="option">
                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.RecordTypeId, option.value)}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div>

                        </div>
                    </div>
               
               
                    <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Default</label>
                            <div class="slds-form-element__control">
                                <lightning:input type="checkbox" checked="{!v.Version.ERP7__Default__c}" />
                            </div>

                        </div>
                    </div>
                    
                   <div class="col-md-3 slds-p-top--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="input-unique-id">Sales Ready</label>
                            <div class="slds-form-element__control">
                              <lightning:input type="checkbox" checked="{!v.Version.ERP7__Sales_Ready__c}" />
                            </div>

                        </div>
                    </div>
                  
        </div>
        
        <div class="row">
            <div class="col-md-3 slds-p-top--small">
                <div class="slds-form-element">
                    <label class="slds-form-element__label" for="input-unique-id">Barcode</label>
                    <div class="slds-form-element__control">
                        <lightning:input type="text" variant="label-hidden" value="{!v.Version.ERP7__Barcode__c}" />
                    </div>
                    
                </div>
            </div>
            <div class="col-md-3 slds-p-top--small">
                <div class="slds-form-element">
                    <label class="slds-form-element__label" for="input-unique-id">Description</label>
                    <div class="slds-form-element__control">
                        <lightning:textarea value="{!v.Version.ERP7__Description__c}" />
                    </div>
                    
                </div>
            </div>
            <div class="col-md-3 slds-p-top--small">
                <div class="slds-form-element">
                    <label class="slds-form-element__label" for="input-unique-id">Active</label>
                    <div class="slds-form-element__control">
                        <lightning:input type="checkbox" checked="{!v.Version.ERP7__Active__c}" />
                    </div>
                </div>
            </div>
        </div>   
         
      
                                    <div class="row ProductDetails-newClass5">                                         
                                         <div class="row ProductDetails-newClass6">                                                                                 
                                            <div class="mainfloatbutton ProductDetails-newClass4">
                                            
                                             <button class="slds-button slds-button--brand" onclick="{!c.saveRecord}" aura:id="saveProductId">Save</button> 
                                                
                                               
                                                
                                            </div> <!--{!v.VersionId==''?'RedButtonClass slds-button slds-button-brand':'slds-button slds-button-brand'}   -->
                                        </div>
                                     
                                          <div class="row ProductDetails-newClass6">                                      
                                            <div class="col-md-10 ProductDetails-newClass4">                                                
                                                                                             
                                            </div>
                                        </div>
                                            
                                            
                                    </div>
        
    
         
    </div>

  </div>   
 
 </aura:if>          
 </div>                       
                          
                        
      
                       
                          
  <div class="" id="mediaTabId" aura:id="mediaTabId"><!-- tab-pane  --> 
      <aura:if isTrue="{!v.Tab=='med'}">
          
             <div class="slds-page-header ProductDetails-newClass7">
                                                <div class="slds-grid">
                                                    <div class="slds-col slds-has-flexi-truncate">
                                                        <div class="slds-media slds-no-space slds-grow">
                                                            <div class="slds-media__body">
                                                                <nav>
                                                                    <ol class="slds-breadcrumb slds-line-height_reset">

                                                                    </ol>
                                                                </nav>
                                                                <h4 class="slds-m-right_small slds-align-middle slds-truncate" title="">Media ({!v.MediaMap.length})
                                                                
                                                                </h4>    
                                                            </div>
                                                            
                                                        </div>
                                                       
                                                                
                                                    </div>
                                                   <div class="slds-col  slds-align-middle">  
                                                   <!--<div class="container-fluid">
                                                            <div class="row slds-m-bottom-small"> -->
                                                                <c:StockTakeSearch Placeholder="Search By Name"/>                                                               
                                                    
                                                    </div> 
                                                    
                                                    <div class="slds-col slds-no-flex slds-grid slds-align-middle">

                                                        <div class="slds-button-group slds-m-top--small" role="group">
                                                            <button onclick="{!c.showNewPopup}" data-name="med"  data-service="new" class="slds-button slds-button--brand" data-toggle="modal" data-target="#myModal">
                                                                <i class="fa fa-plus"></i>&nbsp;New</button> <!-- createRecord  -->
                                                        </div>
                                                    </div>
                                                </div>
                                    
                 
                 
                 
                 						<!-- Media Gallery -->
                                         <div class="maq ProductDetails-newClass9">
                                        
                                           <aura:iteration items="{!v.MediaMap}" var="m" indexVar="index">  
                                        	<div class="responsive">                                 
                                              <div class="gallery"> 
                                             
                                              <a target="_blank" href="{! '/servlet/servlet.FileDownload?file=' + m.value.ERP7__File__c}">  
                                                
                                                 <!--   <iframe width="720" height="480" src="https://www.youtube.com/embed/45JRuZOBIKk"></iframe>
                                                   <img src="" alt="Trolltunga Norway" width="300" height="200"/> -->
                                                  
                                                <aura:if isTrue="{!m.value.ERP7__Type__c=='Video'}">   <!--  noDownload || m.value.ERP7__Type__c=='Audio'  -->
                                                    <video width="270" height="180" controls="true" controlsList="">  
                                                        <source src="{!'data:image/gif;base64,'+m.key}" type="video/webm"/> <!-- video/mp4 video/ogg video/webm  -->
                                                                                         
                                                    </video> 
                                                 
                                                   <aura:set attribute="else">
                                                       <img src="{!'data:image/gif;base64,'+m.key}"/>
                                                   
                                                   </aura:set>
                                               </aura:if>                                             
                                              </a>   
                                               <div class="icons-cd">
                                                      
                                                      <img onclick="{!c.getRecord}" class="ProductDetails-newClass10" id="{!m.value.ERP7__File__c}" data-name="update" 
                                                           data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" 
                                                           title="Edit" />
