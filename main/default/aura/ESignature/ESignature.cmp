<aura:component  controller="ESignature" implements="force:hasSObjectName,force:hasRecordId,force:appHostable,forceCommunity:availableForAllPageTypes,flexipage:availableForRecordHome,force:appHostable,force:lightningQuickActionWithoutHeader" access="global" >
    <ltng:require scripts="{!$Resource.esignature + '/signature_pad.min.js'}" afterScriptsLoaded="{!c.onScriptReady}"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ESignature.css"/>
    <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:attribute name="id" type="String" default=""/>
    <aura:attribute name="minWidth" type="double" default="0.5"/>
    <aura:attribute name="maxWidth" type="double" default="2"/>
    <aura:attribute name="penColor" type="string" default="rgb(0,0,0)"/>
    <aura:attribute name="signatureData" type="string" default=""/>
    <aura:attribute name="readOnly" type="Boolean" default="false"/>
    <aura:attribute name="showSave" type="Boolean" default="true"/>
    <aura:attribute name="style" type="string" access="private"/>
    <aura:attribute name="signaturePad" type="object" access="private"/>
    <aura:attribute name="parentID" type="string" default=""/>
    <aura:attribute name="Name" type="string" default=""/>
    <aura:attribute name="Attachments" type="object[]"/>
    <aura:attribute name="RecordId" type="String" default=""/><!--00P1o00001L4xdaEAB-->
    
    <aura:method name="saveSignatureFromParent" action="{!c.saveSignature}" access="global"/>
    <aura:method name="capture" action="{!c.onCapture}" 
        description="call this method to capture signature"/>
    <aura:method name="clear" action="{!c.onClear}" description="clear the signature"/>
     <aura:registerEvent name="cmpEvent" type="c:SignatureEvent"/>
    
    
    
    
    <div class="mb-signature-container shadow-sign" 
        ontouchmove="{!c.handleTouchMove}"
        ontouchstart="{!c.onTouch}">
        <aura:if isTrue="{!v.readOnly}">
            <div class="mb-signature-pad-readonly">
              <!--  <img alt="User Signature" src="{!v.signatureData}"/> --> 
                <img src="{!'/servlet/servlet.FileDownload?file='+v.RecordId}" class="img-style" alt=""/>
           </div>
            <aura:set attribute="else">
                <input type="text" readonly="true" class="esignature-hide"/>
                <div class="mb-signature-pad" id="{!'signatureWrapper' + v.id}">
                    <div class="mb-signature-pad-body">
                        <canvas></canvas>
                    </div>
                </div>
                <div class="slds-grid pad-5">
                    <div class="slds-col slds-m-right--xx-small">
                        <button onclick="{!c.onClear}" class="slds-button slds-button--neutral width100">{!$Label.c.Clear}</button> <!--added label on 19/02 Asra-->
                    </div>
                    <aura:if isTrue="{!v.showSave}"> 
                        <div class="slds-col">
                            <button aura:id="button1"   name="" value="" class="slds-button slds-button--brand width100" disabled=""  onclick="{!c.saveSignature}">{!$Label.c.ContractConsole_Save}</button><!--added label on 19/02 Asra-->
                        </div>
                    </aura:if>     
                    
                </div>
            </aura:set>
        </aura:if>
    </div>
</aura:component>