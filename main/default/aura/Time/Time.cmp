<aura:component implements="force:appHostable,forceCommunity:availableForAllPageTypes" access="global">  
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-ltng.css" /> 
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css" /> 
    
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
    <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js"/>  
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>    
    <aura:attribute name="value" type="String" default=""/> 
    <aura:attribute name="TimeList" type="String[]" default=""/> 
    <aura:attribute name="RIndex" type="Integer" default="0"/>  
    <aura:attribute name="TIndex" type="Integer" default="0"/>
    <aura:registerEvent name="TimeEvent" type="c:TimeEvent"/> 
    <aura:attribute name="showTimePanel" type="Boolean" default="false"/>			
    <aura:attribute name="DIndex" type="Integer" default="0"/>  
    <aura:attribute name="action" type="String" default=""/>  
    <aura:attribute name="resetComp" type="Boolean" default="true"/> 
    <aura:attribute name="TimeDuration" type="Integer" default="0"/> 
    <aura:attribute name="isAvailable" type="Boolean" default="true"/>  
    
    
    <div class="erp_mark7">
        <form class="slds-form--inline time-cls1"   >        
            <div class="slds-form-element">  <!--  onmouseleave="{!c.onmousemoveTimePanel}" -->   
                <div class="slds-picklist slds-dropdown-trigger slds-dropdown-trigger--click slds-is-open search-refine-element-panel"> 
                    <div class="slds-form-element">
                        <div data-way="inp" data-time="{!v.value}" class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right slds-picklist__input time-cls1" >                    
                            
                            <input type="text" value="{!v.value}" onclick="{!c.onfocusTime}" onkeyup="{!c.changeTime}" onblur="{!c.hideTimePanel}"
                                   class="{!and(v.value==undefined,v.isAvailable==false)?'TimeCursorNotAllowedClass': v.value==undefined? 'TimeDisableClass' : 'slds-input'}"
                                   aura:id="inpTimeId" disabled="{!and(v.value==undefined,v.isAvailable==false)}"/>         
                                
                            
                            <aura:renderIf isTrue="{!v.showTimePanel}" > 
                                <div class="epr_Mark7 slds-dropdown slds-dropdown--left slds-dropdown--length-24 time-cls2" role="listbox" >                         
                                    <div class="row">                                                  
                                        <div class="col-md-12"> 
                                            <ul id="option-list-02" class="slds-dropdown__list" role="group" aria-label="" >
                                                <div aura:id="searchRes" class="slds-form-element scroll-box slds-is-close time-cls3" >     
                                                    <aura:iteration items="{!v.TimeList}" var="item" indexVar="index" >   
                                                        <li onclick="{!c.changeTime}" data-way="li" data-time="{!item.value}" class="slds-is-selected time-cls4" > <!--  role="presentation"  -->                                                                          
                                                            <div  class="slds-form-element"> <!-- {!item.value}  -->
                                                                <table>
                                                                    <tr>                                                 													  
                                                                        <td>
                                                                            <option value="{!item.value}">{!item.label}</option>                                               
                                                                        </td>
                                                                    </tr>
                                                                </table>                                            
                                                            </div>
                                                        </li>
                                                    </aura:iteration> 
                                                </div>   
                                            </ul>                                   
                                        </div>                       
                                    </div>              
                                </div> 
                                
                            </aura:renderIf>    
                            
                            
                            
                        </div>   
                    </div> 
                    
                    
                </div>
                
            </div> 
        </form>
    </div>
</aura:component>