<aura:component controller="ManageProjects" implements="force:appHostable">
    
    <head>
        
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        <ltng:require styles="/resource/ERP7__newGanttChart/GANTT/codebase/dhtmlxgantt.css"/>
        <ltng:require scripts="/resource/ERP7__newGanttChart/GANTT/codebase/dhtmlxgantt.js" afterScriptsLoaded="{!c.initGantt}"/>
        
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProjectScheduler.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        
    </head>
    
    <aura:attribute name = "TODAY" type = "String"/>
    <aura:attribute name = "exceptionError" type = "String" default=""/>
    <aura:attribute name = "ProjectList" type = "object"/>
    <aura:handler name = "init" value = "{!this}" action = "{!c.doInit}"/>
    
    <html background = "#fff">
        <body>
            <div class="maqsood epr_Mark7 slds-theme_default PS-newClass1">
                
                <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'PS-newClass2 slds-notify_container slds-is-fixed','PS-newClass3 slds-notify_container slds-is-fixed')}">
                    <div class="slds-notify slds-notify_toast slds-theme_error PS-newClass4" role="status">
                        <span class="slds-assistive-text">{!$Label.c.Error_UsersShiftMatch}</span>
                        <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                            <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" />
                        </span>
                        <div class="slds-notify__content">
                            <h2 class="slds-text-heading_x-small PS-newClass5">{!v.exceptionError}
                            </h2>
                        </div>
                        <div class="slds-notify__close PS-newClass6">
                            <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="close" />
                                <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <span class="PS-newClass7">
                    <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass PS-newClass8"/>
                </span>
                
                <div class="container-fluid p-5">
                    <div class="head slds-grid">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small PS-newClass9">
                            {!$Label.c.Project_Scheduler}&nbsp;
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small PS-newClass10">
                            <lightning:formattedText value="{!v.TODAY}"/>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small PS-newClass11">
                            <div class="slds-radio_button-group PS-newClass12" aura:id="scale" id="scale" name="scale">
                                <span class="slds-button slds-radio_button">
                                    <input type="radio" name="radio" id="monday" value="5" />
                                    <label class="slds-radio_button__label" for="monday">
                                        <span class="slds-radio_faux">{!$Label.c.Time_ProjectScheduler}</span>
                                    </label>
                                </span>
                                <span class="slds-button slds-radio_button" >
                                    <input type="radio" name="radio" id="tuesday" value="1" checked="true"/>
                                    <label class="slds-radio_button__label" for="tuesday">
                                        <span class="slds-radio_faux">{!$Label.c.Day_ProjectScheduler}</span>
                                    </label>
                                </span>
                                <span class="slds-button slds-radio_button">
                                    <input type="radio" name="radio" id="wednesday" value="2" />
                                    <label class="slds-radio_button__label" for="wednesday">
                                        <span class="slds-radio_faux">{!$Label.c.Week_ProjectScheduler}</span>
                                    </label>
                                </span>
                                <span class="slds-button slds-radio_button">
                                    <input type="radio" name="radio" id="thursday" value="3" />
                                    <label class="slds-radio_button__label" for="thursday">
                                        <span class="slds-radio_faux">{!$Label.c.Month_ProjectScheduler}</span>
                                    </label>
                                </span>
                                <span class="slds-button slds-radio_button">
                                    <input type="radio" name="radio" id="friday" value="4" />
                                    <label class="slds-radio_button__label" for="friday">
                                        <span class="slds-radio_faux">{!$Label.c.Year_ProjectScheduler}</span>
                                    </label>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="container-fluid PS-newClass13">	 
                        <div class="card shadow-sm PS-newClass15">
                            <div class="card-body">
                                <div id="gantt_here" class="PS-newClass16" aura:id="gantt_here" ></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </body>
    </html>
</aura:component>