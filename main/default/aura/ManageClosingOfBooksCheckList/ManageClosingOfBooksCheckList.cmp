<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" controller="ClosingOfBooks_CheckList">
	<ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>  
   
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="change" value="{!v.selectedTab}" action="{!c.switchTab}"/>
    <aura:attribute name="highlightedCardId" type="String" default="pendingPost"/>
    <aura:attribute name="OrgId" type="String" default=""/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="selectedTab" type="String" default="Invoices"/>
    <aura:attribute name="qry" type="String" default=""/>
    <aura:attribute name="AccPeriodStatusoptions" type="List" />
    <aura:attribute name="unReconciledTransactions" type="Transaction__c[]" default=""/>
    <aura:attribute name="AP"                  type="Accounting_Period__c" default="{'sobjectType' : 'Accounting_Period__c'}" />
    <aura:handler name="change" value="{!v.AP.Id}" action="{!c.lookupChangeAccountingPeriod}"/>
    <aura:attribute name="showDialog" type="Boolean" default="false"/>
    <aura:attribute name="isStatusUnchanged" type="Boolean" default="true"/>
    <aura:attribute name="message" type="String" default="Are you sure you want to update the status of Accouting Period?"/>
    <aura:attribute name="TransactionWrapper" type="object" default="{'sObjectType' : 'TransactionWrapper'}"/>
    <aura:attribute name="AssetWrapper" type="object" default="{'sObjectType' : 'ledgerWrap'}"/>
    <aura:attribute name="ArWrapper" type="object" default="{'sObjectType' : 'ledgerWrap'}"/>
    <aura:attribute name="ApWrapper" type="object" default="{'sObjectType' : 'ledgerWrap'}"/>
    <aura:attribute name="IncomeExpenseWrapper" type="object" default="{'sObjectType' : 'ledgerWrap'}"/>
    <aura:handler name="change" value="{!v.OrgId}" action="{!c.lookupClickOrg}"/>
    <lightning:overlayLibrary aura:id="overlayLib"/>
    <!--erp_Mark7-->
   
    <div class="theme-bg erp" style="background:#f5f7fa;">
        
            <aura:if isTrue="{!v.showDialog}">
                <div>
                    <section role="dialog" tabindex="-1" aria-modal="true" aria-labelledby="modal-heading-01" class="slds-modal slds-fade-in-open slds-modal_medium">
                        <div class="slds-modal__container">
                            <header class="slds-modal__header">
                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse"
                                        title="Close" onclick="{!c.hideConfirmation}">
                                    <lightning:icon iconName="utility:close" size="small"/>
                                    <span class="slds-assistive-text">Close</span>
                                </button>
                                <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">
                                    Confirmation
                                </h2>
                            </header>
                            <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                {!v.message}
                            </div>
                            <footer class="slds-modal__footer">
                                <button class="slds-button slds-button_neutral" onclick="{!c.handleOK}">
                                    Yes
                                </button>
                                <button class="slds-button slds-button_neutral" onclick="{!c.hideConfirmation}">
                                    Cancel
                                </button>
                            </footer>
                        </div>
                    </section>
                    <div class="slds-backdrop slds-backdrop_open" role="presentation"></div>
                </div>
            </aura:if>
            <!-- Header Area -->
            <div class="slds-page-header">
                <div class="slds-page-header__row">
                    <div class="slds-page-header__col-title">
                        <div class="slds-media">
                            
                                <div class="slds-media__figure pl-2">
                                    <lightning:icon iconName="action:new_account" size="small"></lightning:icon>
                                </div>
                            <div class="slds-media__body">
                                <div class="slds-page-header__name">
                                    <div class="slds-page-header__name-title pt-2">
                                        <h1>
                                             <span class="slds-page-header__title slds-truncate" title="">CLOSING OF BOOKS CHECKLIST</span>
                                        </h1>
                                    </div>
                                </div>
                                <p class="slds-page-header__name-meta"></p>
                            </div>
                        </div>
                    </div>
                    <div class="slds-page-header__col-controls">
                        <!-- Add the "Adjustment Entries" button here -->
                        
                        <lightning:button label="Adjustment Entries" onclick="{!c.handleAdjustmentEntries}" class="slds-button slds-button_neutral" iconName="utility:description" />
                    </div>
                </div>
             </div>

            <!-- End Of Header -->
           
            <!-- Search area-->
        <div class="container-fluid pb-2"> 
            <div class="slds-grid slds-wrap slds-p-top_small">
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="form-element-01">Organisation</label>
                        <div class="slds-form-element__control">
                            <c:CustomInputLookUp aura:id="inputlookup" objectAPIName="Account" selectedRecordId="{!v.OrgId}" qry="AND ERP7__Account_Type__c ='Organisation'"  IconName="standard:contact"/>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="form-element-01">Accounting Period</label>
                        <div class="slds-form-element__control">
                            <c:CustomInputLookUp aura:id="inputlookup" objectAPIName="ERP7__Accounting_Period__c" selectedRecordId="{!v.AP.Id}" IconName="standard:contact" qry="{!v.qry}"/>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                    <div class="slds-form-element__control">
                        <label class="slds-form-element__label">Accounting Period Start Date</label>
                        <lightning:input type="date" variant="label-hidden" aura:id="start_date" value="{!v.AP.ERP7__Start_Date__c}" disabled="true"/>      
                    </div>
                </div>
                
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                    <div class="slds-form-element__control">
                        <label class="slds-form-element__label">Accounting Period End Date</label>
                        <lightning:input type="date" variant="label-hidden" aura:id="end_date" value="{!v.AP.ERP7__End_Date__c}" disabled="true"/>    
                    </div>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                    <lightning:select name="poStatus"  label="{!$Label.c.Status}" aura:id="poStatus" value="{!v.AP.ERP7__Status__c}" onchange="{!c.handleStatusChange}">
                        <aura:iteration items="{!v.AccPeriodStatusoptions}" var="item">
                            <option text="{!item.label}" value="{!item.value}" selected="{!v.AP.ERP7__Status__c == item.value}"/>
                        </aura:iteration>
                    </lightning:select>
                </div>
                <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small pt-4">
                    <lightning:button variant="brand" label="Change status" title="Change status" class="slds-button slds-button_brand" onclick="{!c.showConfirmation}" disabled="{!v.isStatusUnchanged}"/>
                </div>
            </div>
                </div>
           
            <!--End of search area -->
            <div class="slds-docked-form-footer">
                <lightning:button variant="brand" label="Back" onclick="{!c.navigateToMyComponent}"></lightning:button>
        		
        	</div>
            <!-- Toggle tab selection area-->
        <div class="erp_Mark7">
            <div class="container-fluid pb-2"> 
                <div class="slds-grid slds-wrap mt-3">
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74 activeppr" data-id="pendingPost" aura:id="pendingPost" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative ">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                             <img src="/resource/ERP7__ERPTheme/icons/icon-pending-posting.png"  width="24"></img>
                                            
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0 pt-1">Pending Records</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a  class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74" data-id="unreconciledTrans" aura:id="unreconciledTrans" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                            <img src="/resource/ERP7__ERPTheme/icons/icon-unreconcilled-trasactions.png"  width="24"></img>
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0">Unreconciled transaction</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a  class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74" data-id="assetInventory" aura:id="assetInventory" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                            <img src="/resource/ERP7__ERPTheme/icons/icon-asset-inventory.png"  width="24"></img>
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0 pt-1">Asset Inventory</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a  class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74" data-id="AR" aura:id="AR" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                             <img src="/resource/ERP7__ERPTheme/icons/icon-accounts-receivable.png"  width="24"></img>
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0  pt-1">Accounts Receivable</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a  class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74" data-id="AP" aura:id="AP" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                             <img src="/resource/ERP7__ERPTheme/icons/icon-accounts-payable.png"  width="24"></img>
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0  pt-1">Accounts Payable</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-right_small">
                        <a  class="anchor-colorbk" href="javascript:void(0);">
                            <div class="card shadow-sm min-height74" data-id="incomeRevenue" aura:id="incomeRevenue" onclick="{!c.fetchData}">
                                <div class="card-header p-0 position-relative">
                                    <div class="position-absolute handle card-icon">
                                        <i class="simple-icon-shuffle"></i>
                                    </div>
                                </div>
                                <div class="card-body text-center " data-status="Draft">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-right_small">
                                            <img src="/resource/ERP7__ERPTheme/icons/icon-adjustment-entries.png"  width="24"></img>
                                        </div>
                                        <div class="slds-col text-left"> 
                                            <h6 class="mb-0 mt-0">Income/Revenue Entries</h6>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                </div>
            </div>
        </div>
            <!-- end of tab bars-->
            <aura:if isTrue="{!and(equals(v.highlightedCardId,'pendingPost'),true)}">
             <div class="erp_Mark7 mt-2">
                 <div class="container-fluid pb-5">
                 <div class="card shadow-sm">
                     <div class="card-body p-1" data-status="Draft">
                         <ul class="nav nav-pills nav-fill p-1 " role="tablist">
                             <c:Tab label="Invoices" name="Invoices" selectedTab="{!v.selectedTab}" iconclass="fa fa-list-ol"  /> 
                             <c:Tab label="Bills"  name="Bills" selectedTab="{!v.selectedTab}" iconclass="fa fa-file-text"/>
                             <c:Tab label="Payments" name="Payments" selectedTab="{!v.selectedTab}" iconclass="fa fa-credit-card-alt"/> 
                             <c:Tab label="Credit Notes" name="Credit_notes" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                             <c:Tab label="Debit Notes" name="Credit_Debit_notes" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                             <c:Tab label="Expenses" name="Expenses" selectedTab="{!v.selectedTab}" iconclass="fa fa-sticky-note"/>
                         </ul>
                          <div class="slds-tabs--default">
                             
                             <aura:if isTrue="{!and(equals(v.selectedTab,'Invoices'),true)}">
                                 <lightning:accordion aura:id="accordion" activeSectionName="InvPost">
                                     <lightning:accordionSection name="InvPost" label="{!'UnPosted Invoices (' + v.TransactionWrapper.unpostedInvoices.length + ')'}">
                                         <div class="card shadow-sm card-bordermcobc">
                                             <div class="card-body p-3" >
                                                 
                                                 <!--div class="d-flex justify-content-between pb-2">
                                                     <div>
                                                         <h5 class="mb-1">UnPosted Invoices <span class="badge badge-phoenix badge-phoenix-warning rounded-pill fs-/-1 ms-2"><span class="badge-label">{!v.TransactionWrapper.unpostedInvoices.length}</span></span></h5>
                                                     </div>
                                                 </div-->
                                                 
                                                 <!--<div class="slds-page-header divClass1">Invoices without Transaction <div class="floating">{!v.TransactionWrapper.noTransInvoices.length}</div></div>-->
                                                 <aura:if isTrue="{!v.TransactionWrapper.unpostedInvoices.length>0}">
                                                 <table class="table table-flush dataTable-table">
                                                     <thead>
                                                         <tr class="slds-text-title--caps">
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Name</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Customer</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Date</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Amount</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Organisation</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Action</div>
                                                             </th>
                                                         </tr>
                                                     </thead>
                                                     <tbody>
                                                         <aura:iteration items="{!v.TransactionWrapper.unpostedInvoices}" var="item" indexVar="ind">
                                                             <tr>
                                                                 <td data-label="">
                                                                     <a href="{!'/'+item.Id}" target="__blank">{!item.Name}</a>
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Account__r.Name}
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Invoice_Date__c}
                                                                 </td>
                                                                 <td data-label="">
                                                                     <lightning:formattedNumber value="{!item.ERP7__Invoice_Amount__c}" style="currency"/>
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Organisation__r.Name}
                                                                 </td>
                                                                 <td class="slds-cell-shrink" data-label="">
                                                                     <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" iconSize="x-small" variant="border-filled" menuAlignment="right" onselect="{!c.handleInvoicePost}">
                                                                         <lightning:menuItem label="{!$Label.c.Acc_Recev_Post}" value="{!item.Id}" title="{!Index}"/>
                                                                     </lightning:buttonMenu>
                                                                 </td>
                                                             </tr>
                                                         </aura:iteration>
                                                     </tbody>
                                                 </table>
                                                     <aura:set attribute="else">
                                                         <div class="slds-notify_container slds-is-relative">
                                                             <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                 
                                                                 <div class="slds-notify__content">
                                                                     <p class="slds-text-heading_small mb-0">No Records Found</p>
                                                                 </div>
                                                                 
                                                             </div>
                                                         </div>

                                                     </aura:set>
                                                     </aura:if>
                                             </div>
                                         </div>
                                     </lightning:accordionSection>
                                     <lightning:accordionSection name="InvPaid" label="{!'UnPaid/Partially Paid Invoices (' + v.TransactionWrapper.unpaidInvoices.length + ')'}">
                                         <div class="card shadow-sm card-bordermcobc">
                                             <div class="card-body p-3" >
                                                 
                                                 <!--div class="d-flex justify-content-between pb-2">
                                                     <div>
                                                         <h5 class="mb-1">UnPaid/Partially Paid Invoices 
                                                             <span class="badge badge-phoenix fs-/-1 ms-2">
                                                                 <span class="badge-label">{!v.TransactionWrapper.unpaidInvoices.length}</span>
                                                             </span>
                                                         </h5>
                                                     </div>
                                                 </div-->
                                                 
                                                 
                                                 <!--<div class="slds-page-header divClass2">Invoices with Transaction and without Entries<div class="floating">{!v.TransactionWrapper.noEntriesInvoices.length}</div></div>-->
                                                 <aura:if isTrue="{!v.TransactionWrapper.unpaidInvoices.length>0}">
                                                 <table class="table table-flush dataTable-table">
                                                     <thead>
                                                         <tr class="slds-text-title--caps">
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Name</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Customer</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Date</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Invoice Amount</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Amount Paid</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Organisation</div>
                                                             </th>
                                                             <th scope="col" >
                                                                 <div class="slds-truncate" title="">Action</div>
                                                             </th>
                                                         </tr>
                                                     </thead>
                                                     <tbody>
                                                         <aura:iteration items="{!v.TransactionWrapper.unpaidInvoices}" var="item" indexVar="ind">
                                                             <tr>
                                                                 <td data-label="">
                                                                     <a href="{!'/'+item.Id}" target="__blank">{!item.Name}</a>
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Account__r.Name}
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Invoice_Date__c}
                                                                 </td>
                                                                 <td data-label="">
                                                                     <lightning:formattedNumber value="{!item.ERP7__Invoice_Amount__c}" style="currency"/>
                                                                 </td>
                                                                 <td data-label="">
                                                                     <lightning:formattedNumber value="{!item.ERP7__Paid_Amount__c}" style="currency"/>
                                                                 </td>
                                                                 <td data-label="">
                                                                     {!item.ERP7__Organisation__r.Name}
                                                                 </td>
                                                                 <td class="slds-cell-shrink" data-label="">
                                                                     <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" iconSize="x-small" variant="border-filled" menuAlignment="right" onselect="{!c.getPaymentPopup}">
                                                                         <lightning:menuItem label="Record Payment" value="{!item.Id}" title="{!Index}"/>
                                                                     </lightning:buttonMenu>
                                                                 </td>
                                                             </tr>
                                                         </aura:iteration>
                                                     </tbody>
                                                 </table>
                                                 <aura:set attribute="else">
                                                         <div class="slds-notify_container slds-is-relative">
                                                             <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                 
                                                                 <div class="slds-notify__content">
                                                                     <p class="slds-text-heading_small mb-0">No Records Found</p>
                                                                 </div>
                                                                 
                                                             </div>
                                                         </div>

                                                     </aura:set>
                                                     </aura:if>
                                             </div>
