                            <aura:iteration items="{!v.IncomeExpenseWrapper.ledgerEntries}" var="item" indexVar="ind">
                                <tr>
                                    <td data-label="">
                                        <a href="{!'/'+item.ERP7__Transactions__c}" target="__blank">{!item.ERP7__Transactions__r.Name}</a>
                                    </td>
                                    <td data-label="">
                                        {!item.ERP7__Chart_of_Account__r.Name}
                                    </td>
                                    <td data-label="">
                                                <aura:if isTrue="{!item.ERP7__Credit_Entry__c>0}">
                                                    <span class="badge-label-success"><lightning:formattedNumber value="{!item.ERP7__Credit_Entry__c}" style="currency"/></span>
                                                    <aura:set attribute="else">
                                                        <span class="badge-label-danger"><lightning:formattedNumber value="{!item.ERP7__Debit_Entry__c}" style="currency"/></span>
                                                    </aura:set>
                                                </aura:if>
                                            </td>
                                    <td data-label="">
                                        {!item.ERP7__Transactions__r.ERP7__Transaction_Date__c}
                                    </td>
                                    <td data-label="">
                                        {!item.ERP7__Organisation__r.Name}
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>
                        <aura:set attribute="else">
                                                         <div class="slds-notify_container slds-is-relative">
                                                             <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                 
                                                                 <div class="slds-notify__content">
                                                                     <p class="slds-text-heading_small mb-0">No Records Found</p>
                                                                 </div>
                                                                 
                                                             </div>
                                                         </div>

                                                     </aura:set>
                                                     </aura:if>
                    </div>
                </div>
                <div class="card shadow-sm card-bordermcobc ml-0">
                    <div class="card-body p-3" >
                        
                        <div class="d-flex justify-content-between pb-2">
                            <div>
                                <h5 class="mb-1">Expense Ledger Entries
                                    <span class="badge badge-phoenix  fs--1 ms-2">
                                        <span class="badge-label">{!v.IncomeExpenseWrapper.expenseEntries.length}</span>
                                    </span>
                                </h5>
                                
                            </div>
                            <h6 class="text-700">
                                <span class="badge badge-phoenix fs--2 badge-phoenix-danger">
                                    <span class="badge-label">Debit Sum - <strong>{!v.IncomeExpenseWrapper.ExpenseDebitSum}</strong></span>
                                </span>
                            </h6>
                            <h6 class="text-700">
                                <span class="badge badge-phoenix fs--2 badge-phoenix-success">
                                    <span class="badge-label">Credit Sum - <strong>{!v.IncomeExpenseWrapper.ExpenseCreditSum}</strong></span>
                                </span>
                            </h6>
                         </div>
                      <!--<div class="slds-page-header divClass1">Invoices without Transaction <div class="floating">{!v.TransactionWrapper.noTransInvoices.length}</div></div>-->
                    <aura:if isTrue="{!v.IncomeExpenseWrapper.expenseEntries.length>0}">
                    <table class="table table-flush dataTable-table">
                        <thead>
                            <tr class="slds-text-title--caps">
                                <th scope="col" >
                                    <div class="slds-truncate" title="">Transaction Name</div>
                                </th>
                                <th scope="col" >
                                    <div class="slds-truncate" title="">Chart of Account</div>
                                </th>
                                <th scope="col" >
                                    <div class="slds-truncate" title="">Amount</div>
                                </th>
                                <th scope="col" >
                                    <div class="slds-truncate" title="">Transaction Date</div>
                                </th>
                                <th scope="col" >
                                    <div class="slds-truncate" title="">Organisation</div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.IncomeExpenseWrapper.expenseEntries}" var="item" indexVar="ind">
                                <tr>
                                    <td data-label="">
                                        <a href="{!'/'+item.ERP7__Transactions__c}" target="__blank">{!item.ERP7__Transactions__r.Name}</a>
                                    </td>
                                    <td data-label="">
                                        {!item.ERP7__Chart_of_Account__r.Name}
                                    </td>
                                    <td data-label="">
                                                <aura:if isTrue="{!item.ERP7__Credit_Entry__c>0}">
                                                    <span class="badge-label-success"><lightning:formattedNumber value="{!item.ERP7__Credit_Entry__c}" style="currency"/></span>
                                                    <aura:set attribute="else">
                                                        <span class="badge-label-danger"><lightning:formattedNumber value="{!item.ERP7__Debit_Entry__c}" style="currency"/></span>
                                                    </aura:set>
                                                </aura:if>
                                            </td>
                                    <td data-label="">
                                        {!item.ERP7__Transactions__r.ERP7__Transaction_Date__c}
                                    </td>
                                    <td data-label="">
                                        {!item.ERP7__Organisation__r.Name}
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>
                        <aura:set attribute="else">
                                                         <div class="slds-notify_container slds-is-relative">
                                                             <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                 
                                                                 <div class="slds-notify__content">
                                                                     <p class="slds-text-heading_small mb-0">No Records Found</p>
                                                                 </div>
                                                                 
                                                             </div>
                                                         </div>

                                                     </aura:set>
                                                     </aura:if>
                </div>
                </div>
                </div>
            </aura:if>
       
    
    
    </div>
    <aura:if isTrue="{!v.showMmainSpin}">
        <span class="AccountsPayable-newClass33">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if>
</aura:component>