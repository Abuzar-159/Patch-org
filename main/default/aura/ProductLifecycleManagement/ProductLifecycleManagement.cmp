                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.WIP.ERP7__Quantity_Unit_Of_Measure__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.WIPUoMList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.WIP.ERP7__Quantity_Unit_Of_Measure__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
