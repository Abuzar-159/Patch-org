                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.WIP.Name}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Process Cycle</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Process_Cycle__c" selectedRecordId="{!v.WIP.ERP7__Process_Cycle__c}" placeholder="Search Process..." IconName="standard:contact"/>  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Process Output Product</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="Product2" selectedRecordId="{!v.WIP.ERP7__Process_Output_Product__c}" placeholder="Search Products..."/>  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Version</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c	" selectedRecordId="{!v.WIP.ERP7__Version__c}" placeholder="Search Version..."/>  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Quantity/Unit</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number"  variant="label-hidden" value="{!v.WIP.ERP7__Quantity_Unit__c}"  />  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Type</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.WIP.ERP7__Type__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.WIPTypeList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.WIP.ERP7__Type__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
