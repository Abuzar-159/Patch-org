                      			<!-- Routing Tab Starts -->
                                <div class="" id="routingTabId" aura:id="routingTabId">
                                    <aura:if isTrue="{!v.Tab=='rou'}">
                                        <div class="slds-page-header ProductLCM-newClass12">
                                            <div class="slds-grid">
                                                <div class="slds-col slds-has-flexi-truncate">
                                                    <div class="slds-media slds-no-space slds-grow">
                                                        <div class="slds-media__body">
                                                            <nav>
                                                                <ol class="slds-breadcrumb slds-line-height_reset"> </ol>
                                                            </nav>
                                                            <h4 class="slds-m-right_small slds-align-middle slds-truncate" title="">Routings ({!v.RoutingList.length})</h4>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="slds-col  slds-align-middle">                                                    
                                                    <c:StockTakeSearch Placeholder="Search by Name or BOM Version or Process"/>                                                               
                                                </div>
                                                <div class="slds-col slds-no-flex slds-grid slds-align-middle">
                                                    <div class="slds-button-group slds-m-top--small" role="group">
                                                        <button onclick="{!c.showNewPopup}" data-name="rou"  class="{!v.ProductId==''?'DisaClass slds-button slds-button--brand ':'slds-button slds-button--brand'}" data-toggle="modal" data-target="#myModal">
                                                            <i class="fa fa-plus"></i>&nbsp;New</button>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="slds-card__body ProductLCM-newClass13">
                                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-top--small">
                                                    <thead>
                                                        <tr class="slds-text-title--caps">
                                                            <th class="slds-cell-shrink" scope="col"> &nbsp; </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Actions </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Name </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> BOM Version </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Process </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Work Center </div>
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <aura:if isTrue="{!v.RoutingList.length>0}">
                                                            <aura:iteration items="{!v.RoutingList}" var="r" indexVar="index">
                                                                <tr class="slds-hint-parent">
                                                                    <td scope="row" data-label="">  
                                                                    </td>
                                                                    <td data-label="Actions">
                                                                        <img onclick="{!c.getRecord}" data-name="update" id="{!r.Id}" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" class="ProductLCM-newClass14" title="Edit" />&nbsp;
                                                                        <img onclick="{!c.getDelete}" data-name="delete" id="{!r.Id}" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" class="ProductLCM-newClass14" title="Delete" />
                                                                    </td>
                                                                    <td scope="row" data-label="Name">
                                                                        <div class="slds-truncate" title="">
                                                                            <lightning:formattedText value="{!r.Name}"/> 
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity">
                                                                        <div class="slds-truncate">
                                                                            <lightning:formattedText value="{!r.ERP7__BOM_Version__r.Name}"/> 
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Process">
                                                                        <div class="slds-truncate">
                                                                            <lightning:formattedText value="{!r.ERP7__Process__r.Name}"/> 
                                                                        </div>
                                                                    </td>
