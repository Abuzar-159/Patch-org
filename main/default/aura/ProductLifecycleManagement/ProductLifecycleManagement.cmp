<aura:component controller="ProductLifecycleManagement" implements="force:appHostable,forceCommunity:availableForAllPageTypes" access="global"> <!-- implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" access="global"   force:appHostable,forceCommunity:availableForAllPageTypes  -->
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink"/> 
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css, /resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css,
                              /resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/ProductLifecycleManagement.css"/>
    </head>   
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="disabled" type="Boolean" default="false"/>
    <aura:handler name="onSaveSuccess" event="force:recordSaveSuccess" action="{!c.handleSaveSuccess}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchEventHandler}"/> 
    <aura:attribute name="ProductId" type="String" default="" access="global"/> <!-- 01t24000007zGi7AAE  -->
    <aura:attribute name="Tab" type="String" default="pro"/>
    <aura:attribute name="action" type="String" default=""/>
    <aura:attribute name="showPopup" type="Boolean" default="false"/> 
    <aura:attribute name="Product" type="Product2" default=""/>
    <aura:attribute name="Productname" type="String" default=""/>
    <aura:attribute name="Media" type="Media__c" default=""/>
    <aura:attribute name="MediaList" type="String[]"/>
    <aura:attribute name="MediaMap" type="String[]"/>
    <aura:attribute name="MediaMapD" type="String[]"/>
    <aura:attribute name="Routing" type="Routing__c" default=""/>
    <aura:attribute name="RoutingList" type="String[]"/>
    <aura:attribute name="Version" type="Version__c" default=""/>
    <aura:attribute name="VersionList" type="String[]"/>
    <aura:attribute name="BOM" type="BOM__c" default=""/>
    <aura:attribute name="BOMList" type="BOM__c" default=""/>
    <aura:attribute name="WIP" type="BOM__c" default=""/>
    <aura:attribute name="WIPList" type="BOM__c" default=""/>
    <aura:attribute name="ProductIDold" type="String[]"  default=""/>
   
    <aura:attribute name="WarrantyRP" type="Warranty_Return_Policy__c" default=""/>
    <aura:attribute name="WarrantyRPList" type="String[]"/>
    <aura:attribute name="ChangeOrder" type="Change_Order__c" default=""/>
    <aura:attribute name="ChangeOrderList" type="String[]"/>
    <aura:attribute name="QualityOrder" type="Quality_Order__c" default=""/>
    <aura:attribute name="QualityOrderList" type="String[]"/>
    <aura:attribute name="PBE" type="PricebookEntry"/>
    <aura:attribute name="PBEList" type="String[]"/>
    <aura:attribute name="SelectedProductId" type="String[]"/>
    
    <aura:attribute name="ProductFamilyList" type="String[]"/>
    <aura:attribute name="ProductTypeList" type="String[]"/>
    <aura:attribute name="ProductCategoryList" type="String[]"/>
    <aura:attribute name="ProductTaxCodeList" type="String[]"/>
    <aura:attribute name="ProductSubCategoryList" type="String[]"/>
    <aura:attribute name="ProductUoMList" type="String[]"/>
    <aura:attribute name="ProductQuantityUnitOfMeasureList" type="String[]"/>
    <aura:attribute name="ProductStatusList" type="String[]"/>
    <aura:attribute name="ProductWeightDimensionsList" type="String[]"/>
    
    <aura:attribute name="RoutingStatusList" type="String[]"/>
    <aura:attribute name="RoutingTypeList" type="String[]"/>
    <aura:attribute name="VersionStatusList" type="String[]"/>
    <aura:attribute name="VersionTypeList" type="String[]"/>
    <aura:attribute name="VersionCategoryList" type="String[]"/>
    <aura:attribute name="ReturnPolicyRefundOptionList" type="String[]"/>
    <aura:attribute name="BOMStatusList" type="String[]"/>
    <aura:attribute name="BOMTypeList" type="String[]"/>
    <aura:attribute name="BOMComponentTypeList" type="String[]"/>
    <aura:attribute name="BOMUoMList" type="String[]"/>
    <aura:attribute name="WIPTypeList" type="String[]"/>
    <aura:attribute name="WIPUoMList" type="String[]"/>
    
    <aura:attribute name="seBool" type="Boolean" default="false"/>
    <aura:attribute name="sError" type="String" default="All * Fields are mandatory"/>
    <aura:attribute name="skuError" type="String" default=""/>
    <aura:attribute name="namError" type="String" default=""/>
    <aura:attribute name="priceBookMsg" type="String" />   
    <aura:attribute name="Index" type="ID" default=""/>
    <aura:attribute name="MediaTypeList" type="String[]"/>
    <aura:attribute name="COCategoryList" type="String[]"/>
    <aura:attribute name="COTypeList" type="String[]"/>
    <aura:attribute name="COStatusList" type="String[]"/>
    <aura:attribute name="COProjectList" type="String[]"/>
    <aura:attribute name="SaveMsg" type="String" default=""/> 
    <aura:attribute name="showMainSpin" type="Boolean" default="false"/> 
    <aura:attribute name="WarrantyRPRO" type="String[]"/>
    
    <aura:attribute name="MediaListD" type="String[]"/> 
    <aura:attribute name="RoutingListD" type="String[]"/> 
    <aura:attribute name="VersionListD" type="String[]"/> 
    <aura:attribute name="WarrantyRPListD" type="String[]"/> 
    <aura:attribute name="ChangeOrderListD" type="String[]"/>
    <aura:attribute name="QualityOrderListD" type="String[]"/> 
    <aura:attribute name="BOMListD" type="String[]"/>
    <aura:attribute name="WIPListD" type="String[]"/>
    <aura:attribute name="PBEListD" type="String[]"/> 
    <aura:attribute name="CloneURL" type="String" default=""/> 
    <aura:attribute name="Clone" type="Boolean" default="false"/> 
    <aura:attribute name="CloneEventId" type="String" default=""/> 
   
    <!--<aura:registerEvent name="AttachmentEvnet" type="c:AttachmentEvnet"/> -->
    
    <aura:handler name="change" value="{!v.ProductId}" action="{!c.doInit}"/>
    <aura:handler event="c:AttachmentEvnet" action="{!c.FetchAttachmentBody}"/>
    <aura:attribute name="AttachmentBody" type="String" default=""/>
    <aura:attribute name="ParentId" type="String" default=""/>
    <aura:attribute name="FileName" type="String" default=""/>
    <aura:attribute name="MediaBody" type="String" default=""/> 
    <aura:attribute name="ContentType" type="String" default=""/>
    <aura:attribute name="fileNameVal" type="String" default="" />  
    <aura:attribute name="attachId" type="String" default="" />
    <aura:attribute name="isRelatedRecordCreated" type="Boolean" default="true"/>
    <aura:attribute name="reRenderEventField" type="Boolean" default="true"/>
    
    <aura:attribute name="AVendor" type="Approved_Vendor__c" default=""/>
    <aura:attribute name="AVendorList" type="String[]"/>
    <aura:attribute name="AVendorListD" type="String[]"/>
    <aura:attribute name="AVendorTypeList" type="String[]"/>
    <aura:attribute name="AVendorStatusList" type="String[]"/>
    <aura:attribute name="message" type="Map" default="{Title:'Error',Severity:'error',Text:''}"/>
    <aura:attribute name="isFromButton" type="Boolean" default="false"/>
    <aura:attribute name="showCancelButton" type="Boolean" default="false"/>  
    <aura:attribute name="navfromOtherComponent" type="Boolean" default="false"/> 
    <aura:attribute name="doInitExecute" type="Boolean" default="true"/>
    
    <div class="erp_mark7 ProductLCM-newClass1 " aura:id="body">
    	<div class="slds-page-header">
            <div class="slds-grid">
                <div class="slds-col slds-has-flexi-truncate">
                    <div class="slds-media slds-no-space slds-grow">
                        <div class="slds-media__figure">
                            <lightning:icon iconName="standard:account" variant="inverse" size="large" alternativeText="account" title="account" />
                        </div>
                        <div class="slds-media__bod ProductLCM-newClass2">
                            <p class="slds-text-title--caps slds-line-height--reset"></p>
                            <nav class="slds-context-bar__secondary" role="navigation">
                                <ul class="slds-grid">
                                    <li class="slds-context-bar__item slds-context-bar__dropdown-trigger slds-dropdown-trigger slds-dropdown-trigger--hover ProductLCM-newClass3" aria-haspopup="true">
                                        <a href="javascript:void(0);" class="slds-context-bar__label-action ProductLCM-newClass4" title="Menu Item">
                                            <span class=""><h1 class="slds-page-header__title" title="Product Lifecycle Management (PLM)"> Product Lifecycle Management (PLM)</h1></span>
                                        </a>
                                    </li>
                                </ul>
                            </nav> 
                            <h1 class="slds-page-header__title slds-p-right_x-small ProductLCM-newClass5">
                                <lightning:formattedText value="{!v.Product.Name}"/>
                            </h1>   
                            <aura:if isTrue="{!v.Clone==false}" >
                                <c:CustomInputLookUp objectAPIName="Product2" selectedRecordId="{!v.ProductId}" placeholder="Search Product..." IconName="standard:orders"/>
                            </aura:if>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-no-flex slds-grid slds-align-top" >
                    <button onclick="{!c.gotoClone}" type="button" class="{!v.ProductId==''?'DisaClass slds-button slds-button--brand CloneClass':'slds-button slds-button--brand CloneClass'}" aura:id="CloneId">Clone</button>                                           
                    <aura:if isTrue="{!v.showMainSpin}">  
                        <span class="ProductLCM-newClass6">
                            <lightning:spinner variant="brand" size="large" aura:id="mainSpin" class="mainSpinClass"/>
                        </span>  
                    </aura:if>
                </div>
            </div>
        </div>

        <div class="epr_Mark7 slds-m-bottom--small slds-m-top--xx-small bg-white" >
            <div class="container-fluid">
                <div class="row ProductLCM-newClass7">
                    <div class="col-md-2 col-xs-2 ProductLCM-newClass8">
						<!-- tabs -->
                        <div class="tabbable tabs-left">
                            <ul class="nav nav-tabs">
                                <li class="active ProductLCM-newClass9" onclick="{!c.getTab}" data-name="pro" data-service="0" aura:id="TabId" >
                                    <a data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-product-hunt"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Product</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="pbe" data-service="1" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-book"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Price Book<br/> Entries</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="ver" data-service="2" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab" >
                                        <P class="iconclass"><i class="fa fa-stack-overflow"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Versions</span>
                                    </a>
                                </li>  
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="rou" data-service="3" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-compress"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Routing</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="bom" data-service="4" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-compress"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">BOM</span>
                                    </a> 
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="wip" data-service="5" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab" >
                                        <P class="iconclass"><i class="fa fa-check"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Work in Progress</span>
                                    </a> 
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="av" data-service="6" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab" >
                                        <P class="iconclass"><i class="fa fa-user"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Approved Vendor</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="med" data-service="7" aura:id="TabId" >
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab" >
                                        <P class="iconclass"><i class="fa fa-image"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Media</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="wr" data-service="8" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-tag"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Warranty and<br/> Return</span>
                                    </a>
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="qua" data-service="9" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-check"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Quality</span>
                                    </a> 
                                </li>
                                <li class="ProductLCM-newClass9" onclick="{!c.getTab}" data-name="co" data-service="10" aura:id="TabId">
                                    <a class="{!(v.disabled)?'btn--form-disSave':''}" data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-file"></i></P>
                                        <span class="slds-truncate ProductLCM-newClass21">Change Order</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
            
                    <div class="col-md-10">
                        <div>
                            <div class="tab-content">
                                <!-- Product Tab Starts -->
                                <div class="tab-pane  active" id="productTabId" aura:id="productTabId">                                   
                                    <aura:if isTrue="{!v.Tab=='pro'}">  
                                        <aura:if isTrue="{!v.SaveMsg!=''}">
                                            <div class="maq-only">
                                                <div class="slds-notify_container slds-is-relative">
                                                    <div class="slds-notify slds-notify_toast slds-theme--success" role="alert">                                   
                                                        <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                                                            <lightning:icon iconName="utility:success" variant="inverse" size="x-small" alternativeText="success!" title="success" />
                                                        </span>
                                                        <div class="slds-notify__content ProductLCM-newClass22">
                                                            <h2 class="slds-text-heading_small ">{!v.SaveMsg}</h2>
                                                        </div>
                                                        <div class="slds-notify__content ProductLCM-newClass23">
                                                            <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" onclick="{!c.getNotificationHide}">
                                                                <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />
                                                                <span class="slds-assistive-text">Close</span>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                        <div class="slds-modal__content slds-p-around_medium ProductLCM-newClass24" id="top"><!-- height:250px;   -->
                                            <div class="row">
                                                <div class="row slds-m-top--xx-small"> 
                                                    <div class="col-md-12">    
                                                        <span class="{!v.seBool==true?'red ProductLCM-newClass11':'slds-hide ProductLCM-newClass11'}"
                                                               >
                                                            <i class="fa fa-window-close ProductLCM-newClass16" aria-hidden="true"></i> &nbsp; Name field is mandatory
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Name</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.Name}"  aura:id="baid" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Product Code</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ProductCode}" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Commodity Code</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__Commodity_Code__c}" /> 
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">ASIN Code</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__ASIN_Code__c}" />                               
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Picture</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__Picture__c}" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Brand</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__Brand__c}" /> 
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Product SKU</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.StockKeepingUnit}" aura:id="skuid" /> 
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Declared Shipment Value</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__Declared_Shipment_Value__c}" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">SKU</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__SKU__c}" /> 
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Weight</label>
                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <lightning:input type="number"  variant="label-hidden" value="{!v.Product.ERP7__Weight__c}" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Minimum Order Quantity(MOQ)</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="number"  variant="label-hidden" value="{!v.Product.ERP7__MOQ__c}" />
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Barcode</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="text" variant="label-hidden" value="{!v.Product.ERP7__Barcode__c}" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Inspection Routing</label>
                                                        <div class="slds-form-element__control">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Routing__c" selectedRecordId="{!v.Product.ERP7__Inspection_Routing__c}" placeholder="Search Inspection Routings..." IconName="custom:custom32"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}" -->
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Default Version</label>
                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.Product.ERP7__Version__c}" placeholder="Search Default Versions..." IconName="custom:custom24"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Default Routing</label>
                                                        <div class="slds-form-element__control">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Routing__c" selectedRecordId="{!v.Product.ERP7__Routing__c}" placeholder="Search Default Routings..." IconName="custom:custom32"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Tax Band</label>
