                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Issue_Work_Order__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Issue Purchase Order</label>
                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Issue_Purchase_Order__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Issue Manufacturing Order</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Issue_Manufacturing_Order__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
