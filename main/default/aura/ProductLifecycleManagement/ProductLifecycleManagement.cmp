                                                                <h4 class="modal-title slds-align--absolute-center" >
                                                                    <aura:if isTrue="{!v.Tab!='update'}"> New
                                                                        <aura:set Attribute="else">Update</aura:set>               
                                                                    </aura:if>
                                                                    Change Order
                                                                </h4>
                                                            </div>
                                                            <div class="slds-modal__content slds-p-around_medium ProductLCM-newClass10">
                                                                <div class="row slds-m-top--small">
                                                                    <div class="col-md-12">    
                                                                        <span class="{!v.seBool==true?'red ProductLCM-newClass11':'slds-hide ProductLCM-newClass11'}">
                                                                            <i class="fa fa-window-close ProductLCM-newClass16" aria-hidden="true"></i> &nbsp; Name field is mandatory
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span> Name</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.ChangeOrder.Name}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Category</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.ChangeOrder.ERP7__Category__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.COCategoryList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.ChangeOrder.ERP7__Category__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Type</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.ChangeOrder.ERP7__type__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.COTypeList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.ChangeOrder.ERP7__type__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Project</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Project__c" selectedRecordId="{!v.ChangeOrder.ERP7__Project__c}" placeholder="Search Projects..." IconName="standard:account"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Status</label>
                                                                            <div class="slds-form-element__control">
                                                                                 <lightning:select value="{!v.ChangeOrder.ERP7__Status__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.COStatusList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.ChangeOrder.ERP7__Status__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <footer class="slds-modal__footer slds-text-align--center">
                                                                <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
                                                                <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
                                                            </footer>
                                                        </div>
                                                    </div>   
                                                </section>
                                            </div>    
                                            <div class="slds-backdrop slds-backdrop--open"></div>
                                        </aura:if>
                                    </aura:if>
                                </div>
                                <!-- Change Orders Tab Ends -->
      
                                <!--  ====================================  DELETE RECORDS =========================================== -->                    
                                <div aria-hidden="true" class="slds slds-hide" aura:id="deleteConfirmId"> 
                                    <div aria-hidden="false" role="dialog" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container ProductLCM-newClass17">
                                            <div class="slds-modal__content"> 
                                                <div class="slds-modal__content slds-p-around--medium"> 
                                                    <div class="slds-form-element__control">
                                                        <label class="slds-radio">
                                                            <span class="slds-form-element__label"> 
                                                                <!--Record? --> 
                                                            </span> <br/>
                                                            <span class="ProductLCM-newClass18">Are you sure you want to delete this record?</span>
                                                        </label>
                                                    </div> 
                                                </div>  
                                                <div  class="modal-footer ProductLCM-newClass19">  
                                                    <span >
                                                        <button type="button" class="slds-button slds-button--brand" data-dismiss="modal" data-record="Yes" value="Yes" aura:id="yesId" onclick="{!c.saveRecord}">Yes</button> 
                                                        <button type="button" value="No" class="slds-button slds-button--neutral" data-record="NO"  aura:id="noId" onclick="{!c.cancelDelete}">No</button> 
                                                    </span>   
                                                </div>
                                            </div> 
                                        </div>                    
                                    </div>       
                                    <div class="slds-backdrop slds-backdrop--open"></div>         
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</aura:component>