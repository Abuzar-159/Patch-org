                                                        <div class="slds-form-element__control">
                                                             <lightning:select value="{!v.Product.ERP7__Status__c}"  variant="label-hidden"  class="display-lable">
                                                                <aura:iteration items="{!v.ProductStatusList}" var="option">
                                                                    <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Product.ERP7__Status__c, option.value)}"/>
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </div>
                                                    </div>
                                                </div>
