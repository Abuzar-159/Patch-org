                                                                        <img onclick="{!c.getDelete}"  data-name="delete" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" id="0" class="ProductLCM-newClass14" title="Delete" />
                                                                    </td>
