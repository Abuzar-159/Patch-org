                                                                    <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Product.ERP7__Weight_Dimensions__c, option.value)}"/>
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </div>
                                                    </div>
