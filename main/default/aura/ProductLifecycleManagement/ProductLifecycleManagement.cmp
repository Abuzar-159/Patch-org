                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span> Finished Products Site</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" selectedRecordId="{!v.WIP.ERP7__Finished_Products_Site__c}" placeholder="Search Finished Products Site..." IconName="custom:custom32"/>
                                                                            </div>
                                                                        </div>
