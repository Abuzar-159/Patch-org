                                                        <label class="slds-form-element__label" for="input-unique-id">Active</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.IsActive}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <aura:if isTrue="{!v.Product.ERP7__Picture__c!=undefined}">
                                                    <div class="col-md-3 slds-p-top--xx-small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id">Preview Image</label>
                                                            <div class="slds-form-element__control">
                                                                <img src="{!v.Product.ERP7__Picture__c}" class="ProductLCM-newClass25"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </aura:if>    
                                            </div>
                                        </div>
                                        <div class="row ProductLCM-newClass26">
                                            <div class="row ProductLCM-newClass27">                                                                                 
                                                <div class="mainfloatbutton ProductLCM-newClass9"> 
                                                    <aura:if isTrue="{!v.isFromButton}"> 
                                                        <aura:if isTrue="{!v.showCancelButton==false}">                                     
                                                            <button  onclick="{!c.backToProductDetail}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Back</button>   &nbsp;&nbsp;
                                                        </aura:if> 
                                                    </aura:if>    
                                                    <button onclick="{!c.backToProductDetail}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal" aura:id="closeProductId">Back</button>                                           
                                                    <button class="{!v.ProductId==''?'RedButtonClass slds-button slds-button--brand':'slds-button slds-button--brand'}" onclick="{!c.saveRecord}" aura:id="saveProductId">Save</button>                                           
                                                </div>
                                            </div>
                                            <div class="row ProductLCM-newClass27">                                      
                                                <div class="col-md-10 ProductLCM-newClass9">                                                
                                                </div>
                                            </div>
                                        </div>
                                    </aura:if>  
                                </div>
                                <!-- Product Tab Ends -->
                                
                                <!-- Price Book Entries Tab Starts -->
                                <div class="" id="pBETabId" aura:id="pBETabId">
                                    <aura:if isTrue="{!v.Tab=='pbe'}">
                                        <div class="slds-page-header ProductLCM-newClass12">
                                            <div class="slds-grid">
                                                <div class="slds-col slds-has-flexi-truncate">
                                                    <div class="slds-media slds-no-space slds-grow">
                                                        <div class="slds-media__body">
                                                            <nav>
                                                                <ol class="slds-breadcrumb slds-line-height_reset">
                                                                </ol>
                                                            </nav>
                                                            <h4 class="slds-m-right_small slds-align-middle slds-truncate" title="">
                                                                Price Book Entries ({!v.PBEList.length})
                                                            </h4>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="slds-col slds-align-middle">                                                    
                                                    <c:StockTakeSearch Placeholder="Search by Name or Price Book"/>  <!--  or List Price  -->                                                              
                                                </div>
                                                <div class="slds-col slds-no-flex slds-grid slds-align-middle">
                                                    <div class="slds-button-group slds-m-top--small" role="group">
                                                        <button onclick="{!c.showNewPopup}" data-name="pbe"  class="{!v.ProductId==''?'DisaClass slds-button slds-button--brand ':'slds-button slds-button--brand'}" data-toggle="modal">
                                                            <i class="fa fa-plus"></i>&nbsp;New
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="slds-card__body ProductLCM-newClass13">
                                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-top--small">
                                                    <thead>
                                                        <tr class="slds-text-title--caps">
                                                            <th class="slds-cell-shrink" scope="col"> &nbsp; </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="">  Actions </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="">Name </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title="">Price Book </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Tax Plan </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> List Price </div>
                                                            </th>
                                                            <th scope="col">
                                                                <div class="slds-truncate" title=""> Active </div>
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody> 
                                                        <aura:if isTrue="{!v.PBEList.length>0}">
                                                            <aura:iteration items="{!v.PBEList}" var="r" indexVar="index"> <!-- PBEList RoutingList  -->
                                                                <tr class="slds-hint-parent">
                                                                    <td scope="row" data-label="">
                                                                    </td>
                                                                    <td data-label="Actions">
                                                                        <img onclick="{!c.getRecord}" data-name="update" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" id="0" class="ProductLCM-newClass14" title="Edit" />&nbsp;
                                                                        <img onclick="{!c.getDelete}" data-name="delete" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" id="0" class="ProductLCM-newClass14" title="Delete" />
                                                                    </td>
                                                                    <td scope="row" data-label="Name">
                                                                        <div class="slds-truncate" title="">
                                                                            <lightning:formattedText value="{!r.Name}"/>
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Process">
                                                                        <div class="slds-truncate">
                                                                            <lightning:formattedText value="{!r.Pricebook2.Name}"/> 
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Tax Plan">
                                                                        <div class="slds-truncate">
                                                                            <lightning:formattedText value="{!r.ERP7__Tax_Plan__r.Name}"/> 
                                                                        </div>
                                                                    </td> 
                                                                    <td data-label="Quantity">
                                                                        <div class="slds-truncate">
                                                                            <lightning:input type="checkbox" checked="{!r.UnitPrice}" readonly="true"/> 
                                                                        </div>
                                                                    </td>
                                                                    <td data-label="Quantity">
                                                                        <div class="slds-truncate">
                                                                            <lightning:input type="checkbox" checked="{!r.IsActive}" readonly="true"/> 
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            </aura:iteration>
                                                            <aura:set attribute="else">
                                                                <tr>
                                                                    <td colspan="9" class="ProductLCM-newClass9">
                                                                        <div class="slds-notify_container slds-is-relative ProductLCM-newClass15">
                                                                            <div class="slds-notify slds-notify_toast slds-theme_warning ProductLCM-newClass28" role="alert" >
                                                                                <span class="slds-assistive-text">warning</span>
                                                                                <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                                                                <div class="slds-notify__content ProductLCM-newClass30">
                                                                                    <h2 class="slds-text-heading_small ProductLCM-newClass31">No Records to display</h2>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            </aura:set>
                                                        </aura:if> 
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        
                                        <aura:if isTrue="{!v.showPopup}"> 
                                            <div class="erp_mark7"> 
                                                <section id="ppId" role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal--large"> 
                                                    <div class="slds-modal__container">
                                                        <div>
                                                            <div class="slds-modal__header">
                                                                <button onclick="{!c.HideNewPopup}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />      <span class="slds-assistive-text">Close</span>
                                                                </button>
                                                                <h4 class="modal-title slds-align--absolute-center" > <!-- modal-title slds-align-absolute-center  -->
                                                                    <aura:if isTrue="{!v.Tab!='update'}"> New
                                                                        <aura:set Attribute="else">Update</aura:set>               
                                                                    </aura:if>
                                                                    Price Book Entry
                                                                </h4>
                                                            </div>
                                                            <div class="slds-modal__content slds-p-around_medium ProductLCM-newClass42">
                                                                <div class="row slds-m-top--xx-small">
                                                                    <div class="col-md-12">    
                                                                        <span class="{!v.seBool==true?'red ProductLCM-newClass11':'slds-hide ProductLCM-newClass11'}">
                                                                            <i class="fa fa-window-close ProductLCM-newClass16" aria-hidden="true" ></i> &nbsp;{!v.sError}
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                
                                                                <div class="row slds-m-top--xx-small">
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>List Price</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" formatter="currency" step="0.01" value="{!v.PBE.UnitPrice}"  aura:id="pbeupId"/>							  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Cost Price</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" formatter="currency" step="0.01" value="{!v.PBE.ERP7__Purchase_Price__c}" />
                                                                            </div> 
                                                                        </div>
                                                                    </div>     
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Barcode</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.PBE.ERP7__Barcode__c}"  aura:id="pbeupId"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row slds-m-top--xx-small">	
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Price Book</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="Pricebook2" selectedRecordId="{!v.PBE.Pricebook2Id}" placeholder="Search Price Books..." IconName="standard:orders"/> <br/>  
                                                                                <lightning:formattedText value="{!v.priceBookMsg}" class="red"/>
                                                                            </div> 
                                                                        </div>
                                                                    </div>  
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Tax Plan</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Tax_Plan__c" selectedRecordId="{!v.PBE.ERP7__Tax_Plan__c}" placeholder="Search Tax Plans..." IconName="custom:custom62"/>  
                                                                            </div>
                                                                        </div>
                                                                    </div> 
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Discount Plan</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Discount_Plan__c" selectedRecordId="{!v.PBE.ERP7__Discount_Plan__c}" placeholder="Search Discount Plan..." IconName="custom:custom32"/>  
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row slds-m-top--xx-small">	
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Product Version</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.PBE.ERP7__Product_Version__c}" placeholder="Search Product Version..." IconName="custom:custom32"/> <br/>  
                                                                            </div> 
                                                                        </div>
                                                                    </div>  
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Start Date</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.PBE.ERP7__Start_Date__c}"  />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">End Date</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.PBE.ERP7__End_Date__c}"  />                              
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                
                                                                <div class="row slds-m-top--xx-small">				 
                                                                    <div class="col-md-8">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Description</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:textarea value="{!v.PBE.ERP7__Description__c}" rows="5"/>
                                                                            </div>
                                                                        </div>
                                                                    </div> 
                                                                    
                                                                    <div class="col-md-4">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Active</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="checkbox" checked="{!v.PBE.IsActive}" class="slds-output" aura:id="pbeActiveId"/> 
                                                                            </div>
                                                                        </div>
                                                                    </div>  
                                                                </div> 
                                                                <div class="row slds-m-top--xx-small">
                                                                    <div class="col-md-12">
                                                                    </div>
                                                                </div>   
                                                                
                                                            </div>
                                                            <footer class="slds-modal__footer slds-text-align--center">
                                                                <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
                                                                <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
                                                            </footer>
                                                        </div>
                                                    </div>   
                                                </section>
                                            </div>    
                                            <div class="slds-backdrop slds-backdrop--open"></div>
                                        </aura:if>
                                    </aura:if>
                                </div>
       							<!-- Price Book Entries Tab Ends -->
                                
                                <!-- Version Tab Starts -->
                                <div class="" id="versionTabId" aura:id="versionTabId">
                                    <aura:if isTrue="{!v.Tab=='ver'}">  
                                        <div>
                                            <div class="slds-page-header ProductLCM-newClass12">
                                                <div class="slds-grid">
                                                    <div class="slds-col slds-has-flexi-truncate">
                                                        <div class="slds-media slds-no-space slds-grow">
                                                            <div class="slds-media__body">
                                                                <nav>
                                                                    <ol class="slds-breadcrumb slds-line-height_reset">
                                                                    </ol>
                                                                </nav>
                                                                <h4 class="slds-m-right_small slds-align-middle slds-truncate" title="">Versions ({!v.VersionList.length})</h4>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="slds-col slds-align-middle">                                                    
                                                        <c:StockTakeSearch Placeholder="Search by Code or Category"/>                                                               
                                                    </div>
                                                    <div class="slds-col slds-no-flex slds-grid slds-align-middle">
                                                        <div class="slds-button slds-m-top--small" role="group">
                                                            <button data-name="ver" onclick="{!c.showNewPopup}"  class="{!v.ProductId==''?'DisaClass slds-button slds-button--brand ':'slds-button slds-button--brand'}"> <!--  data-toggle="modal" data-target="#myModal"  -->
                                                                <i class="fa fa-plus" > </i> &nbsp;New</button>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="slds-card__body ProductLCM-newClass13">
                                                    <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-top--small">
                                                        <thead>
                                                            <tr class="slds-text-title--caps">
                                                                <th class="slds-cell-shrink" scope="col">&nbsp;</th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> Actions </div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> Code </div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> Type </div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> Status </div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> Start Date </div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title=""> End Date </div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <aura:if isTrue="{!v.VersionList.length>0}">
                                                                <aura:iteration items="{!v.VersionList}" var="ver" indexVar="index">   
                                                                    <tr class="slds-hint-parent">
                                                                        <td scope="row" data-label="">
                                                                        </td>
                                                                        <td data-label="Actions">
                                                                            <img onclick="{!c.getRecord}" data-name="update" id="{!ver.Id}" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" class="ProductLCM-newClass14" title="Edit" />&nbsp;
                                                                            <img onclick="{!c.getDelete}" data-name="delete" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" id="0" class="ProductLCM-newClass14" title="Delete" />
                                                                        </td>
                                                                        <td scope="row" data-label="Name">
                                                                            <div class="slds-truncate" title="">
                                                                                <lightning:formattedText value="{!ver.Name}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td data-label="Type">
                                                                            <div class="slds-truncate">
                                                                                <lightning:formattedText value="{!ver.ERP7__Type__c}"/>
                                                                            </div>
                                                                        </td> 
                                                                        <td data-label="Category">
                                                                            <div class="slds-truncate">
                                                                                <lightning:formattedText value="{!ver.ERP7__Status__c}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td data-label="Start Date">
                                                                            <div class="slds-truncate">
                                                                                <lightning:formattedText value="{!ver.ERP7__Start_Date__c}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td data-label="End Date">
                                                                            <div class="slds-truncate">
                                                                                <lightning:formattedText value="{!ver.ERP7__To_Date__c}"/>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                </aura:iteration>
                                                                <aura:set attribute="else">
                                                                    <tr>
                                                                        <td colspan="9" class="ProductLCM-newClass9">
                                                                            <div class="slds-notify_container slds-is-relative ProductLCM-newClass15">
                                                                                <div class="slds-notify slds-notify_toast slds-theme_warning ProductLCM-newClass28" role="alert">
                                                                                    <span class="slds-assistive-text">warning</span>
                                                                                    <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                                                                    <div class="slds-notify__content ProductLCM-newClass30">
                                                                                        <h2 class="slds-text-heading_small ProductLCM-newClass31">No Records to display</h2>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                </aura:set>
                                                            </aura:if>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <aura:if isTrue="{!v.showPopup}"> 
                                            <div class="erp_mark7"> 
                                                <section id="ppId" role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open"> 
                                                    <div class="slds-modal__container">
                                                        <div>
                                                            <div class="slds-modal__header">
                                                                <button onclick="{!c.HideNewPopup}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />                                                                    <span class="slds-assistive-text">Close</span>
                                                                </button>
                                                                <h2 class="modal-title slds-align--absolute-center" >
                                                                    <aura:if isTrue="{!v.Tab!='update'}"> New
                                                                        <aura:set Attribute="else">Update</aura:set>               
                                                                    </aura:if>
                                                                    Version
                                                                </h2>
                                                            </div>
                                                            <div class="slds-modal__content slds-p-around_medium ProductLCM-newClass29">
                                                                <div class="row slds-m-top--small">
                                                                    <div class="col-md-12">    
                                                                        <span class="{!v.seBool==true?'red ProductLCM-newClass11':'slds-hide ProductLCM-newClass11'}"
                                                                               >
                                                                            <i class="fa fa-window-close ProductLCM-newClass16" aria-hidden="true"></i> &nbsp; Code field is mandatory
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Code</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.Version.Name}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Start Date</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.Version.ERP7__Start_Date__c}"  />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">To Date</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="date" variant="label-hidden" class="display-lable" value="{!v.Version.ERP7__To_Date__c}"  /> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Category</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.Version.ERP7__Category__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.VersionCategoryList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Category__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Type</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.Version.ERP7__Type__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.VersionTypeList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Type__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Status</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.Version.ERP7__Status__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.VersionStatusList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Version.ERP7__Status__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Asset</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Asset__c" selectedRecordId="{!v.Version.ERP7__Asset__c}" placeholder="Search Assets..."/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Process</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Process__c" selectedRecordId="{!v.Version.ERP7__Process__c}" placeholder="Search Process..."/> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Quantity</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number"  variant="label-hidden" value="{!v.Version.ERP7__Quantity__c}" /> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Price Book</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="PriceBook2" selectedRecordId="{!v.Version.ERP7__Price_Book__c}" placeholder="Search Price Books..."/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Inventory / Stock</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Inventory_Stock__c" selectedRecordId="{!v.Version.ERP7__Inventory_Stock__c}" placeholder="Search Inventory / Stocks..."/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Barcode</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.Version.ERP7__Barcode__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Picture</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.Version.ERP7__Picture__c}" />                            
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Default</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="checkbox" checked="{!v.Version.ERP7__Default__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Active</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="checkbox" checked="{!v.Version.ERP7__Active__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-12 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Description</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:textarea value="{!v.Version.ERP7__Description__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <footer class="slds-modal__footer slds-text-align--center">
                                                                <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
                                                                <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
                                                            </footer>
                                                        </div>
                                                    </div>   
                                                </section>
                                            </div>    
                                            <div class="slds-backdrop slds-backdrop--open"></div>
                                        </aura:if>
                                    </aura:if>          
                                </div>
