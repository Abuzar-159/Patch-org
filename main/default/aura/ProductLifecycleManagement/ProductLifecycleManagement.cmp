                                                        <button onclick ="{!c.showNewPopup}" data-name="av"  class="{!v.ProductId==''?'DisaClass slds-button slds-button--brand ':'slds-button slds-button--brand'}" data-toggle="modal" data-target="#myModal">
                                                            <i class="fa fa-plus"></i>&nbsp;New
                                                        </button>
