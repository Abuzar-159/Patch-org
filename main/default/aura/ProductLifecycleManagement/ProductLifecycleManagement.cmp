                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Lot_Tracked__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Allow Pre-Orders</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Allow_Pre_Orders__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
