                                                        <label class="slds-form-element__label" for="input-unique-id">Serialise</label>
                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Serialise__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
                                                        <label class="slds-form-element__label" for="input-unique-id">Is Asset</label>
                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Is_Asset__c}"/>
                                                        </div>
