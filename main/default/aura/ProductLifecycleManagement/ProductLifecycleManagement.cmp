                                                        <div>
                                                            <div class="slds-modal__header">
                                                                <button onclick="{!c.HideNewPopup}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close!" title="close" />                                                                    <span class="slds-assistive-text">Close</span>
                                                                </button>
                                                                <h4 class="modal-title slds-align--absolute-center" >
                                                                    <aura:if isTrue="{!v.Tab!='update'}"> New
                                                                        <aura:set Attribute="else">Update</aura:set>               
                                                                    </aura:if>
