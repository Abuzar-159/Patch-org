                                                        <div class="slds-form-element__control slds-p-bottom--medium">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Allow_Back_Orders__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div> 
                                            <div class="row">
                                                <div class="col-md-3 slds-p-top--xx-small">
