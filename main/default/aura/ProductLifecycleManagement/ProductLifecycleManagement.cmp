                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">BOM (Assest)</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Asset__c" selectedRecordId="{!v.BOM.ERP7__BOM_Asset__c}" placeholder="Search BOM (Assest)..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">BOM Version</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.BOM.ERP7__BOM_Version__c}" placeholder="Search Version..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Minimum Variance</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number"  variant="label-hidden" value="{!v.BOM.ERP7__Minimum_Variance__c}" /> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Maximum Variance</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number"  variant="label-hidden" value="{!v.BOM.ERP7__Maximum_Variance__c}" aura:id="mid" /> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Unit of measure</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:select value="{!v.BOM.ERP7__Unit_of_Measure__c}"  variant="label-hidden"  class="display-lable">
                                                                                    <aura:iteration items="{!v.BOMUoMList}" var="option">
                                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.BOM.ERP7__Unit_of_Measure__c, option.value)}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Sort</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number"  variant="label-hidden" value="{!v.BOM.ERP7__Sort__c}" aura:id="mid" /> 
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-4 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Active</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="checkbox" checked="{!v.BOM.ERP7__Active__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-8 slds-p-top--xx-small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Description</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:textarea value="{!v.BOM.ERP7__Description__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <footer class="slds-modal__footer slds-text-align--center">
                                                                <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">Cancel</button>
                                                                <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >Save</button>
                                                            </footer>
                                                        </div>
                                                    </div>   
                                                </section>
                                            </div>    
                                            <div class="slds-backdrop slds-backdrop--open"></div>
                                        </aura:if>
                                    </aura:if>          
                                </div>  
      							<!-- BOM Tab Starts -->
                                
                                <!-- WIP Tab Starts -->
                                <div class="" id="wipTabId" aura:id="wipTabId">
                                    <aura:if isTrue="{!v.Tab=='wip'}">
                                        <div class="slds-page-header ProductLCM-newClass12">
                                            <div class="slds-grid">
                                                <div class="slds-col slds-has-flexi-truncate">
                                                    <div class="slds-media slds-no-space slds-grow">
                                                        <div class="slds-media__body">
                                                            <nav>
                                                                <ol class="slds-breadcrumb slds-line-height_reset">
                                                                </ol>
                                                            </nav>
