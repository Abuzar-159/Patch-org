                                                        <div class="slds-form-element__control">
                                                            <lightning:input type="checkbox" checked="{!v.Product.ERP7__Track_Inventory__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3 slds-p-top--xx-small">
                                                    <div class="slds-form-element">
