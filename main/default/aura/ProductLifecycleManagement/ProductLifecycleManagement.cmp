                                                                            <img onclick="{!c.getDelete}" data-name="delete" id="{!b.Id}" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" class="ProductLCM-newClass14" title="Delete" />
