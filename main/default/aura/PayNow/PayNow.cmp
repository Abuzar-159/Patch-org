<aura:component implements="flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes" access="Global">
      
    <aura:attribute name="ISO_currencyCode" type="currency" default="USD"/>
    <aura:attribute name="PayBtnURL" type="String"  default="https://erp-mark-7-dev-ed--c.eu5.content.force.com/servlet/servlet.ImageServer?id=01524000004toj0&amp;oid=00D24000000q8Wb"/>
    <aura:attribute name="MerchantId" type="String" access="global" required="true"/>
    <aura:attribute name="Live_Url" type="String" default="https://www.sandbox.paypal.com/"/>
    <aura:attribute name="return_url" type="String" default="https://erp-mark-7-dev-ed--erp7.eu5.visual.force.com/apex/PaypalPaymentSuccess"/>
    <aura:attribute name="cancel_return_url" type="String" default="https://erp-mark-7-dev-ed.lightning.force.com/apex/ERP7__CardPaymentLC?SON="/>
    <aura:attribute name="soId" type="String"/>
    <aura:attribute name="InvoiceId" type="String"/>
    <aura:attribute name="Invoice_amount" type="Decimal" required="true"/>
    <form action="{!v.Live_Url+'/cgi-bin/webscr'}" method="post" target="_top">
      	<input type="hidden" name="cmd" value="_xclick"/>
        <input type="hidden" name="business" value="{!v.MerchantId}"/>
        <input type="hidden" name="lc" value="US"/>
        <input type="hidden" name="button_subtype" value="services"/>
        <input type="hidden" name="no_note" value="0"/>
        <input type="hidden" name="cn" value="Test"/>
        <input type="hidden" name="no_shipping" value="2"/>
        <input type="hidden" name="rm" value="2"/>
        <input type="hidden" name="amount" value="{!v.Invoice_amount}"/>
        <input type="hidden" name="return" value="{!v.return_url}"/>
        <input type="hidden" name="cancel_return" value="{!v.cancel_return_url+v.soId}"/>
        <input type="hidden" name="currency_code" value="{!v.ISO_currencyCode}"/>
        <input type="hidden" name="bn" value="PP-BuyNowBF:btn_buynowCC_LG.gif:NonHosted"/>
        <input type="hidden" name="item_name" value="{!v.InvoiceId}"/>
         <input type="hidden" name="notify_url" value="https://erp-mark-7-dev-ed--erp7.eu5.visual.force.com/apex/PaypalPaymentSuccess"/>   
        <input type="hidden" name="item_number" value="{!v.soId}"/>
        <input type="image" src="{!v.PayBtnURL}" border="0" name="submit" alt=""/>
    </form>
   
</aura:component>