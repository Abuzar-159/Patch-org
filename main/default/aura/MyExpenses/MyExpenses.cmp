                                                                                        <i class="fa fa-times-circle myExpenese-newClass30" title="{!account.ERP7__Status__c}"></i>&nbsp;
                                                                                        <aura:set attribute="else">
                                                                                            <i title="{!account.ERP7__Status__c}" class="{!(account.ERP7__Status__c == 'Draft')?'myExpenese-newClass30 fa fa-check-circle' : (account.ERP7__Status__c == 'Approved')?'myExpenese-newClass32 fa fa-check-circle' : (account.ERP7__Status__c == 'Submitted')?'myExpenese-newClass33 fa fa-check-circle' : 'myExpenese-newClass30 fa fa-check-circle'}"></i>&nbsp;
                                                                                        </aura:set>
