                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:if isTrue="{!not(greaterthan(v.table.length, 0))}">
                                                        <tr>
                                                            <td colspan="8">
                                                                <div class="no projects myExpenese-newClass26">
                                                                    <div class="slds-notify_container slds-is-relative myExpenese-newClass27">
                                                                        <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                                             <div>
                                                                                <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>
