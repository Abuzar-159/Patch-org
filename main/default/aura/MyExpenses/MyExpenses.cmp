<aura:component Controller="ERP7.ExpenseSheetLC" implements="force:appHostable" >
    <head>
        <ltng:require styles="{!join(',',$Resource.SLDS+ '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/MyExpenses.css"/>
       
        <!--<ltng:require styles="/resource/ERP7__SupplierPoratalComm/SupplierPortalComm/CSS/overiding-standard.css"/>-->
        
    </head>
    
    <!-- varibales & handlers starts -->
    <aura:attribute name="table" type="Expense__c[]" />
    <aura:attribute name="ExpenseListWP" type="ExpenseSheetLC[]"/>
    <aura:attribute name="table2" type="Expense__c[]" />
    <aura:attribute name="table4" type="Expense__c[]" />
    <aura:attribute name="ApprovedExpenseListWP" type="ExpenseSheetLC[]"/>
    <aura:attribute name="empExpenses" type="Expense__c[]" />
    <aura:attribute name="EmpExpenseListWP" type="ExpenseSheetLC[]"/>
    <aura:attribute name="AddExpenseFLSCheck" type="object" default="{'sObjectType' : 'AddExpenseFLSCheck'}"/>
    <aura:attribute name="EmpDetails" type="Employees__c" default="{sobjectType : 'Employees__c'}" />
    <aura:attribute type="ExpenseSheetLC" name="counts" />
    <aura:attribute name="currency" type="Map" default="{'EUR' : '€', 'GBP' : '£', 'USD' : '$', 'GHS' :'¢'}" />
    <aura:attribute name="currencyCode" type="String" />
    <aura:attribute name="emp" type="Employees__c" default="{sobjectType : 'Employees__c'}" />
    <aura:attribute name="Expense" type="Expense__c" />
    <aura:attribute name="eLineItem" type="Expense_Line_Item__c[]" />
    <aura:attribute name="TimeSheetObj" type="ExpenseSheetLC" />
    <aura:attribute name="TimeSheetObjMul" type="ExpenseSheetLC[]" />
    <aura:attribute type="Boolean" name="sortAsc" />
    <aura:attribute name="accessAllExpenses" type="boolean" default="false"/>
    <aura:attribute type="String" name="sortField" />
    <aura:attribute name="ftctrl" type="boolean" default="true"/>
    <aura:attribute name="approvalProcess" type="Boolean" default="true"/>
    <aura:attribute name="Tab" type="String" default="tab1"/>
    <aura:attribute name="UserId" type="String" default=""/>
    <aura:attribute name="View" type="String" default="List"/>
    <aura:attribute name="tabSort" type="String" default="S"/>
    <aura:attribute name="selectedFY" type="String" default="THIS_FISCAL_YEAR"/>
    <aura:attribute name = "serverSuccess" type = "String" default=""/>
    <aura:attribute name = "exceptionError" type = "String" default = ""/>
    <aura:attribute name="editIndex" type="Integer" default="0"/>
    <aura:attribute name="A_Rcomment" type="String" default=""/>
    <aura:attribute name="empExpenseId" type="String" default=""/>
    <aura:attribute name="CurrentExpId" type="String" default=""/>
    <aura:attribute name="empARIndex" type="Integer" default="0"/>
    <aura:attribute name="TempUserId" type="String" default=""/>
    <aura:attribute name="selectedRows" access="global" type="List"/>
    <aura:attribute name="RowIndex" access="global" type="List"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:handler name="change" value="{!v.UserId}" action="{!c.display}" />
    <aura:handler name="init" value="{!this}" action="{!c.display}" />
    <aura:handler name="init" value="{!this}" action="{!c.displayApproved}" />
    <aura:handler name="init" value="{!this}" action="{!c.displayRefund}" />
    <!--<aura:handler name="init" value="{!this}" action="{!c.getExpenseDetailsApproved}" />-->
    <aura:handler name="init" value="{!this}" action="{!c.doesInit}" />
    <aura:handler name="init" value="{!this}" action="{!c.getExpDetailsEmp}" />
    <aura:attribute name="allLIselected" type="Boolean" default="false"/> 
    <aura:attribute name="allselected" type="Boolean" default="false"/> 
    
    <aura:handler name="delete" action="{!c.handleExpenseDelete}" />
    <!-- <aura:registerEvent name="edit" type="ERP7:editTimesheetEvent" />-->
    <aura:registerEvent name="delete" type="c:leaveDelete" /> 
    <!--<aura:handler name="init" value="{!this}" action="{!c.getExpenseDetails}" />-->
    <!-- varibales & handlers ends -->
    <body aura:id="body" class="myExpenese-newClass1">
        <div class="erp_mark7 maqsood myExpenese-newClass2" aura:id="body">
            <span class="myExpenese-newClass25">
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
            <!--Success Message-->
            <div class="{!if(and(v.serverSuccess != '', v.serverSuccess != undefined),'myExpenese-newClass3 slds-notify_container slds-is-fixed','myExpenese-newClass4 slds-notify_container slds-is-fixed')}">
                <div class="slds-notify slds-notify_toast slds-theme_success" role="status">
                    <span class="slds-assistive-text">{!$Label.c.success_AddTimesheets}</span>
                    <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="Description of icon when needed">
                       <lightning:icon iconName="action:approval" size="x-small" alternativeText="{!$Label.c.Success}" title="Success" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_small ">{!v.serverSuccess}</h2>
                    </div>
                    <div class="slds-notify__close">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeSuccess}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="{!$Label.c.Close_Timesheets}" />	
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                        </button>
                    </div>
                </div>
            </div>
            <!--Success Message End-->
            
            <!--Error Message-->
            <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'myExpenese-newClass3 slds-notify_container slds-is-fixed','myExpenese-newClass4 slds-notify_container slds-is-fixed')}">
                <div class="slds-notify slds-notify_toast slds-theme_error myExpenese-newClass5" role="status">
                    <span class="slds-assistive-text">{!$Label.c.error_MyExpenses}</span>
                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="{!$Label.c.error_MyExpenses}" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_x-small myExpenese-newClass6">{!v.exceptionError}
                        </h2>
                    </div>
                    <div class="slds-notify__close myExpenese-newClass7">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="{!$Label.c.Close_Timesheets}" />	
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                        </button>
                    </div>
                </div>
            </div>
            <!--Error Message End-->
            
            <div class="maqsood erp_mark7 erp_Mark7 myExpenese-newClass8">
                
                
                
                <div class="panel-collapse">
                    <div class="panel-body myExpenese-newClass8 pt-0 pl-4">
                        <div class="d-flex align-items-center mb-1 myExpenese-newClass9">
                            <ul class="nav nav-tabs col-lg-7 col-7 myExpenese-newClass10" role="tablist" >
                                <li class="{!(v.Tab == 'tab1')?'nav-item active slds-p-right_small':'nav-item slds-p-right_small'}"> 
                                    <a class="nav-link myExpenese-newClass11"  data-tab = "tab1"  onclick="{!c.toggleTabs}"><!-- onclick="Back2ManufacturingPlanner();" -->
                                        <div class="slds-grid">
                                           
                                            <aura:if isTrue="{!!v.approvalProcess}">
                                                	<div class="mobile-display-none pt-2">{!$Label.c.Expense_My_Expenses}</div>
                                            	<aura:set attribute="else">
                                                	<div class="mobile-display-none pt-2">{!$Label.c.Draft_Submitted_ManageLeave}</div>
                                                </aura:set>
                                            </aura:if>
                                            
                                        </div>   
                                    </a>
                                </li>
                                <aura:if isTrue="{!!v.approvalProcess}">
                                <li class="{!(v.Tab == 'tab4')?'nav-item active slds-p-right_small':'nav-item slds-p-right_small'}"> 
                                    <a class="nav-link slds-grid myExpenese-newClass11"  data-tab = "tab4"  onclick="{!c.toggleTabs}"><!-- onclick="Back2ManufacturingPlanner();" -->
                                        <div class="slds-grid">
                                           
                                            <div class="mobile-display-none pt-2" >{!$Label.c.Expense_Refund_Expenses}</div>
                                        </div>
                                    </a>
                                </li>
                                </aura:if>
                                <aura:if isTrue="{!v.approvalProcess}">
                                <li class="{!(v.Tab == 'tab2')?'nav-item active slds-p-right_small':'nav-item slds-p-right_small'}"> 
                                    <a class="nav-link slds-grid myExpenese-newClass11"  data-tab = "tab2"  onclick="{!c.toggleTabs}"><!-- onclick="Back2ManufacturingPlanner();" -->
                                        <div class="slds-grid">
                                          
                                            <div class="mobile-display-none pt-2" >{!$Label.c.Approved_Rejected_ManageLeave}</div>
                                        </div>
                                    </a>
                                </li>
                                <li class="{!(v.Tab == 'tab3')?'nav-item active ':'nav-item'}"> 
                                    <a class="nav-link slds-grid myExpenese-newClass11"  data-tab = "tab3"  onclick="{!c.toggleTabs}"><!-- onclick="Back2ManufacturingPlanner();" -->
                                        <div class="slds-grid">
                                            
                                            <div class="mobile-display-none pt-2">{!$Label.c.Expense_Submitted_for_your_Approval}</div>
                                        </div>  
                                    </a>
                                </li>
                                </aura:if>
                            </ul>
                            
                            
                            <div class="slds-grid col-lg-5 col-5 myExpenese-newClass12">
                                <div class="mr-2 pt-1">
                                    <lightning:select aura:id="InputSelectDynamic" variant="label-hidden" onchange="{!c.selectFY}" value="{!v.selectedFY}" class="nolabel">
                                        <option value="THIS_FISCAL_YEAR" selected="true">{!$Label.c.Current_FY_ManageLeave}</option>
                                        <option value="">{!$Label.c.To_Date_Timesheets}</option>
                                        <option value="THIS_MONTH">{!$Label.c.Current_Month}</option>
                                        <option value="THIS_QUARTER">{!$Label.c.Current_Quarter}</option>
                                        <option value="LAST_QUARTER">{!$Label.c.Last_Quarter}</option>
                                        <option value="LAST_FISCAL_YEAR">{!$Label.c.Previous_FY_ManageLeave}</option>
                                        <!--<option value="NEXT_FISCAL_YEAR">Next FY</option>-->
                                        <!--<option value="LAST_N_FISCAL_YEARS:2">Previous 2 FY</option>-->
                                        
                                    </lightning:select>
                                </div>
                                <a onclick="{!c.CreateExpense}" data-record="Add" class="addNewBTN" title="Add" href="javascript:void(0);">
                                    &nbsp;<i class="fa fa-plus myExpenese-newClass13" aria-hidden="true"></i>
                                    &nbsp;&nbsp;<strong>{!$Label.c.Expense}</strong>
                                </a>
                                <aura:if isTrue="{!v.accessAllExpenses}">
                                    <div class="width150p">
                                	<c:CustomInputLookUp objectAPIName="User" aura:id="OrgName" IconName="standard:account" selectedRecordId="{!v.UserId}"/>
                                    </div>
                                </aura:if>
                                <div class="myExpenese-newClass14 ">
                                    <a class="{!(v.View == 'Grid')?'myExpenese-newClass15 acitve-list2':'myExpenese-newClass16'}" title="Grid View" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.toggleViews}">
                                        <i class="fa fa-th-large"></i>
                                    </a>
                                    <a class="{!(v.View == 'List')?'myExpenese-newClass15 acitve-list2':'myExpenese-newClass16'}" title="List View" data-tab = "List" href="javascript:void(0);" onclick="{!c.toggleViews}">
                                        <i class="fa fa-list"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <aura:if isTrue="{!v.approvalProcess}">
                <div class="row p-2 m-0 erp_mark7">
                    
                    <div class="col-xl-4 col-lg-6">
                        <div class="card background-inprogress">
                            <div class="card-body text-center myExpenese-newClass17" data-status="Draft">
                                <div class="slds-grid">
                                    <div class="slds-col">
                                        <lightning:icon iconName="utility:clock" size="x-small" alternativeText="{!$Label.c.clock}" title="Clock" variant="bare"/>  
                                    </div>
                                    <div class="slds-col pt-1">
                                        <h6 class="mb-0 mt-0 myExpenese-newClass20">
                                            {!$Label.c.Expense_Submitted_Amount}
                                        </h6>
                                    </div>
                                    <div class="slds-col">
                                        <div class="myExpenese-newClass18"><strong>{!v.currencyCode}</strong>&nbsp;{!v.counts.numAmountSub}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4 col-lg-6">
                        <div class="card background-new">
                            <div class="card-body text-center myExpenese-newClass17" data-status="Cancelled">
                                <div class="slds-grid">
                                    <div class="slds-col">
                                        <lightning:icon iconName="utility:check" size="x-small" alternativeText="{!$Label.c.new_task}" title="new_task" variant="bare" />
                                    </div>
                                    <div class="slds-col pt-1">
                                        <h6 class="mb-0 mt-0 myExpenese-newClass20">
                                            &nbsp;{!$Label.c.Expense_Approved_Amount}</h6>
                                    </div>
                                    <div class="slds-col">
                                        <div class="myExpenese-newClass18"><strong>{!v.currencyCode}</strong>&nbsp;{!v.counts.numAmountApp}</div>
                                    </div>    
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4 col-lg-6">
                        <div class="card background-success">
                            <div class="card-body text-center myExpenese-newClass17" data-status="In Progress">
                                <div class="slds-grid">
                                    <div class="slds-col">
                                        <lightning:icon iconName="utility:warranty_term" size="x-small" alternativeText="{!$Label.c.approval}" title="approval" variant="bare"/>
                                    </div>
                                    <div class="slds-col pt-1">
                                        <h6 class="mb-0 mt-0 myExpenese-newClass20">
                                           Rejected Amount
                                        </h6>
                                    </div>
                                    <div class="slds-col">
                                        <div class="myExpenese-newClass18"><strong>{!v.currencyCode}</strong>&nbsp;{!v.counts.numAmountRej}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </aura:if>
                
             <aura:if isTrue="{!!v.approvalProcess}">   
                 <div class="row m-0" >
                     <div class="col-12">
                         <div class="card widget-inline border-0 " >
                             <div class="card-body p-0 m-0" >
                                 <div class="row g-0 m-0" >
                                     <div class="col-sm-6 col-xl-4 pr-0" >
                                         <div class="card shadow-none m-0 border-0" >
                                             <div class="card-body text-center"  >
                                                 <i class="fa fa-briefcase text-muted font-24" ></i>
                                                 <h3  class="mb-0 color-blue"><span >{!v.currencyCode}&nbsp;{!v.counts.numAmountSub}</span></h3>
                                                 <p class="text-muted font-15 mb-0" >{!$Label.c.Expense_Amount}</p>
                                             </div>
                                         </div>
                                     </div>
                                     <div class="col-sm-6 col-xl-4 pl-0 pr-0 border-start" >
                                         <div class="card shadow-none m-0  border-0" >
                                             <div class="card-body text-center" >
                                                 <i class="fa fa-percent text-muted font-24"  ></i>
                                                 <h3 class="mb-0 color-red"><span >{!v.currencyCode}&nbsp;{!v.counts.numAmountApp}</span></h3>
                                                 <p class="text-muted font-15 mb-0" >{!$Label.c.Expense_Tax_Amount}</p>
                                             </div>
                                         </div>
                                     </div>
                                     <div class="col-sm-6 col-xl-4 pl-0 pr-0 border-start " >
                                         <div class="card shadow-none m-0 border-0" >
                                             <div class="card-body text-center" >
                                                 <i class="fa fa-money text-muted font-24"  ></i>
                                                 <h3  class="mb-0 color-green"><span >{!v.currencyCode}&nbsp;{!v.counts.numAmountPaid}</span></h3>
                                                 <p class="text-muted font-15 mb-0">{!$Label.c.SalesOrderToPurchaseOrder_SO_Total_Amount}</p>
                                             </div>
                                         </div>
                                     </div>
                                     
                                 </div>
                             </div>
                         </div>
                     </div>
                 </div>
                </aura:if>
            </div>
            
            <div class="erp_Mark7 myExpenese-newClass8">
                <div class="tab-content"><!-- margin-bottom: 60px; -->
                    <!--List View-->
                    <div class="{!(v.View == 'List')?'slds-show':'slds-hide'}" aura:id="mosList">
                        <div class="{!(v.Tab == 'tab1')?'slds-show':'slds-hide'}" aura:id="mosList">
                            <div class="maqsood erp_Mark7 container-fluid">
                                <div class="card shadow-mrr myExpenese-newClass21">
                                    <div class="card-body">
                                        <div class="table-responsive myExpenese-newClass22" tabindex="1">
                                            <table class="table">
                                                <thead>
                                                    <tr class="slds-text-title--caps">
                                                        <th scope="col" >
                                                            
                                                         <lightning:input type="checkbox" onchange="{!c.handleChange}" aura:id="expAllId" checked="{!v.allLIselected}" /> 
                                                                    
                                                        </th>
                                                        <th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByName}" class="fcolor1 myExpenese-newClass23">{!$Label.c.Name_ManageLeave}</a>&nbsp;&nbsp;&nbsp;
                                                                <aura:if isTrue="{!and(v.tabSort == 'S', greaterthan(v.table.length, 1))}">
                                                                    <aura:if isTrue="{!and(v.sortField == 'Name' ,v.sortAsc)}">
                                                                        <i class="fa fa-long-arrow-up myExpenese-newClass24" aria-hidden="true"></i>
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!and(v.sortField == 'Name' ,not(v.sortAsc))}">
                                                                                <i class="fa fa-long-arrow-down myExpenese-newClass24" aria-hidden="true"></i>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </span>
                                                        </th>
                                                        <aura:if isTrue="{!v.AddExpenseFLSCheck.projectAccess}">
                                                        <th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByProject}" class="myExpenese-newClass23">{!$Label.c.EmployeeReviewV2_Project}</a>&nbsp;&nbsp;&nbsp;
                                                                <aura:if isTrue="{!and(v.tabSort == 'S', greaterthan(v.table.length, 1))}">
                                                                    <aura:if isTrue="{!and(v.sortField == 'ERP7__Project__r.Name' ,v.sortAsc)}">
                                                                        <i class="fa fa-long-arrow-up myExpenese-newClass24" aria-hidden="true"></i>
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!and(v.sortField == 'ERP7__Project__r.Name' ,not(v.sortAsc))}">
                                                                                <i class="fa fa-long-arrow-down myExpenese-newClass24" aria-hidden="true"></i>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </span>
                                                        </th>
                                                        </aura:if>
                                                        <th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByDate}" class="fcolor1 myExpenese-newClass23">Date</a>&nbsp;&nbsp;&nbsp;
                                                                <aura:if isTrue="{!and(v.tabSort == 'S', greaterthan(v.table.length, 1))}">
                                                                    <aura:if isTrue="{!and(v.sortField == 'ERP7__Date__c' ,v.sortAsc)}">
                                                                        <i class="fa fa-long-arrow-up myExpenese-newClass24" aria-hidden="true"></i>
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!and(v.sortField == 'ERP7__Date__c' ,not(v.sortAsc))}">
                                                                                <i class="fa fa-long-arrow-down myExpenese-newClass24" aria-hidden="true"></i>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </span>
                                                        </th>
                                                        <th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByAmount}" class="fcolor1 myExpenese-newClass23">{!$Label.c.Expense_Submitted_Amount}</a>&nbsp;&nbsp;&nbsp;
                                                                <aura:if isTrue="{!and(v.tabSort == 'S', greaterthan(v.table.length, 1))}">
                                                                    <aura:if isTrue="{!and(v.sortField == 'ERP7__Amount_Submitted__c' ,v.sortAsc)}">
                                                                        <i class="fa fa-long-arrow-up myExpenese-newClass24" aria-hidden="true"></i>
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!and(v.sortField == 'ERP7__Amount_Submitted__c' ,not(v.sortAsc))}">
                                                                                <i class="fa fa-long-arrow-down myExpenese-newClass24"  aria-hidden="true"></i>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </span>
                                                        </th>
                                                        <!--th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByVat}" class="fcolor1 myExpenese-newClass23">{!$Label.c.Epense_VAT_TAX}</a>&nbsp;&nbsp;&nbsp;
                                                                <aura:if isTrue="{!and(v.tabSort == 'S', greaterthan(v.table.length, 1))}">
                                                                    <aura:if isTrue="{!and(v.sortField == 'ERP7__VAT_Amount__c' ,v.sortAsc)}">
                                                                        <i class="fa fa-long-arrow-up myExpenese-newClass24" aria-hidden="true"></i>
                                                                        <aura:set attribute="else">
                                                                            <aura:if isTrue="{!and(v.sortField == 'ERP7__VAT_Amount__c' ,not(v.sortAsc))}">
                                                                                <i class="fa fa-long-arrow-down myExpenese-newClass24"  aria-hidden="true"></i>
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </span>
                                                        </th>-->
                                                        <th scope="col">
                                                            <span class="slds-truncate">
                                                                <a onclick="{!c.sortByVat}" class="fcolor1 myExpenese-newClass23">STATUS</a>&nbsp;&nbsp;&nbsp;
                                                            </span>
                                                        </th>
                                                        <aura:if isTrue="{!v.AddExpenseFLSCheck.caAccess}">
