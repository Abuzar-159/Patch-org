                                    </div>
                                </header>
                                <aura:iteration var="pro" indexVar="count" items="{!v.ProductsAndDiscountsWrapperListtEdit}">
                                    <div class="slds-card__body" >
                                        <div class="epos-class64">
                                            <table class="slds-table slds-table--bordered slds-no-row-hover slds-table--cell-buffer">
                                                <thead >
                                                    <tr class="slds-text-heading--label">
                                                        <th scope="col" width="10%">
                                                            <div class="slds-truncate radioin" title="Code" >Code</div>
                                                        </th>
                                                        <th scope="col" width="14%">
                                                            <div class="slds-truncate" title="Product" >Product</div>
                                                        </th>
                                                        <!--<aura:If isTrue="{!!(pro.Version == '')}">
                                                            <th scope="col" width="8%">
                                                                <div class="slds-truncate" title="Version">Version</div>
                                                            </th>
                                                        </aura:If>-->
                                                        <th scope="col" width="8%">
                                                            <div class="slds-truncate" title="Price">Price</div>
                                                        </th>
                                                        <th scope="col" width="8%">
                                                            <div class="slds-truncate" title="Quantity">Charge/Qty</div>
                                                        </th>
                                                        <th scope="col" width="6%">
                                                            <div class="slds-truncate3" title="UoM">UoM</div>
                                                        </th>
                                                        <th scope="col" width="16%">
                                                            <div class="slds-truncate" title="Discount">Discount </div>
                                                        </th>
                                                        <th scope="col" width="16%">
                                                            <div class="slds-truncate" title="Description">Description</div>
                                                        </th>
                                                        <aura:If isTrue="{!!(v.IsRental)}">
                                                            <th scope="col" width="10%">
                                                                <div class="slds-truncate" title="Availability">Availability</div>
                                                            </th>
                                                        </aura:If>
                                                        
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr class="slds-hint-parent padng10">
                                                        <td align="center">
                                                            <div class="slds-truncate radioin" title="Code">
                                                                <ui:outputText aura:id="code" value="{!pro.product.ProductCode}"/>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="slds-truncate epos-class34" title="Product"  id="{!pro.product.Id}">
                                                                <ui:outputText value="{!pro.product.Name}" click="{!c.NavRecord}" title="{!pro.product.Id}"/>
                                                                <aura:If isTrue="{!(pro.product.ERP7__Picture__c != undefined)}">
                                                                    &nbsp;<img src="{!pro.product.ERP7__Picture__c}" class="epos-class45" />
                                                                </aura:If>
                                                            </div>
                                                        </td>
                                                        
                                                        <!--<aura:If isTrue="{!!(pro.Version == '')}">
                                                            <td>
                                                                <div class="row">
                                                                    <div class="col-md-10 epos-class51" title="Version" name="{!count}" id="{!pro.product.Id}">
                                                                        <ui:inputSelect class="slds-select discnt" aura:id="ver" value="{!pro.Version}" change="{!c.VersionChanged}" labelClass="{!count}">
                                                                            <aura:iteration items="{!pro.Versions}" var="po">
                                                                                <ui:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.Version,true,false)}"/>
                                                                            </aura:iteration>
                                                                        </ui:inputSelect>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        </aura:If>-->
														
                                                        <td>
                                                            <div class="slds-truncate" title="Price">
                                                                <ui:inputCurrency value="{!pro.pricebookEntry.UnitPrice}"/>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="slds-truncate" title="Charge/Qty" name="{!count}" id="{!pro.product.Id}">
                                                                <ui:inputText value="{!pro.quantity_s}" aura:id="quan" class="slds-input" change="{!c.addDiscountEdit}" labelClass="{!count}"/><!-- addDiscountEdit -->
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="slds-truncate3" title="Unit Of Measure" name="{!count}" id="{!pro.product.Id}">
                                                                <ui:outputText value="{!pro.product.QuantityUnitOfMeasure}"/>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="row">
                                                                <div class="col-md-4 epos-class51" title="Discount Plan" name="{!count}" id="{!pro.product.Id}">
                                                                    <ui:inputSelect class="slds-select discnt" aura:id="dis" value="{!pro.discountName}" change="{!c.discountPercentsEdit}" labelClass="{!count}">
                                                                        <aura:iteration items="{!pro.CurrentDiscounts}" var="po">
                                                                            <ui:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.discountName,true,false)}"/>
                                                                            <!--value="{!if(pro.discountName == p.value,true,false)}"-->
                                                                        </aura:iteration>
                                                                    </ui:inputSelect>
                                                                </div>
                                                                <div class="slds-truncate col-md-3 epos-class65" title="Discount/Unit" name="{!count}" id="{!pro.product.Id}">
                                                                    <ui:inputText aura:id="editDiscountper" value="{!pro.discountPercent}" keyup="{!c.editvalidatevaluek}" updateOn="keyup" change="{!c.editvalidatevalue}" class="slds-input" placeholder="{!if(pro.isPercent == true,'Percentage','Value')}" labelClass="{!count}"/>
                                                                    
                                                                </div>
                                                                <div class="slds-truncate col-md-4 epos-class53">
                                                                    [<ui:outputNumber value="{!pro.minDiscountPercent}"/>-<ui:outputNumber value="{!pro.maxDiscountPercent}"/>]
                                                                    <aura:If isTrue="{!(pro.isPercent == true)}">%</aura:If>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div class="" title="Description" name="{!count}" id="{!pro.product.Id}">
                                                                <ui:inputTextArea value="{!pro.product.Description}"/>
                                                            </div>
                                                        </td>
                                                        <aura:If isTrue="{!!(v.IsRental)}">
