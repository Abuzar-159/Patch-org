                <div class="modal-dialog modal-lg width95">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-body">
                            
                            <!-- Table -->
                            <article class="slds-card slds-m-top--small marginTop">
                                <header class="slds-card__header slds-grid">
                                    <div class="slds-media slds-media--center slds-has-flexi-truncate">
                                        <div class="slds-media__figure">
                                        </div>
                                        
                                        <div class="slds-media__body epos-class63">
                                            <h4 class="marginTop">
                                                <span>Edit Sales Order Line Item</span>
                                            </h4>
