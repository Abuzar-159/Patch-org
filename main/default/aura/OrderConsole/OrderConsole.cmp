            <!-- Modal Comment Edit Line Items -->
            <div id="myModal1" aura:id="ProductDescriptionModal" class="slds-modal" role="dialog">
                <div class="modal-dialog margin200auto">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <div class="slds-grid width100">
                                <div class="col-md-4">
                                    <h4 class="modal-title fsize1rem" >Description</h4>
                                </div>
                                <div class="col-md-8 talignRigth" >
                                    <button type="button" onclick="{!c.closeDescripionModal}" class="closEpos">&times;</button>
                                </div>
                            </div>
                        </div>
                        <div class="modal-body">
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <ui:inputTextArea aura:id="pdes" 
                                                      class="slds-textarea"
                                                      rows="4" cols="20"
                                                      value="{!v.prodDescription}"
                                                      />
                                </div>
                            </div>
                            <div class="slds">
                                <div class="row slds-m-top--medium epos-class69">
                                    <div class="col-md-12 slds-m-bottom--small epos-class70">
                                        <ui:button class="slds-button slds-button--brand" press="{!c.descriptionSet}">Update</ui:button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- popup3 ends here -->
            <!-- Modal popup4 Account -->
            <div id="myModalAcc" aura:id="myModalAcc" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-lg">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeAccountModal}"/>
                            </button>
                            
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre" >New Account</h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="AccountError" value="{!v.NewAccountError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--small">
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Name <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="naname" class="slds-input" value="{!v.NewCustomer.Name}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Account Number</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="naaccno" class="slds-input" value="{!v.NewCustomer.AccountNumber}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Profile <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <!--<ERP7:CustomInputLookUp objectAPIName="ERP7__Profiling__c" aura:id="ncprofl" IconName="standard:client" selectedRecord="{!v.AccProfile2}" qry="{!'AND ERP7__Record_Type_Name__c =\'Customer\''}"/>-->
                                                <c:CustomInputLookUp objectAPIName="ERP7__Profiling__c" aura:id="prof2" IconName="standard:client" selectedRecord="{!v.AccProfile2}" qry="{!'AND ERP7__Record_Type_Name__c =\'Customer\''}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Email</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="naemail" class="slds-input" value="{!v.NewCustomer.ERP7__Email__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Phone</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="num" class="slds-input" value="{!v.NewCustomer.Phone}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Fax</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="nafax" class="slds-input" value="{!v.NewCustomer.Fax}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Company</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="nacom" class="slds-input" value="{!v.NewCustomer.ERP7__Company__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Website</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputURL aura:id="naweb" class="slds-input" value="{!v.NewCustomer.Website}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <aura:if isTrue="{!v.eposFLSCheck.taxInput}">
                                        <div class="col-md-3 col-sm-3 col-xs-12">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Tax</label><br/>
                                                <div class="slds-form-element__control" onmouseover="{!c.lookupClickBlank}">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Tax__c" aura:id="cvat" IconName="standard:entity" selectedRecord="{!v.AccTax2}" />
                                                </div>
                                            </div>
                                        </div>
                                    </aura:if>
                                    <aura:if isTrue="{!v.eposFLSCheck.taxRegNoInput}">
                                        <div class="col-md-3 col-sm-3 col-xs-12">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Tax Regn.No.</label><br/>
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="navatr" class="slds-input" value="{!v.NewCustomer.ERP7__VAT_registration_number__c}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </aura:if>
                                    <div class="col-md-3 col-sm-3 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Description</label><br/>
                                            <div class="slds-form-element__control">
                                                <div class="slds-form-element__control">
                                                    <ui:inputTextArea aura:id="ncdes" 
                                                                      class="slds-textarea" 
                                                                      rows="4" cols="20"
                                                                      value="{!v.NewCustomer.Description}"
                                                                      />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <aura:if isTrue="{!v.eposFLSCheck.isPersonAccountBox}">
                                        <div class="col-md-3 col-sm-3 col-xs-12">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Is Person Account</label><br/>
                                                <div class="slds-form-element__control">
                                                    <div class="slds-form-element__control">
                                                        <ui:inputCheckbox aura:id="pAcc"              
                                                                          value="{!v.NewCustomer.ERP7__Is_Person_Account__c}"
                                                                          />
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </aura:if>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeAccountModal}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.CreateAccount}">Save</ui:button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalAccBackdrop"></div>
            <!-- popup 4 Account ends here -->
            <!-- Modal popup5 Contact -->
            <div id="myModalCon" aura:id="myModalCon" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeContactModal}"/>
                            </button>
                            
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">New Contact</h2>
                        </div>
                        <div class="modal-body epos-class71">
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="ContactError" value="{!v.NewContactError}"/>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Account <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control " onmouseover="{!c.lookupClickAccount}">
                                                <c:CustomInputLookUp objectAPIName="Account" aura:id="ncvat" IconName="standard:account" selectedRecord="{!v.NewCust}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">First Name <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncfn" class="slds-input" value="{!v.NewContact.FirstName}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Last Name <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncln" class="slds-input" value="{!v.NewContact.LastName}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Company</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="nccn" class="slds-input" value="{!v.NewContact.ERP7__Company__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Email</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="nce" class="slds-input" value="{!v.NewContact.Email}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Phone</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="num" class="slds-input" value="{!v.NewContact.Phone}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--x-small">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Is Primary</label><br/>
                                            <div class="slds-form-element__control marleft20">
                                                <ui:inputcheckbox value="{!v.NewContact.ERP7__Primary__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeContactModal}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.CreateCon}">Save</ui:button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalConBackdrop"></div>
            <!-- popup 5 Contact ends here -->
            <!-- Modal popup6 address -->
            <div id="myModalAdr" aura:id="myModalAdr" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeAddressModal}"/>
                            </button>
                           
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">New Address</h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="row slds-m-top--xx-small">
                                        <div class="col-md-12 col-sm-12 col-xs-12">
                                            <span class="epos-class20">
                                                <ui:outputText aura:id="AddressError" value="{!v.NewAddressError}"/>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="row slds-m-top--small"/>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Account <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control" onmouseover="{!c.lookupClickAccount}">
                                                <c:CustomInputLookUp objectAPIName="Account" aura:id="addAcc" IconName="standard:account" selectedRecord="{!v.NewCust}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Contact <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control" onclick="{!c.lookupClickAddressContact}">
                                                <c:CustomInputLookUp objectAPIName="Contact" aura:id="addCon" IconName="standard:contact" selectedRecord="{!v.NewCon}" qry="{!v.qry}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Address Line1 <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncphn" class="slds-input" value="{!v.NewAddress.ERP7__Address_Line1__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Address Line 2</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncphn" class="slds-input" value="{!v.NewAddress.ERP7__Address_Line2__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Address Line 3</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncphn" class="slds-input" value="{!v.NewAddress.ERP7__Address_Line3__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">City <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncphn" class="slds-input" value="{!v.NewAddress.ERP7__City__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Zip/Postal Code <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText aura:id="ncphn" class="slds-input" value="{!v.NewAddress.ERP7__Postal_Code__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="span-red">*</div>
                                            <div class="slds-form-element__control">
                                                <lightning:select name="controllerFld"
                         								 value="{!v.objDetail.ERP7__Country__c}"
                          								 onchange="{!c.onControllerFieldChange}" label="Country">
            									<aura:iteration items="{!v.listControllingValues}" var="val">
                										<option value="{!val}">{!val}</option>
            									</aura:iteration>
        										</lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            
                                            <div class="slds-form-element__control">
                                               <!-- <ui:inputSelect class="slds-select" aura:id="CountyList" value="{!v.County}"/>-->
                                                <lightning:select name="dependentFld"
                          							value="{!v.objDetail.ERP7__State__c}"
                          							disabled="{!v.bDisabledDependentFld}" label="State/County">
            									<aura:iteration items="{!v.listDependingValues}" var="val">
                									<option value="{!val}">{!val}</option>
            									</aura:iteration>
        									</lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--x-small">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Is Primary</label><br/>
                                            <div class="slds-form-element__control marleft20">
                                                <ui:inputcheckbox value="{!v.NewAddress.ERP7__Primary__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--x-small">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Is Billing Address</label><br/>
                                            <div class="slds-form-element__control marleft20">
                                                <ui:inputcheckbox value="{!v.NewAddress.ERP7__Is_Billing_Address__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--x-small">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Is Shipping Address</label><br/>
                                            <div class="slds-form-element__control marleft20">
                                                <ui:inputcheckbox value="{!v.NewAddress.ERP7__Is_Shipping_Address__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                           
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeAddressModal}">Cancel</button>
                             <ui:button class="slds-button slds-button--brand" press="{!c.CreateAddress}">Save</ui:button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalAdrBackdrop"></div>
            <!-- popup 6 address ends here -->
            <!-- Modal popup10 UPS -->
            <div id="myModalUPS" aura:id="myModalUPS" class="slds-modal" role="dialog" >
                <div class="modal-dialog modal-lg" >
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeUPSModal}"/>
                            </button>
                           
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">UPS Estimate
                                
                            </h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="upsError" value="{!v.UPSError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Type <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputSelect class="slds-select" aura:id="packType" value="{!v.UPS_Services.PackageType}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="nacusid" class="slds-input" value="{!v.UPS_Services.Weight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Length </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.Length}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Width </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.Width}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Height </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.Height}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Additional %</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="nacusid" class="slds-input" value="{!v.UPS_Services.Additional}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">No.of Package <span  class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naname" class="slds-input" value="{!v.UPS_Services.NoofPackage}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.PackageVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.SOVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Weight</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.SOWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Total Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.UPS_Services.TotalWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight/Pack </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="num" class="slds-input" value="{!v.UPS_Services.WeightPerPack}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Shipment Date <span  class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputDate aura:id="ShipmentDate" value="{!v.UPS_Services.ShipmentDate}" displayDatePicker="true" class="slds-input" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-10 col-sm-2 col-xs-12 epos-class73">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control" >
                                                <ui:outputText aura:id="naname" value="{!v.UPS_Services.UPSErrorMsg}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--x-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 epos-class74">
                                        <table class="slds-table slds-table--bordered" >
                                            <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9" >
                                                <th class="epos-class75">Select</th>
                                                <th class="epos-class76">Service Code</th>
                                                <th class="epos-class76">Service Type</th>
                                                <th class="epos-class76">Total</th>
                                                <th class="epos-class76">Currency</th>
                                                <th class="epos-class76">Delivery Date</th>
                                                <th class="epos-class76">Days To Deliver</th>
                                                <th class="epos-class76">Time To Deliver</th>
                                            </tr>
                                            <aura:iteration var="twl" indexVar="pcount" items="{!v.UPS_Services.Services}">
                                                <tr class="epos-class23">
                                                    <td class="epos-class77">
                                                        <div class="slds-truncate epos-class78">
                                                            <ui:inputRadio aura:id="r0" name="others" value="{!twl.Selected}"/>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class26" >
                                                            <ui:outputText value="{!twl.ServiceCode}" title="{!twl.ServiceCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79" >
                                                        <div class="slds-truncate epos-class91" >
                                                            <ui:outputText value="{!twl.ServiceManual}" title="{!twl.ServiceManual}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79" >
                                                        <aura:If isTrue="{!(twl.negotiatedCharges == '')}">
                                                            <div class="slds-truncate epos-class81" >
                                                                <ui:outputText value="{!twl.totalCharges}" title="{!twl.totalCharges}" />
                                                            </div>
                                                        </aura:If>
                                                        <aura:If isTrue="{!(twl.negotiatedCharges != '')}">
                                                            <div class="slds-truncate epos-class26" >
                                                                <ui:outputText value="{!twl.negotiatedCharges}" title="{!twl.negotiatedCharges}" />
                                                            </div>
                                                        </aura:If>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.currencyCode}" title="{!twl.currencyCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <aura:If isTrue="{!(twl.DeliveryDate != null)}">
                                                            <div class="slds-truncate epos-class81" >
                                                                <ui:outputDate value="{!twl.DeliveryDate}" format="dd/MM/yyyy"/>
                                                            </div>
                                                        </aura:If>
                                                        <aura:If isTrue="{!(twl.DeliveryDate == null)}">
                                                            <div class="slds-truncate epos-class81" >
                                                                <ui:outputText value="{!twl.DeliveryDateS}" title="{!twl.DeliveryDateS}" />
                                                            </div>
                                                        </aura:If>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class26" >
                                                            <ui:outputText value="{!twl.GuaranteedDaysToDelivery}" title="{!twl.GuaranteedDaysToDelivery}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class26" >
                                                            <ui:outputText value="{!twl.ScheduledDeliveryTime}" title="{!twl.ScheduledDeliveryTime}" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <ui:button class="slds-button slds-button--brand" press="{!c.Services}">Get Services</ui:button>
                            <aura:If isTrue="{!and(v.UPS_Services.Services != undefined, v.UPS_Services.Services.length > 0)}">
                                <ui:button class="slds-button slds-button--brand" press="{!c.saveEstimateToOrder}">Save</ui:button>
                            </aura:If>
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeUPSModal}">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalUPSBackdrop"></div>
            <!-- popup 10 UPS ends here -->
            <!-- Modal popup11 SO Shipment -->
            <div id="myModalSOShipment" aura:id="myModalSOShipment" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeShipmentModal}"/>
                            </button>
                           
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Shipment Details
                                
                            </h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="shipError" value="{!v.shipError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Total Quantity</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText class="slds-select" aura:id="TQ" value="{!v.SalesOrder.ERP7__Total_Quantity__c}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Picked Quantity</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText class="slds-select" aura:id="PQ" value="{!v.SalesOrder.ERP7__Picked_Quantity__c}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Packed Quantity</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText class="slds-select" aura:id="PCQ" value="{!v.SalesOrder.ERP7__Packed_Quantity__c}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Shipped Quantity</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText class="slds-select" aura:id="SQ" value="{!v.SalesOrder.ERP7__Shipped_Quantity__c}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Service</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputText class="slds-select" aura:id="service" value="{!v.SalesOrder.ERP7__UPS_Service__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--small">
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Est. Delivery Date </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputDate aura:id="soedd" class="slds-input inputd"
                                                              displayDatePicker="true"
                                                              value="{!v.SalesOrder.ERP7__Estimated_Delivery_Date__c }"
                                                              />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Tracking Number</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.SalesOrder.ERP7__Tracking_Number__c}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Estimated Cost</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.SalesOrder.ERP7__Estimated_Shipping_Amount__c }"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Tax</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.SalesOrder.ERP7__Shipping_VAT__c }" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Total</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="naaccno" class="slds-input" value="{!v.SalesOrder.ERP7__Total_Shipping_Amount__c }" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeShipmentModal}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.draftSaveShipment}">Save</ui:button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalSOShipmentBackdrop"></div>
            <!-- popup 11 SO Shipment ends here -->
            
            <!-- Modal popup12 FedEx -->
            <div id="myModalFedEx" aura:id="myModalFedEx" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-lg" >
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeFedExModal}"/>
                            </button>
                            
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">FedEx Estimate
                                
                            </h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="upsError" value="{!v.FedExError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Type <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputSelect class="slds-select" aura:id="packType1" value="{!v.FEDEX_Services.PackageType}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnacusid" class="slds-input" value="{!v.FEDEX_Services.Weight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Length </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.Length}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Width </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.Width}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Height </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.Height}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Additional %</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnacusid" class="slds-input" value="{!v.FEDEX_Services.Additional}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">No.of Package <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaname" class="slds-input" value="{!v.FEDEX_Services.NoofPackage}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.PackageVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.SOVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Weight</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.SOWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Total Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.FEDEX_Services.TotalWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight/Pack </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnum" class="slds-input" value="{!v.FEDEX_Services.WeightPerPack}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Shipment Date <span class="clr-red;">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputDate aura:id="FShipmentDate" value="{!v.FEDEX_Services.ShipmentDate}" displayDatePicker="true" class="slds-input"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-10 col-sm-2 col-xs-12 epos-class73">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control" >
                                                <ui:outputText aura:id="Fnaname" value="{!v.FEDEX_Services.UPSErrorMsg}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--x-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 epos-class74">
                                        <table class="slds-table slds-table--bordered" >
                                            <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9">
                                                <th class="epos-class75">Select</th>
                                                <th class="epos-class76">Service Type</th>
                                                <th class="epos-class76">Total</th>
                                                <th class="epos-class76">Currency</th>
                                            </tr>
                                            <aura:iteration var="twl" indexVar="pcount" items="{!v.FEDEX_Services.Services}">
                                                <tr class="epos-class23">
                                                    <td class="epos-class77">
                                                        <div class="slds-truncate epos-class78">
                                                            <ui:inputRadio aura:id="Fr0" name="others" value="{!twl.Selected}"/>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class80">
                                                            <ui:outputText value="{!twl.Service}" title="{!twl.Service}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.totalCharges}" title="{!twl.totalCharges}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.currencyCode}" title="{!twl.currencyCode}" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeFedExModal}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.FedExServices}">Get Services</ui:button>
                            <aura:If isTrue="{!(v.FEDEX_Services.Services.length > 0)}">
                                <ui:button class="slds-button slds-button--brand" press="{!c.saveFedExEstimateToOrder}">Save</ui:button>
                            </aura:If>
                            
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalFedExBackdrop"></div>
            <!-- popup 12 FedEx ends here --> 
            
            
            
            
            
            
            <!-- Modal popup DHL -->
            <div aura:id="myModalDHL" id="myModalDHL" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-lg" ><!--margin:6% auto;-->
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeDHLModal}"/>
                            </button>
                            
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">DHL Estimate
                                
                            </h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="upsError" value="{!v.DHLError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Type <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputSelect class="slds-select" aura:id="packType2" value="{!v.DHL_Services.PackageType}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnacusid" class="slds-input" value="{!v.DHL_Services.Weight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Length </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.Length}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Width </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.Width}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Height </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.Height}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Additional %</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnacusid" class="slds-input" value="{!v.DHL_Services.Additional}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">No.of Package <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaname" class="slds-input" value="{!v.DHL_Services.NoofPackage}" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Package Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.PackageVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Volume </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.SOVolume}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">SO Weight</label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.SOWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Total Weight </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnaaccno" class="slds-input" value="{!v.DHL_Services.TotalWeight}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Weight/Pack </label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputNumber aura:id="Fnum" class="slds-input" value="{!v.DHL_Services.WeightPerPack}" disabled="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-2 col-sm-2 col-xs-12">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="name">Shipment Date <span class="clr-red">*</span></label><br/>
                                            <div class="slds-form-element__control">
                                                <ui:inputDate aura:id="FShipmentDate" value="{!v.DHL_Services.ShipmentDate}" displayDatePicker="true" class="slds-input"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-10 col-sm-2 col-xs-12 epos-class73">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control" >
                                                <ui:outputText aura:id="Fnaname" value="{!v.DHL_Services.UPSErrorMsg}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--x-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 epos-class74">
                                        <table class="slds-table slds-table--bordered" >
                                            <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9">
                                                <th class="epos-class75">Select</th>
                                                <th class="epos-class76">Service Type</th>
                                                <th class="epos-class76">Total</th>
                                                <th class="epos-class76">Currency</th>
                                                <th class="epos-class76">Commitment Date</th>
                                            </tr>
                                            <aura:iteration var="twl" indexVar="pcount" items="{!v.DHL_Services.Services}">
                                                <tr class="epos-class23">
                                                    <td class="epos-class77">
                                                        <div class="slds-truncate epos-class78">
                                                            <ui:inputRadio aura:id="Fr0" name="others" value="{!twl.Selected}"/>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class80">
                                                            <ui:outputText value="{!twl.ServiceName}" title="{!twl.Service}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.totalCharges}" title="{!twl.totalCharges}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.currencyCode}" title="{!twl.currencyCode}" />
                                                        </div>
                                                    </td>
                                                    <td class="epos-class79">
                                                        <div class="slds-truncate epos-class81" >
                                                            <ui:outputText value="{!twl.CommitmentDate}" title="{!twl.CommitmentDate}" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                             <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeDHLModal}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.DHLServices}">Get Services</ui:button>
                            <aura:If isTrue="{!(v.DHL_Services.Services.length > 0)}">
                                <ui:button class="slds-button slds-button--brand" press="{!c.saveDHLEstimateToOrder}">Save</ui:button>
                            </aura:If>
                           
                        </div>
                    </div>
                </div>
            </div>
            <!-- popup DHL ends here -->
            
            
            
            <!-- Modal popup 13 Loyalty -->
            <div id="myModalLoyalty" aura:id="myModalLoyalty" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-md">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeMyModalLoyalty}"/>
                            </button>
                            
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Loyalty Payment
                                
                            </h2>
                        </div>
                        <div class="modal-body" >
                            <div class="container-fluid">
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12">
                                        <span class="epos-class20">
                                            <ui:outputText aura:id="paymentError" value="{!v.LoyaltyError}"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-6 col-sm-6 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Invoice Amount:</label>
                                                <ui:outputCurrency aura:id="pAmt"  class="outputTextOR" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01"> Total Due:</label>
                                                <ui:outputCurrency aura:id="fdue" class="outputTextOR" value="{!v.finalDue}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12 slds-m-top--xx-small">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control font-size1rem">
                                                <label class="slds-form-element__label" for="text-input-01">Available Points:</label>
                                                <ui:outputText aura:id="pAmt" 
                                                               class="outputTextOR"
                                                               value="{!v.customerCreditLimit}"
                                                               />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6 col-xs-12 slds-m-top--xx-small">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Loyalty Value:</label>
                                                <ui:outputText aura:id="pAmt" 
                                                               class="outputTextOR"
                                                               value="{!v.Points_Per_Unit_Amount}"
                                                               />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-12 col-sm-12 col-xs-12 ">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <label class="slds-form-element__label font-size1rem" for="text-input-01">Redeem Points<span class="clr-red">*</span> </label>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="pAmt" 
                                                                  class=""
                                                                  value="{!v.LoyaltyPoint2Use}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeMyModalLoyalty}">Cancel</button>
                            <ui:button class="slds-button slds-button--brand" press="{!c.ProcessLoyalty}">Pay Now</ui:button>
                            
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalLoyaltyBackdrop"></div>
            <!-- popup 13 Loyalty ends here -->
            <!-- popup 15 Start here -->
            <!-- Modal Comment Edit Line Items -->
            <div id="myModalSerial" aura:id="myModalcurrentBatchSerial" class="slds-modal" role="dialog">
                <div class="modal-dialog modal-lg width80">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeCurrentBatchSerial}"/>
                            </button>
                            
                            <div class="row">
                                <div class="col-md-12">
                                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignleft">
                                        
                                        <aura:If isTrue="{!(v.SelectedProduct.product.ERP7__Is_Asset__c == true)}">
                                            
                                            <strong>Start Time :</strong> &nbsp;<ui:outputDateTime aura:id="paymethod" class="" value="{!v.SelectedProduct.lineitm.ERP7__Start_Time__c}" format="dd/MM/yyyy HH:mm"/>
                                            &nbsp;&nbsp;&nbsp;
                                            <strong>End Time :</strong> &nbsp;<ui:outputDateTime aura:id="paymethod" class="" value="{!v.SelectedProduct.lineitm.ERP7__End_Time__c}" format="dd/MM/yyyy HH:mm"/> 
                                            
                                        </aura:If>
                                    </h2> 
                                </div>
                                
                            </div>   
                            
                        </div>
                        <div class="modal-body epos-class82">
                            <table class="slds-table slds-no-row-hover slds-table_cell-buffer">
                                <aura:If isTrue="{!(v.mySerialNos.length > 0)}">
                                    <thead>
                                        <tr class="epos-class83">
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Serial Number ">Serial Number</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Name">Product</div>
                                            </th>
                                            <!--
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Fixed Asset">Fixed Asset</div>
                                            </th>
											-->
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Date of Manufacture">Date of Manufacture</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Availability date">Availability date</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Shelf Life Expiration Date">Shelf Life Exp. Date</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Vendor Serial Number">Vendor SLN</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="epos-class83">
                                        <aura:iteration var="Serial" indexVar="serialCounts" items="{!v.mySerialNos}">
                                            
                                            <tr>
                                                <td data-label="Serial Number">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Serial_Number__c}">
                                                        <a href="{!'/'+ Serial.Id}" target="_blank" class="Name">
                                                            <ui:outputText value="{!Serial.ERP7__Serial_Number__c}"/>
                                                        </a>
                                                    </div>
                                                </td>
                                                <td scope="row" data-label="Name">
                                                    <div class="slds-truncate2" title="{!Serial.Name}">
                                                        <a href="{!'/'+ Serial.ERP7__Product__c}" target="_blank" class="Name">
                                                            <ui:outputText value="{!Serial.ERP7__Product__r.Name}"/>
                                                        </a>
                                                    </div>
                                                </td>
                                                <!--
                                                <td data-label="Fixed Asset">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Asset__r.Name}">
                                                        <a href="{!'/'+ Serial.ERP7__Asset__c}" target="_blank" class="Name">
                                                            <ui:outputText value="{!Serial.ERP7__Asset__r.Name}"/>
                                                        </a>
                                                    </div>
                                                </td>
												-->
                                                <td data-label="Date of Manufacture">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Date_of_Manufacture__c}">
                                                        <ui:outputDate value="{!Serial.ERP7__Date_of_Manufacture__c}"/>
                                                    </div>
                                                </td>
                                                <td data-label="Availability date">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Availability_date__c}">
                                                        <ui:outputDate value="{!Serial.ERP7__Availability_date__c}"/>
                                                    </div>
                                                </td>
                                                <td data-label="Shelf Life Exp. Date">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Shelf_Life_Expiration_Date__c}">
                                                        <ui:outputDate value="{!Serial.ERP7__Shelf_Life_Expiration_Date__c}"/>
                                                    </div>
                                                </td>
                                                <td data-label="Vendor SLN">
                                                    <div class="slds-truncate2" title="{!Serial.ERP7__Vendor_Serial_Number__c}">
                                                        <ui:outputText value="{!Serial.ERP7__Vendor_Serial_Number__c}"/>
                                                    </div>
                                                </td>
                                            </tr>
                                            
                                        </aura:iteration>
                                    </tbody>
                                </aura:If>
                                
                                <aura:If isTrue="{!(v.myBatchNos.length > 0)}">
                                    <thead >
                                        <tr class="slds-text-heading--label epos-class83">
                                            <th width="25%" scope="col">
                                                <div class="slds-truncate2" title="Batch Number">Batch.No</div>
                                            </th>
                                            <th width="40%" scope="col">
                                                <div class="slds-truncate2" title="Product">Product</div>
                                            </th>
                                            
                                            <th width="25%" scope="col">
                                                <div class="slds-truncate2" title="Availability">Availability</div>
                                            </th> 
                                            
                                        </tr>
                                    </thead>
                                    <aura:iteration var="SLN" indexVar="counts" items="{!v.myBatchNos}">
                                        <tbody>
                                            <tr class="slds-hint-parent epos-class83">
                                                <td>
                                                    <div class="slds-truncate epos-class34" title="SLN"  id="{!SLN.Id}">
                                                        <ui:outputText value="{!SLN.Name}" click="{!c.NavRecord}" title="{!SLN.Id}"/>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-truncate epos-class34" title="Product" id="{!SLN.ERP7__Product__c}">
                                                        <ui:outputText value="{!SLN.ERP7__Product__r.Name}" click="{!c.NavRecord}" title="{!SLN.ERP7__Product__c}"/>
                                                        <aura:If isTrue="{!(SLN.ERP7__Product__r.ERP7__Picture__c != undefined)}">
                                                            &nbsp;&nbsp;<img src="{!SLN.ERP7__Product__r.ERP7__Picture__c}" class="epos-class45" />
                                                        </aura:If>    
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-truncate" title="Availability">
                                                        <ui:outputText value="{!SLN.ERP7__Available_Quantity__c}" />    
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </aura:iteration>
                                </aura:If>
                            </table>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeCurrentBatchSerial}">Cancel</button>
                        </div>
                    </div>
                </div>
                
            </div>
            <div class="slds-backdrop" aura:id="myModalcurrentBatchSerialBackdrop"></div>
            <!-- popup15 ends here -->
            
            <!-- Modal Comment Edit Line Items -->
            <div id="myModalCancelled" aura:id="myModalCancelled" class="slds-modal" role="dialog">
                <div class="modal-dialog margin200auto">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header" >
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.cancelReasonDone}"/>
                            </button>
                           
                            <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Cancellation Reason</h2>
                        </div>
                        <div class="modal-body">
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <ui:inputTextArea aura:id="pdes" 
                                                      class="slds-textarea"
                                                      rows="4" cols="20"
                                                      value="{!v.SalesOrder.ERP7__Cancelled_Reason__c}"
                                                      />
                                </div>
                            </div>
                            
                            <div class="slds">
                                <div class="row slds-m-top--medium epos-class69">
                                    <div class="col-md-12 slds-m-bottom--small talignCentre">
                                        <lightning:button onclick="{!c.cancelReasonDone}" class="slds-button" label="Done" variant="brand"/>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop" aura:id="myModalCancelledBackdrop"></div>
            <!-- popup3 ends here -->
        </div>
        <!--Delete Modal Starts Here-->
        
        <div role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-hide slds-modal slds-fade-in-open epos-class84" aura:id="deleteModal">
            <div class="slds-modal__container epos-class85">
                <div class="slds-modal__content slds-p-around_medium">
                    <p class="talignCenter">
                        Delete Sales Order Line Item ?</p>
                </div>
                <div class="slds-modal__footer talignCenter">
                    <button class="slds-button slds-button--neutral" onclick="{!c.hideDeletePopup}">No</button>
                    <button class="slds-button slds-button--brand" onclick="{!c.DeleteRecordById}">Yes</button>
                </div>
            </div>
        </div>
        <div class="slds-backdrop "></div>
        
        <!--Delete Modal Ends Here-->
        
    <!--======================Configuration Modal start=============================-->
    <div id="configModal" aura:Id="configModal1" class="slds-modal" role="dialog">        
        <div class="slds-modal__container epos-class86">            
            <div class="slds-modal__content epos-class87">
                <div class="positon-fixed-maq"><Strong>Configuration - {!v.proName}</Strong></div><br/>
                <aura:if isTrue="{!v.proOptions.length >0}">
                    <aura:iteration items="{!v.proOptions}" var="pro">
                        <article class="slds-card maq-card margTop20">
                            <div class="slds-card__header slds-grid header-maq">
                                <header class="slds-media slds-media_center slds-has-flexi-truncate">                            
                                    <div class="slds-media__body">
                                        <h1 class="slds-card__header-title  epos-class88">   
                                            <aura:if isTrue="{!pro.feature.Name != undefined}">
                                                <strong >{!pro.feature.Name}</strong>
                                            </aura:if>
                                        </h1>
                                    </div>
                                    <div class="slds-no-flex">                                
                                    </div>
                                </header>
                            </div>
                            <div class="slds-card__body">
                                <table class="slds-table slds-table_cell-buffer slds-no-row-hover slds-table_bordered slds-table_fixed-layout" role="grid">
                                    <thead>
                                        <tr class="slds-line-height_reset">
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">                                            
                                                </div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">Product Name</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">Product Code</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">Stock</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">Price</div>
                                            </th>
                                            <th class="" scope="col">
                                                <div class="slds-truncate" title="">Quantity</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:if isTrue="{!pro.featOpt.length > 0}">
                                            <aura:iteration items="{!pro.featOpt}" var="fo">
                                                <tr class="slds-hint-parent">                                     
                                                    <td>
                                                        <div class="slds-form-element__control" title="{!fo.Id}"><!-- title="Hello"-->
                                                            <label class="slds-checkbox">
                                                                <input type="checkbox" id="{!fo.Id}" onchange="{!c.handleChange}" data-value="{!fo.Id}" data-feature="{!pro.feature.Id}" checked="false"/>
                                                                <span class="slds-checkbox--faux"></span>
                                                                <span class="slds-form-element__label text"></span>
                                                            </label>
                                                        </div>
                                                    </td>
                                                    <th>
                                                        <div class="slds-truncate slds-grid" title="">
                                                            <aura:if isTrue="{!and(or(pro.feature.Name == 'Color',pro.feature.Name == 'Colors',pro.feature.Name == 'Colour',pro.feature.Name == 'Colours',pro.feature.Name == 'color',pro.feature.Name == 'colors'),fo.ERP7__Optional_SKU__r.ERP7__Picture__c != undefined)}">
                                                                <aura:if isTrue="{!(fo.ERP7__Optional_SKU__r.ERP7__Picture__c != undefined)}">
                                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12">
                                                                        <img src="{!fo.ERP7__Optional_SKU__r.ERP7__Picture__c}" class="epos-class89" />
                                                                    </div>
                                                                </aura:if>
                                                                <aura:set attribute="else">
                                                                    <a onclick="{!c.detailPage}" data-proId="{!fo.ERP7__Optional_SKU__r.Id}">{!fo.ERP7__Optional_SKU__r.Name}</a>
                                                                    <aura:if isTrue="{!(fo.ERP7__Optional_SKU__r.ERP7__Picture__c != undefined)}">
                                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12">
                                                                            <img src="{!fo.ERP7__Optional_SKU__r.ERP7__Picture__c}" class="epos-class89"  />
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:set>                                                            
                                                            </aura:if>                                                            
                                                        </div>
                                                    </th>
                                                    <td>
                                                        <div class="slds-truncate" title="">{!fo.ERP7__Optional_SKU__r.ProductCode}</div>
                                                    </td>  
                                                    <td>
                                                        <aura:iteration items="{!v.totalStock}" var="stock">                                                                
                                                            <aura:if isTrue="{! (stock.ProId == fo.ERP7__Optional_SKU__c)}">
                                                                <aura:if isTrue="{!stock.stockAvlb == 0}">
                                                                    <aura:if isTrue="{!fo.ERP7__Optional_SKU__r.ERP7__Allow_Back_Orders__c}">
                                                                        <ui:outputText value="Back Order"/>
                                                                        <aura:set attribute="else">
                                                                            <ui:outputText value="{!stock.stockAvlb}"/>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                    <aura:set attribute="else">
                                                                        <ui:outputText value="{!stock.stockAvlb}"/>
                                                                    </aura:set>
                                                                </aura:if>                                                         
                                                            </aura:if>                                                            
                                                        </aura:iteration>                                                         
                                                    </td>  
                                                    <td>
                                                        <aura:iteration items="{!pro.pbe}" var="pri">
                                                            <aura:if isTrue="{!(pri.Product2Id ==fo.ERP7__Optional_SKU__c)}">
                                                                <div class="slds-truncate" title="">
                                                                    <ui:inputCurrency value="{!pri.UnitPrice}"/>
                                                                </div>
                                                            </aura:if>
                                                        </aura:iteration>
                                                    </td>
                                                    <!--<td>{!fo.ERP7__Optional_SKU__r.Id}
                                                        <lightning:input type="number" value="1" id="{!fo.ERP7__Optional_SKU__r.Id}"/>
                                                    </td>-->
                                                    <td>
                                                       	<div class="slds-truncate" title=""><input value="1" type="number" class="slds-input width100p" name="{!fo.ERP7__Optional_SKU__r.Id}" id="{!fo.ERP7__Optional_SKU__r.Id}" min="1"/></div><!---->
                                                    </td>
                                                </tr>
                                            </aura:iteration>                             
                                        </aura:if>                                    
                                    </tbody>
                                </table>
                            </div>                        
                        </article>
                    </aura:iteration>
                    <aura:set attribute="else">
                        <div class="epos-class90">
                            <ui:message severity="warning" closable="false">
                                Configuration Not Available
                            </ui:message>
                        </div>
                    </aura:set>   
                </aura:if>
            </div>
            <div class="slds-modal__footer talignCentre">
                <lightning:button aura:id="addConfiguration" onclick="{!c.confirmConfiguration}" variant="brand">Confirm Configuration</lightning:button>
                <a href="javascript:void(0);" onclick="{!c.closeConfigureModal}" class="slds-button slds-button--neutral">Cancel</a>               
            </div>
        </div>
        <!-- Modal content-->
    </div>
    <div class="slds-backdrop" aura:id="configModalBackdrop"></div>
    <!-- ===================Configuration modal ends=============================== --> 
        
    </div>
</aura:component>