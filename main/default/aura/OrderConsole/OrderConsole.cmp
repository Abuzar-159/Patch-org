                                                                    <ui:outputNumber value="{!pro.stock}"/>
                                                                </div>
                                                            </td>
                                                        </aura:If>
                                                        
                                                    </tr>
                                                </tbody>
                                            </table>
                                            
                                            <!--Ends Here -->
                                            <aura:If isTrue="{!(v.SerialPopup)}">
