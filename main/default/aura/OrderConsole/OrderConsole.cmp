                                    <!--<ui:button aura:id="editUpdate" class="slds-button slds-button-\-brand" press="{!c.updateItem}">Update</ui:button>
                                    <button type="button" class="slds-button slds-button-\-neutral" onclick="{!c.closeEditProduct}">Close</button>-->
                                    <lightning:button aura:id="editUpdate" onclick="{!c.updateItem}" class="slds-button" label="Update" variant="brand"/>
                                    <lightning:button  label="Cancel" onclick="{!c.closeEditProduct}" variant="neutral"/>
