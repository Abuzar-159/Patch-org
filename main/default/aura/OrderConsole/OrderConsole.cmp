                                                                                            <ui:button aura:id="addButton" class="neutralC" press="{!c.assignBatchEdit}" labelClass="{!counts}">
                                                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_plus.png" class="epos-class19"/>
                                                                                            </ui:button>
                                                                                        </aura:If>
                                                                                        <aura:If isTrue="{!pro.allBatchesStock >= pro.quantity_s}">
                                                                                            <ui:button aura:id="addButton" class="neutralC" labelClass="{!counts}">
                                                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_plusgrey.png" class="epos-class19"/>
                                                                                            </ui:button>
                                                                                        </aura:If>
