                                                                </div>
                                                            </header>
                                                            
                                                            <div class="maquiScroller epos-class68"  >                                                                
                                                                <table class="slds-table slds-table--bordered slds-no-row-hover slds-table--cell-buffer">
                                                                    <thead >
                                                                        <tr class="slds-text-heading--label">
                                                                            <th scope="col">
                                                                                <div class="slds-truncate" title="Action">&nbsp;</div>
                                                                            </th>
                                                                            <th scope="col">
                                                                                <div class="slds-truncate" title="Batch Number">Batch.No</div>
                                                                            </th>
                                                                            <th scope="col">
                                                                                <div class="slds-truncate" title="Product">Product</div>
                                                                            </th>
                                                                            
                                                                            <th scope="col">
                                                                                <div class="slds-truncate" title="Availability">Availability</div>
                                                                            </th> 
                                                                        </tr>
                                                                    </thead>
                                                                    <aura:iteration var="SLN" indexVar="counts" items="{!v.pdLists}">
                                                                        <tbody>
