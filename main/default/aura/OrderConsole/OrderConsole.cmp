<aura:component Controller="ERP7.POSLightning" implements="flexipage:availableForAllPageTypes,force:appHostable,forceCommunity:availableForAllPageTypes" access="global">
    
    <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css', $Resource.PickPackShipResource + '/assets/styles/main-scrollers.css')}"  />
    <ltng:require styles="{!join(',',$Resource.Order_Console + '/assets/styles/custom1.css', $Resource.Order_Console + '/assets/styles/font-awesome.css')}"  />
    <ltng:require styles="{!join(',',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/OrderConsole.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/> 

    <aura:attribute name="Customer" type="Object" default="{sobjectType : 'Account','ERP7__VAT__c':'','Id':'','Name':''}" />
    <aura:attribute name="CustomerTemp" type="Object" default="{sobjectType : 'Account','ERP7__VAT__c':''}" />
    <aura:attribute name="Custo" type="Account" default="{sobjectType : 'Account','ERP7__VAT__c':''}" />
    <aura:attribute name="Contact" type="Contact" default="{sobjectType  : 'Contact'}" />
    <aura:attribute name="SalesOrder" type="Object" />
    <aura:attribute name="Invoiced" type="Invoice__c" default="{sobjectType : 'Invoice__c','ERP7__Account__c':''}" />
     
    <aura:attribute name="SOLI" type="Object" />  
    <aura:attribute name="activeSections" type="List" default="['A']" />
    <aura:attribute name="activeSectionsMessage" type="String" default="" />
    <aura:attribute name="AccProfile1" type="Object" />  
    <aura:attribute name="AccProfile2" type="Object" />
    <aura:attribute name="NewCust" type="Object" />
    <aura:attribute name="NewCon" type="Object" />
    <aura:attribute name="AccTax1" type="Object" />
    <aura:attribute name="AccTax2" type="Object" />
    <aura:attribute name="Payment" type="Object" />
    <aura:attribute name="PaymentMethod" type="Object" />
    <aura:attribute name="UPS_Services" type="Object" />
    <aura:attribute name="FEDEX_Services" type="Object" /> 
    <aura:attribute name="DHL_Services" type="Object" />
    <aura:attribute name="lineItemTOdelete" type="Integer"/>
    <aura:attribute name="CountHolder" type="Integer"/>
    <aura:attribute name="CVV" type="String" />
    <aura:attribute name="qry" type="String" />
    <aura:attribute name="payType" type="String" />
    <aura:attribute name="qry2" type="String" />
    <aura:attribute name="CardError" type="String"/>
    <aura:attribute name="CashError" type="String"/>
    <aura:attribute name="BankError" type="String"/>
    <aura:attribute name="UPSError" type="String"/>
    <aura:attribute name="NewAccountError" type="String"/>
    <aura:attribute name="NewContactError" type="String"/>
    <aura:attribute name="NewAddressError" type="String"/>
    <aura:attribute name="FedExError" type="String"/>
    <aura:attribute name="DHLError" type="String"/>
    <aura:attribute name="shipError" type="String"/>
    <aura:attribute name="Coupon" type="String"/>
    <aura:attribute name="accType" type="String"/>
    <aura:attribute name="Points_Per_Unit_Amount" type="Decimal" default="0.000"/>
    <aura:attribute name="LoyaltyError" type="String"/>
    <aura:attribute name="CreditError" type="String"/>
    <aura:attribute name="LoyaltyPoint2Use" type="Integer"/>
    <aura:attribute name="productLimit" type="Integer" default="200"/>
    <aura:attribute name="CreditAmount2Use" type="Integer"/>
    <aura:attribute name="TaxRate" type="Decimal" default="0.000"/>
    <aura:attribute name="accTaxRate" type="Decimal" default="0.000"/>
    <aura:attribute name="custInvoiceTest" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}"/>
    <aura:attribute name="addAddress" type="Address__c" default="{sobjectType:'Address__c','ERP7__Contact__c': ''}"/>
    <aura:attribute name="NewCustomer" type="Account" default="{sobjectType : 'Account','unknown_custom_field':'','ERP7__VAT__c':''}" />
    <aura:attribute name="NewContact" type="Contact" default="{sobjectType:'Contact','LastName' : '','AccountId': ''}" />
    <aura:attribute name="NewAddress" type="Address__c" default="{sobjectType:'Address__c','ERP7__Customer__c': '','ERP7__Contact__c': ''}"/>
    <aura:attribute name="BillAddress" type="Address__c" default="{sobjectType:'Address__c','ERP7__Customer__c': '','ERP7__Contact__c': ''}"/>
    <aura:attribute name="com" type="Commission__c" default="{sobjectType : 'Commission__c'}"/>
    <aura:attribute name="currentSalepoint" type="Channel__c" default="{sobjectType : 'Channel__c'}" />
    <aura:attribute name="currentEmployee" type="Employees__c" default="{sobjectType : 'Employees__c','Name': ''}" />
    <aura:attribute name="Invoice" type="Invoice__c" default="{sobjectType : 'Invoice__c','ERP7__Account__c':''}" />
    <aura:attribute name="pageSubscription" type="Subscription__c" default="{sobjectType : 'Subscription__c'}" />
    <aura:attribute name="fieldError" type="String" default=""/>
    <aura:attribute name="SON" type="String"/>
    <aura:attribute name="SOP" type="String"/>
    <aura:attribute name="bAdd" type="String"/>
    <aura:attribute name="sAdd" type="String"/>
    <aura:attribute name="lockProfile" type="Boolean" default="false"/>
    <aura:attribute name="isClosed" type="Boolean" default="false"/>
    <aura:attribute name="orderStatus" type="String"/>
    <aura:attribute name="Country" type="String"/>
    <aura:attribute name="County" type="String"/>
    <aura:attribute name="itemName" type="String" default=""/>
    <aura:attribute name="orgId" type="String" default=""/>
    <aura:attribute name="exceptionError" type="String"/>
    <aura:attribute name="subTotal" type="Decimal" default="0"/>
    <aura:attribute name="discounts" type="Decimal" default="0"/>
    <aura:attribute name="taxes" type="Decimal" default="0.000"/>
    <aura:attribute name="totalDue" type="Decimal" default="0"/>
    <aura:attribute name="amountPaid" type="Decimal" default="0"/>
    <aura:attribute name="loyaltyPoints" type="Decimal" default="0"/>
    <aura:attribute name="loyaltyAmount" type="Decimal" default="0"/>
    <aura:attribute name="shippingAmount" type="Decimal" default="0"/>
    <aura:attribute name="finalDue" type="Decimal" default="0"/>
    <aura:attribute name="itemWrapperListt" type="object[]"/>
    <aura:attribute name="Payments" type="object[]"/>
    <aura:attribute name="CreditNotes" type="object[]"/>
    <aura:attribute name="Shipments" type="object[]"/>
    <aura:attribute name="ProductsAndDiscountsWrapperListt" type="object[]"/>
    <aura:attribute name="pdLists" type="object[]"/>
    <aura:attribute name="Serials2Delete" type="String[]"/>
    <aura:attribute name="SerialCount" type="Integer"/>
    <aura:attribute name="SelectedProduct" type="object" default=""/>
    <aura:attribute name="mySerialNos" type="object[]"/>
    <aura:attribute name="myBatchNos" type="object[]"/>
    <aura:attribute name="ProductsAndDiscountsWrapperListtEdit" type="object[]"/>
    <aura:attribute name="prod_Family_Type" type="Product2" default="{sobjectType : 'Product2'}"/>
    <aura:attribute name="prodFam" type="String"/>
    <aura:attribute name="prodCat" type="String"/>
    <aura:attribute name="prodSubCat" type="String"/>
    <aura:attribute name="prodDescription" type="String"/>
    <aura:attribute name="paymentGatewayList" type="List" default="[]"/>
    <aura:attribute name="invoiceName" type="String"/>
    <aura:attribute name="CUST" type="String"/>
    <aura:attribute name="CON" type="String"/>
    <aura:attribute name="preCon" type="String"/>
    <aura:attribute name="proceed" type="Boolean" default="false"/>
    <aura:attribute name="popup1Spinner" type="Boolean" default="true"/>
    <aura:attribute name="popup2Spinner" type="Boolean"/>
    <aura:attribute name="serialShow" type="Boolean" default="false"/>
    <aura:attribute name="lineItem2delete" type="String[]"/>
    <aura:attribute name="customerCreditLimit" type="String"/>
    <aura:attribute name="editCount" type="Integer"/>
    <aura:attribute name="RecentlyViewedList" type="object[]"/>
    <aura:attribute name="RentalUnit" type="object[]"/>
    <aura:attribute name="IsRental" type="Boolean" default="false"/>
    <aura:attribute name="showAvailable" type="Boolean" default="true"/>
    <aura:attribute name="isMultiCurrency" type="Boolean" default="false"/>
    <aura:attribute name="orderCurrency" type="String"/>
    <aura:attribute name="ABool" type="Boolean" default="false"/>
    <aura:attribute name="CBool" type="Boolean" default="false"/>
    <aura:attribute name="SBool" type="Boolean" default="false"/>
    <aura:attribute name="isSO_Authorised" type="Boolean" default="false"/>
    <aura:attribute name="SerialNumber" type="String"/>
    <aura:attribute name="BatchNumber" type="String"/>
    <aura:attribute name="SerialPopup" type="Boolean" default="false"/>
    <aura:attribute name="BatchPopup" type="Boolean" default="false"/>
    <aura:attribute name="projId" type="String" default=""/>
    <aura:attribute name="showTabs" type="String" default="cus"/>				
	<aura:attribute name="FromAR" type="Boolean" default="false"/>
    <aura:attribute name="Organisation" type="Map" default="{}"/> 
    <!--aura:attribute name="cancelclick" type="Aura.Action" default="{!c.goBack}"/-->
    <!--This is implemented for multiple invoice payment for the same Sales Order-->
    <!--<aura:attribute name="invList" type="List" default="[]"/>	
    <aura:attribute name="selInvList" type="List" default="[]"/>
    <aura:attribute name="allInvoices" type="Object"/>-->
    
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <!--<aura:method name="resetPage" action="{!c.getAllDetailsInit}"></aura:method>-->
    <aura:method name="saveMethod" action="{!c.draftSave}"></aura:method>
    <aura:method name="fetchProductNew" action="{!c.fetchProduct}"></aura:method>
    <aura:handler name="change" value="{!v.Customer.Id}" action="{!c.lookupChangeAccount}"/>
    <aura:handler name="change" value="{!v.Contact.Id}" action="{!c.lookupChangeContact}"/>
    <aura:handler name="change" value="{!v.SalesOrder.Id}" action="{!c.lookupChangeOrder}"/>
    <aura:handler event="force:refreshView" action="{!c.getAllDetails}" />
    <aura:attribute name="num" type="integer" default="100000"/>
    <aura:attribute name="crudValues" type="Map" default="{}" />
    <aura:attribute name="Mtask" type="Actions_Tasks__c"/>
    <aura:attribute name="projectId" type="String"/>
    <aura:attribute name = "currentMilestones" type = "object"/>
    <aura:attribute name = "currentProject" type = "Project__c"/>
    <aura:attribute name = "salesOrderTab" type = "Boolean" default="true"/>
    <aura:attribute name = "paymentTab" type = "Boolean" default="false"/>
    <aura:attribute name = "discountTab" type = "Boolean" default="false"/>
    <aura:attribute name = "deliveryTab" type = "Boolean" default="false"/>
    <aura:attribute name = "chatterTab" type = "Boolean" default="false"/>
    <aura:attribute name = "accountTab" type = "Boolean" default="false"/>
    <aura:attribute name="eposFLSCheck" type="object" default="{'sObjectType' : 'eposFlsWrap'}"/>
     <aura:attribute name="listControllingValues" type="list" default="[]" description="to store controller field values"/>
    <aura:attribute name="listDependingValues" type="list" default="['--- None ---']" description="to store dependent field values"/>
    <aura:attribute name="depnedentFieldMap" type="map" description="map to store dependent values with controlling value"/>
    <aura:attribute name="bDisabledDependentFld" type="boolean" default="true"/> 
    
    <aura:attribute name="objDetail" type="Address__c" default="{'sobjectType' : 'Address__c'}"/>
    <aura:attribute name="controllingFieldAPI" type="string" default="ERP7__Country__c" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI" type="string" default="ERP7__State__c" description="store field API name of dependent field"/>
    
    <!--========Product Configuration==========-->
    <aura:attribute name="proforConfig" type="String"/>
    <aura:attribute name="proName" type="String"/>
    <aura:attribute name="proOptions" type="Object"/>
    <aura:attribute name="optionRules" type="Object"/>
    <aura:attribute name="totalStock" type="Object"/>
    <aura:attribute name="proMap" type="Map" default="{}"/>
    <aura:attribute name="proFeatureMap" type="Map" default="{}"/>
    <aura:attribute name="selConfiguration" type="String[]"/>
    <aura:attribute name="resVersion" type="String"/>
    <aura:attribute name="fromProject" type="Boolean" default="false"/>
    <aura:attribute name = "currentProj" type = "Project__c" default="{'sObjectType':'ERP7__Project__c',
                                                                            'Name': '',
                                                                            'ERP7__Status__c': '--none--',
                                                                            'ERP7__Project_Manager__c': '',
                                                                            'ERP7__Organisations__c' : '',
                                                                            'ERP7__Default_Routing__c' : '',
                                                                            'ERP7__Team__c' : '',
                                                                            'ERP7__Account__c' : '',
                                                                            'ERP7__Contact__c' : '',
                                                                            'ERP7__Total_Expense_Amount__c' : '',
                                                                            'ERP7__Total_Income__c' : ''
                                                                            }"/>
    <!--========Product Configuration==========-->
    
    <div class="erp_mark7 epos-newClass1" aura:id="body">
        <span class="curPointer">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
        <div class="epr_Mark7 bg-white">
            <div class="container-fluid">
                <div class="row bgwhiteerp">
                    <!--Error Message-->
                    <div class="slds-notify_container slds-is-absolute">
                       <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'topdisplay','todiplay-none')}">
                        <div class="slds-notify slds-notify_toast slds-theme_error minWidth20" role="status">
                            <span class="slds-assistive-text">error</span>
                            <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                                <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="error" title="error" />
                            </span>
                            <div class="slds-notify__content">
                                <h2 class="slds-text-heading_x-small fsize13" >{!v.exceptionError} 
                                </h2>
                            </div>
                            <div class="slds-notify__close top25" >
                                <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="close" title="close" />
                                    <span class="slds-assistive-text">Close</span>
                                </button>
                            </div>
                        </div>
                        </div>
                    </div>
                    <!--Error Message End-->
                    <div class="col-sm-5 col-md-5 pad-leftRight0" >
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name"><span class="clr-required">*</span> Account Name</label>
                                <div class="slds-form-element" onmouseover="{!c.doneRendering}">
                                    <div class="slds-form-element__control lookupik" onclick="{!c.ABool}"><!-- onclick="{!c.lookupClickAccount}" -->
                                        <c:CustomInputLookUp objectAPIName="Account" aura:id="OrgName" IconName="standard:account" selectedRecordId="{!v.Customer.Id}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Account Number</label>
                                <div class="slds-form-element" onmouseover="{!c.doneRendering}">
                                    
                                    <div class="slds-form-element__control" onclick="{!c.ABool}">
                                        <aura:If isTrue="{!(v.Customer.AccountNumber != undefined)}">
                                            <c:CustomInputLookUp objectAPIName="Account" aura:id="cc" selectedRecord="{!v.Customer}" qry="{!'AND ERP7__Account_Type__c =\'Customer\''}" SearchField="AccountNumber"/>
                                        </aura:If>
                                        <aura:If isTrue="{!(v.Customer.AccountNumber == undefined)}">
                                            <ui:inputText aura:id="Accnum" 
                                                          class="slds-input" 
                                                          value="{!v.Customer.AccountNumber}"
                                                          />
                                        </aura:If>
                                    </div>
                                    
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Title</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <ui:inputText aura:id="titl" 
                                                      class="slds-input"
                                                      value="{!v.Contact.Title}"
                                                      />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name"><span class="clr-required">*</span> Contact Name</label>
                                <div class="slds-form-element" onmouseover="{!c.doneRendering}">
                                    <div class="slds-form-element__control" onclick="{!c.CBool}" onmouseover="{!c.lookupClickContact}"><!-- onclick="{!c.lookupClickContact}" -->
                                        <c:CustomInputLookUp objectAPIName="Contact" aura:id="conN" IconName="standard:contact" selectedRecord="{!v.Contact}" qry="{!v.qry}"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Contact Email</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <ui:inputText aura:id="conE" 
                                                      class="slds-input"
                                                      value="{!v.Contact.Email}"
                                                      />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="slds-form-element__label" for="name">Contact Phone</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <ui:inputText aura:id="num" 
                                                      class="slds-input" 
                                                      value="{!v.Contact.Phone}"
                                                      />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row slds-p-around--x-small">
                            <div class="col-md-6">
                                <label class="slds-form-element__label" for="name"><span class="clr-required">*</span> Bill to</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <ui:inputSelect class="slds-select" aura:id="bAdd" value="{!v.bAdd}" change="{!c.onSelectBA}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control padng5">
                                        <ui:inputTextArea aura:id="ba" disabled="true"
                                                          class="slds-textarea" 
                                                          rows="4" cols="20"
                                                          value="{!v.pageSubscription.ERP7__Bill_To_Address__c}"
                                                          />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="slds-form-element__label" for="name"><span class="clr-required">*</span> Ship to</label>
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <ui:inputSelect class="slds-select" aura:id="sAdd" value="{!v.sAdd}" change="{!c.onSelectSA}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element padng5">
                                    <div class="slds-form-element__control">
                                        <ui:inputTextArea aura:id="sa" disabled="true"
                                                          class="slds-textarea" 
                                                          rows="4" cols="20"
                                                          value="{!v.pageSubscription.ERP7__Ship_To_Address__c}"
                                                          />
                                    </div>
                                </div>
                            </div>
                            <table>
                                <tr class="dispNone">
                                    <td>
                                        <input></input> 
                                    </td>
                                    <td>
                                        <input></input> 
                                    </td>
                                </tr>
                            </table>
                            
                        </div>
                    </div>
                    
                    <div class="col-sm-7 col-md-7 padngright0" >
                        <!--<ul class="nav nav-tabs " role="tablist" onclick="{!c.doneRendering}">
                            <li class="nav-item active"> <a class="nav-link" data-toggle="tab" onclick="{!c.tab1}" role="tab"><i class="fa fa-file-text-o" aria-hidden="true"></i> Sales Order</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" onclick="{!c.tab2}" role="tab"><i class="fa fa-qrcode fa-1x"></i> Payment</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" onclick="{!c.tab3}" role="tab"><i class="fa fa-truck fa-1x"></i> Delivery</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" onclick="{!c.tab4}" role="tab"><i class="fa fa-users fa-1x"></i> Chatter</a> </li>
                            <li class="nav-item"> <a class="nav-link" data-toggle="tab" onclick="{!c.tab5}" role="tab"><i class="fa fa-user fa-1x"></i> Account</a> </li>
                        </ul>-->
                        <ul class="slds-tabs--default__nav" role="tablist" onclick="{!c.doneRendering}">
                            <li onclick="{!c.tab1}" class="{!(v.salesOrderTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Sales Order" role="presentation">
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                    <i class="fa fa-file-text-o" aria-hidden="true"></i> Sales Order
                                </a>
                            </li>
                            <li onclick="{!c.tab6}" class="{!(v.discountTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Discount" role="presentation" >
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                    <i class="fa fa-qrcode fa-1x"></i> Discount
                                </a>
                            </li>
                            <li onclick="{!c.tab2}" class="{!(v.paymentTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Payment" role="presentation" >
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                    <i class="fa fa-qrcode fa-1x"></i> Payment
                                </a>
                            </li>
                            <li onclick="{!c.tab3}" class="{!(v.deliveryTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Delivery" role="presentation" >
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                    <i class="fa fa-truck fa-1x"></i> Delivery
                                </a>
                            </li>
                            <li onclick="{!c.tab4}" class="{!(v.chatterTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Chatter" role="presentation" >
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                    <i class="fa fa-users fa-1x"></i> Chatter
                                </a>
                            </li>
                            <li onclick="{!c.tab5}" class="{!(v.accountTab)?'slds-tabs--default__item slds-active epos-class2':'slds-tabs--default__item epos-class2'}" title="Account" role="presentation">
                                <a class="slds-tabs--default__link epos-class3" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                    <i class="fa fa-user fa-1x"></i> Account
                                </a>
                            </li>
                        </ul>
                        <div class="tab-content">
                            <div class="{!(v.salesOrderTab)?'slds-show':'slds-hide'}" aura:id="home"  role="tabpanel">
                                <div class="col-md-6">
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">Sales Order</label>
                                            <div class="slds-form-element" onmouseover="{!c.doneRendering}">
                                                <div class="slds-form-element__control" onclick="{!c.SBool}" onmouseover="{!c.lookupClickOrder}">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Sales_Order__c" aura:id="so" IconName="standard:orders" selectedRecord="{!v.SalesOrder}" nameValue="{!v.SalesOrder.Name}" qry="{!v.qry}"/><!--selectedRecordId="{!v.SalesOrder.Id}" -->
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">
                                                <span class="clr-required">*</span> Order Profile</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputSelect class="slds-select" aura:id="InputSelectDynamic" value="{!v.SOP}" disabled="{!if(v.itemWrapperListt.length > 0,true,false)}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small padng4">
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">Invoice No.</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="sio" disabled="true"
                                                                  class="slds-input"
                                                                  value="{!v.invoiceName}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">Payment Status</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="so" 
                                                                  class="slds-input"
                                                                  disabled="true"
                                                                  value="{!v.SalesOrder.ERP7__Payments_Status__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small epos-class4">
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label fsize11" for="name">PO Reference</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="sopon" 
                                                                  class="slds-input"
                                                                  value="{!v.SalesOrder.ERP7__Purchase_Order_Number__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">{!$Label.c.OrderConsole_Expected_Date}</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control height30" >
                                                    <ui:inputDate aura:id="so" class="slds-input inputd"
                                                                  displayDatePicker="true"
                                                                  value="{!v.SalesOrder.ERP7__Expected_Date__c}"
                                                                  />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small padngTop12">
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">Status</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputSelect class="slds-select" aura:id="orderStatus" value="{!v.orderStatus}" change="{!c.SOStatus}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6 col-xs-12" >
                                            <label class="slds-form-element__label" for="name">Special Instructions</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputTextArea aura:id="sa" 
                                                                      class="slds-textarea slds-textareaa"
                                                                      rows="3" cols="20"
                                                                      value="{!v.SalesOrder.ERP7__Special_Instructions__c}"
                                                                      />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="row slds-m-top--x-small">
                                        
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name"><span class="clr-required">*</span>{!$Label.c.EposEmployee} </label><br/>
                                                <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" aura:id="emp" IconName="standard:user" selectedRecord="{!v.currentEmployee}"/>
                                            </div>
                                            
                                        </div>
                                        
                                        <div class="col-md-12 slds-m-top--x-small">
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Project</label><br/>
                                                <c:CustomInputLookUp objectAPIName="ERP7__Project__c" aura:id="proj" IconName="custom:custom33" selectedRecordId="{!v.projId}"/>
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-12 slds-m-top--x-small">
                                            
                                            <div class="slds-form-element">
                                                <label class="slds-form-element__label" for="name">Shipment Type</label><br/>
                                                <div class="slds-form-element__control">
                                                    <ui:inputSelect class="slds-select" aura:id="STP" value="{!v.SalesOrder.ERP7__Shipment_Type__c}"/>
                                                </div>
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-12 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                        <ui:inputcheckbox value="{!v.SalesOrder.ERP7__Is_Back_Order__c}"  disabled="true"/>
                                                        <label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Back Order</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                        <ui:inputcheckbox value="{!v.SalesOrder.ERP7__Is_Pre_Order__c}"  disabled="true"/><!--click="{!c.POrder}"-->
                                                        <label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Pre Order</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>
                                            
                                        </div>
                                        
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <aura:If isTrue="{!v.crudValues.ERP7__Authorised__c}">
                                                    <lightning:input type="checkbox" label="Authorised" name="input3" checked="{!v.SalesOrder.ERP7__Authorised__c}" disabled="{!v.isSO_Authorised == true}"/>
                                                </aura:If>
                                            </div>
                                            
                                        </div>
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <span class="slds-checkbox">
                                                          <lightning:input type="checkbox" label="Is Closed" name="input4" checked="{!v.SalesOrder.ERP7__Is_Closed__c}" disabled="{!(v.SalesOrder.Id == undefined)}"/>
                                                   			<!--<ui:inputcheckbox value="{!v.SalesOrder.ERP7__Is_Closed__c}" disabled="{!(v.SalesOrder.Id == undefined)}"/>-->
                                                        <!--<label class="slds-checkbox__label" for="checkbox-1">
                                                            <span class="slds-checkbox_faux"></span>
                                                            <span class="slds-form-element__label">Is Closed</span>
                                                        </label>-->
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="slds-form-element">
                                                <aura:If isTrue="{!v.crudValues.ERP7__Issue_Invoice__c}">
                                                    <lightning:input type="checkbox" label="Issue Invoice" name="input5" checked="{!v.SalesOrder.ERP7__Issue_Invoice__c}" disabled="{!(v.SalesOrder.Id == undefined)}"/>
                                                    <!--<ui:inputcheckbox value="{!v.SalesOrder.ERP7__Issue_Invoice__c}" /> --> 
                                                    <!--<label class="slds-checkbox__label" for="checkbox-1">
                                                        <span class="slds-checkbox_faux"></span>
                                                        <span class="slds-form-element__label padngleft8">Issue Invoice</span>
                                                    </label>-->
                                                </aura:If>    
                                            </div>
                                        </div>
                                        <div class="col-md-12 dispNone" >
                                            <c:ProjectLookups type="Account" aura:id="OrgName" value="{!v.custInvoiceTest.ERP7__Account__c}" className="slds-input" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 padngleftright4" onmouseover="{!c.doneRendering}" >
                                    <div class="row">
                                        <div class="col-lg-12 col-md-11 text-small-formb">
                                            <aura:If isTrue="{!(v.SalesOrder.Name != undefined )}">
                                                <button type="button" onclick="{!c.OpenOrder}" class="slds-button slds-button--neutral slds-m-top--xx-small slds-m-bottom--xx-small fieldswidth100">
                                                    <i class="fa fa-list" aria-hidden="true"></i> Order Document
                                                </button>
                                            </aura:If>
                                        </div>
                                        <div class="col-lg-12 col-md-11 text-small-formb">
                                            <aura:If isTrue="{!and(v.Invoice.Name != undefined, v.SalesOrder.ERP7__Issue_Invoice__c==true)}">
                                                <button type="button" onclick="{!c.OpenInvoice}" class="slds-button slds-button-neutral slds-m-top-xx-small fieldswidth100">
                                                    <i class="fa fa-list" aria-hidden="true"></i>&nbsp;Invoice Document
                                                </button>
                                            </aura:If>
                                        </div>
                                        <div class="col-lg-12 col-md-11 text-small-formb">
                                            <aura:If isTrue="{!(v.SalesOrder.ERP7__Is_Closed__c  == true)}">
                                                <button type="button" class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100"  onclick="{!c.RMA}">
                                                    <i class="fa fa-external-link" aria-hidden="true"></i>&nbsp;RMA
                                                </button>
                                            </aura:If>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="{!(v.discountTab)?'slds-show':'slds-hide'}" id="orderDiscount" role="tabpanel">
                                <div class="col-md-7">
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-12">
                                            <label class="slds-form-element__label fsize11" for="name" >Order Discount Amount</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="orDis" class="slds-input" value="{!v.SalesOrder.ERP7__Order_Discount__c}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12 slds-p-top--x-small">
                                            <label class="slds-form-element__label" for="name">Description</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputTextArea aura:id="ordisDes" 
                                                                      class="slds-textarea slds-textareaa"
                                                                      rows="3" cols="20"
                                                                      value="{!v.SalesOrder.ERP7__Order_Discount_Description__c}"
                                                                      />
                                                </div>
                                            </div>
                                        </div>
                                    </div>  
                                </div>
                            </div>
                            <div class="{!(v.paymentTab)?'slds-show':'slds-hide'}" aura:id="payment" role="tabpanel">
                                <div class="col-lg-9 col-md-8">
                                    <h3 class="epos-class5">
                                        <span class="epos-class6">
                                            <strong>Invoice Amount : </strong>
                                            <ui:outputCurrency aura:id="lop" class="" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                            &nbsp;&nbsp;
                                        </span> 
                                        &nbsp;&nbsp; 
                                        <span class="epos-class6">
                                            <strong>Paid : </strong>
                                            <ui:outputCurrency aura:id="lop" class="" value="{!v.SalesOrder.ERP7__Amount_Paid__c}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp; 
                                        <span class="epos-class6">
                                            <strong>Total Due : </strong>
                                            <ui:outputCurrency aura:id="lop" value="{!v.finalDue}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp;
                                        <span class="epos-class6">
                                            <strong>Credit : </strong>
                                            <ui:outputCurrency aura:id="lop" class="" value="{!v.Customer.ERP7__Available_Credit_Balance__c}"/>
                                            &nbsp;&nbsp;
                                        </span>
                                        &nbsp;&nbsp;
                                    </h3>
                                    <aura:If isTrue="{!(v.SalesOrder.Name != undefined)}">
                                        <div class="epos-class7">
                                            <table class="slds-table slds-table--bordered">
                                                <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9" >
                                                    <th class="epos-class8">Type</th>
                                                    <th class="epos-class8">Name</th>
                                                    <th class="epos-class8">Date</th>
                                                    <th class="epos-class8">Amount</th>
                                                </tr> 
                                                <aura:iteration var="pay" indexVar="pcount" items="{!v.Payments}">
                                                    <tr class="fweight-normal">
                                                        <td class="epos-class9">
                                                            <div class="slds-truncate fontsize13" title="{!pay.RecordType.Name}">
                                                                {!pay.ERP7__Payment_Type__c}
                                                            </div>
                                                        </td>
                                                        <td class="">
                                                            <div class="slds-truncate epos-class11"  id="{!pay.Id}">
                                                                <ui:outputText value="{!pay.Name}" click="{!c.NavRecord}" title="{!pay.Id}"/>
                                                            </div>
                                                        </td>
                                                        <!--  -->
                                                        <td class="">
                                                            <div class="slds-truncate epos-class14" title="{!pay.CreatedDate}">
                                                                <ui:outputDateTime aura:id="paymethod" class="" value="{!pay.CreatedDate}" format="dd/MM/yyyy HH:mm"/>
                                                            </div>
                                                        </td>
                                                        <td class="">
                                                            <div class="slds-truncate epos-class13" title="{!pay.ERP7__Total_Amount__c}">
                                                                <ui:outputCurrency aura:id="payamt" class="" value="{!pay.ERP7__Total_Amount__c}"/>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </aura:iteration>
                                            </table>
                                        </div>
                                        <aura:if isTrue="{!equals($Label.c.EPOS_Coupon, 'True')}">
                                            <div class="epos-class15">
                                                <div class="row margin0" >
                                                    <div class="col-md-3 col-xs-3 slds-m-bottom--x-small slds-m-top--x-small">
                                                        <h3 class="epos-class16"><strong>Coupon Codes</strong></h3>
                                                    </div>
                                                    <div class="col-md-9 col-xs-9 slds-m-bottom--x-small slds-grid talignRigth" >
                                                        <ui:inputText aura:id="coupon" class="fifty" value="{!v.Coupon}"/>
                                                        &nbsp;&nbsp;&nbsp;
                                                        <button type="button" onclick="{!c.ApplyCoupon}" class="slds-button slds-button--brand" >Apply</button>
                                                    </div>
                                                </div>
                                                <table class="slds-table slds-table--bordered">
                                                    <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9" >
                                                        <th class="epos-class17">Name</th>
                                                        <th class="epos-class17">Coupon</th>
                                                        <th class="epos-class17">Applied Date</th>
                                                        <th class="epos-class17">Amount</th>
                                                        <th></th>
                                                    </tr>
                                                    <aura:iteration var="CN" indexVar="cncount" items="{!v.CreditNotes}">
                                                        <tr>
                                                            <td class="epos-class18">
                                                                <div class="slds-truncate  epos-class61" id="{!CN.Id}">
                                                                    <ui:outputText value="{!CN.Name}" click="{!c.NavRecord}" title="{!CN.Id}"/>
                                                                </div>
                                                            </td>
                                                            <td class="epos-class18">
                                                                <div class="slds-truncate epos-class61" id="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__c}">
                                                                    <ui:outputText value="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__r.Name}" click="{!c.NavRecord}" title="{!CN.ERP7__Coupon_Redemption__r.ERP7__Coupon__c}"/>
                                                                </div>
                                                            </td>
                                                            <td class="epos-class18">
                                                                <div class="slds-truncate">
                                                                    <div class="slds-truncate epos-class14 " title="{!CN.ERP7__Applied_Date__c}">
                                                                        <ui:outputDateTime aura:id="appDate" class="" value="{!CN.ERP7__Applied_Date__c}" format="dd/MM/yyyy"/>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                            <td class="epos-class18">
                                                                <div class="slds-truncate"><ui:outputCurrency aura:id="curr" value="{!CN.ERP7__Amount__c}"/></div>
                                                            </td>
                                                            <td class="epos-class10">
                                                                <lightning:button onclick="{!c.DeleteCoupon}"  name="{!CN.Id}" class="neutralC"><a title="Cancel" ><img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="epos-class19" /> </a></lightning:button>
                                                            </td>
                                                        </tr>
                                                    </aura:iteration>
                                                </table>
                                            </div>
                                        </aura:if>
                                    </aura:If>
                                </div>
                                <div class="col-lg-3 col-md-4 padngleft0" onmouseover="{!c.doneRendering}" >
                                    <div class="row">
                                        <div class="col-lg-12 col-md-12">
                                            <a href="javascript:void(0)" onclick="{!c.openCardModal}" title="Card Payment"  class="tdecorNone">
                                                <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100" >
                                                    <i class="fa fa-credit-card" aria-hidden="true"></i> Credit / Debit
                                                </ui:button>
                                            </a>
                                        </div>
                                        <div class="col-lg-12 col-md-12">   
                                            <a href="javascript:void(0)"   onclick="{!c.openBankModal}" title="Bank Payment"  class="tdecorNone">
                                                <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100" >
                                                    <i class="fa fa-building-o" aria-hidden="true"></i> Bank / Cheque
                                                </ui:button>
                                            </a>
                                        </div>
                                        <div class="col-lg-12 col-md-12">
                                            <a href="javascript:void(0)"   onclick="{!c.openCashModal}" data-target="#myModalCash" title="Cash Payment"  class="tdecorNone">
                                                <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100" >
                                                    <i class="fa fa-money" aria-hidden="true"></i> Cash
                                                </ui:button>
                                            </a>
                                        </div>
                                        <div class="col-lg-12 col-md-12">
                                            <aura:If isTrue="{!(v.Customer.ERP7__No_of_Loyalty_Cards__c > 0)}">
                                                <a href="javascript:void(0)"   onclick="{!c.openMyModalLoyalty}" data-target="#myModalLoyalty" title="Loyalty Payment"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100">
                                                        <i class="fa fa-ellipsis-h" aria-hidden="true"></i> Loyalty 
                                                        <aura:If isTrue="{!(v.customerCreditLimit != null)}">
                                                            <span>
                                                                (
                                                                <ui:outputText aura:id="lop" class="" value="{!v.customerCreditLimit}"/>
                                                                )
                                                            </span>
                                                        </aura:If>
                                                    </ui:button>
                                                </a>
                                            </aura:If>
                                        </div>
                                        <div class="col-lg-12 col-md-12">
                                            <aura:If isTrue="{!and(v.invoiceName != '', v.invoiceName != undefined)}">
                                                <a href="javascript:void(0)"   data-toggle="modal" onclick="{!c.openApplyCredModal}" title="Apply Credits"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100" >
                                                        <i class="fa fa-ticket" aria-hidden="true"></i> Apply Credits
                                                    </ui:button>
                                                </a>
                                            </aura:If>
                                        </div>
                                        <div class="col-lg-12 col-md-12">
                                            <aura:If isTrue="{!(v.Invoice.Name != undefined)}">
                                                <ui:button press="{!c.OpenInvoice}" class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100 margin-left-0">
                                                    <i class="fa fa-list" aria-hidden="true"></i> Invoice Document
                                                </ui:button>
                                            </aura:If>
                                        </div>
                                    </div>
                                </div>
                                <!-- Modal popup7 Cash -->
                                <div id="myModalCash" aura:id="myModalCash" class="slds-modal" role="dialog">
                                    <div class="modal-dialog modal-md">
                                        <!-- Modal content-->
                                        <div class="modal-content">
                                            <div class="modal-header" >
                                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                    <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeCashModal}"/>
                                                </button>
                                               
                                                <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Cash Payment
                                                    
                                                </h2>
                                            </div>
                                            <div class="modal-body" >
                                                <div class="container-fluid">
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-12 col-sm-12 col-xs-12">
                                                            <span class="epos-class20">
                                                                <ui:outputText aura:id="paymentError" value="{!v.CashError}"/>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Actual Amount</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputCurrency aura:id="fdue" 
                                                                                      class="slds-input"
                                                                                      disabled="true"
                                                                                      value="{!v.finalDue}"
                                                                                      />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Amount</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputCurrency aura:id="pAmt" 
                                                                                      class="slds-input"
                                                                                      value="{!v.Payment.ERP7__Total_Amount__c}"
                                                                                      />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                 <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeCashModal}">Cancel</button>
                                                <ui:button class="slds-button slds-button--brand" press="{!c.CashPayment}">Pay Now</ui:button>
                                               
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-backdrop" aura:id="myModalCashBackdrop"></div>
                                <!-- popup 7 Cash ends here -->
                                <!-- Modal popup8 Bank -->
                                <div id="myModalBank" aura:id="myModalBank" class="slds-modal" role="dialog">
                                    <div class="modal-dialog modal-md">
                                        <!-- Modal content-->
                                        <div class="modal-content">
                                            <div class="modal-header" >
                                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                    <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeBankModal}"/>
                                                </button>
                                              
                                                <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Bank Payment
                                                    
                                                </h2>
                                            </div>
                                            <div class="modal-body" >
                                                <div class="container-fluid">
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-12 col-sm-12 col-xs-12">
                                                            <span class="epos-class20">
                                                                <ui:outputText aura:id="paymentError" value="{!v.BankError}"/>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"> Bank</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="bank" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Bank__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"> Account Holder Name</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="pAmt" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Account_Holder_Name__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"> Account Type</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSelect class="slds-select" aura:id="accountType" value="{!v.Payment.ERP7__Account_Type__c}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01">Account Number</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="pAmt" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Account_Number__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"> {!$Label.c.Epos_Bank_Code}</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="route" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Bank_Code__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label pr-0" for="text-input-01"><span class="clr-red">* </span> Reference/Cheque No.</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="bank" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Reference_Cheque_No__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Actual Amount</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputCurrency aura:id="fdue" 
                                                                                      class="slds-input"
                                                                                      disabled="true"
                                                                                      value="{!v.finalDue}"
                                                                                      />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Amount</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputCurrency aura:id="pAmt" 
                                                                                      class="slds-input"
                                                                                      value="{!v.Payment.ERP7__Total_Amount__c}"
                                                                                      />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- Moin added this on 22nd feb 2024 -->
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <span class="slds-form-element__label slds-no-flex">{!$Label.c.Acc_Pay_Payment_Date}</span>
                                                                <lightning:input type="date"  value="{!v.Payment.ERP7__Payment_Date__c}" class="displaynone-label" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <c:CustomInputLookUp label="{!$Label.c.Payment_Account}" objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:account" selectedRecordId="{!v.Payment.ERP7__Payment_Account__c}" aura:Id="paymentAccount"  required="true" qry="{! v.orgId != ''?' AND ERP7__Organisation__c =\''+ v.orgId+'\''+ ' AND ERP7__Payment_Account__c=true' : ' AND ERP7__Payment_Account__c=true'}"/>
                                                            </div>
                                                        </div>
                                                        <!--Moin added this on 04th March 2024-->
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <lightning:select name="RecordType" label="{!$Label.c.Payment_Method}" aura:id="PayRecordTy" ><!-- onchange="{!c.fetchDetails}" -->
                                                                    <aura:iteration items="{!v.paymentGatewayList}" var="item">
                                                                        
                                                                        <option text="{!item}" value="{!item}" selected="{!v.Payment.ERP7__Payment_Gateway__c}" />
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <lightning:button class="slds-button slds-button--brand" onclick="{!c.BankPayment}">Save</lightning:button>
                                                <lightning:button class="slds-button slds-button--neutral" onclick="{!c.closeBankModal}">Cancel</lightning:button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-backdrop" aura:id="myModalBankBackdrop"></div>
                                <!-- popup 8 Bank ends here -->
                                <!-- Modal popup9 Card -->
                                <div id="myModalCard" aura:id="myModalCard" class="slds-modal slds-modal_large" role="dialog">
                                    <div class="modal-dialog modal-md width80" >
                                        <!-- Modal content-->
                                        
                                        <div class="modal-content">
                                            
                                            <header class="slds-modal__header height55">
                                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                    <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeCardModal}"/>
                                                </button>
                                                
                                                <div class="slds-grid">
                                                    <div class="col-md-4">
                                                        <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignleft">Card Payment</h2>
                                                    </div>
                                                    
                                                    <div class="col-md-3">
                                                        <!--<aura:if isTrue="{!v.invList.length lt 2}">-->
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Invoice__c" selectedRecord="{!v.Invoiced}" IconName="standard:account" placeholder="Search Invoice" qry="{!v.qry2}" />
                                                        <!--</aura:if>-->
                                                    </div>
                                                    
                                                    <div class="col-md-3">
                                                        <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.orgId}"
                                                        IconName="standard:account" placeholder="Search Organisation" qry="AND ERP7__Account_Type__C = 'Organisation'"/>
                                                     </div>
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <!--<label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Payment Type</label>-->
                                                            <div class="slds-form-element__control">
                                                                <ui:inputSelect class="slds-select" aura:id="payType" value="{!v.payType}"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                 </div>
                                            </header>
                                            <div class="slds-grid slds-hide">
                                                    <div class="col-md-12 text-center slds-p-top_small" >
                                                    	<lightning:icon iconName="utility:info" size="small"></lightning:icon>&nbsp;This is a currency message
                                                    </div>
                                                
                                                </div>
                                            
                    
                                            <div class="modal-body pdngtop0" >
                                                <div class="container-fluid">
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-12 col-sm-12 col-xs-12">
                                                            <span class="epos-class20">
                                                                <ui:outputText aura:id="paymentError" value="{!v.CardError}"/>
                                                            </span>
                                                        </div>
                                                    </div>
                         							<!--<aura:if isTrue="{!!equals(v.payType, 'Stripe')}">-->
                                                      <div class="slds-grid slds-wrap slds-m-top--xx-small" >    
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Card Holder Name</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="pAmt" 
                                                                                  class="slds-input"
                                                                                  value="{!v.PaymentMethod.ERP7__Name_on_Card__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Card Type</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSelect class="slds-select" aura:id="cardType" value="{!v.PaymentMethod.ERP7__CardType__c}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Card Number</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSecret aura:id="pAmt" 
                                                                                    class="slds-input"
                                                                                    value="{!v.PaymentMethod.ERP7__Card_Number__c}"
                                                                                    />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                        
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span>CVV</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSecret aura:id="cvv" 
                                                                                    class="slds-input"
                                                                                    maxlength="4"
                                                                                    value="{!v.CVV}"
                                                                                    />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Expiry Month</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSelect class="slds-select" aura:id="expiryMonth" value="{!v.PaymentMethod.ERP7__Card_Expiration_Month__c}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Expiry Year</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputSelect class="slds-select" aura:id="expiryYear" value="{!v.PaymentMethod.ERP7__Card_Expiration_Year__c}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                        <aura:if isTrue="{!v.isMultiCurrency}">
                                                            <div class="col-md-4 col-sm-4 col-xs-12">
                                                                <div class="slds-form-element">
                                                                    <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Actual Amount</label>
                                                                    <div class="slds-form-element__control">
                                                                        {!v.orderCurrency}&nbsp;<lightning:formattedNumber value="{!v.finalDue}" class="decimal" maximumFractionDigits="2" minimumFractionDigits="2"/>
                                                                        
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <aura:set attribute="else">
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Actual Amount</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputCurrency aura:id="fdue" 
                                                                                              class="slds-input"
                                                                                              disabled="true"
                                                                                              value="{!v.finalDue}"
                                                                                              />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                
                                                            </aura:set>
                                                        </aura:if>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">* </span> Amount</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputCurrency aura:id="pAmt" 
                                                                                              class="slds-input"
                                                                                              value="{!v.Payment.ERP7__Total_Amount__c}"
                                                                                              />
                                                                    <!--<aura:if isTrue="{!v.invList.length > 1}">
                                                                        <lightning:input type="number" formatter="currency" value="{!v.Payment.ERP7__Total_Amount__c}" disabled="true" class="nolble"/>
                                                                        <aura:set attribute="else">
                                                                            <ui:inputCurrency aura:id="pAmt" 
                                                                                              class="slds-input"
                                                                                              value="{!v.Payment.ERP7__Total_Amount__c}"
                                                                                              />
                                                                        </aura:set>
                                                                    </aura:if>-->
                                                                    
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"></span> Reference No</label>
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText aura:id="pRefer" 
                                                                                  class="slds-input"
                                                                                  value="{!v.Payment.ERP7__Reference_Cheque_No__c}"
                                                                                  />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                        
                                                    </div>
                                                    <div class="container-fluid"> 
                                                    <div class="row slds-m-top--xx-small">
                                                        <h2 class="pdngten0"><strong>Billing Address</strong></h2>
                                                        <!--<lightning:accordion allowMultipleSectionsOpen="true" activeSectionName="{!v.activeSections}">
                            								<lightning:accordionSection name="A" label="Billing Address">-->
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"> </span> Address Line1</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputText aura:id="bAdding" 
                                                                                          class="slds-input"
                                                                                          value="{!v.BillAddress.ERP7__Address_Line1__c}"
                                                                                          />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"> </span> Address Line2</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputText aura:id="bAdding2" 
                                                                                          class="slds-input"
                                                                                          value="{!v.BillAddress.ERP7__Address_Line2__c}"
                                                                                          />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"> </span> Country</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputSelect class="slds-select" aura:id="bAdding4" value="{!v.BillAddress.ERP7__Country__c}"/>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"> </span> City</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputText aura:id="bAdding5" 
                                                                                          class="slds-input"
                                                                                          value="{!v.BillAddress.ERP7__City__c}"
                                                                                          />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red">*</span> State/Province</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputSelect class="slds-select" aura:id="bAdding6" value="{!v.BillAddress.ERP7__State__c}"/>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <label class="slds-form-element__label" for="text-input-01"><span class="clr-red"> </span> Zip/Postal Code</label>
                                                                        <div class="slds-form-element__control">
                                                                            <ui:inputText aura:id="bAdding7" 
                                                                                          class="slds-input"
                                                                                          value="{!v.BillAddress.ERP7__Postal_Code__c}"
                                                                                          />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            <!--</lightning:accordionSection>
                                                        </lightning:accordion>-->
                                                        <div class="col-md-4 col-sm-4 col-xs-12">
                                                        </div>
                                                    </div>
                                                        </div>
                                                        
                                                    <!--</aura:if>-->
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeCardModal}">Cancel</button>
                                                <ui:button class="slds-button slds-button--brand" press="{!c.CardPayment}">Pay Now</ui:button>
                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-backdrop" aura:id="myModalCardBackdrop"></div>
                                <!-- popup 9 Card ends here -->
                                <!-- Modal popup 14 Applycredit -->
                                <div id="myModalApplyCred" aura:id="myModalApplyCred" class="slds-modal" role="dialog">
                                    <div class="modal-dialog modal-md">
                                        <!-- Modal content-->
                                        <div class="modal-content">
                                            <div class="modal-header" >
                                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                    <lightning:icon iconName="utility:close" class="customfill" alternativeText="Close" title="Close" onclick="{!c.closeApplyCredModal}"/>
                                                </button>
                                                
                                                <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate talignCentre">Apply Credits</h2>
                                            </div>
                                            <div class="modal-body" >
                                                <div class="container-fluid">
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-12 col-sm-12 col-xs-12">
                                                            <span class="epos-class20">
                                                                <ui:outputText aura:id="paymentError" value="{!v.CreditError}"/>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="row slds-m-top--xx-small">
                                                        <div class="col-md-6 col-sm-6 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <label class="slds-form-element__label font-size1rem" for="text-input-01">Invoice Amount:</label>
                                                                    <ui:outputCurrency aura:id="pAmt"  class="outputTextOR" value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6 col-sm-6 col-xs-12">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <label class="slds-form-element__label font-size1rem" for="text-input-01"> Total Due:</label>
                                                                    <ui:outputCurrency aura:id="fdue" class="outputTextOR" value="{!v.finalDue}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="row slds-m-top--small">
                                                        
                                                        <div class="col-md-12 col-sm-12 col-xs-12 ">
                                                            <div class="row">
                                                                <div class="col-md-6 col-sm-6 col-xs-12">
                                                                    <div class="slds-form-element">
                                                                        <div class="slds-form-element__control font-size1rem">
                                                                            <label class="slds-form-element__label" for="text-input-01">Available Credit:</label>
                                                                            <ui:outputText aura:id="pAmt" 
                                                                                           class="outputTextOR"
                                                                                           value="{!v.Customer.ERP7__Available_Credit_Balance__c}"
                                                                                           />
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-6 padngleft8">
                                                                    <label class="slds-form-element__label font-size1rem" for="text-input-01">
                                                                        <div class="slds-form-element__control slds-grid">
                                                                            <span class="clr-red">* </span>Redeem Credit :  <ui:inputText aura:id="pAmt" class="" value="{!v.CreditAmount2Use}"/>
                                                                        </div>
                                                                    </label>
                                                                    
                                                                    
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                
                                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeApplyCredModal}">Cancel</button>
                                                <ui:button class="slds-button slds-button--brand" press="{!c.ProcessCredit}">Save</ui:button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-backdrop" aura:id="myModalApplyBackdrop"></div>
                                <!-- Applycredit 14 Loyalty ends here -->
                                
                            </div>
                            <div class="{!(v.deliveryTab)?'slds-show slds-p-top--xx-small':'slds-hide'}" id="delivery" role="tabpanel">
                                <div class="col-md-9">
                                    <div class="epos-class21">
                                        <table class="slds-table slds-table--bordered" >
                                            <tr class="slds-text-heading--label fweight-bold" bgcolor="#f4f6f9" >
                                                <th class="epos-class22">Type</th>
                                                <th class="epos-class22">Name</th>
                                                <th class="epos-class22">Tracking No.</th>
                                                <th class="epos-class22">Delivery Date</th>
                                                <th class="epos-class22">Status</th>
                                            </tr>
                                            <aura:iteration var="shipment" indexVar="pcount" items="{!v.Shipments}">
                                                <tr class="epos-class23">
                                                    <td class="epos-class24">
                                                        <div class="slds-truncate fsize12"  title="{!shipment.RecordType.Name}">
                                                            <i class="fa fa-plane clr70d2" aria-hidden="true"/>&nbsp;
                                                            <aura:If isTrue="{!(shipment.RecordType.Name == 'Internal Shipping')}">
                                                                Internal
                                                            </aura:If>
                                                            <aura:If isTrue="{!(shipment.RecordType.Name == 'UPS Shipping')}">
                                                                UPS 
                                                            </aura:If>
                                                            <aura:If isTrue="{!(shipment.RecordType.Name == 'Fedex Shipping')}">
                                                                Fedex 
                                                            </aura:If>
                                                            <aura:If isTrue="{!(shipment.RecordType.Name == 'DHL Shipping')}">
                                                                DHL 
                                                            </aura:If>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class24">
                                                        <div class="slds-truncate epos-class25"  id="{!shipment.Id}">
                                                            <ui:outputText value="{!shipment.Name}" click="{!c.NavRecord}" title="{!shipment.Id}"/>
                                                        </div>
                                                    </td>
                                                    <!--  -->
                                                    <td class="epos-class24">
                                                        <div class="slds-truncate epos-class26" >
                                                            <ui:outputText aura:id="paymethod" class="" value="{!shipment.ERP7__TrackingNumber__c }"/>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class24">
                                                        <div class="slds-truncate epos-class26" title="{!shipment.ERP7__Shipment_Delivery_Date__c}">
                                                            <ui:outputDateTime aura:id="paymethod" class="" value="{!shipment.ERP7__Shipment_Delivery_Date__c}" format="dd/MM/yyyy"/>
                                                        </div>
                                                    </td>
                                                    <td class="epos-class24">
                                                        <div class="slds-truncate epos-class26"  title="{!shipment.ERP7__Status__c}">
                                                            <ui:outputText aura:id="payamt" class="" value="{!shipment.ERP7__Status__c}"/>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </div>
                                <div class="col-md-3" onmouseover="{!c.doneRendering}">
                                    <div class="row">
                                        <div class="col-md-10">
                                            <aura:If isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'UPS' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)" onclick="{!c.openUPSModal}" title="UPS"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100 slds-button--neutralups" press="{!c.Services}">
                                                        <img class="slds-button__icon slds-button__icon--right epos-class27" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/glo_ups_brandmark.gif"/>
                                                    </ui:button>
                                                </a>
                                            </aura:If>
                                        </div>
                                        <div class="col-md-10">     
                                            <aura:If isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'FedEx' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)" onclick="{!c.openFedExModal}" title="FedEx"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100" press="{!c.FedExServices}">
                                                        <img class="slds-button__icon slds-button__icon--right epos-class28" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/FedEx.png" /> 
                                                    </ui:button>
                                                </a>
                                            </aura:If>
                                        </div> 
                                        <div class="col-md-10">     
                                            <aura:If isTrue="{!(v.SalesOrder.ERP7__Shipment_Type__c == 'DHL' || v.SalesOrder.ERP7__Shipment_Type__c == 'Any')}">
                                                <a href="javascript:void(0)" onclick="{!c.openDHLModal}" title="DHL"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100 slds-button--neutraldhl" press="{!c.DHL_Services}">
                                                        <img class="slds-button__icon slds-button__icon--right epos-class28" src="/resource/1484261900000/ERP7__ERPCustomIcons/erpicons/dhl.png"/> 
                                                    </ui:button>
                                                </a>
                                            </aura:If>
                                        </div>
                                        <div class="col-md-10">
                                            <aura:If isTrue="{!!(v.SalesOrder.ERP7__Shipment_Type__c == 'FedEx' || v.SalesOrder.ERP7__Shipment_Type__c == 'UPS' || v.SalesOrder.ERP7__Shipment_Type__c == 'DHL')}">
                                                <a href="javascript:void(0)" onclick="{!c.openShipmentModal}" title="Shipment"  class="tdecorNone">
                                                    <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small fieldswidth100">
                                                        <i class="fa fa-truck" aria-hidden="true"></i> Shipment
                                                    </ui:button> 
                                                </a>
                                            </aura:If>
                                        </div>
                                    </div> 
                                </div>
                            </div>
                            <div class="{!(v.chatterTab)?'slds-show slds-p-top--xx-small':'slds-hide'}" id="chatter" role="tabpanel" >
                                <div class="col-md-12">
                                    <iframe src="{!'/apex/ERP7__ChatterLC?core.apexpages.devmode.url=1'}" width="100%" height="300px;" frameBorder="0" align="top"/>
                                </div>
                            </div>
                            
                            <div class="{!(v.accountTab)?'slds-show':'slds-hide'}" id="account" role="tabpanel">
                                <div class="col-md-7">
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label fsize11" for="name" >Company</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="comp" class="slds-input" value="{!v.Customer.ERP7__Company__c}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Website</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="comp" class="slds-input" value="{!v.Customer.Website}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>  
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Phone</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="num" class="slds-input" value="{!v.Customer.Phone}"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Fax</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <ui:inputText aura:id="comp" class="slds-input" value="{!v.Customer.Fax}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small">
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Profile</label>
                                            <div class="slds-form-element"> <!-- onclick="{!c.lookupClickProfile}" -->
                                                <div class="slds-form-element__control">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Profiling__c" aura:id="profl" IconName="standard:client" selectedRecord="{!v.AccProfile1}" qry="{!'AND ERP7__Record_Type_Name__c =\'Customer\''}"/>
                                                </div>
                                            </div> 
                                        </div>
                                        <div class="col-md-6">
                                            <label class="slds-form-element__label" for="name">Account No.</label>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control" >
                                                    <ui:inputText aura:id="comp" class="slds-input" value="{!v.Customer.AccountNumber}"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-p-around--x-small">
                                        <aura:if isTrue="{!v.eposFLSCheck.taxInput}">
                                            <div class="col-md-6">
                                                <label class="slds-form-element__label" for="name">Tax</label>
                                                <div class="slds-form-element" onmouseover="{!c.lookupClickBlank}">
                                                    <div class="slds-form-element__control">
                                                        <!--<ERP7:CustomInputLookUp objectAPIName="ERP7__Tax__c" aura:id="cvat" IconName="standard:entity" selectedRecord="{!v.AccTax1}" />-->
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Tax__c" aura:id="cvat2" IconName="standard:entity" selectedRecord="{!v.AccTax1}" />
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                        <aura:if isTrue="{!v.eposFLSCheck.taxRegNoInput}">
                                            <div class="col-md-6">
                                                <label class="slds-form-element__label" for="name">Tax Regn.No.</label>
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <ui:inputText aura:id="vatregis" class="slds-input" value="{!v.Customer.ERP7__VAT_registration_number__c}"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                    </div>
                                </div>
                                <div class="col-md-5 margtop1" >
                                    <div class="col-md-12" onmouseover="{!c.doneRendering}">
                                        <a href="javascript:void(0)"   onclick="{!c.openAccountModal}" title="Add Account" class="tdecorNone">
                                            <ui:button class="slds-button slds-button--neutral paddingrightaccounttab">
                                                <i class="fa fa-plus" aria-hidden="true"></i> Account
                                            </ui:button>
                                        </a>
                                    </div>
                                    <aura:If isTrue="{!!(v.Customer.ERP7__Is_Person_Account__c == true)}">
                                        <div class="col-md-12" onmouseover="{!c.doneRendering}">
                                            <a href="javascript:void(0)"   onclick="{!c.openContactModal}" data-target="#myModalCon" title="Add Contact"  class="tdecorNone">
                                                <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small paddingrightaccounttab">
                                                    <i class="fa fa-plus" aria-hidden="true"></i> Contact
                                                </ui:button>
                                            </a>
                                        </div>
                                    </aura:If>
                                    <div class="col-md-12" onmouseover="{!c.doneRendering}">
                                        <a href="javascript:void(0)"  onclick="{!c.openAddressModal}" data-target="#myModalAdr" title="Add Address" class="tdecorNone">
                                            <ui:button class="slds-button slds-button--neutral slds-m-top--xx-small paddingrightaccounttab">
                                                <i class="fa fa-plus" aria-hidden="true"></i> Address
                                            </ui:button>
                                        </a>
                                    </div>
                                    <div class="col-md-12 slds-m-top--x-small" >
                                        <article class="slds-card slds-card--narrow">
                                            <div class="slds-card__header slds-grid epos-class29">
                                                <header class="slds-media slds-media--center slds-has-flexi-truncate">
                                                    <div class="slds-media__body slds-truncate pdng0">
                                                        <h2 class="epos-class30">
                                                            <a href="javascript:void(0);" class="slds-text-link--reset">
                                                                <span class="slds-text-heading--small fsize16">Recent Items</span>
                                                            </a>
                                                        </h2>
                                                    </div>
                                                </header>
                                            </div>
                                            <div class="slds-card__body epos-class31">
                                                <div class="slds-card__body--inner epos-class32">
                                                    <aura:iteration var="recentItem" indexVar="counts" items="{!v.RecentlyViewedList}">
                                                        <div class="slds-tile slds-truncate1 epos-class33">
                                                            <aura:If isTrue="{!(recentItem.Type == 'Account')}">
                                                                <i class="fa fa-file clrFF9800" aria-hidden="true" ></i>
                                                            </aura:If>
                                                            <aura:If isTrue="{!(recentItem.Type == 'Contact')}">
                                                                <i class="fa fa-user clrbb4a20" aria-hidden="true" ></i>
                                                            </aura:If>
                                                            <aura:If isTrue="{!(recentItem.Type == 'ERP7__Sales_Order__c')}">
                                                                <i class="fa fa-suitcase clr3F51B5" aria-hidden="true" ></i>
                                                            </aura:If>
                                                            &nbsp;
                                                            <span  id="{!recentItem.Id}" name="{!recentItem.Type}" class="epos-class34">
                                                                <ui:outputText value="{!recentItem.Name}" title="{!recentItem.Id}" class="{!recentItem.Type}" click="{!c.Navigat}" />
                                                            </span>
                                                        </div>
                                                    </aura:iteration>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                    </div>
                    <aura:If isTrue="false">
                        <div class="row" >
                            <div class="col-sm-12 col-md-12 epos-class35">
                                
                                <label class="slds-form-element__label" for="name">Cancelled Reason : </label>
                                <ui:outputText aura:id="lop" value="{!v.SalesOrder.ERP7__Cancelled_Reason__c}"/>    
                                
                            </div>
                        </div> 
                    </aura:If>
                </div> 
                <div class="row">
                    <div class="col-sm-12 col-md-12 epos-class36">
                        
                    </div>
                </div>
                <div  class="epos-class37">
                    <table class="slds-table slds-table--condensed  slds-no-row-hover"> <!-- slds-max-medium-table-(removedonedash0)stacked-horizontal -->
                        <thead>
                            <tr class="header-fixed1 slds-text-heading--label epos-class38">
                                <aura:if isTrue = "{!v.isSO_Authorised != true}">
                                    <th class="slds-is-sortable" scope="col"> 
                                        <aura:If isTrue="{!!(v.SalesOrder.ERP7__Is_Closed__c == true || v.SOP == '' || v.SOP == undefined)}">
                                            <a href="javascript:void(0)" onclick="{!c.NewProductPopup}"  data-toggle="modal" data-target="#myModal" title="Add Product" class="epos-class41">
                                                Add 
                                            </a> 
                                        </aura:If>
                                    </th>
                                </aura:if>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate talignCenter" >Code</div>
                                </th>
                                <th scope="col" class="slds-size--2-of-8">
                                    <div class="slds-truncate epos-class39">Product</div>
                                </th>
                                <aura:if isTrue="{!equals($Label.c.EPOS_UnitPrice, 'True')}">
                                    <th scope="col" class="slds-size--1-of-8">
                                        <div class="slds-truncate talignCenter" >Unit Price</div>
                                    </th>
                                </aura:if>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate talignCenter" >Charge/Qty</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate talignCenter" >UoM</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8" >
                                    <div class="slds-truncate talignCenter">Base Price</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate talignCenter">Discount</div>
                                </th>
                                <aura:if isTrue="{!equals($Label.c.EPOS_Coupon, 'True')}">
                                    <th scope="col" class="slds-size--1-of-8">
                                        <div class="slds-truncate  talignCenter">Coupon</div>
                                    </th>
                                </aura:if>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate talignCenter">Tax</div>
                                </th>
                                <th scope="col" class="slds-size--1-of-8">
                                    <div class="slds-truncate epos-class40">Total Price</div>
                                </th>
                                <th>&nbsp;</th>
                            </tr>
                        </thead>
                        <aura:iteration var="item" indexVar="count" items="{!v.itemWrapperListt}">
                            <tbody>
                                <tr  bgcolor="#FFFFFF">
                                    <aura:if isTrue = "{!v.isSO_Authorised != true}">
                                        <td align="center" valign="middle">
                                            <table width="100%" border="0" bgcolor="">
                                                <tr>
                                                    <td width="33%" align="center" valign="middle" class="pdng0" id="{!item.product.Id}" name="{!count}">
                                                        <lightning:button aura:id="assignButton"  name="{!count}" onclick="{!c.descriptionGet}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}" class="neutralC">
                                                            <a title="Add Product Description">
                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_discription.png" class="epos-class42" />
                                                            </a>
                                                        </lightning:button>
                                                    </td>
                                                    <td width="33%" align="center" valign="bottom" class="epos-class43" id="{!item.product.Id}" name="{!count}">
                                                        <lightning:button aura:id="assignButton" class="neutralC" name="{!count}" onclick="{!c.removeItem}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                                            <a title="Remove Item" >
                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="epos-class19"/>
                                                            </a>
                                                        </lightning:button>
                                                    </td>
                                                    <td width="34%" align="center" valign="top" class="pdng0" id="{!item.product.Id}" name="{!count}">
                                                        <lightning:button aura:id="assignButton" class="neutralC" name="{!count}" onclick="{!c.editItem}" disabled="{!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                                            <a data-toggle="modal" data-target="#myModale" title="Edit Product" class="epos-class44">
                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" class="epos-class19" />
                                                            </a>
                                                        </lightning:button>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </aura:if>
                                    <td align="center" valign="middle"  >
                                        <div class="slds-truncate talignCentre">
                                            <ui:outputText value="{!item.product.ProductCode}" />
                                        </div>
                                    </td>
                                    <td align="center" valign="middle" class="epos-class34" id="{!item.product.Id}">
                                        <div class="slds-truncate epos-class39">
                                            <aura:If isTrue="{!(item.SerialNos.length > 0)}">
                                                <lightning:button aura:id="assignButton" class="borderzero" name="{!count}" onclick="{!c.CurrentSerialNumbers}" ><a data-toggle="modal" data-target="#myModalSerial" title="Serial Numbers"><i class="fa fa-info-circle fsize20" aria-hidden="true" name="{!count}"></i></a></lightning:button>
                                            </aura:If>
                                            <aura:If isTrue="{!(item.Batches.length > 0)}">
                                                <lightning:button aura:id="assignButton" class="borderzero" name="{!count}" onclick="{!c.CurrentBatchNumbers}" ><a data-toggle="modal" data-target="#myModalSerial" title="Batch Numbers"><i class="fa fa-info-circle fsize20" aria-hidden="true" name="{!count}" ></i></a></lightning:button>
                                            </aura:If>
                                            <a href="{!'/'+ item.product.Id}" target="_blank" class="Name pdng10">
                                                <ui:outputText value="{!item.product.Name}"/>
                                            </a>
                                            <aura:If isTrue="{!(item.product.ERP7__Picture__c != undefined)}">
                                                &nbsp;<img src="{!item.product.ERP7__Picture__c}" class="epos-class45" />
                                            </aura:If>
                                        </div>
                                    </td>
                                    <aura:if isTrue="{!equals($Label.c.EPOS_UnitPrice, 'True')}">
                                        <td align="center" valign="middle">
                                            <div class="slds-truncate talignCenter">
                                                <ui:outputNumber value="{!item.price / item.quantity_s}"/>
                                            </div>
                                        </td>
                                    </aura:if>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputNumber value="{!item.quantity_s}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputText value="{!item.product.QuantityUnitOfMeasure}"/>  
                                        </div>
                                    </td>
                                    <!--<td align="center" valign="middle">
                                     <ui:outputNumber value="{!item.rewardPoints}"/>  </td>-->
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputCurrency value="{!item.price}"/>
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputCurrency value="{!item.discount}"/>
                                        </div>
                                    </td>
                                    <aura:if isTrue="{!equals($Label.c.EPOS_Coupon, 'True')}">
                                        <td align="center" valign="middle">
                                            <div class="slds-truncate talignCenter">
                                                <ui:outputCurrency value="{!item.couponDiscount}"/>
                                            </div>
                                        </td>
                                    </aura:if>
                                    <!-- Moin commented this and added below code so that user can update the tax amount on 1st march 2024-->
                                    <!--<td align="center" valign="middle" >
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputCurrency value="{!item.vat+item.tax}"/>
                                        </div>
                                    </td>-->
                                    <td align="left" valign="left" >
                                        <div class="slds-truncate talignCenter" style="width: 100px;">
                                            <ui:inputCurrency value="{!item.vat}" updateOn="keyup"     blur="{!c.updateonTaxChange}" />
                                        </div>
                                    </td>
                                    <td align="center" valign="middle">
                                        <div class="slds-truncate talignCenter">
                                            <ui:outputCurrency value="{!item.priceWithVat}"/>&nbsp;
                                        </div>          
                                    </td>
                                    <td>
                                        <div class="epr_Mark7 slds-no-flex floatright">
                                            <aura:If isTrue="{!	item.product.ERP7__Issue_Purchase_Order__c || item.product.ERP7__Issue_Work_Order__c || item.product.ERP7__Issue_Manufacturing_Order__c || item.product.ERP7__Issue_Purchase_Requisition__c}">
                                               
                                                <div class="dropdown">
                                                    <ui:menu>
                                                        <ui:menuTriggerLink> 
                                                            <button class="slds-button slds-button--icon-border-filled slds-button--icon-x-small dropdown-toggle" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <span class="caret"></span>
                                                            </button> 
                                                        </ui:menuTriggerLink>
                                                        <ui:menuList class="actionMenu" aura:id="actionMenu">
                                                            <aura:If isTrue="{!and(item.product.ERP7__Issue_Purchase_Order__c, v.crudValues.ERP7__PO__c)}">
                                                                <li><a href="javascript:void(0);" onclick="{!c.CreatePO}" data-recordId="{!item.lineitm.Id}" data-toggle="modal" data-target="#myModal2"><span class="slds-form-element__label" >Create Purchase Order</span></a></li>
                                                            </aura:If>
                                                            <aura:If isTrue="{!and(item.product.ERP7__Issue_Purchase_Requisition__c, v.crudValues.ERP7__Requisition__c)}">
                                                                <li><a href="javascript:void(0);" onclick="{!c.CreatePR}" data-recordId="{!item.lineitm.Id}" data-toggle="modal" data-target="#myModal2"><span class="slds-form-element__label" >Create Purchase Requisition</span></a></li>
                                                            </aura:If>
                                                            <aura:If isTrue="{!and(item.product.ERP7__Issue_Work_Order__c, v.crudValues.ERP7__WO__c)}">
                                                                <li ><a href="javascript:void(0);" onclick="{!c.CreateWO}" data-soliId="{!item.lineitm.Id}"><span class="slds-form-element__label" >Create Work Order</span></a></li>
                                                            </aura:If>
                                                            <aura:If isTrue="{!and(item.product.ERP7__Issue_Manufacturing_Order__c, v.crudValues.ERP7__Manufacturing_Order__c)}">
                                                                <li><a href="javascript:void(0);" onclick="{!c.CreateMO}" data-mosoliId="{!item.lineitm.Id}"><span class="slds-form-element__label" >Create Manufacturing Order</span></a></li>
                                                            </aura:If>
                                                        </ui:menuList>
                                                    </ui:menu>
                                                </div>
                                            </aura:If>
                                        </div>
                                        
                                    </td>
                                    
                                </tr>
                            </tbody>
                        </aura:iteration>
                        <tr>
                            <td colspan="10" height="100" bgcolor="#FFFFFF">&nbsp;</td>
                        </tr>
                    </table>
                </div>
                <table class="slds-table slds-table--condensed slds-m-top--medium slds-max-medium-table--stacked-horizontal slds-no-row-hover mb-30"> <!-- slds-max-medium-table-(rm1d)stacked-horizontal -->
                    <tbody>
                        <tr class="rtext epos-class46">
                            <td align="left">Sub Total: </td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input" value="{!v.subTotal}" disabled="true"/>
                            </td>
                            <td align="left">Taxes:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input"  value="{!v.SalesOrder.ERP7__Total_Tax_Amount__c}" disabled="true"/>
                            </td>
                            <td align="left">Shipping Amount:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input"  value="{!v.SalesOrder.ERP7__Total_Shipping_Amount__c}" disabled="true"/>
                            </td>
                            <td align="left">Discounts:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input"  value="{!v.discounts + v.SalesOrder.ERP7__Coupon_Discount__c + v.SalesOrder.ERP7__Product_Coupon_Discount__c}" disabled="true"/>
                            </td>                   
                        </tr>
                        <tr class="rtext">
                            <td align="left">Shipping Discount:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input"  value="{!v.SalesOrder.ERP7__Shipping_Discount__c}" disabled="true"/>
                            </td>
                            <td align="left">Total Amount:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input"  value="{!v.SalesOrder.ERP7__Sales_Order_Amount__c}" disabled="true"/>
                            </td>
                            <!-- totalDue -->
                            <td align="left">Amount Paid:</td>
                            <td align="left">
                                <ui:inputCurrency class="slds-input" value="{!v.SalesOrder.ERP7__Amount_Paid__c }" disabled="true"/>
                            </td>
                            <td align="left" class="fweight-bold">Total Due:</td>
                            <td align="left" width="13%">
                                <ui:inputCurrency class="slds-input" value="{!v.finalDue}" disabled="true"/>
                            </td>
                        </tr>
                        <tr class="rtext height50">
                            <td align="left" class="fweight-bold">&nbsp;</td>
                            <td align="left" width="13%">&nbsp;</td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                            <td align="left">&nbsp;</td>
                            <td align="left">&nbsp; </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <!--<div class="slds-clearfix"></div>-->
            <div class="slds-docked-form-footer">
             
                    <div class="row epos-class47">
                        <div class="col-md-12" >
                            <aura:if isTrue="{!v.FromAR}">
                                <lightning:button label="Back"  class="slds-button slds-button--neutral" onclick="{!c.goBack}"/> &nbsp;
                            </aura:if>
                            <aura:if isTrue="{!v.fromProject}">
                                <lightning:button label="Back"  class="slds-button slds-button--neutral" onclick="{!c.goBackProject}"/> &nbsp;
                            </aura:if>
                            <aura:if isTrue="{!v.Mtask}">
                                <lightning:button label="Back"  class="slds-button slds-button--neutral" onclick="{!c.goBackTask}"/> &nbsp;
                            </aura:if>
                            <a href="javascript:void(0);" onclick="{!c.getAllDetailsInit}"><button class="slds-button slds-button--neutral slds-m-right--small">Reset</button></a>   
                            <aura:If isTrue="{!!(v.SalesOrder.ERP7__Is_Closed__c == true)}">
                                <lightning:button onclick="{!c.draftSave}" class="slds-button slds-button--brand " label="Save"/>
                            </aura:If>
                        </div>
                    </div>
               
            </div>
            <!-- Modal Product Line Items -->
            <div id="myModal" aura:Id="addProductModal" class="slds-modal slds-modal_medium" role="dialog">
                <div>
                    <!-- Modal content-->
                    <div class="slds-modal__container">
                        <div class="slds-modal__content slds-p-around_medium" >
                            <div class="slds-form--inline">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="name">Name</label><br/>
                                    <div class="slds-form-element__control">
                                        <ui:inputText aura:id="so" class="slds-input" value="{!v.itemName}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="prodFam">{!$Label.c.EPOS_Product_Family}</label><br/>
                                    <div class="slds-form-element__control">
                                        <ui:inputSelect class="slds-select slds-selectmaq" aura:id="prodFam" value="{!v.prodFam}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="prodCat">Category</label><br/>
                                    <div class="slds-form-element__control">
                                        <ui:inputSelect class="slds-select slds-selectmaq" aura:id="prodCat" value="{!v.prodCat}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element nodisplay">
                                    <label class="slds-form-element__label" for="prodCat">Sub Category</label><br/>
                                    <div class="slds-form-element__control">
                                        <ui:inputSelect class="slds-select slds-selectmaq" aura:id="prodSubCat" value="{!v.prodSubCat}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="prodCat">Available Only</label><br/>
                                    <div class="slds-form-element__control epos-class48{">
                                        <ui:inputCheckbox aura:id="availablecbox" value="{!v.showAvailable}"/>
                                    </div>
                                </div>
                                <div class="slds-form-element margTop20">
                                    <ui:button class="slds-button slds-button--brand" press="{!c.fetchProduct}"><i class="fa fa-search" aria-hidden="true"></i> Find</ui:button>
                                    
                                </div>
                                
                            </div>
                            <!-- Table -->
                            <div class="row margin0">
                                <aura:If isTrue="true">
                                   
                                    <div id="maindv" class="{!if((v.SerialPopup || v.BatchPopup),'pdng2 width100oc','')}" ><!-- class="{!if(v.SerialPopup,'col-md-8','col-md-12')}" -->
                                        <article class="slds-card slds-m-top--small" >
                                            
                                            <div class="slds-card__body" >
                                                
                                                <div class="maquiScroller">
                                                    <table class="slds-table slds-table--bordered slds-no-row-hover slds-table--cell-buffer">
                                                        <thead >
                                                            <tr class="slds-text-heading--label">
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Action">&nbsp;</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Code">Code</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Product">Product</div>
                                                                </th>
                                                                <th></th>
                                                                <!--<aura:If isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                    <th scope="col">
                                                                        <div class="slds-truncate" title="Version">Version</div>
                                                                    </th>
                                                                </aura:If>-->
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Price">Price</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Quantity">Charge/Qty</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="UoM">UoM</div>
                                                                </th>
                                                                <aura:If isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                    <th scope="col">
                                                                        <div class="slds-truncate" title="Discount">Discount</div>
                                                                    </th>
                                                                </aura:If>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="UoM">Description</div>
                                                                </th>
                                                                <th scope="col" class="talignCenter">
                                                                    <div class="slds-truncate" title="Availability">Availability</div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <aura:if isTrue="{!v.ProductsAndDiscountsWrapperListt.length > 0}">
                                                                <aura:iteration var="pro" indexVar="count" items="{!v.ProductsAndDiscountsWrapperListt}">
                                                                <aura:if isTrue="{!(v.showAvailable)?equals(pro.showcbox,v.showAvailable):true}">
                                                                    <tr class="slds-hint-parent">
                                                                        <td align="center">
                                                                            <div class="slds-truncate epos-class49" title="Action" >
                                                                                <ui:inputCheckbox aura:id="sel" value="{!pro.selected}" disabled="{!not(pro.showcbox)}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td align="center">
                                                                            <div class="slds-truncate" title="Code" >
                                                                                <ui:outputText aura:id="code" value="{!pro.product.ProductCode}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate epos-class34" title="Product"  id="{!pro.product.Id}">
                                                                                <ui:outputText value="{!pro.product.Name}" click="{!c.NavRecord}" title="{!pro.product.Id}"/>
                                                                                <aura:If isTrue="{!(pro.product.ERP7__Picture__c != undefined)}">
                                                                                    &nbsp;<img src="{!pro.product.ERP7__Picture__c}" class="epos-class45" />
                                                                                </aura:If>
                                                                            </div>
                                                                        </td>
                                                                        <aura:If isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                            <td>
                                                                                <div class="row">
                                                                                    <aura:If isTrue="{!and(pro.product.ERP7__Configure__c == true, pro.Version != '', pro.Version != undefined)}">
                                                                                        <div class="col-md-2">
                                                                                            <i class="fa fa-cogs epos-class50" aria-hidden="true"  data-versionId="{!pro.Version}" data-proId="{!pro.product.Id}" onclick="{!c.Configure}" data-toggle="modal" data-target="#configModal" title="Configure Product"></i>
                                                                                        </div>
                                                                                    </aura:If>
                                                                                </div>
                                                                            </td>
                                                                        </aura:If>
                                                                        <td>
                                                                            <div class="slds-truncate" title="Price">
                                                                                <ui:inputCurrency value="{!pro.pricebookEntry.UnitPrice}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate" title="Charge/Qty" name="{!count}" id="{!pro.product.Id}">
                                                                                <ui:inputText value="{!pro.quantity_s}" aura:id="quan" class="slds-input charge" change="{!c.addDiscount}" labelClass="{!count}"/> <!-- addDiscount-->
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate" title="UoM" name="{!count}" id="{!pro.product.Id}">
                                                                                <ui:outputText value="{!pro.product.QuantityUnitOfMeasure}"/>
                                                                            </div>
                                                                        </td>
                                                                        <aura:If isTrue="{!!(v.SerialPopup || v.BatchPopup)}">
                                                                            <td>
                                                                                <div class="row">
                                                                                    <div class="col-md-4 epos-class51" title="Discount" name="{!count}" id="{!pro.product.Id}" >
                                                                                        <ui:inputSelect class="slds-select discnt" aura:id="dis" value="{!pro.discountName}" change="{!c.discountPercents}" labelClass="{!count}">
                                                                                            <aura:iteration items="{!pro.CurrentDiscounts}" var="po">
                                                                                                <ui:inputSelectOption text="{!po.value}" label="{!po.label}" value="{!if(po.value==pro.discountName,true,false)}"/>
                                                                                                <!--value="{!if(pro.discountName == p.value,true,false)}"-->
                                                                                            </aura:iteration>
                                                                                        </ui:inputSelect>
                                                                                    </div>
                                                                                    <div class="slds-truncate col-md-3 epos-class52"  title="Discount/Unit" name="{!count}" id="{!pro.product.Id}">
                                                                                        <ui:inputText aura:id="discountPer" labelClass="{!count}" value="{!pro.discountPercent}"  keyup="{!c.addvalidatevaluek}" change="{!c.addvalidatevalue}" updateOn="keyup" class="slds-input" placeholder="{!if(pro.isPercent == true,'Percentage','Value')}"/>
                                                                                        <!--keyup="{!c.validatevalue}"-->
                                                                                    </div>
                                                                                    <div class="slds-truncate col-md-5 epos-class53">
                                                                                        [<ui:outputNumber value="{!pro.minDiscountPercent}"/>-<ui:outputNumber value="{!pro.maxDiscountPercent}"/>]
                                                                                        <aura:If isTrue="{!(pro.isPercent == true)}">%</aura:If>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </aura:If>
                                                                        <td>
                                                                            <div class="slds-truncate" title="Description" name="{!count}" id="{!pro.product.Id}">
                                                                                <!--ui:inputTextArea value="{!pro.product.Description}"/--> <!--changed by Arshad 31 july 23 for javascript error on epos search products screen -->
                                                                                <lightning:textarea variant="label-hidden" value="{!pro.product.Description}"/>
                                                                            </div>
                                                                        </td>
                                                                        <td class="pdng3">
                                                                            <div class="slds-truncate talignCenter" title="Availability" >
                                                                                <div class="slds-grid" >
                                                                                    <div class="slds-col">
                                                                                        <lightning:button aura:id="assignButton" class="{!(pro.showcbox)? (and(equals(pro.stock,0),or(pro.product.ERP7__Allow_Pre_Orders__c,pro.product.ERP7__Allow_Back_Orders__c)))? 'slds-button slds-button--brand orange':'slds-button slds-button--brand green':'slds-button slds-button--brand grey'}" name="{!count}" onclick="{!(pro.product.ERP7__Serialise__c)?c.getSerials:(pro.product.ERP7__Lot_Tracked__c)?c.getBatches:c.NewProduct}">
                                                                                            {!pro.product_Type}
                                                                                            <aura:If isTrue="{!and(pro.stock > 0,(pro.product.ERP7__Serialise__c || pro.product.ERP7__Lot_Tracked__c))}">
                                                                                                <i class="fa fa-chevron-circle-right epos-class54" aria-hidden="true" ></i>
                                                                                            </aura:If>
                                                                                        </lightning:button>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    
                                                                    <tr class="heightauto">
                                                                        <td class="epos-class55"></td>
                                                                        <aura:If isTrue="{!(v.showAvailable)?equals(pro.showcbox,v.showAvailable,(pro.SerialNos.length > 0 || pro.Batches.length > 0)):equals(!v.showAvailable,(pro.SerialNos.length > 0 || pro.Batches.length > 0))}">
                                                                            <td colspan="6" class="epos-class56">
                                                                                <aura:If isTrue="{!pro.SerialNos.length > 0}">
                                                                                    <aura:iteration var="Serial" indexVar="serialCounts" items="{!pro.SerialNos}">
                                                                                        <a href="{!'/'+ Serial.Id}" target="_blank" >
                                                                                            <span class="fsize12"> {!Serial.Name} </span>
                                                                                        </a>
                                                                                        <lightning:buttonIcon iconName="utility:close" variant="close" onclick="{!c.removeSerialNew}" alternativeText="Remove Serial" title="{!count}" name="{!serialCounts}" class="RemoveSerial"/>
                                                                                        &nbsp;
                                                                                    </aura:iteration> 
                                                                                </aura:If>
                                                                                <aura:If isTrue="{!pro.Batches.length > 0}">
                                                                                    <aura:iteration var="batch" indexVar="batchCounts" items="{!pro.Batches}">
                                                                                        <a href="{!'/'+ batch.Id}" target="_blank" >
                                                                                            <span class="fsize12"> {!batch.Name} </span>
                                                                                        </a>
                                                                                        <lightning:buttonIcon iconName="utility:close" variant="close" onclick="{!c.removeBatchNew}" alternativeText="Remove Batch" title="{!count}" name="{!batchCounts}" class="RemoveSerial"/>
                                                                                        &nbsp;
                                                                                    </aura:iteration> 
                                                                                </aura:If>
                                                                            </td>
                                                                        </aura:If>
                                                                    </tr>                                           
                                                                    
                                                                </aura:if>
                                                            </aura:iteration>
                                                                <aura:set attribute="else">
                                                                    <tr>
                                                                        <td colspan="10">
                                                                            <div class="slds-notify slds-notify_alert slds-alert_warning" role="alert">
                                                                                <span class="slds-assistive-text">warning</span>
                                                                                <span class="slds-icon_container slds-icon-utility-warning customheight34 slds-m-right_x-small" title="Description of icon when needed">
                                                                                    <lightning:icon iconName="utility:warning" size="x-small"></lightning:icon>
                                                                                    
                                                                                </span>
                                                                                <h2 class="mt-0 mb-0">Products not found
                                                                                </h2>
                                                                                
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                </aura:set>
                                                            </aura:if>
                                                            
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            
                                        </article>
                                    </div>
                                </aura:If>
                                <aura:If isTrue="{!(v.BatchPopup)}">
                                    <div class="Serial" id="demo1">
                                        <article class="slds-card slds-m-top--small">
                                            <header class="slds-card__header slds-grid">
                                                <div class="slds-media slds-media--center slds-has-flexi-truncate">
                                                    <div class="epos-class57">
                                                        <ui:inputText value="{!v.BatchNumber}" class="slds-input" placeholder="Batch Number"/>
                                                    </div>
                                                    <div class="epos-class58">
                                                        <lightning:button aura:id="assignButton" class="slds-button slds-button--brand" name="" onclick="{!c.getBatches}">
                                                            <i class="fa fa-search" aria-hidden="true"></i> Search
                                                        </lightning:button>
                                                    </div>
                                                </div>
                                                <div class="slds-no-flex">
                                                </div>
                                                <button type="button" class="close1" id="demo1" onclick="{!c.NewProduct}">&times;</button>
                                            </header>
                                            <div class="slds-card__body" >
                                                
                                                <div class="maquiScroller epos-class59">
                                                    <table class="slds-table slds-table--bordered slds-no-row-hover slds-table--cell-buffer">
                                                        <thead >
                                                            <tr class="slds-text-heading--label">
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Action">&nbsp;</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Batch Number">Batch.No</div>
                                                                </th>
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Product">Product</div>
                                                                </th>
                                                                
                                                                <th scope="col">
                                                                    <div class="slds-truncate" title="Availability">Availability</div>
                                                                </th> 
                                                                
                                                            </tr>
                                                        </thead>
                                                        <aura:iteration var="SLN" indexVar="counts" items="{!v.pdLists}">
