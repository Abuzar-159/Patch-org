                                                                                <div class="slds-truncate" title="Product">Product</div>
                                                                            </th>
                                                                            <th scope="col">
                                                                                <div class="slds-truncate" title="Fixed Asset">Fixed Asset</div>
                                                                            </th>
                                                                            <aura:If isTrue="{!(v.IsRental)}">
