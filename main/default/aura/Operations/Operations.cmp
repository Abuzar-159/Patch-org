<aura:component controller="ProductConfig">
    <ltng:require styles="/resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.css" />
	<aura:attribute name="routeOperations" type="Operation__c" default="{'sObjectType':'ERP7__Operation__c',
                                                                              'Name':'',
                                                                              'ERP7__Operation_No__c':'',
                                                                              'ERP7__Setup_Time__c':'',
                                                                              'ERP7__Run_Time__c':'',
                                                                              'ERP7__Wait_Time__c':'',
                                                                              'ERP7__Move_Time__c':'',
                                                                              'ERP7__Quantity__c':'',
                                                                              'ERP7__Variable_Cost__c':'',
                                                                              'ERP7__Fixed_Cost__c':''}"/>
    <div id="content-path-1" class="slds-tabs--path__content slds-show" role="tabpanel" aria-labelledby="tab-path-1">
        <div class="epr_Mark7">
            <div class="row slds-m-top--small">
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="text" Label="Name" value="{!v.routeOperations.Name}" maxlength="30" />
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Operation No" value="{!v.routeOperations.ERP7__Operation_No__c}" maxlength="30" />
                    </div>
                </div>

                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Setup Time" value="{!v.routeOperations.ERP7__Setup_Time__c}" maxlength="30" />
                    </div>

                </div>
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Run Time" value="{!v.routeOperations.ERP7__Run_Time__c}" maxlength="30" />
                    </div>
                </div>



                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Wait Time" value="{!v.routeOperations.ERP7__Wait_Time__c}" maxlength="30" />
                    </div>
                </div>

                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Move Time" value="{!v.routeOperations.ERP7__Move_Time__c}" maxlength="30" />
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Quantity" value="{!v.routeOperations.ERP7__Quantity__c}" maxlength="30" />
                    </div>
                </div>

                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Variable Cost" value="{!v.routeOperations.ERP7__Variable_Cost__c}" maxlength="30" />
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <lightning:input type="number" label="Fixed Cost" value="{!v.routeOperations.ERP7__Fixed_Cost__c}" maxlength="30" />
                    </div>
                </div>
                <!--<aura:renderIf isTrue="{!v.operations[0]!=opr}">-->
                <div class="col-md-1">
                    <div class="slds-form-element">
                        <label class="slds-form-element__label" for="text-input-01"></label>
                        <div class="slds-form-element__control">
                            <a class="svg" onclick="{!c.handleDelClick}">
                                                    <img src="/resource/ERP7__SLDS0121/assets/icons/action/delete_60_red.png" height="22" title="Remove Item" width="22" class="curpointer" />
                                                </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</aura:component>