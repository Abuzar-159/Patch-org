<aura:component controller="MultipleManufacturingOrder" implements="force:appHostable">
    <aura:attribute name="errorMsg" type="String" default=""/>
	<aura:attribute name="flows" type="String" default="initial"/>
    <aura:attribute name="Container" type="Object"/>
    <aura:attribute name="selProdStockList" type="String[]"/>
    <aura:attribute name="searchText" type="String" default=""/>
    <aura:attribute name="channelId" type="String" default=""/>
    <aura:attribute name="dChannelId" type="String" default=""/>
    <aura:attribute name="itemToDel" type="String" default=""/>
    <!--<aura:attribute name="MOrderStatus" type="List"/>-->
    <aura:attribute name="MOrder2Insert" type="object"/>
    <!--<aura:attribute name="CreatedMOs" type="Object"/>-->
    <aura:attribute name="SOAccess" type="boolean" default="true"/>
    <aura:attribute name="show" type="String" default="{!$Label.c.Pagination_Default_Limit}"/><!--10-->
    
    
    <aura:attribute name="Spinner" type="boolean" default="false"/>
    <!--<aura:handler name="init" value="{!this}" action="{!c.fetchAllProducts}"/>-->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="change" value="{!v.dChannelId}" action="{!c.fetchAllProducts}"/>
    <aura:method name="LoadNow" action="{!c.LoadNow}"></aura:method>
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css" />
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/MultipleManufacturingOrder.css"/>
    <ltng:require styles="/resource/ERP7__axoltmain/Assets/css/axolt-main.css" />
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
	   
    <aura:if isTrue="{!v.Spinner}">
        <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}"/>        
    </aura:if>
    
    <div class="theme-bg multiplemanufacturing bgmain">    
        <div class="{!if(and(v.errorMsg != '', v.errorMsg != undefined),'slds-notify_container slds-is-fixed displaynone1','slds-notify_container slds-is-fixed displaynone')}">           
            <div class="slds-notify slds-notify_toast slds-theme_error" role="status" >
                <span class="slds-assistive-text">{!$Label.c.error}</span>
                <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top slds-icon1">
                    <lightning:buttonIcon iconName="utility:error" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" size="medium" variant="bare-inverse" />
                </span>
                <div class="slds-notify__content">
                    <div > <!--class="alert alert-danger" role="alert">-->
                        {!v.errorMsg}
                    </div>
                    
                </div>
                <div class="slds-notify__close" >
                    <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                        <lightning:buttonIcon iconName="utility:close"  variant="bare-inverse" title="Close" alternativeText="{!$Label.c.Close_window}" size="medium"/>
                        <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                    </button>
                </div>
            </div>
        </div>
        
        
        <aura:if isTrue="{!equals(v.flows,'initial')}">
            <div class=" slds-container--fluid theme-bg cpq ">
                <div class="container-fluid theme-bg mt-2">
                    
                    <div class="row">
                        <div class="col-sm-12">
                           
                            <div class="card">
                                <div class="card-body profile-user-box">
                                    
                                    <div class="row">
                                        <div class="col-sm-8">
                                            <div class="row align-items-center">
                                                <div class="col-auto">
                                                    <div class="avatar-md">
                                                        <img src="/resource/ERP7__axoltmain/Assets/img/3876332-200.png" alt="" class="rounded-circle img-thumbnail"/>
                                                        </div>
                                                    </div>
                                                    <div class="col">
                                                        <div>
                                                            <h4 class="mt-1 mb-1">{!$Label.c.Multi_Manufacturing_Orders}</h4>
                                                            
                                                            <ul class="mb-0 list-inline">
                                                                <li class="list-inline-item me-3">
                                                                    <div class="slds-grid">
                                                                        <div class="slds-col">
                                                                            <Lightning:input placeholder="{!$Label.c.Search_Products}" value="{!v.searchText}" oncommit ="{!c.LoadNow}" maxlength='80'/>
                                                                        </div>
                                                                        
                                                                    </div>
                                                                </li>
                                                               
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div> <!-- end col-->
                                            
                                            <div class="col-sm-4 p-0">
                                                <div class="text-left mt-sm-0 mt-3 text-sm-start">
                                                    <div class="slds-grid" >
                                                        <div class="slds-col slds-m-right--xx-small">
                                                            <div class="newClass5">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Channel__c" IconName="custom:custom24" selectedRecordId="{!v.channelId}" label="{!$Label.c.Channel_StockTake}" />
                                                            </div>
                                                        </div>
                                                        <div class="slds-col">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                                <div class="newClass5"> 
                                                                    <c:CustomInputLookUp objectAPIName="ERP7__Distribution_Channel__c" required="true" IconName="custom:custom32"  selectedRecordId="{!v.dChannelId}" label="{!$Label.c.Distribution_Channel_StockRunRate}" qry="{!'And ERP7__Channel__c = \''+v.channelId+'\''}" inputStyleclass=""/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                    </div> 
                                                </div>
                                            </div> 
                                        </div>
                                        
                                    </div> 
                                </div>
                            </div> 
                        </div>
                    
              	  
                </div>
            
        
            
           </div>  
           
            <div class="container-fluid bg-white">
            	<div class="card mb-0">
                    <div class="card-body">
                        <table class="slds-table slds-table_bordered">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>{!$Label.c.Name_ManageLeave}</th>
                                    <th>{!$Label.c.UOM}</th>
                                    <th>{!$Label.c.InventoryConsole_Items_in_Stock}</th>
                                    <th>{!$Label.c.POLI_Awaiting_Stock}</th>
                                    <th>{!$Label.c.Demand_UsersShiftMatch}</th>
                                    
                                    <th width="12%">{!$Label.c.Quantity_To_Produce}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.Container.prodStockList}" var="pro" indexVar="ind">
                                    <tr>                                        
                                        <td>
                                            <lightning:input type="checkbox" checked="{!pro.isSelected}" onchange="{!c.SelectItem}" class="no-input-lable" title="{!pro.prod.Id}"/>
                                        </td>
                                        <td>
                                            <div class="max-width200p">
                                                <lightning:formattedUrl value="{!'/'+pro.prod.Id}" label="{!pro.prod.Name}"  target="_blank" title="{!pro.prod.Name}"/>
                                            </div>
                                            </td>
                                        <td>
                                            <div class="slds-truncate max-width140p" title="{!pro.prod.QuantityUnitOfMeasure}">
                                          	  {!pro.prod.QuantityUnitOfMeasure}
                                            </div>
                                            </td>
                                        <td>
                                            <aura:if isTrue="{!pro.demand > pro.stock}">
                                                <div class="badge bg-danger width60c">
                                                    {!pro.stock}
                                                </div>
                                                <aura:set attribute="else">
                                                    <div class="badge bg-success width60c">
                                                        {!pro.stock}
                                                    </div>
                                                </aura:set>
                                            </aura:if>
                                        </td>
                                        <td>
                                             <div class="badge bg-warning width50c">
                                        		{!pro.AwaitingStock}
                                            </div>
                                        </td>
                                        <td>
                                             <div class="badge bg-warning width60c">
                                        		{!pro.demand}
                                            </div>
                                        </td>
                                        
                                        <td width="12%"> 
                                            <lightning:input type="number" class="no-input-lable" value="{!pro.prod.ERP7__MOQ__c}" maxlength="10"/>
                                        </td>
                                    </tr>
                                </aura:iteration>                                
                            </tbody>                            
                        </table>
                        <aura:if isTrue="{!v.Container.prodStockList.length == 0}">
                            <div class="slds-notify slds-notify_alert slds-alert_warning" role="alert">
                                <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>                                        
                                <h2>{!$Label.c.Product_Not_Found}</h2>                                    
                            </div>
                        </aura:if>
                    </div>
            </div>
            </div>
            <div class="cpq">
                <div class="row m-0 pb-70 pt-2 bg-white">
                    <div class="col-lg-2 class38">
                        <div class="slds-grid" >
                            <div class="slds-col text-right pt-1">
                                {!$Label.c.Acc_Recev_Show}&nbsp;&nbsp;
                            </div>
                            <div class="slds-col" >
                                <lightning:select value="{!v.show}" onchange="{!c.SetShow}" variant="label-hidden" class="display-lable">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </lightning:select>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 text-center pt-2" >
                        {!$Label.c.Acc_Recev_Showing} <span class="text-lightblue">{!v.Container.startCount}-{!v.Container.endCount}</span> {!$Label.c.Acc_Recev_of_total} <span class="text-lightblue"> {!v.Container.recSize} </span> {!$Label.c.Acc_Recev_Records}
                    </div>
                    
                    <div class="col-md-4 class41">
                        <nav aria-label="Page navigation example">
                            <ul class="pagination class42">
                                <li class="class43" >
                                    <a class="{!if(1 >= v.Container.startCount,'class44','class45')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> 
                                </li>
                                <li class="class50" >
                                    <a class="{!if(1 >= v.Container.startCount,'class44','class45')}"  onclick="{!c.Previous}">  {!$Label.c.Previous}</a> 
                                </li>                                
                                <li class="class50" >
                                    <a class="{!if(v.Container.endCount == v.Container.recSize,'class46','class47')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> 
                                </li>
                                <li class="class51" >
                                    <a class="{!if(v.Container.endCount == v.Container.recSize,'class46','class47')}" onclick="{!c.NextLast}">&gt;&gt; </a> 
                                </li>
                            </ul>
                        </nav> 
                    </div>
                    
                    
                    <div class="col-md-3" >
                        <div class="slds-grid">
                            <div class="slds-col pr-2 text-right pt-1">
                                Page 
                            </div>
                            <div class="col-5 class53">
                                <lightning:input type="number" value="{!v.Container.PageNum}" variant="label-hidden" class="display-lable width100" oncommit="{!c.OfsetChange}" maxlength="10"/>
                            </div>
                            <div class="slds-col text-left pl-2" ><span class="text-lightblue"> of {!v.Container.PNS.length}</span>
                            </div>
                        </div>
                    </div> 
                    
                </div> 
            </div>
            <div class="slds-docked-form-footer">
                	
                    <lightning:button label="{!'Continue ('+v.selProdStockList.length+')'}" onclick="{!c.multiMOPage}" variant="brand"  disabled="{!v.selProdStockList.length == 0}" iconName="utility:chevronright" iconPosition="right"/>&nbsp;
                	<!--<span class="slds-button slds-button_neutral cursor" onclick="{!c.openModal}">
                       <i class="fa fa-cart-arrow-down me-1"></i> 
                        <lightning:formattedText value="{!'Selected ('+v.selProdStockList.length+')'}" class="cursor ">
                                              
                         </lightning:formattedText>
                	</span>-->
            </div>
            
        </aura:if>
        
        <aura:if isTrue="{!equals(v.flows,'multiMOPage')}">
            <div class="container-fluid shakaal">
                <div class="card mt-2">
                    <div class="card-body pb-5">
                        <table class="slds-table slds-table_bordered mb-0">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>{!$Label.c.AddSubscription_Product}</th>
                                    <th>Version</th>
                                    <th>{!$Label.c.Routing}</th>
                                    <th>{!$Label.c.MO_Owner}</th>
                                    <th>{!$Label.c.QuotationPDF_Quantity}</th>
                                    <th>{!$Label.c.Expected_Date}</th>
                                    <!--<th>Status</th>-->
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.MOrder2Insert}" var="mo" indexVar="ind">
                                    <tr class="{!if(mo.ERP7__Product__c=='','displaynone','displaynone1')}"><!---->
                                        <td>{!ind+1} </td>
                                        <td>
                                            <div class="slds-form-element__control">
                                                <c:CustomInputLookUp objectAPIName="Product2" aura:id="mpr" IconName="standard:product" selectedRecordId="{!mo.ERP7__Product__c}" hideRemove="true" required="true"/> 
                                            </div>
                                        </td>
                                        <td>
                                            <div class="slds-form-element__control">
                                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c" aura:id="mvr" IconName="standard:flow" selectedRecordId="{!mo.ERP7__Version__c}" qry="{!' And ERP7__Product__c = \''+mo.ERP7__Product__c+'\''}" required="true"/> 
                                            </div>
                                        </td>
                                        <td>
                                            <div class="slds-form-element__control">																		
                                                <c:CustomInputLookUp objectAPIName="ERP7__Routing__c" aura:id="mrt" IconName="standard:environment_hub" selectedRecordId="{!mo.ERP7__Routing__c}" qry="{!' AND ERP7__Product__c =\''+mo.ERP7__Product__c+'\' AND ERP7__BOM_Version__c =\''+mo.ERP7__Version__c+'\''}" required="true"/> 
                                            </div>
                                        </td>
                                        <td>
                                            <div class="slds-form-element__control">																		
                                                <c:CustomInputLookUp objectAPIName="User" aura:id="mrt" IconName="standard:avatar" selectedRecordId="{!mo.ERP7__Owner__c}" qry="{!' AND IsActive =true'}" required="true"/> 
                                            </div>
                                        </td>
                                        <td>
                                            <div class="slds-form-element__control no-display">
                                                <lightning:input type="Number"  value="{!mo.ERP7__Quantity__c}" maxlength="10"/> 
                                            </div>
                                        </td>
                                        <td>
                                            <div class="slds-form-element__control">
                                                <lightning:input type="datetime" value="{!mo.ERP7__ExpectedDate__c}" variant="label-hidden" required="true"/> 
                                            </div>
                                        </td>                            
                                        <!--<td>
                                <span class="badge bg-primary width60c">Draft</span>
                            </td>-->
                                        <td>
                                            <lightning:buttonIcon alternativeText="{!$Label.c.Delete_UserAvailabilities}" onclick='{!c.delOpenModal}' iconName="utility:delete"  variant="destructive" title="{!mo.ERP7__Product__c}" class="delete-icon" />
                                            <!--<lightning:icon  iconName="action:delete" size="xx-small" variant="error" onclick="{!c.removeItem}" title="{!ind}" class="cursor"  ></lightning:icon>-->
                                        </td>
                                    </tr>
                                </aura:iteration>  
                                
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <aura:if isTrue="{!v.selProdStockList.length ==0}">
                <div class="slds-notify slds-notify_alert slds-alert_warning" role="alert">
                    <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>
                    
                    <h2>{!$Label.c.Item_Not_Available}</h2>                                    
                </div>
            </aura:if>
            
            <!--<div class="margbt">
                <aura:iteration items="{!v.MOrder2Insert}" var="mo" indexVar="index">
                    <div class="container-fluid">
                        <div class="card mt-2">
                            <div class="card-body">
                                <div class="dropdown float-end">
                                    <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown" aria-expanded="false">
                                      <lightning:icon iconName="utility:chevrondown" size="x-small"></lightning:icon> 
                                    </a>
                                   
                                </div>
                                
                                <h4 class="header-title mb-1">MO - {!index+1}</h4>
