                                                        <c:CustomInputLookUp objectAPIName="Product2" aura:id="mpr" IconName="standard:product" selectedRecordId="{!mo.ERP7__Product__c}" inputStyleclass="slds-input" hideRemove="true" required="true"/> 
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">Production Version <span class="MOs_class17">*</span></label>
                                                    <div class="slds-form-element__control" onmouseover="{!c.lookupClickVersion}">
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Version__c" aura:id="mvr" IconName="standard:flow" selectedRecordId="{!mo.ERP7__Version__c}" inputStyleclass="slds-input" qry="{!' And ERP7__Product__c = \''+mo.ERP7__Product__c+'\''}" required="true"/> 
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">{!$Label.c.MO_ProductQty} <span class="MOs_class17">*</span></label>
                                                    <div class="slds-form-element__control no-display">
                                                        <lightning:input type="Number"  value="{!mo.ERP7__Quantity__c}"/> </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> 
                                                    <div class="slds-form-element__control">
                                                        <lightning:select  aura:id="moStatus" value="{!mo.ERP7__Status__c}" label="Status">
                                                            <aura:iteration items="{!v.MOrderStatus}" var="pckopt"  >
                                                                <option value="{!pckopt.value}" selected="{!(pckopt.value == mo.ERP7__Status__c)}">{!pckopt.label}</option>   
                                                            </aura:iteration>
                                                        </lightning:select> 
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                   
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">Routing <span class="MOs_class17">*</span></label>
                                                    <div class="slds-form-element__control" onmouseover="{!c.lookupClickRouting}">																		
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Routing__c" aura:id="mrt" IconName="standard:environment_hub" selectedRecordId="{!mo.ERP7__Routing__c}" qry="{!' AND ERP7__Product__c =\''+mo.ERP7__Product__c+'\' AND ERP7__BOM_Version__c =\''+mo.ERP7__Version__c+'\''}" required="true"/> 
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">Start Date <span class="MOs_class17">*</span></label>
                                                    <div class="slds-form-element__control">
                                                        <lightning:input type="datetime"  value="{!mo.ERP7__StartDate__c}"  variant="label-hidden" required="true"/> </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="">
                                                <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">Expected Date <span class="MOs_class17">*</span></label>
                                                    <div class="slds-form-element__control">
                                                        <lightning:input type="datetime" value="{!mo.ERP7__ExpectedDate__c}" variant="label-hidden" required="true"/> </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                    </div>
</div>
                            </div>
                        </div> 
            </div>
            </aura:iteration>
            </div>-->
            
            
            
            
            <div class="slds-docked-form-footer">
                <lightning:button label="{!$Label.c.EmployeeReviewV2_Back}"  onclick="{!c.backToInitial}" iconName="utility:chevronleft" class="width140p" iconPosition="left"/>
                <lightning:button label="{!$Label.c.Schedule_MO}" variant="brand" iconName="utility:chevronright"  onclick="{!c.createMO}" iconPosition="right" disabled="{!v.selProdStockList.length ==0}"/><!---->
            </div>
        </aura:if>
        
        <section aura:id="delModal" role="dialog" tabindex="-1" aria-labelledby="delModalHeading" aria-modal="true" aria-describedby="delModalBody" class="slds-modal slds-modal_xx-small">
            <div class="slds-modal__container wd30">
                <div class="slds-modal__content slds-p-around_medium" id="ModalBody">
                    <p class="align-text">
                        {!$Label.c.Do_you_want_to_Delete_Item}
                    </p><br/><br/>
                    <div class="slds-grid align-center">
                        <lightning:button onclick="{!c.delcloseModal}" variant="neutral">{!$Label.c.Cancel_UserAvailabilities}</lightning:button>
                        <lightning:button onclick="{!c.removeItem}" variant="brand" >{!$Label.c.Delete_UserAvailabilities}</lightning:button>
                    </div>                    
                </div>
            </div>
        </section>
        <div aura:id="delModalBackdrop" class="slds-backdrop"></div>
        
        
        <!--<aura:if isTrue="{!equals(v.flows,'MOListPage')}">
            
           <div class="container-fluid mt-2">
            <div class="card">
                <div class="card-body">
                    <h4 class="header-title mb-3">All Created Manufacturing Orders</h4>
                    
                    <div class="table-responsive">
                        <table class="table table-hover table-centered mb-0">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Name</th>
                                    <th>Quantity</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <aura:iteration items="{!v.CreatedMOs}" var="cmo" indexVar="ind">
                                <tr>
                                    <td>{!ind+1}</td>
                                    <td>{!cmo.Name}</td>
                                    <td>{!cmo.ERP7__Quantity__c}</td>
                                    <td><span class="{!if((cmo.ERP7__Status__c == 'Draft'),'badge bg-primary width60c displaynone1','badge bg-secondary displaynone')}">
                                        {!cmo.ERP7__Status__c}
                                        </span>
                                        <span class="{!if((cmo.ERP7__Status__c == 'Release'),'badge bg-secondary width60c displaynone1','badge bg-primary displaynone')}">
                                        {!cmo.ERP7__Status__c}
                                        </span>
                                        <span class="{!if((cmo.ERP7__Status__c == 'In Progress'),'badge bg-warning width60c displaynone1','badge bg-warning displaynone')}">
                                        {!cmo.ERP7__Status__c}
                                        </span>
                                        <span class="{!if((cmo.ERP7__Status__c == 'Complete'),'badge bg-success width60c displaynone1','badge bg-success displaynone')}">
                                        {!cmo.ERP7__Status__c}
                                        </span>
                                        <span class="{!if((cmo.ERP7__Status__c == 'Cancelled'),'badge bg-danger width60c displaynone1','badge bg-danger displaynone')}">
                                        {!cmo.ERP7__Status__c}
                                        </span>
                                    </td>
                                </tr>
                            </aura:iteration>
                                
                               
                            </tbody>
                        </table>
                    </div> 
                </div> 
            </div>
            </div>
            <div class="slds-docked-form-footer">
                <lightning:button label="Home" variant="brand" class="width140p" onclick="{!c.navigateHome}" iconPosition="left" iconName="utility:home"/>
            </div>
        </aura:if>-->
        
    </div>
