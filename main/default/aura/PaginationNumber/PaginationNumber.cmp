<aura:component  implements="force:appHostable,forceCommunity:availableForAllPageTypes" access="global">     
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-ltng.css" /> 
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css" /> 
    <ltng:require styles="/resource/ERP7__InviteIcons/ERP7custom/css/ERP7-ie7-codes.css,
                          /resource/ERP7__InviteIcons/ERP7custom/css/ERP7-ie7-codes.css,/resource/ERP7__InviteIcons/ERP7custom/css/ERP7-ie7.css,
                           /resource/ERP7__InviteIcons/ERP7custom/css/ERP7-embedded.css,/resource/ERP7__InviteIcons/ERP7custom/css/ERP7-codes.css                             
                          ,/resource/ERP7__InviteIcons/ERP7custom/css/ERP7.css,/resource/ERP7__InviteIcons/ERP7custom/css/animation.css,
                           /resource/ERP7__EROK2/Src/css/font-awesome.css
                           ,/resource/ERP7__EROK2/Src/css/stylecalendar.css,
                            /resource/ERP7__bootstrap/bootstrap/css/bootstrap.css, 
                           /resource/ERP7__bootstrap/bootstrap/css/bootstrap.min.css,
                           /resource/ERP7__Event_Rok0277/Event_Rok0277/assets/styles/erp_mark7_bootstrap.css                                                          
    "/> 
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/PaginationNumber.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doinit}" />
    <aura:attribute name="counter" type="Integer" default="0"/>
    <aura:attribute name="limitSize" type="Integer" default="10"/>
    <aura:attribute name="totalSize" type="Integer" default="0"/>
    <aura:attribute name="pageNumbers" type="String[]" default="1"/> 
    
    <aura:attribute name="Entries" type="Integer" default="2"/>
    <aura:attribute name="nextDisa" type="Boolean" default="false"/>
    <aura:attribute name="prevDisa" type="Boolean" default="true"/>
    <aura:attribute name="RecordList" type="String[]" default=""/>    
    <aura:registerEvent name="PaginationEvent" type="c:PaginationEvent"/> 
    <aura:handler name="change" value="{!v.RecordList}" action="{!c.doinit}"/>
                  
   <div class="PaginationNumber-newClass1">
        <lightning:button variant="brand" label="Previous" onclick="{!c.previous}" disabled="{!v.prevDisa}" /> &nbsp;&nbsp;&nbsp;&nbsp;     
         <aura:iteration items="{!v.pageNumbers}" var="pn">          
             <a class="" aura:id="PNIds">{!pn}</a> &nbsp;  
        </aura:iteration>       
       &nbsp;&nbsp;&nbsp;&nbsp;
       <lightning:button variant="brand" label="Next" onclick="{!c.next}" disabled="{!v.nextDisa}" aura:id="AllNextId"/>  
       
       
  </div>
</aura:component>