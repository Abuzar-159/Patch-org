                                                                                        <lightning:formattedText  value="{!LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Vendor_product_Name__c}" class=""/>
                                                                                    </div>
                                                                                </div>
                                                                            </aura:if>
                                                                            
                                                                            <div class="slds-col">
                                                                                <label class="slds-form-element__label" >{!$Label.c.Expected_QTY}</label>
                                                                                <div class="slds-p-top_small ri-mx150">
                                                                                    <span class="badge bg-primary"> <strong><lightning:formattedNumber value="{!LOLI.ExpectedQty}"/></strong></span>
                                                                                </div>
                                                                            </div>
                                                                             <div class="slds-col">
                                                                                <label class="slds-form-element__label" >{!$Label.c.Acc_Pay_PO_Name}</label>
                                                                                <div class="slds-p-top_small ri-mx150">
                                                                                    <lightning:formattedUrl target="_blank"  label="{!LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Purchase_Orders__r.Name}" value="{!'/'+LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Purchase_Orders__c}" class=""/>
                                                                                </div>
                                                                            </div> 
                                                                        
                                                                            <aura:if isTrue="{!v.displayUplaodforItems}">
                                                                                <div class="slds-col">
                                                                                    <lightning:fileUpload label="{!$Label.c.Attach_Files}"  accept="{!v.filetype}"  multiple="true"  recordId="{!LOLI.LOLI.Id}" onuploadfinished="{!c.handleUploadFinished}"/>
                                                                                    <aura:if isTrue="{!(LOLI.Attach.length > 0)}">
                                                                                        <aura:iteration items="{!LOLI.Attach}" var="attachment" indexVar="index">
                                                                                            <div class="slds-grid">
                                                                                                <div class="slds-col">
                                                                                                    <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!attachment.Id}" title="{!LOLI.LOLI.Id}">
                                                                                                        <a href="javascript:void(0)" title="delete" class="InboundLog-class32">
                                                                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="InboundLog-class33" />  
                                                                                                        </a>
                                                                                                    </lightning:button>
                                                                                                    &nbsp;
                                                                                                    <lightning:formattedUrl value="{!'/'+attachment.ContentDocumentId}" label="{!attachment.ContentDocument.Title}" tooltip="{!attachment.ContentDocument.Title}" target="_blank" class="fcolor"/>
                                                                                                </div>
                                                                                                <!--div class="slds-col">
                                                                                                    <img src="{!'/servlet/servlet.FileDownload?file='+attachment.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                                                                                </div-->
                                                                                            </div>
                                                                                        </aura:iteration>
                                                                                    </aura:if> 
                                                                                </div>
                                                                            </aura:if>
                                                                            
                                                                            <aura:if isTrue="{!v.showBarcode}">
                                                                                <div class="col-md-12">
                                                                                    <span class="mobiledisplaynone mobiledisplaynone-landscape" >
                                                                                        <div class="slds-truncate">
                                                                                            <aura:if isTrue="{!and(and(LOLI.ProdBarcode != undefined,LOLI.ProdBarcode != null),LOLI.ProdBarcode != '')}">
                                                                                                <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!LOLI.ProdBarcode}"/>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </span>
                                                                                </div>
                                                                            </aura:if>
                                                                        </div>
                                                                    </div>
                                                                    
                                                                    <aura:if isTrue="{!and(v.AllocationAccess,v.Container.poliDimensions.length>0)}">
                                                                        <aura:if isTrue="{!and(LOLI.LOLI.ERP7__Purchase_Line_Items__c != undefined,LOLI.LOLI.ERP7__Purchase_Line_Items__c != null)}">
                                                                            <table class="table slds-no-row-hover Receive-class61">
                                                                                <aura:iteration items="{!v.Container.poliDimensions}" var="poliD" indexVar="poliDCounter">
                                                                                    <aura:if isTrue="{!poliD.ERP7__Purchase_Line_Items__c == LOLI.LOLI.ERP7__Purchase_Line_Items__c}">
                                                                                        <tr>
                                                                                            <td colspan="10">
                                                                                                <div class="erp_Mark7">
                                                                                                    <div class="row m-0">
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Account_Category} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Account_Category__c != undefined,poliD.ERP7__Account_Category__c != null)}">
                                                                                                                <lightning:formattedText value="{!poliD.ERP7__Account_Category__c}" />
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-3 slds-truncate">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Accounting_Account} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Chart_of_Account__c != undefined,poliD.ERP7__Chart_of_Account__c != null)}">
                                                                                                                <lightning:formattedUrl target="_blank" value="{!'/'+poliD.ERP7__Chart_of_Account__c}" label="{!poliD.ERP7__Chart_of_Account__r.Name}"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Allocation_Percentage} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Allocation_Percentage__c != undefined,poliD.ERP7__Allocation_Percentage__c != null)}">
                                                                                                                <lightning:formattedNumber value="{!poliD.ERP7__Allocation_Percentage__c}" style="percent-fixed"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Allocation_Amount} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Allocation_Amount__c != undefined,poliD.ERP7__Allocation_Amount__c != null)}">
                                                                                                                <lightning:formattedNumber value="{!poliD.ERP7__Allocation_Amount__c}" /><!--style="currency"-->
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-3 slds-truncate">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Analytical_Account} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Project__c != undefined,poliD.ERP7__Project__c != null)}">
                                                                                                                <lightning:formattedUrl target="_blank" value="{!'/'+poliD.ERP7__Project__c}" label="{!poliD.ERP7__Project__r.Name}"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:if>
                                                                                </aura:iteration>
                                                                            </table>
                                                                        </aura:if>
                                                                    </aura:if>
                                                                    <!-- added by shaguftha-->
                                                                    <div class="slds-grid slds-wrap slds-m-bottom_small">
                                                                        <div class="col-md-4">
                                                                            <lightning:input type="text" label="{!$Label.c.Serial_Prefix}" value="{!LOLI.LOLI.ERP7__Serial_Number_Prefix__c}"  />
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <lightning:input type="text" label="{!$Label.c.From_Serial_Number}"  value="{!LOLI.LOLI.ERP7__Starting_Number__c}"   />
                                                                        </div>
                                                                        <div class="col-md-4 p-top">
                                                                            <lightning:button label="{!$Label.c.Generate_Serial_Numbers}" onclick="{!c.generateSerials}" variant="brand" name="{!LOLI.LOLI.Id}"/>
                                                                        </div>
                                                                    </div>
                                                                    <table class="table slds-no-row-hover Receive-class61">
                                                                        <thead>
                                                                            <tr bgcolor="#f3f3f3">
                                                                                <th class="slds-text-heading--label slds-truncate2 Receive-class62" width="5%">
                                                                                    <lightning:input type="Checkbox"  aura:id="selectAllSerials" onchange="{!c.selectAllSerials}" name="{!LOLI.loliId}"></lightning:input>&nbsp; <!--checked="{!v.SelectSerials}"-->
                                                                                </th> 
                                                                                <th class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" align="left" valign="middle" width="">{!$Label.c.Qty2Receive}<span class="redtxt"> *</span></th>
                                                                                <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle" width=""> {!$Label.c.Serial_StockTake} <span class="redtxt"> *</span></th>
                                                                                <aura:if isTrue="{!v.DisplayStatus}"><th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.InboundStatus} </th></aura:if>
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.InventoryConsole_Location} </th>
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> <aura:if isTrue="{!LOLI.showBin}"> {!$Label.c.Bin} </aura:if> </th> 
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.Expiry_date} </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <aura:iteration items="{!v.Container.SPLIS}" var="Stock" indexVar="stockCounter">
                                                                                <aura:if isTrue="{!LOLI.loliId == Stock.loliId}">
                                                                                    <aura:if isTrue="{!and(Stock.sili.ERP7__Product__r.ERP7__Serialise__c == true,Stock.sili.ERP7__Product__r.ERP7__Lot_Tracked__c == false)}">
                                                                                        <tr class="{!if((Stock.siliverified),'Pick-newClass28','')}">
                                                                                            <td><lightning:input type="Checkbox" checked="{!Stock.isSelected}" aura:id="newCheck" onchange="{!c.getselectedlineitems}" title="{!itemCounter}" name="{!stockCounter}"></lightning:input></td>
                                                                                            <td class="slds-truncate2 scanMN" data-label="Quantity" align="left"  valign="middle">
                                                                                                <lightning:input type="number" variant="label-hidden" value="{!Stock.sili.ERP7__Quantity__c}" onchange="{!c.handlequantity}" title="{!Stock.sili.ERP7__Logistic_Line_Item__c}" name="{!stockCounter}" disabled="true"/>
                                                                                            </td>
                                                                                            <td data-label="Serial No." align="left" class="{!if(Stock.sili.ERP7__Product__r.ERP7__Serialise__c == true,'slds-truncate2 scanMN ','slds-truncate2 scanMN Receive-class34')}" valign="middle">
                                                                                                <aura:if isTrue="{!or(and(and(Stock.sili.ERP7__Transfer_Order_Line_Item__c != undefined,Stock.sili.ERP7__Transfer_Order_Line_Item__c != null),Stock.sili.ERP7__Transfer_Order_Line_Item__c != ''),and(and(Stock.sili.ERP7__RMA_Line_Item__c != undefined,Stock.sili.ERP7__RMA_Line_Item__c != null),Stock.sili.ERP7__RMA_Line_Item__c != ''))}">
                                                                                                    <aura:if isTrue="{!and(and(Stock.sili.ERP7__Serial__c != undefined,Stock.sili.ERP7__Serial__c != null),Stock.sili.ERP7__Serial__c != '')}">
                                                                                                        <span><c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" IconName="standard:macros" selectedRecordId="{!Stock.sili.ERP7__Serial__c}"  hideRemove="true"/></span>
                                                                                                        <aura:set attribute="else">
                                                                                                            <lightning:input type="text" variant="label-hidden" value="{!Stock.sili.ERP7__Serial_Number__c}" name="{!stockCounter}" class="scanMN" oncommit="{!c.checkSerials}"/>
                                                                                                        </aura:set>
                                                                                                    </aura:if>
                                                                                                    <aura:set attribute="else">
                                                                                                        <lightning:input type="text" variant="label-hidden" value="{!Stock.sili.ERP7__Serial_Number__c}" name="{!stockCounter}" class="scanMN" oncommit="{!c.checkSerials}"/>
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <aura:if isTrue="{!v.DisplayStatus}">
                                                                                                <td class="slds-truncate2 scanMN" data-label="Quantity" align="left"  valign="middle">
                                                                                                    <!--<aura:if isTrue="{!and((Stock.sili.ERP7__Status__c == 'In Stock' || Stock.sili.ERP7__Status__c == 'Quality Check(QA)'),v.showQA)}">
                                                                                                        {!Stock.sili.ERP7__Status__c}
                                                                                                        <aura:set attribute="else">-->
                                                                                                            <lightning:select label="{!$Label.c.CreateClubcard_Status}" variant="label-hidden"   value="{!Stock.sili.ERP7__Status__c}" class="nolabel" disabled="{!and((Stock.sili.ERP7__Status__c == 'In Stock' || Stock.sili.ERP7__Status__c == 'Quality Check(QA)'),v.showQA)}">
                                                                                                                <aura:iteration items="{!v.statusOption}" var="item">
                                                                                                                    <option text="{!item.label}" value="{!item.value}" selected="{!Stock.sili.ERP7__Status__c == item.value}"/>
                                                                                                                </aura:iteration>
                                                                                                            </lightning:select> 
                                                                                                       <!-- </aura:set>
                                                                                                    </aura:if>-->
                                                                                                </td>
                                                                                            </aura:if>
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <span><c:CustomInputLookUp objectAPIName="ERP7__Location__c" aura:id="sl" IconName="standard:location" selectedRecordId="{!Stock.sili.ERP7__Location__c}" qry="{!' AND ERP7__Site__c = \''+v.selectedSite+'\''}" hideRemove="{!v.disableLocReceive}"/></span>
                                                                                            </td>
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <aura:if isTrue="{!LOLI.showBin}"> 
                                                                                                    <span><c:CustomInputLookUp objectAPIName="ERP7__StorageContainer__c" aura:id="sl" IconName="standard:entity" selectedRecordId="{!Stock.sili.ERP7__StorageContainer__c}" qry="{!' AND ERP7__Location__c = \''+Stock.sili.ERP7__Location__c+'\' AND ERP7__Site__c = \''+v.selectedSite+'\''}"/></span>
                                                                                                </aura:if>
                                                                                            </td> 
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <lightning:input type="date" variant="label-hidden" value="{!Stock.sili.ERP7__Expiry_Date__c}" aura:id="ed" title="Expiry Date" />
                                                                                            </td>                                                                                   </tr>
                                                                                    </aura:if>
                                                                                </aura:if>
                                                                                <!--<aura:if isTrue="{!LOLI.LOLI.ERP7__Product__r.ERP7__Quality_Check_QA__c}">                                                       
                                                                                    <aura:if isTrue="{!and(v.showQA,v.Container.ProdChecks.length>0)}"> 
                                                                                        <aura:iteration items="{!v.Container.ProdChecks}" var="ck" indexVar="checklistsIndex">
                                                                                            
                                                                                            <aura:if isTrue="{!Stock.sili.ERP7__Product__c == ck.ERP7__Product__c}">
                                                                                                
                                                                                                <tr>
                                                                                                    <td></td>
                                                                                                    <td>
                                                                                                        
                                                                                                        <div class="slds-truncate2" title="">
                                                                                                            <aura:if isTrue="{!ck.ERP7__Is_Mandatory__c}">
                                                                                                                {!ck.Name}<span class="cpo-class21">*</span>
                                                                                                                <aura:set attribute="else">
                                                                                                                    <lightning:formattedText value="{!ck.Name}"/>
                                                                                                                </aura:set>
                                                                                                            </aura:if> 
                                                                                                        </div>
                                                                                                        
                                                                                                    </td>
                                                                                                    <td>
                                                                                                        <aura:if isTrue="{!ck.ERP7__Has_Checklist__c}">
                                                                                                            <aura:if isTrue="{!greaterthan(v.depnedentFieldMap.length,0)}">
                                                                                                                <aura:iteration items="{!v.depnedentFieldMap}"  var="mapKey" indexVar="key">  
                                                                                                                    <aura:if isTrue="{!(mapKey.key == ck.Name)}">
                                                                                                                        <lightning:select name="dependentFld"
                                                                                                                                          value="{!ck.ERP7__Result__c}" 
                                                                                                                                          variant ="label-hidden"
                                                                                                                                          disabled="" class="checklistlabel">
                                                                                                                            <aura:iteration items="{!mapKey.value}" var="val">
                                                                                                                                <option value="{!val}" selected="{!val==ck.ERP7__Result__c}">{!val}</option>
                                                                                                                            </aura:iteration>
                                                                                                                        </lightning:select>
                                                                                                                    </aura:if>  
                                                                                                                </aura:iteration>
                                                                                                            </aura:if>			                                                                                                                    
                                                                                                            <aura:if isTrue="{!(ck.Name==key)}">
                                                                                                                
                                                                                                            </aura:if>
                                                                                                            
                                                                                                            <aura:set attribute="else">
                                                                                                                
                                                                                                                <lightning:inputRichText label="" placeholder="Enter your comments" class="mheight300"
                                                                                                                                         title="note"
                                                                                                                                         value="{!ck.ERP7__Action_Detail__c}" disabledCategories="FORMAT_TEXT,FORMAT_FONT,FORMAT_BODY,ALIGN_TEXT,INSERT_CONTENT,REMOVE_FORMATTING"
                                                                                                                                         />
                                                                                                            </aura:set>
                                                                                                            
                                                                                                        </aura:if>
                                                                                                    </td>
                                                                                                </tr>
                                                                                            </aura:if>
                                                                                        </aura:iteration>
                                                                                        
                                                                                        
                                                                                        
                                                                                    </aura:if>
                                                                                </aura:if>-->
                                                                            </aura:iteration>
                                                                        </tbody>
                                                                    </table>
                                                                    
                                                                    <div class="b-top-n-p-20"></div>
                                                                </aura:if>
                                                            </aura:if>
                                                        </aura:iteration>
                                                    </div>
                                                </div>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!v.SerBatchProdsize > 0}">
                                                
                                                <div class="card mb-2 mt-2">
                                                         <h2 class="slds-card__header-title slds-p-around_x-small">{!$Label.c.Serialized_and_Batch_Products}</h2>
                                                    <div class="card-body">
                                                        <!--h5 class="card-title mb-2"><i class="far fa-file-alt"></i>&nbsp;Serialized and Lot Products</h5-->
                                                        <aura:iteration var="LOLI" indexVar="itemCounter" items="{!v.Container.LOLIS}">
                                                            <aura:if isTrue="{!LOLI.silisize > 0}">
                                                                <aura:if isTrue="{!and(LOLI.isSerialized == true,LOLI.isBatchLot == true)}">
                                                                    <div class="card-header text-left padding-10-5 b-bottom-0">
                                                                        <div class="slds-grid slds-wrap">
                                                                            <div class="slds-col">
                                                                                <label class="slds-form-element__label" >{!$Label.c.Product_Name_StockTake}</label>
                                                                                
                                                                                    <span class="Receive-class21">
                                                                                        <div class="slds-grid">
                                                                                            {!itemCounter+1}.&nbsp; 
                                                                                            <div class="col-md-12 ri-mx180 pr-0"  title="{!LOLI.LOLI.ERP7__Product__r.Name}">
                                                                                                <lightning:formattedUrl target="_blank"  label="{!LOLI.LOLI.ERP7__Product__r.Name}" value="{!'/'+LOLI.LOLI.Id}" class=""/>
                                                                                            </div>
                                                                                            
                                                                                        </div>
                                                                                    </span>
                                                                                
                                                                            </div>
                                                                           
                                                                            <aura:if isTrue="{!v.showVendorCode}">
                                                                                 <div class="slds-col">
                                                                                    <label class="slds-form-element__label" >{!$Label.c.Product_Code}</label>
                                                                                    <div class="slds-p-top_small ri-mx150">
                                                                                        <lightning:formattedText label="Product Code" value="{!LOLI.LOLI.ERP7__Product__r.ProductCode}" class=""/>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="slds-col">
                                                                                    <label class="slds-form-element__label" >{!$Label.c.PO_Vendor_part_no}</label>
                                                                                    <div class="slds-p-top_small ri-mx150">
                                                                                        <lightning:formattedText  label="Vendor Product Code" value="{!LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Vendor_product_Name__c}" class=""/>
                                                                                    </div>
                                                                                </div>
                                                                            </aura:if>
                                                                            
                                                                            <div class="slds-col">
                                                                                <label class="slds-form-element__label" >{!$Label.c.Expected_QTY}</label>
                                                                                    <div class="slds-p-top_small ri-mx150">
                                                                                <span class="badge bg-primary"><strong><lightning:formattedNumber value="{!LOLI.ExpectedQty}"/></strong></span>
                                                                                </div>
                                                                            </div>
                                                                             <div class="slds-col">
                                                                                <label class="slds-form-element__label" >{!$Label.c.Acc_Pay_PO_Name}</label>
                                                                                <div class="slds-p-top_small ri-mx150">
                                                                                    <lightning:formattedUrl target="_blank"  label="{!LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Purchase_Orders__r.Name}" value="{!'/'+LOLI.LOLI.ERP7__Purchase_Line_Items__r.ERP7__Purchase_Orders__c}" class=""/>
                                                                                </div>
                                                                            </div>
                                                                            <div class="slds-col">
                                                                                <div class="ri-mx200">
                                                                                <span >
                                                                                    <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Batch_Lot}<span class="redtxt"> *</span></label>
                                                                                    <div class="slds-grid scanMN epr_Mark7">
                                                                                        <div class="col-md-11 pl-0 pr-0">
                                                                                            <span data-index="{!LOLI.LOLI.Id}" name="{!LOLI.assignedBatch}" onclick="{!c.handlelotchange}">
                                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="sl" IconName="standard:user" selectedRecordId="{!LOLI.assignedBatch}" qry="{!' And ERP7__Expired__c=false And ERP7__Product__c = \''+LOLI.LOLI.ERP7__Product__c+'\''}" />
                                                                                            </span>
                                                                                        </div>
                                                                                        <div class="col-md-1 pr-0 Receive-class73" >                                                                                               
                                                                                            <i class="fa fa-cogs Receive-class74" onclick="{!c.createBatchModal}" title="Create New Batch" data-index="{!LOLI.LOLI.Id}" data-prodId="{!LOLI.LOLI.ERP7__Product__c}" data-proName="{!LOLI.LOLI.ERP7__Product__r.Name}"/>                                                                                               
                                                                                        </div>
                                                                                    </div>
                                                                                </span>
                                                                                </div>
                                                                            </div>
                                                                            <aura:if isTrue="{!v.displayUplaodforItems}">
                                                                                <div class="slds-col">
                                                                                    <lightning:fileUpload label="{!$Label.c.Attach_Files}"   multiple="true"  recordId="{!LOLI.LOLI.Id}" onuploadfinished="{!c.handleUploadFinished}"/>
                                                                                    <aura:if isTrue="{!(LOLI.Attach.length > 0)}">
                                                                                        <aura:iteration items="{!LOLI.Attach}" var="attachment" indexVar="index">
                                                                                            <div class="slds-grid">
                                                                                                <div class="slds-col">
                                                                                                    <lightning:button onclick="{!c.DeleteRecordAT}" class="neutralC" name="{!attachment.Id}" title="{!LOLI.LOLI.Id}">
                                                                                                        <a href="javascript:void(0)" title="delete" class="InboundLog-class32">
                                                                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="InboundLog-class33" />  
                                                                                                        </a>
                                                                                                    </lightning:button>
                                                                                                    &nbsp;
                                                                                                    <lightning:formattedUrl value="{!'/'+attachment.ContentDocumentId}" label="{!attachment.ContentDocument.Title}" tooltip="{!attachment.ContentDocument.Title}" target="_blank" class="fcolor"/>
                                                                                                </div>
                                                                                                <!--div class="slds-col">
                                                                                                    <img src="{!'/servlet/servlet.FileDownload?file='+attachment.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                                                                                </div-->
                                                                                            </div>
                                                                                        </aura:iteration>
                                                                                    </aura:if> 
                                                                                </div>
                                                                            </aura:if>
                                                                            
                                                                            <aura:if isTrue="{!v.showBarcode}">
                                                                                <div class="slds-p-top_small col-md-12">
                                                                                    <span class="mobiledisplaynone mobiledisplaynone-landscape" >
                                                                                        <div class="slds-truncate">
                                                                                            <aura:if isTrue="{!and(and(LOLI.ProdBarcode != undefined,LOLI.ProdBarcode != null),LOLI.ProdBarcode != '')}">
                                                                                                <c:AQBarcodeZoneLC aura:id="brcd128" BrcdHeight="35" BrcdType="code128" Value="{!LOLI.ProdBarcode}"/>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </span>
                                                                                </div>
                                                                            </aura:if>
                                                                            
                                                                        </div>
                                                                    </div>
                                                                    
                                                                    <aura:if isTrue="{!and(v.AllocationAccess,v.Container.poliDimensions.length>0)}">
                                                                        <aura:if isTrue="{!and(LOLI.LOLI.ERP7__Purchase_Line_Items__c != undefined,LOLI.LOLI.ERP7__Purchase_Line_Items__c != null)}">
                                                                            <table class="table slds-no-row-hover Receive-class61">
                                                                                <aura:iteration items="{!v.Container.poliDimensions}" var="poliD" indexVar="poliDCounter">
                                                                                    <aura:if isTrue="{!poliD.ERP7__Purchase_Line_Items__c == LOLI.LOLI.ERP7__Purchase_Line_Items__c}">
                                                                                        <tr>
                                                                                            <td colspan="10">
                                                                                                <div class="erp_Mark7">
                                                                                                    <div class="row m-0">
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Account_Category} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Account_Category__c != undefined,poliD.ERP7__Account_Category__c != null)}">
                                                                                                                <lightning:formattedText value="{!poliD.ERP7__Account_Category__c}" />
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-3 slds-truncate">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Accounting_Account} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Chart_of_Account__c != undefined,poliD.ERP7__Chart_of_Account__c != null)}">
                                                                                                                <lightning:formattedUrl target="_blank" value="{!'/'+poliD.ERP7__Chart_of_Account__c}" label="{!poliD.ERP7__Chart_of_Account__r.Name}"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Allocation_Percentage} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Allocation_Percentage__c != undefined,poliD.ERP7__Allocation_Percentage__c != null)}">
                                                                                                                <lightning:formattedNumber value="{!poliD.ERP7__Allocation_Percentage__c}" style="percent-fixed"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-2">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Allocation_Amount} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Allocation_Amount__c != undefined,poliD.ERP7__Allocation_Amount__c != null)}">
                                                                                                                <lightning:formattedNumber value="{!poliD.ERP7__Allocation_Amount__c}" /><!--style="currency"-->
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                        <div class="col-md-3 slds-truncate">
                                                                                                            <label  class="slds-form-element__label">{!$Label.c.Analytical_Account} : </label>
                                                                                                            <aura:if isTrue="{!and(poliD.ERP7__Project__c != undefined,poliD.ERP7__Project__c != null)}">
                                                                                                                <lightning:formattedUrl target="_blank" value="{!'/'+poliD.ERP7__Project__c}" label="{!poliD.ERP7__Project__r.Name}"/>
                                                                                                            </aura:if>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:if>
                                                                                </aura:iteration>
                                                                            </table>
                                                                            <div class="b-top-n-p-20"></div>
                                                                        </aura:if>
                                                                    </aura:if>
                                                                      <div class="slds-grid slds-wrap slds-m-bottom_small">
                                                                        <div class="col-md-4">
                                                                            <lightning:input type="text" label="{!$Label.c.Serial_Prefix}" value="{!LOLI.LOLI.ERP7__Serial_Number_Prefix__c}"   />
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <lightning:input type="text" label="{!$Label.c.From_Serial_Number}"  value="{!LOLI.LOLI.ERP7__Starting_Number__c}"  />
                                                                        </div>
                                                                        <div class="col-md-4 p-top">
                                                                            <lightning:button label="{!$Label.c.Generate_Serial_Numbers}" onclick="{!c.generateSerials}" variant="brand" name="{!LOLI.LOLI.Id}"/>
                                                                        </div>
                                                                    </div>
                                                                    <table class="table slds-no-row-hover Receive-class61">
                                                                        <thead>
                                                                            <tr bgcolor="#f3f3f3">
                                                                                
                                                                                
                                                                                
                                                                                <th class="slds-text-heading--label slds-truncate2 Receive-class62" width="5%">
                                                                                    <lightning:input type="Checkbox" checked="{!v.SelectBatchSerials}" aura:id="selectAllBatchSerials" onchange="{!c.selectAllbatchSerials}" name="{!LOLI.loliId}"></lightning:input>&nbsp; 
                                                                                </th>
                                                                                <th class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" align="left" valign="middle" width="">{!$Label.c.Qty2Receive}<span class="redtxt"> *</span></th>
                                                                                <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle" width=""> {!$Label.c.Serial_StockTake} <span class="redtxt"> *</span></th>
                                                                                <aura:if isTrue="{!v.DisplayStatus}"> <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.InboundStatus} </th></aura:if>
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.InventoryConsole_Location} </th>
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""><aura:if isTrue="{!LOLI.showBin}"> {!$Label.c.Bin} </aura:if></th> 
                                                                                <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle" width=""> {!$Label.c.Expiry_date} </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <aura:iteration items="{!v.Container.SPLIS}" var="Stock" indexVar="stockCounter">
                                                                                <aura:if isTrue="{!LOLI.loliId == Stock.loliId}">
                                                                                    <aura:if isTrue="{!and(Stock.sili.ERP7__Product__r.ERP7__Serialise__c == true,Stock.sili.ERP7__Product__r.ERP7__Lot_Tracked__c == true)}">
                                                                                        <tr class="{!if((Stock.siliverified),'Pick-newClass28','')}">
                                                                                            <td><lightning:input type="Checkbox" checked="{!Stock.isSelected}" aura:id="newCheck" onchange="{!c.getselectedlineitems}" title="{!itemCounter}" name="{!stockCounter}"></lightning:input></td>
                                                                                            <td class="slds-truncate2 scanMN" data-label="Quantity" align="left"  valign="middle">
                                                                                                <lightning:input type="number" variant="label-hidden" value="{!Stock.sili.ERP7__Quantity__c}" onchange="{!c.handlequantity}" title="{!Stock.sili.ERP7__Logistic_Line_Item__c}" name="{!stockCounter}" disabled="true"/>
                                                                                            </td>
                                                                                            <td data-label="Serial No." align="left" class="{!if(Stock.sili.ERP7__Product__r.ERP7__Serialise__c == true,'slds-truncate2 scanMN ','slds-truncate2 scanMN Receive-class34')}" valign="middle">
                                                                                                <aura:if isTrue="{!or(and(and(Stock.sili.ERP7__Transfer_Order_Line_Item__c != undefined,Stock.sili.ERP7__Transfer_Order_Line_Item__c != null),Stock.sili.ERP7__Transfer_Order_Line_Item__c != ''),and(and(Stock.sili.ERP7__RMA_Line_Item__c != undefined,Stock.sili.ERP7__RMA_Line_Item__c != null),Stock.sili.ERP7__RMA_Line_Item__c != ''))}">
                                                                                                    <aura:if isTrue="{!and(and(Stock.sili.ERP7__Serial__c != undefined,Stock.sili.ERP7__Serial__c != null),Stock.sili.ERP7__Serial__c != '')}">
                                                                                                        <span><c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" IconName="standard:macros" selectedRecordId="{!Stock.sili.ERP7__Serial__c}"  hideRemove="true"/></span>
                                                                                                        <aura:set attribute="else">
                                                                                                            <lightning:input type="text" variant="label-hidden" value="{!Stock.sili.ERP7__Serial_Number__c}" name="{!stockCounter}" class="scanMN" oncommit="{!c.checkSerials}"/>
                                                                                                        </aura:set>
                                                                                                    </aura:if>
                                                                                                    <aura:set attribute="else">
                                                                                                        <lightning:input type="text" variant="label-hidden" value="{!Stock.sili.ERP7__Serial_Number__c}" name="{!stockCounter}" class="scanMN" oncommit="{!c.checkSerials}"/>
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <aura:if isTrue="{!v.DisplayStatus}">
                                                                                                <td class="slds-truncate2 scanMN" data-label="Quantity" align="left"  valign="middle">
                                                                                                    <!--<aura:if isTrue="{!and((Stock.sili.ERP7__Status__c == 'In Stock' || Stock.sili.ERP7__Status__c == 'Quality Check(QA)'),v.showQA)}">
                                                                                                        {!Stock.sili.ERP7__Status__c}
                                                                                                        <aura:set attribute="else">-->
                                                                                                            <lightning:select label="{!$Label.c.CreateClubcard_Status}" variant="label-hidden"   value="{!Stock.sili.ERP7__Status__c}" class="nolabel" disabled="{!and((Stock.sili.ERP7__Status__c == 'In Stock' || Stock.sili.ERP7__Status__c == 'Quality Check(QA)'),v.showQA)}">
                                                                                                                <aura:iteration items="{!v.statusOption}" var="item">
                                                                                                                    <option text="{!item.label}" value="{!item.value}" selected="{!Stock.sili.ERP7__Status__c == item.value}"/>
                                                                                                                </aura:iteration>
                                                                                                            </lightning:select> 
                                                                                                       <!-- </aura:set>
                                                                                                    </aura:if>-->
                                                                                                </td>
                                                                                            </aura:if>
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <span><c:CustomInputLookUp objectAPIName="ERP7__Location__c" aura:id="sl" IconName="standard:location" selectedRecordId="{!Stock.sili.ERP7__Location__c}" qry="{!' AND ERP7__Site__c = \''+v.selectedSite+'\''}" hideRemove="{!v.disableLocReceive}"/></span>
                                                                                            </td>
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <aura:if isTrue="{!LOLI.showBin}"> 
                                                                                                    <span><c:CustomInputLookUp objectAPIName="ERP7__StorageContainer__c" aura:id="sl" IconName="standard:entity" selectedRecordId="{!Stock.sili.ERP7__StorageContainer__c}" qry="{!' AND ERP7__Location__c = \''+Stock.sili.ERP7__Location__c+'\' AND ERP7__Site__c = \''+v.selectedSite+'\''}"/></span>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <td align="left" class="scanMN" valign="middle">
                                                                                                <lightning:input type="date" value="{!Stock.sili.ERP7__Expiry_Date__c}" variant="label-hidden" aura:id="ed" title="Expiry Date" />
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:if>
                                                                                </aura:if>
                                                                            </aura:iteration>
                                                                        </tbody>
                                                                    </table>
                                                                    <div class="b-top-n-p-20"></div>
                                                                </aura:if>
                                                            </aura:if>
                                                        </aura:iteration>
                                                    </div>
                                                </div>
                                            </aura:if>
                                            
                                            <aura:set attribute="else">
                                                <div class=" mb-2 mt-2">
                                                    <div class="card-body p-1 text-center">
                                                        <i class="fa fa-check-circle check-circle"></i>
                                                        <h5 class="success-message__title  mb-2">{!$Label.c.All_Items_Received}</h5>
                                                    </div>
                                                </div>
                                            </aura:set>
                                        </aura:if>
                                        
                                        <aura:if isTrue="{!greaterthan(v.ExistingSILI.length,0)}"> 
                                            <div class="row">
                                                <div class="col-12 mt-2 p-0">
                                                    <div class="card shadow-sm">
                                                        <div class="card-body p-2">
                                                            <div class="page-title-box" data-aura-rendered-by="1215:0">
                                                                <aura:if isTrue="{!and(v.DisplayStatus,v.preventsStatusEdit == false)}">
                                                                    <div class="page-title-right" data-aura-rendered-by="1216:0">
                                                                        <lightning:button label="{!$Label.c.Change_Status_of_All_Received_Items}" onclick="{!c.showStatusChange}" variant="brand"  aura:id="changeStatus"/>
                                                                    </div>
                                                                </aura:if>
                                                                <h4 class="page-title card-pricing headermt" data-aura-rendered-by="1292:0">
                                                                    <strong>{!$Label.c.Received_Line_Items}</strong>
                                                                </h4>
                                                            </div>
                                                            <table class="table slds-no-row-hover Receive-class61">
                                                                <thead>
                                                                    <tr bgcolor="#f3f3f3">
                                                                        <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class63" scope="col" valign="middle">{!$Label.c.Name_ManageLeave}</th>
                                                                        <aura:if isTrue="{!v.showVendorCode}">
                                                                            <th class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" align="left" valign="middle">{!$Label.c.PurchaseOrderPDF_Product}</th>
                                                                        </aura:if>
                                                                        <th class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" align="left" valign="middle">{!$Label.c.Qty2Receive}</th>
                                                                        <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.Batch_Lot} </th>
                                                                        <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.Serial_StockTake} </th>
                                                                        <aura:if isTrue="{!v.DisplayStatus}"><th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.InboundStatus} </th></aura:if>
                                                                        <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle"> {!$Label.c.InventoryConsole_Location} </th>                                    
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <aura:iteration items="{!v.ExistingSILI}" var="sili" indexVar="index">
                                                                        <tr>
                                                                            <td align="left" class="slds-truncate2 scanMN Receive-class71" valign="middle">
                                                                                <lightning:formattedText  variant="label-hidden" value="{!sili.sili.Name}" class=" scanMN"/>
                                                                            </td>
                                                                             <aura:if isTrue="{!v.showVendorCode}">
                                                                                 <td class="scanMN Receive-class72" data-label="Product" align="left"  valign="middle">
                                                                                     <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Product__r.Name}" class=" scanMN"/>
                                                                                 </td>
                                                                            </aura:if>
                                                                            <td class="slds-truncate2 scanMN Receive-class72" data-label="Quantity" align="left"  valign="middle">
                                                                                <lightning:formattedNumber  variant="label-hidden" value="{!sili.sili.ERP7__Quantity__c}" class=" scanMN"/>
                                                                            </td>
                                                                            <td data-label="Batch No." align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                <aura:if isTrue="{!sili.sili.ERP7__Product__r.ERP7__Lot_Tracked__c == true}">
                                                                                    <aura:if isTrue="{!and(and(sili.sili.ERP7__Material_Batch_Lot__c != undefined,sili.sili.ERP7__Material_Batch_Lot__c != null),sili.sili.ERP7__Material_Batch_Lot__c != '')}">
                                                                                        <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Material_Batch_Lot__r.Name}" class=" scanMN"/>
                                                                                    </aura:if>
                                                                                </aura:if>
                                                                            </td>
                                                                            <td data-label="Serial No." align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                <aura:if isTrue="{!sili.sili.ERP7__Product__r.ERP7__Serialise__c == true}">
                                                                                    <aura:if isTrue="{!and(and(sili.sili.ERP7__Serial__c != undefined,sili.sili.ERP7__Serial__c != null),sili.sili.ERP7__Serial__c != '')}">
                                                                                        <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Serial__r.Name}" class=" scanMN"/>
                                                                                    </aura:if>
                                                                                </aura:if>
                                                                            </td>
                                                                            <aura:if isTrue="{!v.DisplayStatus}">
                                                                                <td data-label="Status" align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                    <aura:if isTrue="{!(v.preventsStatusEdit == false)}">
                                                                                        <lightning:select name="{!sili.sili.Id}"  label="{!$Label.c.CreateClubcard_Status}" variant="label-hidden"   value="{!sili.sili.ERP7__Status__c}" onchange="{!c.handleStatusChange}" class="nolabel"> 
                                                                                            <aura:iteration items="{!v.statusOption}" var="item">
                                                                                                <option text="{!item.label}" value="{!item.value}" selected="{!(sili.sili.ERP7__Status__c == item.value)}"/> 
                                                                                            </aura:iteration>
                                                                                        </lightning:select>  
                                                                                        <aura:set attribute="else">
                                                                                            {!sili.sili.ERP7__Status__c}
                                                                                        </aura:set>
                                                                                    </aura:if>
                                                                                    
                                                                                    <!--<aura:if isTrue="{!sili.ERP7__Status__c != 'In Stock'}"><aura:set attribute="else">
                                                                                        <lightning:formattedText  variant="label-hidden" value="{!sili.ERP7__Status__c}" class=" scanMN"/>
                                                                                   </aura:set>
                                                                                </aura:if>-->
                                                                                </td>
                                                                            </aura:if>
                                                                            
                                                                            <td align="left" class="scanMN slds-truncate2" valign="middle">
                                                                                <aura:if isTrue="{!and(and(sili.sili.ERP7__Location__c != undefined,sili.sili.ERP7__Location__c != null),sili.sili.ERP7__Location__c != '')}">
                                                                                    <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Location__r.Name}" class=" scanMN"/>
                                                                                </aura:if>
                                                                            </td>
                                                                        </tr>
                                                                        
                                                                        <aura:if isTrue="{!(sili.sili.ERP7__Product__r.ERP7__Quality_Check_QA__c || sili.sili.ERP7__Product__r.ERP7__QA_Handling_Inbound_Post_MO_Completion__c)}">                                           
                                                                            <aura:if isTrue="{!(sili.guideline.length > 0)}"> 
                                                                                <aura:iteration items="{!sili.guideline}" var="ck" indexVar="checklistsIndex">
                                                                                    <aura:if isTrue="{!sili.sili.Id == ck.ERP7__Stock_Inward_Line_Item__c}">
                                                                                        <tr>
                                                                                            <td valign="top" class="valigntop"></td>
                                                                                            <td valign="top" class="valigntop">
                                                                                                
                                                                                                <div class="slds-truncate2" title="{!ck.Name}">
                                                                                                    <aura:if isTrue="{!ck.ERP7__Checklist__r.ERP7__Is_Mandatory__c}">
                                                                                                        <span class="cpo-class21">*</span>{!ck.Name}
                                                                                                        <aura:set attribute="else">
                                                                                                            <lightning:formattedText value="{!ck.Name}"/>
                                                                                                        </aura:set>
                                                                                                    </aura:if> 
                                                                                                </div>
                                                                                                
                                                                                            </td>
                                                                                            <td valign="top" class="valigntop">
                                                                                                <aura:if isTrue="{!and(ck.ERP7__Checklist__r.ERP7__Comply__c != null, ck.ERP7__Checklist__r.ERP7__Comply__c != '--None--')}">
                                                                                                    <aura:if isTrue="{!greaterthan(v.depnedentFieldMap.length,0)}">
                                                                                                        <aura:iteration items="{!v.depnedentFieldMap}"  var="mapKey" indexVar="key">  
                                                                                                            <aura:if isTrue="{!(mapKey.key == ck.Name)}">
                                                                                                                <lightning:select label="{!$Label.c.Checklist_Operation}" value="{!ck.ERP7__Instructions__c}" variant ="label-hidden" disabled="{!or(sili.sili.ERP7__Status__c == $Label.c.InStockPickListValue, ck.ERP7__Is_Mandatory__c == false)}" class="checklistlabel" onchange="{!c.setChecklistResult}"><!-- Moin added label="{!$Label.c.Checklist_Operation}" on 09th september -->
                                                                                                                    <aura:iteration items="{!mapKey.value}" var="val">
                                                                                                                        <option value="{!val.value}" selected="{!val.value == ck.ERP7__Instructions__c}">{!val.label}</option>
                                                                                                                    </aura:iteration>
                                                                                                                </lightning:select>
                                                                                                            </aura:if>  
                                                                                                        </aura:iteration>
                                                                                                    </aura:if>	
                                                                                                    
                                                                                                    <aura:set attribute="else">
                                                                                                        
                                                                                                        <lightning:textarea type="text" label="" placeholder="Enter your comments" class="mheight300 nolabel" maxlength="255"
                                                                                                                         onchange="{!c.setActions}" disabled="{!or(sili.sili.ERP7__Status__c == $Label.c.InStockPickListValue,ck.ERP7__Is_Mandatory__c == false)}"
                                                                                                                         value="{!ck.ERP7__Instructions__c}" disabledCategories="FORMAT_TEXT,FORMAT_FONT,FORMAT_BODY,ALIGN_TEXT,INSERT_CONTENT,REMOVE_FORMATTING"
                                                                                                                         />
                                                                                                    </aura:set>
                                                                                                    
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <td class="valigntop">
                                                                                                <aura:if isTrue="{!and(v.displayUplaodforItems,ck.ERP7__Is_Mandatory__c)}">
                                                                                                    <div class="slds-grid slds-wrap">
                                                                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                                                                                            <lightning:input aura:id="fileId" type="file" name="{!ck}" onchange="{!c.onFileUploadedQAGuideLines}"  multiple="true" class="InboundLog-class31"/>
                                                                                                        </div>
                                                                                                        <aura:if isTrue="{!and(ck.Id != undefined,ck.Id != null)}"> 
                                                                                                            <aura:if isTrue="{!and(ck.Attachments != undefined,ck.Attachments != null)}">
                                                                                                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 slds-truncate">
                                                                                                                    <div class="scroll-wrap-height-cntl">
                                                                                                                        <aura:if isTrue="{!ck.Attachments.length > 0}">
                                                                                                                            <aura:iteration var="attch" indexVar="attchIndex" items="{!ck.Attachments}">
                                                                                                                                <aura:if isTrue="{!(attch.Id != undefined)}">
                                                                                                                                    <div class="slds-grid slds-p-top_small">
                                                                                                                                        <div class="slds-col">
                                                                                                                                            <lightning:buttonIcon iconName="utility:delete" variant="bare" name="{!attch.Id}" title="{!ck.Id}" onclick="{!c.DeleteRecordATforQAGuideLines}" alternativeText="delete" class="colorRed"/>
                                                                                                                                            &nbsp;
                                                                                                                                            <lightning:formattedUrl value="{!'/'+attch.Id}" label="{!attch.Name}" tooltip="{!attch.Name}" target="_blank" class="fcolor"/>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </aura:if>
                                                                                                                            </aura:iteration>
                                                                                                                        </aura:if>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </aura:if>
                                                                                                        </aura:if>
                                                                                                    </div>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:if>
                                                                                </aura:iteration>
                                                                            </aura:if>
                                                                        </aura:if>
                                                                        
                                                                    </aura:iteration>
                                                                </tbody>
                                                            </table>
                                                            <!--aura:set attribute="else">
                                                                {!$Label.c.No_Received_Items}
                                                            </aura:set-->
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                    </div>
                                </div>
                                <div class="slds-docked-form-footer" >
                                    <div class="col-md-12 Receive-class46" > 
                                        <!--<aura:if isTrue="{!!v.hideSave}"> </aura:if>-->
                                        <lightning:button label="{!$Label.c.ContractConsole_Save}" onclick="{!c.SaveAllLOLines}" variant="brand"  aura:id="saveId" disabled="{!v.hideSave}"/>
                                        
                                        <button type="button" class="slds-button slds-button--neutral" onclick="{!c.back2Inbound}">{!$Label.c.Cancel_ManageLeave}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <aura:if isTrue="{!v.showCreateNewLotModal}">
            <section role="dialog" tabindex="-1" id="myModalCard" aura:id="myModalCard" class="slds-modal  slds-modal_xx-small slds-fade-in-open" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                            <lightning:icon iconName="utility:close" class="customfill" alternativeText="{!$Label.c.Close_Timesheets}" title="Close" onclick="{!c.closeBatchModal}"/>
                        </button>
                        <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate Receive-class81" >{!$Label.c.Inbound_Create_New}&nbsp; {!$Label.c.Batch_Lot}</h2>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium pt-c" id="modal-content-id-1">                
                        <div class="container-fluid">
                            <div class="row slds-m-top--xx-small">
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <span class="Receive-class82">
                                        <lightning:formattedText aura:id="paymentError" value="{!v.BatchError}"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small scanMN">
                                <div class="quote-main">
                                    <label class="slds-form-element__label Receive-class8"><strong>{!$Label.c.Batch_Lot} <span class="red">*</span></strong></label>
                                </div>
                                <lightning:input type="text" aura:id="NewLotNameFocus" value="{!v.newBatch.Name}" placeholder="{!$Label.c.Batch_Lot+'Number'}" class="nolble scanMN" onchange="{!c.updateBarcode}"/>
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small scanMN">
                                <div class="quote-main">
                                    <label class="slds-form-element__label Receive-class8"><strong>{!$Label.c.Inbound_Expiry_Date}</strong></label>
                                </div>
                                <lightning:input type="date" value="{!v.newBatch.ERP7__Shelf_Life_Expiration_Date__c}" placeholder="{!$Label.c.Inbound_Expiry_Date}" class="nolble scanMN"/>
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small scanMN">
                                <div class="quote-main slds-m-top--xx-small">
                                    <label class="slds-form-element__label Receive-class8"><strong>{!$Label.c.ProdVersion}</strong></label>
                                </div>
                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c" aura:id="sl" IconName="standard:catalog" selectedRecordId="{!v.newBatch.ERP7__Production_Version__c}" qry="{!' AND ERP7__Product__c = \''+v.newBatch.ERP7__Product__c+'\''}" required="true"/>                         
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small">
                                <div class="quote-main slds-m-top--xx-small">
                                    <label class="slds-form-element__label Receive-class8"><strong>{!$Label.c.Product_UsersShiftMatch}</strong></label>
                                </div>                                                                                                                          
                                <!--<c:CustomInputLookUp objectAPIName="Product2" aura:id="sl" IconName="standard:product_item" selectedRecordId="{!v.newBatch.ERP7__Product__c}" qry="{!' AND Id = \''+v.newBatch.ERP7__Product__c+'\''}"/>-->
                                <lightning:input value="{!v.proNameForBatch}" placeholder="{!$Label.c.Product_UsersShiftMatch}" class="nolble" disabled="true"/>
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small">
                                <div class="quote-main">
                                    <label class="slds-form-element__label Receive-class8"><strong>{!$Label.c.Barcode_Outbound_logistics}</strong></label>
                                </div>
                                <lightning:input value="{!v.newBatch.ERP7__Barcode__c}" placeholder="{!$Label.c.Barcode_Outbound_logistics}" class="nolble" disabled="true"/>
                            </div>
                            <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small">
                                <div class="quote-main">
                                    <label class="slds-form-element__label Receive-class8"><strong>Description</strong></label>
                                </div>
                                <lightning:textarea value="{!v.newBatch.ERP7__Description__c}" placeholder="Description" class="nolble" />
                            </div>
                            <aura:if isTrue="{!v.showfileUpload}">
                                <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small">
                                    
                                    <div class="slds-grid"><span >{!$Label.c.Attachment}</span></div>
                                    <lightning:input aura:id="fileId" type="file"  onchange="{!c.handleFilesChange}" multiple="true" label="{!$Label.c.Upload_Attachment}" variant="label-hidden" />
                                    <aura:if isTrue="{!v.showDelete}">
                                        <a onclick="{!c.removeAttachment}" title="Remove Attachment" class="createbill-class6">
                                            <i class="fa fa-minus-circle" aria-hidden="true"></i>
                                        </a>                        
                                    </aura:if>
                                    <aura:iteration items="{!v.fillList}" var="file" indexVar='count'>
                                        <div class="slds-text-body_small slds-text-color_error">{!file}&nbsp;&nbsp;&nbsp;
                                        </div>
                                    </aura:iteration>
                                    <aura:if isTrue="{!v.showLoadingSpinner}">
                                        <div class="slds-text-body_small slds-text-color_error">{!$Label.c.Uploading} 
                                            <img src="/auraFW/resources/aura/images/spinner.gif" class="spinner-img" alt="Loading"/>'
                                        </div>
                                    </aura:if>
                                    <br/>
                                </div>
                            </aura:if>
                        </div>
                    </div>
                    <footer class="slds-modal__footer text-center">
                        <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeBatchModal}">{!$Label.c.Cancel_ManageLeave}</button>
                        <button type="button" class="slds-button slds-button--brand" onclick="{!c.CreateBatch1}">{!$Label.c.Transfer_Order_Create}&nbsp;{!$Label.c.Batch_Lot}</button>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open" aura:id="myModalCardBackdrop"></div> 
        </aura:if>
        
        <section role="dialog" tabindex="-1" id="myModalStatus" aura:id="myModalStatus" class="slds-modal  slds-modal_xx-small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                        <lightning:icon iconName="utility:close" class="customfill" alternativeText="{!$Label.c.Close_Timesheets}" title="Close" onclick="{!c.closestatusModal}"/>
                    </button>
                    <h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate Receive-class81" >{!$Label.c.Change_Status}</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium pt-c" id="modal-content-id-1">                
                    <div class="container-fluid">
                        
                        <div class="col-md-12 col-sm-12 col-xs-12 slds-m-top--xx-small scanMN">
                            <lightning:select  label="{!$Label.c.CreateClubcard_Status}" variant="label-hidden" aura:id="siliStatus" value="{!v.SelectedStatus}"  class="nolabel">
                                <aura:iteration items="{!v.statusOption}" var="item">
                                    <option text="{!item.label}" value="{!item.value}" selected="{!v.SelectedStatus == item.value}"/>
                                </aura:iteration>
                            </lightning:select> 
                        </div>
                        
                    </div>
                </div>
                <footer class="slds-modal__footer text-center">
                    <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closestatusModal}">{!$Label.c.Cancel_ManageLeave}</button>
                    <button type="button" class="slds-button slds-button--brand" onclick="{!c.updateStatus}">{!$Label.c.Change_Status}</button>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop" aura:id="myModalStatusBackdrop"></div> 
    </body>
</aura:component>