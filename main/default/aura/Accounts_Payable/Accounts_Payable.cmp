                                                                    </ui:actionMenuItem>
                                                                    <ui:actionMenuItem >
                                                                        <a href="javascript:void(0);"   data-record="{#acc.Id}" data-name="{#acc.Name}" onclick="{!c.createDebitNote}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#acc.Id}" data-name="{#acc.Name}">{!$Label.c.Acc_Recev_New_Debit_Note}</span></a>
                                                                    </ui:actionMenuItem>
