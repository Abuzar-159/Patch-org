                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{!acc.ERP7__Credit_Balance__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
