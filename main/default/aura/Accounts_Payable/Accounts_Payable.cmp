                                    </a>
                                    </div>
                                            <div class="slds-col">
                                                <div class="grid-list-icon"> 
                                                    
                                                    <a class="{!(v.grid)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.gridView}">
                                                        <i class="fa fa-th-large"></i>
                                                    </a>
                                                    <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
