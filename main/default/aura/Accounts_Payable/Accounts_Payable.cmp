                                                            <div class="slds-truncate2" title="{!vou.Name}"><a href="{!'/'+vou.Id}" target="_blank">{!vou.Name}</a></div>
                                                        </td>
                                                        <td data-label="Vendor Name">
                                                            <div class="slds-truncate2" title="{!vou.ERP7__Vendor__r.Name}"><a href="{!'/'+vou.ERP7__Vendor__r.Id}" target="_blank">{!vou.ERP7__Vendor__r.Name}</a></div>
                                                        </td>
                                                        <td data-label="Purchase Order">
                                                            <div class="slds-truncate2" title="{!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Purchase_Order__r.Name}">
                                                                <!--<aura:if isTrue="{!index==1}">
                                                                    <a href="" target="_blank"><strong>Test Po, Testing_po, PO-008723</strong></a>
                                                                    <aura:set attribute="else">-->
                                                                <a href="{!'/'+vou.ERP7__Vendor_invoice_Bill__r.ERP7__Purchase_Order__r.Id}" target="_blank"><strong>{!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Purchase_Order__r.Name}</strong></a> 
                                                                <!--</aura:set>
                                                                    </aura:if>-->
                                                            </div>
                                                        </td>
                                                        <td data-label="Vendor Invoice">
                                                            <div class="slds-truncate2" title="{!vou.ERP7__Vendor_invoice_Bill__r.Name}"><a href="{!'/'+vou.ERP7__Vendor_invoice_Bill__r.Id}" target="_blank">{!vou.ERP7__Vendor_invoice_Bill__r.Name}</a></div>
                                                        </td>
                                                        
                                                        <td data-label="Vendor Invoice">
                                                            <div class="slds-truncate2" title="{!vou.ERP7__Vendor_invoice_Bill__r.Name}"><lightning:formattedDateTime value="{!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Bill_Date__c}" year="numeric" month="numeric" day="numeric" timeZone="UTC"/></div>
                                                        </td>
                                                        <td data-label="Vendor Invoice">
                                                            <div class="slds-truncate2" title="{!vou.ERP7__Vendor_invoice_Bill__r.Name}"><lightning:formattedDateTime value="{!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Due_Date__c}" year="numeric" month="numeric" day="numeric" timeZone="UTC"/></div>
                                                        </td>
                                                        
                                                        
                                                        <td data-label="Amount">
                                                            <div class="slds-truncate2" title="{#vou.ERP7__Amount__c}">
                                                                <aura:if isTrue="{!v.displayCurrency}">
                                                                    <lightning:formattedNumber style="currency"  value="{#vou.ERP7__Amount__c}"/>
                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{#vou.ERP7__Amount__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
                                                        <td data-label="Approved">
                                                            <div class="slds-truncate2" title="">
                                                                <aura:if isTrue="{!vou.ERP7__Approved__c}">
                                                                    <span class="slds-button--success">{!$Label.c.Yes_UserAvailabilities}</span>
                                                                    <aura:set attribute="else">
                                                                        <span class="slds-button--destructive">{!$Label.c.No}</span>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
                                                        <td class="slds-cell-shrink" data-label="Actions">
                                                            <ui:menu >
                                                                <ui:menuTriggerLink aura:id="trigger" label="">
                                                                    <lightning:button variant="neutral" label="" class="slds-button slds-button--icon-border-filled slds-button--icon-x-small dropdown-toggle btnlineheight" iconName="utility:down"/>
                                                                </ui:menuTriggerLink>    
                                                                <ui:menuList aura:id="actionMenu" class="customMenuposition"><!--autoPosition="true"-->
                                                                    <aura:if isTrue="{!!v.undisplayEditVouPay}">
                                                                    <ui:actionMenuItem >
                                                                        <a href="javascript:void(0);"  data-record="{#vou.Id}" onclick="{!c.EdiVoucher}" title=""><span class="slds-form-element__label MatchBI-class5" >{!$Label.c.Edit_Voucher} </span></a>
                                                                    </ui:actionMenuItem>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!vou.ERP7__Approved__c}">		
                                                                        <ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"  data-record="{#vou.Id}" onclick="{!c.approveUnVoucher}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#vou.Id}" >Un-Approve</span></a>
                                                                        </ui:actionMenuItem>
                                                                        <ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"  data-record="{#vou.Id}" onclick="{!c.payvoucher}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#vou.Id}" >{!$Label.c.Acc_Pay_Make_Payment}</span></a>
                                                                        </ui:actionMenuItem>
                                                                        
                                                                    </aura:if>  
                                                                    <aura:if isTrue="{!vou.ERP7__Approved__c==false}">		
                                                                        <ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"  data-record="{#vou.Id}" onclick="{!c.approveVoucher}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#vou.Id}" >{!$Label.c.Approve_ManageLeave}</span></a>
                                                                        </ui:actionMenuItem>
                                                                    </aura:if>  
                                                                    
                                                                    
                                                                </ui:menuList>
                                                            </ui:menu>
                                                            
                                                        </td>
                                                    </tr>
                                                </aura:iteration>  
                                                <aura:set attribute="else">
                                                    <tr>
                                                        <td colspan="12" class=" AccountsPayable-newClass15">
                                                            <div class="slds-notify_container slds-is-relative AccountsPayable-newClass16">
                                                                <div class="slds-notify slds-notify_toast slds-theme_warning AccountsPayable-newClass17" role="alert">
                                                                    <span class="slds-assistive-text">{!$Label.c.warning}</span>
                                                                    <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                                                    <div class="slds-notify__content AccountsPayable-newClass18">
                                                                        <h2 class="slds-text-heading_small AccountsPayable-newClass23">{!$Label.c.Acc_Pay_No_Items_in_Table}</h2>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </aura:set>
                                            </aura:if>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="epr_Mark7 ">
                            <div class="slds-docked-form-footer h60px">
                                <aura:if isTrue="{!v.Vouchers.length>0}">
                                    <div class="col-md-2 AccountsPayable-newClass21">
                                        <div class="slds-grid" >
                                            <div class="slds-col AccountsPayable-newClass22">
                                                {!$Label.c.Acc_Recev_Show}&nbsp;
                                            </div>  
                                            <div class="slds-col AccountsPayable-newClass23"> 
                                                <lightning:select class="slds-show_inline-block no-lable"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                    <option value="10">10</option>
                                                    <option value="25">25</option>
                                                    <option value="50">50</option>
                                                    <option value="100">100</option>
                                                    <option value="150">150</option>
                                                </lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                </aura:if>
                                <aura:if isTrue="{!v.Vouchers.length>0}">
                                    
                                    <div class="col-md-3 AccountsPayable-newClass24">
                                         {!$Label.c.Acc_Recev_Showing}&nbsp;<span class="text-lightblue">{!v.startCount}-{!v.endCount}</span>&nbsp;{!$Label.c.Acc_Recev_of_total}&nbsp;<span class="text-lightblue">{!v.recSize}</span>&nbsp;{!$Label.c.Acc_Recev_Records}
                                    </div>
                                    
                                </aura:if> 
                                
                                <aura:if isTrue="{!v.Vouchers.length>0}">
                                    
                                    <div class="col-md-4 AccountsPayable-newClass25">
                                        <nav aria-label="Page navigation example">
                                            <ul class="pagination m-0">
                                                <li>
                                                    <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                                </li>
                                                <li>
                                                    <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.Previous}"> {!$Label.c.Previous}</a> <!-- -->
                                                </li>
                                                
                                                <li>
                                                    <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> <!--  -->
                                                </li>
                                                <li>
                                                    <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                                </li>
                                            </ul>
                                        </nav>
                                    </div>
                                    
                                </aura:if> 
                                <aura:if isTrue="{!v.Vouchers.length>0}">
                                    
                                    <div class="col-md-2">
                                        <div class="slds-grid">
                                            <div class="slds-col slds-p-top_x-small">
                                                {!$Label.c.page} 
                                            </div>
                                            <div class="slds-col ">
                                                
                                                <ui:inputNumber aura:id="ikVou" value="{!v.PageNum}" change="{!c.OfsetChange}" class="width100p"/> 
                                            </div>
                                            <div class="slds-col slds-p-top_x-small"><span class="text-lightblue"> {!$Label.c.page_of}&nbsp;{!v.PNS.length}</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                </aura:if>
                            </div>
                        </div>
                        
                    </div>
                </aura:if>
                <aura:if isTrue="{!v.showModal}">
                    <div class="demo-only" aura:id="PayVoucher">
                        <section  tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-modal_medium slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header AccountsPayable-newClass33" >
                                    <!-- <lightning:button iconName="utility:close"  variant="inverse" onclick="{!c.hideModal}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse"/>-->
                                    
                                    <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate AccountsPayable-newClass32">{!$Label.c.Acc_Pay_Pay_Voucher}</h4>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="slds-grid slds-wrap slds-m-top--small">
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:select name="RecordType" label="{!$Label.c.Select_a_RecordType}" aura:id="PayRecordType" onchange="{!c.fetchDetails}"><!-- onchange="{!c.fetchDetails}" -->
                                                        <aura:iteration items="{!v.paymentRecordType}" var="item">
                                                            <!--<option text="Bank Payments" value="Bank Payments" />
                                                                    <option text="Card Payments" value="Card Payments"/>-->
                                                            <option text="{!item.name}" value="{!item.name}" selected="{!item.defaultRecordTypeMapping}" />
                                                        </aura:iteration>
                                                    </lightning:select>
                                                    <!--<ui:inputText value="{!v.voucherPayment.Name}" label="Name" required="true" aura:id="payvoucherName" class="slds-input"/>-->
                                                </div>
                                            </div>    
                                        </div>
                                        <div class="slds-col slds-p-horizontal--medium slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                            <div class="slds-form-element">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.voucherPayment.ERP7__Account__c}" label="{!$Label.c.EmployeeReview_Organisation}" required="true" aura:Id="paymentvendorAcc" qry=" AND (ERP7__Account_Type__c = 'Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')" hideRemove="true"/><!--NameValue="{!v.Bill.ERP7__Vendor__r.Name}" -->
                                            </div>
                                        </div>
                                        <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                            <lightning:input type="number" value="{!v.payAmount}" label="{!$Label.c.Acc_Pay_Payment_Amount}" formatter="currency" step="0.01" disabled="true"/>
                                        </lightning:layoutItem>
                                         <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small" title="">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <!--<ui:inputCurrency aura:id="paymentamount" label="{!$Label.c.Cash_Payment_Amount}" value="{!v.voucherPayment.ERP7__Amount__c}"  format="0.00" class="slds-input" required="true"/>-->
                                                        <lightning:input type="date" name="input1" label="{!$Label.c.Acc_Pay_Payment_Date}"  value="{!v.voucherPayment.ERP7__Payment_Date__c}" required="true" onchange="{!c.onDateFieldChange}"/>
                                                        <div class="AccountsPayable-newClass34">{!v.DateErrMsg}</div>
                                                    </div>
                                                </div>    
                                            </div>
                                        <aura:if isTrue="{!v.displayDiscount}">
                                        <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                            <lightning:input type="percentage" value="{!v.voucherPayment.ERP7__Discount_Rate__c}" label="{!$Label.c.Acc_Pay_Discount_Percentage}" disabled="true" />
                                        </lightning:layoutItem>
                                        <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                            <lightning:input type="number" value="{!v.voucherPayment.ERP7__Discount_Amount__c}" label="{!$Label.c.Discount_Amount}" formatter="currency" step="0.01" disabled="true"/>
                                        </lightning:layoutItem>
                                        </aura:if>
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <!--<ui:inputCurrency aura:id="paymentamount" label="Amount" value="{!v.voucherPayment.ERP7__Amount__c}"  format="0.00" class="slds-input" required="true"/>-->
                                                    <lightning:input aura:id="paymentamount"
                                                                     label="{!$Label.c.Invoice_Amount_Paid}"
                                                                     class="field"
                                                                     value="{!v.voucherPayment.ERP7__Amount__c}"
                                                                     required="true"
                                                                     type="currency" />

                                                    <!--ui:inputCurrency aura:id="paymentamount" label="{!$Label.c.Invoice_Amount_Paid}" class="field" value="{!v.voucherPayment.ERP7__Amount__c}" required="true"/-->
                                                    <div class="AccountsPayable-newClass34">{!v.AmtErrMsg}</div>
                                                </div>
                                            </div>    
                                        </div>
                                        <aura:if isTrue="{!v.displayDiscount}">
                                        <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                            <lightning:input type="number" value="{!(v.voucherPayment.ERP7__Amount__c-v.voucherPayment.ERP7__Discount_Amount__c)}" label="{!$Label.c.Acc_Pay_Final_amount_after_discount}" formatter="currency" step="0.01" disabled="true" />
                                        </lightning:layoutItem>
                                        </aura:if>
                                        
                                        <!--<div class="slds-col slds-p-horizontal-/-medium slds-size-/-1-of-2 slds-m-top-/-small">
                                                    <div class="slds-form-element">
                                                        <ERP7:CustomInputLookUp objectAPIName="ERP7__Voucher__c" IconName="standard:account" selectedRecordId="{!v.voucherPayment.ERP7__Voucher__c}" label="Voucher" required="true" aura:Id="paymentVoucher"  hideRemove="true"/>
                                                    </div>
                                                </div>-->
                                        
                                        
                                        <aura:if isTrue="{!v.cnAmount>0}">
                                            <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                                <lightning:input type="number" value="{!(v.payAmount - v.cnAmount)}" label="{!$Label.c.Acc_Pay_Balance_Amount}" formatter="currency" step="0.01" disabled="true"/>
                                            </lightning:layoutItem>
                                            <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                                <lightning:input type="number" value="{!v.cnAmount}" label="{!$Label.c.Acc_Pay_Applied_Credit}" formatter="currency" step="0.01" disabled="true"/>
                                            </lightning:layoutItem>
                                            
                                        </aura:if>
                                        <aura:if isTrue="{!!v.NoPayment}">
                                            
                                            
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <lightning:select name="RecordType" label="{!$Label.c.Payment_Method}" aura:id="PayRecordTy" ><!-- onchange="{!c.fetchDetails}" -->
                                                            <aura:iteration items="{!v.paymentGatewayList}" var="item">
                                                                
                                                                <option text="{!item}" value="{!item}" selected="{!v.selectedType}" />
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                </div>    
                                            </div>
                                            
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                                <div class="slds-form-element">
                                                    
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:account" selectedRecordId="{!v.voucherPayment.ERP7__Payment_Account__c }" label="{!$Label.c.Acc_Pay_Payment_Account}" required="true"  aura:Id="paymentAccount" qry="{!v.AccountsFilter}"/>
                                                    <div class="AccountsPayable-newClass34">{!v.AcctErrMsg}</div>
                                                </div>
                                            </div>
                                            
                                           
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <ui:inputText aura:id="paymentamount" label="{!$Label.c.Reference_No}" class="field" value="{!v.voucherPayment.ERP7__Reference_Cheque_No__c}"/>
                                                    </div>
                                                </div>    
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                                <div class="slds-form-element">
                                                    <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Acc_Pay_Account_Balance}</label>
                                                    <div class="slds-form-element__control">
                                                        {!v.currCode}&nbsp;<ui:outputCurrency aura:id="AccountBalance" value="{!v.PaymentAccountBalance}"  format="0.00"   /><!--label="Account Balance"-->
                                                        <aura:if isTrue="{!v.PaymentAccountBalanceConversion!=Null}">
                                                            &nbsp;({!v.currencyType}&nbsp;<ui:outputCurrency aura:id="AccountBalanceCon" value="{!v.PaymentAccountBalanceConversion}"  format="0.00"   />)
                                                        </aura:if>
                                                    </div>
                                                </div>    
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top_x-small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <!--ui:inputCheckbox value="{!v.post}" label="{!$Label.c.Acc_Recev_Posted}" class="slds-checkbox"/-->
                                                        <lightning:input type="checkbox"
                                                                         label="{!$Label.c.Acc_Recev_Posted}"
                                                                         class="slds-checkbox"
                                                                         checked="{!v.post}" />
                                                    </div>
                                                </div>    
                                            </div>
                                        </aura:if>
                                        <lightning:layoutItem size="12" class="slds-p-top_medium">
                                            <div class="card shadow-custom m-3">
                                                <div class="card-body">
                                                    <aura:if isTrue="{!v.debitNotes1.length>0}">
                                                        <a href="javascript:void(0)" onclick="{!c.displayCreditNote}">
                                                            <h3 class="creditnotes-text"><lightning:icon iconName="utility:chevrondown" size="x-small"></lightning:icon>&nbsp;{!$Label.c.Acc_Pay_Debit_Notes}</h3>
                                                            
                                                        </a>
                                                        <div class="mb-3"></div>
                                                    </aura:if>
                                                    <aura:if isTrue="{!and(v.debitNotes1.length>0, v.displayCN)}">
                                                        <!--<aura:if isTrue="{!v.PaymentAccountBalance>0}">-->
                                                        <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                                            <thead>
                                                                <tr class="slds-line-height_reset">
                                                                    <th class="" scope="col">
                                                                        <div class="slds-truncate" title="Name">{!$Label.c.Debit_Note}</div>
                                                                    </th>
                                                                    <th class="" scope="col">
                                                                        <div class="slds-truncate" title="Credit">{!$Label.c.Acc_Pay_Available_Credit}</div>
                                                                    </th>
                                                                    <th class="" scope="col">
                                                                        <div class="slds-truncate" title="Credit">{!$Label.c.Acc_Recev_Debit}</div>
                                                                    </th>
                                                                    <th  scope="col" >
                                                                        <div class="slds-truncate" title="Balance">{!$Label.c.Acc_Pay_Balance}</div>
                                                                    </th>
                                                                    
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <aura:if isTrue="{!v.debitNotes1.length>0}">
                                                                    <aura:iteration items="{!v.debitNotes1}" var="item">
                                                                        <tr class="slds-hint-parent">
                                                                            <td data-label="Reference #">
                                                                                <a href="{!('/'+item.debNote.Id)}" target="_blank">{!item.debNote.Name}</a>
                                                                            </td>
                                                                            <td data-label="Total Amount" >
                                                                                <lightning:formattedNumber value="{!item.debNote.ERP7__Remaining_Amount__c}" style="currency"/>
                                                                            </td>
                                                                            <td data-label="Payment">
                                                                                <lightning:input type="number" aura:id="appliedpayment" value="{!item.debitAmount}" variant="label-hidden" name="{!item.Id}" formatter="currency" step="0.01" class="cinput2" max="{!(item.credNote.ERP7__Credit__c-item.credNote.ERP7__Debit__c)}" onchange="{!c.updatePaymentAmount}"/>
                                                                            </td>
                                                                            <td data-label="Amount Due" >
                                                                                <lightning:formattedNumber value="{!(item.debNote.ERP7__Remaining_Amount__c -item.debitAmount)}" style="currency"/>
                                                                            </td>
                                                                        </tr>
                                                                        
                                                                    </aura:iteration>
                                                                </aura:if>
                                                            </tbody>
                                                        </table>
                                                    </aura:if>
                                                    <!--</aura:if>-->
                                                </div>
                                            </div>
                                        </lightning:layoutItem>
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-2 slds-m-top--small">
                                        </div>
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-2 slds-m-top--small">
                                        </div>
                                    </div>
                                </div>
                                <footer class="slds-modal__footer AccountsPayable-newClass15">
                                    <lightning:button class="slds-button slds-button--neutral" label="{!$Label.c.QuotationConsole_Cancel}" onclick="{!c.hideModal}" variant="neutral"/>
                                    <aura:if isTrue="{!v.showSave}">
                                        <lightning:button class="slds-button slds-button--brand" variant="brand"  label="{!$Label.c.ContractConsole_Save}" disabled="{!or(v.PaymentAccountBalance>0, v.NoPayment)?false:(v.cnAmount>0)?false:true}" onclick="{!c.pay_Voucher}"/> <!-- disabled="{!or(v.PaymentAccountBalance>0, v.NoPayment)?false:(v.cnAmount>0)?false:true}" --><!-- Moin removed this on 06th july 2023 -->
                                        <aura:set Attribute="else">
                                            <lightning:button class="slds-button slds-button--brand" variant="brand" label="{!$Label.c.ContractConsole_Save}" onclick="{!c.pay_Voucher}"/>
                                        </aura:set>
                                    </aura:if>
                                </footer>
                            </div> 
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                    </div>
                </aura:if>
                <aura:if isTrue="{!v.showMultiPayment}">
                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-modal_medium slds-fade-in-open">
                            <div class="slds-modal__container">
                                <header class="slds-modal__header AccountsPayable-newClass33">
                                    <!-- <lightning:button iconName="utility:close"  variant="inverse" onclick="{!c.hideModal}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse"/>-->
                                    
                                    <h4 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate AccountsPayable-newClass32">{!$Label.c.Acc_Pay_Pay_Voucher} </h4>
                                </header>
                                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                                    <div class="AccountsPayable-newClass34_1">{!v.AmtErrMsg}</div>
                                    <table class="slds-table slds-table_bordered">
                                        <thead>
                                            <tr>
                                                <th>{!$Label.c.Acc_Pay_Voucher_Name}</th>
                                                <th>{!$Label.c.Acc_Pay_Bill}</th>
                                                <th>{!$Label.c.EmployeeReviewV2_Due_Date}</th>
                                                <th>{!$Label.c.Acc_Pay_Due_Amount}</th>
                                                <th>{!$Label.c.Acc_Recev_Paid_Amount}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:iteration items="{!v.listOfVouchers}" var="vou" indexVar="index">
                                                <tr>
                                                    <td><lightning:formattedUrl value="{!'/'+vou.Id}" label="{!vou.Name}" target="_blank" /></td>
                                                    <td><lightning:formattedUrl value="{!'/'+vou.ERP7__Vendor_invoice_Bill__r.Id}" label="{!vou.ERP7__Vendor_invoice_Bill__r.Name}" target="_blank" /></td>
                                                    <td><lightning:formattedText value="{!vou.ERP7__Vendor_invoice_Bill__r.ERP7__Due_Date__c}"/></td>
                                                    <td><lightning:input variant="label-hidden" type="number" value="{!vou.ERP7__Amount_Due__c}" step=".01" disabled="true"/></td>
                                                    <td><lightning:input variant="label-hidden" type="number" value="{!vou.ERP7__Amount__c}" required="true" onchange="{!c.handleTotalAmount}" step=".01"/></td>
                                                </tr>
                                            </aura:iteration>                                                    
                                        </tbody>
                                    </table>
                                    
                                    <div class="slds-grid slds-wrap slds-m-top--small">
                                        
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:select name="RecordType" label="{!$Label.c.Select_a_RecordType}" aura:id="PayMultiRecordType" onchange="{!c.fetchDetails}"><!-- onchange="{!c.fetchDetails}" -->
                                                        <aura:iteration items="{!v.paymentRecordType}" var="item">
                                                            <!--<option text="Bank Payments" value="Bank Payments" />
                                                                    <option text="Card Payments" value="Card Payments"/>-->
                                                            <option text="{!item.name}" value="{!item.name}" selected="{!item.defaultRecordTypeMapping}" />
                                                        </aura:iteration>
                                                    </lightning:select>
                                                    <!--<ui:inputText value="{!v.voucherPayment.Name}" label="Name" required="true" aura:id="payvoucherName" class="slds-input"/>-->
                                                </div>
                                            </div>    
                                        </div>
                                        <div class="slds-col slds-p-horizontal--medium slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.MultiVoucherPaymentInfo.ERP7__Account__c}" label="{!$Label.c.EmployeeReview_Organisation}" required="true" qry=" AND (ERP7__Account_Type__c = 'Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor'" hideRemove="true"/><!--NameValue="{!v.Bill.ERP7__Vendor__r.Name}" -->
                                            </div>
                                        </div>
                                        
                                        <div class="slds-col slds-p-horizontal--medium slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.MultiVoucherPaymentInfo.ERP7__Accounts__c}" label="{!$Label.c.InventoryConsole_Vendor}" required="true" qry=" AND (ERP7__Account_Type__c = 'Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')" hideRemove="true"/><!--NameValue="{!v.Bill.ERP7__Vendor__r.Name}" -->
                                            </div>
                                        </div>
                                        <aura:if isTrue="{!!v.NoPayment}">
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small" title="">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <!--<ui:inputCurrency aura:id="paymentamount" label="Amount" value="{!v.voucherPayment.ERP7__Amount__c}"  format="0.00" class="slds-input" required="true"/>-->
                                                    <lightning:input type="date" name="input1" label="{!$Label.c.Acc_Pay_Payment_Date}"  value="{!v.MultiVoucherPaymentInfo.ERP7__Payment_Date__c}" required="true"/>
                                                    <div class="AccountsPayable-newClass34">{!v.DateErrMsg1}</div>
                                                </div>
                                            </div>    
                                        </div>
                                        </aura:if>
                                        <!--<div class="slds-col slds-p-horizontal-/-medium slds-size-/-1-of-2 slds-m-top-/-small">
                                                    <div class="slds-form-element">
                                                        <ERP7:CustomInputLookUp objectAPIName="ERP7__Voucher__c" IconName="standard:account" selectedRecordId="{!v.voucherPayment.ERP7__Voucher__c}" label="Voucher" required="true"  hideRemove="true"/>
                                                    </div>
                                                </div>-->
                                        
                                        
                                        
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small" title="Can not edit for multiple vouchers payment">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control" >
                                                    <ui:inputCurrency label="{!$Label.c.Cash_Payment_Amount}" class="field" value="{!v.multiTotalAmount}" required="true" disabled="true"/>
                                                    <!--<div class="AccountsPayable-newClass34">{!v.AmtErrMsg}</div>-->
                                                </div>
                                            </div>    
                                        </div>
                                        <aura:if isTrue="{!!v.NoPayment}">
                                        <aura:if isTrue="{!v.displayDis}">
                                        <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <lightning:select name="Discount Plan" label="{!$Label.c.Discount_Plan}" aura:id="mySelect" value="{!v.selectedTerm}" onchange="{!c.TermChange}"><!-- onchange="{!c.fetchDetails}" -->
                                                        <aura:iteration items="{!v.payTerms}" var="item">
                                                            <!--<option text="Bank Payments" value="Bank Payments" />
                                                                    <option text="Card Payments" value="Card Payments"/>-->
                                                            <option text="{!item}" value="{!item}"  />
                                                        </aura:iteration>
                                                    </lightning:select>
                                                    <!--<ui:inputText value="{!v.voucherPayment.Name}" label="Name" required="true" aura:id="payvoucherName" class="slds-input"/>-->
                                                </div>
                                            </div>    
                                        </div>
                                            <aura:if isTrue="{!v.MultiVoucherPaymentInfo.ERP7__Discount_Rate__c!=null}">
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small" title="Can not edit for multiple vouchers payment">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control" >
                                                        <lightning:input type="number" value="{!v.MultiVoucherPaymentInfo.ERP7__Discount_Rate__c}" label="{!$Label.c.Discount_Amount}" formatter="currency" step="0.01" disabled="true"/>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small" title="Can not edit for multiple vouchers payment">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control" >
                                                        <lightning:input type="number" value="{!v.MultiVoucherPaymentInfo.ERP7__Discount_Amount__c}" label="{!$Label.c.Discount_Amount}" formatter="currency" step="0.01" disabled="true"/>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small" title="Can not edit for multiple vouchers payment">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control" >
                                                        <lightning:input type="number" value="{!(v.multiTotalAmount-v.MultiVoucherPaymentInfo.ERP7__Discount_Amount__c)}" label="{!$Label.c.Acc_Pay_Final_amount_after_discount}" formatter="currency" step="0.01" disabled="true" />
                                                    </div>
                                                </div>
                                            </div>
                                                
                                            </aura:if>
                                        </aura:if>
                                        </aura:if>
                                        <aura:if isTrue="{!v.cnAmount>0}">
                                            <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                                <lightning:input type="number" value="{!(v.multiTotalAmount - v.cnAmount)}" label="Payed Amount" formatter="currency" step="0.01" disabled="true"/>
                                            </lightning:layoutItem>
                                            <lightning:layoutItem size="4" padding="horizontal-small" class="slds-m-top_x-small">
                                                <lightning:input type="number" value="{!v.cnAmount}" label="{!$Label.c.Acc_Pay_Applied_Credit}" formatter="currency" step="0.01" disabled="true"/>
                                            </lightning:layoutItem>
                                            
                                        </aura:if>
                                        <aura:if isTrue="{!!v.NoPayment}">
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                                <div class="slds-form-element">
                                                    
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Chart_of_Accounts__c" IconName="standard:account" selectedRecordId="{!v.MultiVoucherPaymentInfo.ERP7__Payment_Account__c }" label="{!$Label.c.Acc_Pay_Payment_Account}" required="true" qry="{!v.AccountsFilter}"/>
                                                    <div class="AccountsPayable-newClass34">{!v.AcctErrMsg}</div>
                                                </div>
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <lightning:select name="RecordType" label="{!$Label.c.Payment_Method}" aura:id="PayRecord" ><!-- onchange="{!c.fetchDetails}" -->
                                                            <aura:iteration items="{!v.paymentGatewayList}" var="item">
                                                                <!--<option text="Bank Payments" value="Bank Payments" />
                                                                    <option text="Card Payments" value="Card Payments"/>-->
                                                                <option text="{!item}" value="{!item}" selected="{!v.selectedType}" />
                                                            </aura:iteration>
                                                        </lightning:select>
                                                        <!--<ui:inputText value="{!v.voucherPayment.Name}" label="Name" required="true" aura:id="payvoucherName" class="slds-input"/>-->
                                                    </div>
                                                </div>    
                                            </div>
                                            
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <!--<ui:inputCurrency aura:id="paymentamount" label="{!$Label.c.Cash_Payment_Amount}" value="{!v.voucherPayment.ERP7__Amount__c}"  format="0.00" class="slds-input" required="true"/>-->
                                                        <ui:inputText aura:id="paymentamount" label="{!$Label.c.Reference_No}" class="field" value="{!v.MultiVoucherPaymentInfo.ERP7__Reference_Cheque_No__c}"/>
                                                    </div>
                                                </div>    
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                                <div class="slds-form-element">
                                                    <div class="slds-form-element__control">
                                                        <ui:inputCheckbox value="{!v.postForMulti}" label="{!$Label.c.Acc_Recev_Posted}" class="slds-checkbox"/>
                                                    </div>
                                                </div>    
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                                <div class="slds-form-element">
                                                    <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Acc_Pay_Account_Balance}</label>
                                                    <div class="slds-form-element__control">
                                                        {!v.currCode} <ui:outputCurrency aura:id="AccountBalance" value="{!v.PaymentAccountBalance}"  format="0.00"   /><!--label="Account Balance"-->
                                                        <!--<ui:outputCurrency aura:id="curr" value="{!v.PaymentAccountBalance}"/>-->
                                                        <aura:if isTrue="{!v.PaymentAccountBalanceConversion!=Null}">
                                                            ({!v.currencyType} <ui:outputCurrency aura:id="AccountBalanceCon" value="{!v.PaymentAccountBalanceConversion}"  format="0.00"   />)
                                                        </aura:if>
                                                    </div>
                                                </div>    
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            </div>
                                            <div class="slds-col slds-p-horizontal--medium slds-size--1-of-3 slds-m-top--small">
                                            </div>
                                        </aura:if>
                                    </div>
                                
                                <aura:if isTrue="{!v.debitNotes1.length>0}">
                                                <a href="javascript:void(0)" onclick="{!c.displayCreditNote}">
                                                    <h3 class="creditnotes-text"><lightning:icon iconName="utility:chevrondown" size="x-small"></lightning:icon>&nbsp;{!$Label.c.Acc_Pay_Debit_Notes}</h3>
                                                    
                                                </a>
                                                <div class="mb-3"></div>
                                            </aura:if>
                                            <aura:if isTrue="{!and(v.debitNotes1.length>0, v.displayCN)}">
                                                <!--<aura:if isTrue="{!v.PaymentAccountBalance>0}">-->
                                                <table class="slds-table slds-table_cell-buffer slds-table_bordered">
                                                    <thead>
                                                        <tr class="slds-line-height_reset">
                                                            <th class="" scope="col">
                                                                <div class="slds-truncate" title="Name">{!$Label.c.Debit_Note}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class="slds-truncate" title="Credit">{!$Label.c.Acc_Pay_Available_Credit}</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class="slds-truncate" title="Credit">{!$Label.c.Acc_Recev_Debit}</div>
                                                            </th>
                                                            <th  scope="col" >
                                                                <div class="slds-truncate" title="Balance">{!$Label.c.Acc_Pay_Balance}</div>
                                                            </th>
                                                            
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <aura:if isTrue="{!v.debitNotes1.length>0}">
                                                            <aura:iteration items="{!v.debitNotes1}" var="item">
                                                                <tr class="slds-hint-parent">
                                                                    <td data-label="Reference #">
                                                                        <a href="{!('/'+item.debNote.Id)}" target="_blank">{!item.debNote.Name}</a>
                                                                    </td>
                                                                    <td data-label="Total Amount" >
                                                                        <lightning:formattedNumber value="{!item.debNote.ERP7__Remaining_Amount__c}" style="currency"/>
                                                                    </td>
                                                                    <td data-label="Payment">
                                                                        <lightning:input type="number" aura:id="appliedpayment" value="{!item.debitAmount}" variant="label-hidden" name="{!item.Id}" formatter="currency" step="0.01" class="cinput2" max="{!(item.credNote.ERP7__Credit__c-item.credNote.ERP7__Debit__c)}" onchange="{!c.updatePaymentAmountMulti}"/>
                                                                    </td>
                                                                    <td data-label="Amount Due" >
                                                                        <lightning:formattedNumber value="{!(item.debNote.ERP7__Remaining_Amount__c -item.debitAmount)}" style="currency"/>
                                                                    </td>
                                                                </tr>
                                                                
                                                            </aura:iteration>
                                                        </aura:if>
                                                    </tbody>
                                                </table>
                                            </aura:if>
                                    </div>
                                <footer class="slds-modal__footer AccountsPayable-newClass15">
                                    <lightning:button class="slds-button slds-button--neutral" label="{!$Label.c.Cancel_ManageLeave}" onclick="{!c.hideMultiModal}" variant="neutral"/>
                                    <aura:if isTrue="{!!v.NoPayment}">
                                        <aura:if isTrue="{!v.showSave}">
                                            <lightning:button class="slds-button slds-button--brand" variant="brand" disabled="{!v.PaymentAccountBalance>0?false:true}" label="{!$Label.c.ContractConsole_Save}" onclick="{!c.pay_Voucher1}"/> <!-- disabled="{!v.PaymentAccountBalance>0?false:true}" --><!-- Moin removed this on 06th july 2023 -->
                                            <aura:set Attribute="else">
                                                <lightning:button class="slds-button slds-button--brand" variant="brand" label="{!$Label.c.ContractConsole_Save}" onclick="{!c.pay_Voucher1}"/>
                                            </aura:set>
                                        </aura:if>
                                    </aura:if>
                                    <aura:if isTrue="{!v.NoPayment}">
                                        <lightning:button class="slds-button slds-button--brand" variant="brand" label="Apply Credit" onclick="{!c.apply_Voucher1}"/>
                                    </aura:if>
                                </footer>
                            </div> 
                        </section>
                        <div class="slds-backdrop slds-backdrop_open"></div>
                </aura:if>
                <aura:if isTrue="{!and(equals(v.selectedTab,'Vendor'),v.grid)}">
                    <div class="maqsood erp_Mark7 AccountsPayable-newClass29 pb-5 pt-0">
                        
                        
                        <aura:if isTrue="{!v.vendorAccounts.length>0}">
                            <div class="card-header bg-white">
                               <div class="slds-grid">
                                            <div class="slds-col">
                                                <h6 class="slim-card-title">
                                                    <c:StockTakeSearch searchString="{!v.setSearch}"/>
                                                </h6>
                                            </div>
                                            <div class="slds-col">
                                                
                                                
                                            </div>
                                             <div class="col-8 text-right">
                                                <div class="slds-grid float-right">
                                                    <div class="AccountsPayable-newClass4  slds-m-right_small" ><c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" /></div>
                                                    <div class="maqdropdown">
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Vendor')}">
                                                            <a class="addNewBTN AccountsPayable-newClass5" onclick="{!c.createAccount}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Vendor} 
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}">
                                                            <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}"> 
                                                                <aura:renderIf isTrue="{!v.showMultiPO}">
                                                                    <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 ml-1" onclick="{!c.createMultiPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} 
                                                                    </a>
                                                                    <aura:set attribute="else">
                                                                        &nbsp;
                                                                        <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 " onclick="{!c.createPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} 
                                                                        </a> 
                                                                    </aura:set>
                                                                </aura:renderIf>
                                                                
                                                            </aura:if>
                                                        </aura:if> 
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Bills')}">
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Bill} 
                                                            </a>&nbsp;
                                                            <aura:if isTrue="{!v.tabular}">
                                                                <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.matchBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                    {!$Label.c.Acc_Pay_Match_Bill}         
                                                                </a>
                                                            </aura:if>
                                                            <!-- <div class="maqdropdown-content">
                                       
                                    </div>  -->                 
                                                        </aura:if> 
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Vouchers')}">
                                                            
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.doneMultiPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                <i class="fa fa-credit-card" aria-hidden="true"></i> &nbsp; {!$Label.c.Acc_Pay_Make_Payment}              
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Payments')}">
                                                            
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_Cheque_Payment}               
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Credit_notes')}">
                                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createCredit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Credit_Note}                                                             </a>
