                                                    <!--<div class="slds-truncate2" title="Paid Amount">{!$Label.c.Acc_Recev_Paid_Amount}
                                                    <span onclick="{!c.getSortedRecords}" data-service="DESC" data-record="ERP7__Amount_Paid__c" title="Descending Order">
                                                        <lightning:icon iconName="utility:arrowdown"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                     
