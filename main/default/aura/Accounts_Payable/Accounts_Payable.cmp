                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND (ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Total_Due__c" Label="{!$Label.c.Acc_Pay_Balance_Due}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if>  
                                                    </div>
                                                </th>
                                                
                                                <th class="slds-cell-shrink" scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
