                                                        <ui:inputCheckbox label="" aura:id="cbox_bill" class="slds-checkbox" name="{!bill.Id}" change="{!c.selectedBill}" updateOn="change"/>
                                                    </td>
                                                    <td scope="row" data-label="{!bill.Name}">
                                                        <div class="slds-truncate2" title="{!bill.Name}">{!bill.Name}</div>
                                                    </td>
                                                    <td data-label="Vendor Name">
                                                        <div class="slds-truncate2" title="{!bill.ERP7__Vendor__r.Name}"><a href="{!'/'+bill.ERP7__Vendor__r.Id}" target="_blank">{!bill.ERP7__Vendor__r.Name}</a></div>
                                                    </td>
                                                    <td data-label="Purchase Order Name">
                                                        <div class="slds-truncate2" title="{!bill.ERP7__Purchase_Order__r.Name}">{!bill.ERP7__Purchase_Order__r.Name}</div>
                                                    </td>
                                                    <td data-label="Status slds-hide">
                                                        <div class="slds-truncate2" title="{!bill.ERP7__Status__c}">{!bill.ERP7__Status__c}</div>
                                                    </td>
                                                    <td data-label="Paid Amount">
                                                        <div class="slds-truncate2" title="{!bill.ERP7__Amount_Paid__c}"><ui:outputNumber format="#0.00" value="{!bill.ERP7__Amount_Paid__c}"/></div>
                                                    </td>
                                                    <td data-label="Total Due">
                                                        <div class="slds-truncate2" title="{!bill.ERP7__Amount_Due__c}"><ui:outputNumber format="#0.00" value="{!bill.ERP7__Amount_Due__c}"/></div>
                                                    </td>
                                                    
                                                </tr>
