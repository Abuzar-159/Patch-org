<aura:component implements="force:appHostable" controller="AccountsPayable"> 
    <ltng:require styles="{!join(',',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.css',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.min.css',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css',$Resource.PickPackShipResource + '/assets/styles/font-awesome.css' )}"/>
    <ltng:require styles="{!join(',',$Resource.SLDS+ '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
    <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
    <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>   
    
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <ltng:require styles="resource/ERP7__CMP_CSS/CSS/AccountsPayable.css"/> 
    <ltng:require styles="resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/AccountsReceivable.css"/> 
    <ltng:require styles="/resource/SLDS/assets/styles/salesforce-lightning-design-system-vf.css"/>
    
    <aura:attribute name="showMultiPO" type="Boolean" default="false"/><!-- to show Multi PO  based on custom setttings in new PO page-->
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="FromClosing"     type="String" default="false"/> 
    <aura:attribute name="AccoutingPeriod"                  type="Accounting_Period__c" default="{'sobjectType' : 'Accounting_Period__c'}" />
    <aura:handler name="change" value="{!v.selectedTab}" action="{!c.switchTab}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.handleComponentEvent}"/>
    <aura:handler name="change" value="{!v.Organisation.Id}" action="{!c.FilterByOrg}"/>
    <aura:attribute name="vendorAccounts" type="List"/>
    <aura:attribute name="payTerms" type="List"/>
    <aura:attribute name="SelectedAccounts" type="List"/>
    <aura:attribute name="SelectedPOS" type="List"/>
    <aura:attribute name="SelectedVen" type="List"/>
    <aura:attribute name="NoPayment" type="Boolean" default="false"/>
    <aura:attribute name="approvalProcess" type="Boolean" default="false"/>
    <aura:attribute name="undisplayVoucher" type="Boolean" default="false"/>
    <aura:attribute name="undisplayEditVouPay" type="Boolean" default="false"/>
    <aura:attribute name="displayDiscount" type="Boolean" default="false"/>
    <aura:attribute name="displayDis" type="Boolean" default="false"/>
    <aura:attribute name="Organisation" type="Map" default="{}"/>
    <aura:attribute name="debitNotes1" type="Object[]" default="{'sObjectType':'DNWrapper'}"/>
    <aura:attribute name="Bills" type="List"/>
    <aura:attribute name="DueFilter" type="Integer" default="-1"/>
    <aura:attribute name="SelectedPayments" type="List"/>
    <aura:attribute name="displayCN" type="Boolean" default="true"/>
    <aura:attribute name="SelectedBills" type="List"/>
    <aura:attribute name="SelectedBillIds" type="List"/>
    <aura:attribute name="DebitNotes" type="List"/>
    <aura:attribute name="Payments" type="List"/>
    <aura:attribute name="voucherPayment" type="Map" default="{}"/>
    <aura:attribute name="MultiVoucherPayment" type="Object"/>
    <aura:attribute name="MultiVoucherPaymentInfo" type="Map" default="{}"/>
    <aura:attribute name="listOfVouchers" type="Object"/>
    <aura:attribute name="Vouchers" type="List"/>
    <aura:attribute name="SelectedVouchers" type="List"/>
    <aura:attribute name="PaymentAccountBalance" type="Currency" default="0.00"/>
    <aura:attribute name="PaymentAccountBalanceConversion" type="Currency" default="0.00"/>
    <aura:attribute name="creditNotes" type="Object[]"/> 
    <aura:attribute name="CreditNotesSL" type="Object[]"/> 
    <aura:attribute name="POList" type="List"/>
    <aura:attribute name="Contacts" type="List"/>
    <aura:attribute name="ShowPOType" type="Boolean" default="false"/>
    <aura:attribute name="displayCredNote" type="Boolean" default="false"/>
    <aura:attribute name="showModal" type="Boolean" default="false"/> 
    <aura:attribute name="singleVoucherToPay" type="String" default=""/>
    <aura:attribute name="multipleVoucherVendor" type="String" default=""/>
    <aura:attribute name="showMultiPayment" type="Boolean" default="false"/>
    <aura:attribute name="showOnlineModal" type="Boolean" default="false"/> 
    <aura:attribute name="showSave" type="Boolean" default="true"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="AmtErrMsg" type="String" />
    <aura:attribute name="AcctErrMsg" type="String" />
    <aura:attribute name="selectedTerm" type="String" />
    <aura:attribute name="DateErrMsg" type="String" />
    <aura:attribute name="DateErrMsg1" type="String" />
    <aura:attribute name="selectedType" type="String" />
    <aura:attribute name="paymentRecordType" type="List" default="[]"/>
    <aura:attribute name="paymentGatewayList" type="List" default="[]"/>
    <aura:attribute name="showMatchBill" type="Boolean" default="true"/>
    <aura:attribute name="HideMatchBill" type="Boolean" default="false"/>
    <aura:attribute name="displayPagination" type="Boolean" default="false"/>
    <aura:attribute name="selectedTab" type="String" default="Vendor"/>
    <aura:attribute name="multiTotalAmount" type="Decimal" default="0.00"/>
    <!--<aura:attribute name="disablemultiTotalAmount" type="Boolean" default="true"/>-->
    <aura:handler name="change" value="{!v.voucherPayment.ERP7__Payment_Account__c}" action="{!c.getCOADetails}"/>
    <aura:handler name="change" value="{!v.MultiVoucherPaymentInfo.ERP7__Payment_Account__c}" action="{!c.getCOADetails1}"/>
    
    <aura:handler name="SortRecord" event="c:SortRecord" action="{!c.SortRecodEventHandler}"/>
    <aura:attribute name="accIds" type="String[]" default=""/>
    <aura:attribute name="OrderBy" type="String" default="Name"/> 
    <aura:attribute name="Order" type="String" default="DESC"/>
    <aura:attribute name="post" type="Boolean" default="true"/>
    <aura:attribute name="postForMulti" type="Boolean" default="true"/>
    <aura:attribute name="DisplayCard" type="Boolean" default="false"/>
    <aura:attribute name="displayMultipleBill" type="Boolean" default="false"/>
    <aura:attribute name="PNS" type="Object"/>
    <aura:attribute name="startCount" type="Integer" default="0"/>
    <aura:attribute name="endCount" type="Integer" default="0"/>
    <aura:attribute name="Offset" type="Integer" default="0"/>
    <aura:attribute name="recSize" type="Integer" default="0"/>
    <aura:attribute name="PageNum" type="Integer" default="0"/>
    <aura:attribute name="show" type="Integer" default="{!$Label.c.Pagination_Default_Limit}"/>
    <aura:attribute name="CheckOffset" type="Boolean" default="false"/>
    <aura:attribute name="displayCurrency" type="Boolean" default="false"/>
    <aura:attribute name="vendorAccountsSL" type="List"/>
    <aura:attribute name="BillsSL" type="List"/>
    <aura:attribute name="DebitNotesSL" type="List"/>
    <aura:attribute name="POListSL" type="List"/>
    <aura:attribute name="VouchersSL" type="List"/>
    <aura:attribute name="PaymentsSL" type="List"/>
    <aura:attribute name="currencyType" type="String" />
    <aura:attribute name="setSearch" type="String" />
    <aura:attribute name="currCode" type="String" />
    <aura:attribute name="AccountsFilter" type="String" default=" AND Id=null"/>
    <aura:attribute name="View" type="String" default="Grid"/>
    <aura:attribute name="tabular" type="Boolean" default="true"/>
    <aura:attribute name="grid" type="Boolean" default="false"/>
    <aura:attribute name="cnAmount" type="Decimal" default="0.00" />
    <aura:attribute name="payAmount" type="Decimal" default="0.00" />
    <aura:attribute name="billDate" type="Date"/>
    <aura:attribute name="vouchered" type="Voucher__c"/>
    <div class="erp_mark7 bg-gp erp pb100" aura:Id="body">
        
        <lightning:spinner variant="brand" size="large" aura:id="spinner" class="slds-hide"/>
        <div class="slds-container--fluid ">
            <aura:if isTrue="{!!HideMatchBill}">
            <div class="slim-pageheader slds-p-around_small slds-hide">
                <ol class="breadcrumb slim-breadcrumb">
                    <li class="breadcrumb-item">
                        <div class="slds-button-group" role="group"> 
                            
                            <div class="AccountsPayable-newClass4" ><c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" /></div> 
                            &nbsp;
                            <div class="maqdropdown"> 
                            </div>
                        </div>
                    </li> 
                </ol>
                <h6 class="slim-pagetitle">{!$Label.c.Acc_Pay_Accounts_Payable}</h6>
            </div>
            <div class="slim-navbar">
                <div class="slds-container">
                    
                    <ul class="nav">
                        <li class="{!v.selectedTab == 'Vendor' ? 'nav-item active' : 'nav-item '}" label="{!$Label.c.InventoryConsole_Vendor}" name="Vendor"  onclick="{!c.calledVendor}" title="{!$Label.c.InventoryConsole_Vendor}">
                            <a class="nav-link" href="javascript:void(0);"  >
                                <i class="icon fa fa-list-ol"></i>
                                <span>{!$Label.c.InventoryConsole_Vendor}</span>
                            </a>
                           
                        </li>
                        <li  class="{!v.selectedTab == 'Purchase_Orders' ? 'nav-item  active' : 'nav-item '}" label="{!$Label.c.Acc_Pay_Purchase_Orders}" name="Purchase_Orders" onclick="{!c.calledPO}" title="{!$Label.c.Acc_Pay_Purchase_Orders}">
                            <a class="nav-link" href="javascript:void(0);">
                                <i class="icon fa fa-file-text-o"></i>
                                <span>{!$Label.c.Acc_Pay_Purchase_Orders}</span>
                            </a>
                            
                        </li>
                        
                        <li class="{!v.selectedTab == 'Bills' ? 'nav-item  active' : 'nav-item '}" onclick="{!c.calledBill}" title="{!$Label.c.Acc_Pay_Bills}">
                            <a class="nav-link" href="javascript:void(0);">
                                <i class="icon fa fa-file-text"></i>
                                <span>{!$Label.c.Acc_Pay_Bills}</span>
                            </a>
                           
                        </li>
                        
                        <aura:if isTrue="{!!v.undisplayVoucher}">
                        <li class="{!v.selectedTab == 'Vouchers' ? 'nav-item  active' : 'nav-item'}" onclick="{!c.calledVou}" title="{!$Label.c.Acc_Pay_Vouchers}">
                            <a class="nav-link" href="javascript:void(0);" data-toggle="dropdown">
                                <i class="icon fa fa-file-o"></i>
                                <span>{!$Label.c.Acc_Pay_Vouchers}</span>
                            </a>
                           
                        </li>
                        </aura:if>
                        <!-- _____________________-->
                        
                        <li class="{!v.selectedTab == 'Payments' ? 'nav-item  active' : 'nav-item'}" onclick="{!c.calledPay}" title="{!$Label.c.Acc_Recev_Payments}">
                            <a class="nav-link" href="javascript:void(0);" data-toggle="dropdown">
                                <i class="icon fa fa-credit-card-alt"></i>
                                <span>{!$Label.c.Acc_Recev_Payments}</span>  
                            </a>
                            
                        </li>
                        <!-- _______________________________ -->
                        
                        <li class="{!v.selectedTab == 'Credit_debit_notes' ? 'nav-item active' : 'nav-item'}" onclick="{!c.calledDebit}" title="{!$Label.c.Acc_Pay_Debit_Notes}">
                            <a class="nav-link" href="javascript:void(0);">
                                <i class="icon fa fa-sticky-note"></i>
                                <span>{!$Label.c.Acc_Pay_Debit_Notes}</span>
                            </a>
                            
                        </li>
                        
                    </ul>
                </div><!-- container -->
            </div>
            </aura:if>
            <div class="slds-tabs--default bg-gp "> 
                <aura:if isTrue="{!and(equals(v.selectedTab,'Vendor'),v.tabular)}">
                    <div class="maqsood erp_Mark7 erp">
                        <div class="card shadow-custom card-table">
                            <aura:if isTrue="{!!v.HideMatchBill}">
                            <div class="card-header bg-white">
                                <div class="slds-grid">
                                    <div class="slds-col">
                                        <h6 class="slim-card-title">
                                            <c:StockTakeSearch searchString="{!v.setSearch}"/>
                                        </h6>
                                    </div>
                                    <div class="slds-col">
                                        
                                        
                                    </div>
                                    <div class="col-8 text-right">
                                        <div class="slds-grid float-right">
                                            <div class="AccountsPayable-newClass4  slds-m-right_small" ><c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" /></div>
                                            <div class="maqdropdown">
                                                <aura:if isTrue="{!equals(v.selectedTab,'Vendor')}">
                                                    <a class="addNewBTN AccountsPayable-newClass5" onclick="{!c.createAccount}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Vendor} <span class="caret"></span>
                                                    </a>
                                                </aura:if>
                                                <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}">
                                                    <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}"> 
                                                        <aura:renderIf isTrue="{!v.showMultiPO}">
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 ml-1" onclick="{!c.createMultiPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} <span class="caret"></span>
                                                            </a>
                                                            <aura:set attribute="else">
                                                                &nbsp; 
                                                                <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 " onclick="{!c.createPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                    <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} <span class="caret"></span>
                                                                </a> 
                                                            </aura:set>
                                                        </aura:renderIf>
                                                        
                                                    </aura:if>
                                                </aura:if> 
                                                <aura:if isTrue="{!equals(v.selectedTab,'Bills')}">
                                                    <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Bill} <span class="caret"></span>
                                                    </a>&nbsp;
                                                    <aura:if isTrue="{!v.tabular}">
                                                        <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.matchBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                            {!$Label.c.Acc_Pay_Match_Bill} <span class="caret"></span>                
                                                        </a>
                                                    </aura:if>
                                                    <!-- <div class="maqdropdown-content">
                                       
                                    </div>  -->                 
                                                </aura:if> 
                                                <aura:if isTrue="{!equals(v.selectedTab,'Vouchers')}">
                                                    
                                                    <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.doneMultiPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                        <i class="fa fa-credit-card" aria-hidden="true"></i> &nbsp; {!$Label.c.Acc_Pay_Make_Payment} <span class="caret"></span>                
                                                    </a>
                                                </aura:if>
                                                <aura:if isTrue="{!equals(v.selectedTab,'Payments')}">
                                                    
                                                    <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_Cheque_Payment} <span class="caret"></span>                
                                                    </a>
                                                </aura:if>
                                                <aura:if isTrue="{!equals(v.selectedTab,'Credit_notes')}">
                                                    <a class="addNewBTN dropdown-toggle" onclick="{!c.createCredit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Credit_Note} <span class="caret"></span>
                                                    </a>
                                                </aura:if>  
                                                <aura:if isTrue="{!equals(v.selectedTab,'Credit_debit_notes')}">
                                                    <a class="addNewBTN dropdown-toggle slds-m-right_small" onclick="{!c.createDebit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Debit_Note} <span class="caret"></span>
                                                    </a>
                                                    <a class="addNewBTN dropdown-toggle" onclick="{!c.createDebitPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_Receive_Payment} <span class="caret"></span>
                                                    </a>
                                                </aura:if>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="slds-p-right_small">
                                    <a title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.navigateToDashboard}">
                                       <img src="/resource/ERP7__ERPCustomIcons/erpicons/research.png" style="width:30px"></img>
                                    </a>
                                    </div>
                                    <div class="slds-col">
                                        <div class="grid-list-icon"> 
                                            
                                            <a class="{!(v.grid)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.gridView}">
                                                <i class="fa fa-th-large"></i>
                                            </a>
                                            <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
                                                <i class="fa fa-list"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div><!-- card-header -->
                            </aura:if>
                            <div id="tab-default-1" class="epr_Mark7 slds-tabs--default__content slds-show" role="tabpanel" aria-labelledby="tab-default-1__item">
                                
                                <div class="table-responsive AccountsPayable-newClass13" tabindex="1"> 
                                    <table class="table">  
                                        <!-- <table class="slds-table slds-table-/-bordered slds-max-medium-table-/-stacked-horizontal">-->
                                        <thead>
                                            <tr class="slds-text-title--caps">
                                                <th class="slds-cell-shrink" scope="col">
                                                 </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Name_ManageLeave}"> 
                                                        
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="Account" OrderBy="Name" Label="{!$Label.c.Name_ManageLeave}" show="{!v.show}"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ( ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="Name" Label="{!$Label.c.Name_ManageLeave}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if> 
                                                        
                                                        
                                                        
                                                        
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Select_Bank_Payment_Method_Account_Number}">
                                                        
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="Account" OrderBy="AccountNumber" Label="{!$Label.c.Select_Bank_Payment_Method_Account_Number}" show="{!v.show}"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND (ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="AccountNumber" Label="{!$Label.c.Select_Bank_Payment_Method_Account_Number}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if> 
                                                        
                                                    </div>
                                                </th>
                                                
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Acc_Recev_Opening_Balance}">
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Opening_Balance__c" Label="{!$Label.c.Acc_Recev_Opening_Balance}" show="{!v.show}"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND (ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Opening_Balance__c" Label="{!$Label.c.Acc_Recev_Opening_Balance}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if>   
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Acc_Recev_Credit}">
                                                        
                                                        
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Credit_Balance__c" Label="{!$Label.c.Acc_Recev_Credit}" show="{!v.show}"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND (ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Credit_Balance__c" Label="{!$Label.c.Acc_Recev_Credit}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if> 
                                                        
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Acc_Recev_Debit}">
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Debit_Note_Balance__c" Label="{!$Label.c.Acc_Recev_Debit}" show="{!v.show}"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND (ERP7__Account_Type__c  = \'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/>  
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="Account" OrderBy="ERP7__Debit_Note_Balance__c"  Label="{!$Label.c.Acc_Recev_Debit}" show="{!v.show}"
                                                                                  Query=" AND (ERP7__Account_Type__c='Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>  
                                                            </aura:set>    
                                                        </aura:if>     
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.Acc_Pay_Balance_Due}">
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
