                                                    <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
                                                        <i class="fa fa-list"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                
                            </div><!-- card-header -->
                            <div class="row m-0">
                                <aura:iteration items="{!v.Vouchers}" var="voucher" indexVar="i">
                                    <div class="col-md-3 mt-2">
                                        
                                        <!-- ************************OLD****************************** -->
                                        
                                        <div class="card-contact p-3">
                                            <div class="slds-grid text-left pb-2">
                                                <div class="col-1 pl-0 ">
                                                    <ui:inputCheckbox label="" aura:id="cbox_voucher" class="slds-checkbox" name="{#voucher.Id}" change="{!c.selectedVoucher}" updateOn="change"/>
                                                </div>
                                                <div class="col-9 pl-0">
                                                    <h5 class="">
                                                        
                                                        <a href="{!'/'+voucher.Id}" target="_blank"  class="contact-name">&nbsp;{!i+1}.&nbsp;{!voucher.Name}</a>
                                                        
                                                    </h5>
                                                </div>
                                                <div class="col-2 pr-0 text-right">
                                                    <p>
                                                        <ui:menu >
                                                            <ui:menuTriggerLink aura:id="trigger" label="">
                                                                <lightning:button variant="neutral" label="" class="slds-button slds-button--icon-border-filled slds-button--icon-x-small dropdown-toggle btnlineheight" iconName="utility:down"/>
                                                            </ui:menuTriggerLink>    
                                                            <ui:menuList aura:id="actionMenu" class="customMenuposition"><!--autoPosition="true"-->
                                                                <!--<aura:if isTrue="{!and(vou.ERP7__Posted__c,not(vou.ERP7__Paid__c))}">	-->	
                                                                <aura:if isTrue="{!voucher.ERP7__Approved__c}">		
                                                                    <ui:actionMenuItem >
                                                                        <a href="javascript:void(0);"  data-record="{#voucher.Id}" onclick="{!c.payvoucher}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#voucher.Id}" >{!$Label.c.Acc_Pay_Make_Payment}</span></a>
                                                                    </ui:actionMenuItem>
                                                                    
                                                                </aura:if>  
                                                                <aura:if isTrue="{!voucher.ERP7__Approved__c==false}">		
                                                                    <ui:actionMenuItem >
                                                                        <a href="javascript:void(0);"  data-record="{#voucher.Id}" onclick="{!c.approveVoucher}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#voucher.Id}" >{!$Label.c.Approve_ManageLeave}</span></a>
                                                                    </ui:actionMenuItem>
                                                                </aura:if>  
                                                                
                                                            </ui:menuList>
                                                        </ui:menu>
                                                    </p>
                                                </div>
                                            </div>
                                            
                                            <p class="contact-item">
                                                <span>{!$Label.c.InventoryConsole_Vendor}:</span>
                                                <span>
                                                    <a href="{!'/'+voucher.ERP7__Vendor__r.Id}" target="_blank">{!voucher.ERP7__Vendor__r.Name}</a></span>
                                            </p>
                                            
                                            <p class="contact-item">
                                                <span>{!$Label.c.Purchase_Order}:</span>
                                                <a href="{!'/'+voucher.ERP7__Vendor_invoice_Bill__r.ERP7__Purchase_Order__r.Id}" target="_blank">{!voucher.ERP7__Vendor_invoice_Bill__r.ERP7__Purchase_Order__r.Name}</a>
                                            </p>
                                            
                                            <p class="contact-item">
                                                <span>{!$Label.c.Acc_Pay_Bill}:</span>
                                                <a href="{!'/'+voucher.ERP7__Vendor_invoice_Bill__r.Id}" target="_blank">{!voucher.ERP7__Vendor_invoice_Bill__r.Name}</a>
                                            </p>
                                            
                                            <p class="contact-item">
                                                <span>{!$Label.c.Cash_Payment_Amount}:</span>
                                                <a href="javascript:void(0);" target="_blank"> <ui:outputNumber format="#0.00" value="{!voucher.ERP7__Amount__c}"/></a>
                                            </p>
                                            
                                            <div class="slds-grid pt-1 pb-1">
                                                <div class="slds-col col-6 pl-0"> 
                                                    <div class="startime-maq AccountsPayable-newClass37">
                                                        {!$Label.c.Cash_Payment_Amount} : &nbsp;<ui:outputNumber format="#0.00" value="{!voucher.ERP7__Amount__c}"/> 
                                                    </div>
                                                </div>
                                                <div class="slds-col col-6 pr-0 text-right">
                                                    <div class="endime-maq AccountsPayable-newClass38">
                                                        {!$Label.c.MyExpensesheets_Approved} : &nbsp;{!voucher.ERP7__Approved__c ? $Label.c.Other_Tax_Display : $Label.c.DefaultValuesOnPO}<!--{!voucher.ERP7__Approved__c} - changed on 30.01.24 for translation by Asra-->
                                                    </div>
                                                </div> 
                                            </div>
                                        </div>
                                        <!-- ************OLD************** -->
                                        
                                   </div>
                                    
                                </aura:iteration>
                            </div>    
                        </aura:if>
                    </div>
                    <div class="epr_Mark7">
                        <div class="slds-docked-form-footer h60px">
                            <aura:if isTrue="{!v.Vouchers.length>0}">
                                <div class="col-md-2 AccountsPayable-newClass21">
                                    <div class="slds-grid" >
                                        <div class="slds-col AccountsPayable-newClass22">
                                            {!$Label.c.Acc_Recev_Show}&nbsp;
                                        </div>  
                                        <div class="slds-col AccountsPayable-newClass23"> 
                                            <lightning:select class="slds-show_inline-block no-lable"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                <option value="10">10</option>
                                                <option value="25">25</option>
                                                <option value="50">50</option>
                                                <option value="100">100</option>
                                                <option value="150">150</option>
                                            </lightning:select>
                                        </div>
                                    </div>
                                </div>
                            </aura:if>
                            <aura:if isTrue="{!v.Vouchers.length>0}">
                                
                                <div class="col-md-3 AccountsPayable-newClass24">
                                    {!$Label.c.Acc_Recev_Showing}&nbsp;<span class="text-lightblue">{!v.startCount}-{!v.endCount}</span>&nbsp;{!$Label.c.Acc_Recev_of_total}&nbsp;<span class="text-lightblue"> {!v.recSize}</span>&nbsp;{!$Label.c.Acc_Recev_Records}
                                </div>
                                
                            </aura:if> 
                            
                            <aura:if isTrue="{!v.Vouchers.length>0}">
                                
                                <div class="col-md-4 AccountsPayable-newClass25">
                                    <nav aria-label="Page navigation example">
                                        <ul class="pagination m-0">
                                            <li>
                                                <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                            </li>
                                            <li>
                                                <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.Previous}"> {!$Label.c.Previous}</a> <!-- -->
                                            </li>
                                            
                                            <li>
                                                <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> <!--  -->
                                            </li>
                                            <li >
                                                <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                                
                            </aura:if> 
                            <aura:if isTrue="{!v.Vouchers.length>0}">
                                
                                <div class="col-md-2">
                                    <div class="slds-grid">
                                        <div class="slds-col slds-p-top_x-small">
                                            {!$Label.c.page} 
                                        </div>
                                        <div class="slds-col ">
                                            
                                            <ui:inputNumber aura:id="ikVou" value="{!v.PageNum}" change="{!c.OfsetChange}" class="width100p"/> 
                                        </div>
                                        <div class="slds-col slds-p-top_x-small"><span class="text-lightblue"> {!$Label.c.page_of}&nbsp;{!v.PNS.length}</span>
                                        </div>
                                    </div>
                                </div>
                                
                            </aura:if>
                        </div>
                    </div>
                    
                </aura:if>
            </div>
        </div>
        
        <aura:if isTrue="{!v.FromClosing}">
            <div class="slds-grid slds-p-bottom_small">
                <div class="col-md-12 text-center">
                    <lightning:button variant="brand" label="Back to CBC" onclick="{!c.navigateToClosingComponent}"></lightning:button>
                </div>
            </div>
            
        </aura:if>
    </div>
    <aura:if isTrue="{!v.showMmainSpin}">
        <span class="AccountsPayable-newClass33">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if>
    
    <aura:if isTrue="{!v.ShowPOType}"> 
        <div class="erp_Mark7 ">
            <section role="dialog" tabindex="-2" aria-labelledby="modal-heading-02" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.closePopUP}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="small" alternativeText="close" title="close" />
                            
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate createbill-class8">{!$Label.c.Acc_Pay_Select_order_type} </h2>
                    </header>
                    <div class="slds-modal__content" id="modal-content-id-1">
                        
                        <div class="epr_Mark7">
                            <div class="container-fluid ">
                                <div class="row slds-p-around--small createbill-class9">
                                    <div class="col-md-6">
                                        <div class="card cursor-pointer card-extra-apnp" aura:id="pOcheckbox" data-billType='PO' onclick="{!c.onCheck}">
                                            <div class="card-content">
                                                <div class="card-body">
                                                    <div class="media d-flex">
                                                        <div class="align-self-center">
                                                            <lightning:icon iconName="standard:bill_of_materials" size="medium"></lightning:icon>
                                                        </div>
                                                        <div class="media-body text-center pt-1">
                                                            
                                                            <span class="pofsize-16">{!$Label.c.Acc_Pay_New_PO}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        
                                    </div>
                                    <div class="col-md-6">
                                        <div class="card cursor-pointer card-extra-rtov" aura:id="billcheckbox" data-billType="return" onclick="{!c.onCheck}">
                                            <div class="card-content">
                                                <div class="card-body">
                                                    <div class="media d-flex">
                                                        <div class="align-self-center">
                                                            <lightning:icon iconName="standard:shift_type" size="medium"></lightning:icon>
                                                        </div>
                                                        <div class="media-body text-center pt-1">
                                                            
                                                            <span class="pofsize-16">{!$Label.c.Acc_Pay_Return_To_Vendor}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        
                                    </div>
                                </div> 
                                
                            </div>
                            <footer class="slds-modal__footer createbill-class10">
                                <lightning:button label="{!$Label.c.QuotationConsole_Cancel}" variant="destructive" onclick="{!c.closePopUP}" class="createbill-class12" />&nbsp;
                            </footer>
                        </div>
                        
                    </div> 
                </div>
                
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
    </aura:if>
</aura:component>