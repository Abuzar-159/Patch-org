                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Amount_Paid__c" Label="{!$Label.c.Acc_Recev_Paid_Amount}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Vendor__c != Null'}"/>   
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Amount_Paid__c" Label="{!$Label.c.Acc_Recev_Paid_Amount}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                                  Query=" AND ERP7__Vendor__c!=Null"/> 
                                                            </aura:set>    
                                                        </aura:if> 
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.AddSubscription_Total_Due}">
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Total_Amount__c" Label="{!$Label.c.AddSubscription_Total_Due}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Vendor__c != Null'}"/>   
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Total_Amount__c" Label="{!$Label.c.AddSubscription_Total_Due}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                                  Query=" AND ERP7__Vendor__c!=Null"/> 
                                                            </aura:set>    
                                                        </aura:if> 
                                                    </div>
                                                </th>
                                                <th scope="col">
                                                    <div class="slds-truncate2" title="{!$Label.c.InventoryConsole_Order_Date}">
                                                        <aura:if isTrue="{!v.Organisation.Id!=''}">   
                                                            <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Order_Date__c" Label="{!$Label.c.InventoryConsole_Order_Date}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                              Query="{! ' AND ERP7__Organisation__c = \''+ v.Organisation.Id+'\''+ ' AND ERP7__Vendor__c != Null'}"/>   
                                                            <aura:set Attribute="else">
                                                                <c:SortRecords ObjectAPIName="ERP7__PO__c" OrderBy="ERP7__Order_Date__c" Label="{!$Label.c.AddSubscription_Total_Due}" show="{!v.show}" Fields=",ERP7__Vendor__r.Name"
                                                                                  Query=" AND ERP7__Vendor__c!=Null"/> 
                                                            </aura:set>    
                                                        </aura:if> 
                                                    </div>
                                                </th>
                                                <aura:if isTrue="{!!v.displayMultipleBill}">
                                                <th class="slds-cell-shrink" scope="col">{!$Label.c.Clone}</th>
                                                </aura:if>
                                                <th class="slds-cell-shrink" scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:if isTrue="{!v.POList.length>0}">
                                                <aura:iteration items="{!v.POList}" var="po">
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <aura:if isTrue="{!or(po.ERP7__Status__c=='Approved', !v.approvalProcess)}">
                                                        <td class="slds-cell-shrink" data-label="Select Row">
                                                            <ui:inputCheckbox label="" aura:id="cbox" class="slds-checkbox" name="{#po.Id}" change="{!c.selectedPO}" updateOn="change"/>
                                                        </td>
                                                            <aura:set attribute="else">
                                                                <td class="slds-cell-shrink" data-label="Select Row">
                                                                    
                                                                </td>
                                                            </aura:set>
                                                        </aura:if>
                                                        <td scope="row" data-label="PO Name">
                                                            <!--<div class="slds-truncate2" title="{!po.Name}"><a data-record="{!po.Id}" onclick="{!c.NavigateToManagePO}" target="_blank">{!po.Name}</a></div>-->
                                                            <div class="slds-truncate2" title="{!po.Name}"><a href="{!'/'+po.Id}" target="_blank">{!po.Name}</a></div>
                                                        </td>
                                                        <td data-label="vendor Number">
                                                            <div class="slds-truncate2" title="{!po.ERP7__Vendor__r.Name}"><a href="{!'/'+po.ERP7__Vendor__r.Id}" target="_blank">{!po.ERP7__Vendor__r.Name}</a></div>
                                                        </td>
                                                        <td data-label="Phone">
                                                            <div class="slds-truncate2" title="{!po.ERP7__Total_Quantity__c}">
                                                                <lightning:formattedNumber value="{!po.ERP7__Total_Quantity__c}"/>
                                                            </div>
                                                        </td>
                                                        <td data-label="PaymentTerms">
                                                            <div class="slds-truncate2" > <!--new stage - title="{!po.ERP7__Status__c}"--> 
                                                                <aura:if isTrue="{!and(po.ERP7__Stage__c != undefined,po.ERP7__Stage__c != null)}">
                                                                    <div title="{!po.ERP7__Stage__c}">{!po.ERP7__Stage__c}</div>
                                                                </aura:if>
                                                                <!--aura:if isTrue="{!po.ERP7__Logistic_Quantity__c >0}">
                                                                    <aura:if isTrue="{!and(po.ERP7__Putaway_Quantity__c==po.ERP7__Reconciled_Quantity__c,po.ERP7__Total_Quantity__c==po.ERP7__Reconciled_Quantity__c)}">
                                                                        <div title="{!$Label.c.Acc_Pay_Received}">{!$Label.c.Acc_Pay_Received}
                                                                        </div>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!and(po.ERP7__Putaway_Quantity__c>0,po.ERP7__Putaway_Quantity__c!=po.ERP7__Total_Quantity__c)}">
                                                                        <div title="{!$Label.c.Acc_Pay_Partially_Received}">{!$Label.c.Acc_Pay_Partially_Received} 
                                                                        </div>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!(po.ERP7__Putaway_Quantity__c==0)}">
                                                                        <div title="{!$Label.c.Acc_Pay_Not_Yet_Received}">{!$Label.c.Acc_Pay_Not_Yet_Received}
                                                                        </div>
                                                                    </aura:if>
                                                                    <aura:set attribute="else">
                                                                        {!$Label.c.Acc_Pay_Logistic_Not_Initiated}
                                                                    </aura:set>
                                                                </aura:if--> 
                                                                <!--{#po.ERP7__Status__c}--></div>
                                                        </td>
                                                        <td data-label="Paid Amount">
                                                            <div class="slds-truncate2" title="{!po.ERP7__Amount_Paid__c}">
                                                                <aura:if isTrue="{!v.displayCurrency}">
                                                                    <lightning:formattedNumber style="currency" value="{!po.ERP7__Amount_Paid__c}"/>
                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{!po.ERP7__Amount_Paid__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
                                                        <td data-label="Balance Due">
                                                            <div class="slds-truncate2" title="{!po.ERP7__Total_Due__c}">
                                                                <aura:if isTrue="{!v.displayCurrency}">
                                                                    <lightning:formattedNumber style="currency" value="{!po.ERP7__Total_Due__c}"/>
                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{!po.ERP7__Total_Due__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                                
                                                            </div>
                                                        </td>
                                                        <td data-label="Balance Due">
                                                            <div class="slds-truncate2" title="{!po.ERP7__Order_Date__c}"><lightning:formattedDateTime value="{!po.ERP7__Order_Date__c}" year="numeric" month="numeric" day="numeric" timeZone="UTC"/></div>
                                                        </td>
                                                        <aura:if isTrue="{!!v.displayMultipleBill}">
                                                        <td data-label="Clone">
                                                            <a data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.ClonePo}">
                                                            <lightning:icon iconName="action:clone" size="x-small" />
                                                            </a>
                                                        </td>
														</aura:if>
                                                        <aura:if isTrue="{!or(po.ERP7__Status__c=='Approved', !v.approvalProcess)}">
                                                        <td class="slds-cell-shrink" data-label="Actions">
                                                            <ui:menu >
                                                                <ui:menuTriggerLink aura:id="trigger" label="">
                                                                    <lightning:button variant="neutral" label="" class="slds-button slds-button--icon-border-filled slds-button--icon-x-small dropdown-toggle btnlineheight" iconName="utility:down"/>
                                                                </ui:menuTriggerLink>    
                                                                <ui:menuList aura:id="actionMenu" class="customMenuposition"><!--autoPosition="true"-->
                                                                    <aura:if isTrue="{!equals('Return_to_Vendor_RTV', po.RecordType.DeveloperName)}">
                                                                        <!--<ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.ClonePo}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-file-text-o"></i>&nbsp;{!$Label.c.Clone_Purchase_Order}</span></a>
                                                                        </ui:actionMenuItem>-->
                                                                        <ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.ManagePo}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-pencil"></i>&nbsp;{!$Label.c.Edit_Purchase_Order}</span></a>
                                                                        </ui:actionMenuItem>
                                                                        <ui:actionMenuItem >
                                                                            <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.createDebit}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-plus"></i>&nbsp;{!$Label.c.Acc_Recev_New_Debit_Note}</span></a>
                                                                        </ui:actionMenuItem>
                                                                        
                                                                        <aura:set attribute="else">
                                                                            <!--<ui:actionMenuItem >
                                                                                <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.ClonePo}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-file-text-o"></i>&nbsp;{!$Label.c.Clone_Purchase_Order}</span></a>
                                                                            </ui:actionMenuItem>-->
                                                                            <ui:actionMenuItem >
                                                                                <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.ManagePo}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-pencil"></i>&nbsp;{!$Label.c.Edit_Purchase_Order}</span></a>
                                                                            </ui:actionMenuItem>
                                                                            <ui:actionMenuItem >
                                                                                <a href="javascript:void(0);"   data-record="{#po.Id}" data-name="{#po.Name}" onclick="{!c.createBill_PO}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{#po.Id}" data-name="{#po.Name}"><i class="fa fa-plus"></i>&nbsp;{!$Label.c.Acc_Pay_New_Bill}</span></a>
                                                                            </ui:actionMenuItem>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </ui:menuList>
                                                            </ui:menu>
                                                        </td>
                                                            <aura:set attribute="else">
                                                                <td class="slds-cell-shrink" data-label="Actions">
                                                                    
                                                                </td>
                                                            </aura:set>
                                                        </aura:if>
                                                    </tr>
                                                </aura:iteration> 
                                                <aura:set attribute="else">
                                                    <tr>
                                                        <td colspan="12" class="AccountsPayable-newClass15">
                                                            <div class="slds-notify_container slds-is-relative AccountsPayable-newClass16">
                                                                <div class="slds-notify slds-notify_toast slds-theme_warning AccountsPayable-newClass17" role="alert">
                                                                    <span class="slds-assistive-text">{!$Label.c.warning}</span>
                                                                    <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                                                    <div class="slds-notify__content AccountsPayable-newClass18">
                                                                        <h2 class="slds-text-heading_small AccountsPayable-newClass21">{!$Label.c.Acc_Pay_No_Items_in_Table}</h2>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </aura:set>
                                            </aura:if>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="epr_Mark7 ">
                                    <div class="slds-docked-form-footer h60px">
                                        <aura:if isTrue="{!v.POList.length>0}">
                                            <div class="col-md-2 AccountsPayable-newClass21">
                                                <div class="slds-grid" >
                                                    <div class="slds-col AccountsPayable-newClass22">
                                                        {!$Label.c.Acc_Recev_Show}&nbsp;
                                                    </div>  
                                                    <div class="slds-col AccountsPayable-newClass23"> 
                                                        <lightning:select class="slds-show_inline-block no-lable"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                            <option value="10">10</option>
                                                            <option value="25">25</option>
                                                            <option value="50">50</option>
                                                            <option value="100">100</option>
                                                            <option value="150">150</option>
                                                        </lightning:select>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                        <aura:if isTrue="{!v.POList.length>0}">
                                            
                                            <div class="col-md-3 AccountsPayable-newClass24">
                                                {!$Label.c.Acc_Recev_Showing}&nbsp;<span class="text-lightblue">{!v.startCount}-{!v.endCount}</span>&nbsp;{!$Label.c.Acc_Recev_of_total}&nbsp;<span class="text-lightblue"> {!v.recSize}</span>&nbsp;{!$Label.c.Acc_Recev_Records}
                                            </div>
                                            
                                        </aura:if> 
                                        
                                        <aura:if isTrue="{!v.POList.length>0}">
                                            
                                            <div class="col-md-4 AccountsPayable-newClass25">
                                                <nav aria-label="Page navigation example">
                                                    <ul class="pagination  m-0">
                                                        <li >
                                                            <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                                        </li>
                                                        <li>
                                                            <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.Previous}"> {!$Label.c.Previous}</a> <!-- -->
                                                        </li>
                                                        <li >
                                                            <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> <!--  -->
                                                        </li>
                                                        <li >
                                                            <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                                        </li>
                                                    </ul>
                                                </nav>
                                            </div>
                                            
                                        </aura:if> 
                                        <aura:if isTrue="{!v.POList.length>0}">
                                            
                                            <div class="col-md-2">
                                                <div class="slds-grid">
                                                    <div class="slds-col slds-p-top_x-small">
                                                        {!$Label.c.page} 
                                                    </div>
                                                    <div class="slds-col ">
                                                        
                                                        <ui:inputNumber aura:id="ikPO" value="{!v.PageNum}" change="{!c.OfsetChange}" class="width100p"/> 
                                                    </div>
                                                    <div class="slds-col slds-p-top_x-small"><span class="text-lightblue"> {!$Label.c.page_of}&nbsp;{!v.PNS.length}</span>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                        </aura:if>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                        
                    </div> 
                </aura:if>
                <aura:if isTrue="{!and(equals(v.selectedTab,'Bills'),v.tabular)}">
                    <div id="tab-default-1" class="epr_Mark7 slds-tabs--default__content slds-show slds-m-bottom--small AccountsPayable-newClass21" role="tabpanel" aria-labelledby="tab-default-1__item">
                        <div class="card shadow-custom card-table">
                            <div class="card-header bg-white">
                               <div class="slds-grid">
                                            <div class="slds-col">
                                                <h6 class="slim-card-title">
                                                    <c:StockTakeSearch searchString="{!v.setSearch}"/>
                                                </h6>
                                            </div>
                                            <div class="slds-col">
                                                
                                                
                                            </div>
                                             <div class="col-8 text-right">
                                                <div class="slds-grid float-right">
                                                    <div class="AccountsPayable-newClass4  slds-m-right_small">
                                                        <lightning:select name="controllerFld"
                                                                          value="{!v.DueFilter}"
                                                                          label="{!$Label.c.Acc_Pay_Bill_Due}" onchange="{!c.onControllerFieldChange}" class="laebel-overide"><!-- onchange="{!c.onControllerFieldChange}" -->
                                                            <option value="-1">{!$Label.c.Acc_Pay_All_Bills}</option>
                                                            <option value="0">{!$Label.c.Acc_Pay_Overdue_Bills}</option>
                                                            <option value="30">0-30 {!$Label.c.Days_ManageLeave}</option>
                                                            <option value="60">31-60 {!$Label.c.Days_ManageLeave}</option>
                                                            <option value="90">61-90 {!$Label.c.Days_ManageLeave}</option>
                                                            <option value="2000">90+ {!$Label.c.Days_ManageLeave}</option>
                                                        </lightning:select>
                                                    </div>
                                                    <div class="AccountsPayable-newClass4  slds-m-right_small" ><c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.Organisation.Id}" NameValue="{!v.Organisation.Name}" IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')" /></div>
                                                    <div class="maqdropdown">
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Vendor')}">
                                                            <a class="addNewBTN AccountsPayable-newClass5" onclick="{!c.createAccount}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Vendor} 
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}">
                                                            <aura:if isTrue="{!equals(v.selectedTab,'Purchase_Orders')}"> 
                                                                <aura:renderIf isTrue="{!v.showMultiPO}">
                                                                    <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 ml-1" onclick="{!c.createMultiPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                        <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} 
                                                                    </a>
                                                                    <aura:set attribute="else">
                                                                        &nbsp;
                                                                        <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5 " onclick="{!c.createPO}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                            <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Purchase_Order} 
                                                                        </a> 
                                                                    </aura:set>
                                                                </aura:renderIf>
                                                                
                                                            </aura:if>
                                                        </aura:if> 
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Bills')}">
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_New_Bill} 
                                                            </a>&nbsp;
                                                            <aura:if isTrue="{!v.tabular}">
                                                                <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.matchBill}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                    {!$Label.c.Acc_Pay_Match_Bill}         
                                                                </a>
                                                            </aura:if>
                                                            <!-- <div class="maqdropdown-content">
                                       
                                    </div>  -->                 
                                                        </aura:if> 
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Vouchers')}">
                                                            
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.doneMultiPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                <i class="fa fa-credit-card" aria-hidden="true"></i> &nbsp; {!$Label.c.Acc_Pay_Make_Payment}              
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Payments')}">
                                                            
                                                            <a class="addNewBTN dropdown-toggle AccountsPayable-newClass5" onclick="{!c.createPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown">
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_Cheque_Payment}               
                                                            </a>
                                                        </aura:if>
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Credit_notes')}">
                                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createCredit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Credit_Note}                                                             </a>
                                                        </aura:if>  
                                                        <aura:if isTrue="{!equals(v.selectedTab,'Credit_debit_notes')}">
                                                            <a class="addNewBTN dropdown-toggle slds-m-right_small" onclick="{!c.createDebit}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Recev_New_Debit_Note}
                                                            </a>
                                                            <a class="addNewBTN dropdown-toggle" onclick="{!c.createDebitPayment}" target="_blank" aria-haspopup="true" data-toggle="dropdown"> 
                                                                <i class="fa fa-plus" aria-hidden="true"></i> &nbsp;{!$Label.c.Acc_Pay_Receive_Payment} 
                                                            </a>
                                                        </aura:if>
                                                    </div>
                                                </div>
                                            </div>
                                   <div class="slds-p-right_small">
                                    <a title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.navigateToDashboard}">
                                       <img src="/resource/ERP7__ERPCustomIcons/erpicons/research.png" style="width:30px"></img>
                                    </a>
                                    </div>
                                            <div class="slds-col">
                                                <div class="grid-list-icon"> 
                                                    
                                                    <a class="{!(v.grid)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "Grid" href="javascript:void(0);" onclick="{!c.gridView}">
                                                        <i class="fa fa-th-large"></i>
                                                    </a>
                                                    <a class="{!(v.tabular)?'acitve-list2 AccountsReceivable-newClass7':'AccountsReceivable-newClass8 p-10'}" title="" data-tab = "List" href="javascript:void(0);" onclick="{!c.tabularView}">
                                                        <i class="fa fa-list"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>                                
                            </div><!-- card-header -->
                            <aura:if isTrue="{!v.showMatchBill}">
                                <c:MatchBill SelectedBillIds="{!v.SelectedBillIds}" SelectedPOs="{!v.SelectedPOS}" approvalProcess="{!v.approvalProcess}" disCurrency="{!v.displayCurrency}" show="{!v.show}" showHeader="false" aura:Id="mBill" organisation="{#v.Organisation}" BillList="{!v.Bills}" BillsSL="{!v.BillsSL}" displayPage="{!v.displayPagination}"/><!--BillList="{!v.Bills}"-->
                               <aura:if isTrue="{!and(v.Bills.length>0, !v.displayPagination)}"> 
                                <div class="epr_Mark7 ">
                                    <div class="slds-docked-form-footer h60px">
                                        
                                            <div class="col-md-2 AccountsPayable-newClass21" >
                                                <div class="slds-grid" >
                                                    <div class="slds-col AccountsPayable-newClass22">
                                                        {!$Label.c.Acc_Recev_Show}&nbsp;
                                                    </div>  
                                                    <div class="slds-col AccountsPayable-newClass23"> 
                                                        <lightning:select class="slds-show_inline-block no-lable"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                                            <option value="10">10</option>
                                                            <option value="25">25</option>
                                                            <option value="50">50</option>
                                                            <option value="100">100</option>
                                                            <option value="150">150</option>
                                                        </lightning:select>
                                                    </div>
                                                </div>
                                            </div>
                                      
                                        <aura:if isTrue="{!and(v.Bills.length>0, !v.displayPagination)}">
                                            
                                            <div class="col-md-3 AccountsPayable-newClass24">
                                                {!$Label.c.Acc_Recev_Showing}&nbsp;<span class="text-lightblue">{!v.startCount}-{!v.endCount}</span>&nbsp;{!$Label.c.Acc_Recev_of_total}&nbsp;<span class="text-lightblue"> {!v.recSize}</span>&nbsp;{!$Label.c.Acc_Recev_Records}
                                            </div>
                                            
                                        </aura:if> 
                                        
                                        <aura:if isTrue="{!and(v.Bills.length>0, !v.displayPagination)}">
                                            
                                            <div class="col-md-4 AccountsPayable-newClass25">
                                                <nav aria-label="Page navigation example">
                                                    <ul class="pagination m-0">
                                                        <li>
                                                            <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                                        </li>
                                                        <li >
                                                            <a class="{!if(1 >= v.startCount,'AccountsPayable-newClass27','AccountsPayable-newClass28')}"  onclick="{!c.Previous}"> {!$Label.c.Previous}</a> <!-- -->
                                                        </li>
                                                        
                                                        <li>
                                                            <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.Next}">{!$Label.c.Next_UsersShiftMatch} </a> <!--  -->
                                                        </li>
                                                        <li >
                                                            <a class="{!if(v.endCount == v.recSize,'AccountsPayable-newClass27','AccountsPayable-newClass28')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                                        </li>
                                                    </ul>
                                                </nav>
                                            </div>
                                            
                                        </aura:if> 
                                        <aura:if isTrue="{!and(v.Bills.length>0, !v.displayPagination)}">
                                            
                                            <div class="col-md-2" >
                                                <div class="slds-grid">
                                                    <div class="slds-col slds-p-top_x-small">
                                                        {!$Label.c.page} 
                                                    </div>
                                                    <div class="slds-col ">
                                                        
                                                        <ui:inputNumber aura:id="ikBills" value="{!v.PageNum}" change="{!c.OfsetChange}" class="width100p"/> 
