                                        <tbody>
                                            <aura:if isTrue="{!v.DebitNotes.length>0}">
                                                <aura:iteration items="{!v.DebitNotes}" var="debitNote">
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <td class="slds-cell-shrink" data-label="Select Row">
                                                            
                                                        </td>
                                                        <td scope="row" data-label="Debit Note">
                                                            <div class="slds-truncate2" title="{!debitNote.Name}"><a href="{!'/'+debitNote.Id}" target="_blank">{!debitNote.Name}</a></div>
                                                        </td>
                                                        <td data-label="Account Name">
                                                            <div class="slds-truncate2"><a href="{!'/'+debitNote.ERP7__Account__r.Id}" target="_blank">{!debitNote.ERP7__Account__r.Name}</a></div>
                                                        </td>
                                                        <td data-label="Invoice Bill Name">
                                                            <div class="slds-truncate2"><a href="{!'/'+debitNote.ERP7__Vendor_Invoice_Bill__r.Id}" target="_blank">{!debitNote.ERP7__Vendor_Invoice_Bill__r.Name}</a></div>
                                                        </td>
                                                        <td data-label="Purchase Order Name">
                                                            <div class="slds-truncate2"><a href="{!'/'+debitNote.ERP7__Purchase_Orders__r.Id}" target="_blank">{!debitNote.ERP7__Purchase_Orders__r.Name}</a></div>
                                                        </td>
                                                        <td data-label="Date">  
                                                            <div class="slds-truncate2" title="{!debitNote.ERP7__Credit_Note_Date__c}">
                                                                <lightning:formattedDateTime value="{!debitNote.ERP7__Credit_Note_Date__c}" year="numeric" month="numeric" day="numeric" timeZone="UTC"/> </div>
                                                        </td>
                                                        <td data-label="Debit">  
                                                            <div class="slds-truncate2" title="{!debitNote.ERP7__Debit__c}">
                                                                <aura:if isTrue="{!v.displayCurrency}">
                                                                    <lightning:formattedNumber style="currency"  value="{!debitNote.ERP7__Debit__c}"/>
                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{!debitNote.ERP7__Debit__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
                                                        <td data-label="Remaining Amount">  
                                                            <div class="slds-truncate2" title="{!debitNote.ERP7__Remaining_Amount__c}">
                                                                <aura:if isTrue="{!v.displayCurrency}">
                                                                    <lightning:formattedNumber style="currency"  value="{!debitNote.ERP7__Remaining_Amount__c}"/>
                                                                    <aura:set attribute="else">
                                                                    	<lightning:formattedNumber value="{!debitNote.ERP7__Remaining_Amount__c}" minimumFractionDigits="2"  maximumFractionDigits="2"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </div>
                                                        </td>
                                                        
                                                        
                                                        <!--<td data-label="Type">
                                                            <div class="slds-truncate2" >{!debitNote.ERP7__Type__c}</div>
                                                        </td>-->
                                                        <td data-label="Posted">
