<aura:event type="APPLICATION" description="For Attachment(File, Image, audio, video)" access="global">
    <aura:attribute name="ParentId" type="String" default=""/>
    <aura:attribute name="Body" type="String" default=""/>
    <aura:attribute name="FileName" type="String" default=""/>
    <aura:attribute name="ContentType" type="String" default=""/>
</aura:event>