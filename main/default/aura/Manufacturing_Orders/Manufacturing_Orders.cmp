                                                                <lightning:formattedDateTime value="{!v.manuOrder.ERP7__StartDate__c}"  variant="label-hidden" year="numeric" month="numeric" day="numeric" hour="2-digit" minute="2-digit" hour12="true"/>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                </div>
