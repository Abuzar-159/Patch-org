                                                <div class="col-md-3">
                                                    <div class="">
                                                        <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">{!$Label.c.SalesOrderToPurchaseOrder_Sales_Order_Line_Items_Details}</label>
                                                            <div class="slds-form-element__control">
                                                                
                                                                <aura:if isTrue="{!(v.manuOrder.ERP7__Order_Product__c != null || v.StandardOrder == true)}" >
