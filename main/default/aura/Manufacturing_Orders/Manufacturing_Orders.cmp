                                                                    <aura:if isTrue="{!!v.isEditable}">
                                                                        <aura:if isTrue="{!v.linksNewOptions}">
                                                                            <lightning:formattedUrl value="{!'/'+v.manuOrder.ERP7__Order_Product__c}" label="{!v.manuOrder.ERP7__Order_Product__r.OrderItemNumber}" target="_blank" class="fcolor"/>
                                                                        </aura:if>
                                                                        <aura:if isTrue="{!!v.linksNewOptions}">
                                                                            {!v.manuOrder.ERP7__Order_Product__r.OrderItemNumber}
                                                                        </aura:if>
                                                                    </aura:if>
                                                                    <aura:set attribute="else">
