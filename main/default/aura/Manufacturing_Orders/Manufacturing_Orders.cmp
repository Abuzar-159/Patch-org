                                                                    <aura:set attribute="else">
                                                                        <lightning:input type="Number"  value="{!v.manuOrder.ERP7__Quantity__c}" /> <div class="each-position">{!v.manuOrder.ERP7__Product__r.QuantityUnitOfMeasure} </div> 
                                                                    </aura:set>
                                                                </aura:if>
                                                                
                                                            </aura:if>
                                                            <aura:if isTrue="{!!v.isEditable}">
                                                                <aura:if isTrue="{!(v.manuOrder.ERP7__Routing__r.ERP7__Max_Allowed_Cuts__c > 0)}"> 
                                                                    <lightning:FormattedNumber value="{!(v.manuOrder.ERP7__Quantity__c * v.manuOrder.ERP7__Routing__r.ERP7__Max_Allowed_Cuts__c)}"/> &nbsp; {!v.manuOrder.ERP7__Product__r.QuantityUnitOfMeasure}
                                                                    <aura:set attribute="else">
