                                                                                        <div class="slds-truncate"> {!$Label.c.Serial_MO}</div>
                                                                                    </th>
                                                                                </aura:if>
                                                                                <th class="slds-is-sortable" scope="col">
                                                                                    <div class="slds-truncate"> {!$Label.c.Qty_Pick} </div>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <aura:iteration items="{!bo.SOLIs}" var="soli" indexVar="i" end="100">
                                                                            <tbody>
