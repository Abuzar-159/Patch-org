                                                                                    <td class="slds-is-sortable " scope="col" height="30px">
                                                                                        <div class="slds-grid slds-truncate" name="{!i}">
                                                                                            <div class="slds-col">
                                                                                                <lightning:button onclick="{!c.DeleteRecordSOLI}" class="neutralC" name="{!soli.Id}"> <a href="javascript:void(0)" title="delete" class="MOs_class37">
                                                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="MOs_class36" />  
                                                                                                    </a> </lightning:button>
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                        <div class="slds-form-element">
                                                                                            <div class="slds-form-element__control"> {!soli.Name} </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <aura:if isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                        <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                            <div class="slds-form-element">
                                                                                                <div class="slds-form-element__control"> {!soli.ERP7__Material_Batch_Lot__r.Name} </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}">
                                                                                        <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                            <div class="slds-form-element">
                                                                                                <div class="slds-form-element__control"> {!soli.ERP7__MO_WO_Material_Batch_Lot__r.Name} </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <aura:if isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                        <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                            <div class="slds-form-element">
                                                                                                <div class="slds-form-element__control"> {!soli.ERP7__Serial__r.Name} </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                        <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                            <div class="slds-form-element">
                                                                                                <div class="slds-form-element__control"> {!soli.ERP7__MO_WO_Serial__r.Name} </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                        <div class="slds-form-element">
                                                                                            <div class="slds-form-element__control"> 
                                                                                                <lightning:formattedNumber value="{!soli.ERP7__Quantity__c*bo.WeightMultiplier}"/>&nbsp; {!bo.SelectedUOM} <!--{!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure}-->
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </aura:iteration>
                                                                    </table>
                                                                </div>
