                            <fieldset class="slds-form--compound">
                                <div class="slds-form-element__group">
                                    <div class="row">
                                        <h2 class="slds-p-around--x-small slds-align-middle MOs_class18">{!v.editErrorMsg}</h2>
                                        <!--div class="col-md-6"> 
                                            <lightning:input type="Text" aura:id="name"  label="{!$Label.c.Name_ManageLeave}" required="true"
                                                             value="{!v.NewMRP.Name}" /> 
                                        </div-->
                                        <div class="col-md-6 slds-m-top--xx-small"> 
                                            <label class="slds-form-element__label" for="input-02">{!$Label.c.AddSubscription_Product}<span class="MOs_class17"> *</span></label>
                                            <c:CustomInputLookUp objectAPIName="Product2" aura:id="product" IconName="standard:product" selectedRecordId="{!v.NewMRP.ERP7__MRP_Product__c}" inputStyleclass="slds-input" /> 
                                        </div>
                                    
                                
                           
                                    
                                        
                                        <div class="col-md-6 slds-m-top--xx-small"> <label class="slds-form-element__label" for="input-03">{!$Label.c.Work_Order}<span class="MOs_class17"> *</span></label>
                                            <c:CustomInputLookUp objectAPIName="ERP7__WO__c"
                                                                 aura:id="wo" IconName="standard:entity" selectedRecordId="{!v.NewMRP.ERP7__Work_Order__c}" inputStyleclass="slds-input" qry="{!'And ERP7__MO__c = \''+v.manuOrder.Id+'\''}" /> </div>
                                        <div class="col-md-6 slds-m-top--xx-small">
                                             <label class="slds-form-element__label" for="input-02">{!$Label.c.Quantity_Required}<span class="MOs_class17"> *</span></label>
                                            <lightning:input type="Decimal"  aura:id="num" value="{!v.NewMRP.ERP7__Total_Amount_Required__c}" variant="label-hidden" fieldLevelHelp="Enter the total quantity required for the BOM per 1 unit of manufacturing product"
                                                             /> </div>
                                    </div>
                                </div>
                            </fieldset>
                            <fieldset class="slds-form--compound">
                                <div class="slds-form-element__group">
                                    <div class="row">
                                        <div class="col-md-12 slds-m-top--xx-small"> 
                                            <lightning:textarea aura:id="notes" class="slds-textareaa height200" maxlength="700" messageWhenTooLong="A maximum of 500 characters are allowed." label="{!$Label.c.Notes}"
                                                                value="{!v.NewMRP.ERP7__Notes__c}" /> </div>
