<aura:component controller="ManufacturingOrder" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,lightning:isUrlAddressable" access="global">
    <aura:attribute name="qry" type="String" />
    <aura:attribute name="pageSize" type="Integer" default="50"/>
    <aura:attribute name="RefreshSerials" type="Boolean" default="true"/>
    <aura:attribute name="showScrapDetails" type="Boolean" default="false"/>
    <aura:attribute name="showMOLabels" type="Boolean" default="false"/>
    <aura:attribute name="allowMRPDelete" type="Boolean" default="false"/>
    <aura:attribute name="showSerials" type="String" default="100"/>
    <aura:attribute name="showVendorCode" type="Boolean" default="false"/>
    <aura:attribute name="WipflowsShow" type="String" default="100"/>
    <aura:attribute name="moSerialNosShow" type="String" default="100"/>
    <aura:attribute name="SelectedSerialsCount" type="Integer" default="0"/>
    <aura:attribute name="WipflowsShowStart" type="String" default="0"/>
    <aura:attribute name="moSerialNosShowStart" type="String" default="0"/>
    <aura:attribute name="showRequisition" type="Boolean" default="true" />
    <aura:attribute name="prevent" type="Boolean" default="false" />
    <aura:attribute name="selectAllSerials" type="Boolean" default="false" />
    <aura:attribute name="StandardOrder" type="Boolean" default="false" />
    <aura:attribute name="blObj" type="object" default="{Name='',Id=''}"/>
    <aura:attribute name="Product" type="object" />
    <aura:attribute name="Version" type="object" />
    <aura:attribute name="Routing" type="object" />  
    <aura:attribute name="schedulerMO" type="Boolean" default="false" />
    <aura:attribute name="CancelURL" type="String" />
    <aura:attribute name="Back2Parent" type="Boolean" default="false" />
    <aura:attribute name="WCAP" type="Boolean" default="false" /> 
    <aura:attribute name="PrintSB" type="Boolean" default="false" />
    <aura:attribute name="show" type="Boolean" default="false" />
    <aura:attribute name="sigTab" type="Boolean" default="false" />
    <aura:registerEvent name="SetQRYParam" type="c:SetQRYParam" />
    <aura:attribute name="manuOrder" type="Manufacturing_Order__c" default="{'sObjectType':'ERP7__Manufacturing_Order__c',ERP7__Version__c:'',ERP7__Routing__c:'',ERP7__Product__c:'',ERP7__Sales_Order__c:'',ERP7__Order__c:''}" />
    <aura:attribute name="manuOrderNew" type="Manufacturing_Order__c" default="{'sObjectType':'ERP7__Manufacturing_Order__c',ERP7__Version__c:'',ERP7__Routing__c:'',ERP7__Product__c:'',ERP7__Sales_Order__c:'',ERP7__Order__c:''}" />
    <aura:attribute name="NewWO" type="WO__c" default="{sobjectType : 'WO__c', ERP7__MO__c:'' }"/>
    <aura:attribute name="MRPs" type="object[]" />
    <aura:attribute name="MRPEdit" type="object" />
    <aura:attribute name="selectedMRP" type="object" />
    <aura:attribute name="SerialNumber2Upsert" type="object" />
    <aura:attribute name="Batch2Upsert" type="object" />
    <aura:attribute name="BatchNumber2Upsert" type="object" />
    <aura:attribute name="NewMRPs" type="object" />
    <aura:attribute name="NewMRP" type="object" />
    <aura:attribute name="WOs" type="object[]" />
    <aura:attribute name="WOWS" type="object[]" />
    <aura:attribute name="PRSS" type="object[]" />
    <aura:attribute name="POSS" type="object[]" /> 
    <aura:attribute name="NewSOLI" type="Stock_Outward_Line_Item__c" default="{sobjectType : 'Stock_Outward_Line_Item__c','ERP7__Material_Batch_Lot__c':'','ERP7__Serial__c':'','ERP7__MO_WO_Material_Batch_Lot__c':'','ERP7__MO_WO_Serial__c':''}"/>
    <aura:attribute name="NewSOLITemp" type="object" default="{sobjectType : 'Stock_Outward_Line_Item__c','ERP7__Material_Batch_Lot__c':'','ERP7__Serial__c':'','ERP7__MO_WO_Material_Batch_Lot__c':'','ERP7__MO_WO_Serial__c':''}"/>
    <aura:attribute name="SOLIs" type="object[]" />
    <aura:attribute name="SOLIs2Delete" type="object[]" />
    <aura:attribute name="SILIs" type="object[]" />
    <aura:attribute name="Wipflows" type="object[]" />
    <aura:attribute name="mySerialNos" type="object[]" />
    <aura:attribute name="SerialsForAllocation" type="object[]" />
    <aura:attribute name="myBatchNos" type="object[]" />
    <aura:attribute name="moSerialNos" type="object[]" />
    <aura:attribute name="moBatchNos" type="object[]" />
    <aura:attribute name="UOMCs" type="object[]" />
    <aura:attribute name="Features" type="object[]" />
    <aura:attribute name="MO" type="String" />
    <aura:attribute name="RD" type="String" />
    <aura:attribute name="NAV" type="String" />
    <aura:attribute name="PID" type="String"/>
    <aura:attribute name="RID" type="String"/>
    <aura:attribute name="VER" type="String"/>
    <aura:attribute name="QUAN" type="String"/>
    <aura:attribute name="WeightCapture" type="Boolean" default="false" />
    <aura:attribute name="Weight" type="Decimal" default="0.00" />
    <aura:attribute name="WeightStr" type="String" default="0" />
    <aura:attribute name="Fulfilled" type="Boolean" default="false" />
    <aura:attribute name="TotalWeight" type="Decimal" default="0.00" />
    <aura:attribute name="errorMsg" type="String" />
    <aura:attribute name="editErrorMsg" type="String" />
    <aura:attribute name="SerialPopupErrorMsg" type="String" />
    <aura:attribute name="BatchPopupErrorMsg" type="String" />
    <aura:attribute name="WeightPopupErrorMsg" type="String" default=""/>
    <aura:attribute name="custInvoiceTest" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}" />
    <aura:attribute name="mosoliId" type="String" default="" />
    <aura:attribute name="MOrdItm" type="String" default="" />
    <aura:attribute name="mrpId" type="String" default="" />
    <aura:attribute name="mpslineId" type="String" default="" />
    <aura:attribute name="productId" type="String"/>
    <aura:attribute name="productName" type="String"/>
    <aura:attribute name="ReserveStock" type="Boolean" default="false" />
    <aura:attribute name="scanValue" type="String" default=''/>
    <aura:attribute name="SelectedUOM" type="String" default=''/>
    <aura:attribute name="UOMS" type="object[]" />
    <aura:attribute name="SelectedAttachments" type="object[]"/>
    <aura:attribute name="soliID" type="Id" default=""/>
    <aura:attribute name="OrdItmId" type="Id" default=""/>
    <aura:attribute name="allowNav" type="Boolean" default="false"/>
    <aura:attribute name="MOrderStatus" type="List"/>
    <aura:attribute name="selectedMRPstoDelete" type="List" default="[]"/>
    <aura:attribute name="time" type="object[]"/>
    <aura:attribute name="workOrderTab" type="Boolean" default="false"/>
    <aura:attribute name="MRPSTab" type="Boolean" default="false"/>
    <aura:attribute name="finishedProductsTab" type="Boolean" default="false"/>
    <aura:attribute name="serialorBatchesTab" type="Boolean" default="false"/>
    <aura:attribute name="signatureTab" type="Boolean" default="false"/>
    <aura:attribute name="saPage" type="Boolean" default="false"/>
    <aura:attribute name="exceptionError" type="String" /> 
    <aura:attribute name="RecordId" type="String" />
    <aura:attribute name="showSAButton" type="Boolean" default="false"/>
    <aura:attribute name="WOSSelectAll" type="Boolean" default="false"/>
    
    <aura:attribute name="showAutoStockAllocation" type="Boolean" default="false"/>
    <aura:attribute name="showManualStockAllocation" type="Boolean" default="false"/>
    <aura:attribute name="showMultiPOs" type="Boolean" default="false"/>
    <aura:attribute name="WipflowsLength" type="Integer" default="0"/>
    <aura:attribute name="SerialsLength" type="Integer" default="0"/>
    
    <force:recordData aura:id="deleteHandler" recordId="{!v.RecordId}" fields="Id" recordUpdated="{!c.CommitDeleteRecord}" targetError="{!v.errorMsg}" />
    
    <aura:attribute name="showCosts" type="Boolean" />
    <aura:attribute name="isEditable" type="Boolean" />
    <aura:attribute name="linksNewOptions" type="Boolean" />
    <aura:attribute name="locationQry" type="String" default=" "/>
<aura:attribute name="SOLI_LocationStock" type="Double" default="0"/>
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <aura:method name="popMRPDetails" action="{!c.getAllMRPDetails}"></aura:method>
    <aura:method name="loadSerialForAllocation" action="{!c.SerialForAllocation}"></aura:method>
    <aura:method name="saveMethod" action="{!c.SaveMO}"></aura:method>
    <aura:method name="CaptureTheWeight" action="{!c.CaptureWeight}"></aura:method>
    <aura:attribute name="changeTrack" type="Boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:handler name="change" value="{!v.NewWO.ERP7__MO__c}" action="{!c.lookupChangeMO}"/>
    
    <aura:handler name="change" value="{!v.Product}" action="{!c.lookupChangeProduct}"/>
    <aura:handler name="change" value="{!v.Version}" action="{!c.lookupChangeVersion}"/>
    <aura:handler name="change" value="{!v.Routing}" action="{!c.lookupChangeRouting}"/>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__Location__c}" action="{!c.getSOLILocationStock}"/>

    <aura:attribute name="ReplaceTravellerOrgURL" type="boolean" default="false"/>
    <aura:attribute name="ShowLangOptionForTraveller" type="Boolean" default="false"/>
    <aura:attribute name="ShowLangOptionForTravellerModal" type="Boolean" default="false"/>
    <aura:attribute name="Langoptions" type="List" default="[
                                                            {'label': 'English', 'value': 'English'},
                                                            {'label': 'French', 'value': 'French'}
                                                            ]"/>
    <aura:attribute name="SelectedLang" type="String" default="English"/>
    <aura:attribute name="MOId" type="String" default=""/>
    
    <aura:handler name="change" value="{!v.scanValue}" action="{!c.verifyScanCode}"/>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__MO_WO_Serial__c}" action="{!c.SerialBOMValidation}"/>
    <aura:handler name="cmpEvent" event="c:SignatureEvent" action="{!c.handleSignatureEvent}"/> 
    <aura:registerevent name="forceNavig2Component" type="force:navigateToComponent"/> 
    
    <!-- pagination for WIP and serials -->
    <aura:attribute name="AllWipflows" type="object[]" />
    <aura:attribute name="AllmoSerialNos" type="object[]" />
    <!-- QA process-->
    <aura:attribute name="enableQA" type="boolean" default="false"/>
    <aura:attribute name="qualityCheckTab" type="boolean" default="false"/>
    <aura:attribute name="ExistingSILI" type="object"/>
    <aura:attribute name="preventsStatusEdit" type="Boolean" default="false" />
    <aura:attribute name="statusOption" type="object" /> 
    <aura:attribute name="displayUplaodforItems" type="Boolean" default="false" />
    <aura:attribute name="objDetail" type="Checklist__c" default="{'sobjectType' : 'Checklist__c'}"/>
    <aura:attribute name="controllingFieldAPI" type="string" default="ERP7__Comply__c" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI" type="string" default="ERP7__Result__c" description="store field API name of dependent field"/>
    <aura:attribute name="listDependingValues" type="list" default="['--- None ---']" description="to store dependent field values"/>
    <aura:attribute name="listControllingValues" type="String" default="" description="to store controller field values"/>
    <aura:attribute name="bDisabledDependentFld" type="boolean" default="true"/> 
    <aura:attribute name="depnedentFieldMap" type="object" description="map to store dependent values with controlling value"/>
    <aura:attribute name="showchecklistvalue" type="boolean" default="false"/>
    <aura:attribute name="ControllingValue" type="String" default="" description="to store controller field values"/>
    <aura:handler name="change" value="{!v.ControllingValue}" action="{!c.onControllerFieldChange}"/>
    <aura:attribute name="uplodedfiles" type="String[]" default="[]"/> 
    <aura:attribute name="FileListforQAguidelines" type="List"/>
      <aura:method name="tabQA" action="{!c.tabQA}"/>
    
    <!-- for custom serial number generation -->
    <aura:attribute name="showSerialNumGeneration" type="boolean" default="false"/>
    <aura:attribute name="FromSerialNum" type="Integer" default=""/>
    <aura:attribute name="StartNo" type="Integer" default="0"/>
    <aura:attribute name="EndNum" type="Integer" default="0"/>
    <aura:attribute name="SerialPrefix" type="String" default="{!$Label.c.Serial_Number_Format}"/>
    <!--<html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink"> commenting for security review-->
    
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__Serial__c}" action="{!c.getSOLISerialStock}"/>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__Material_Batch_Lot__c}" action="{!c.getSOLIBatchStock}"/>
    <aura:attribute name="SOLI_SerialStock" type="Double" default="0"/>
    <aura:attribute name="SOLI_BatchStock" type="Double" default="0"/>
    <aura:attribute name="showSpinner" type="boolean" default="false"/>
    <aura:attribute name="setmyParams" type="boolean" default="false"/>
    <aura:attribute name="AutoSTockAllocationLimit" type="String" default="{!$Label.c.AutoStockLimit}"/>
    <html>
        <head>
            <meta charset="utf-8" /> 
            <meta name="viewport" content="width=device-width,initial-scale=1" />
            <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css" />
            <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css" />
            <!-- <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/main-scrollers.css" />
            <ltng:require styles="/resource/ERP7__Order_Console/assets/styles/custom.css" /> 
            <ltng:require styles="/resource/ERP7__Order_Console/assets/styles/font-awesome.css" />-->
            <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
            <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css" />
            <ltng:require styles="/resource/ERPCustomIcons/style/erp-play.css"/>
            <ltng:require styles="{!join(',',$Resource.ERPFonts + '/src/stylesheet.css')}"  />
            <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
            <ltng:require scripts="/resource/ERP7__jQuery/js/jquery_3.5.0.min.js" afterScriptsLoaded="{!c.focusTOscan}"/>
            <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>  
            <ltng:require scripts="/resource/ERP7__Weighing/Weighing/WeighingScript.js"/> 
            <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
            <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/Manufacturing_orders.css"/>
            <ltng:require styles="/resource/ERP7__axoltmain/Assets/css/axolt-main.css" />
            
        </head>
        <div class="erp_mark7 theme-bg maqsood erp cpq" aura:id="body"> 
            <span class="MOs_class1">
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
            </span>
            <span class="MOs_class1">
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpinLoad" class="mainSpinClass"/>
            </span>
            <aura:if isTrue="{!v.showSpinner}">
                <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" class="mainSpinClass"/>
            </aura:if>
            
            <aura:if isTrue="{!v.ShowLangOptionForTravellerModal}">
                <section role="dialog" tabindex="-1" aria-modal="true" aria-label="Meaningful description of the modal content" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container">
                        <div class="slds-modal__content slds-p-around_medium slds-modal__content_headless" id="modal-content-id-1">
                            <lightning:radioGroup name="radioGroup"
                                                  label="Select Language"
                                                  options="{! v.Langoptions }"
                                                  value="{! v.SelectedLang }"
                                                  type="radio"/>
                        </div>
                        <div class="slds-modal__footer">
                            <lightning:button label="Cancel" onclick="{!c.goBackTraveller}"/>
                            <lightning:button variant="brand" label="Next" onclick="{!c.TravellerNext}"/>
                        </div>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open" role="presentation"></div>
            </aura:if>
            <aura:if isTrue="{!!v.saPage}">
                <div class="theme-bg">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-12">
                                <div class="page-title-box">
                                    <div class="page-title-right mt-0">
                                        <ol class="breadcrumb m-0">
                                            <li class="breadcrumb-item">
                                                <div class="slds-form-element MOs_class4">
                                                    <div class="slds-form-element__control">
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Manufacturing_Order__c" aura:id="mol" IconName="standard:macros" selectedRecordId="{!v.NewWO.ERP7__MO__c}" inputStyleclass="slds-input" label="{!$Label.c.Search_MO}"/> 
                                                    </div>
                                                </div>
                                            </li>
                                            <li class="breadcrumb-item">
                                                <aura:if isTrue="{!v.manuOrder.Id != undefined}">
                                                    <div class="slds-col  slds-no-flex slds-grid slds-align-top MOs_class8 slds-p-top_large" > <!-- slds-no-flex slds-grid slds-align-top-->
                                                        <div class="slds-button" role="group">
                                                            <div onclick="{!c.TravellerDoc}" data-record-Id="{!v.manuOrder.Id}">
                                                                <img src="/resource/ERP7__ERPTheme/icons/pdf.png" class="cursor-pointer" title="Traveller" width="30"></img>
                                                            </div>&nbsp;
                                                            <!-- <a href="{!($Label.c.Traveller_URL_for_MO+'?ra=pdf&amp;RId='+v.manuOrder.Id)}"  target="_blank" title="Traveller">
                                                                <img src="/resource/ERP7__ERPTheme/icons/pdf.png" class="cursor-pointer" title="Traveller" width="30"></img>
                                                            </a>&nbsp;-->
                                                        </div>
                                                    </div>
                                                </aura:if>
                                            </li>
                                        </ol>
                                        <!--<ol class="breadcrumb m-0">
         <li class="breadcrumb-item"><a href="javascript: void(0);">Hyper</a></li>
         <li class="breadcrumb-item"><a href="javascript: void(0);">Pages</a></li>
         <li class="breadcrumb-item active">Manufacturing Order</li>
        </ol>-->
                                    </div>
                                    <h4 class="page-title card-pricing headermt">
                                        
                                        <a href="javascript:void(0);"  onclick="{!c.cancelAction}"><i class="card-pricing-icon text-primary fa fa-home"></i>&nbsp;{!$Label.c.Workbench}
                                        </a>
                                    </h4>
                                    <!-- <lightning:buttonIcon iconName="utility:refresh" variant="bare" onclick="{!c.getAllDetails }" alternativeText="Refresh" title="Refresh" />-->
                                    <aura:if isTrue="{!(v.manuOrder.ERP7__Manufacturing_Order__c != undefined)}">
                                        <a href="{!'/apex/ERP7__ManufacturingOrderLC?MO='+v.manuOrder.ERP7__Manufacturing_Order__c}" class="slds-m-right--small" >({!v.manuOrder.ERP7__Manufacturing_Order__r.Name})</a>
                                    </aura:if>
                                    
                                    <aura:if isTrue="{!(v.PRSS.length > 0)}">
                                        <div class="slds-col  slds-no-flex slds-grid slds-align-middle slds-p-around_x-small">
                                            <strong>  {!$Label.c.Purchase_Requisitions} :</strong>&nbsp;
                                            <aura:iteration items="{!v.PRSS}" var="PR" indexVar="i">
                                                <a href="{!'/'+PR.Id}" target="_blank" class="slds-m-right--xx-small">{!PR.Name} <aura:if isTrue="{!!(v.PRSS.length-1 == i )}">,</aura:if></a>
                                            </aura:iteration>    
                                            
                                        </div>
                                    </aura:if>
                                    
                                    
                                    <aura:if isTrue="{!(v.POSS.length > 0)}">
                                        <div class="slds-col slds-no-flex slds-grid slds-align-top  slds-p-around_x-small">
                                            <strong> {!$Label.c.Acc_Pay_Purchase_Orders} :</strong>&nbsp;
                                            <aura:iteration items="{!v.POSS}" var="PO" indexVar="i">
                                                <aura:if isTrue="{!! and(PO.ERP7__Inbound_Total_Quantity__c > 0, PO.ERP7__Inbound_Total_Quantity__c == PO.ERP7__Inbound_Received_Quantity__c)}">
                                                    <a href="{!'/'+PO.Id}" target="_blank" class="cRed">{!PO.Name}<aura:if isTrue="{!!(v.POSS.length-1 == i )}">,</aura:if></a>
                                                </aura:if>
                                                <aura:if isTrue="{!and(PO.ERP7__Inbound_Total_Quantity__c > 0, PO.ERP7__Inbound_Total_Quantity__c == PO.ERP7__Inbound_Received_Quantity__c)}">
                                                    <a href="{!'/'+PO.Id}" target="_blank" class="norm">{!PO.Name}<aura:if isTrue="{!!(v.POSS.length-1 == i )}">,</aura:if></a>
                                                </aura:if>
                                            </aura:iteration>  
                                            
                                        </div>
                                    </aura:if>
                                    
                                </div>
                            </div>
                        </div>
                        
                        
                    </div>
                </div>
            </aura:if>
            
            <div class="epr_Mark7">
                <!--Error Message-->
                <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed MOs_class11','slds-notify_container slds-is-fixed MOs_class12')}">
                    <div class="slds-notify slds-notify_toast slds-theme_error" role="status" >
                        <span class="slds-assistive-text">{!$Label.c.error}</span>
                        <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                            <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" />
                        </span>
                        <div class="slds-notify__content">
                            <h2 class="slds-text-heading_x-small MOs_class14">{!v.exceptionError}
                            </h2>
                        </div>
                        <div class="slds-notify__close">
                            <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeError}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_ProjectScheduler}" title="Close" />	
                                <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                            </button>
                        </div>
                    </div>
                </div>
                <!--Error Message End-->
                <aura:if isTrue="{!!v.saPage}">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-12">
                                <div class="card mb-2">
                                    <div class="card-body">
                                        
                                        <div class="row slds-p-around--xx-small MOs_class16">
                                            
                                            <div class="col-md-3">
                                                <div class="">
                                                    <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">{!$Label.c.AddSubscription_Product} <span class="MOs_class17">*</span></label>
                                                        <div class="slds-form-element__control" onclick="{!c.lookupClickProduct}">
                                                            <!--here {!v.Product.Id}-->
                                                            <aura:if isTrue="{!v.isEditable}"><c:CustomInputLookUp objectAPIName="Product2" aura:id="mpr" IconName="standard:product" selectedRecordId="{!v.Product.Id}" inputStyleclass="slds-input"/></aura:if>
                                                            <aura:if isTrue="{!!v.isEditable}">
                                                                <aura:if isTrue="{!v.linksNewOptions}">
                                                                    <lightning:formattedUrl value="{!'/'+v.Product.Id}" label="{!v.Product.Name}" target="_blank" class="fcolor"/>
                                                                </aura:if>
                                                                <aura:if isTrue="{!!v.linksNewOptions}">
                                                                    {!v.Product.Name}
                                                                </aura:if>
                                                            </aura:if>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="">
                                                    <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01">{!$Label.c.Production_Version} <span class="MOs_class17">*</span></label>
