                <section role="dialog" tabindex="-1" class="slds-modal slds-modal_medium" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" id="myModal9" aura:id="newMRPModal" >
                    
                    <div class="slds-modal__container">
