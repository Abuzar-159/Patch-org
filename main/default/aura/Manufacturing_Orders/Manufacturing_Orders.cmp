                                                            {!Serial.ERP7__Vendor_Serial_Number__c} </div>
                                                    </td>
                                                </tr>
                                            </aura:iteration>
                                        </tbody>
                                    </aura:if>
                                    <aura:if isTrue="{!(v.myBatchNos.length > 0)}">
