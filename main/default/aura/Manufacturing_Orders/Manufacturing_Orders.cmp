                                                                                <aura:if isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                    <th class="slds-is-sortable " scope="col">
                                                                                        <div class="slds-truncate"> {!$Label.c.Batch} </div>
                                                                                    </th>
                                                                                </aura:if>
                                                                                <aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}">
