                <section role="dialog" tabindex="-1" class="slds-modal fade slds-modal_small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" id="myModalSelectWOs" aura:id="selectWOsModal">
                    <!--<div class="slds-modal fade MOs_class53" id="myModalSelectWOs" aura:id="selectWOsModal" role="dialog" >-->
                    <div class="slds-modal__container">
                        <header class="slds-modal__header slds-modal__header_empty">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.closeSelectWOsModal}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="medium"></lightning:icon>
                                
                                <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                            </button>
                            
                        </header>
                        <!-- Modal content-->
                        <div class="modal-content">
                            <div class="slds-modal__content slds-p-around_medium">
                                <div class="table-responsive MOs_class27 MOs_height" tabindex="1">
                                    <table class="table" data-aura-rendered-by="555:495;a">
                                        <thead>
                                            <tr class="slds-text-title--caps">
                                                <th class="slds-is-sortable" scope="col">
                                                    <div class="slds-truncate"> {!$Label.c.Work_Orders} </div>
                                                </th> 
                                                <td data-label="Select">
                                                    <div class="slds-form-element">
                                                        <div class="slds-form-element__control"> 
                                                            <lightning:input type="checkbox" checked="{!v.WOSSelectAll}" onchange="{!c.AutoStockAllocationSelectAll}"></lightning:input>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        </thead>
                                        <aura:iteration items="{!v.WOWS}" var="wo" indexVar="i">
                                            <tbody>
                                                <tr class="slds-hint-parent">
                                                    <td data-label="Work Order">
                                                        <div class="slds-grid">
                                                            <!--<div class="slds-truncate" >{!i +1+ '. '}&nbsp;</div>-->
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control"> 
                                                                    <strong>
                                                                        <a data-record-id = "{!wo.WorkOrder.Id}" title="{!wo.WorkOrder.Name}">
                                                                            <div class="slds-truncate2" > {!wo.WorkOrder.Name}</div>
                                                                        </a>
                                                                    </strong>
                                                                </div>                                                
                                                            </div>
                                                        </div>
                                                    </td>
                                                    
                                                    <td data-label="Select">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control"> 
                                                                <lightning:input type="checkbox" checked="{!wo.isSelect}"></lightning:input>
                                                            </div>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <aura:if isTrue="{!and(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c , wo.isSelect)}">
                                                    <tr>
                                                        <td colspan="10">
                                                            <table class="slds-table slds-table_bordered slds-table_fixed-layout slds-table_resizable-cols">
                                                                <thead>
                                                                    <tr>
                                                                        <th>
                                                                            <div class="slds-truncate"> {!$Label.c.AddSubscription_Product} </div>
                                                                        </th>
                                                                        <th>
                                                                            <div class="slds-truncate">{!$Label.c.MO_ReqQty}</div>
                                                                        </th>
                                                                        <th>
                                                                            <div class="slds-truncate"> {!$Label.c.MO_Fulfilled}</div>
                                                                        </th>
                                                                        <th>
                                                                            <div class="slds-truncate"> Stock </div>
                                                                        </th>
                                                                        <th>
                                                                            <div class="slds-truncate">Qty </div>
                                                                        </th>
                                                                        <th>
                                                                            <div class="slds-truncate"> &nbsp; </div>
                                                                        </th>
                                                                    </tr>
                                                                </thead>
                                                                <aura:iteration items="{!v.MRPs}" var="MRP" indexVar="x">
                                                                    <aura:if isTrue="{!(MRP.MRP.ERP7__Work_Order__c == wo.WorkOrder.Id)}">
                                                                        <tr>
                                                                            <td>
                                                                                <div class="slds-truncate2">
                                                                                    <span class=""><lightning:formattedUrl value="{!'/'+MRP.MRP.ERP7__MRP_Product__c}" label="{!MRP.MRP.ERP7__MRP_Product__r.Name}" target="_blank" /> </span> 
                                                                                </div>
                                                                            </td>
                                                                            <td>
                                                                                <div class="slds-truncate2">
                                                                                    {!MRP.MRP.ERP7__Total_Amount_Required__c} &nbsp;{!MRP.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                                </div>
                                                                            </td>
                                                                            <td>
                                                                                {!MRP.MRP.ERP7__Fulfilled_Amount__c}
                                                                            </td>
                                                                            <td>
                                                                                <lightning:formattedNumber value="{!(MRP.Stock * MRP.WeightMultiplier) }"  minimumFractionDigits="2" maximumFractionDigits="2"/>
                                                                            </td>
                                                                            <!-- <td>
                                                                                <div class="slds-form-element__control">
                                                                                    <lightning:input type="Number"  step="0.01" value="{!MRP.MRPQuantity}" onchange="{!c.EvaluteMRPQty}" title="{!MRP.MRP.Id}" disabled="{!(MRP.MRP.ERP7__Total_Amount_Required__c == MRP.MRP.ERP7__Fulfilled_Amount__c)}"></lightning:input>
                                                                                </div> 
                                                                            </td>-->
                                                                            <td>
                                                                                <aura:if isTrue="{!(MRP.MRP.ERP7__Total_Amount_Required__c != MRP.MRP.ERP7__Fulfilled_Amount__c)}">
                                                                                    <span class="slds-badge slds-theme_success cursor-pointer width93-prt" onclick="{!c.allocateForMRP}" name="{!MRP.MRP.Id}" title="For serials only 250 is allowed">{!$Label.c.Allocate}</span>
                                                                                    <!--button class="slds-button slds-button-/-brand" onclick="{!c.allocateForMRP}" name="{!MRP.MRP.Id}">{!$Label.c.Allocate}</button--> 
                                                                                    <aura:set attribute="else">
                                                                                        <span class="slds-badge slds-badge_inverse">{!$Label.c.Stock_allocated}</span>
                                                                                    </aura:set>
                                                                                </aura:if>
                                                                            </td>
                                                                            
                                                                        </tr>
                                                                    </aura:if>
                                                                </aura:iteration>
                                                            </table>
                                                            
                                                        </td>
                                                    </tr>
                                                    
                                                </aura:if>
                                            </tbody>
                                        </aura:iteration>
                                    </table>
                                </div>
                            </div>
                            <footer class="slds-modal__footer text-center"> 
                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeSelectWOsModal}">{!$Label.c.close_UserAvailabilities}</button>		<!-- cancel label was changed to close, {!$Label.c.cancel_UserAvailabilities} to {!$Label.c.close_UserAvailabilities} , bushra on 29/01/2025-->
                                <aura:if isTrue="{!!v.manuOrder.ERP7__Product__r.ERP7__Serialise__c}">
                                    <button class="slds-button slds-button--brand" onclick="{!c.ReserveMRPStocks}">{!$Label.c.Allocate}</button> 
                                </aura:if>
                                
                            </footer>
                        </div>
                    </div>
                    <!--</div>-->
                </section>
                <div class="slds-backdrop" aura:id="myselectWOsModalBackdrop"></div>
                
                <!-- Create PO confirm pop-up start-->
                <section role="dialog" tabindex="-1" class="slds-modal fade slds-modal_small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" id="myPOConfirmModalShow" aura:id="POConfirmModalShow">
               <!-- <section role="dialog" tabindex="-1" aria-modal="true" aria-labelledby="modal-heading-01" class="slds-modal " aura:id="POConfirmModalShow">-->
                    <div class="slds-modal__container">
                        <div class="slds-modal__header">
                            <lightning:buttonIcon iconName="utility:close"
                                                  onclick="{!c.closePOConfirmModal }"
                                                  alternativeText="close"
                                                  variant="bare-inverse"
                                                  class="slds-modal__close" size="large"/>
                            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Type_of_PO}</h2>
                        </div>
                        <div class="slds-modal__content slds-p-around_medium text-center" id="modal-content-id-1">
                            <lightning:button class="slds-button slds-button--brand slds-m-right_medium" label="{!$Label.c.Create_Single_PO}" onclick="{!c.createSinglePO}" iconName="utility:page" iconPosition="right"/>
                            <lightning:button class="slds-button slds-button--brand"  onclick="{!c.createMultiplePO}" label="{!$Label.c.Create_Multiple_PO}" iconName="utility:multi_picklist" iconPosition="right"/>
                            </div>
                            <div class="slds-modal__footer">
                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closePOConfirmModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                            </div>
                        </div>
                    
                    </section>
                <div class="slds-backdrop" role="presentation" aura:id="POConfirmModalBackdrop"></div>
               
                <!-- Create PO confirm pop-up End-->
                <!-- mODEL END -->
            </div>
            
        </div>
        
    </html>
</aura:component>