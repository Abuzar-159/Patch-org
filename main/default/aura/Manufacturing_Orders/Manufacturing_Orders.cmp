                                                                        <aura:if isTrue="{!v.isEditable}"><c:CustomInputLookUp objectAPIName="ERP7__Sales_Order__c" aura:id="mso" IconName="standard:orders" selectedRecordId="{!v.manuOrder.ERP7__Sales_Order__c}" inputStyleclass="slds-input" /> </aura:if>
                                                                        <aura:if isTrue="{!and(!v.isEditable,v.manuOrder.ERP7__Sales_Order__c != null)}">
                                                                            <aura:if isTrue="{!v.linksNewOptions}">
