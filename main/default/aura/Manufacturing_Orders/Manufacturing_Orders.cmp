                                                            <aura:if isTrue="{!(SLN.ERP7__Product__r.ERP7__Picture__c != undefined)}"> &nbsp;&nbsp;<img src="{!SLN.ERP7__Product__r.ERP7__Picture__c}" class="MOs_class65" /> </aura:if>
