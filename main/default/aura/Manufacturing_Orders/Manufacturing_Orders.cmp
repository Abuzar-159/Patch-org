                                                                                <aura:if isTrue="{!and(v.preventsStatusEdit == false)}">
                                                                                    <div class="page-title-right" data-aura-rendered-by="1216:0">
                                                                                        <lightning:button label="{!$Label.c.Change_Status_of_All_Received_Items}" onclick="{!c.showStatusChange}" variant="brand"  aura:id="changeStatus"/>
                                                                                    </div>
                                                                                </aura:if>
                                                                                <h4 class="page-title card-pricing headermt" data-aura-rendered-by="1292:0">
                                                                                    <strong>Produced/Scrapped Items</strong>
                                                                                </h4>
                                                                            </div>
                                                                            <table class="table slds-no-row-hover Receive-class61">
                                                                                <thead>
                                                                                    <tr bgcolor="#f3f3f3">
                                                                                        <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class63" scope="col" valign="middle">{!$Label.c.Name_ManageLeave}</th>
                                                                                        <th class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" align="left" valign="middle">Quantity</th>
                                                                                        <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.Batch_Lot} </th>
                                                                                        <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.Serial_StockTake} </th>
                                                                                        <th  scope="col" align="left" class="slds-text-heading--label slds-truncate2 Receive-class65" valign="middle"> {!$Label.c.InboundStatus} </th>
                                                                                        <th align="left" class="slds-text-heading--label slds-truncate2 Receive-class64" scope="col" valign="middle"> Produced/Scrapped </th>                                    
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    <aura:iteration items="{!v.ExistingSILI}" var="sili" indexVar="index">
                                                                                        <tr>
                                                                                            
                                                                                            <td class="scanMN Receive-class72" data-label="Product" align="left"  valign="middle">
                                                                                                <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Product__r.Name}" class=" scanMN"/>
                                                                                            </td>
                                                                                            
                                                                                            <td class="slds-truncate2 scanMN Receive-class72" data-label="Quantity" align="left"  valign="middle">
                                                                                                <lightning:formattedNumber  variant="label-hidden" value="{!sili.sili.ERP7__Quantity__c}" class=" scanMN"/>
                                                                                            </td>
                                                                                            <td data-label="Batch No." align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                                <aura:if isTrue="{!sili.sili.ERP7__Product__r.ERP7__Lot_Tracked__c == true}">
                                                                                                    <aura:if isTrue="{!and(and(sili.sili.ERP7__Material_Batch_Lot__c != undefined,sili.sili.ERP7__Material_Batch_Lot__c != null),sili.sili.ERP7__Material_Batch_Lot__c != '')}">
                                                                                                        <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Material_Batch_Lot__r.Name}" class=" scanMN"/>
                                                                                                    </aura:if>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <td data-label="Serial No." align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                                <aura:if isTrue="{!sili.sili.ERP7__Product__r.ERP7__Serialise__c == true}">
                                                                                                    <aura:if isTrue="{!and(and(sili.sili.ERP7__Serial__c != undefined,sili.sili.ERP7__Serial__c != null),sili.sili.ERP7__Serial__c != '')}">
                                                                                                        <lightning:formattedText  variant="label-hidden" value="{!sili.sili.ERP7__Serial__r.Name}" class=" scanMN"/>
                                                                                                    </aura:if>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                            <td data-label="Status" align="left" class="slds-truncate2 scanMN" valign="middle">
                                                                                                <aura:if isTrue="{!(v.preventsStatusEdit == false)}">
                                                                                                    <lightning:select name="{!sili.sili.Id}"  label="{!$Label.c.CreateClubcard_Status}" variant="label-hidden"   value="{!sili.sili.ERP7__Status__c}" onchange="{!c.handleStatusChange}" class="nolabel"> 
                                                                                                        <aura:iteration items="{!v.statusOption}" var="item">
                                                                                                            <option text="{!item.label}" value="{!item.value}" selected="{!(sili.sili.ERP7__Status__c == item.value)}"/> 
                                                                                                        </aura:iteration>
                                                                                                    </lightning:select>  
                                                                                                    <aura:set attribute="else">
                                                                                                        {!sili.sili.ERP7__Status__c}
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                                
                                                                                            </td>
                                                                                            
                                                                                            <td align="left" class="scanMN slds-truncate2" valign="middle">
                                                                                                <aura:if isTrue="{!sili.sili.ERP7__Scrap__c}">
                                                                                                    Scrapped
                                                                                                    <aura:set attribute="else">
                                                                                                        Produced
                                                                                                    </aura:set>
                                                                                                </aura:if>
                                                                                            </td>
                                                                                        </tr>
                                                                                        
                                                                                        <aura:if isTrue="{!(sili.sili.ERP7__Product__r.ERP7__Quality_Check_QA__c)}">                                           
                                                                                            <aura:if isTrue="{!(sili.guideline.length > 0)}"> 
                                                                                                <aura:iteration items="{!sili.guideline}" var="ck" indexVar="checklistsIndex">
                                                                                                    <aura:if isTrue="{!sili.sili.Id == ck.ERP7__Stock_Inward_Line_Item__c}">
                                                                                                        <tr>
                                                                                                            <td valign="top" class="valigntop"></td>
                                                                                                            <td valign="top" class="valigntop">
                                                                                                                
                                                                                                                <div class="slds-truncate2" title="{!ck.Name}">
                                                                                                                    <aura:if isTrue="{!ck.ERP7__Checklist__r.ERP7__Is_Mandatory__c}">
                                                                                                                        <span class="cpo-class21">*</span>{!ck.Name}
                                                                                                                        <aura:set attribute="else">
                                                                                                                            <lightning:formattedText value="{!ck.Name}"/>
                                                                                                                        </aura:set>
                                                                                                                    </aura:if> 
                                                                                                                </div>
                                                                                                                
                                                                                                            </td>
                                                                                                            <td valign="top" class="valigntop">
                                                                                                                <aura:if isTrue="{!and(ck.ERP7__Checklist__r.ERP7__Comply__c != null, ck.ERP7__Checklist__r.ERP7__Comply__c != '--None--')}">
                                                                                                                    <aura:if isTrue="{!greaterthan(v.depnedentFieldMap.length,0)}">
                                                                                                                        <aura:iteration items="{!v.depnedentFieldMap}"  var="mapKey" indexVar="key">  
                                                                                                                            <aura:if isTrue="{!(mapKey.key == ck.Name)}">
                                                                                                                                <lightning:select label="{!$Label.c.Checklist_Operation}" value="{!ck.ERP7__Instructions__c}" variant ="label-hidden" disabled="{!or(sili.sili.ERP7__Status__c == $Label.c.InStockPickListValue, ck.ERP7__Is_Mandatory__c == false)}" class="checklistlabel"><!-- Moin added label="{!$Label.c.Checklist_Operation}" on 09th september -->
                                                                                                                                    <aura:iteration items="{!mapKey.value}" var="val">
                                                                                                                                        <option value="{!val.value}" selected="{!val.value == ck.ERP7__Instructions__c}">{!val.label}</option>
                                                                                                                                    </aura:iteration>
                                                                                                                                </lightning:select>
                                                                                                                            </aura:if>  
                                                                                                                        </aura:iteration>
                                                                                                                    </aura:if>	
                                                                                                                    
                                                                                                                    <aura:set attribute="else">
                                                                                                                        
                                                                                                                        <lightning:input type="text" label="" placeholder="Enter your comments" class="mheight300"
                                                                                                                                          disabled="{!or(sili.sili.ERP7__Status__c == $Label.c.InStockPickListValue,ck.ERP7__Is_Mandatory__c == false)}"
                                                                                                                                         value="{!ck.ERP7__Instructions__c}" disabledCategories="FORMAT_TEXT,FORMAT_FONT,FORMAT_BODY,ALIGN_TEXT,INSERT_CONTENT,REMOVE_FORMATTING"
                                                                                                                                         />
                                                                                                                    </aura:set>
                                                                                                                    
                                                                                                                </aura:if>
                                                                                                            </td>
                                                                                                            <td class="valigntop">
                                                                                                                <aura:if isTrue="{!and(v.displayUplaodforItems,ck.ERP7__Is_Mandatory__c)}">
                                                                                                                    <div class="slds-grid slds-wrap">
                                                                                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12">
                                                                                                                            <lightning:input aura:id="fileId" type="file" name="{!ck}" onchange="{!c.onFileUploadedQAGuideLines}"  multiple="true" class="InboundLog-class31"/>
                                                                                                                        </div>
                                                                                                                        <aura:if isTrue="{!and(ck.Id != undefined,ck.Id != null)}"> 
                                                                                                                            <aura:if isTrue="{!and(ck.Attachments != undefined,ck.Attachments != null)}">
                                                                                                                                <div class="slds-col slds-size_1-of-1 slds-large-size_12-of-12 slds-truncate">
                                                                                                                                    <div class="scroll-wrap-height-cntl">
                                                                                                                                        <aura:if isTrue="{!ck.Attachments.length > 0}">
                                                                                                                                            <aura:iteration var="attch" indexVar="attchIndex" items="{!ck.Attachments}">
                                                                                                                                                <aura:if isTrue="{!(attch.Id != undefined)}">
                                                                                                                                                    <div class="slds-grid slds-p-top_small">
                                                                                                                                                        <div class="slds-col">
                                                                                                                                                            <lightning:buttonIcon iconName="utility:delete" variant="bare" name="{!attch.Id}" title="{!ck.Id}" onclick="{!c.DeleteRecordATforQAGuideLines}" alternativeText="delete" class="colorRed"/>
                                                                                                                                                            &nbsp;
                                                                                                                                                            <lightning:formattedUrl value="{!'/'+attch.Id}" label="{!attch.Name}" tooltip="{!attch.Name}" target="_blank" class="fcolor"/>
                                                                                                                                                        </div>
                                                                                                                                                    </div>
                                                                                                                                                </aura:if>
                                                                                                                                            </aura:iteration>
                                                                                                                                        </aura:if>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            </aura:if>
                                                                                                                        </aura:if>
                                                                                                                    </div>
                                                                                                                </aura:if>
                                                                                                            </td>
                                                                                                        </tr>
                                                                                                    </aura:if>
                                                                                                </aura:iteration>
                                                                                            </aura:if>
                                                                                        </aura:if>
                                                                                        
                                                                                    </aura:iteration>
                                                                                </tbody>
                                                                            </table>
                                                                            <aura:set attribute="else">
                                                                                No Items in Quality Check
                                                                            </aura:set>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                    </div>
                                                    <div class="slds-docked-form-footer MOs_class16">
                                                        <div class="col-md-12 MOs_class10" >
                                                            <aura:if isTrue="{!(v.RD == 'yes')}">
                                                                
                                                                <lightning:button class="slds-button slds-button--neutral" type="Cancel" label="{!$Label.c.EmployeeReviewV2_Back}" onclick="{!c.cancelAction}" />
                                                            </aura:if>
                                                            
                                                            <aura:if isTrue="{!v.RD != 'yes'}">
                                                                <aura:if isTrue="{!v.manuOrder.Id != undefined}">
                                                                    <a href="{!'/'+ v.manuOrder.Id}" label="Cancel" class="slds-button slds-button--neutral" >{!$Label.c.EmployeeReviewV2_Back}</a></aura:if>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.Back2Parent}"> 
                                                                <aura:if  isTrue="{!(v.manuOrder.ERP7__Sales_Order__c != undefined)}">
                                                                    <a href="javascript:void(0);" onclick="{!c.Nav2Epos}" data-mosoliId="{!v.manuOrder.ERP7__Sales_Order__c}" class="slds-button slds-button--neutral"><lightning:icon iconName="utility:chevronleft"></lightning:icon>&nbsp;{!$Label.c.EmployeeReviewV2_Back}</a>							
                                                                </aura:if>
                                                                <aura:if  isTrue="{!(v.manuOrder.ERP7__Order__c != undefined)}">
                                                                    <a href="javascript:void(0);" onclick="{!c.Nav2Epos}" data-mosoliId="{!v.manuOrder.ERP7__Order__c}" class="slds-button slds-button--neutral" ><lightning:icon iconName="utility:chevronleft"></lightning:icon>&nbsp;{!$Label.c.EmployeeReviewV2_Back}</a>							
                                                                </aura:if>
                                                            </aura:if> 
                                                            <aura:if isTrue="{!and(v.manuOrder.Id != undefined, v.isEditable)}">
                                                                <button class="slds-button slds-button--brand" onclick="{!c.SaveMO}">{!$Label.c.ContractConsole_Save}</button>
                                                            </aura:if>
                                                            <aura:if isTrue="{!and(v.manuOrder.Id == undefined, v.isEditable)}"> 
                                                                <button class="slds-button slds-button--brand" onclick="{!c.SaveMO}"> {!$Label.c.Schedule_Production}</button>
                                                            </aura:if>
                                                            <aura:if isTrue="{!and(v.qualityCheckTab, v.enableQA)}"> 
                                                                <button class="slds-button slds-button--brand" onclick="{!c.SaveChecklists}"> Save Checklists</button>
                                                            </aura:if>
                                                            
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </aura:if>
                
                <aura:if isTrue="{!v.saPage}">
                    <div id="WeightCaptures" aura:id="stockAllocationModal">
                        <div class="">
                            <!-- Modal content-->
                            
                            <div class="{!if(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c || v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c,'modal-header modalbg MOs_class60 slds-hide','modal-header modalbg MOs_class59 slds-hide')}"> 
                                <button type="button" class="close MOs_class61" onclick="{!c.closeStockAllocationModal}" >x</button>
                                
                                <aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                    <div class="slds-grid MOs_class62"> 
                                        <div class="slds-col slds-m-top--medium MOs_class67">
                                            <span class="slds-text-heading_xx-small"><strong class="MOs_class68">{!$Label.c.Serial_MO} </strong>
                                                <span class="MOs_class17">*</span></span> 
                                        </div>
                                        <div class="slds-col slds-m-top--x-small MOs_class69" onmouseover="{!c.lookupClickSerialFor}">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisn" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Serial__c}"
                                                                 inputStyleclass="slds-input" qry="{!v.qry}" />
                                        </div>
                                    </div>     
                                </aura:if>
                                
                                <aura:if isTrue="{!and(!v.manuOrder.ERP7__Product__r.ERP7__Serialise__c,v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}"> 
                                    <div class="slds-grid MOs_class62">
                                        <div class="slds-col slds-m-top--medium MOs_class67">
                                            <span class="slds-text-heading_xx-small"> <strong class="MOs_class68">{!$Label.c.Batch_MO}</strong>
                                                <span class="MOs_class17">*</span></span> 
                                        </div>  
                                        
                                        <div class="slds-col slds-m-top--x-small MOs_class69" onmouseover="{!c.lookupClickBatchFor}">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solibt" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c}" inputStyleclass="slds-input" qry="{!v.qry}" />
                                        </div>
                                    </div>
                                </aura:if>
                                
                            </div>
                            
                            <div class="container-fluid theme-bg">
                                <aura:if isTrue="{!(v.WeightPopupErrorMsg != '')}">
                                    <h2 class="slds-m-right-small slds-align-middle MOs_class71">{!v.WeightPopupErrorMsg}</h2>
                                </aura:if>
                                <div class="row">
                                    
                                    <div  class="{!if((v.SerialsForAllocation.length > 0), 'col-md-2 slds-m-top--small2 pl-2 pr-1', 'col-md-3 slds-m-top--small2 pl-2 pr-1')}">
                                        <div class="card shadow-none mb-4 ">
                                            <div class="card-header">
                                                <h5 class="text-primary fw-bold m-0 pt-2 pb-2">{!$Label.c.Bill_of_Materials_BOM}</h5>
                                            </div>
                                            <div class="scroll-bar-wrap shadow-sm bg-white"> 
                                                <div class="scroll-box manufacturing-newClass28">
                                                
                                                    <ul class="list-group list-group-flush">
                                                        <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                            <!--<aura:if isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'gram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'kilogram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'milligram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'lbs')}">-->
                                                            <li class="{!if(bo.isSelect,'list-group-item active-card cursor-pointer','list-group-item cursor-pointer non-active-card')}"  data-mrpcount="{!i}" onclick="{!c.SelectMRP}">
                                                                <div class="row align-items-center no-gutters">
                                                                    <div class="col" title="{!bo.MRP.ERP7__MRP_Product__r.Name}" id="{!bo.MRP.ERP7__MRP_Product__c}">
                                                                        <h6 class="mb-1 mt-1">
                                                                            <strong>
                                                                                {!bo.MRP.ERP7__MRP_Product__r.Name}
                                                                            </strong>
                                                                        </h6>
                                                                    </div>
                                                                    <div class="col-auto">
                                                                        <aura:if isTrue="{!and(bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c != undefined,bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c != '')}">
                                                                            &nbsp;&nbsp;<img src="{!bo.MRP.ERP7__MRP_Product__r.ERP7__Picture__c}" class="MOs_class65" />
                                                                        </aura:if>  
                                                                    </div>
                                                                </div>
                                                            </li>
                                                            <!--</aura:if>-->
                                                        </aura:iteration>
                                                    </ul>
                                                </div>
                                                <div class="cover-bar"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Serials for allocation imran -->
                                    <div class="col-md-2 slds-m-top--small2 pl-1 pr-1" style="{!if((v.SerialsForAllocation.length > 0), '', 'display:none')}">
                                         <div class="card shadow-sm mb-4">
                                        <aura:if isTrue="{!!(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                           
                                                <div class="card-header">
                                                    <h5 class="text-primary fw-bold m-0 pt-2 pb-2">Selected Serials - {!v.SelectedSerialsCount}</h5>
                                                    <div class="slds-grid slds-grid ">
                                                        <lightning:input type="checkbox" aura:id="selectAllSerials" checked="{!v.selectAllSerials}" label="Select" onchange="{!c.selectAllSerials}" class="slds-p-top_xx-small"></lightning:input>
                                                        <lightning:select value="{!v.showSerials}" onchange="{!c.SetShowSerial}" variant="label-hidden" class="noLabel">
                                                            <option value="10">10</option>
                                                            <option value="50">50</option>
                                                            <option value="100">100</option>
                                                            <option value="200">200</option>
                                                            <option value="500">500</option> 
                                                            <!--<option value="1000">1000</option> 
                                                    <option value="3000">All</option> -->
                                                        </lightning:select>
                                                    </div>
                                                    
                                                </div>
                                                
                                          
                                            
                                            
                                            
                                        </aura:if>
                                             <div class="scroll-bar-wrap"> 
                                                 <div class="{!if((!(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c)),'scroll-box mo-heightctl','scroll-box mo-heightctl2')}">
                                                      <ul class="list-group list-group-flush">
                                                     <aura:iteration items="{!v.SerialsForAllocation}" var="bo" indexVar="i" end="{!v.showSerials}"> 
                                                        
                                                             <li class="{!if((AND(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c == true, bo.Id == v.NewSOLI.ERP7__MO_WO_Serial__c) || AND(bo.SelectItem == true)),'list-group-item active-card cursor-pointer','list-group-item cursor-pointer non-active-card')}"  data-serialcount="{!i}" onclick="{!If((v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c == true), c.SelectSerialForAllocation,'')}">
                                                                 <div class="row align-items-center no-gutters" data-serialId="{!bo.Id}" onclick="{!If(!(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c == true), c.selectTheSerialonDiv,'')}">
                                                                     <div class="col-1">
                                                                     <aura:if isTrue="{!!(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                 <lightning:input type="checkbox" style="visibility:hidden;" aura:id="selectAllSerials" checked="{!bo.SelectItem}" onchange="{!c.selectTheSerial}"></lightning:input> 
                                                                             </aura:if>
                                                                     </div>
                                                                     <div class="col" title="{!bo.Name}" id="{!bo.Id}">
                                                                        
                                                                            
                                                                         <h6 class="mb-0 mt-0"><strong> {!bo.Name}  </strong></h6>
                                                                     </div>
                                                                     
                                                                 </div>
                                                             </li>
                                                        
                                                         
                                                         
                                                               
                                                                 <!--<p class="my-1" id="active-users-count">
                                                                <div class="slds-grid slds-wrap">
                                                                    <div class="col-4">
                                                                        <div class="text-muted">{!$Label.c.MO_ReqQty}</div>
                                                                    </div>
                                                                    <div class="col-8 " >
                                                                        <span class="text-warning me-2 valign-top">
                                                                            <span class="slds-text-heading-small">
                                                                                {!v.selectedMRP.ERP7__BOM__r.ERP7__Quantity__c} 
                                                                                &nbsp;{!v.selectedMRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                            </span>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </p>-->
                                                             
                                                                                    
                                                     </aura:iteration>
                                                      </ul>
                                                 </div>
                                                 <div class="cover-bar"></div>
                                             </div>
                                        </div>
                                    </div> 
                                    
                                    <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                        <aura:if isTrue="{!(bo.isSelect)}">
                                            <div class="{!if((v.SerialsForAllocation.length > 0),'col-md-8 slds-m-top--small2 pl-1','col-md-9 slds-m-top--small2 pl-1')}">
                                                
                                                <article class="card mb-0">
                                                    <div class="card-body pt-1">
                                                        
                                                        <div class="container-fluid">
                                                            <div class="row">
                                                                
                                                                <div class="col-md-5">
                                                                    <div class="row">
                                                                        <div class="col-md-12 mb-1">   
                                                                            <div class="{!if(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c || v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c,' MOs_class60','  MOs_class59')}"> 
                                                                                <!--<aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                    <div class="slds-grid slds-wrap MOs_class62"> 
                                                                                        <div class="col-md-12 slds-m-top-xx-small p-0 ">
