                                    </div>
                                    
                                    
                                </div>
                            </div>
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-12 pl-0 pr-0">
                                        <div class="card">
                                            <div class="card-body">
                                                <div class="panel-collapse collapse in">
                                                    <div class="panel-body MOs_class19">
                                                        <!-- Nav tabs -->
                                                        <ul class="slds-tabs--default__nav" role="tablist">
                                                            <li onclick="{!c.tab1}" class="{!(v.MRPSTab)?'MOs_class20 slds-tabs--default__item slds-active':'MOs_class20 slds-tabs--default__item'}" title="{!$Label.c.MRPS}" role="presentation">
                                                                <a class="slds-tabs--default__link MOs_class21" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item" >
                                                                    <i class="fa fa-outdent MOs_class24" aria-hidden="true"  ></i>&nbsp;{!$Label.c.MOMRPSTab} <!--MRPS-->
                                                                </a>
                                                            </li>
                                                            <li onclick="{!c.tab2}" class="{!(v.workOrderTab)?'MOs_class20 slds-tabs--default__item slds-active':'MOs_class20 slds-tabs--default__item'}" title="Work Orders" role="presentation" >
                                                                <a class="slds-tabs--default__link MOs_class21" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                                                    <i class="fa fa-file-text MOs_class24" aria-hidden="true" ></i>&nbsp;{!$Label.c.Work_Orders}
                                                                </a>
                                                            </li>
                                                            <li onclick="{!c.tab3}" class="{!(v.finishedProductsTab)?'MOs_class20 slds-tabs--default__item slds-active':'MOs_class20 slds-tabs--default__item'}" title="{!$Label.c.MOFinishedProductsTab}" role="presentation" >
                                                                <a class="slds-tabs--default__link MOs_class21" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                                                    <i class="fa fa-check-circle MOs_class24" aria-hidden="true"  ></i>&nbsp;{!$Label.c.MOFinishedProductsTab}<!--Finished Products-->
                                                                </a>
                                                            </li>
                                                            <aura:if isTrue="{!(v.manuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c || v.manuOrder.ERP7__Product__r.ERP7__Serialise__c || (v.moBatchNos.length > 0))}"> <!-- added on 20_11_23-->
                                                                <li onclick="{!c.tab4}" class="{!(v.serialorBatchesTab)?'MOs_class20 slds-tabs--default__item slds-active':'MOs_class20 slds-tabs--default__item'}" title="Serial Numbers/Batches" role="presentation">
                                                                    <a class="slds-tabs--default__link MOs_class21" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                                                        <i class="fa fa-tasks MOs_class24" aria-hidden="true" ></i>&nbsp;{!$Label.c.Serial_Numbers_Batches}
                                                                    </a>
                                                                </li>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.enableQA}">
                                                                <aura:if isTrue="{!and(v.manuOrder.ERP7__Product__r.ERP7__Quality_Check_QA__c,v.manuOrder.ERP7__Product__r.ERP7__QA_Handling_Inbound_Post_MO_Completion__c == false)}">
                                                                    <li onclick="{!c.tabQA}" class="{!(v.qualityCheckTab)?'MOs_class20 slds-tabs--default__item slds-active':'MOs_class20 slds-tabs--default__item'}" title="Quality Check(QA)" role="presentation">
                                                                        <a class="slds-tabs--default__link MOs_class21" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-deafult-1__item">
                                                                            <i class="fa fa-tasks MOs_class24" aria-hidden="true" ></i>&nbsp;Quality Check(QA)
                                                                        </a>
                                                                    </li>         
                                                                </aura:if>
                                                            </aura:if>
                                                        </ul>
                                                    </div>
                                                </div>
                                                <!-- tab 1 -->
                                                <div class="tab-content">
                                                    <div class="{!(v.MRPSTab)?'slds-show':'slds-hide'}" id="home" role="tabpanel">
                                                        <div class="panel-body MOs_class22" >
                                                            <div class="row slds-m-top--small MOs_class16" >
                                                                <div class="col-md-12">
                                                                    <aura:if isTrue="{!v.linksNewOptions}">
                                                                        
                                                                        <div class="MOs_class30 slds-p-right_small">
                                                                            <a href="javascript:void(0)" data-toggle="modal" data-target="#myModal9" onclick="{!c.NewMRP}" title="Add MRP" class="slds-button slds-button_neutral">
                                                                                <i class="fa fa-plus"></i>&nbsp;{!$Label.c.New_AddTimeCardEntry}  
                                                                            </a> 
                                                                        </div>
                                                                        
                                                                    </aura:if> 
                                                                    <div class="dropdown float-end">
                                                                        <aura:if isTrue="{!v.showSAButton}">                                                                         
                                                                            <aura:if isTrue="{!v.MRPs.length > 0}"> 
                                                                                <i class="fa fa-refresh float-end refreshClass" aura:id="rot"  aria-hidden="true" onclick="{!c.Reload}"></i>
                                                                                <div class="maqdropdown">  
                                                                                    <a class="slds-button slds-button_brand dropdown-toggle text-white" href="javascript:void(0)"> 
                                                                                        <i class="fa fa-calculator" aria-hidden="true"></i> &nbsp; {!$Label.c.Stock_Allocation} <!--<span class="caret"></span>-->
                                                                                    </a>
                                                                                    <div class="maqdropdown-content">
                                                                                        <ul>
                                                                                             <!--aura:if isTrue="{!and(v.manuOrder.ERP7__Product__r.ERP7__Serialise__c, v.manuOrder.ERP7__Quantity__c &lt;= 2)}">
                                                                                                <div class="slds-m-bottom_small">
                                                                                                    <lightning:button label="Allocate All" 
                                                                                                                      variant="brand" 
                                                                                                                      onclick="{!c.allocateAllMRPs}" 
                                                                                                                      title="Allocate stock to all unallocated MRPs (batched for large BOMs)"/>
                                                                                                </div>
                                                                                            </aura:if-->
                                                                                            <aura:if isTrue="{!v.showAutoStockAllocation}">
                                                                                                <aura:if isTrue="{!v.ReserveStock}">
                                                                                                    <li class="myli"> 
                                                                                                        <a href="javascript:void(0)" target="_blank" aria-haspopup="true" data-toggle="modal" data-target="#myModalSelectWOs" onclick="{!c.AutoStockAllocationInitial}" class="MOs_class25"> 
                                                                                                            {!$Label.c.Auto_Stock_Allocation}
                                                                                                        </a> 
                                                                                                    </li>                                                                  
                                                                                                </aura:if> 
                                                                                            </aura:if>
                                                                                            <aura:if isTrue="{!v.showManualStockAllocation}">
                                                                                                <li class="myli"> <a href="" target="_blank" aria-haspopup="true" data-toggle="dropdown" onclick="{!c.SelectMRP1}" class="MOs_class25"> 
                                                                                                    {!$Label.c.Manual_Stock_Allocation} 
                                                                                                    </a> 
                                                                                                </li>
                                                                                            </aura:if>
                                                                                            <aura:if isTrue="{!v.showRequisition}">
                                                                                                <li class="myli"> <a href="" target="_blank" aria-haspopup="true" data-toggle="dropdown" onclick="{!c.CreatePurchaseRequisition}" class="MOs_class25"> 
                                                                                                    {!$Label.c.Create_Purchase_Requisition}
                                                                                                    </a> </li>
                                                                                            </aura:if>
                                                                                            <li class="myli"> <a href="" target="_blank" aria-haspopup="true" data-toggle="dropdown" onclick="{!c.CreatePurchaseOrder}" class="MOs_class25"> 
