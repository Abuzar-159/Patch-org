                                                                <div class="slds-form-element__control"> {!do.Stock} </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </aura:iteration>
                                        </table>
                                    </div>
                                </aura:if>
                            </div>
