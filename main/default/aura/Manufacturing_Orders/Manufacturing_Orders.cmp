                                                                                    <td data-label="Quantity" valign="middle" class="MOs_class29">
                                                                                        <div class="slds-form-element">
                                                                                            <div class="slds-form-element__control"> 
                                                                                                <lightning:formattedNumber value="{!soli.ERP7__Quantity__c*bo.WeightMultiplier}"     minimumFractionDigits="6"    maximumFractionDigits="6"/>&nbsp;{!bo.SelectedUOM} <!--{!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure}-->
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </aura:iteration>
                                                                    </table>
                                                                    <!-- Add this after the closing </table> tag and before the closing </div> of the card -->
<div class="slds-grid slds-align_absolute-center slds-m-top_small">
    <div class="slds-col slds-size_1-of-1 slds-text-align_center">
        <!-- Previous Button -->
        <lightning:button 
            name="{!i}" 
            value="prev" 
            onclick="{!c.changePage}" 
            variant="neutral"
            iconName="utility:left" 
            iconPosition="left"
            disabled="{!bo.currentPage == 1}"
            class="slds-m-right_x-small"
            title="Previous Page" />
        
        <!-- Page Numbers -->
        <aura:iteration items="{!bo.displayPages}" var="pageNum">
            <lightning:button 
                name="{!i}" 
                value="{!pageNum}" 
                onclick="{!c.goToPage}" 
                variant="{!if(pageNum == bo.currentPage, 'brand', 'neutral')}"
                label="{!pageNum}"
                class="slds-m-horizontal_xxx-small"
                title="{!'Go to page ' + pageNum}" />
        </aura:iteration>
        
        <!-- Next Button -->
        <lightning:button 
            name="{!i}" 
            value="next" 
            onclick="{!c.changePage}" 
            variant="neutral"
            iconName="utility:right" 
            iconPosition="right"
            disabled="{!bo.currentPage == bo.totalPages}"
            class="slds-m-left_x-small"
            title="Next Page" />
        
        <!-- Page Info -->
        <span class="slds-m-left_medium slds-text-body_small">
            {!bo.pageInfo}
        </span>
    </div>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </article>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-9 slds-m-top--small slds-hide">
                                                
                                                <article class="card mb-0">
                                                    <div class="card-body">
                                                        <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                            <div class="row">
                                                                <div class="col-md-8">
                                                                    <div class="slds-grid">
                                                                        <div class="col-md-8 MOs_class19">   
                                                                            <div class="slds-media__body slds-text-align--center">
                                                                                <h2 class="slds-text-heading_small digitalregular MOs_class75">
                                                                                    <input type="text" id="WeightStr" class="digitalregular slds-text-align--center MOs_class76" value="{!v.WeightStr}"/>
                                                                                    <lightning:input type="number" step="0.00" class="digitalregular slds-text-align--center invisi" value="{!v.Weight}" /> </h2>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-md-4 MOs_class74">   
                                                                            <!-- <span class="slds-text-heading_xx-small"><strong>UOM </strong></span> -->
                                                                            <div class="slds-m-top--x-small">
                                                                                <lightning:select   label="{!$Label.c.UOM}" aura:id="UOMS" value="{!bo.SelectedUOM}"  onchange="{!c.UOMChange}"><!-- change="{!c.UOMChange}" disabled="{!if(v.UOMS.length > 1,false,true)}" -->
                                                                                    <aura:iteration items="{!bo.UOMS}" var="UO" indexVar="z">
                                                                                        <option text="{!UO.label}" value="{!UO.value}" selected="{!UO.selected}"/>
                                                                                    </aura:iteration>
                                                                                </lightning:select>
                                                                            </div>
                                                                        </div>
                                                                        
                                                                    </div>
                                                                    
                                                                    <!-- <aura:if isTrue="{!(and(v.WCAP,and(bo.MRP.ERP7__Maximum_Variance__c > 0, (bo.MRP.ERP7__Maximum_Variance__c + bo.MRP.ERP7__Expected_Quantity__c) &gt; bo.ActualWeight)))}">--><!-- || and(!(bo.MRP.ERP7__Maximum_Variance__c > 0), bo.MRP.ERP7__Expected_Quantity__c > bo.ActualWeight)-->
                                                                    <aura:if isTrue="{!(and(v.WCAP,bo.MRP.ERP7__Maximum_Variance__c > 0, (bo.MRP.ERP7__Maximum_Variance__c + bo.MRP.ERP7__Expected_Quantity__c) > bo.ActualWeight) || and(!(bo.MRP.ERP7__Maximum_Variance__c > 0), bo.MRP.ERP7__Expected_Quantity__c > bo.ActualWeight))}">
                                                                        <aura:if isTrue="{!(bo.Stock * bo.WeightMultiplier > 0)}">
                                                                            
                                                                            <button class="slds-button slds-button--brand MOs_class76" onclick="{!c.CaptureWeight}">{!$Label.c.Capture}</button>
                                                                            <aura:set attribute="else"> <button class="slds-button branddisabled MOs_class76" disabled="">{!$Label.c.Capture}</button> </aura:set>
                                                                        </aura:if>
                                                                    </aura:if>
                                                                </div>
                                                                <div class="col-md-4 slds-m-top--small MOs_class77">
                                                                    <aura:if isTrue="{!and(!bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c, !bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}"> 
                                                                        <span class="slds-text-heading_xx-small"><strong>{!$Label.c.Batch_Serial} </strong></span> <br/>
                                                                        <div class="slds-m-top--x-small">
                                                                            <input class="slds-input" disabled="true"></input>
                                                                        </div>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!(bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}"> <span class="slds-text-heading_xx-small">
                                                                        <strong>Serial </strong><span class="MOs_class17">*</span></span> <br/>
                                                                        <div class="slds-m-top--x-small" onmouseover="{!c.lookupClickSerial}">
                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisni" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Serial__c}"
                                                                                                 inputStyleclass="slds-input" qry="{!v.qry}" />
                                                                        </div>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!and(!bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c,bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}"> <span class="slds-text-heading_xx-small"> 
                                                                        <strong>Batch</strong><span class="MOs_class17">*</span></span> <br/>
                                                                        <div class="slds-m-top--x-small" onmouseover="{!c.lookupClickBatch}">
                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solibti" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Material_Batch_Lot__c}"
                                                                                                 inputStyleclass="slds-input" qry="{!v.qry}" />
                                                                        </div>
                                                                        
                                                                    </aura:if> 
                                                                    <img id="weightspins" src="/resource/ERP7__SLDS0121/assets/images/spinners/slds_spinner_brand.gif" class="MOs_class2"/> 
                                                                </div>
                                                            </div>
                                                        </header>
                                                    </div>
                                                </article>
                                                <div class="row ">
                                                    <div class="col-md-12 slds-p-top--xx-small ">
                                                        <article class="{!if(bo.isSelect,'slds-card','slds-card')}" data-mrpcount="{!i}" > <!-- onclick="{!c.SelectMRP}" -->
                                                            <div class="slds-card__header slds-grid" >
                                                                <header class="slds-media slds-media_center slds-has-flexi-truncate fadeIn delay-three">
                                                                    <div class="slds-media__bod slds-col MOs_class78">
                                                                        <h2 class="slds-card__header-title"> <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" title="Accounts" >
                                                                            <span class="slds-text-heading_small">
                                                                                <div class="slds-truncate MOs_class48" title="{!bo.MRP.ERP7__MRP_Product__c}" aura:id="{!bo.MRP.ERP7__MRP_Product__c}"  onclick="{!c.NavRecord}">
                                                                                    {!bo.MRP.ERP7__MRP_Product__r.Name}
                                                                                    
                                                                                </div>
                                                                            </span>
                                                                            </a> </h2>
                                                                    </div>
                                                                </header>
                                                            </div>
                                                            <div class="slds-card__header slds-grid">
                                                                <div class="slds-col slds-align-middle  slds-p-bottom_xx-small">
                                                                    <div class="slds-m-right--x-small">
                                                                        <div class="row MOs_class50" >
                                                                            <div class="col-xs-2 slds-text-heading_xx-small MOs_class7">
                                                                                <!--<aura:if isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Exact_Quantity__c)}"></aura:if>-->
                                                                                <strong>BOM :</strong> 
                                                                            </div>
                                                                            <div class="col-xs-9 slds-text-heading_xx-small slds-truncate1 MOs_class49">
                                                                                <lightning:formattedNumber value="{!bo.MRP.ERP7__BOM__r.ERP7__Quantity__c*bo.BOMWeightMultiplier}"/>&nbsp; 
                                                                                <aura:if isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Minimum_Variance__c > 0 || bo.MRP.ERP7__BOM__r.ERP7__Maximum_Variance__c > 0)}">
                                                                                    (<lightning:formattedNumber value="{!(bo.MRP.ERP7__BOM__r.ERP7__Quantity__c-bo.MRP.ERP7__BOM__r.ERP7__Minimum_Variance__c)*bo.BOMWeightMultiplier}"/>-<lightning:formattedNumber value="{!(bo.MRP.ERP7__BOM__r.ERP7__Quantity__c+bo.MRP.ERP7__BOM__r.ERP7__Maximum_Variance__c)*bo.BOMWeightMultiplier}"/>)
                                                                                </aura:if>
                                                                                {!bo.SelectedUOM} <!--{!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure}-->
                                                                            </div>
                                                                        </div>
                                                                        <div class="row MOs_class50">
                                                                            <div class="col-xs-2 slds-text-heading_xx-small MOs_class7"> 
                                                                                <strong>Actual :</strong></div>
                                                                            <div class="col-xs-9 slds-truncate1 MOs_class49">
                                                                                <lightning:formattedNumber value="{!bo.MRP.ERP7__Total_Amount_Required__c*bo.BOMWeightMultiplier}"/>&nbsp;
                                                                                <aura:if isTrue="{!(bo.MRP.ERP7__Minimum_Variance__c > 0 || bo.MRP.ERP7__Maximum_Variance__c > 0)}">
                                                                                    (<lightning:formattedNumber value="{!(bo.MRP.ERP7__Total_Amount_Required__c-bo.MRP.ERP7__Minimum_Variance__c)*bo.BOMWeightMultiplier}"/>-<lightning:formattedNumber value="{!(bo.MRP.ERP7__Total_Amount_Required__c+bo.MRP.ERP7__Maximum_Variance__c)*bo.BOMWeightMultiplier}"/>)
                                                                                </aura:if>
                                                                                {!bo.SelectedUOM} <!--{!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure}-->
                                                                            </div>
                                                                            
                                                                        </div>
                                                                        <div class="row MOs_class50">
                                                                            <div class="col-xs-2 slds-text-heading_xx-small MOs_class7">
                                                                                <strong>{!$Label.c.Added} :</strong>
                                                                            </div>  
                                                                            <div class="col-xs-9 slds-truncate1 MOs_class49">
                                                                                <lightning:formattedNumber value="{!bo.ActualWeight*bo.WeightMultiplier}"/>&nbsp;
                                                                                {!bo.SelectedUOM} <!--{!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure}-->
                                                                            </div>
                                                                            
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                
                                                            </div>
                                                            <div class="slds-card__body slds-card__body_inner MOs_class51" >
                                                                <div id="cardTransition" class="row">
                                                                    <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                                        <thead>
                                                                            <tr class="slds-text-title--caps">
                                                                                <th class="slds-is-sortable " scope="col" height="30px">
                                                                                    <div class="slds-truncate"> Action </div>
                                                                                </th>
