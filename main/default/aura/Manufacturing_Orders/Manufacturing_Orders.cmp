                                                                                            <aura:if isTrue="{!and(v.allowMRPDelete,v.manuOrder.ERP7__Status__c != 'Complete')}">
                                                                                                <lightning:button onclick="{!c.deleteAllMRPs}" variant="destructive" label="Delete all" title="Delete all" class="width85-mo" />
                                                                                                <!--<span class="slds-truncate slds-p-top_small" title="Delete">&nbsp; <a onclick="{!c.deleteAllMRPs}" title="Delete"> <i class="fa fa-trash cl9-delete" aria-hidden="true"></i>&nbsp;Delete</a></span>-->
                                                                                            </aura:if>
