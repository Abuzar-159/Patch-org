                                                                                                    <div class="slds-truncate2"><!--{!bo.MRP.ERP7__BOM_unit_Price__c} ERP7__BOM__r.ERP7__Cost_Price__c} -->     {!bo.MRP.ERP7__BOM_unit_Price__c != null ? bo.MRP.ERP7__BOM_unit_Price__c : 0}
</div>
                                                                                                </div>
