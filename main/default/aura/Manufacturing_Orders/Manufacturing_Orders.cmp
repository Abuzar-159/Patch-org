                                                            <aura:if isTrue="{!!v.isEditable}">
                                                                <aura:if isTrue="{!v.linksNewOptions}">
                                                                    <lightning:formattedUrl value="{!'/'+v.Version.Id}" label="{!v.Version.Name}" target="_blank" class="fcolor"/>
                                                                </aura:if>
