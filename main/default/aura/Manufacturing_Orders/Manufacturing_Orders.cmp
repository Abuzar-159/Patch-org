                                                        </article>
                                                    </div>
                                                </div>
                                            </div>
                                        </aura:if>
                                    </aura:iteration>
                                </div>
                                
                            </div>
                            <div class="slds-docked-form-footer" > 
                                <button class="slds-button slds-button--neutral" onclick="{!c.closeStockAllocationModal}">{!$Label.c.SA_page_back}</button>	
                                <!-- <button class="slds-button slds-button-bbrand" onclick="{!c.upsertWeights}">Save</button> -->
                                
                                
                                <button class="slds-button slds-button_neutral MOs_class52">
                                    <a href="{!'/apex/ERP7__MOrderLabel?MId='+ v.manuOrder.Id+'&amp;ra=pdf'}" target="_blank" > 
                                        <i class="fa fa-print print-icon1" aria-hidden="true" ></i>
                                    </a>
                                </button>
                                <aura:If isTrue="{!(v.PrintSB)}"> 
                                    
                                    <aura:if isTrue="{!and(v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != '', v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c != undefined)}">
                                        <button class="slds-button slds-button_neutral MOs_class52">
                                            <a href="{!'/apex/ERP7__MOLabel1?RId='+v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c+'&amp;ra=pdf'}" target="_blank" > 
                                                <i class="fa fa-print print-icon1" aria-hidden="true" ></i>   
                                            </a>
                                        </button>
                                    </aura:if>
                                    <aura:if isTrue="{!and(v.NewSOLI.ERP7__MO_WO_Serial__c != '', v.NewSOLI.ERP7__MO_WO_Serial__c != undefined)}">
                                        <button class="slds-button slds-button_neutral MOs_class52">
                                            <a href="{!'/apex/ERP7__MOLabel1?RId='+ v.NewSOLI.ERP7__MO_WO_Serial__c+'&amp;ra=pdf'}" target="_blank" > 
                                                <i class="fa fa-print print-icon1" aria-hidden="true"></i>
                                            </a>
                                        </button>
                                    </aura:if> 	
