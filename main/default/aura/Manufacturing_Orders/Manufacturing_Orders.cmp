                                                                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="MOs_class36" />  
                                                                                                                </a>
                                                                                                            </lightning:button>
                                                                                                            <!--lightning:icon alternativeText="{!$Label.c.Delete_UserAvailabilities}" onclick='{!c.deleteMRPs}' iconName="action:delete"  variant="destructive" title="{!bo.MRP.Id}" size="small"/-->   
                                                                                                        </aura:if>
                                                                                                        
                                                                                                        <lightning:button onclick="{!c.EditMRP}" class="neutralC" name="{!i}"> 
