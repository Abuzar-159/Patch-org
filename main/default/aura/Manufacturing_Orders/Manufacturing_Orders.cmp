                </aura:if>
                
                <!-- popup starts here *-->
                <div id="myModale" aura:id="editMRPModal" class="slds-modal fade" role="dialog">
                    <div class="modal-dialog modal-medium">
                        <!-- Modal content-->
                        <div class="modal-content">
                            
                            <div class="modal-body MOs_class54">
                                <h2 class=" slds-m-right-small slds-align-middle MOs_class10" title="" >{!v.editErrorMsg}</h2>
                                <div class="row slds-m-top--xx-small">
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                        <div class="slds-form-element"> 
                                            <div class="slds-form-element__control">
                                                <lightning:input type="Text"  label="{!$Label.c.AddSubscription_Product}" value="{!v.MRPEdit.MRP.ERP7__MRP_Product__r.Name}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                        <div class="slds-form-element"> 
                                            <div class="slds-form-element__control">
                                                <lightning:input type="number" label="{!$Label.c.QuotationPDF_Quantity}" step="0.000001" value="{!v.MRPEdit.MRP.ERP7__Total_Amount_Required__c}" disabled="{!v.MRPEdit.MRP.ERP7__BOM__r.ERP7__Is_Protected__c}"></lightning:input>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                        <div class="slds-form-element"> 
                                            <div class="slds-form-element__control">
                                                <lightning:input type="Text"  label="{!$Label.c.Stock}" value="{!v.MRPEdit.Stock}"  readonly="true"/>
                                                
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <aura:if isTrue="{!v.NewMRPs.MRPs.length > 0}">
                                    <div class="row MOs_class55">
                                        <div class="col-md-12">
                                            <h1 class="MOs_class56">{!$Label.c.BOM_Variances}</h1>
                                        </div>
                                    </div>
                                    <div class="MOs_class57">
                                        <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-m-top--small">
                                            <thead>
                                                <tr class="slds-text-title--caps">
                                                    <th class="slds-is-sortable " scope="col">
                                                        <div class="slds-truncate"> {!$Label.c.NewCase_Action} </div>
                                                    </th>
                                                    <th class="slds-is-sortable " scope="col">
                                                        <div class="slds-truncate"> {!$Label.c.AddSubscription_Product} </div>
                                                    </th>
                                                    <th class="slds-is-sortable" scope="col">
                                                        <div class="slds-truncate"> {!$Label.c.Qty_Pick} </div>
                                                    </th>
                                                    <th class="slds-is-sortable" scope="col">
                                                        <div class="slds-truncate"> {!$Label.c.Stock} </div>
                                                    </th>
                                                </tr>
                                            </thead>
                                            <aura:iteration items="{!v.NewMRPs.MRPs}" var="do" indexVar="y">
                                                <tbody>
                                                    <tr class="slds-hint-parent">
                                                        <th class="slds-is-sortable MOs_class29" scope="col">
