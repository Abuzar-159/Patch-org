                                                                        <aura:if isTrue="{!and(!v.isEditable,v.manuOrder.ERP7__Sales_Order_Line_Item__c != null)}">
                                                                            <aura:if isTrue="{!v.linksNewOptions}">
                                                                                <lightning:formattedUrl value="{!'/'+v.manuOrder.ERP7__Sales_Order_Line_Item__c}" label="{!v.manuOrder.ERP7__Sales_Order_Line_Item__r.Name}" target="_blank" class="fcolor"/>
                                                                            </aura:if>
