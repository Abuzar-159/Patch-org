                                                    <div class="slds-truncate2">
                                                        {!package.ERP7__Length__c}  
                                                    </div>
                                                </td>
                                                <td class="greyheadlabel">
                                                    <div class="slds-truncate2">
                                                        {!package.ERP7__Width__c} 
                                                    </div>
