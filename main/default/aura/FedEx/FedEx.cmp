                            </aura:if>
                            <aura:if isTrue="{!and(v.errorMsg1 != undefined, v.errorMsg1 != '')}">
                                <div class="row fedex-class8"> <lightning:formattedText value="{!v.errorMsg1}" class="colorErrorMsg"/> </div>                                                    
                            </aura:if>
