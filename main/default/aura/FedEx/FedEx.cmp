                                        <lightning:formattedText value="{!v.addresserrmsg}" class="colorErrorMsg"/> &nbsp;
                                    </a>
                                </div>                                                    
                            </aura:if>
                            <aura:if isTrue="{!and(v.errorMsg != undefined, v.errorMsg != '')}"> 
