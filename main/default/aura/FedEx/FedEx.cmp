                                        <c:CustomInputLookUp objectAPIName="ERP7__Address__c" aura:id="bilAdd" IconName="standard:address" selectedRecordId="{!v.shipment.ERP7__Billing_Address__c}"  hideRemove="{!v.showeditBillDetails}" disabled="{!v.showeditBillDetails}"/>
                                    </div>
                                </div>
