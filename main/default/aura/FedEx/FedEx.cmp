<aura:component controller="Fedex" implements="force:appHostable">
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css, /resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css,
                          /resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/Fedex.css"/>
    <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:attribute name="ShowInvoice" type="boolean" default="false"/>
    <aura:attribute name="showeditBillDetails" type="boolean" default="false"/>
    <aura:attribute name="SuggestedAddress" type="String"/>
    <aura:attribute name="displayModal" type="boolean" default="false"/>
    <aura:attribute name="ShowTimeInCostTab" type="boolean" default="false"/>
    <aura:attribute name="ShowGetRate" type="boolean" default="true"/>
    <aura:attribute name="selectedTab" type="String" default="SHIPPING_SERVICES"/>
    <aura:attribute name="signatureservice" type="List"/>
    <aura:attribute name="statusconfirmation" type="List"/>
    <aura:attribute name="packageId" type="List"/>
    <aura:attribute name="shipmentId" type="String"/>
    <aura:attribute name="address" type="Object"/> 
    <aura:attribute name="fromAddress" type="Object"/> 
    <aura:attribute name="myConsW" type="Object"/> 
    <aura:attribute name="packageList" type="List"/> 
    <aura:attribute name="packageLists" type="List"/>
    <aura:attribute name="recordIdMap" type="Map"/>
    <aura:attribute name="Spinner" type="boolean" default="false"/>
    <aura:attribute name="ShiptoContact" type="object"/>
    <!--aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/-->
    <aura:attribute name="shipment" type="Shipment__c" default="{ 'sobjectType': 'Shipment__c', 'ERP7__Terms_Of_Shipment__c': '--None--', 'ERP7__Reason_For_Export__c':'SAMPLE', 'ERP7__Signature_Services__c':'SERVICE_DEFAULT', 'ERP7__Status__c':''}"/>
    <aura:attribute name="fedexCred" type="Object"/>
    <aura:attribute name="FEDEX_Services" type="Object" />
    <aura:attribute name="result" type="String"/>
    <aura:attribute name="retValue" type="String" default=""/>
    <aura:attribute name="errorMsg" type="String"/>
    <aura:attribute name="WrapperMsg" type="String"/>
    <aura:attribute name="errorMsg1" type="String"/>
    <aura:attribute name="trackWrapperList" type="Object"/>
    <aura:attribute name="toShipmentType" type="Boolean" default="false"/>
    <aura:attribute name="fromShipmentType" type="Boolean" default="false"/>
    <aura:attribute name="spodLetter" type="Attachment" default="{'sObjectType':'Attachment'}"/>
    <aura:attribute name="bufferlbl" type="Attachment" default="{'sObjectType':'Attachment'}"/>
    <aura:attribute name="attUrl" type="String"/> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <!-- <aura:handler name="change" value="{!v.address.Id}" action="{!c.toadresschange}"/>
    <aura:handler name="change" value="{!v.fromAddress.Id}" action="{!c.fromAddresschange}"/> -->
    <aura:attribute name="statusconfirmationOptions" type="List"/>
    <aura:attribute name="signatureserviceOptions" type="List"/>
    <aura:attribute name="specialServicesFedex" type="List"/>
    
    <aura:attribute name="reasonforexportOptions" type="List"/>
    <aura:attribute name="termsofshipmentOptions" type="List"/>
    <aura:attribute name="billingOptions" type="List"/>
    <aura:attribute name="isforRMA" type="Boolean" default="false"/>
    <aura:attribute name="showSendReturnLabel" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="boolean" default="false"/>
    <aura:attribute name="exceptionError" type="String" default=""/>
    <aura:attribute name="redirectURL" type="String" default=""/>
    <aura:attribute name="addresserrmsg" type="String" default=""/>
    <aura:attribute name="returnshipment" type="Shipment__c" default="{ 'sobjectType': 'Shipment__c','ERP7__Billing_Account_Number__c':'','ERP7__Billing_Postal_Code__c':'','ERP7__Billing_Country_Code__c':'','ERP7__Shipment_Billing_options__c':'','ERP7__Billing_Contact__c':'','ERP7__Billing_Address__c':''}"/>
    <aura:attribute name="returnshipmentdate" type="date" default=""/>
    <aura:attribute name="showreturnmodal" type="boolean" default="false"/>
    <aura:attribute name="allowReturnShipment" type="boolean" default="false"/>
    
    <aura:attribute name="allowUPSReturnShipmentFromFedEx" type="boolean" default="false"/>
    <aura:attribute name="selectedTabRS" type="String" default="FedEx"/>
    <aura:attribute name="UPS_Services" type="Object" />
    <aura:attribute name="UpsmyConsW" type="Object"/> 
    <aura:attribute name="disableEditBillOptReturnShipment" type="boolean" default="false"/>
    <aura:attribute name="selectedLogisticReturnShipType" type="String" default=""/>
    
    <body id="mybody">
        <div class="erp_mark7" aura:id="sldshide" >
            <aura:if isTrue="{!not(empty(v.exceptionError))}">
                <div class="slds-notify_container slds-is-absolute top15" >
                    <div class="slds-notify slds-notify_toast slds-theme_error" role="status" >
                        <span class="slds-assistive-text">{!$Label.c.error}</span>
                        <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                            <lightning:icon iconName="utility:error" variant="inverse" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" size="x-small"/>
                        </span>
                        <div class="slds-notify__content">
                            <p class="slds-text-heading_x-small mb-0">
                                <lightning:formattedText value="{!v.exceptionError}"/>
                            </p>
                        </div>
                        <div class="slds-notify__close" >
                            <a onclick="{!c.closeError}" class="textdeccolor">
                                <lightning:icon iconName="utility:close" variant="inverse" alternativeText="close!" title="Close" size="x-small"/>
                            </a>
                        </div>
                    </div>
                </div>
            </aura:if>
            
            <aura:if isTrue="{!v.isLoading}">
                <lightning:spinner variant="brand" size="small" aura:id="spinner" />
            </aura:if>
            
            <div class="slds-page-header">
                <div class="slds-media">
                    <div class="slds-media__figure">
                        <span class="slds-icon_container slds-icon-standard-" title="">
                            <span class="slds-icon slds-page-header__icon" aria-hidden="true">
                                <img src="/resource/ERP7__PickPackShipResource/assets/images/logo-header-fedex-gb.png" width="92" height="40" alt="Fedex"  class="fedex-class1"/> 
                            </span>
                        </span>
                    </div>
                    <div class="slds-media__body">
                        <h1 class="slds-page-header__title slds-truncate slds-align-middle" title=""></h1>
                        <p class="slds-text-body_small slds-line-height_reset"></p>
                    </div>
                    <aura:if isTrue="{!if(or(or(v.shipment.Id == null,v.shipment.Id == undefined),v.shipment.Id == ''), true,false)}">
                        <div>
                            <lightning:button label="{!$Label.c.Validate_Address}" onclick="{!c.callOnAddressAPI}"></lightning:button>
                        </div>
                        <!--aura:set attribute="else">
                            <aura:if isTrue="{!v.allowReturnShipment}">
                                <aura:if isTrue="{!if(or(or(v.returnshipment.Id == null,v.returnshipment.Id == undefined),v.returnshipment.Id == ''), true,false)}">
                                    <div>
                                        <lightning:button label="{!$Label.c.GenerateReturnShipment}" onclick="{!c.getreturnshipmentrates}"></lightning:button>
                                    </div>
                                </aura:if>
                            </aura:if>
                        </aura:set-->
                    </aura:if>
                </div>
            </div>
            
            <div class="epr_Mark7">
                <div class="row fedex-class2">  
                    <div class="col-md-6 slds-m-top--small">
                        <div>
                            <div class="slds-page-header slds-m-top--xx-small fedex-class3" onclick="{!c.sectionOne}">
                                <section class="slds-clearfix">
                                    <div class="slds-float--left ">
                                        <lightning:icon class="slds-hide" aura:id="articleOne" iconName="utility:right" size="x-small"/>
                                        <lightning:icon class="slds-show" aura:id="articleOne" iconName="utility:up" size="x-small" />
                                    </div>
                                    
                                    <div class="slds-m-left--large" >{!$Label.c.X1_Where_is_this_shipment_going}</div>
                                </section>
                            </div>
                            
                            <div aura:id="articleOne">
                                <div class="epr_Mark7 fedex-class4">
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <label class="slds-form-element__label"> {!$Label.c.To_Address}:</label> 
                                                <c:CustomInputLookUp objectAPIName="ERP7__Address__c" label="" IconName="standard:address" selectedRecordId="{!v.address.Id}" hideRemove="true"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.address.ERP7__Contact__r.ERP7__Company__c !=null,v.address.ERP7__Contact__r.ERP7__Company__c !='')}">
                                                    <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.address.ERP7__Contact__r.ERP7__Company__c}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.address.ERP7__Customer__r.ERP7__Company__c}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </div> 
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.ShiptoContact != null,v.ShiptoContact != '')}">
                                                    <lightning:input type="text" label="{!$Label.c.ContractConsole_Contact}" value="{!v.ShiptoContact.Name}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="text" label="{!$Label.c.ContractConsole_Contact}" value="{!v.address.ERP7__Contact__r.Name}"/>
                                                    </aura:set>
                                                </aura:if>
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.address.ERP7__Contact__r.Email !=null,v.address.ERP7__Contact__r.Email !='')}">
                                                    <lightning:input type="email" label="Email" value="{!v.address.ERP7__Contact__r.Email}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="email" label="Email" value="{!v.address.ERP7__Customer__r.ERP7__Email__c}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.address.ERP7__Contact__r.Phone !=null,v.address.ERP7__Contact__r.Phone !='')}">
                                                    <lightning:input type="tel" label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.address.ERP7__Contact__r.Phone}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="tel" label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.address.ERP7__Customer__r.Phone}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Address_line_1}" value="{!v.address.ERP7__Address_Line1__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Address_line_2}" value="{!v.address.ERP7__Address_Line2__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.City_town}" value="{!v.address.ERP7__City__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.State_country}" value="{!v.address.ERP7__State__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Zip_post_code}" value="{!v.address.ERP7__Postal_Code__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Cash_Payment_Country}" value="{!v.address.ERP7__Country__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="checkbox" label="{!$Label.c.Is_Residential}" variant="label-hidden" class="display-lable" checked="{!v.toShipmentType}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="slds-page-header Message slds-m-top--xx-small fedex-class3" onclick="{!c.sectionTwo}">
                                <section class="slds-clearfix">
                                    <div class="slds-float--left ">
                                        <lightning:icon class="slds-show" aura:id="articleTwo" iconName="utility:up" size="x-small"/>
                                        <lightning:icon class="slds-hide" aura:id="articleTwo" iconName="utility:right" size="x-small" />
                                    </div>
                                    <div class="slds-m-left--large" >2.{!$Label.c.Where_is_this_shipment_coming_from}</div>
                                </section>
                            </div>
                            <div class="slds-show" aura:id="articleTwo">
                                <div class="epr_Mark7 fedex-class4">
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <label class="slds-form-element__label">{!$Label.c.From_Address}</label>
                                                <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" label="" selectedRecordId="{!v.fromAddress.Id}" hideRemove="true"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.fromAddress.ERP7__Contact__r.ERP7__Company__c !=null,v.fromAddress.ERP7__Contact__r.ERP7__Company__c !='')}">
                                                    <lightning:input type="tel" label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress.ERP7__Contact__r.ERP7__Company__c}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="tel" label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress.ERP7__Customer__r.ERP7__Company__c}"/>
                                                    </aura:set>
                                                </aura:if>
                                                <!--<lightning:input type="text" label="{!$Label.c.CompanyLabel}" value="{!v.fromAddress.ERP7__Contact__r.ERP7__Company__c}"/>-->
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.ContractConsole_Contact}" value="{!v.fromAddress.ERP7__Contact__r.Name}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.fromAddress.ERP7__Contact__r.Email !=null,v.fromAddress.ERP7__Contact__r.Email !='')}">
                                                    <lightning:input type="email" label="Email" value="{!v.fromAddress.ERP7__Contact__r.Email}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="email" label="Email" value="{!v.fromAddress.ERP7__Customer__r.ERP7__Email__c}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <aura:if isTrue="{!and(v.fromAddress.ERP7__Contact__r.Phone !=null,v.fromAddress.ERP7__Contact__r.Phone !='')}">
                                                    <lightning:input type="tes" label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.fromAddress.ERP7__Contact__r.Phone}"/>
                                                    <aura:set attribute="else">
                                                        <lightning:input type="tes" label="{!$Label.c.Phone_AddTimeCardEntry}" value="{!v.fromAddress.ERP7__Customer__r.Phone}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Address_line_1}" value="{!v.fromAddress.ERP7__Address_Line1__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Address_line_2}" value="{!v.fromAddress.ERP7__Address_Line2__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.City_town}" value="{!v.fromAddress.ERP7__City__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.State_country}" value="{!v.fromAddress.ERP7__State__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row slds-grid slds-m-around--small fedex-class5">
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Zip_post_code}" value="{!v.fromAddress.ERP7__Postal_Code__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="text" label="{!$Label.c.Cash_Payment_Country}" value="{!v.fromAddress.ERP7__Country__c}"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-xs-4">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <lightning:input type="checkbox" label="{!$Label.c.Is_Residential}" variant="label-hidden" class="display-lable" checked="{!v.fromShipmentType}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            
                            <div class="slds-page-header Message slds-m-top--xx-small fedex-class3" onclick="{!c.sectionThree}">
                                <section class="slds-clearfix">
                                    <div class="slds-float--left ">
                                        <lightning:icon class="slds-show" aura:id="articleThree" iconName="utility:up" size="x-small"/>
                                        <lightning:icon class="slds-hide" aura:id="articleThree" iconName="utility:right" size="x-small" />
                                    </div>
                                    <div class="slds-m-left--large" >3.{!$Label.c.What_are_you_shipping}</div>
                                </section>
                            </div>
                            
                            
                            <div class="slds-show" aura:id="articleThree">
                                <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <th scope="col"> <div class="slds-truncate2" title="{!$Label.c.Package}">{!$Label.c.Package}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Order">{!$Label.c.Order_RMA}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Weight">{!$Label.c.PackageSlip_List_Weight}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Length">{!$Label.c.ShipmentManagement_Package_Length}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Width">{!$Label.c.ShipmentManagement_Package_Width}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Height">{!$Label.c.Height_Pack}</div> </th>
                                            <th scope="col"> <div class="slds-truncate2" title="Declared Value">{!$Label.c.Pack_Declared_Value}</div> </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items="{!v.packageList}" var="package">				
                                            <tr class="slds-hint-parent">
                                                <td class="greyheadlabel">
                                                    <div class="slds-truncate2">
                                                        <lightning:formattedUrl label="{!package.Name}" value="{!'/'+package.Id}" target="_blank"/>
                                                    </div>
                                                </td>
                                                <td class="greyheadlabel">
                                                    <div class="slds-truncate2">
                                                        <aura:if isTrue="{!package.ERP7__Sales_Order__c!=null}">
                                                            <lightning:formattedUrl label="{!package.ERP7__Sales_Order__r.Name}" value="{!'/'+package.ERP7__Sales_Order__c}" target="_blank"/>
                                                        </aura:if>
                                                        <aura:if isTrue="{!package.ERP7__Transfer_Order__c!=null}">
                                                            <lightning:formattedUrl label="{!package.ERP7__Transfer_Order__r.Name}" value="{!'/'+package.ERP7__Transfer_Order__c}" target="_blank"/>
                                                        </aura:if>
                                                        <aura:if isTrue="{!package.ERP7__Order__c !=null}">
                                                            <aura:if isTrue="{!package.ERP7__Order__r.Name !=null}">
                                                                <lightning:formattedUrl label="{!package.ERP7__Order__r.Name}" value="{!'/'+package.ERP7__Order__c}" target="_blank"/>
                                                                <aura:set attribute="else">
                                                                    <lightning:formattedUrl label="{!package.ERP7__Order__r.OrderNumber}" value="{!'/'+package.ERP7__Order__c}" target="_blank"/>
                                                                </aura:set>
                                                            </aura:if>
                                                        </aura:if>
                                                        <aura:if isTrue="{!package.ERP7__Return_Merchandise_Authorisation__c != null}">
                                                            <aura:if isTrue="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__c !=null}">
                                                                <aura:if isTrue="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__r.Name !=null}">
                                                                    <lightning:formattedUrl label="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__r.Name}" value="{!'/'+package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__c}" target="_blank"/>
                                                                    <aura:set attribute="else">
                                                                        <lightning:formattedUrl label="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__r.OrderNumber}" value="{!'/'+package.ERP7__Return_Merchandise_Authorisation__r.ERP7__Order__c}" target="_blank"/>
                                                                    </aura:set>
                                                                </aura:if>
                                                            </aura:if>
                                                            <aura:if isTrue="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__SO__c!=null}">
                                                                <lightning:formattedUrl label="{!package.ERP7__Return_Merchandise_Authorisation__r.ERP7__SO__r.Name}" value="{!'/'+package.ERP7__Return_Merchandise_Authorisation__r.ERP7__SO__c}" target="_blank"/>
                                                            </aura:if>
                                                        </aura:if>
                                                    </div>
                                                </td> 
                                                <td class="greyheadlabel">
                                                    <div class="slds-truncate2">
                                                        {!package.ERP7__Weight__c}
                                                    </div>
                                                </td>
