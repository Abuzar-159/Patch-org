                            <div class="row">-->
                                <aura:if isTrue="{!and(v.allowReturnShipment,v.isforRMA == false)}">
                                    <aura:if isTrue="{!and(and(v.shipment.Id != undefined, v.shipment.Id != null),v.shipment.Id != '')}">
                                        <aura:if isTrue="{!if(or(or(v.returnshipment.Id == null,v.returnshipment.Id == undefined),v.returnshipment.Id == ''), true,false)}">
                                            <div class="col-xs-12 col-sm-4 col-md-4 slds-m-top--small fedex-class8"> 
                                                <lightning:button class="width100PL" label="{!$Label.c.GenerateReturnShipment}" onclick="{!c.getreturnshipmentrates}"></lightning:button>
                                            </div>
                                        </aura:if>
                                        <aura:if isTrue="{!and(and(v.returnshipment.Id != undefined, v.returnshipment.Id != null),v.returnshipment.Id != '')}">
                                            <div class="col-xs-12 col-sm-4 col-md-4 slds-m-top--small fedex-class8"> 
                                                <lightning:button variant="brand" class="width100PL fontcolorwhite"  onclick="{!c.CreateFedexReturnLabel}" label="{!$Label.c.View_Return_Label}"/>
                                            </div>
                                            <div class="col-xs-12 col-sm-4 col-md-4 slds-m-top--small fedex-class8"> 
