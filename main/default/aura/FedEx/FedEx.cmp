                                <div class="row">
                                    <div class="col-md-10 col-sm-2 col-xs-12 fedex-class9">
                                        <lightning:formattedText aura:id="UPSErrorMsg" value="{!v.WrapperMsg}"/>
                                    </div>
                                </div>
                            </aura:if>
                            
                            <aura:if isTrue="{!v.ShowTimeInCostTab}">
