                                                    <div class="slds-truncate2">
                                                        <lightning:input type="number" formatter="currency" step="0.01" value="{!package.ERP7__Declared_Value__c}"/>
                                                    </div>
                                                </td></tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div>
                            <div class="slds-page-header slds-m-top--xx-small fedex-class3" onclick="{!c.sectionFour}">
                                <section class="slds-clearfix">
