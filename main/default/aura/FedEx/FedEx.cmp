                                        <div class="col-xs-12 col-sm-4 col-md-4 slds-m-top--small fedex-class8"> 
                                            <lightning:button variant="brand" class="width100PL fontcolorwhite"  onclick="{!c.CreateInvoice}" label="{!$Label.c.View_Commercial_Invoice}"/>
                                        </div>
                                    </aura:if>
                                </aura:if>
                                
                                <aura:if isTrue="{!v.FEDEX_Services.showAndHideMap3}">
                                    <div class="col-xs-12 col-sm-4 col-md-4 slds-m-top--small fedex-class8"> 
                                        <lightning:button variant="neutral" class="width101" onclick="{!c.Cancel_Request}" label="{!$Label.c.UPS_Cancel_Shipment}"/>
                                    </div>
                                </aura:if>
