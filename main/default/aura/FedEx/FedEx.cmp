                                        <lightning:icon class="slds-show" aura:id="articleFour" iconName="utility:right" size="x-small"/>
                                        <lightning:icon class="slds-hide" aura:id="articleFour" iconName="utility:up" size="x-small" />
                                    </div>
                                    <div class="slds-m-left--large" >4.{!$Label.c.SupplierInvoice_Invoice_Details}</div>
                                </section>
