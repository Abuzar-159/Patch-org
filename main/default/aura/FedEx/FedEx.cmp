                                                <aura:iteration items="{!v.specialServicesFedex}" var="option">
                                                    <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.shipment.ERP7__Fedex_Special_Services__c, option.value)}"/>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>    
                                    </div>
                                </div>
                                
                            </div>
