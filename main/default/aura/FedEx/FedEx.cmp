                                            <a href="{!'/servlet/servlet.FileDownload?file='+v.bufferlbl.Id}" class="slds-button slds-button--neutral1"  target="_blank">Buffer Label</a>
                                            <aura:set attribute="else">
                                                <lightning:button variant="brand" class="width100PL fontcolorwhite"  onclick="{!c.CreateFedexLabel}" label="{!$Label.c.View_Label}"/>
                                                
                                            </aura:set>
                                        </aura:if>
                                        
                                    </div>
                                    <aura:if isTrue="{!and(v.showSendReturnLabel,v.isforRMA)}">
