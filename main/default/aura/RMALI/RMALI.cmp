<aura:component controller="RMA" implements="force:appHostable,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <aura:attribute name="min" type="Decimal" default="1.00"/>
    <aura:attribute name="errMsg" type="String" default=''/>
    <aura:attribute name="qty" type="Decimal"/>
    <aura:attribute name="max" type="Decimal"/>
           
    <td data-label="QTY">
        <div class="slds-truncate" title="">
            <lightning:input type="number" variant="label-hidden" aura:id="qty2ret" class="{!if(empty(v.errMsg),'','error')}" value="{!v.qty}"  required="true" onchange="{!c.validationCheck}"/>
        </div>
        <aura:if isTrue="{!not(empty(v.errMsg))}">
            <span class="has-error uiInputDefaultError uiInput uiInputText uiInput--default uiInput--input">
                {!v.errMsg}
            </span>
        </aura:if>
    </td>
</aura:component>