        <div class="editMSmodal" aura:id="allLeaveModals">
            <section aura:id="newTimeOffModal" role="dialog" tabindex="-1" class="slds-modal slds-modal_small" aria-labelledby="contactModalHeading" aria-modal="true" aria-describedby="contactModalBody1">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closeTimeOffModal}" variant="bare-inverse" size="large"/> 
                        <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate manageLeave-newClass43">Apply Leave</h2>
                    </header>
                    <div class="slds-grid slds-wrap manageLeave-newClass44">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <label class="slds-form-element__label" for="unique-id-of-input">{!$Label.c.Name_ManageLeave}<span class="manageLeave-newClass45">*</span></label>
                                <lightning:input type="Name" aura:id="newTimeOffName" variant="label-hidden" value="{!v.newTimeOff.Name}" placeholder="{!$Label.c.Enter_Name_ManageLeave}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <aura:if isTrue="{!v.resetLookups}">
                                       <c:CustomInputLookUp objectAPIName="User" label="{!$Label.c.Approver_ManageLeave}" IconName="standard:user" selectedRecordId="{!v.newTimeOff.ERP7__Approvers__c}" hideRemove="true"/><!--qry="{!'And Id != \''+v.currentEmployee+'\''}-->
                                    <aura:set attribute="else">
                                       <c:CustomInputLookUp objectAPIName="User" label="{!$Label.c.Approver_ManageLeave}" IconName="standard:user" selectedRecordId="{!v.newTimeOff.ERP7__Approvers__c}" /><!--qry="{!'And Id != \''+v.currentEmployee+'\''}"-->
                                    </aura:set>
                                </aura:if>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="Date" label="{!$Label.c.Start_Date_ManageLeave}" value="{!v.newTimeOff.ERP7__Leave_Start_Date__c}" onchange="{!c.leaveDateChange}" placeholder="{!$Label.c.Enter_Date_ManageLeave}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="Date" label="End Date" value="{!v.newTimeOff.ERP7__Leave_End_Date__c}" onchange="{!c.leaveDateChange}" placeholder="{!$Label.c.Enter_Date_ManageLeave}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:select value="{!v.newTimeOff.ERP7__Leave_Type__c}" label="Type">
                                    <option text="Choose one..." value=""/>
                                    <aura:iteration items="{!v.leaveTypes}" var="option">
                                        <option text="{!option.label}" value="{!option.value}"/>
                                    </aura:iteration>
                                </lightning:select>
                            </div> 
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="Number" min="1" label="{!$Label.c.Number_Of_Days_ManageLeave}" disabled="true" value="{!v.newTimeOff.ERP7__Number_of_Days__c}" placeholder="{!$Label.c.Time_Period_ManageLeave}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="Date" label="Applied Date" value="{!v.newTimeOff.ERP7__Applied_Date__c}" />
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <!--lightning:input label="{!$Label.c.Reason_ManageLeave}" value="{!v.Leavereason}" placeholder="{!$Label.c.Enter_Reason_ManageLeave}"/-->
                                <lightning:input aura:id="leaveReason2" label="{!$Label.c.Reason_ManageLeave}" value="{!v.newTimeOff.ERP7__Reason__c}" placeholder="{!$Label.c.Enter_Reason_ManageLeave}"/><!--inputRichText-->
                            </div>
                        </div>
                    </div>
                    <footer class="slds-modal__footer text-center">
                        <lightning:button  label="{!$Label.c.Cancel_ManageLeave}" onclick="{!c.closeTimeOffModal}" variant="neutral"/>
                        <lightning:button onclick="{!c.saveTimeOff}" label="Save As Draft" variant="brand"/>
                        <lightning:button onclick="{!c.submitTimeOff}" label="{!$Label.c.Submit_ManageLeave}" variant="Success"/>
                    </footer>
                </div>
            </section>
            <section aura:id="approveTimeOffModal" role="dialog" tabindex="-1" class="slds-modal">
                <div class="slds-modal__container">
                    <header class="slds-modal__header slds-modal__header_empty">
                        <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closeApproveModal}" variant="bare-inverse" size="large"/>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input aura:id="ReasonApproved" value="{!v.A_Rcomment}" variant="label-hidden" placeholder="{!$Label.c.Enter_Comment_ManageLeave}"/><!--inputRichText-->
                            </div>
                        </div>
                    </div>
                    <footer class="slds-modal__footer">
                        <lightning:button  label="{!$Label.c.Cancel_ManageLeave}" onclick="{!c.closeApproveModal}" variant="neutral"/>
                        <lightning:button onclick="{!c.ApproveLeave}" label="Approve" variant="Success"/>
                    </footer>
                </div>
            </section>
            <section aura:id="rejectTimeOffModal" role="dialog" tabindex="-1" class="slds-modal">
                <div class="slds-modal__container">
                    <header class="slds-modal__header slds-modal__header_empty">
                        <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closeRejectModal}" variant="bare-inverse" size="large"/>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input aura:id="ReasonRejected" value="{!v.A_Rcomment}" variant="label-hidden" placeholder="{!$Label.c.Enter_Comment_ManageLeave}"/><!--inputRichText-->
                            </div>
                        </div>
                    </div>
                    <footer class="slds-modal__footer">
                        <lightning:button  label="{!$Label.c.Cancel_ManageLeave}" onclick="{!c.closeRejectModal}" variant="neutral"/>
                        <lightning:button onclick="{!c.RejectLeave}" label="{!$Label.c.Reject_ManageLeave}" variant="destructive"/>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop" aura:id="newTimeOffModalBackdrop"></div>
        </div>

        <div class="editMSmodal" aura:id="allLeaveModals1">
            <section aura:id="viewAplliedRequest" role="dialog" tabindex="-1" class="slds-modal slds-modal_small" aria-labelledby="contactModalHeading" aria-modal="true" aria-describedby="contactModalBody1">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closePopupModal}" variant="bare-inverse" size="large"/> 
                        <aura:if isTrue="{!v.CurrentPopUp == 'Delete-Leaverequest'}">
                            <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate manageLeave-newClass43">Delete Leave Application
                               <!-- <lightning:formattedUrl value="{!'/' + v.newTimeOff.Id}"  target="_blank" class="fcolor1">Delete Leave Application </lightning:formattedUrl> -->
                            </h2>                            
                            <aura:set attribute="else">
                                <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate manageLeave-newClass43">Leave Application
                                  <!--  <lightning:formattedUrl value="{!'/' + v.newTimeOff.Id}"  target="_blank" class="fcolor1">Leave Application </lightning:formattedUrl> -->
                                </h2>
                            </aura:set>
                        </aura:if>
                    </header>
                    
                    <aura:if isTrue="{!v.CurrentPopUp == 'Delete-Leaverequest'}">
                        <div class="slds-modal__content slds-p-around_medium tcenter">
                                <p>Are you Sure to Delete this Leave Request?</p>
                                <!--lightning:icon iconName="action:delete" alternativeText="Clone Icon"/-->
                        </div>
                        <aura:set attribute="else">
                            <div class="slds-grid slds-wrap manageLeave-newClass44">
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <label class="slds-form-element__label" for="unique-id-of-input">{!$Label.c.Name_ManageLeave}<span class="manageLeave-newClass45">*</span></label>
                                        <lightning:input type="Name" aura:id="newTimeOffName" variant="label-hidden" value="{!v.newTimeOff.Name}" placeholder="{!$Label.c.Enter_Name_ManageLeave}"/>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <aura:if isTrue="{!v.resetLookups}">
                                               <c:CustomInputLookUp objectAPIName="User" label="{!$Label.c.Approver_ManageLeave}" IconName="standard:user" selectedRecordId="{!v.newTimeOff.ERP7__Approvers__c}" qry="{!'And Id != \''+v.currentEmployee+'\''}" hideRemove="true"/>
                                            <aura:set attribute="else">
                                               <c:CustomInputLookUp objectAPIName="User" label="{!$Label.c.Approver_ManageLeave}" IconName="standard:user" selectedRecordId="{!v.newTimeOff.ERP7__Approvers__c}" qry="{!'And Id != \''+v.currentEmployee+'\''}"/>
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="Date" label="{!$Label.c.Start_Date_ManageLeave}" value="{!v.newTimeOff.ERP7__Leave_Start_Date__c}" onchange="{!c.leaveDateChange}" placeholder="{!$Label.c.Enter_Date_ManageLeave}"/>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="Date" label="End Date" value="{!v.newTimeOff.ERP7__Leave_End_Date__c}" onchange="{!c.leaveDateChange}" placeholder="{!$Label.c.Enter_Date_ManageLeave}"/>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:select value="{!v.newTimeOff.ERP7__Leave_Type__c}" label="Type">
                                            <option text="Choose one..." value=""/>
                                            <aura:iteration items="{!v.leaveTypes}" var="option">
                                                <option text="{!option.label}" value="{!option.value}"/>
                                            </aura:iteration>
                                        </lightning:select>
                                    </div> 
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="Number" min="1" label="{!$Label.c.Number_Of_Days_ManageLeave}" disabled="true" value="{!v.newTimeOff.ERP7__Number_of_Days__c}" placeholder="{!$Label.c.Time_Period_ManageLeave}"/>
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input type="Date" label="Applied Date" value="{!v.newTimeOff.ERP7__Applied_Date__c}" />
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" label="Employee Requester" IconName="standard:user" selectedRecordId="{!v.newTimeOff.ERP7__Employee__c}" qry="{!'And Id != \''+v.newTimeOff.ERP7__Employee__c+'\''}" hideRemove="true"/> <!--qry="{!'And Id != \''+v.newTimeOff.ERP7__Employee__c+'\''}"-->      
                                    </div>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-right_small slds-p-top_small">
                                    <div class="slds-form-element__control">
                                        <lightning:input aura:id="leaveReason" label="{!$Label.c.Reason_ManageLeave}" value="{!v.newTimeOff.ERP7__Reason__c}" placeholder="{!$Label.c.Enter_Reason_ManageLeave}"/><!--inputRichText-->
                                    </div>
                                </div>
                            </div>         
                        </aura:set>
                    </aura:if>
                    
                    <footer class="slds-modal__footer text-center">
                        <aura:if isTrue="{!v.CurrentPopUp == 'Delete-Leaverequest'}">

                            <lightning:button  label="No" onclick="{!c.closePopupModal}" variant="neutral"/>
                            <lightning:button onclick="{!c.DeleteLeaveReq}" label="Yes" variant="brand" />

                            <aura:set attribute="else">
                                <lightning:button  label="{!$Label.c.Cancel_ManageLeave}" onclick="{!c.closePopupModal}" variant="neutral"/>
                                <aura:if isTrue="{!v.newTimeOff.ERP7__Status__c == 'Draft'}">
                                    <lightning:button onclick="{!c.Save}" label="Save" variant="Success"/>
                                    <lightning:button onclick="{!c.SaveSubmit}" label="Submit" variant="Success"/>
                                    <aura:set attribute="else">
                                        <lightning:button onclick="{!c.Save}" label="Save" variant="Success" disabled="true"/>
                                    </aura:set>
                                </aura:if>
                            </aura:set>

                        </aura:if>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop" aura:id="newTimeOffModalBackdrop1"></div>
        </div>
        <!-- Emp View/Edit modal start -->
        <div class="EmpViewModal" aura:id="EmpModal">
            
            <section aura:id="EmployeeEditModal" role="dialog" tabindex="-1" class="slds-modal slds-modal_small" aria-labelledby="contactModalHeading" aria-modal="true" aria-describedby="contactModalBody1">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <lightning:buttonicon class=" slds-modal__close" iconName="utility:close" title="Close" onclick="{!c.closeEmployeeEditModal}" variant="bare-inverse" size="large"/> 
                        <aura:if isTrue="{!v.isEmployeeEdit}">
                            <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate manageLeave-newClass43">Edit Employee</h2>
                            <aura:set attribute="else">
                                <h2 id="contactModalHeading" class="slds-text-heading_medium slds-hyphenate manageLeave-newClass43">View Employee</h2>
                            </aura:set>
                        </aura:if>
                    </header>

                    <div class="slds-grid slds-wrap manageLeave-newClass44">
                        <!-- Group 1: First Name, Last Name, Gender, Address -->
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="text" label="First Name" value="{!v.EmployeeEdit.ERP7__First_Name__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="text" label="Last Name" value="{!v.EmployeeEdit.ERP7__Last_Name__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:select label="Gender" value="{!v.EmployeeEdit.ERP7__Gender__c}">
                                    <option value="">-- None --</option>
                                    <aura:iteration items="{!v.GenderPicklistValues}" var="item">
                                        <option value="{!item.value}">{!item.label}</option>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <c:CustomInputLookUp objectAPIName="ERP7__Address__c" label="Address" IconName="standard:user" selectedRecordId="{!v.EmployeeEdit.ERP7__Address__c}" />

                               <!-- <lightning:input type="text" label="{!$Label.c.Addresss}" value="{!v.EmployeeEdit.Address__c}"/> -->
                            </div>
                        </div>
                 <!--   </div>  -->
                    
                 <!--   <div class="slds-grid slds-wrap manageLeave-newClass44">  -->
                        <!-- Group 2: Leave Balances -->
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="number" label="Annual Leave Available" value="{!v.EmployeeEdit.ERP7__Annual_Leave_Available__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="number" label="Casual Leave Available" value="{!v.EmployeeEdit.ERP7__Casual_Leave_Available__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="number" label="Sick Leave Available" value="{!v.EmployeeEdit.ERP7__Sick_Leave_Available__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="number" label="Paternity Leave Available" value="{!v.EmployeeEdit.ERP7__Paternity_Leave_Avaiable__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="number" label="Earned Leave Available" value="{!v.EmployeeEdit.ERP7__Earned_Leave_Available__c}"/>
                            </div>
                        </div>
                   <!-- </div>-->
                    
                  <!--  <div class="slds-grid slds-wrap manageLeave-newClass44">  -->
                        <!-- Group 3: Job Title, First Working Day, etc. -->
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="text" label="Job Title" value="{!v.EmployeeEdit.ERP7__Job_Title__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="date" label="First Working Day" value="{!v.EmployeeEdit.ERP7__First_Working_Day__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="text" label="Description" value="{!v.EmployeeEdit.ERP7__Description__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                            	<c:CustomInputLookUp objectAPIName="ERP7__Employees__c" label="Manager" IconName="standard:user" selectedRecordId="{!v.EmployeeEdit.ERP7__Employee_User__r.ManagerId}" qry="{!'And Id != \''+v.currentEmp+'\''}" />
                              <!--  <lightning:input type="text" label="Manager" value="{!v.EmployeeEdit.ReportingManager__r.Name}"/>   qry="{!'And Id != \''+v.currentEmployee+'\''}"-->
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:select label="Marital Status" value="{!v.EmployeeEdit.ERP7__Marital_Status__c}">
                                    <option value="">-- None --</option>
                                    <aura:iteration items="{!v.MaritalStatusPicklistValues}" var="item">
                                        <option value="{!item.value}">{!item.label}</option>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                        </div>                        
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="checkbox" label="Active" checked="{!v.EmployeeEdit.ERP7__Active__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="tel" label="Phone" value="{!v.EmployeeEdit.ERP7__Phone__c}"/>
                            </div>
                        </div>
                        <div class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_6-of-12 slds-p-right_small slds-p-top_small">
                            <div class="slds-form-element__control">
                                <lightning:input type="email" label="Email" value="{!v.EmployeeEdit.ERP7__Email__c}"/>
                            </div>
                        </div>
                    </div>
                    <aura:if isTrue="{!v.isEmployeeEdit}">
                        <footer class="slds-modal__footer text-center">
                            <lightning:button  label="Cancel" onclick="{!c.closeEmployeeEditModal}" variant="neutral"/>
                            <lightning:button onclick="{!c.saveEmployeeEditModal}" label="Save" variant="Success"/>
                            <aura:set attribute="else">
                                <lightning:button  label="Cancel" onclick="{!c.closeEmployeeEditModal}" variant="neutral"/>
                            </aura:set>
                        </footer>
                    </aura:if>
                </div>
            </section>
           
            <div class="slds-backdrop" aura:id="EmployeeEditBackdrop"></div>
        </div>
        <!-- Emp View/Edit modal end -->
    </body>
</aura:component>