                                                                            </a>&nbsp;&nbsp;
                                                                            <aura:set attribute="else">
                                                                                <a class="svg disabled-link" onclick="{!c.EditClickAdmin}" data-index="{!i}" data-record="{!LeaveReq.Id}"> 
