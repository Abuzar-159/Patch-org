<aura:component controller="LeaveManagementLC" implements="force:appHostable">
    <head>
        <ltng:require styles="{!join(',',$Resource.SLDS+ '/assets/styles/salesforce-lightning-design-system-vf.css')}"  />
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/manageleave.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>
        <ltng:require styles="/resource/ERP7__ERPTheme/css/main-leavemanagement.css"/>
    </head>
    
    <aura:attribute name="Holidays" type="Leave_Entitlements_Holidays__c[]" />
    <aura:attribute name="EmpEnt" type="Leave_Entitlement__c[]" />
    <aura:attribute name="Records" type="Leave_Request__c[]" />
    <aura:attribute name="ForApprovalRecords" type="Leave_Request__c[]" />
    <aura:attribute name="EmployeeRecords" type="Employees__c[]" />
    <aura:attribute name="table" type="Leave_Request__c[]" />
    <aura:attribute type="LeaveManagementLC" name="counts" />
    <aura:attribute name="items" type="Leave_Request__c[]" />
    <aura:attribute name="var" type="Leave_Request__c" default="{ 'sobjectType': 'Leave_Request__c' }" />
    <aura:attribute name="Employee" type="Employees__c" default="{ 'sobjectType': 'Employees__c' }" />
    <aura:registerEvent name="edit" type="c:editForm" />
    <aura:registerEvent name="delete" type="c:leaveDelete" />
    <aura:handler name="delete" action="{!c.handleAccountDelete}" />
    <aura:handler name="init" value="{!this}" action="{!c.getHolidays}" />			
    <aura:handler name="init" value="{!this}" action="{!c.getValues}" />			
    <aura:handler name="init" value="{!this}" action="{!c.displayApproved}" />
    <aura:handler name="init" value="{!this}" action="{!c.displaySubmitted}" />		
    <aura:handler name="init" value="{!this}" action="{!c.display}" />				
    <aura:handler name="init" value="{!this}" action="{!c.getEmpLeaveDetails}" />	
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:handler name="init" value="{!this}" action="{!c.setLeaveTypes}" />

    <aura:attribute type="Boolean" name="sortAsc" />
    <aura:attribute type="String" name="sortField" default=""/>
    <aura:attribute type="String" name="CurrentLeaveId" default=""/>
    <aura:attribute type="String" name="UserImageURL" default=""/>
    <aura:attribute name="ftctrl" type="boolean" default="true"/>
    <aura:attribute name="EorH" type="String" default=""/>

    <aura:attribute name="Tab" type="String" default="tab1"/>
    <aura:attribute name="View" type="String" default="List"/>
    <aura:attribute name="currentEmployee" type="String" default=""/>
    <aura:attribute name="selectedFY" type="String" default=""/>
    <aura:attribute name="editIndex" type="Integer" default="0"/>
    <aura:attribute name="A_Rcomment" type="String" default=""/>
    <aura:attribute name="empLeaveId" type="String" default=""/>
    <aura:attribute name="empARIndex" type="Integer" default="0"/>
    <aura:attribute name="isEdit" type="Boolean" default="false"/>
    <aura:attribute name="resetLookups" type="Boolean" default="true"/>
    <aura:attribute name="empLeaves" type="Leave_Request__c[]" />
    <aura:attribute name = "serverSuccess" type = "String" default=""/>
    <aura:attribute name = "exceptionError" type = "String" default = ""/>
    <aura:attribute name="leaveTypes" type="list[]"/>
    <aura:attribute name="newTimeOff" type="Leave_Request__c" default="{ 'sobjectType': 'Leave_Request__c'}" /> 
    <aura:attribute type="String" name="DraftActive" default="active-page"/>
    <aura:attribute type="String" name="ApprovedActive"  default = ""/>
    <aura:attribute type="String" name="RejectedActive" default = ""/>
    <aura:attribute type="String" name="EntitleActive" default = ""/>
    <aura:attribute type="Boolean" name="IsAdmin" default = "false"/>
    <aura:attribute type="String" name="CurrentTab" default = "LeaveApplication-tab"/>
    <aura:attribute type="String" name="CurrentPopUp" default = ""/>
    <aura:attribute name="currentFiscalYear" type="Integer" />
    <aura:attribute name="Leavereason" type="String" default=""/>
    <aura:handler name="change" value="{!v.currentFiscalYear}" action="{!c.displayApproved}" />
    
    <aura:attribute name="ApprovedRec" type="Leave_Request__c[]" />
    <aura:attribute name="RejectedRec" type="Leave_Request__c[]" />
    <aura:attribute name="SubmittedRec" type="Leave_Request__c[]" />
    <aura:attribute name="DraftRec" type="Leave_Request__c[]" />
    <aura:attribute name="currentEmp" type="String" default="" />
    <aura:attribute name="EmployeeEdit" type="Employees__c" default="{ 'sobjectType': 'Employees__c' }" />
    <aura:attribute name="isEmployeeEdit" type="Boolean" default="false"/>
    <aura:attribute name="GenderPicklistValues" type="List" default="[{'label': 'Male', 'value': 'Male'}, {'label': 'Female', 'value': 'Female'}]"/>
    <aura:attribute name="MaritalStatusPicklistValues" type="List" default="[{'label': 'Single', 'value': 'Single'}, {'label': 'Married', 'value': 'Married'}, {'label': 'Divorced', 'value': 'Divorced'}, {'label': 'Widowed', 'value': 'Widowed'}]"/>
    
    <body aura:id="body" class="manageLeave-newClass" style="background-color: #f3f4f7;">
        
        <!-- Employee Section Starts -->
        	<aura:if isTrue="{!not(v.Employee.ERP7__Admin__c)}">
            <div class="erp erp-lm" aura:id="Employee-View"> 
                <div class="page-container p-2">
                    <div class="page-header">
                        <nav class="navbar navbar-expand-lg d-flex justify-content-between">
                            <div class="" id="navbarNav">
                                <ul class="navbar-nav" id="leftNav">
                                    <li class="nav-item">
                                        <a class="nav-link" id="sidebar-toggle" href="#">
                                            <i class="fa fa-home"></i>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <h3 class="slds-p-top_small">Leave Management</h3>
                                    </li>
                                    
                                </ul>
                            </div>
                            <div class="logo" style="justify-content: flex-end;">
                                <p class="pt-1 pr-2"><strong>{!v.Employee.Name}</strong></p>
                                <span class="slds-avatar slds-avatar_circle">
                                    <span class="slds-icon_container slds-icon-standard-user" title="">
                                        <aura:if isTrue="{!not(empty(v.UserImageURL))}">
                                            <img src="{!v.UserImageURL}" alt="Image not Avaialble"/> 
                                            <aura:set attribute="else">
                                                <lightning:icon iconName="standard:user" ></lightning:icon>  
                                            </aura:set>
                                        </aura:if>
                                        <span class="slds-assistive-text">User</span>
                                    </span>
                                </span>
                                
                            </div>
                            
                        </nav>
                    </div>
                    <div class="page-sidebar mt-6p">
                        
                        <div class="card mb-0">
                            <div class="card-body p-3">
                                <h5 class="card-title mb-2">{!v.Employee.Name}</h5>
                                <ul class="list-unstyled profile-about-list">
                                    <li><i class="fa fa-envelope m-r-xxs"></i><span>{!v.Employee.ERP7__Email__c}</span></li>
                                    <li><i class="fa fa-compass m-r-xxs"></i><span>Lives in <a href="#">{!v.Employee.ERP7__Place_of_Birth__c}</a></span></li>
                                    <li><i class="fa fa-address-book m-r-xxs"></i><span>{!v.Employee.ERP7__Phone__c}</span></li>
                                </ul>
                            </div>
                        </div>
                        <ul class="list-unstyled accordion-menu">
                            <li class="sidebar-title">
                                Non Admin User
                            </li>
                            <li class="{!v.DraftActive}" data-attribute="draft" onclick="{!c.ChangeActive}">
                                <a href="javascript:void(0)" onclick="{!c.displayApproved}"> <i class="fa fa-home pr-2"></i>&nbsp;Draft / Submitted </a>
                            </li>
                            
                            <li class="{!v.ApprovedActive}" data-attribute="Approved" onclick="{!c.ChangeActive}">
                                    <a href="javascript:void(0)" onclick="{!c.Approved}" data-attribute="Approved"> <i class="fa fa-check-circle pr-2"></i>&nbsp;Approved </a>
                            </li>
                            <li class="{!v.RejectedActive}" data-attribute="Rejected" onclick="{!c.ChangeActive}">
                                <a href="javascript:void(0)" onclick="{!c.Approved}" data-attribute="Rejected"><i class="fa fa-times-circle pr-2"></i>&nbsp;Rejected</a>
                            </li>
                        <!--    <li class="{!v.EntitleActive}" data-attribute="Entitle" onclick="{!c.ChangeActive}">
                                <a href="javascript:void(0)">
                                    <i class="fa fa-file-text-o pr-2"></i>&nbsp;Entitlements / Holidays
                                </a>
                            </li> -->
                            
                            
                            
                        </ul>
                    </div>
                    <div class="page-content">
                        <div class="main-wrapper">
                            <div class="card">
                                <div class="card-body p-3">
                                    <div class="row">
                                        <div class="col-md-8">
                                           <!-- <h6 class="card-title mb-1" style="font-size: 14px;"><i class="fa fa-calendar-check-o pr-2 fa-2x"></i>&nbsp;<i class="fa fa-chevron-left pr-2" style="color: #7888FC;"></i>&nbsp;01/01/2024 - 31/12/2024&nbsp;<i class="fa fa-chevron-right pl-2" style="color: #7888FC;"></i></h6>-->
                                            <span aura:id="dateRange" class="card-title mb-1" style="font-size: 14px;">
                                                <lightning:icon iconName="utility:calendar" class="pr-2 fa-2x" size="small"/>
                                                <lightning:buttonIcon iconName="utility:left" class="pr-2" variant="bare" onclick="{!c.handlePrevButtonClick}" />
                                                <span id="dateText">01/01/{!v.currentFiscalYear} - 31/12/{!v.currentFiscalYear}</span>
                                                <lightning:buttonIcon iconName="utility:right" class="pl-2" variant="bare" onclick="{!c.handleNextButtonClick}" />
                                            </span>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="float:right;">
                                                <button type="submit" class="btn btn-primary" onclick="{!c.openTimeOffModal}" data-attribute="New"><i class="fa fa-plus pr-2"></i>&nbsp;Apply Leave</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3 col-xl-2">
                                    <div class="card stat-widget">
                                        <div class="card-body p-3 text-center">
                                            <h5 class="card-title mb-1">Annual Leaves</h5>
                                            <img src="/resource/ERP7__ERPTheme/icons/leave.png" style="width:50px;"></img>
                                            <hr/>
                                            
                                            <p class="mb-1"><strong>Available:</strong>
                                               
                                            </p>
                                             <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Annual_Leave_Available__c}</h4></div>
                                            <hr/>
                                            
                                            <p class="mb-1"><strong>Booked:</strong> 
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Annual_Leave_Booked__c}</h4></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-xl-2">
                                    <div class="card stat-widget">
                                        <div class="card-body p-3 text-center">
                                            <h5 class="card-title mb-1">Casual Leave</h5>
                                            <img src="/resource/ERP7__ERPTheme/icons/error.png" style="width:50px;"></img>
                                            <hr/>
                                          
                                            <p class="mb-1"><strong>Available:</strong> 
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0"> {!v.Employee.ERP7__Casual_Leave_Available__c}</h4></div>
                                            <hr/>
                                           
                                            <p class="mb-1"><strong>Booked:</strong>
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Casual_Leave_Boooked__c}</h4></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-xl-2">
                                    <div class="card stat-widget">
                                        <div class="card-body p-3 text-center">
                                            <h5 class="card-title mb-1">Sick Leave</h5>
                                            <img src="/resource/ERP7__ERPTheme/icons/stethoscope.png" style="width:50px;"></img>
                                            <hr/>
                                            
                                            <p class="mb-1"><strong>Available:</strong> 
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0"> {!v.Employee.ERP7__Sick_Leave_Available__c}</h4></div>
                                            <hr/>
                                            
                                            <p class="mb-1"><strong>Booked:</strong> 
                                               
                                            </p>
                                             <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Sick_Leave_Booked__c}</h4></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-xl-2">
                                    <div class="card stat-widget">
                                        <div class="card-body p-3 text-center">
                                            <h5 class="card-title mb-1">Paternity Leave</h5>
                                            <img src="/resource/ERP7__ERPTheme/icons/feet.png" style="width:50px;"></img>
                                            <hr/>
                                           <p class="mb-1"><strong>Available:</strong> 
                                              
                                            </p>
                                             <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Paternity_Leave_Avaiable__c}</h4></div>
                                            <hr/>
                                             <p class="mb-1"><strong>Booked:</strong> 
                                                
                                            </p>
                                             <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Paternity_Leave_Booked__c}</h4></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-xl-2">
                                    <div class="card stat-widget text-center">
                                        <div class="card-body p-3">
                                            <h5 class="card-title mb-1">Earned Leave</h5>
                                            <img src="/resource/ERP7__ERPTheme/icons/wallet.png" style="width:50px;"></img>
                                            <hr/>
                                          	<p class="mb-1"><strong>Available:</strong> 
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Earned_Leave_Available__c} </h4></div>
                                            <hr/>
                                            <p class="mb-1"><strong>Booked:</strong> 
                                                
                                            </p>
                                            <div class="float-right"><h4 class="mb-0">{!v.Employee.ERP7__Earned_Leave_Booked__c} </h4></div>
                                        </div>
                                    </div>
                                </div>
                                
                            </div>
                            
                            <div class="card">
                                <div class="card-body p-2">
                                    <h5 class="card-title mb-2">All Leaves and holidays</h5>
                                    <div id="zero-conf_wrapper" class="dataTables_wrapper dt-bootstrap4">
                                        
                                        
                                            <div class="table-responsive">
                                                <table class="slds-table slds-table_bordered">
                                                    <thead>
                                                        <tr class="slds-text-title--caps">
                                                            <th scope="col">#</th>
                                                            <th scope="col">Leave Request<br/> Name</th>
                                                            <th scope="col">Leave Period</th>
                                                            <th scope="col">Days Taken</th>
                                                            <th scope="col">Date of<br/> request</th>
                                                            <th scope="col">Leave Type</th>
                                                            <th scope="col">Status</th>
                                                            <th scope="col"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <aura:iteration items="{!v.Records}" var="Approved" indexVar="i">
                                                            <tr>
                                                                <th scope="row"> <lightning:formattedText value = "{!i + 1 + '.'}"/>&nbsp;&nbsp;</th>
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                    <strong>
                                                                    <lightning:formattedUrl value="{!'/'+Approved.Id}" label="{!Approved.Name}" target="_blank" class="fcolor1"/>
                                                                </strong>
                                                                    </div>
                                                                    </td>
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                    <lightning:formattedDateTime value="{!Approved.ERP7__Leave_Start_Date__c}"/> - <lightning:formattedDateTime value="{!Approved.ERP7__Leave_End_Date__c}"/>
                                                                    </div>
                                                                    </td>
                                                                <td><div class="slds-truncate max-widthml">{!Approved.ERP7__Number_of_Days__c}</div></td>
                                                                <td><div class="slds-truncate max-widthml"><lightning:formattedDateTime value="{!Approved.ERP7__Applied_Date__c}"/></div></td>
                                                                <td><div class="slds-truncate max-widthml"><lightning:formattedText value="{!Approved.ERP7__Leave_Type__c}" /></div></td>
                                                                <td>
                                                                    
                                                                    <span class="{! (Approved.ERP7__Status__c == 'Draft') ? 'badge badge-warning' : (Approved.ERP7__Status__c == 'Approved') ? 'badge badge-success' : (Approved.ERP7__Status__c == 'Submitted') ? 'badge badge-info' : (Approved.ERP7__Status__c == 'Rejected') ? 'badge badge-danger' : 'badge' }">{!Approved.ERP7__Status__c}</span></td>
                                                                <td>
                                                                    <aura:if isTrue="{!(Approved.ERP7__Status__c == 'Draft')}">
                                                                        <i class="fa fa-edit slds-p-right_small" onclick="{!c.openTimeOffModal}" data-attribute="Edit" data-index="{!i}"></i>
                                                                    </aura:if>
                                                                </td>
                                                            </tr>
                                                        </aura:iteration>
                                                    </tbody>
                                                </table>
                                            </div>
                                        
                                        <div class="row">
                                            <div class="col-sm-12 col-md-5 slds-p-around_small">
                                                <!--<div class="dataTables_info" id="zero-conf_info" role="status" aria-live="polite">Showing 1 to {!v.Records.length} of {!v.Records.length} entries</div>-->
                                            </div>
                                            
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aura:if>
        <!-- Employee Section Ends -->
        
        <!-- Admin Section Starts -->
        	<aura:if isTrue="{!(v.Employee.ERP7__Admin__c)}">
            <div class="erp erp-lm " aura:id="Admin-View"> 
                <div class="page-container p-2">
                    <div class="page-header">
                        <nav class="navbar navbar-expand-lg d-flex justify-content-between">
                            <div class="" id="navbarNav">
                                <ul class="navbar-nav" id="leftNav">
                                    <li class="nav-item">
                                        <a class="nav-link" id="sidebar-toggle" href="#">
                                            <i class="fa fa-home"></i>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <h3 class="slds-p-top_small">Leave Management Admin</h3>
                                    </li>
                                    
                                </ul>
                            </div>
                            <div class="logo" style="justify-content: flex-end;">
                                <p class="pt-1 pr-2"><strong>{!v.Employee.Name}</strong></p>
                                <span class="slds-avatar slds-avatar_circle">
                                    <span class="slds-icon_container slds-icon-standard-user" title="">
                                        <aura:if isTrue="{!not(empty(v.UserImageURL))}">
                                            <img src="{!v.UserImageURL}" alt="Image not Avaialble"/> 
                                            <aura:set attribute="else">
                                                <lightning:icon iconName="standard:user" ></lightning:icon>  
                                            </aura:set>
                                        </aura:if>
                                        <span class="slds-assistive-text">User</span>
                                    </span>
                                </span>
                                
                            </div>
                            
                        </nav>
                    </div>
                    <div class="page-sidebar mt-6p">
                       
                        <!-- admin menu section -->
                        <div class="card mb-0">
                            <div class="card-body p-3">
                                <h5 class="card-title mb-3">{!v.Employee.Name}</h5>
                                <ul class="list-unstyled profile-about-list">
                                    <li><i class="fa fa-envelope m-r-xxs"></i><span>{!v.Employee.ERP7__Email__c}</span></li>
                                    <li><i class="fa fa-compass m-r-xxs"></i><span>Lives in <a href="#">{!v.Employee.ERP7__Place_of_Birth__c}</a></span></li>
                                    <li><i class="fa fa-address-book m-r-xxs"></i><span>{!v.Employee.ERP7__Phone__c}</span></li>
                                </ul>
                            </div>
                        </div>
                        <ul class="list-unstyled accordion-menu">
                            <li class="sidebar-title">
                                Admin User
                            </li>
                            <li class="active-page" data-attribute="LeaveApplication-tab" onclick="{!c.tabChange}" aura:id="LeaveApp-Page">
                                <a href="javascript:void(0)" onclick="{!c.displaySubmitted}" >
                                    <i class="fa fa-home pr-2"></i>&nbsp;Leave Applications
                                </a>
                            </li>
                            <li data-attribute="Draft-tab" onclick="{!c.tabChange}" aura:id="Draft-Page"><!--Approved-tab-->
                                    <a href="javascript:void(0)" data-attribute="Draft" onclick="{!c.DraftSubmit}" > 
                                        <i class="fa fa-home pr-2"></i>&nbsp;Draft/ Submitted 
                                	</a>
                            </li>
                            
                            <li data-attribute="Approved-tab" onclick="{!c.tabChange}" aura:id="Approved-Page"><!--Approved-tab-->
                                    <a href="javascript:void(0)" data-attribute="Approved" onclick="{!c.Approved}" > 
                                        <i class="fa fa-check-circle pr-2"></i>&nbsp;Approved 
                                	</a>
                            </li>
                            
                            <li data-attribute="Rejected-tab"  onclick="{!c.tabChange}" aura:id="Rejected-Page"><!--Rejected-tab-->
                                <a href="javascript:void(0)" data-attribute="Rejected" onclick="{!c.Approved}" >
                                    <i class="fa fa-times-circle pr-2"></i>&nbsp;Rejected
                                </a>
                            </li>
                            
                            <li data-attribute="Employees-tab" onclick="{!c.tabChange}" aura:id="Employees-Page">
                                <a href="javascript:void(0)">
                                    <i class="fa fa-users pr-2"></i>&nbsp;Employees
                                </a>
                            </li>
                          <!--  <li>
                                <a href="javascript:void(0)" data-attribute="Policy-tab" onclick="{!c.tabChange}" aura:id="Policy-Page">
                                    <i class="fa fa-file-text pr-2"></i>&nbsp;Policy
                                </a>
                            </li>
                            <li>
                                <a href="javascript:void(0)" data-attribute="Entitlement-tab" onclick="{!c.tabChange}" aura:id="Entitlement-Page">
                                    <i class="fa fa-file-text-o pr-2"></i>&nbsp;Leave Entitlements
                                </a>
                            </li>-->
                            
                            
                            
                        </ul>
                        <!-- admin menu section -->
                        
                    </div>
                    
                    <!--Admin main area -->
                    <div class="page-content">
                        <div class="main-wrapper">
                            <div class="card">
                                <div class="card-body p-3">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <!-- <h6 class="card-title mb-1" style="font-size: 14px;"><i class="fa fa-calendar-check-o pr-2 fa-2x"></i>&nbsp;<i class="fa fa-chevron-left pr-2" style="color: #7888FC;"></i>&nbsp;01/01/2024 - 31/12/2024&nbsp;<i class="fa fa-chevron-right pl-2" style="color: #7888FC;"></i></h6>-->
                                            <span aura:id="dateRange" class="card-title mb-1" style="font-size: 14px;">
                                                <lightning:icon iconName="utility:calendar" class="pr-2 fa-2x" size="small"/>
                                                <lightning:buttonIcon iconName="utility:left" class="pr-2" variant="bare" onclick="{!c.handlePrevButtonClick}" />
                                                <span id="dateText">01/01/{!v.currentFiscalYear} - 31/12/{!v.currentFiscalYear}</span>
                                                <lightning:buttonIcon iconName="utility:right" class="pl-2" variant="bare" onclick="{!c.handleNextButtonClick}" />
                                            </span>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="float:right;">
