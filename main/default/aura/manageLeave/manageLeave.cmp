                                                            <th scope="col">Leave Period</th>
                                                            <th scope="col">Days Taken</th>
                                                            <th scope="col">Date of <br/>Request</th>
                                                            <th scope="col">Leave Type</th>
                                                            <th scope="col">Employee</th>
                                                            <th scope="col">Status</th>
                                                            <th scope="col"></th>
                                                            <th scope="col"></th>
                                                            <th scope="col"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <aura:if isTrue="{!v.ForApprovalRecords.length >0}">
                                                        	<aura:iteration items="{!v.ForApprovalRecords}" var="LeaveReq" indexVar="i">
                                                            <tr>
                                                                <td> <lightning:formattedText value = "{!i + 1 + '.'}"/>&nbsp;&nbsp;</td>
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                        <strong>
                                                                            <lightning:formattedUrl value="{!'/'+LeaveReq.Id}" label="{!LeaveReq.Name}" target="_blank" class="fcolor1" />
                                                                        </strong>
                                                                    </div>
                                                                </td>
                                                                <!--td scope="row"><input type="checkbox" class="form-input" /></td>-->
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                    <lightning:formattedDateTime value="{!LeaveReq.ERP7__Leave_Start_Date__c}"/>  - <lightning:formattedDateTime value="{!LeaveReq.ERP7__Leave_End_Date__c}"/>
                                                                    </div>
                                                                    </td>
                                                                <td><div class="slds-truncate max-widthml">{!LeaveReq.ERP7__Number_of_Days__c}</div></td>
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                        <lightning:formattedDateTime value="{!LeaveReq.ERP7__Applied_Date__c}"/>
                                                                    </div>
                                                                </td>
                                                                <td><div class="slds-truncate max-widthml">{!LeaveReq.ERP7__Leave_Type__c}</div></td>
                                                                <td>
                                                                    <div class="slds-truncate max-widthml">
                                                                    <span class="slds-avatar slds-avatar_circle">
                                                                        <span class="slds-icon_container slds-icon-standard-user" title="">  
                                                                            <aura:if isTrue="{!not(empty(LeaveReq.ERP7__Employee__r.ERP7__Employee_User__r.SmallPhotoUrl))}">
                                                                                <img src="{!LeaveReq.ERP7__Employee__r.ERP7__Employee_User__r.SmallPhotoUrl}" alt="Image not Avaialble"/> 
                                                                                <aura:set attribute="else">
                                                                                    <lightning:icon iconName="standard:user" ></lightning:icon>
                                                                                </aura:set>
                                                                            </aura:if>
                                                                            
                                                                            <span class="slds-assistive-text">User</span>
                                                                        </span>
                                                                    </span>
                                                                    &nbsp;&nbsp;<lightning:formattedUrl value="{!'/'+LeaveReq.ERP7__Employee__r.Id}" label="{!LeaveReq.ERP7__Employee__r.Name}" target="_blank" class="fcolor1"/>
                                                                    </div>
                                                                </td>
                                                                <td> 
                                                                    <aura:if isTrue="{!(LeaveReq.ERP7__Status__c == 'Submitted')}">
                                                                        <span class="badge badge-info">To Be Approved</span>
                                                                        <aura:set attribute="else">
                                                                            <span class="{! (LeaveReq.ERP7__Status__c == 'Approved') ? 'badge badge-success' : (LeaveReq.ERP7__Status__c == 'Rejected') ? 'badge badge-danger' : 'badge' }">{!LeaveReq.ERP7__Status__c}</span>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </td>
                                                                <aura:if isTrue="{!(LeaveReq.ERP7__Status__c == 'Submitted')}"><!--<aura:if isTrue="{!or(LeaveReq.ERP7__Status__c != 'Rejected',LeaveReq.ERP7__Status__c != 'Approved') }">-->
                                                                    <td>
                                                                        <i class="fa fa-check-square mr-2 btn-success fa-2x" aria-hidden="true" onclick="{!c.openApprovedRejectedModel}" data-recordId="{!LeaveReq.Id}" data-name="Approve" data-index="{!i}"></i>
                                                                    </td>
                                                                    <td>
                                                                        <i class="fa fa-window-close btn-danger fa-2x" aria-hidden="true" onclick="{!c.openApprovedRejectedModel}" data-recordId="{!LeaveReq.Id}" data-name="Reject" data-index="{!i}"></i>
                                                                    </td>
                                                                    
                                                                    <td>
                                                                      <!--  <ui:menu >
                                                                            <ui:menuTriggerLink aura:id="trigger1" label="">
                                                                                <lightning:button variant="neutral" label="" class="slds-button slds-button-icon-border-filled slds-button-icon-x-small  btnlineheight slds-p-right_x-small" iconName="utility:down"/>
                                                                            </ui:menuTriggerLink>    
                                                                            <ui:menuList aura:id="actionMenu" class="customMenuposition">
                                                                                <ui:actionMenuItem >
                                                                                    <a href="javascript:void(0);"   data-recordId="{#LeaveReq.Id}" data-name="{#LeaveReq.Name}" onclick="{!c.editEmployeeByAdmin}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{!LeaveReq}" data-name="{#LeaveReq.Name}" onclick="{!c.openPopupModal}" data-attribute="Edit-Leaverequest" data-index="{!i}"><i class="fa fa-pencil">&nbsp;&nbsp;</i>Edit</span></a>
                                                                                </ui:actionMenuItem>
                                                                                <ui:actionMenuItem >
                                                                                    <a href="javascript:void(0);"   data-recordId="{#LeaveReq.Id}" data-name="{#LeaveReq.Name}" onclick="{!c.viewEmployee}" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{!LeaveReq}" data-name="{#LeaveReq.Name}" onclick="{!c.openPopupModal}" data-attribute="View-Leaverequest" data-index="{!i}"><i class="fa fa-eye"></i>&nbsp;&nbsp;View</span></a>
                                                                                </ui:actionMenuItem>
                                                                                <ui:actionMenuItem >
                                                                                    <a href="javascript:void(0);"   data-recordId="{#LeaveReq.Id}" data-name="{#LeaveReq.Name}" onclick="" title=""><span class="slds-form-element__label AccountsPayable-newClass14" data-record="{!LeaveReq}" data-name="{#LeaveReq.Name}" onclick="{!c.openPopupModal}" data-attribute="Delete-Leaverequest" data-index="{!i}"><i class="fa fa-trash-o">&nbsp;&nbsp;</i>Delete</span></a>
                                                                                </ui:actionMenuItem> 
                                                                            </ui:menuList>
                                                                        </ui:menu> -->
                                                                    </td>
                                                                </aura:if>
                                                            </tr>
                                                        </aura:iteration>
