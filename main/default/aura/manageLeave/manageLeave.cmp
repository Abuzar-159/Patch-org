                                                                                    <h3 class="slds-text-heading_small"> No Leave Applications to Approve/Reject </h3>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            </aura:set>
                                                        </aura:if>
                                                    </tbody>
                                                </table>
