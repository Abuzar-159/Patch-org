<aura:component controller="ProductListComm" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
    <ltng:require styles="{!join(',',$Resource.BankReconcile + '/css/font-awesome.css')}"  />
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:attribute name="Name" type="String"/>
    <aura:attribute name="Mobile" type="String"/>
    <!--<aura:attribute name="Name1" type="String"/>
    <aura:attribute name="Email" type="String"/>
    
    <aura:attribute name="addLine1" type="String"/>
    <aura:attribute name="addLine2" type="String"/>
    <aura:attribute name="addLine3" type="String"/>
    <aura:attribute name="City" type="String"/>-->
    <aura:attribute name="Country" type="String[]"/>
    <aura:attribute name="State" type="String[]"/>
    <aura:attribute name="CountrySel" type="String" default=""/>
    <aura:attribute name="StateSel" type="String" default=""/>
    <aura:attribute name="Zip" type="String"/>
    <aura:attribute name="conId" type="String"/>
    <aura:attribute name="errorMsg" type="String" default=""/>
    <aura:attribute name="errorMsg1" type="String" default=""/>
    <aura:attribute name="errorMsg2" type="String" default=""/>
    <aura:attribute name="errorMsg3" type="String" default=""/>
    <aura:attribute name="errorMsg4" type="String" default=""/>
    <aura:attribute name="errorMsg5" type="String" default=""/>
    <aura:attribute name="errorMsg6" type="String" default=""/>
    <aura:attribute name="errorMsg7" type="String" default=""/>
    <aura:attribute name="addNewShipAdd" type="boolean" default="false"/>
    <aura:attribute name="showContent" type="boolean" default="false"/>    
    
    <aura:attribute name="priAddToUpdate" type="String"/>
    <aura:attribute name="billAddToUpdate" type="String"/>
    <aura:attribute name="shipAddToUpdate" type="String"/>
    <aura:attribute name="addToDel" type="String"/>
    
    <aura:attribute name="addDefault" type="String[]"/>
    <aura:attribute name="addBilling" type="String[]"/>
    <aura:attribute name="addShipping" type="Object"/>
    <aura:attribute name="addAll" type="Object"/> 
    <aura:handler name="init" value="{!this}" action="{!c.initial}"/>    
    
    <div class="main">
        <div class="container-fluid margin_30">
            <div class="page_header">
                
                <h4 class="client">{!v.Name}</h4>
                <div class="breadcrumbs">
                    <ul>
                        <li><a href="javascript:void(0)" onclick="{!c.home}">Home</a></li>                            
                        <li>My Account</li>
                    </ul>
                </div>
            </div>
            <!-- /page_header -->
            
            <aura:if isTrue="{!v.showContent}">
                <aura:if isTrue="{!v.addAll.length > 0}">
                    <div class="maqsood row">
                        <aura:iteration var="def" items="{!v.addDefault}">
                            <div class="col-md-4">
                                <div class=" box_general summary ProductListCommMyAcc-newClass1">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between"> 
                                            <div>
                                                <p class="mb-0"><strong>Default Address</strong></p><!--&nbsp;<a onclick="{!c.openEditModal}" value="{!def.Id}">Update</a>-->
                                                <p class="mb-0">Name :&nbsp;<strong>{!def.Name}</strong></p>
                                                <!--<div>Email :&nbsp;<strong>{!v.Email}</strong></div>-->
                                                <p class="mb-0">Mobile :&nbsp;<strong>{!v.Mobile}</strong></p>
                                                <p class="mb-0">Address :&nbsp;<strong>{!def.ERP7__Address_Line1__c}&nbsp;{!def.ERP7__Address_Line2__c}&nbsp;{!def.ERP7__Address_Line3__c}</strong></p>
                                                <p class="mb-0">City :&nbsp;<strong>{!def.ERP7__City__c}</strong></p>
                                                <p class="mb-0">State :&nbsp;<strong>{!def.ERP7__State__c}</strong></p>
                                                <p class="mb-0">Zip :&nbsp;<strong>{!def.ERP7__Postal_Code__c}</strong></p>
                                                <p class="mb-0">Country :&nbsp;<strong>{!def.ERP7__Country__c}</strong></p>
                                            </div>
                                            <span class="dropdown">
                                                <a href="#" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fa fa-ellipsis-v" aria-hidden="true"></i>
                                                </a>
                                                <span class="dropdown-menu dropdown-menu-right">                                                    
                                                    <a class="dropdown-item" onclick="{!c.openPriEditModal}" data-id="{!def.Id}">Edit</a>                                                    
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                
                            </div>
                        </aura:iteration>
                        <aura:iteration var="bil" items="{!v.addBilling}">
                            <div class="col-md-4">
                                <div class="box_general summary ProductListCommMyAcc-newClass1">
                                    <div class="card-body">
                                        
                                        <div class="d-flex justify-content-between">
                                            <div>
                                                <strong><p class="mb-0">Billing Address</p></strong><!--&nbsp;<a onclick="{!c.openEditModal}" value="{!bil.Id}">Update</a> -->                   
                                                <p class="mb-0">Name :&nbsp;<strong>{!bil.Name}</strong></p>
                                                <!--<div>Email :&nbsp;<strong>{!v.Email}</strong></div>-->
                                                <!--<div>Mobile :&nbsp;<strong>{!v.Mobile}</strong></div>-->
                                                <p class="mb-0">Address :&nbsp;<strong>{!bil.ERP7__Address_Line1__c}&nbsp;{!bil.ERP7__Address_Line2__c}&nbsp;{!bil.ERP7__Address_Line3__c}</strong></p>
                                                <p class="mb-0">City :&nbsp;<strong>{!bil.ERP7__City__c}</strong></p>
                                                <p class="mb-0">State :&nbsp;<strong>{!bil.ERP7__State__c}</strong></p>
                                                <p class="mb-0">Zip :&nbsp;<strong>{!bil.ERP7__Postal_Code__c}</strong></p>
                                                <p class="mb-0">Country :&nbsp;<strong>{!bil.ERP7__Country__c}</strong></p>
                                            </div>
                                            <span class="dropdown">
                                                <a href="#" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fa fa-ellipsis-v" aria-hidden="true"></i>
                                                </a>
                                                <span class="dropdown-menu dropdown-menu-right">                                                    
                                                    <a class="dropdown-item" onclick="{!c.openPriBillModal}" data-id="{!bil.Id}">Edit</a>                                                    
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </aura:iteration>
                    </div>
                    
                    <div class="row mb-2">
                        <div class="col-md-12">
                            <p class="mb-0"><strong>Shipping Address</strong></p>&nbsp;<a onclick="{!c.addShipAdd}">Add</a>
                        </div>
                    </div>
                    <div class="maqsood row">                        
                        
                        <aura:iteration var="shi" items="{!v.addShipping}">
                            <div class="col-md-4">
                                <div class="box_general summary ProductListCommMyAcc-newClass1">
                                    <div class="card-body">                                        
                                        <div class="d-flex justify-content-between">
                                            <div>
                                                <!--<a onclick="{!c.openEditModal}" value="{!shi.Id}">Update</a> -->                   
                                                <p class="mb-0">Name :&nbsp;<strong>{!shi.Name}</strong></p>
                                                <!--<div>Email :&nbsp;<strong>{!v.Email}</strong></div>-->
                                                <!--<div>Mobile :&nbsp;<strong>{!v.Mobile}</strong></div>-->
                                                <p class="mb-0">Address :&nbsp;<strong>{!shi.ERP7__Address_Line1__c}&nbsp;{!shi.ERP7__Address_Line2__c}&nbsp;{!shi.ERP7__Address_Line3__c}</strong></p>
                                                <p class="mb-0">City :&nbsp;<strong>{!shi.ERP7__City__c}</strong></p>
                                                <p class="mb-0">State :&nbsp;<strong>{!shi.ERP7__State__c}</strong></p>
                                                <p class="mb-0">Zip :&nbsp;<strong>{!shi.ERP7__Postal_Code__c}</strong></p>
                                                <p class="mb-0">Country :&nbsp;<strong>{!shi.ERP7__Country__c}</strong></p>                                                
                                            </div>                                            
                                            <span class="dropdown">
                                                <a href="#" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fa fa-ellipsis-v" aria-hidden="true"></i>
                                                </a>
                                                <span class="dropdown-menu dropdown-menu-right">                                                    
                                                    <a class="dropdown-item" onclick="{!c.openShipModal}" data-id="{!shi.Id}">Edit</a>
													<a class="dropdown-item" onclick="{!c.openDeleteAdd}" data-id="{!shi.Id}">Delete</a>                                                    
                                                </span>
                                            </span>
                                        </div>
                                    </div>
                                    
                                </div>
                                
                            </div>
                        </aura:iteration>
                    </div>
                    <aura:set attribute="else">
                        <!--Add first address-->
                        <div class="slds-grid slds-wrap">
                            <h4>Add your address</h4>
                            <div class="slds-col col-6">
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newName1" label="Name" value="{!v.Name}" placeholder="Name"/>
                                </div>
                            </div>
                            <div class="slds-col col-6"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newMobile" label="Phone" value="{!v.Mobile}" placeholder="Phone" maxlength="10"/>                                         
                                </div>
                            </div>                                 
                            <div class="slds-col col-12"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newAdd1" label="Address Line 1" placeholder="1234 Main St"/>                                         
                                </div>
                            </div>
                            <div class="slds-col col-12"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newAdd2" label="Address Line 2" placeholder="Apartment, studio, or floor"/>                                         
                                </div>
                            </div>
                            <div class="slds-col col-12"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newAdd3" label="Address Line 3" placeholder="Landmark"/>                                         
                                </div>
                            </div>
                            <div class="slds-col col-6"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newCity" label="City" />                                         
                                </div>
                            </div>
                            <div class="slds-col col-6"> 
                                <div class="slds-form-element">
                                    <lightning:input type="text" aura:id="newZip" label="Zip"/>                                         
                                </div>
                            </div>
                            <div class="slds-col col-6"> 
                                <div class="slds-form-element">
                                    <lightning:select aura:id="newCountry" label="Country">
                                        <aura:iteration items="{!v.Country}" var="ct">
                                            <option value="{!ct}">{!ct}</option>
                                        </aura:iteration>
                                    </lightning:select>
                                    <aura:if isTrue="{!v.errorMsg2 != ''}">	<!--Make it as error message like others-->
                                        <li>{!v.errorMsg2}</li>>
                                    </aura:if>
                                </div>
                            </div>
                            <div class="slds-col col-6"> 
                                <div class="slds-form-element">
                                    <lightning:select aura:id="newState" label="State">
                                        <aura:iteration items="{!v.State}" var="st">
                                            <option value="{!st}">{!st}</option>
                                        </aura:iteration>
                                    </lightning:select>  
                                    <aura:if isTrue="{!v.errorMsg3 != ''}">	<!--Make it as error message like others-->
                                        <li>{!v.errorMsg3}</li>>
                                    </aura:if>
                                </div>
                            </div>                                 
                            <div class="slds-col col-6">
                                <lightning:button label="Save" variant="brand" onclick="{!c.saveAdd}"/>
                            </div>
                        </div>                    
                    </aura:set>
                </aura:if>
            </aura:if>
            
            <!-- /row -->
        </div>
    </div>
    <!--primary address edit modal-->
    <section aura:id="EditModal" role="dialog" tabindex="-1" aria-labelledby="EditModalHeading" aria-modal="true" aria-describedby="EditModalBody" class="slds-modal">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <lightning:buttonIcon class="slds-modal__close" alternativeText="Close" iconName="utility:close" onclick="{!c.EditCloseModal}" variant="bare-inverse" size="large"></lightning:buttonIcon>
                <h2 id="EditModalHeading" class="slds-text-heading_medium slds-hyphenate">Default Address</h2>
            </header>
            <div class="slds-modal__content slds-p-around_xx-small">
                
                <div class="row justify-content-center">
                    
                    <div class="col-xl-12 col-lg-12 col-md-12">
                        
                        <div class="box_account shadow-sm ProductListCommMyAcc-newClass2" >
                            
                            <form>
                                
                                <div class="row">
                                    <div class="form-group col-md-4">
                                        <label class="slds-form-element__label">
                                            Name
                                        </label>
                                        <lightning:input type="text" aura:id="name" placeholder="Name"/>
                                    </div>
                                    <!--<div class="form-group col-md-4">
                                    <label class="slds-form-element__label">
                                        Email
                                    </label>
                                    <lightning:input type="text" aura:id="email" value="{!v.Email}" placeholder="Email" disabled="true"/>
                                </div>-->
                                    <div class="form-group col-md-4">
                                        <label class="slds-form-element__label">
                                            Mobile
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="mobile" required="true" value="{!v.Mobile}" placeholder="Mobile" maxlength="10"/><!--maxlength="10" minlength="10"  messageWhenValueMissing="Please enter a valid email address" -->
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="add1" placeholder="1234 Main St"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 2
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="add2" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 3
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="add3" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label class="slds-form-element__label">
                                            City
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="city" required="true"/>
                                    </div>                         
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputCountry">Country</label>-->	<!--Don't remove label from lightning:select-->
                                        <lightning:select aura:id="country" label="Country" value="{!v.CountrySel}"><!--value="{!v.CountrySel}"-->
                                            <aura:iteration items="{!v.Country}" var="ct">
                                                <option value="{!ct}" selected="{!ct == v.CountrySel}">{!ct}</option>
                                            </aura:iteration>
                                        </lightning:select> 
                                        <aura:if isTrue="{!v.errorMsg1 != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg1}</li>>
                                        </aura:if>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputState">State</label>-->
                                        
                                        <lightning:select aura:id="state" label="State" value="{!v.StateSel}"><!--value="{!v.StateSel}"-->
                                            <aura:iteration items="{!v.State}" var="st">
                                                <option value="{!st}" selected="{!st == v.StateSel}">{!st}</option>
                                            </aura:iteration>
                                        </lightning:select>
                                        <aura:if isTrue="{!v.errorMsg != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg}</li>>
                                        </aura:if>
                                    </div>                  
                                    <div class="form-group col-md-2">
                                        <label class="slds-form-element__label">
                                            Zip
                                        </label>							
                                        <lightning:input type="text" variant="label-hidden" aura:id="zip" value="{!v.Zip}" required="true"/>
                                    </div>
                                </div>
                            </form>
                        </div>				
                    </div>
                </div>
            </div>
            <footer class="slds-modal__footer">
                <div class="offset-md-2 col-md-8 text-center pl-3 pr-3 ProductListCommMyAcc-newClass3">
                    <input type="submit" onclick="{!c.updatePriAdd}" value="Update" class="btn_1 half-width mr-2"/>
                    <input type="submit" value="Cancel" onclick="{!c.EditCloseModal}" class="btn_1 gray half-width"/>
                </div>                
            </footer>
        </div>
    </section>  
    <div aura:id="EditModalBackdrop" class="slds-backdrop"></div>
    <!--/primary address edit modal-->
    
    <!--billing address edit modal-->
    <section aura:id="BillModal" role="dialog" tabindex="-1" aria-labelledby="BillModalHeading" aria-modal="true" aria-describedby="BillModalBody" class="slds-modal">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <lightning:buttonIcon class="slds-modal__close" alternativeText="Close" iconName="utility:close" onclick="{!c.BillCloseModal}" variant="bare-inverse" size="large"></lightning:buttonIcon>
                <h2 id="BillModalHeading" class="slds-text-heading_medium slds-hyphenate">Billing Address</h2>
            </header>
            <div class="slds-modal__content slds-p-around_xx-small">                
                <div class="row justify-content-center">                    
                    <div class="col-xl-12 col-lg-12 col-md-12">                        
                        <div class="box_account shadow-sm ProductListCommMyAcc-newClass2">                            
                            <form>                                
                                <div class="row">
                                    <div class="form-group col-md-4">
                                        <label class="slds-form-element__label">
                                            Name
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="bilname" placeholder="Name"/>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="biladd1" placeholder="1234 Main St"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 2
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="biladd2" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 3
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="biladd3" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label class="slds-form-element__label">
                                            City
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="bilcity" required="true"/>
                                    </div>                         
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputCountry">Country</label>-->	<!--Don't remove label from lightning:select-->
                                        <lightning:select aura:id="bilcountry" label="Country" value="{!v.CountrySel}"><!--value="{!v.CountrySel}"-->
                                            <aura:iteration items="{!v.Country}" var="ct">
                                                <option value="{!ct}" selected="{!ct == v.CountrySel}">{!ct}</option>
                                            </aura:iteration>
                                        </lightning:select> 
                                        <aura:if isTrue="{!v.errorMsg4 != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg4}</li>>
                                        </aura:if>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputState">State</label>-->
                                        
                                        <lightning:select aura:id="bilstate" label="State" value="{!v.StateSel}"><!--value="{!v.StateSel}"-->
                                            <aura:iteration items="{!v.State}" var="st">
                                                <option value="{!st}" selected="{!st == v.StateSel}">{!st}</option>
                                            </aura:iteration>
                                        </lightning:select>
                                        <aura:if isTrue="{!v.errorMsg5 != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg5}</li>
                                        </aura:if>
                                    </div>                  
                                    <div class="form-group col-md-2">
                                        <label class="slds-form-element__label">
                                            Zip
                                        </label>							
                                        <lightning:input type="text" variant="label-hidden" aura:id="bilzip" value="{!v.Zip}" required="true"/>
                                    </div>
                                </div>
                            </form>
                        </div>				
                    </div>
                </div>
            </div>
            <footer class="slds-modal__footer">
                <div class="offset-md-2 col-md-8 text-center pl-3 pr-3 ProductListCommMyAcc-newClass3">
                    <input type="submit" onclick="{!c.updateBillAdd}" value="Update" class="btn_1 half-width mr-2"/>
                    <input type="submit" value="Cancel" onclick="{!c.BillCloseModal}" class="btn_1 gray half-width"/>
                </div>                
            </footer>
        </div>
    </section>  
    <div aura:id="BillModalBackdrop" class="slds-backdrop"></div>
    <!--/billing address edit modal-->
    
    <!--shipping address edit modal-->
    <section aura:id="ShipModal" role="dialog" tabindex="-1" aria-labelledby="ShipModalHeading" aria-modal="true" aria-describedby="ShipModalBody" class="slds-modal">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <lightning:buttonIcon class="slds-modal__close" alternativeText="Close" iconName="utility:close" onclick="{!c.ShipCloseModal}" variant="bare-inverse" size="large"></lightning:buttonIcon>
                <h2 id="ShipModalHeading" class="slds-text-heading_medium slds-hyphenate">Shipping Address</h2>
            </header>
            <div class="slds-modal__content slds-p-around_xx-small">                
                <div class="row justify-content-center">                    
                    <div class="col-xl-12 col-lg-12 col-md-12">                        
                        <div class="box_account shadow-sm ProductListCommMyAcc-newClass2">                            
                            <form>                                
                                <div class="row">
                                    <div class="form-group col-md-4">
                                        <label class="slds-form-element__label">
                                            Name
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="sipname" placeholder="Name"/>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="sipadd1" placeholder="1234 Main St"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 2
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="sipadd2" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="form-group">
                                    <label class="slds-form-element__label">
                                        Address Line 3
                                    </label>
                                    <lightning:input type="text" variant="label-hidden" aura:id="sipadd3" placeholder="Apartment, studio, or floor"/>
                                </div>
                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label class="slds-form-element__label">
                                            City
                                        </label>
                                        <lightning:input type="text" variant="label-hidden" aura:id="sipcity" required="true"/>
                                    </div>                         
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputCountry">Country</label>-->	<!--Don't remove label from lightning:select-->
                                        <lightning:select aura:id="sipcountry" label="Country" value="{!v.CountrySel}"><!--value="{!v.CountrySel}"-->
                                            <aura:iteration items="{!v.Country}" var="ct">
                                                <option value="{!ct}" selected="{!ct == v.CountrySel}">{!ct}</option>
                                            </aura:iteration>
                                        </lightning:select> 
                                        <aura:if isTrue="{!v.errorMsg6 != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg6}</li>>
                                        </aura:if>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <!--<label for="inputState">State</label>-->
                                        
                                        <lightning:select aura:id="sipstate" label="State" value="{!v.StateSel}"><!--value="{!v.StateSel}"-->
                                            <aura:iteration items="{!v.State}" var="st">
                                                <option value="{!st}" selected="{!st == v.StateSel}">{!st}</option>
                                            </aura:iteration>
                                        </lightning:select>
                                        <aura:if isTrue="{!v.errorMsg7 != ''}">	<!--Make it as error message like others-->
                                            <li>{!v.errorMsg7}</li>
                                        </aura:if>
                                    </div>                  
                                    <div class="form-group col-md-2">
                                        <label class="slds-form-element__label">
                                            Zip
                                        </label>							
                                        <lightning:input type="text" variant="label-hidden" aura:id="sipzip" value="{!v.Zip}" required="true"/>
                                    </div>
                                </div>
                            </form>
                        </div>				
                    </div>
                </div>
            </div>
            <footer class="slds-modal__footer">
                <div class="offset-md-2 col-md-8 text-center pl-3 pr-3 ProductListCommMyAcc-newClass3">
                    <input type="submit" onclick="{!c.updateShipAdd}" value="Update" class="btn_1 half-width mr-2"/>
                    <input type="submit" value="Cancel" onclick="{!c.ShipCloseModal}" class="btn_1 gray half-width"/>
                </div>                
            </footer>
        </div>
    </section>  
    <div aura:id="ShipModalBackdrop" class="slds-backdrop"></div>
    <!--/shipping address edit modal-->
    <!--delete Modal-->
    <section aura:id="delModal" role="dialog" tabindex="-1" aria-labelledby="delModalHeading" aria-modal="true" aria-describedby="delModalBody" class="slds-modal">
        <div class="slds-modal__container">
            <header class="slds-modal__header">
                <lightning:buttonIcon class="slds-modal__close" alternativeText="Close" iconName="utility:close" onclick="{!c.closeDeleteAdd}" variant="bare-inverse" size="large"></lightning:buttonIcon>
                <h2 id="delModalHeading" class="slds-text-heading_medium slds-hyphenate">Delete Address</h2>
            </header>
            <div class="slds-modal__content slds-p-around_xx-small">               
                <div class="row justify-content-center">
                    Do you want to delete this address?				
                </div>
            </div>
            <footer class="slds-modal__footer">
                <div class="offset-md-2 col-md-8 text-center pl-3 pr-3 ProductListCommMyAcc-newClass3">                    
                    <input type="submit" onclick="{!c.deleteAdd}" value="yes" class="btn_1 half-width mr-2"/>
                    <input type="submit" value="No" onclick="{!c.closeDeleteAdd}" class="btn_1 gray half-width"/>
                </div>                
            </footer>
        </div>
    </section>  
    <div aura:id="delModalBackdrop" class="slds-backdrop"></div>
    <!--/delete modal-->
</aura:component>