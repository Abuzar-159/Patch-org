<aura:component controller="SupplierPortalPO" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/SupplierPortalComm/CSS/SupplierportalComm.css'}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
    <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" />
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require scripts="{!join(',',
                           $Resource.ProductListComm + '/ProductListComm/script/common_scripts.min.js',                           
                           $Resource.ProductListComm + '/ProductListComm/script/main.js',
                           $Resource.ProductListComm + '/ProductListComm/script/carousel_with_thumbs.js'
                           )}"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierPortalPayments.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    
    <aura:attribute name="Payments" type="Payment__c[]"/>
    <aura:attribute name="PaymentsDup" type="Payment__c[]"/>
    <aura:attribute name="SelectedAccounts" type="List"/>
    <aura:attribute name="SelectedVouchers" type="List"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUserRecord}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUser}"/>
    <aura:attribute name="NoSlotsMessage" type="String"/>
    <aura:attribute name="PNS" type="Object"/>
    <aura:attribute name="OrderBy" type="String" default="Name"/> 
    <aura:attribute name="Order" type="String" default="DESC"/>
    <aura:attribute name="Offset" type="Integer" default="0"/>
    <aura:attribute name="startCount" type="Integer" default="0"/>
    <aura:attribute name="endCount" type="Integer" default="0"/>
    <aura:attribute name="PageNum" type="Integer" default="0"/>
    <aura:attribute name="show" type="Integer" default="10"/>
    <aura:attribute name="recSize" type="Integer" default="0"/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="SearchString" type="String" default=""/>
    <aura:attribute name="revert" type="Boolean" default="true"/>
    <aura:method name="doInit" action="{!c.doInit}"/>
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:attribute name="CheckOffset" type="Boolean" default="false"/>
    
    <aura:handler event="force:navigateToSObject" action="{!c.navigate}"/> 
    
    <div aura:id="sldshide"> 
        <div class="maqsood erp_Mark7 erp_mark7 SupplierPPaymnt-class1" aura:Id="body">
            <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="spinner" class="slds-hide"/>
            
            <div>
                <div class="container-fluid SupplierPPaymnt-class1">
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPaymnt-class9" onclick="{!c.getRFPs}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-agenda mb-0 SupplierPPaymnt-class10"></i>
                                    </div> 
                                    <div class="slds-col pt-3 pr-0 pl-1 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">RFP ( Request for Proposal)</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <!--div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a"> 
                            <a class="box_topic SupplierPPaymnt-class3" onclick="{!c.getExpenses}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-stats-up SupplierPPaymnt-class4" ></i>
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3>Expenses</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPaymnt-class5" onclick="{!c.getTimesheets}" href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i 	class="ti-timer mb-0 SupplierPPaymnt-class6"></i>
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Timesheets</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div-->
                        <div class="col-lg-3 col-md-6 mt-3" data-aura-rendered-by="54:125;a">
                            <a class="box_topic SupplierPPaymnt-class7" onclick="{!c.getContracts}"  href="javascript:void(0);">
                                <div class="slds-grid">
                                    <div class="slds-col col-3">
                                        <i class="ti-pencil-alt mb-0 SupplierPPaymnt-class8" ></i>
                                        
                                    </div> 
                                    <div class="slds-col pt-3 col-9 text-left"> 
                                        <h3 data-aura-rendered-by="57:125;a">Contracts</h3>
                                    </div>    
                                </div>    
                            </a>
                        </div>
                        
                    </div>
                    
                    <div class="card shadow-custom SupplierPPaymnt-class11" >
                        <div class="card-body">  
                            <div class="card-body pb-0  pl-2 pt-2">
                                <div class="d-flex justify-content-between pb-2">
                                    <div class="breadcrumbs">
                                       
                                        <h6 class="card-title mb-1">
                                            <a class="SupplierPPaymnt-class12" onclick="{!c.home}" href="">
                                                Home&nbsp;
                                            </a>
                                            >&nbsp;Payments
                                        </h6>
                                    </div>
                                    
                                    
                                </div>
                                
                                 <div class="container-fluid pl-0">
                                    <div class="col-md-3 pl-0">
                                       <c:SearchRecord searchString="{!v.SearchString}" Placeholder="Payment.." aura:id="Payment_Id"/>
                                    </div>
                                </div>
                                
                            </div>
                            
                            
                            <div class="table-responsive SupplierPPaymnt-class15" tabindex="1">
                                <table class="table">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <th class="slds-cell-shrink" scope="col">
                                                <!-- <label class="slds-checkbox">
                                            <input type="checkbox" name="options" value="on" />
                                            <span class="slds-checkbox_faux"></span>
                                            <span class="slds-assistive-text">Select All</span>
                                        </label>-->
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Payments">NAME
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="Name" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                   
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Bill">BILL
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Bill__r.Name" title="Descending Order" class="arrowColor">
                                                       <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                          
                                                    </span>-->
                                                    
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Purchase">PURCHASE ORDER
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Bill__r.ERP7__Purchase_Order__r.Name" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                              
                                                    </span> 
                                                  <!--  <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                             
                                                    </span>-->
                                                         
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Status">STATUS
                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Status__c" title="Descending Order" class="arrowColor">
                                                        <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                   
                                                    </span> 
                                                 <!--   <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                          
                                                    </span>-->
                                                </div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate2" title="Amount">AMOUNT
                                                   <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Amount__c" title="Descending Order" class="arrowColor">
                                                       <lightning:icon iconName="utility:sort"  size="x-small" alternativeText="arrowdown!" title="arrowdown" />                                       
                                                    </span> 
                                                   <!-- <span onclick="{!c.getSortedRecords}" data-service="ASC" data-record="Name"  title="Ascending Order" class="arrowColor">      
                                                        <lightning:icon iconName="utility:arrowup"  size="x-small" alternativeText="arrowup!" title="arrowup" />                            
                                                    </span>-->
                                                     
                                                </div>
                                            </th>
                                            <th class="slds-cell-shrink" scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:if isTrue="{!not(greaterthan(v.Payments.length, 0))}">
                                        <tr>
                                            <td colspan="8">
                                                <div class="no projects" >
                                                    <div class="slds-notify_container slds-is-relative" >
                                                        <div class="slds-notify slds-notify_toast slds-theme_warning" role="status">
                                                            <div>
                                                                <span class="slds-assistive-text">warning</span>
                                                                <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="No PO">
                                                                    <lightning:icon iconName="utility:warning" size="medium" alternativeText="warning"/>
                                                                </span>
                                                            </div>
                                                            <div class="slds-notify__content SupplierPPaymnt-class37">
                                                                <h2 class="slds-text-heading_small SupplierPPaymnt-class16">Sorry, No Records Available.</h2>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        <aura:set attribute="else">
                                        <aura:iteration items="{!v.Payments}" var="pay">
                                            
                                            <tr class="slds-hint-parent">
                                                <td class="slds-cell-shrink" data-label="Select Row">
                                                  
                                                </td>
                                                <th scope="row" data-label="Payment Name">
                                                    <div class="slds-truncate2" title="{!pay.Name}"><a href="javascript:void(0);" target="_blank"   data-record="{!pay.Id}" data-name="{!pay.Name}" onclick="{!c.getRecord}">{!pay.Name}</a></div>
                                                </th>
                                                <td data-label="Bill Name">
                                                    <div class="slds-truncate2" title="{!pay.ERP7__Bill__r.Name}"><lightning:formattedText value="{!pay.ERP7__Bill__r.Name}"/>
                                                        <!--<a href="javascript:void(0);"   data-record="{!pay.ERP7__Bill__r.Id}" data-name="{!pay.ERP7__Bill__r.Name}" onclick="{!c.getRecord}" target="_blank">{!pay.ERP7__Bill__r.Name}</a>-->
                                                    </div>
                                                    
                                                </td>
                                                <td data-label="Purchase Order">
                                                    <div class="slds-truncate2" title="{!pay.ERP7__Bill__r.ERP7__Purchase_Order__r.Id}"><lightning:formattedText value="{!pay.ERP7__Bill__r.ERP7__Purchase_Order__r.Name}"/>
                                                        <!--<a href="javascript:void(0);"   data-record="{!pay.ERP7__Bill__r.ERP7__Purchase_Order__r.Id}" data-name="{!pay.ERP7__Bill__r.ERP7__Purchase_Order__r.Name}" onclick="{!c.getRecord}" target="_blank">{!pay.ERP7__Bill__r.ERP7__Purchase_Order__r.Name}</a>-->
                                                    </div>
                                                    
                                                </td>
                                                <td data-label="Status">
                                                    <div class="slds-truncate2" title="{!pay.ERP7__Status__c }">{!pay.ERP7__Status__c }</div>
                                                </td>
                                                <td data-label="Vendor Amount">
                                                    <div class="slds-truncate2" title="{!pay.ERP7__Amount__c }">
                                                        <lightning:formattedNumber style="currency" value="{!pay.ERP7__Amount__c}"/>
                                                    </div>
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                            </aura:set>
                                        </aura:if>
                                    </tbody>
                                </table>
                            </div> 
                            <aura:if isTrue="{!(v.Payments.length>0)}">
                            <aura:if isTrue="{!and(v.NoSlotsMessage!=undefined, v.NoSlotsMessage!='')}"><!--(v.NoSlotsMessage!=undefined, v.NoSlotsMessage!='')-->
                                <div class="slds-notify_container slds-is-relative SupplierPPaymnt-class31" aura:id="criteriaMsgId">
                                    <div class="slds-notify slds-notify_toast slds-theme_warning SupplierPPaymnt-class17" role="alert">
                                        <span class="slds-assistive-text">warning</span>
                                        <lightning:icon iconName="utility:warning" size="small" alternativeText="warning"/>
                                        <div class="slds-notify__content SupplierPPaymnt-class18">
                                            <h2 class="slds-text-heading_small SupplierPPaymnt-class19" >
                                                {!v.NoSlotsMessage}
                                            </h2>
                                        </div>
                                    </div>
                                </div>     
                            </aura:if>
                            </aura:if>
                        </div>
                    </div>
                </div>
            </div>
            <aura:if isTrue="{!v.showMmainSpin}">
                <span class="SupplierPPaymnt-class20">
                    <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading" aura:id="mainSpin" class="mainSpinClass"/>
                </span>
            </aura:if> 
        </div>
        <aura:if isTrue="{!v.revert}">
            <div class="epr_Mark7">
                <div class="row SupplierPPaymnt-class32">
                    <aura:if isTrue="{!v.Payments.length>0}">
                        <div class="col-md-2 SupplierPPaymnt-class29" >
                            <div class="slds-grid" >
                                <div class="slds-col SupplierPPaymnt-class22">
                                    Show&nbsp;&nbsp;
                                </div>  
                                <div class="slds-col SupplierPPaymnt-class23"> 
                                    <lightning:select class="slds-show_inline-block"  name="select1"  value="{!v.show}" onchange="{!c.setShow}">
                                        <option value="5">5</option>
                                        <option value="10">10</option>
                                        <option value="25">25</option>
                                        <option value="50">50</option>
                                    </lightning:select>
                                </div>
                            </div>
                        </div>
                    </aura:if>
                    <aura:if isTrue="{!v.Payments.length>0}">
                        
                        <div class="col-md-3 SupplierPPaymnt-class24" >
                            Showing <span class="text-lightblue">{!v.startCount}-{!v.endCount}</span> of total <span class="text-lightblue"> {!v.recSize} </span> Records
                        </div>
                        
                    </aura:if> 
                    
                    <aura:if isTrue="{!v.Payments.length>0}">
                        
                        <div class="col-md-3 SupplierPPaymnt-class25" >
                            <div class="pb-3" >
                                <nav aria-label="Page navigation example" >
                                    <ul class="pagination SupplierPPaymnt-class26">
                                        <li class="SupplierPPaymnt-class29">
                                            <a class="{!if(1 >= v.startCount,'SupplierPPaymnt-class27','SupplierPPaymnt-class28')}"  onclick="{!c.PreviousFirst}"> &lt;&lt; </a> <!-- -->
                                        </li>
                                        <li class="SupplierPPaymnt-class24" >
                                            <a class="{!if(1 >= v.startCount,'SupplierPPaymnt-class27','SupplierPPaymnt-class28')}"  onclick="{!c.Previous}"> Previous</a> <!-- -->
                                        </li>
                                        
                                        <li class="padding:0px;">
                                            <a class="{!if(v.endCount == v.recSize,'SupplierPPaymnt-class27','SupplierPPaymnt-class28')}" onclick="{!c.Next}">Next </a> <!--  -->
                                        </li>
                                        <li class="SupplierPPaymnt-class29">
                                            <a class="{!if(v.endCount == v.recSize,'SupplierPPaymnt-class27','SupplierPPaymnt-class28')}" onclick="{!c.NextLast}">&gt;&gt; </a> <!--  -->
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </aura:if> 
                    <aura:if isTrue="{!v.Payments.length>0}">
                        
                        <div class="col-md-3" >
                            <div class="mb-1" >
                                <div class="slds-grid">
                                    <div class="slds-col SupplierPPaymnt-class24">
                                        Page 
                                    </div>
                                    <div class="slds-col">
                                        <lightning:input type="number" variant="label-hidden" aura:id="ik" value="{!v.PageNum}" oncommit="{!c.OfsetChange}" class="width100p"/> 
                                    </div>
                                    <div class="slds-col SupplierPPaymnt-class24" ><span class="text-lightblue"> of &nbsp;&nbsp;{!v.PNS.length}</span>
                                    </div>
                                </div>
                            </div>
                        </div> 
                    </aura:if>
                </div>
            </div></aura:if>
        <!--Pagination End-->
    </div>
</aura:component>