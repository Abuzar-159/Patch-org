                                                                                        <div class="text-muted"><strong>{!$Label.c.MO_Fulfilled}</strong></div>
                                                                                    </div>
                                                                                    <div class="col-7 text-left">
                                                                                        <span class="text-black me-2"><span class="mdi mdi-arrow-up-bold"></span>
                                                                                            <span class="slds-text-heading-small">
                                                                                                {!bo.ActualWeight} &nbsp; {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                                            </span>
                                                                                        </span>
