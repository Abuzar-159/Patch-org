                                                                    <div class="row">

                                                                        <div class="col-md-5">
                                                                            <div class="{!if(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c || v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c,'','')}">
                                                                                <!--
                                                                                <aura:if isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                    <div class="slds-grid slds-wrap">
                                                                                        <div class="col-md-12 slds-m-top-small">
                                                                                            <span class="slds-text-heading_xx-small"><strong class="BuildSchedule_M-newClass90">{!$Label.c.Serial_MO}</strong>
                                                                                                <span class="BuildSchedule_M-newClass92">*</span></span>
                                                                                        </div>
                                                                                        <div class="col-md-12 slds-m-top-x-smal" onmouseover="{!c.lookupClickSerialFor}">
                                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisn" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Serial__c}"
                                                                                                                 inputStyleclass="slds-input" qry="{!v.qry}" />
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>-->
                                                                                <aura:if isTrue="{!and(!v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c,v.ManuOrder.ERP7__Product__r.ERP7__Lot_Tracked__c)}">
                                                                                    <div class="slds-grid slds-wrap">
                                                                                        <div class="col-md-12 slds-m-top--small ">
                                                                                            <span class="slds-text-heading_xx-small"> <strong class="BuildSchedule_M-newClass90">{!$Label.c.Batch_MO}</strong>
                                                                                                <span class="BuildSchedule_M-newClass92">*</span></span>
                                                                                        </div>
                                                                                        <div class="col-md-12 slds-m-top--x-small " onmouseover="{!c.lookupClickBatchFor}">
                                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solibt" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__MO_WO_Material_Batch_Lot__c}" inputStyleclass="slds-input" qry="{!v.qry}" />
                                                                                        </div>
                                                                                    </div>
                                                                                </aura:if>
