                                                <aura:iteration items="{!v.AllWOs}" var="BWO" indexVar="currentWOindex">

                                                    <aura:If isTrue="{!and(BWO.Id != v.WorkOrder.Id, BWO.ERP7__Status__c == 'Complete')}">
