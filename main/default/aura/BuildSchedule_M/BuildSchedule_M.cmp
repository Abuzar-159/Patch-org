                                                                        <th scope="col">
                                                                            <div class="slds-truncate2" >Status</div>
                                                                        </th>
                  -->
                                                                                <th scope="col">
                                                                                    <div class="slds-truncate2" >{!$Label.c.NewCase_Action}</div>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <aura:iteration var="TCE" indexVar="TCEC" items="{!v.TimeCardEntries}">
