                                                                                <aura:if isTrue="{!(bo.Stock * bo.WeightMultiplier > 0)}">
                                                                                    <button class="slds-button slds-button_brand text-center color-white BuildSchedule_M-newClass101"  onclick="{!c.CaptureWeight}">{!$Label.c.Capture}</button>
                                                                                    <aura:set attribute="else"> <button class="slds-button branddisabled BuildSchedule_M-newClass101" disabled="">{!$Label.c.Capture}</button> </aura:set>
                                                                                </aura:if>
                                                                            </aura:if>
                                                                        </div>
