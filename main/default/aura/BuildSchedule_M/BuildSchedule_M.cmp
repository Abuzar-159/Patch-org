                                                                                        <div class="slds-text-heading_xx-small slds-m-top--x-small"><strong>{!$Label.c.Serial}</strong><span class="BuildSchedule_M-newClass92">*</span></div>
                                                                                        <div class="slds-m-top--x-small" onmouseover="{!c.lookupClickSerial}">
                                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="solisn" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Serial__c}" inputStyleclass="slds-input" qry="{!v.qry}"/>
                                                                                        </div>
                                                                                        <div class="slds-m-top-/-x-small" style="padding: 10px 0px;">
                                                                                            <strong>Stock :</strong> {!v.SOLI_SerialStock*bo.WeightMultiplier}
                                                                                        </div>
                                                                                    </aura:if>
