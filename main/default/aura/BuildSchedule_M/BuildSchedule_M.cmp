                                                                                </th>

                                                                                <th class="slds-is-sortable" scope="col">
                                                                                    <div class="slds-truncate2">
                                                                                        {!$Label.c.MO_Fulfilled}
                                                                                    </div>
                                                                                </th>
                                                                                <th class="slds-is-sortable" scope="col">
                                                                                    <div class="slds-truncate2" >
                                                                                        {!$Label.c.Consumed}
                                                                                    </div>
                                                                                </th>
                                                                                <th class="slds-is-sortable" scope="col">
                                                                                    <div class="slds-truncate2" >
                                                                                        {!$Label.c.Scrapped_Waste}
                                                                                    </div>
                                                                                </th>
                                                                                <th class="slds-is-sortable" scope="col">
                                                                                    <div class="slds-truncate2" >
                                                                                        {!$Label.c.Stock}
                                                                                    </div>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                                            <aura:if isTrue="{!bo.Feature.Name != undefined}" >

                                                                                <tr class="BuildSchedule_M-newClass68">

                                                                                    <td align="center" valign="middle" colspan="10" class="BuildSchedule_M-newClass69">
                                                                                        <div class="BuildSchedule_M-newClass70">
                                                                                            <aura:if isTrue="{!bo.Feature.Id != undefined}" >
                                                                                                <h1 class="slds-text-heading_small BuildSchedule_M-newClass71" >{!bo.Feature.Name}</h1></aura:if>
                                                                                        </div>
                                                                                    </td>

                                                                                </tr>

                                                                            </aura:if>
                                                                            <tbody>
                                                                                <tr class="slds-hint-parent" >
                                                                                    <aura:if isTrue="{!v.linksNewOptions}">
                                                                                        <td class="slds-is-sortable BuildSchedule_M-newClass72" scope="col">
                                                                                            <div class="slds-grid slds-truncate2" name="{!i}">
                                                                                                <div class="slds-col">
                                                                                                    <lightning:button onclick="{!c.EditMRP}" class="neutralC" name="{!i}" >
                                                                                                        <a href="javascript:void(0)" data-toggle="modal" data-target="#myModale" title="Edit Product" class="BuildSchedule_M-newClass73">
                                                                                                            <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" class="BuildSchedule_M-newClass74" />
                                                                                                        </a>
                                                                                                    </lightning:button>
                                                                                                </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <aura:if isTrue="{!v.showVendorCode}">
                                                                                        <td scope="row" data-label="Product code" valign="middle" class="BuildSchedule_M-newClass75">
                                                                                            <div class="slds-truncate"> {!bo.MRP.ERP7__MRP_Product__r.ProductCode} </div>
                                                                                        </td>
                                                                                        <td scope="row" data-label="vendor code" valign="middle" class="BuildSchedule_M-newClass75">
                                                                                            <div class="slds-truncate">{!bo.MRP.ERP7__MRP_Product__r.ERP7__Vendor_product_Name__c} </div>
                                                                                        </td>
                                                                                    </aura:if>
                                                                                    <td scope="row" data-label="Purchase Order" valign="middle" class="BuildSchedule_M-newClass75">
                                                                                        <div class="slds-truncate2" title="">

                                                                                            <span class="BuildSchedule_M-newClass76">
                                                                                                <lightning:formattedUrl value="{!'/'+bo.MRP.ERP7__MRP_Product__c}" label="{!bo.MRP.ERP7__MRP_Product__r.Name}" target="_blank" class="fcolor"/>
                                                                                            </span>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass77">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass77">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                {!bo.MRP.ERP7__Status__c}
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass77">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                {!bo.MRP.ERP7__Total_Amount_Required__c}
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>

                                                                                    <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass77">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                <!-- <a href="javascript:void(0)" data-mrpcount="{!i}" class="BuildSchedule_M-newClass78" onclick="{!c.SelectMRP}" data-toggle="modal" data-target="#WeightCapture" title="Weight Capture" > </a> -->
                                                                                                {!bo.MRP.ERP7__Fulfilled_Amount__c}

                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Quantity" class="BuildSchedule_M-newClass77">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                {!bo.MRP.ERP7__Consumed_Quantity__c}
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Stock Quantity" class="BuildSchedule_M-newClass84">
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                {!bo.MRP.ERP7__Scrapped_Quantity__c}
                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Stock " valign="middle" class="{!bo.bgColor}"><!--{!bo.bgColor}-->
                                                                                        <div class="slds-form-element slds-truncate2">
                                                                                            <div class="slds-form-element__control">
                                                                                                <lightning:formattedNumber value="{! (bo.Stock * bo.WeightMultiplier) }"  minimumFractionDigits="2" maximumFractionDigits="2"/>
                                                                                                <!-- {!(bo.Stock * bo.WeightMultiplier)} 09/10/13 SM-->

                                                                                            </div>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td valign="middle" class="BuildSchedule_M-newClass79">
                                                                                        <aura:If isTrue="{!and(bo.MO.Id == undefined, bo.MRP.ERP7__MRP_Product__r.ERP7__Issue_Manufacturing_Order__c == true)}">
                                                                                            <div class="erp_Mark7 slds-no-flex BuildSchedule_M-newClass80">

                                                                                                <lightning:buttonMenu alternativeText="{!$Label.c.Show_menu}" variant="border" onselect="{!c.menuAction}" iconSize="small" menuAlignment="right">
                                                                                                    <lightning:menuItem value="{!bo.MRP.Id}" label="{!$Label.c.Create_Manufacturing_Order}" />
                                                                                                </lightning:buttonMenu>

                                                                                            </div>
                                                                                        </aura:If>
                                                                                    </td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </aura:iteration>
                                                                        <tr class="BuildSchedule_M-newClass81">
                                                                            <td colspan="10" class="BuildSchedule_M-newClass82">
                                                                                &nbsp;
                                                                            </td>
                                                                        </tr>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- New MRP Modal -->
                                                    <section id="myModal9" aura:id="newMRPModal" role="dialog" tabindex="-1" class="slds-modal slds-modal_medium" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">


                                                        <div class="slds-modal__container">
                                                            <!-- Modal content-->
                                                            <header class="slds-modal__header slds-modal__header_empty">
                                                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.closeNewMRPModal}">
                                                                    <lightning:icon iconName="utility:close" variant="bare"></lightning:icon>

                                                                    <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                                </button>

                                                            </header>
                                                            <div class="slds-modal__content slds-p-around_medium min-height340" id="modal-content-id-1">



                                                                <fieldset class="slds-form--compound">
                                                                    <div class="slds-form-element__group">
                                                                        <h2 class="slds-align-middle BuildSchedule_M-newClass116" title="">{!v.editErrorMsg}</h2>
                                                                        <div class="row">

                                                                            <div class="col-md-6">
                                                                                <lightning:input type="text" aura:id="name"  value="{!v.NewMRP.Name}" label="Name" required="true"/>
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <label class="slds-form-element__label" for="input-02">{!$Label.c.AddSubscription_Product}<span class="BuildSchedule_M-newClass92"> *</span></label>
                                                                                <c:CustomInputLookUp objectAPIName="Product2" aura:id="bom" IconName="standard:product" selectedRecordId="{!v.NewMRP.ERP7__MRP_Product__c}" inputStyleclass="slds-input"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </fieldset>
                                                                <fieldset class="slds-form--compound">
                                                                    <div class="slds-form-element__group">
                                                                        <div class="row pt-2">
                                                                            <div class="col-md-6">
                                                                                <label class="slds-form-element__label" for="input-02">{!$Label.c.Bill_Of_Material}<span class="BuildSchedule_M-newClass92"> *</span></label>
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__BOM__c" aura:id="bom" IconName="standard:orders" selectedRecordId="{!v.NewMRP.ERP7__BOM__c}" inputStyleclass="slds-input"/>
                                                                            </div>
                                                                            <div class="col-md-6 slds-m-top--xx-small">
                                                                                <lightning:input type="Number" label="{!$Label.c.Quantity_Required}" aura:id="num" value="{!v.NewMRP.ERP7__Total_Amount_Required__c}" required="true"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </fieldset>
                                                                <fieldset class="slds-form--compound">
                                                                    <div class="slds-form-element__group">
                                                                        <div class="row">
                                                                            <div class="col-md-12 slds-m-top--xx-small">
                                                                                <lightning:textarea aura:id="notes" label="{!$Label.c.Notes}"
                                                                                                    class="slds-textareaa height200"
                                                                                                    maxlength="500" messageWhenTooLong="A maximum of 500 characters are allowed."                                                                                              value="{!v.NewMRP.ERP7__Notes__c}"
                                                                                                    />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </fieldset>
                                                            </div>
                                                            <footer class="slds-modal__footer text-center">
                                                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeNewMRPModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                                                                <button class="slds-button slds-button--brand" onclick="{!c.updateMRP}">{!$Label.c.ContractConsole_Save}</button>

                                                            </footer>

                                                        </div>
                                                    </section>

                                                    <!-- new MRP Modal END -->
                                                    <!-- edit MRP Modal -->
                                                    <div id="myModale" aura:id="editMRPModal" class="slds-modal" role="dialog">
                                                        <div class="modal-dialog modal-medium">
                                                            <!-- Modal content-->
                                                            <div class="modal-content">

                                                                <div class="modal-body BuildSchedule_M-newClass118">
                                                                    <h2 class=" slds-m-right-small slds-align-middle BuildSchedule_M-newClass119" title="">{!v.editErrorMsg}</h2>
                                                                    <div class="row slds-m-top--xx-small">
                                                                        <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                            <div class="slds-form-element" >
                                                                                <label class="slds-form-element__label" for="text-input-01" > {!$Label.c.AddSubscription_Product}</label>
                                                                                <div class="slds-form-element__control">
                                                                                    <lightning:formattedText label="{!$Label.c.AddSubscription_Product}" value="{!v.MRPEdit.MRP.ERP7__MRP_Product__r.Name}"></lightning:formattedText>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                            <div class="slds-form-element" >
                                                                                <div class="slds-form-element__control">
                                                                                    <lightning:input label="{!$Label.c.QuotationPDF_Quantity}" required="true" type="Number" class="" value="{!v.MRPEdit.MRP.ERP7__Total_Amount_Required__c}" disabled="{!v.MRPEdit.MRP.ERP7__BOM__r.ERP7__Is_Protected__c}"></lightning:input>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                                                            <div class="slds-form-element" >
                                                                                <label class="slds-form-element__label" for="text-input-01" > {!$Label.c.Stock}</label>
                                                                                <div class="slds-form-element__control">
                                                                                    <lightning:formattedText class="" value="{!v.MRPEdit.Stock}" label="Stock"></lightning:formattedText>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="row BuildSchedule_M-newClass120">
                                                                        <div class="col-md-12">
                                                                            <h1 class="BuildSchedule_M-newClass121">{!$Label.c.BOM_Variances}</h1>
                                                                        </div>
                                                                    </div>
                                                                    <div class="BuildSchedule_M-newClass122">
                                                                        <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-m-top--small">
                                                                            <thead>
                                                                                <tr class="slds-text-title--caps">
                                                                                    <th class="slds-is-sortable " scope="col">
                                                                                        <div class="slds-truncate2" >
                                                                                            {!$Label.c.NewCase_Action}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="slds-is-sortable " scope="col">
                                                                                        <div class="slds-truncate2" >
                                                                                            {!$Label.c.AddSubscription_Product}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="slds-is-sortable" scope="col">
                                                                                        <div class="slds-truncate2">
                                                                                            {!$Label.c.Qty_Pick}
                                                                                        </div>
                                                                                    </th>
                                                                                    <th class="slds-is-sortable" scope="col">
                                                                                        <div class="slds-truncate2" >
                                                                                            {!$Label.c.Stock}
                                                                                        </div>
                                                                                    </th>
                                                                                </tr>
                                                                            </thead>
                                                                            <aura:iteration items="{!v.NewMRPs.MRPSS}" var="do" indexVar="y">
                                                                                <tbody>
                                                                                    <tr class="slds-hint-parent" >
                                                                                        <th class="slds-is-sortable BuildSchedule_M-newClass77" scope="col">
                                                                                            <div class="slds-truncate2 BuildSchedule_M-newClass123" name="{!y}">
                                                                                                <lightning:input type="checkbox" checked="{!do.isSelect}" onchange="{!c.Evaluate}"></lightning:input>
                                                                                            </div>
                                                                                        </th>
                                                                                        <th scope="row" data-label="Product" class="BuildSchedule_M-newClass77">
                                                                                            <div class="slds-truncate2" title="">
                                                                                                <lightning:formattedText value="{!do.MRP.Name}"></lightning:formattedText>
                                                                                            </div>
                                                                                        </th>
                                                                                        <td data-label="Quantity" class="BuildSchedule_M-newClass124">
                                                                                            <div class="slds-truncate2" title="">
                                                                                                <lightning:input type="Number" class="" value="{!do.Qnty}" disabled="{!v.MRPEdit.MRP.ERP7__BOM__r.ERP7__Is_Protected__c}"></lightning:input>
                                                                                            </div>
                                                                                        </td>
                                                                                        <td data-label="Stock " class="BuildSchedule_M-newClass124">
                                                                                            <div class="slds-form-element slds-truncate2">
                                                                                                <div class="slds-form-element__control">
                                                                                                    {!do.Stock}
                                                                                                </div>
                                                                                            </div>
                                                                                        </td>
                                                                                    </tr>
                                                                                </tbody>
                                                                            </aura:iteration>
                                                                        </table>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-12 BuildSchedule_M-newClass86">
                                                                    <c:ProjectLookups type="Account" aura:id="OrgName" value="{!v.custInvoiceTest.ERP7__Account__c}" className="slds-input" />
                                                                </div>
                                                                <footer class="slds-modal__footer text-center">
                                                                    <button class="slds-button slds-button--neutral" onclick="{!c.closeEditMRPModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                                                                    <button class="slds-button slds-button--brand" onclick="{!c.updateMRPNew}">{!$Label.c.Update}</button>

                                                                </footer>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- edit MRP Modal END-->
                                                    <div class="slds-backdrop" aura:id="myMRPModalBackdrop"></div>
                                                </div>

                                                <!-- @end of Tab 5 -->


                                                <div class="{!(v.resourceTab)?'slds-show':'slds-hide'}" id="ResourceAllocation" role="tabpanel">
                                                    <div class="panel-body bg-white BuildSchedule_M-newClass65">
                                                        <div class="row slds-m-top--small">
                                                            <div class="col-md-12">
                                                                <div class="BuildSchedule_M-newClass52">
                                                                    {!$Label.c.Allocated_Resources}
                                                                    <!--<i class="fa fa-refresh erp-rotation BuildSchedule_M-newClass62" id="rot1" aria-hidden="true" onclick="{!c.Reload1}"></i>-->
                                                                    <aura:if isTrue="{!(v.CapacityPlanner.Id != undefined)}">
                                                                        <div class="dropdown float-end">
                                                                            <div class="maqdropdown">
                                                                                <a class="slds-button slds-button_brand  text-white" href="javascript:void(0)"  onclick="{!c.openResourceAllocationModal}" title="Resource Allocation">
                                                                                    <i class="fa fa-server" aria-hidden="true"></i> &nbsp; {!$Label.c.Resource_Allocation} <span class="caret"></span>
                                                                                </a>
                                                                            </div>
                                                                        </div>
                                                                    </aura:if>
                                                                </div>
                                                                <!-- Resource Allocation table -->
                                                                <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover" >
                                                                    <thead>
                                                                        <tr class="slds-text-title--caps">
                                                                            <th class="slds-is-sortable " scope="col">
                                                                                <div class="slds-truncate2">
                                                                                    {!$Label.c.NewCase_Action}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable " scope="col">
                                                                                <div class="slds-truncate2">
                                                                                    {!$Label.c.Name_ManageLeave}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.Resource_Group}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.Employee_StockTake}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.Machine}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.Type_ManageLeave}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.AddSubscription_Start_Date}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.CreateClubcard_End_Date}
                                                                                </div>
                                                                            </th>
                                                                            <th class="slds-is-sortable" scope="col">
                                                                                <div class="slds-truncate2" >
                                                                                    {!$Label.c.Hours_Timesheets}
                                                                                </div>
                                                                            </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="BuildSchedule_M-newClass125">
                                                                        <aura:iteration items="{!v.RAS}" var="RA" indexVar="i">
                                                                            <tr class="slds-hint-parent">
                                                                                <td class="slds-is-sortable BuildSchedule_M-newClass124" scope="row" height="47px">
                                                                                    <div class="slds-grid slds-truncate2" name="{!i}">
                                                                                        <div class="slds-col">
                                                                                            <lightning:button onclick="{!c.DeleteRecordRA}" class="neutralC" name="{!RA.Id}">
                                                                                                <a href="javascript:void(0)" title="delete" class="BuildSchedule_M-newClass110">
                                                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="BuildSchedule_M-newClass74" />
                                                                                                </a>
                                                                                            </lightning:button>
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td  data-label="Purchase Order" height="47px" class="BuildSchedule_M-newClass124">
                                                                                    <div class="slds-truncate2" title="">{!RA.Name}  </div>
                                                                                </td>
                                                                                <td data-label="Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            {!RA.ERP7__Resource_Group__r.Name}
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            {!RA.ERP7__Employees__r.Name}
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            {!RA.ERP7__Machine__r.Name}
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            {!RA.ERP7__Type__c}
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            <lightning:formattedDateTime value="{!RA.ERP7__Start_Date__c}"  />
                                                                                            <!-- format="MMM dd, yyyy hh:mm a z" timezone="America/Los_Angeles" -->
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            <lightning:formattedDateTime value="{!RA.ERP7__End_Date__c}"/>
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                                <td data-label="Stock Quantity" class="BuildSchedule_M-newClass77">
                                                                                    <div class="slds-form-element slds-truncate2">
                                                                                        <div class="slds-form-element__control">
                                                                                            {!RA.ERP7__Hours__c}
                                                                                        </div>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        </aura:iteration>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="slds-backdrop" aura:id="myResourceAllocationModalBackdrop"></div>
                                                </div>
                                                <!-- Drawing tab-->
                                                <div class="{!(v.drawingTab)?'slds-show':'slds-hide'}" id="drawing" role="tabpanel">
                                                    <div class="panel-body BuildSchedule_M-newClass126">
                                                        <div class="row">
                                                            <div class="col-md-3 slds-m-top--small">
                                                                <table class="slds-table slds-table-bordered" width="100%">
                                                                    <aura:iteration var="OAs" indexVar="OA_counts" items="{!v.OperationAttachments}">
                                                                        <aura:if isTrue="{!(OAs.Attachments.length > 0)}">
                                                                            <tr class="operation-head ">
                                                                                <td  width="90%" class="operation-headtd1">
                                                                                    <h6>{!OAs.Operation.Name}</h6>
                                                                                </td>
                                                                                <td width="10%" class="operation-headtd2">
                                                                                    &nbsp;
                                                                                </td>
                                                                            </tr>
                                                                            <aura:iteration var="As" indexVar="A_counts" items="{!OAs.Attachments}">
                                                                                <tr class="{!if(As.Id == v.Attachment.Id,'actives','')}">
                                                                                    <td width="90%" name="{!A_counts}" par="{!OA_counts}" class="{!if(As.Id == v.Attachment.Id,'operation-headtd11 actives','operation-headtd11')}">
                                                                                        <div class="{!if(As.Id == v.Attachment.Id,'actives BuildSchedule_M-newClass107','inactives BuildSchedule_M-newClass107')}" title="{!A_counts}" id="{!OA_counts}"  onclick="{!c.SelectAttachment}">
                                                                                            {!As.Name}
                                                                                        </div>
                                                                                    </td>
                                                                                    <td width="10%" name="{!A_counts}" par="{!OA_counts}" class="{!if(As.Id == v.Attachment.Id,'operation-headtd22 actives','operation-headtd22')}">
                                                                                        <!-- <span class="{!if(As.Id == v.Attachment.Id,'fa fa-download actives','fa fa-download inactives')}">
                                                                                <lightning:formattedUrl label=" " value="{!'/servlet/servlet.FileDownload?file='+As.Id}" target="_blank" />
                                                                                </span>-->
                                                                                        <a href="{!'/servlet/servlet.FileDownload?file='+As.Id}" target="_blank" >
                                                                                            <i class="{!if(As.Id == v.Attachment.Id,'fa fa-download actives','fa fa-download inactives')}" aria-hidden="true"></i>
                                                                                        </a>
                                                                                    </td>
                                                                                </tr>
                                                                            </aura:iteration>
                                                                            <br/>
                                                                        </aura:if>
                                                                    </aura:iteration>
                                                                </table>
                                                            </div>
                                                            <div class="col-md-9 slds-m-top--small">
                                                                <div class="list-group">
                                                                    <img src="{!'/servlet/servlet.FileDownload?file='+v.Attachment.Id}" class="{!if(v.Attachment.Id != undefined,'BuildSchedule_M-newClass85','BuildSchedule_M-newClass86')}" width="50"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>


                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <section role="dialog" tabindex="-1" class="slds-modal fade slds-modal_small" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" id="myModalSelectWOs" aura:id="selectWOsModal">
                    <!--<div class="slds-modal fade MOs_class53" id="myModalSelectWOs" aura:id="selectWOsModal" role="dialog" >-->
                    <div class="slds-modal__container">
                        <header class="slds-modal__header slds-modal__header_empty">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.closeSelectWOsModal}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="medium"></lightning:icon>

                                <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                            </button>

                        </header>
                        <!-- Modal content-->
                        <div class="modal-content" style="min-height:400px;overflow:auto;">
                            <div class="slds-modal__content slds-p-around_medium">
                                <div class="table-responsive MOs_class27 MOs_height" tabindex="1">
                                    <table class="table" data-aura-rendered-by="555:495;a">
                                        <thead>
                                            <tr class="slds-text-title--caps">
                                                <th class="slds-is-sortable" scope="col">
                                                    <div class="slds-truncate"> {!$Label.c.Work_Orders} </div>
                                                </th>

                                            </tr>
                                        </thead>

                                        <tbody>
                                            <tr class="slds-hint-parent">
                                                <td data-label="Work Order">
                                                    <div class="slds-grid">
                                                        <!--<div class="slds-truncate" >{!i +1+ '. '}&nbsp;</div>-->
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <strong>
                                                                    <a data-record-id = "{!v.WorkOrder.Id}" title="{!v.WorkOrder.Name}">
                                                                        <div class="slds-truncate2" > {!v.WorkOrder.Name}</div>
                                                                    </a>
                                                                </strong>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                            <aura:if isTrue="{!and(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                <tr>
                                                    <td colspan="10">
                                                        <table class="slds-table slds-table_bordered slds-table_fixed-layout slds-table_resizable-cols">
                                                            <thead>
                                                                <tr>
                                                                    <th>
                                                                        <div class="slds-truncate"> {!$Label.c.AddSubscription_Product} </div>
                                                                    </th>
                                                                    <th>
                                                                        <div class="slds-truncate">{!$Label.c.MO_ReqQty}</div>
                                                                    </th>
                                                                    <th>
                                                                        <div class="slds-truncate"> {!$Label.c.MO_Fulfilled}</div>
                                                                    </th>
                                                                    <th>
                                                                        <div class="slds-truncate"> Stock </div>
                                                                    </th>
                                                                    <th>
                                                                        <div class="slds-truncate">Qty </div>
                                                                    </th>
                                                                    <th>
                                                                        <div class="slds-truncate"> &nbsp; </div>
                                                                    </th>
                                                                </tr>
                                                            </thead>

                                                            <aura:iteration items="{!v.MRPs}" var="MRP" indexVar="x">
                                                                <aura:if isTrue="{!(MRP.MRP.ERP7__Work_Order__c == v.WorkOrder.Id)}">
                                                                    <tr>
                                                                        <td>
                                                                            <div class="slds-truncate2">
                                                                                <span class=""><lightning:formattedUrl value="{!'/'+MRP.MRP.ERP7__MRP_Product__c}" label="{!MRP.MRP.ERP7__MRP_Product__r.Name}" target="_blank" /> </span>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="slds-truncate2">
                                                                                {!MRP.MRP.ERP7__Total_Amount_Required__c} &nbsp;{!MRP.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c}
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            {!MRP.MRP.ERP7__Fulfilled_Amount__c}
                                                                        </td>
                                                                        <td>
                                                                            <lightning:formattedNumber value="{!(MRP.Stock * MRP.WeightMultiplier) }"  minimumFractionDigits="2" maximumFractionDigits="2"/>
                                                                        </td>
                                                                        <!-- <td>
                                                                                <div class="slds-form-element__control">
                                                                                    <lightning:input type="Number"  step="0.01" value="{!MRP.MRPQuantity}" onchange="{!c.EvaluteMRPQty}" title="{!MRP.MRP.Id}" disabled="{!(MRP.MRP.ERP7__Total_Amount_Required__c == MRP.MRP.ERP7__Fulfilled_Amount__c)}"></lightning:input>
                                                                                </div>
                                                                            </td>-->
                                                                        <td>
                                                                            <aura:if isTrue="{!(MRP.MRP.ERP7__Total_Amount_Required__c != MRP.MRP.ERP7__Fulfilled_Amount__c)}">
                                                                                <span class="slds-badge slds-theme_success cursor-pointer width93-prt" onclick="{!c.allocateForMRP}" name="{!MRP.MRP.Id}" title="For serial only 250 allocated">{!$Label.c.Allocate}</span>
                                                                                <!--button class="slds-button slds-button-/-brand" onclick="{!c.allocateForMRP}" name="{!MRP.MRP.Id}">{!$Label.c.Allocate}</button-->
                                                                                <aura:set attribute="else">
                                                                                    <span class="slds-badge slds-badge_inverse">Stock allocated</span>
                                                                                </aura:set>
                                                                            </aura:if>
                                                                        </td>

                                                                    </tr>
                                                                </aura:if>
                                                            </aura:iteration>
                                                        </table>

                                                    </td>
                                                </tr>

                                            </aura:if>
                                        </tbody>

                                    </table>
                                </div>
                            </div>
                            <footer class="slds-modal__footer text-center">
                                <button type="button" class="slds-button slds-button--neutral" onclick="{!c.closeSelectWOsModal}">{!$Label.c.Cancel_UserAvailabilities}</button>
                                <aura:if isTrue="{!!v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c}">
                                    <button class="slds-button slds-button--brand" onclick="{!c.ReserveMRPStocks}">{!$Label.c.Allocate}</button>
                                </aura:if>

                            </footer>
                        </div>
                    </div>
                    <!--</div>-->
                </section>
                <div class="slds-backdrop" aura:id="myselectWOsModalBackdrop"></div>
            </aura:if>
        </body>
    </div>
</aura:component>