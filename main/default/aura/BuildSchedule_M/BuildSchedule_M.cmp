                                                                                                                                    </aura:if>

                                                                                                                                    <lightning:button iconName="utility:close" variant="destructive" onclick="{!c.StopTask}" name="{!v.SelectedTask.Id}" title="close" class="slds-m-right_small pr-p5 slds-p-left_small"/>

                                                                                                                                </aura:if>

                                                                                                                                <aura:if isTrue="{!!v.Busy}">
                                                                                                                                    <aura:if isTrue="{!(v.SelectedTask.ERP7__Status__c == 'In Progress')}">
                                                                                                                                        <aura:if isTrue="{!(v.SelectedTask_TimeCardEntry.Id == undefined)}">

                                                                                                                                            <lightning:button iconName="utility:clock" label="Clock In" variant="brand"  title="Clock In" class="slds-m-right_small" onclick="{!c.StartTimeCardEntry}"/>

                                                                                                                                        </aura:if>
                                                                                                                                    </aura:if>
                                                                                                                                </aura:if>

                                                                                                                                <aura:if isTrue="{!v.Busy}">
