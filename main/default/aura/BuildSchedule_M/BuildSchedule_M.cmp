                                                <div class="slds-grid slds-grid pt-2 slds-p-left_medium">
                                                    <lightning:input type="checkbox" aura:id="selectAllSerials" checked="{!v.selectAllSerials}" label="Select" onchange="{!c.selectAllSerials}" class="slds-p-top_xx-small"></lightning:input>
