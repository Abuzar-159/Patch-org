                                                                                <div class="slds-grid slds-wrap">
                                                                                    <div class="col-4">
                                                                                        <div class="text-muted"><strong>{!$Label.c.MO_ReqQty}</strong></div>
                                                                                    </div>
                                                                                    <div class="col-8 text-left pl-2" >
                                                                                        <span class="text-black me-2 valign-top">
