<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes" access="global" controller="BuildWorkOrder">
    <!--WO execution page-->
    <head>
        <!--ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" /-->
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        <ltng:require styles="{!join(',',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css')}"  />
        <ltng:require styles="/resource/ERPCustomIcons/style/erp-play.css"/>
        <ltng:require styles="{!join(',',$Resource.ERPFonts + '/src/stylesheet.css')}"  />
        <ltng:require styles="resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/BuildSchedule_M.css"/>
        <ltng:require styles="/resource/ERP7__axoltmain/Assets/css/axolt-main.css" />
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/Manufacturing_orders.css"/>
    </head>

    <aura:attribute name="AutoSTockAllocationLimit" type="String" default="{!$Label.c.AutoStockLimit}"/>
    <aura:attribute name="SerialsLength" type="Integer" default="0"/>
    <aura:attribute name="showVendorCode" type="Boolean" default="false"/>
    <aura:attribute name="WPoptions" type="List" default="[]"/>
    <aura:attribute name="StartNo" type="Integer" default="0"/>
    <!--For checlists-->
    <aura:attribute name="showSerials" type="String" default="100"/>
        <aura:attribute name="SerialPopupErrorMsg" type="String" />
        <aura:attribute name="SerialNumber2Upsert" type="object" />
    <aura:attribute name="WipflowsShow" type="String" default="100"/>
    <aura:attribute name="WipflowsShowforBuild" type="String" default="200"/>
    <aura:attribute name="moSerialNosShow" type="String" default="100"/>
    <aura:attribute name="WipflowsShowStart" type="String" default="0"/>
    <aura:attribute name="moSerialNosShowStart" type="String" default="0"/>
    <aura:attribute name="taskStatus" type="String" default="{!$Label.c.TaskStatus}"/>
    <aura:attribute name="showScrapDetails" type="Boolean" default="false"/>
    <aura:attribute name="selectAllCheckbox" type="Boolean" default="false" />
    <aura:attribute name="selectAllSerials" type="Boolean" default="false" />
    <aura:attribute name="showProductDesc" type="Boolean" default="false"/>
    <aura:attribute name="showWC" type="Boolean" default="true"/>
    <aura:attribute name="showTaskSave" type="Boolean" default="true"/>
    <aura:attribute name="checkAll" type="Boolean" default="false"/>
    <aura:attribute name="showcheck" type="Boolean" default="true"/>
    <aura:attribute name="Checklist" type="Object" />
    <aura:attribute name="guidelinechecklist" type="object" />
    <aura:attribute name="guidelinexits" type="boolean" default="false"/>
    <aura:attribute name="rendertablist" type="List" />
    <aura:attribute name="showLoadingSpinner" type="boolean" default="false" />
    <aura:attribute name="qry" type="String"/>
    <aura:attribute name="NWO" type="String" />
    <aura:attribute name="PWO" type="String" />
    <aura:attribute name="agentWOId" type="String" default="" />
    <aura:attribute name="agentMOId" type="String" default="" />
    <aura:attribute name="agentToBuild" type="boolean" default="false" />
    <aura:attribute name="WCAP" type="Boolean" default="true" />
    <aura:attribute name="isReload" type="Boolean" default="true" />
    <aura:attribute name="PrintSB" type="Boolean" default="false" />
    <aura:attribute name="commitWIPFlow" type="Boolean" default="false" />
    <aura:attribute name="WeightCapture" type="Boolean" default="false"/>
    <aura:attribute name="Weight" type="Decimal" default="0.00"/>
    <aura:attribute name="TotalWeight" type="Decimal" default="0.00"/>
    <aura:attribute name="WeightPopupErrorMsg" type="String" default=""/>
    <aura:attribute name="WeightStr" type="String" default="0"/>
    <aura:attribute name="custInvoiceTest" type="Invoice__c" default="{sobjectType:'Invoice__c','ERP7__Account__c':''}"/>
    <aura:registerEvent name="SetQRYParam" type="c:SetQRYParam"/>
    <aura:attribute name="WorkOrder" type="WO__c" default="{'sObjectType':'ERP7__WO__c'}"/>
    <aura:attribute name="ManuOrder" type="Manufacturing_Order__c" default="{'sObjectType':'ERP7__Manufacturing_Order__c'}"/>
    <aura:attribute name="WO2Fin" type="WO__c" default="{sobjectType : 'WO__c'}"/>
    <aura:attribute name="Tasks" type="object[]"/>
    <aura:attribute name="tasklists" type="object[]"/>
    <aura:attribute name="FileList" type="object[]"/>
    <aura:attribute name="UOMCs" type="object[]" />
    <aura:attribute name="TimeCardEntries" type="object[]"/>
    <aura:attribute name="SelectedTask" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c'}"/>
    <aura:attribute name="Employee" type="object"/>
    <aura:attribute name="SelectedTask_TimeCardEntry" type="object"/>
    <aura:attribute name="TimeSheet" type="object"/>
    <aura:attribute name="NewTask" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c'}"/>
    <aura:attribute name="NewMRP" type="object"/>
    <aura:attribute name="NewNote" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="NewNoteTemp" type="Note" default="{'sObjectType':'Note'}"/>
    <aura:attribute name="NewMRPs" type="object"/>
    <aura:attribute name="Task" type="Actions_Tasks__c" default="{'sObjectType':'ERP7__Actions_Tasks__c',Name:'',ERP7__Notes__c : '',ERP7__Operation__c : '', ERP7__Operation__r : {Id : '' , Name :''}, ERP7__Process_Cycle__c : '', ERP7__Process_Cycle__r : {Id : '' , Name : ''},ERP7__Work_Center__c : '', ERP7__Work_Center__r :{Id : '', Name :''}  }"/>
    <aura:attribute name="OperationAttachments" type="object[]"/>
    <aura:attribute name="SelectedAttachments" type="object[]"/>
    <aura:attribute name="Signatures" type="object[]"/>
    <aura:attribute name="Signature" type="object"/>
    <aura:attribute name="SelectedNotes" type="object[]"/>
    <aura:attribute name="Attachment" type="Attachment" default="{'sObjectType':'Attachment'}"/>
    <aura:attribute name="NewSOLI" type="Stock_Outward_Line_Item__c" default="{sobjectType : 'Stock_Outward_Line_Item__c','ERP7__Material_Batch_Lot__c':'','ERP7__Serial__c':'','ERP7__MO_WO_Material_Batch_Lot__c':'','ERP7__MO_WO_Serial__c':''}"/>
    <aura:attribute name="MRPSS" type="object[]"/>
    <aura:attribute name="MRPs" type="object[]"/>
    <aura:attribute name="constantMRPs" type="object[]"/>
    <aura:attribute name="MRPEdit" type="object"/>
    <aura:attribute name="selectedMRP" type="object" />
    <aura:attribute name="ReserveStock" type="Boolean" default="false"/>
    <aura:attribute name="mySerialNos" type="object[]"/>
    <aura:attribute name="myBatchNos" type="object[]"/>
    <aura:attribute name="WO" type="String"/>
    <aura:attribute name="RD" type="String"/>
    <aura:attribute name="NAV" type="String"/>
    <aura:attribute name="Timer" type="String" default=""/>
    <aura:attribute name="errorMsg" type="String"/>
    <aura:attribute name="errorMsgPop" type="String"/>
    <aura:attribute name="editErrorMsg" type="String"/>
    <aura:attribute name="attUrl" type="String"/>
    <aura:attribute name="ToProduce" type="Decimal" default="0"/>
    <aura:attribute name="ToScrap" type="Decimal" default="0"/>
    <aura:attribute name="ExpectedDuration" type="String" default=""/>
    <aura:attribute name="RealDuration" type="String" default=""/>
    <aura:attribute name="Batch" type="Boolean" default="false"/>
    <aura:attribute name="Serial" type="Boolean" default="false"/>
    <aura:attribute name="Evaluate" type="Boolean" default="false"/>
    <aura:attribute name="Permit" type="Boolean" default="false"/>
    <aura:attribute name="Busy" type="Boolean" default="false"/>
    <aura:attribute name="moSerialNos" type="object[]" />
    <aura:attribute name="moBatchNos" type="object[]" />
    <aura:attribute name="RAS" type="object[]"/>
    <aura:attribute name="ResourcePopupErrorMsg" type="String"/>
    <aura:attribute name="ResourceStr" type="String" default=""/>
    <aura:attribute name="WorkPlanners" type="object[]"/>
    <aura:attribute name="StartTime" type="DateTime"/>
    <aura:attribute name="EndTime" type="DateTime"/>
    <aura:attribute name="SelectedWIP" type="object" />
    <aura:attribute name="SelectedWIPflow" type="object" />
    <aura:attribute name="WIPs" type="object" />
    <aura:attribute name="WIPFlows" type="object" />
    <aura:attribute name="AllWIPFlows" type="object" />
    <aura:attribute name="WIPFlowsAll" type="object" />
    <aura:attribute name="oldWIPFlows" type="object" default="{sObjectType :'ERP7__WIP_Flow__c'}"/>
    <aura:attribute name="scanValue" type="String" default=''/>
    <aura:attribute name="AvailableResources" type="object[]" />
    <aura:attribute name="CapacityPlanner" type="object" />
    <aura:attribute name="SelectedWP" type="String" default=""/>
    <aura:attribute name="selectedRR" type="String" default=""/>
    <aura:attribute name="selectedRRName" type="String" default=""/>
    <aura:attribute name="Fulfilled" type="Boolean" default="false" />
    <aura:attribute name="SelectedUOM" type="String" default=''/>
    <aura:attribute name="exceptionError" type="String" default=''/>
    <aura:attribute name="warningError" type="String" default=''/>
    <aura:attribute name="UOMS" type="object[]" />
    <aura:attribute name="AllWOs" type="object[]" />
    <aura:attribute name="allWOProducts" type="Product2[]" />
    <aura:attribute name="IsSignatureTab" type="Boolean" default="false"/>
    <aura:attribute name="signatureExist" type="Boolean" default="false"/>
    <aura:attribute name="checkDrawings" type="Boolean" default="false"/>

    <aura:attribute name="wipRerender" type="Boolean" default="true"/>
    <aura:attribute name="worksheetTab" type="Boolean" default="true"/>
    <aura:attribute name="drawingTab" type="Boolean" default="false"/>
    <aura:attribute name="timeTrackingTab" type="Boolean" default="false"/>
    <aura:attribute name="MRPSTab" type="Boolean" default="false"/>
    <aura:attribute name="resourceTab" type="Boolean" default="false"/>
    <aura:attribute name="currentProductionTab" type="Boolean" default="false"/>
    <aura:attribute name="serialorBatchesTab" type="Boolean" default="false"/>
    <aura:attribute name="signatureTab" type="Boolean" default="false"/>
    <aura:attribute name="isWOcomplete" type="Boolean" default="true"/>
    <aura:attribute name="wipFlowIndex" type="Integer" default="-1"/>
    <aura:attribute name="SOLI_SerialStock" type="Double" default="0"/>
    <aura:attribute name="SOLI_BatchStock" type="Double" default="0"/>
    <aura:attribute name="WIPflowQty" type="Integer" default="0"/>
    <aura:attribute name="showSAButton" type="Boolean" default="false"/>
    <aura:attribute name="linksNewOptions" type="Boolean" />
    <aura:attribute name="showCompleteWO" type="Boolean" />
    <aura:attribute name="showAutoStockAllocation" type="Boolean" default="false"/>
    <aura:attribute name="showManualStockAllocation" type="Boolean" default="false"/>
    <aura:attribute name="EnterconsumeQty" type="Boolean" default="false"/>
    <aura:attribute name="SerialsForAllocation" type="object[]" />

    <aura:handler name="init" value="{!this}" action="{!c.getAllDetails}" />
    <aura:method name="CaptureTheWeight" action="{!c.CaptureWeight}"></aura:method>
    <aura:method name="popInit" action="{!c.getAllDetails}"></aura:method>
    <aura:method name="BuildFinish" action="{!c.WO2Finish}"></aura:method>
    <aura:method name="loadSerialForAllocation" action="{!c.SerialForAllocation}"></aura:method>
    <aura:method name="FinishMethod" action="{!c.FinishTask}"></aura:method>
    <aura:method name="CompleteTask" action="{!c.CompleteTask}"></aura:method>

    <aura:method name="PreFinishTasks" action="{!c.PreFinishTask}"></aura:method>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__MO_WO_Serial__c}" action="{!c.SerialBOMValidation}"/>
    <aura:handler event="force:refreshView" action="{!c.getAllDetails}" />
    <aura:handler name="change" value="{!v.scanValue}" action="{!c.verifyScanCode}"/>
    <aura:handler name="change" value="{!v.ToProduce}" action="{!c.Consume_ScrapQty}"/>
    <aura:handler name="change" value="{!v.ToScrap}" action="{!c.Consume_ScrapQty}"/>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__Serial__c}" action="{!c.getSOLISerialStock}"/>
    <aura:handler name="change" value="{!v.NewSOLI.ERP7__Material_Batch_Lot__c}" action="{!c.getSOLIBatchStock}"/>
    <aura:handler name="cmpEvent" event="c:SignatureEvent" action="{!c.handleSignatureEvent}"/>

    <aura:attribute name="objDetail" type="Checklist__c" default="{'sobjectType' : 'Checklist__c'}"/>
    <aura:attribute name="controllingFieldAPI" type="string" default="ERP7__Comply__c" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI" type="string" default="ERP7__Result__c" description="store field API name of dependent field"/>
    <aura:attribute name="listDependingValues" type="list" default="['--- None ---']" description="to store dependent field values"/>
    <aura:attribute name="listControllingValues" type="String" default="" description="to store controller field values"/>
    <aura:attribute name="bDisabledDependentFld" type="boolean" default="true"/>
    <aura:attribute name="depnedentFieldMap" type="object" description="map to store dependent values with controlling value"/>
    <aura:attribute name="showchecklistvalue" type="boolean" default="false"/>
    <aura:attribute name="ControllingValue" type="String" default="" description="to store controller field values"/>

    <aura:attribute name="saPage" type="boolean" default="false"/>
    <aura:attribute name="fPage" type="boolean" default="false"/>
    <aura:attribute name="raPage" type="boolean" default="false"/>
    <aura:attribute name="mainPage" type="boolean" default="true"/>
    <aura:handler name="change" value="{!v.saPage}" action="{!c.manageScreen}"/>
    <aura:handler name="change" value="{!v.fPage}" action="{!c.manageScreen}"/>
    <aura:handler name="change" value="{!v.raPage}" action="{!c.manageScreen}"/>

    <aura:attribute name="showSerialNumGeneration" type="boolean" default="false"/>
    <aura:attribute name="FromSerialNum" type="Integer" default=""/>
    <aura:attribute name="SerialPrefix" type="String" default="{!$Label.c.Serial_Number_Format}"/>
    <aura:attribute name="TotalWIPQtyScrapped" type="Integer" default="0"/>
    <aura:attribute name="TotalWIPQtyProduced" type="Integer" default="0"/>
    <aura:attribute name="TypeOfWIP" type="String" default="Produced"/>
    <aura:attribute name="showWIPsection" type="boolean" default="true"/>
    <aura:attribute name="byPassWOComplete" type="boolean" default="false"/>
    <aura:attribute name="isFromMO" type="boolean" default="false"/>

    <aura:attribute name="selectWIPs" type="boolean" default="200"/>

    <aura:handler name="change" value="{!v.ControllingValue}" action="{!c.onControllerFieldChange}"/>

    <!-- added by shaguftha on 04/08/2023 -->
    <aura:attribute name="WIPflowType" type="String" default="Produced"/>
    <aura:attribute name="AllmoSerialNos" type="object[]" />
    <aura:attribute name="moSerialForProduction" type="object[]" />
        <aura:attribute name="RefreshSerials" type="Boolean" default="true"/>

    <!-- added for search WIPs section -->
    <aura:attribute name="showSearchWIP" type="Boolean" default="false" />
    <aura:attribute name="displayProducedSection" type="Boolean" default="false" />
    <aura:attribute name="maxCutValidation" type="Boolean" default="false" />
    <aura:attribute name="hideToProduceforMRP" type="Boolean" default="false" />
    <aura:attribute name="gradeList" type="object[]" />
    <aura:attribute name="WIPProducts" type="object[]"  />
    <aura:attribute name="selectedGrade" type="String"  default=""/>
    <aura:attribute name="selectedWIPProduct" type="String"  default=""  />
    <aura:attribute name="selectedWidth" type="String"  default=""  />
    <aura:attribute name="thickness" type="String"  default=""  />
    <aura:attribute name="searchWIP" type="String"  default=""  />
    <aura:attribute name="thicknessList" type="object[]"  />
    <aura:attribute name="SearchWIPFlows" type="object[]"  />
    <aura:attribute name="widthList" type="object[]"  />
    <aura:attribute name="lengthList" type="object[]"/>
    <aura:attribute name="length" type="String"  default=""/>
    <aura:attribute name="onlyManufacturedWIPFlows" type="object[]"  />
    <aura:attribute name="MaxAllowedCuts" type="Decimal" default="0" />
    <aura:attribute name="wipRecord" type="Object" />

    <aura:attribute name="startingSerial" type="String"  default=""/>
    <aura:attribute name="startNum" type="Integer"  default="0"/>
    <aura:attribute name="endNum" type="Integer"  default="200"/>
    <div aura:id="body">
        <!--Warning Message End-->
        <span class="BuildSchedule_M-newClass18">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>

        <body class="theme-bg">
            <!--Error Message-->
            <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed BuildSchedule_M-newClass12','slds-notify_container slds-is-fixed BuildSchedule_M-newClass13')}">
                <div class="slds-notify slds-notify_toast slds-theme_error BuildSchedule_M-newClass14" role="status">
                    <span class="slds-assistive-text">{!$Label.c.error}</span>
                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_x-small BuildSchedule_M-newClass15 mt-0" >{!v.exceptionError}&nbsp;
                        </h2>
                    </div>
                    <div class="slds-notify__close" >
                        <button class="slds-button slds-button_icon slds-button_icon-inverse slds-align-top" title="Close" onclick="{!c.closeError}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="close" />
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                        </button>
                    </div>
                </div>
            </div>
            <!--Error Message End-->

            <!--Warning Message-->
            <div class="{!if(and(v.warningError != '', v.warningError != undefined),'slds-notify_container slds-is-fixed  BuildSchedule_M-newClass12','slds-notify_container slds-is-fixed  BuildSchedule_M-newClass13')}" >
                <div class="slds-notify slds-notify_toast slds-theme_warning BuildSchedule_M-newClass14" role="status">
                    <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>
                    <span class="slds-icon_container slds-icon-utility-warning slds-m-right_x-small" title="Description of icon when needed">
                        <lightning:icon iconName="utility:warning" size="medium" alternativeText="{!$Label.c.warning_UsersShiftMatch}"/>
                    </span>
                    <div class="slds-notify__content">
                        <h2  class="slds-text-heading_x-small BuildSchedule_M-newClass15">
                            &nbsp;{!v.warningError}&nbsp;
                        </h2>
                    </div>
                    <div class="slds-notify__close outbound-class20">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.closeWarning}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="close" />
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                        </button>
                    </div>
                </div>
            </div>

            <aura:if isTrue="{!v.fPage}">
                <div class="erp_Mark7 erp_mark7 maqsood theme-bg">
                    <div>
                        <div class="theme-bg min-height85vh">
                            <div class="slds-page-header__name-title slds-p-around_xxx-small borderbottom-bs1">
                                <h4 class="page-title card-pricing headermt mt-0 mb-0">
                                    <a href="javascript:void(0);">
                                        <i class="card-pricing-icon text-primary fa fa-file-text plpt-bs1"></i>
                                        &nbsp;{!$Label.c.Work_in_Progress_WIPs}
                                    </a>
                                </h4>
                                <!-- Header 1
                                <h1 class="mb-0 pl-3">
                                    <span class="slds-page-header__title slds-truncate" title="Work in Progress(WIPs)">{!$Label.c.Work_in_Progress_WIPs}</span>
                                </h1>
                                -->

                            </div>
                            <!-- search WIP and filter section -->

                            <aura:if  isTrue="{!and(v.showSearchWIP,v.AllWIPFlows.length > 1)}">
                                <div class="slds-grid slds-wrap slds-p-left_medium slds-p-top_small">
                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12">
                                        <div class="slds-form-element__control">
                                            <lightning:input type="text" id="form-element-01" placeholder="{!$Label.c.Search_by_Name}" class="" value="{!v.searchWIP}" oncommit="{!c.getWIPs}"/>
                                        </div>
                                    </div>
                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_2-of-12 slds-large-size_2-of-12 slds-p-left_small">
                                        <div class="dropdown">
                                            <div class="dropbtn"> <i class="fa fa-filter fa-2x"></i></div>
                                            <div class="dropdown-content">
                                                <div class="slds-form-element">
                                                    <label class="slds-form-element__label" for="select-01">Grade</label>
                                                    <div class="slds-form-element__control">
                                                        <lightning:select name="grade"  label="grade" aura:id="grade" value="{!v.selectedGrade}" variant="label-hidden" onchange="{!c.getWIPs}" disabled="{!(v.gradeList.length == 0)}">
                                                            <aura:iteration items="{!v.gradeList}" var="item">
                                                                <option text="{!item}" value="{!item}" selected="{!v.selectedGrade == item}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                </div>
                                                <!--   <div class="slds-form-element">
                                                    <label class="slds-form-element__label" for="select-01">Select Product</label>
                                                    <div class="slds-form-element__control">
                                                        <lightning:select name="wipProduct"  label="wipProduct" aura:id="wipProduct" value="{!v.selectedWIPProduct}" variant="label-hidden" onchange="{!c.getWIPs}" disabled="{!(v.WIPProducts.length == 0)}">
                                                            <aura:iteration items="{!v.WIPProducts}" var="item">
                                                                <option text="{!item.label}" value="{!item.value}" selected="{!v.selectedWIPProduct == item.value}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                </div> -->


                                                <div class="slds-form-element__control slds-p-bottom_xx-small slds-p-top_xx-small">
                                                    <label class="slds-form-element__label" for="select-01">Thickness</label>
                                                    <lightning:select name="thickness"  label="thickness" aura:id="thickness" value="{!v.thickness}" variant="label-hidden" onchange="{!c.getWIPs}" disabled="{!(v.thicknessList.length == 0)}">
                                                        <aura:iteration items="{!v.thicknessList}" var="item">
                                                            <option text="{!item}" value="{!item}" selected="{!v.thickness == item}"/>
                                                        </aura:iteration>
                                                    </lightning:select>
                                                </div>
                                                <div class="slds-form-element">
                                                    <label class="slds-form-element__label" for="select-01">{!$Label.c.ShipmentManagement_Package_Width}</label>
                                                    <div class="slds-form-element__control">
                                                        <lightning:select name="grade"  label="grade" aura:id="grade" value="{!v.selectedWidth}" variant="label-hidden" onchange="{!c.getWIPs}" disabled="{!(v.widthList.length == 0)}">
                                                            <aura:iteration items="{!v.widthList}" var="item">
                                                                <option text="{!item}" value="{!item}" selected="{!v.selectedWidth == item}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                </div>
                                                <div class="slds-form-element__control slds-p-bottom_xx-small slds-p-top_xx-small">
                                                    <label class="slds-form-element__label" for="select-01">Length</label>
                                                    <lightning:select name="length" label="length" aura:id="length" value="{!v.length}" variant="label-hidden" onchange="{!c.getWIPs}" disabled="{!(v.lengthList.length == 0)}">
                                                        <aura:iteration items="{!v.lengthList}" var="item">
                                                            <option text="{!item}" value="{!item}" selected="{!v.length == item}"/>
                                                        </aura:iteration>
                                                    </lightning:select>
                                                </div>

                                            </div>
                                        </div>


                                    </div>
                                </div>
                            </aura:if>
                            <!-- end Search-->
                            <div class="slds-grid slds-wrap">
                                <div class="{!if(greaterthan(v.WIPFlows.length, 1),  'slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12',  'slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12')}">

                                    <aura:if isTrue = "{!greaterthan(v.WIPFlows.length,0)}">
                                        <!-- scenario 2-->
                                        <aura:if isTrue = "{!equals(v.WIPFlows.length,1)}">
                                            <div class="slds-p-around_xx-small pl-4">
                                                <div class="slds-grid slds-wrap">
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">

                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.AddSubscription_Product}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <!-- <a href="javascript:void(0);" tabindex="-1"><strong><lightning:formattedText value="{!v.WorkOrder.ERP7__Product__r.Name}"/></strong></a>-->
                                                            <aura:if isTrue="{!v.linksNewOptions}">
                                                                <a href="{!'/'+ v.WIPFlows[0].wipFlow.Id}" target="_blank" tabindex="-1">
                                                                    <strong><lightning:formattedText value="{!v.WIPFlows[0].wipFlow.ERP7__Product__r.Name}"/></strong>
                                                                </a>
                                                            </aura:if>
                                                            <aura:if isTrue="{!!v.linksNewOptions}">
                                                                <strong><lightning:formattedText value="{!v.WIPFlows[0].wipFlow.ERP7__Product__r.Name}"/></strong>
                                                            </aura:if>
                                                        </div>

                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small ">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.Ordered}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WIPFlows[0].wipFlow.ERP7__Quantity_Ordered__c}"/>
                                                        </div>

                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small ">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.Built_QTY}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WIPFlows[0].wipFlow.ERP7__Quantity__c}"/>
                                                        </div>
                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.WO_Scrapped_qty}</label>
                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WIPFlows[0].wipFlow.ERP7__Quantity_Scrapped__c}"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <aura:set attribute="else">
                                                <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12">

                                                    <div class="slds-grid slds-wrap">
                                                        <div class="scroll-bar-wrap">
                                                            <div class="scroll-box manufacturing-newClass28">
                                                                <aura:iteration items="{!v.WIPFlows}" var="WIPflow" indexVar="i" end="{!v.WipflowsShowforBuild}">
                                                                    <aura:if isTrue="{!AND(WIPflow.wipFlow.ERP7__Quantity_Ordered__c != (WIPflow.wipFlow.ERP7__Quantity__c + WIPflow.wipFlow.ERP7__Quantity_Scrapped__c), WIPflow.StockAllocated == true)}">
                                                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12 slds-p-around_x-small">
                                                                            <div onclick="{!c.SelectWIPflow}" data-index="{!i}" class="card shadow-mrr BuildSchedule_M-newClass158 mb-0">
                                                                                <div class="{!(v.SelectedWIPflow.Id == WIPflow.wipFlow.Id)?'card-body active-card pr-2':'card-body '}">
                                                                                    <div class="row">
                                                                                        <div class="col-md-12 p-0">
                                                                                            <div class="slds-grid slds-wrap">
                                                                                                <div class="col-md-4">
                                                                                                    <label class="" for="form-element-01">{!$Label.c.AddSubscription_Product}</label>
                                                                                                </div>
                                                                                                <div class="col-md-8">
                                                                                                    <div class="slds-form-element__control pt-1 slds-truncate max-widthBM">
                                                                                                        <aura:if isTrue="{!v.linksNewOptions}">
                                                                                                            <a href="{!'/'+ WIPflow.wipFlow.Id}" target="_blank" tabindex="-1">
                                                                                                                <strong><lightning:formattedText value="{!WIPflow.wipFlow.ERP7__Product__r.Name}"/></strong>
                                                                                                            </a>
                                                                                                        </aura:if>
                                                                                                        <aura:if isTrue="{!!v.linksNewOptions}">
                                                                                                            <strong><lightning:formattedText value="{!WIPflow.wipFlow.ERP7__Product__r.Name}"/></strong>
                                                                                                        </aura:if>

                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="slds-grid slds-wrap">

                                                                                                <div class="col-md-4">
                                                                                                    <label class="" for="form-element-01">{!$Label.c.Ordered}</label>
                                                                                                </div>
                                                                                                <div class="col-md-8">
                                                                                                    <div class="slds-form-element__control pt-1 slds-truncate">
                                                                                                        <lightning:formattedNumber value="{!WIPflow.wipFlow.ERP7__Quantity_Ordered__c}"/>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="slds-grid slds-wrap">
                                                                                                <div class="col-md-4 pr-0">
                                                                                                    <label class="" for="form-element-01">{!$Label.c.Built_QTY}</label>
                                                                                                </div>
                                                                                                <div class="col-md-8">
                                                                                                    <div class="slds-form-element__control pt-1 slds-truncate">
                                                                                                        <lightning:formattedNumber value="{!WIPflow.wipFlow.ERP7__Quantity__c}"/>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="slds-grid slds-wrap">
                                                                                                <div class="col-md-4 ">
                                                                                                    <label class="" for="form-element-01">{!$Label.c.WO_Scrapped_qty}</label>
                                                                                                </div>
                                                                                                <div class="col-md-8">
                                                                                                    <div class="slds-form-element__control pt-1 slds-truncate">
                                                                                                        <lightning:formattedNumber value="{!WIPflow.wipFlow.ERP7__Quantity_Scrapped__c}"/>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>

                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                            <!-- </aura:set>
                                                                </aura:if>-->
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:iteration>
                                                            </div>
                                                            <div class="cover-bar"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aura:set>
                                        </aura:if>
                                        <!-- Scenario 2 ends-->
                                        <aura:set attribute= "else">
                                            <!--Scenario 1-->
                                            <div class="slds-p-around_small pl-4">
                                                <div class="slds-grid slds-wrap ">
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">

                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.AddSubscription_Product}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <a href="javascript:void(0);" tabindex="-1"><strong><lightning:formattedText value="{!v.WorkOrder.ERP7__Product__r.Name}"/></strong></a>
                                                        </div>

                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small ">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.Ordered}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WorkOrder.ERP7__Quantity_Ordered__c}"/>
                                                        </div>

                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small ">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.Built_QTY}</label>

                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WorkOrder.ERP7__Quantity_Built__c}"/>
                                                        </div>
                                                    </div>
                                                    <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                        <label class="slds-form-element__label" for="form-element-01">{!$Label.c.WO_Scrapped_qty}</label>
                                                        <div class="slds-form-element__control pt-1">
                                                            <lightning:formattedNumber value="{!v.WorkOrder.ERP7__Quantity_Scrapped__c }"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!--Scenario 1 ends-->
                                        </aura:set>

                                    </aura:if>


                                    <div class="cover-bar2"></div>
                                </div>
                                <div class="{!if(greaterthan(v.WIPFlows.length, 1),  'slds-col slds-size_1-of-1 slds-medium-size_9-of-12 slds-large-size_9-of-12',  'slds-col slds-size_1-of-1 slds-medium-size_12-of-12 slds-large-size_12-of-12')}">

                                    <div class="scroll-bar-wrap">
                                        <div class="theme-bg shadow-none scroll-box2 BuildSchedule_minheight650">
                                            <div class="card shadow-sm m-2">

                                                <div class="slds-grid slds-wrap">
                                                    <!-- scenario 4 serial section-->
                                                    <div class="{! v.moSerialForProduction.length > 0 &amp;&amp; v.WIPFlows.length == 1 ? 'col-md-2 slds-m-top-xx--small p-0' : 'col-md-0 noneDisplay' }">
                                                        <aura:if isTrue="{!(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                            <div class="slds-grid slds-grid pt-2 slds-p-left_medium">
                                                                <lightning:input type="checkbox" aura:id="selectAllCheckbox" checked="{!v.selectAllCheckbox}" label="Select" onchange="{!c.selectSerialsForProduction}" class="slds-p-top_xx-small"></lightning:input>
                                                            </div>
                                                            <div class="pt-2 slds-p-left_medium">
                                                               <!-- <lightning:input type="checkbox" aura:id="selectAllCheckbox" checked="{!v.selectAllCheckbox}" label="Select" onchange="{!c.selectSerialsForProduction}" class="slds-p-top_xx-small"></lightning:input>-->
                                                                <label class="slds-form-element__label">Starting Serial Number:</label>
                                                                <div class="slds-grid slds-wrap">
                                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_8-of-12">
                                                                        <lightning:input variant="label-hidden" class="noLabel slds-p-right_xx-small" type="text" id="startingSerialInput" value="{!v.startingSerial}" oncommit="{!c.getfilteredSerials}"></lightning:input>
                                                                    </div>
                                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                                                                        <lightning:select value="{!v.WipflowsShowforBuild}" onchange="{!c.setSerialForProduction}" variant="label-hidden" class="noLabel">
                                                                            <option value="10">10</option>
                                                                            <option value="50">50</option>
                                                                            <option value="100">100</option>
                                                                            <option value="200">200</option>
                                                                            <!-- <option value="500">500</option> -->
                                                                            <!--<option value="1000">1000</option>
                                                                                <option value="3000">All</option> -->
                                                                        </lightning:select>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                        </aura:if>
                                                        <div class="scroll-bar-wrap">
                                                            <div class="scroll-box manufacturing-newClass28">
                                                                <aura:iteration items="{!v.moSerialForProduction}" var="serials" indexVar="i" start="{!v.startNum}" end="{!v.endNum}">
                                                                    <aura:if isTrue="{!and(serials.ERP7__Available__c != true ,serials.ERP7__Scrap__c != true)}">
                                                                        <div class="{!if((serials.selected == true),'card tilebox-one active-card m-2 cursor-pointer','card  tilebox-one m-2 cursor-pointer non-active-card')}"  data-serialcount="{!i}">
                                                                            <div class="card-body" data-serialId="{!serials.Id}" onclick="{!c.selectdivSerials}">
                                                                                <h6 class="text-uppercase mt-1 mb-1">
                                                                                    <span class="slds-text-heading_small">
                                                                                        <div class="slds-grid slds-truncate MOs_class47" title="{!serials.Name}" id="{!serials.Id}">
                                                                                            {!serials.Name}
                                                                                        </div>
                                                                                    </span>
                                                                                </h6>
                                                                            </div>
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:iteration>
                                                            </div>
                                                            <div class="cover-bar"></div>
                                                        </div>
                                                    </div>

                                                    <div class ="{!if((v.moSerialForProduction.length > 0), 'col-md-10 slds-m-top-xx--small p-0', 'col-md-12 slds-m-top-xx--small p-0')}">
                                                        <aura:if isTrue="{!and(not(greaterthan(v.WIPFlows.length,0)),v.hideToProduceforMRP == false)}">
                                                            <div class="slds-grid BuildSchedule_M-newClass159">
                                                                <div class="col-md-2 slds-m-top--xx-small">
                                                                    <lightning:input type="number" formatter="decimal" step="0.0001" label="{!$Label.c.To_Produce}" value="{!v.ToProduce}" min="0"/>
                                                                </div>
                                                                <div class="col-md-2 slds-m-top--xx-small">
                                                                    <lightning:input type="number" formatter="decimal" step="0.0001" label="{!$Label.c.To_Scrap_Waste}" value="{!v.ToScrap}" min="0"><!--To {!$Label.c.WO_Scrapped_qty}--> </lightning:input>
                                                                </div>
                                                            </div>
                                                        </aura:if>

                                                        <aura:if isTrue="{!v.showWIPsection}">
                                                            <aura:if isTrue="{!greaterthan(v.WIPFlows.length,0)}">
                                                                <div class="card-body BuildSchedule_M-newClass160 pb-0">
                                                                    <div class="BuildSchedule_M-newClass161 " tabindex="1"><!--table-responsive-->
                                                                        <table class="table">
                                                                            <thead>
                                                                                <tr class="slds-line-height_reset">
                                                                                    <!-- <th class="BuildSchedule_M-newClass162" scope="col">
                                                                        <div class="slds-truncate3" title="Product">Build Product</div>
                                                                    </th>-->
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col" width="20%">
                                                                                        <div class="slds-truncate3" title="Type">{!$Label.c.Type_ManageLeave}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col" width="30%">
                                                                                        <div class="slds-truncate3" title="Start Date">{!$Label.c.Build_Date}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="Quantity">{!$Label.c.Qty_Pick}<span class="BuildSchedule_M-newClass92"> *</span></div>
                                                                                    </th>
                                                                                     <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="Expiry date">{!$Label.c.Expiry_date}<span class="BuildSchedule_M-newClass92"> </span></div>
                                                                                    </th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <aura:iteration items="{!v.WIPFlows}" var="WIPflow" indexVar="i">
                                                                                    <aura:if isTrue="{!and(v.SelectedWIPflow != undefined, v.SelectedWIPflow.Id == WIPflow.wipFlow.Id)}">
                                                                                        <tr class="slds-hint-parent">
                                                                                            <!-- <td data-label="Product" class="BuildSchedule_M-newClass163">
                                                                                        <div class="slds-truncate3" >{!WIPFlow.ERP7__Product__r.Name}</div>
                                                                                    </td>-->
                                                                                            <td data-label="Type" class="BuildSchedule_M-newClass164">
                                                                                                <div class="slds-truncate3 displaynoneselect">
                                                                                                    <aura:If isTrue="{!and(WIPflow.wipFlow.ERP7__Status__c != 'Completed')}">
                                                                                                        <lightning:select aura:id="WIPFlowType" class="{!i}"  value ="{!v.WIPflowType}" onchange="{!c.handleWipStatusChange}" name="{!WIPflow.wipFlow.Id}"> <!--value="{!WIPflow.wipFlow.ERP7__Type__c}"-->
                                                                                                            <option value = "Produced" text = "Produced"/>
                                                                                                            <option value = "Scrapped" text = "Scrapped"/>
                                                                                                        </lightning:select>
                                                                                                        <!-- <aura:set attribute="else">
                                                                                                    {!WIPflow.wipFlow.ERP7__Type__c}
                                                                                                </aura:set>-->
                                                                                                    </aura:If>
                                                                                                </div>
                                                                                            </td>
                                                                                            <!-- <aura:if isTrue="{!and(WIPFlow.ERP7__Status__c != 'Completed')}"> -->
                                                                                            <td data-label="Start Date" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate3 noLabel">
                                                                                                    <lightning:input type="date"  value="{!WIPflow.wipFlow.ERP7__Start_Date__c}" />
                                                                                                </div>
                                                                                            </td>
                                                                                            <!-- <aura:if isTrue="{!v.rendertablist[2]}">
                                                                                                    <td data-label="End Date" class="BuildSchedule_M-newClass163">
                                                                                                        <div class="slds-truncate3 noLabel">
                                                                                                            <lightning:input type="date" value="{!WIPFlow.ERP7__End_Date__c}"  />
                                                                                                        </div>
                                                                                                    </td>
                                                                                                </aura:if> -->
                                                                                            <td data-label="Qty" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate3 noLabel">
                                                                                                    <aura:if isTrue="{!and(!WIPflow.wipFlow.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                                        <lightning:input aura:id="WIPqty" type="number" formatter="decimal" step="0.0001" variant="label-hidden" value="{!v.WIPflowQty}" name="{!(WIPflow.wipFlow.Id)}" onchange="{!c.validateFlowQnty}" disabled="{!((WIPflow.wipFlow.ERP7__Quantity__c + WIPflow.wipFlow.ERP7__Quantity_Scrapped__c) == WIPflow.wipFlow.ERP7__Quantity_Ordered__c)}"/>
                                                                                                    </aura:if>
                                                                                                    <aura:if isTrue="{!and(WIPflow.wipFlow.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                                                        <lightning:formattedNumber value="1"/><!--{!WIPFlow.ERP7__Quantity__c}-->
                                                                                                    </aura:if>
                                                                                                </div>
                                                                                            </td>

                                                                                            <td data-label="Expiry Date" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate3 noLabel">
                                                                                                    <lightning:input type="date" onchange="{!c.handleExpiryDateChange}" value="{!WIPflow.wipFlow.ERP7__Expiry_Date__c}" />
                                                                                                </div>
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:if>
                                                                                </aura:iteration>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                </div>
                                                            </aura:if>

                                                            <aura:set attribute="else">
                                                                <aura:if isTrue="{!greaterthan(v.WIPFlows.length,0)}">
                                                                    <aura:if isTrue="{!and(v.ManuOrder.ERP7__Product__r.ERP7__Serialise__c)}">
                                                                        <div class="slds-grid slds-wrap slds-p-around_small">
                                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                                <lightning:select value="{!v.TypeOfWIP}" onchange="{!c.handleWiptypeChange}" class="label-hidden-select">
                                                                                    <option value = "Produced" text = "Produced"/>
                                                                                    <option value = "Scrapped" text = "Scrapped"/>
                                                                                </lightning:select>
                                                                            </div>
                                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                                <div class="total-qty-produced">{!$Label.c.Total_Qty_Produced} <div class="float-right">{!v.TotalWIPQtyProduced}</div> </div>
                                                                            </div>
                                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                                <div class="total-qty-scrapped">{!$Label.c.Total_Qty_Scrapped} <div class="float-right">{!v.TotalWIPQtyScrapped}</div> </div>
                                                                            </div>
                                                                            <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12">
                                                                                            <div class="slds-truncate3 noLabel">
                                                                                                    <lightning:input type="date" placeholder="Expiry date" onchange="{!c.handleExpiryDateChange}"  />
                                                                                            </div>
                                                                                        </div>
                                                                        </div>
                                                                    </aura:if>
                                                                </aura:if>
                                                            </aura:set>
                                                        </aura:if>
                                                        <aura:if isTrue="{!greaterthan(v.MRPSS.length,0)}">

                                                            <div class="card-body BuildSchedule_M-newClass163 pt-0" >
                                                                <div class="scroll-bar-wrap">
                                                                    <div class="{!'scroll-box ' + ((and(v.displayProducedSection,greaterthan(v.AllWIPFlows.length,0))) ? 'BuildS-heigth45' : 'manufacturing-newClass28')}">

                                                                        <div class="BuildSchedule_M-newClass51" tabindex="1"><!--table-responsive-->
                                                                            <table class="table">
                                                                                <thead>
                                                                                    <tr class="slds-line-height_reset">
                                                                                        <th width="30%" class="BuildSchedule_M-newClass162">{!$Label.c.Bill_of_Materials_BOM}</th>
                                                                                        <th width="10%" class="BuildSchedule_M-newClass162">{!$Label.c.MO_ReqQty}</th>
                                                                                        <th width="10%" class="BuildSchedule_M-newClass162">{!$Label.c.MO_Fulfilled}</th>
                                                                                        <th width="10%" class="BuildSchedule_M-newClass162">{!$Label.c.Consumed}</th>
                                                                                        <th width="10%" class="BuildSchedule_M-newClass162">{!$Label.c.WO_Scrapped_qty}</th>
                                                                                        <th width="15%" class="BuildSchedule_M-newClass162">{!$Label.c.To_Consume}<span class="BuildSchedule_M-newClass166"> *</span></th>
                                                                                        <th width="15%" class="BuildSchedule_M-newClass162">{!$Label.c.To_Scrap_Waste}<span class="BuildSchedule_M-newClass166"> *</span></th>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    <aura:iteration var="MRP" indexVar="TCEC" items="{!v.MRPSS}">
                                                                                        <tr>
                                                                                            <td data-label="Product" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate2 BuildSchedule_M-newClass167" title="">{!MRP.MRP.ERP7__MRP_Product__r.Name}</div>
                                                                                            </td>
                                                                                            <td data-label="Qnty" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate2" title="">{!MRP.MRP.ERP7__Total_Amount_Required__c}</div>
                                                                                            </td>
                                                                                            <td data-label="Fulfilled" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate2" title="">{!MRP.MRP.ERP7__Fulfilled_Amount__c}</div>
                                                                                            </td>
                                                                                            <td data-label="Consumed" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate2" title="">{!MRP.MRP.ERP7__Consumed_Quantity__c}</div>
                                                                                            </td>
                                                                                            <td data-label="Scrapped" class="BuildSchedule_M-newClass163">
                                                                                                <div class="slds-truncate2" title="">{!MRP.MRP.ERP7__Scrapped_Quantity__c}</div>
                                                                                            </td>
                                                                                            <td data-label="To Consume" class="BuildSchedule_M-newClass163 noLabel">
                                                                                                <lightning:input type="number" formatter="decimal" step="0.0001" aura:id="cq" class="widthcustommk" value="{!MRP.quantityToConsume}" disabled="{!(MRP.MRP.ERP7__Fulfilled_Amount__c == (MRP.MRP.ERP7__Consumed_Quantity__c + MRP.MRP.ERP7__Scrapped_Quantity__c))}" readonly="true"/>
                                                                                            </td>
                                                                                            <td data-label="To Scrap2" class="BuildSchedule_M-newClass163 noLabel">
                                                                                                <lightning:input type="number" formatter="decimal" step="0.0001" aura:id="sq" class="widthcustommk" value="{!MRP.quantityToScrap}" disabled="{!(MRP.MRP.ERP7__Fulfilled_Amount__c == (MRP.MRP.ERP7__Consumed_Quantity__c + MRP.MRP.ERP7__Scrapped_Quantity__c))}"/>
                                                                                            </td>
                                                                                        </tr>
                                                                                    </aura:iteration>
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="cover-bar"></div>
                                                            </div>

                                                        </aura:if>
                                                        <!-- Produced WIPS section-->
                                                        <aura:if isTrue="{!and(v.displayProducedSection,v.AllWIPFlows.length > 0)}">
                                                            <div class="card shadow-sm mt-2">
                                                                <div class="card-body BuildSchedule_M-newClass160 pb-0">
                                                                    <div class="slds-grid slds-wrap">
                                                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                            <h5>{!$Label.c.Produced}&nbsp;{!$Label.c.Work_in_Progress_WIPs}</h5>
                                                                        </div>
                                                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                            <div class="total-qty-produced">{!$Label.c.Total_Qty_Produced} <div class="float-right">{!v.WorkOrder.ERP7__Quantity_Built__c}</div></div>
                                                                        </div>
                                                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                                                            <div class="total-qty-scrapped">{!$Label.c.Total_Qty_Scrapped} <div class="float-right">{!v.WorkOrder.ERP7__Quantity_Scrapped__c}</div></div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="BuildSchedule_M-newClass161 pad-40 pt-4" tabindex="1" >
                                                                        <table class="table">
                                                                            <thead>
                                                                                <tr class="slds-line-height_reset">
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.AddSubscription_Product}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.UOM}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.To_Produce}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.Built_QTY}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.Scrap_Waste_QTY}</div>
                                                                                    </th>
                                                                                    <th class="BuildSchedule_M-newClass162" scope="col">
                                                                                        <div class="slds-truncate3" title="">{!$Label.c.NewCase_Action}</div>
                                                                                    </th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <aura:if isTrue="{!(v.onlyManufacturedWIPFlows.length > 0)}">
                                                                                    <aura:iteration items="{!v.onlyManufacturedWIPFlows}" var="flows" indexVar="i">
                                                                                        <tr class="slds-hint-parent" >
                                                                                            <td scope="row" data-label="Products">
                                                                                                <div class="slds-truncate2" title="">
                                                                                                    {!i +1+ '. '}
                                                                                                    <lightning:formattedUrl value="{!'/'+flows.ERP7__Product__c}" label="{!flows.ERP7__Product__r.Name}" target="_blank" class="fcolor"/>
                                                                                                </div>
                                                                                            </td>
                                                                                            <td scope="row" data-label="UOM">
                                                                                                <div class="slds-truncate2" title="">
                                                                                                    {!flows.ERP7__Product__r.QuantityUnitOfMeasure}
                                                                                                </div>
                                                                                            </td>
                                                                                            <td data-label="Ordered Quantity">
                                                                                                <div class="slds-form-element">
                                                                                                    <div class="slds-form-element__control">
                                                                                                        {!flows.ERP7__Quantity_Ordered__c}
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                            <td data-label="Built Qty">
                                                                                                <div class="slds-form-element">
                                                                                                    <div class="slds-form-element__control">
                                                                                                        {!flows.ERP7__Quantity__c}
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                            <td data-label="Scrap Qty">
                                                                                                <div class="slds-form-element">
                                                                                                    <div class="slds-form-element__control">
                                                                                                        {!flows.ERP7__Quantity_Scrapped__c}
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                            <td data-label="edit">
                                                                                                <div class="slds-form-element">
                                                                                                    <div class="slds-form-element__control">
                                                                                                        <lightning:buttonIcon iconName="utility:edit" variant="bare" onclick="{!c.handleWIPEdit}" alternativeText="{!$Label.c.EditLabel}" title="{!$Label.c.EditLabel}" name="{!flows.Id}"/>
                                                                                                    </div>
                                                                                                </div>
                                                                                            </td>
                                                                                            <!-- <td data-label="Lot">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-truncate2">
                                                                                                <aura:If isTrue="{!(WIPFlow.wipFlow.ERP7__WIP__c != undefined)}">
                                                                                                    <aura:if isTrue="{!(WIPFlow.wipFlow.ERP7__WIP__r.ERP7__Serial_Number__c != undefined)}">
                                                                                                        {!WIPFlow.wipFlow.ERP7__WIP__r.ERP7__Serial_Number__r.Name}
                                                                                                    </aura:if>
                                                                                                    <aura:if isTrue="{!(WIPFlow.wipFlow.ERP7__WIP__r.ERP7__Material_Batch_Lot__c != undefined)}">
                                                                                                        {!WIPFlow.wipFlow.ERP7__WIP__r.ERP7__Material_Batch_Lot__r.Name}
                                                                                                    </aura:if>
                                                                                                </aura:If>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </td>-->
                                                                                        </tr>
                                                                                    </aura:iteration>
                                                                                    <aura:set attribute="else">
                                                                                        <tr>
                                                                                            <td colspan="6">
                                                                                                <div class="slds-notify_container slds-is-relative">
                                                                                                    <div class="slds-notify slds-notify_toast slds-theme_warning p-1 justity-center" role="status">
                                                                                                        <span class="slds-assistive-text">warning</span>
                                                                                                        <div class="slds-notify__content">
                                                                                                            <h2 class="slds-text-heading_small ">{!$Label.c.No}&nbsp;{!$Label.c.AddSubscription_Product}&nbsp;{!$Label.c.Produced}
                                                                                                            </h2>
                                                                                                        </div>

                                                                                                    </div>
                                                                                                </div>

                                                                                            </td>
                                                                                        </tr>


                                                                                    </aura:set>
                                                                                </aura:if>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                        <!--Produced WIPS scetion End-->
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <footer class="slds-docked-form-footer">
                            <center>
                                <lightning:button onclick="{!c.closeFinishModal}" label="{!$Label.c.EmployeeReviewV2_Back}" variant="neutral" />
                                <lightning:button aura:id="button1" name="" value="" variant="brand" disabled=""  onclick="{!c.FinishWO}">{!$Label.c.Build_Commit_To_Inventory}</lightning:button>
                            </center>
                        </footer>
                        <!-- Edit WIP -->
                        <div class="slds-modal" aura:id="editWIPModal">
                            <div class="slds-modal__container">
                                <div class="slds-modal__header">
                                    <h2 class="slds-text-heading_medium">Edit WIP</h2>
                                    <button class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.closeWIPpopup}">
                                        <lightning:icon iconName="utility:close" size="small" />
                                    </button>
                                </div>
                                <div class="slds-modal__content">
                                    <!-- Form for editing WIP details -->
                                    <div class="slds-grid slds-wrap slds-p-around_small">
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small">
                                            <label class="slds-form-element__label"><strong>WIP Name</strong></label><br/>
                                            <lightning:formattedText label="WIP Name" value="{!v.wipRecord.Name}" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small" title="">
                                            <label class="slds-form-element__label"><strong>Product Name</strong></label><br/>
                                            <lightning:formattedUrl value="{!'/'+v.wipRecord.ERP7__Product__c}" label="{!v.wipRecord.ERP7__Product__r.Name}" target="_blank" class="fcolor"/>
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small" >
                                            <label class="slds-form-element__label"><strong>TO Produces</strong></label><br/>
                                            <lightning:formattedNumber label="Order Quantity" value="{!v.wipRecord.ERP7__Quantity_Ordered__c}" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small" >
                                            <lightning:input label="Built QTY" value="{!v.wipRecord.ERP7__Quantity__c}" />
                                        </div>
                                        <div class="slds-col slds-size_1-of-1 slds-medium-size_4-of-12 slds-large-size_4-of-12 slds-p-right_small" >
                                            <lightning:input label="Scrap/Waste Qty" value="{!v.wipRecord.ERP7__Quantity_Scrapped__c}" />
                                        </div>
                                    </div>
                                </div>
                                <div class="slds-modal__footer text-center">
                                    <button class="slds-button slds-button_brand" onclick="{!c.saveEditWIP}">Save</button>
                                    <button class="slds-button slds-button_neutral" onclick="{!c.closeWIPpopup}">Cancel</button>
                                </div>
                            </div>
                        </div>
                        <div class="slds-backdrop" aura:id="myeditModalBackdrop"></div>
                        <!-- Edit WIP -->
                    </div>
                </div>
            </aura:if>

            <aura:if isTrue="{!v.raPage}">
                <div id="ResourceAllocationPOPUP" aura:id="myResourceAllocationModal">

                    <!-- Modal content-->
                    <div class="container-fluid pl-1 pr-1">
                        <!-- <div class="modal-header modalbg BuildSchedule_M-newClass111">
                        <h1 class="slds-text-heading_medium slds-hyphenate headertextreset">
                            <span class="BuildSchedule_M-newClass171">
                                <strong>
                                    <aura:if isTrue="{!!(v.CapacityPlanner.Id != undefined)}"> Capacity planner unavailable </aura:if>
                                    <aura:if isTrue="{!(v.CapacityPlanner.Id != undefined)}"> {!v.CapacityPlanner.Name}</aura:if>
                                </strong>
                            </span>
                        </h1>
                    </div> -->
                        <aura:if isTrue="{!(v.CapacityPlanner.Id != undefined)}">
                            <div class="container-fluid pl-1 pr-1">
                                <h2 class="slds-m-right-small slds-align-middle BuildSchedule_M-newClass94" title="" >{!v.ResourcePopupErrorMsg}</h2>
                                <div class=" slds-m-top--xx-small">
                                    <div class="row">
                                        <div class="col-md-4 slds-m-top--small">
                                            <span class="BuildSchedule_M-newClass173">{!$Label.c.Work_Planner} : </span>
                                            <lightning:combobox class="slds-m-bottom--xx-small" aura:id="wpList" value="{!v.SelectedWP}" dropdown-alignment="auto" options="{! v.WPoptions }"/>
                                            <div class="scrollarea-boxes BuildSchedule_M-newClass118">
                                                <aura:iteration items="{!v.WorkPlanners}" var="bo" indexVar="i">
                                                    <aura:if isTrue="{!and(v.SelectedWP == bo.WorkPlanner.Id)}">
                                                        <aura:iteration items="{!bo.RRS}" var="RS" indexVar="k">
                                                            <article class="{!if(RS.Id == v.selectedRR,'card card-hover active-card BuildSchedule_M-newClass174 mt-2','card card-hover shadow-sm BuildSchedule_M-newClass174 mt-2')}" data-mrpcount="{!i}" data-rr="{!RS.Id}" data-rrname="{!RS.ERP7__Resource_Group__r.Name}" onclick="{!c.SelectWP}">
                                                                <div class="slds-card__header slds-grid">
                                                                    <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                                        <div class="slds-media__body">
                                                                            <h2 class="slds-card__header-title">
                                                                                <a href="javascript:void(0);" class="slds-card__header-link slds-truncate" >
                                                                                    <span class="slds-text-heading_small">
                                                                                        <div class="slds-truncate" title="{!RS.ERP7__Resource_Group__r.Name}">
                                                                                            <a href="{!'/'+ RS.ERP7__Resource_Group__c}" target="_blank" class="">
                                                                                                <lightning:formattedText value="{!RS.ERP7__Resource_Group__r.Name}" /> </a>
                                                                                            <!--{!selectedRR}-->
                                                                                        </div>
                                                                                    </span>
                                                                                </a>
                                                                            </h2>
                                                                        </div>
                                                                    </header>
                                                                </div>
                                                                <div class="BuildSchedule_M-newClass175 pb-2 pt-1">{!$Label.c.Run_Time} : {!RS.ERP7__Runtime__c}</div>
                                                            </article>
                                                        </aura:iteration>
                                                    </aura:if>
                                                </aura:iteration>
                                            </div>
                                        </div>
                                        <div class="col-md-8 BuildSchedule_M-newClass176">
                                            <div class="card shadow-mrr">
                                                <div class="card-body">
                                                    <div class="slds-media__body slds-text-align--left">
                                                        <div class="row">
                                                            <div class="col-md-12">
                                                                <div class="slds-grid">
                                                                    <div class="slds-col slds-m-right--x-small">
                                                                        <lightning:input type="datetime" class="selectDate" value="{!v.StartTime}" onchange="{!c.GetResources}" label="{!$Label.c.From_StockRunRate}" required="true"/>
                                                                    </div>
                                                                    <div class="slds-col">
                                                                        <lightning:input type="datetime" class="selectDate"  value="{!v.EndTime}" onchange="{!c.GetResources}" label="{!$Label.c.To_StockRunRate}" required="true"/>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                        </div>
                                                    </div>

                                                    <div class="slds-grid">
                                                        <div class="slds-col slds-m-right--x-small slds-m-top--xx-small">

                                                            <lightning:input label="{!$Label.c.Name_ManageLeave}" type="Text" class="" placeholder="{!$Label.c.Search_By_Resource_Name}" value="{!v.ResourceStr}" onchange="{!c.GetResources}"/>
                                                        </div>
                                                        <div class="slds-col slds-m-top--large">
                                                            <button class="slds-button slds-button--brand" onclick="{!c.GetResources}">{!$Label.c.Find_StockTake}</button>
                                                        </div>
                                                    </div>
                                                    <table class="table table-condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                        <thead>
                                                            <tr class="slds-text-title--caps">
                                                                <th class="slds-is-sortable "  scope="col" height="40px">
                                                                    <div class="slds-truncate2" >
                                                                        Action
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable " scope="col">
                                                                    <div class="slds-truncate2" >
                                                                        {!$Label.c.Resource}
                                                                    </div>
                                                                </th>
                                                                <th class="slds-is-sortable" scope="col">
                                                                    <div class="slds-truncate2">
                                                                        {!$Label.c.Group}
                                                                    </div>
                                                                </th>
                                                            </tr>
                                                        </thead>
                                                        <aura:iteration items="{!v.AvailableResources}" var="AR" indexVar="i">
                                                            <tbody>
                                                                <tr class="slds-hint-parent" >
                                                                    <td class="slds-is-sortable " scope="col" height="40px">
                                                                        <div class="slds-grid slds-truncate" name="{!i}">
                                                                            <div class="slds-col">
                                                                                <lightning:input type="Checkbox" aura:id="checkbox" checked="{!AR.isSelect}"/>
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                    <aura:if isTrue="{!(AR.Resource.ERP7__Employee__c != undefined)}">
                                                                        <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass39">
                                                                            <div class="slds-form-element slds-truncate2">
                                                                                <div class="slds-form-element__control" style="color: black;">
                                                                                    {!AR.Resource.ERP7__Employee__r.Name}
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                    </aura:if>
                                                                    <aura:if isTrue="{!(AR.Resource.ERP7__Machine__c != undefined)}">
                                                                        <td data-label="Quantity" valign="middle" class="BuildSchedule_M-newClass39">
                                                                            <div class="slds-form-element slds-truncate2">
                                                                                <div class="slds-form-element__control" style="color: black;">
                                                                                    {!AR.Resource.ERP7__Machine__r.Name}
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                    </aura:if>
                                                                    <td data-label="Group" valign="middle" class="BuildSchedule_M-newClass39">
                                                                        <div class="slds-form-element slds-truncate2">
                                                                            <div class="slds-form-element__control" style="color: black;">
                                                                                {!AR.Resource.ERP7__Resource_Group__r.Name}
                                                                            </div>
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            </tbody>
                                                        </aura:iteration>
                                                    </table>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </aura:if>
                        <div class="slds-docked-form-footer">
                            <button class="slds-button slds-button--neutral" onclick="{!c.closeResourceAllocationModal}">{!$Label.c.EmployeeReviewV2_Back}</button>
                            <aura:if isTrue="{!and(v.CapacityPlanner.Id != undefined,v.AvailableResources.length != 0)}"><button class="slds-button slds-button--brand" onclick="{!c.upsertResources}" >Save</button></aura:if>
                        </div>
                    </div>
                </div>
            </aura:if>

            <aura:if isTrue="{!v.saPage}">
                <div id="WeightCaptures" aura:id="stockAllocationModal">

                    <div class="container-fluid p-0">
                        <div class="slds-grid">
                            <div class="col-md-12 theme-bg min-height500 p-0">
                                <!-- Modal content-->


                                <aura:if isTrue="{!(v.WeightPopupErrorMsg != '')}">
                                    <h2 class=" slds-m-right-small slds-align-middle BuildSchedule_M-newClass94" title="">{!v.WeightPopupErrorMsg}</h2>
                                </aura:if>
                                <div class="container-fluid p-0">
                                    <div class="row m-0">
                                        <div class="col-md-3 slds-m-top--x-small pl-2">
                                            <div class="scroll-bar-wrap">
                                                <div class="scroll-box manufacturing-buildernewClass28">
                                                    <aura:iteration items="{!v.MRPs}" var="bo" indexVar="i">
                                                        <!--<aura:if isTrue="{!(bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'gram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'kilogram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'milligram' || bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c == 'lbs')}">-->
                                                        <article class="{!if(bo.isSelect,'card card-hover active-card mb-1 m-1 BuildSchedule_M-newClass96','shadow-mrr card card-hover mb-1 m-1 BuildSchedule_M-newClass96')}" data-mrpcount="{!i}" onclick="{!c.SelectMRP}">
