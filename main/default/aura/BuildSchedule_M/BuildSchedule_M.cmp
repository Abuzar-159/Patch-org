                        <div class="slds-path lightningProgressIndicator" data-aura-rendered-by="115:0" data-aura-class="lightningProgressIndicator">
                            <div class="slds-grid slds-path__track" data-aura-rendered-by="116:0">
                                <div class="slds-grid slds-path__scroller-container" data-aura-rendered-by="117:0">
