                                                        <div class="{!if((AND(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c == true, bo.Id == v.NewSOLI.ERP7__MO_WO_Serial__c) || AND(bo.SelectItem == true)),'card tilebox-one active-card m-2 cursor-pointer','card  tilebox-one m-2 cursor-pointer non-active-card')}"  data-serialcount="{!i}" onclick="{!If((v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c == true), c.SelectSerialForAllocation,'')}">
