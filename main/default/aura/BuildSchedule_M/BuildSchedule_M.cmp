                                                                                            <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="solib" IconName="standard:orders" selectedRecordId="{!v.NewSOLI.ERP7__Material_Batch_Lot__c}" inputStyleclass="slds-input" qry="{!v.qry}"/>
                                                                                        </div>
