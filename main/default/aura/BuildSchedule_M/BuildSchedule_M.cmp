                                                    <div class="epr_Mark7">
                                                        <section  id="myModalNote" aura:id="newTaskNoteModal" role="dialog" tabindex="-1" class="slds-modal slds-modal_medium" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">

                                                            <div class="slds-modal__container ">
                                                                <!-- Modal content-->
                                                                <header class="slds-modal__header slds-modal__header_empty">
                                                                    <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.ReloadNew}">
                                                                        <lightning:icon iconName="utility:close" variant="inverse" size="medium"></lightning:icon>

                                                                        <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                                    </button>

                                                                </header>
                                                                <div class="slds-modal__content slds-p-around_medium min-height250" id="modal-content-id-1">


                                                                    <div class="BuildSchedule_M-newClass168">{!v.errorMsgPop}</div>
                                                                    <fieldset class="slds-form--compound">
                                                                        <div class="slds-form-element__group">
                                                                            <div class="row">
                                                                                <div class="col-md-9">
                                                                                    <lightning:input type="Text" aura:id="name" class="" value="{!v.NewNote.Title}" label="{!$Label.c.Title}" required="true"/>
                                                                                </div>
                                                                                <div class="col-md-3 slds-m-top--xx-small">
                                                                                    <label class="slds-form-element__label" for="input-06">{!$Label.c.Private}</label><br/>
                                                                                    <lightning:input type="Checkbox" aura:id="chkp"                                                                              class=""
                                                                                                     checked="{!v.NewNote.isPrivate}"
                                                                                                     />
                                                                                </div>
                                                                            </div>
                                                                            <div class="row">
                                                                                <div class="col-md-12 slds-m-top--xx-small">
                                                                                    <lightning:textarea aura:id="details"  label="Body"
                                                                                                        class="slds-textareaa heightppbs"
                                                                                                        maxlength="250" messageWhenTooLong="A maximum of 250 characters are allowed."
                                                                                                        value="{!v.NewNote.Body}"
                                                                                                        />
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </fieldset>
                                                                </div>
                                                                <footer class="slds-modal__footer">
                                                                    <button type="button" class="slds-button slds-button--neutral" onclick="{!c.ReloadNew}">{!$Label.c.Cancel_UserAvailabilities}</button>
                                                                    <button class="slds-button slds-button--brand" onclick="{!c.SaveNote}">{!$Label.c.ContractConsole_Save}</button>

                                                                </footer>

                                                            </div>
                                                        </section>
                                                    </div>
                                                    <!-- New Notes Modal END-->
                                                    <div class="slds-backdrop" aura:id="newTaskModalBackdrop"></div>
                                                </div>
                                                <!-- @end of tab k -->
                                                <!-- Tab 2 -->
                                                <div class="{!(v.timeTrackingTab)?'slds-show':'slds-hide'}" id="timetracking" role="tabpanel">
                                                    <div class="panel-body BuildSchedule_M-newClass47">
                                                        <div class="card shadow-sm BuildSchedule_M-newClass21">
                                                            <div class="card-body">
                                                                <div class="row slds-p-around--xx-small">
                                                                    <div class="col-md-6">
                                                                        <div class="slds-form--inline">
                                                                            <div class="slds-form-element">
                                                                                <label class="slds-form-element__label BuildSchedule_M-newClass48" for="text-input-01">{!$Label.c.Planned_Date}</label>
                                                                                <div class="slds-form-element__control pl-4">
                                                                                    <aura:if isTrue="{!if(and(v.WorkOrder.ERP7__Planned_Date_From__c != '',v.WorkOrder.ERP7__Planned_Date_From__c != undefined),true,false)}" >
                                                                                        {!$Label.c.From_StockRunRate}&nbsp;
                                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Planned_Date_From__c}" variant="label-hidden"/>
                                                                                    </aura:if>
                                                                                    <aura:if isTrue="{!if(and(v.WorkOrder.ERP7__Planned_Date_To__c != '',v.WorkOrder.ERP7__Planned_Date_To__c != undefined),true,false)}" >
                                                                                        &nbsp;{!$Label.c.To_StockRunRate}&nbsp;
                                                                                        <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Planned_Date_To__c}" variant="label-hidden"/>
                                                                                    </aura:if>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="slds-form--inline">
                                                                            <div class="slds-form-element">
                                                                                <label class="slds-form-element__label" for="text-input-01">{!$Label.c.Expected_Duration}</label>
                                                                                <div class="slds-form-element__control">
                                                                                    {!v.ExpectedDuration}
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="slds-form--inline">
                                                                            <div class="slds-form-element ">
                                                                                <label class="slds-form-element__label" for="text-input-01">{!$Label.c.Effective_Date}</label>
                                                                                <div class="slds-form-element__control pl-4">
                                                                                    {!$Label.c.From_StockRunRate}&nbsp;
                                                                                    <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__Start_Date__c}" variant="label-hidden"/>
                                                                                    &nbsp;{!$Label.c.To_StockRunRate}&nbsp;
                                                                                    <lightning:formattedDateTime value="{!v.WorkOrder.ERP7__End_Date__c}" variant="label-hidden"/>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="slds-form--inline">
                                                                            <div class="slds-form-element">
                                                                                <label class="slds-form-element__label BuildSchedule_M-newClass49" for="text-input-01">{!$Label.c.Real_Duration}</label>
                                                                                <div class="slds-form-element__control BuildSchedule_M-newClass50">
                                                                                    {!v.RealDuration}
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="table-responsive BuildSchedule_M-newClass51" tabindex="1">
                                                                    <table class="slds-table slds-table_bordered">
                                                                        <thead>
                                                                            <tr class="slds-text-title--caps">
