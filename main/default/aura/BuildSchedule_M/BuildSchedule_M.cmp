                                                                                                    <aura:if isTrue="{!(TCE.ERP7__End_Time__c == undefined)}">
                                                                                                        <lightning:button value="{!TCE.Id}" variant="brand" onclick="{!c.StopTimeCard}">
                                                                                                            <div id="Finish" ><span class="BuildSchedule_M-newClass44"><i class="fa fa-clock-o BuildSchedule_M-newClass45" aria-hidden="true"></i>&nbsp;&nbsp;{!$Label.c.Clock_Out}</span></div>
                                                                                                        </lightning:button>
                                                                                                    </aura:if>
                                                                                                </aura:if>
                                                                                            </aura:if>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </aura:iteration>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
