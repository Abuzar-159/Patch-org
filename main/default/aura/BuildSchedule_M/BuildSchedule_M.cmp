                                                                                                <aura:if isTrue="{!(bo.MRP.ERP7__Minimum_Variance__c > 0 || bo.MRP.ERP7__Maximum_Variance__c > 0)}">
                                                                                                    (<lightning:formattedNumber value="{!(bo.MRP.ERP7__Total_Amount_Required__c-bo.MRP.ERP7__Minimum_Variance__c)*bo.BOMWeightMultiplier}"/>-<lightning:formattedNumber value="{!(bo.MRP.ERP7__Total_Amount_Required__c+bo.MRP.ERP7__Maximum_Variance__c)*bo.BOMWeightMultiplier}"/>)
                                                                                                </aura:if>
                                                                                                {!bo.SelectedUOM}  // commented {!bo.SelectedUOM} {!bo.MRP.ERP7__BOM__r.ERP7__Unit_of_Measure__c} {!bo.MRP.ERP7__MRP_Product__r.QuantityUnitOfMeasure} // commented
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>

                                                                                    <div class="col-md-4 slds-text-heading_xx-small MOs_class7">
