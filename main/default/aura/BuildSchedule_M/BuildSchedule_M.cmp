                                                                                                                         minute="2-digit"  hour12="true"/>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="End Date">
                                                                                        <div class="slds-truncate2" title="">
                                                                                            <lightning:formattedDateTime value="{!TCE.ERP7__End_Time__c}" variant="label-hidden" year="numeric" month="numeric" day="numeric" hour="2-digit"
                                                                                                                         minute="2-digit"  hour12="true"/>
                                                                                        </div>
                                                                                    </td>
                                                                                    <td data-label="Total Hours">
