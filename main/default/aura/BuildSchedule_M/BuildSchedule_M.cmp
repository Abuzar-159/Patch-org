                                                                                    </td>
                                                                                    <!--
                                                                            <td data-label="Status">
                                                                                <div class="slds-truncate2" title="">{!TCE.ERP7__Status__c}</div>
                                                                            </td>
                   -->
                                                                                    <td data-label="Finish">
                                                                                        <div class="slds-truncate2" title="">
                                                                                            <aura:if isTrue="{!v.Permit}">
