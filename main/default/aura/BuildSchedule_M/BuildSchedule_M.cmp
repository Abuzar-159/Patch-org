                                                                </span>
                                                                <span class="slds-path__title">{!BWO.Name}-{!BWO.ERP7__Status__c}</span>
                                                            </a>
                                                        </div>
                                                    </aura:If>

                                                    <aura:If isTrue="{!BWO.Id == v.WorkOrder.Id}">
                                                        <div data-record="{!BWO.Id}" data-index="{!currentWOindex}" onclick="{!c.changeCurrentWO}" class="slds-is-active slds-path__item slds-is-current" title="{!BWO.Name}">
                                                            <a aria-selected="true" href="javascript:void(0);" role="option" tabindex="0" class="slds-path__link">
                                                                <span class="slds-path__stage">
                                                                    <span class="slds-assistive-text">{!BWO.Name}- {!BWO.ERP7__Status__c}</span>
                                                                </span>
                                                                <span class="slds-path__title">{!BWO.Name}- {!BWO.ERP7__Status__c}</span>
                                                            </a>
                                                        </div>
                                                    </aura:If>

                                                    <aura:If isTrue="{!and(BWO.Id != v.WorkOrder.Id, BWO.ERP7__Status__c != 'Complete')}">
