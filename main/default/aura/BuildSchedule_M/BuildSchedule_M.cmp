                                                                                                                                <aura:if isTrue="{!(v.SelectedTask.ERP7__Status__c == 'New' || v.SelectedTask.ERP7__Status__c == 'On-Hold' || v.SelectedTask.ERP7__Status__c == '' || v.SelectedTask.ERP7__Status__c == undefined || v.SelectedTask.ERP7__Status__c == 'Backlog' || v.SelectedTask.ERP7__Status__c == 'Nouveau')}">
