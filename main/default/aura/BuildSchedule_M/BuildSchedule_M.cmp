                                                                                            <lightning:formattedUrl value="{!'/'+bo.MRP.ERP7__MRP_Product__c}" label="{!bo.MRP.ERP7__MRP_Product__r.Name}" tooltip="{!bo.MRP.ERP7__MRP_Product__r.Name}" target="_blank" />
                                                                                        </div>
                                                                                    </aura:if>
                                                                                </div>
