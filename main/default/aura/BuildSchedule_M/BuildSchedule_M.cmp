                                                                                        <aura:iteration items="{!bo.UOMS}" var="uom">
                                                                                            <option text="{!uom.label}" value="{!uom.value}" selected="{!uom.value == bo.SelectedUOM}" />           <!--selected="{!uom.selected}"-->                                                                                                         </aura:iteration>
                                                                                    </lightning:select>

                                                                                </div>
                                                                                <aura:if isTrue="{!and(!bo.MRP.ERP7__MRP_Product__r.ERP7__Serialise__c, !bo.MRP.ERP7__MRP_Product__r.ERP7__Lot_Tracked__c)}">
                                                                                    <div class="col-md-12 slds-m-top--x-small">
                                                                                        <div class="slds-text-heading_xx-small slds-m-top--x-small"><strong>{!$Label.c.Batch_Serial}</strong></div>
