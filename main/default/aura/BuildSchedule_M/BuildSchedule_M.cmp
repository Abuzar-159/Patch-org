                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                            <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01"> {!$Label.c.Availability_date}</label>
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="date" aura:id="ad" format="dd-MM-yyyy"   value="{!v.SerialNumber2Upsert.ERP7__Availability_date__c}"></lightning:input>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4 col-sm-4 col-xs-12 slds-m-top--small">
                                            <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01"> {!$Label.c.Shelf_Life_Exp_Date} </label>
                                                <div class="slds-form-element__control">
