                                                                                            <div class="slds-text-heading_xx-small slds-m-top--x-small"><strong> Stock : </strong>{!v.SOLI_BatchStock*bo.WeightMultiplier} </div>
                                                                                        </div>
                                                                                    </aura:if>
                                                                                </div>

                                                                            </div>



                                                                            <!--<img id="weightspins" src="/resource/ERP7__SLDS0121/assets/images/spinners/slds_spinner_brand.gif" class="BuildSchedule_M-newClass104"/> -->
                                                                        </div>
                                                                        <div class="col-md-6">
