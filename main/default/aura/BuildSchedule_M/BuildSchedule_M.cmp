                                                                <h6 class="text-uppercase mt-1 mb-1">
                                                                    <span class="slds-text-heading_small">
                                                                        <div class="slds-grid slds-truncate MOs_class47" title="{!bo.Name}" id="{!bo.Id}">
                                                                            <aura:if isTrue="{!!(v.selectedMRP.ERP7__MRP_Product__r.ERP7__Serialise__c)}">
                                                                                <lightning:input type="checkbox" style="visibility:hidden;" aura:id="selectAllSerials" checked="{!bo.SelectItem}" onchange="{!c.selectTheSerial}"></lightning:input>
                                                                            </aura:if>
                                                                            {!bo.Name}
                                                                        </div>
                                                                    </span>
