                                            <div class="slds-form-element"> <label class="slds-form-element__label" for="text-input-01"> {!$Label.c.Serial_Numbers} <span class="MOs_class17">*</span></label>
                                                <div class="slds-form-element__control">
                                                    <lightning:input type="text" value="{!v.SerialNumber2Upsert.ERP7__Serial_Number__c}"></lightning:input>
                                                </div>
                                            </div>
                                        </div>
