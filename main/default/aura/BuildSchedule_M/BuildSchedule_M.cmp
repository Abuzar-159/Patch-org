                                                                                </th>
                                                                                <th scope="col">
                                                                                    <div class="slds-truncate2 slds-p-left--medium" title="pdf">{!$Label.c.Label}</div>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <aura:if isTrue="{!(v.SerialsLength > 0)}">
