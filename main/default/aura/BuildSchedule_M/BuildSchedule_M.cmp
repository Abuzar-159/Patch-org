                                                                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" class="MOs_class44 " />
                                                                                                                    </a> </lightning:button>
                                                                                                                <lightning:button aura:id="assignButton" class="neutralC" name="{!Serial.Id}"
                                                                                                                                  onclick="{!c.DeleteRecordserial}"> <a title="Delete Serial">
                                                                                                                    <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="MOs_class36"/>
                                                                                                                    </a> </lightning:button>
                                                                                                            </div>
                                                                                                        </td>
                                                                                                    </tr>
                                                                                                </table>
                                                                                            </div>
