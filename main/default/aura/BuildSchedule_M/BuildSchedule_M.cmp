                <div id="myModalMOSerial" aura:id="myModalMOSerial" class="slds-modal fade" role="dialog">
                    <div class="modal-dialog">
                        <!-- Modal content-->
                        <div class="modal-content">

                            <div class="modal-body MOs_class66">
