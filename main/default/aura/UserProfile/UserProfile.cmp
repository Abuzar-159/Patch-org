<!--
 For changing the password, question and de-activating the user.
-->
<aura:component  Controller="ERP7.ProductListCommSignIn" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/bootstrap.custom.min.css',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css" />
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/UserProfile.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="SQ" type="List"/> 
    <aura:attribute name="UserName" type="String"/><!--type="String"-->
    <aura:attribute name="PortalUser" type="Boolean" default="false"/> 
    <aura:attribute name="showSQ" type="Boolean" default="true"/> 
    <aura:attribute name="showallSQ" type="Boolean" default="false"/>
    <aura:attribute  name="allSecQues1" type="List"/>
    <aura:attribute  name="allSecQues2" type="List"/>
    <aura:attribute name="selSQ1" type="String"/>
    <aura:attribute name="selSQ2" type="String"/>
    <aura:attribute name="changeSPN" type="Boolean" default="false"/>
    <aura:attribute name="EditPass" type="Boolean" default="false"/>
    <aura:attribute name="showPass" type="Boolean" default="true"/>
    <aura:attribute name="ShowTM" type="Boolean" default="false"/>
    <aura:attribute name="message" type="String"/>
    <aura:attribute name="SQForPassword" type="String"/> 
    <aura:attribute name="SAForPassword" type="String"/>   
    <aura:attribute name="errmsg" type="String"/>
    <aura:attribute name="isOpen" type="Boolean" default="false"/>
    <aura:attribute name="UserEmail" type="String"/>
    <aura:attribute name="imageURL" type="String" default=""/>
    
    <div class="erp_mark7 erp_Mark7 USRProf-class1" ><!--class="event-rok bookingkare event_rok"-->
        <!--<aura:renderIf isTrue="{!(v.PortalUser)}">--> 
        <!--<c:CommunityHeaderROP></c:CommunityHeaderROP>-->
        <!--<c:ComunityHeader></c:ComunityHeader>
        <lightning:spinner variant="brand" size="large" aura:id="mainSpin" class="slds-hide"/>
   </aura:renderIf>
   <aura:renderIf isTrue="{!!(v.PortalUser)}">
     <c:CommunityPortal></c:CommunityPortal>-->
        <!--<c:ROPPortal></c:ROPPortal>-->
        <!--</aura:renderIf>-->   
        
        <div class="container-fluid user-custom-erp" >
            <div class="ml-5">
                <aura:if isTrue="{!v.imageURL != ''}">
                    <img src="{!v.imageURL}" class="USRProf-class2"></img>
                    <aura:set attribute="else">
                        <h4>Demo Site</h4>
                    </aura:set>
                </aura:if>
            </div>
        </div>
        
        <div class="container">
            <aura:if isTrue="{!v.ShowTM}">
                <div ><!--class="maq-only"--> 
                    <div class="slds-notify_container slds-is-fixed">
                        <div class="slds-notify slds-notify_toast slds-theme--error" role="alert">                                   
                            <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                            </span>
                            <div class="slds-notify__content USRProf-class3" >
                                <h2 class="slds-text-heading_small ">{!v.message}</h2>
                            </div>
                            
                            <div class="slds-notify__content USRProf-class4">
                                <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" 
                                        onclick="{!c.hideNotification}">
                                    <span class="slds-assistive-text">Close</span> 
                                </button> 
                            </div>
                        </div>
                    </div>
                </div>
            </aura:if>
            <div class="slds-col--padded comm-content-footer comm-layout-column">
                <div data-region-name="footer" >
                    <div class="ui-widget mt-4" >
                        <div class="topWidth2 topWidth3 cRPLightningCommunityMyProfile" data-aura-class="cRPLightningCommunityMyProfile">
                            <h1 class="tempStyle USRProf-class5">Your Profile</h1>
                            
                            <p class="How-to-Get-Started USRProf-class6">Account Settings</p>
                            
                            <div>
                                <div class="row mb-2 shadow-sm USRProf-class7" >
                                    <div class="col-md-9 py-4">
                                        <div class="Field-Title">
                                            <h6>Name</h6></div>
                                        <div class="Contnet mb-3">
                                            <h6 class="uiOutputText USRProf-class8" >{!v.UserName}</h6>
                                        </div>
                                    </div>
                                </div>
                                <div class="row mb-2 shadow-sm USRProf-class7">
                                    <div class="col-md-9 py-4">
                                        <div class="Field-Title">
                                            <h6>Password</h6>
                                        </div>
                                        <aura:if isTrue="{!v.errmsg.length>0}"> 
                                            <div class="USRProf-class10">
                                                {!v.errmsg}
                                            </div>
                                        </aura:if>    
                                        <aura:if isTrue="{!v.showPass}"> 
                                            <div class="Contnet" >
                                                <h6 class="uiOutputText USRProf-class8" >**********</h6>
                                            </div>
                                        </aura:if>
                                        
                                        <aura:if isTrue="{!v.EditPass}">
                                            
                                            <div class="col-md-12 mt-2" >
                                                <label for="SubType">*&nbsp;Old Password  &nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="password" variant="label-hidden" aura:id="OP" maxlength="30" placeholder="Old Password" class=""/>  
                                                    </div>
                                                </div>   
                                            </div>
                                            
                                            <div class="col-md-12 mt-2">
                                                <label for="SubType">*&nbsp;New Password  &nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="password" variant="label-hidden" aura:id="NP"    maxlength="30" placeholder="New Password" class=""/>  
                                                    </div>
                                                </div>   
                                            </div>
                                            <div class="col-md-12 mt-2" >
                                                <label for="SubType">*&nbsp;Verify New Password  &nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="password" variant="label-hidden" aura:id="VFNP" maxlength="30" placeholder="Verify New Password" class=""/>  
                                                    </div>
                                                </div>   
                                            </div>
                                            <div class="col-md-12 mt-2 " >
                                                <label for="SubType">*&nbsp;Security Answer  &nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12 mt-2">
                                                        {!v.SQForPassword}
                                                    </div>    
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="text" variant="label-hidden" aura:id="SQAns" maxlength="30" placeholder="Security Answer" class=""/>  
                                                    </div>
                                                </div>   
                                            </div>
                                            <div class="row topMargin ml-1 mb-2">
                                                <div class="col-md-2 col-6">
                                                    <button class="slds-button slds-button--brand  mt-2 USRProf-class11" type="button" onclick="{!c.updatePass}">
                                                        Save
                                                    </button>
                                                </div> 
                                                <div class="col-md-2 col-6">
                                                    <button class="slds-button slds-button--neutral mt-2 USRProf-class11" type="button" onclick="{!c.CancelPassword}">
                                                        Cancel
                                                    </button> 
                                                </div>
                                            </div>
                                        </aura:if> 
                                    </div>
                                    <aura:if isTrue="{!v.showPass}"> 
                                        <div class="col-md-3 topMargin mb-3">
                                            <button class="btn btn-default mt-3 USRProf-class12" onclick="{!c.showChangePass}" type="button" > <!-- href="/ROPCommunityChangePassword"  -->
                                                <!--<a  role="menuitem"  tabindex="0" data-aura-rendered-by="312:0">--> Change Password <!--</a>-->
                                            </button>
                                        </div>
                                    </aura:if>    
                                </div>
                                <div class="row mb-2 shadow-sm USRProf-class7" >
                                    <div class="col-md-9 py-4">
                                        <div class="Field-Title">
                                            <h6>Security Questions</h6>
                                        </div>
                                        <aura:if isTrue="{!v.showSQ}">
                                            <aura:iteration items="{!v.SQ}" var="ques">
                                                <div class="Contnet">
                                                    <h6 class="USRProf-class8">{!ques} &nbsp;</h6>
                                                    <span class="uiOutputText">**********</span>
                                                </div>
                                            </aura:iteration>
                                        </aura:if>
                                        <aura:if isTrue="{!v.showallSQ}">
                                            <div class="col-md-12 mt-2">
                                                <label for="SubType">Security Question1&nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <lightning:select aura:id="SecQ1" value="{!v.selSQ1}" variant="label-hidden"  class="display-lable"> <!--class="cursor-pointer form-control"-->
                                                            <aura:iteration items="{!v.allSecQues1}" var="option">
                                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.selSQ1, option.value)}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="text" variant="label-hidden" aura:id="SQ1Ans" maxlength="30" placeholder="Security Answer" class=""/>  
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-12 mt-2">
                                                <label for="SubType">Security Question2&nbsp;<span class="USRProf-class9"></span></label>
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <lightning:select aura:id="SecQ2" value="{!v.selSQ2}" variant="label-hidden"  class="display-lable"> <!--class="cursor-pointer form-control"-->
                                                            <aura:iteration items="{!v.allSecQues2}" var="option">
                                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.selSQ2, option.value)}"/>
                                                            </aura:iteration>
                                                        </lightning:select>
                                                    </div>
                                                    <div class="col-md-12 mt-2">
                                                        <lightning:input type="text" variant="label-hidden" aura:id="SQ2Ans" maxlength="30" placeholder="Security Answer" class="" />  
                                                    </div> 
                                                </div>
                                            </div>
                                            <div class="row topMargin ml-1 mb-2">
                                                <div class="col-md-2 col-6">
                                                    <button class="slds-button slds-button--brand  mt-2 USRProf-class11" type="button" onclick="{!c.saveQuestions}" >
                                                        Save
                                                    </button>
                                                </div>
                                                <div class="col-md-2 col-6">
                                                    <button class="slds-button slds-button--neutral mt-2 USRProf-class11" type="button" onclick="{!c.CancelQuestions}">
                                                        Cancel
                                                    </button>   
                                                </div>
                                            </div>
                                        </aura:if> 
                                    </div>
                                    <aura:if isTrue="{!v.showSQ}"> 
                                        <div class="col-md-3 topMargin mb-3">
                                            <button class="btn btn-default  mt-3 USRProf-class12" type="button" onclick="{!c.changeQuestions}"  >
                                                Change Questions
                                            </button>
                                        </div>
                                    </aura:if>
                                </div>
                                <div class="slds-grid" >
                                    <div class="slds-col slds-size_7-of-8 topMargin">
                                        <div>
                                        </div>
                                    </div>
                                </div>
                                
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
            <div class="slds-grid slds-m-top--large" >
                <div class="slds-col slds-size_7-of-8 topMargin">
                    <div>
                        <!-- <lightning-input  class="slds-form-element" lightning-input_input-host="">-->
                        <div class="slds-form-element__control" lightning-input_input="">
                            <!-- <span class="slds-checkbox" lightning-input_input="">
                          <input type="checkbox" id="input-1" name="connectToPeelNewsLetterCheck" change="{!c.subscribe}" value="{!v.changeSPN}" lightning-input_input=""/>
         <label for="input-1" class="slds-checkbox__label" lightning-input_input="">
         <span class="slds-checkbox_faux" lightning-input_input=""></span>-->
                            <h6 class="USRProf-class8">
                                <lightning:input type="checkbox" class="myCheckbox" aura:id="checkboxLeads"  onchange="{!c.subscribe}" checked="{!v.changeSPN}"/> 
                                
                                &nbsp;Subscribe to ERP Newsletter</h6>
                            <!-- </label>
                               </span>--></div>
                        <!-- </lightning-input>-->
                    </div>
                </div>
            </div>
            <button class="slds-button slds-button--brand mt-2 mb-2 mr-2"  type="button" onclick="{!c.goBack}">
                Back
            </button>
            <button class="slds-button slds-button_destructive mt-2 mb-2 " onclick="{!c.openPopup}" type="button" >
                Deactivate Account
            </button>
            <aura:if isTrue="{!v.isOpen}">
                <section role="dialog" tabindex="-2" aria-labelledby="modal-heading-02" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open USRProf-class12" >
                    <div class="slds-modal__container">
                        <div class="slds-modal__content slds-p-around_large" id="modal-content-id-1">
                            <label class="slds-radio">
                                <span class="slds-form-element__label"> <!--Record? --> </span> 
                                <span class="USRProf-class14">Are you sure you want to deactivate your account ?</span>
                            </label>
                        </div>
                        <footer class="slds-modal__footer event_rok USRProf-class15" >
                            <button type="button" class="slds-button slds-button_brand" data-dismiss="modal" data-record="delete" value="Yes"  aura:id="yesId" onclick="{!c.DeactivateUser}">Yes</button> 
                            <button  type="button" value="No" class="slds-button slds-button_neutral" data-record="NO"  aura:id="noId" onclick="{!c.CancelPopup}" >No</button> 
                            
                        </footer>
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open" role="presentation"></div>
            </aura:if> 
        </div>
        <!--<c:CommunityFooter></c:CommunityFooter>-->
    </div>
    
</aura:component>