<aura:component Controller="ERP7.IncomeStatementLightning" implements="force:hasSObjectName,force:hasRecordId,force:appHostable,forceCommunity:availableForAllPageTypes,flexipage:availableForRecordHome,force:appHostable,force:lightningQuickActionWithoutHeader" access="global">
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css,
                          /resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css
                          "/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/> 
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/IncomeStatement.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/IncomeStatementUpdated.css"/>
    <ltng:require styles="/resource/ERP7__ERPTheme/css/erpmain-theme.css"/>  
    
    <aura:method name="doInit" action="{!c.doInit}"/>
    <aura:attribute name="TotalIncome"   	 type="Double"  default="0.00"  />
    <aura:attribute name="TotalExpense"   	 type="Double"  default="0.00"  />
    <aura:attribute name="netProfit"   	 type="Double"  default="0.00"  />
    <aura:attribute name="showGraph"   	 type="Boolean"  default="true"  />
    <aura:attribute name="stopRepeat"  	 type="Boolean"  default="true"  />
    <aura:attribute name="showFilter"  	 type="Boolean"  default="false"  />
    <aura:attribute name="showSpinner"   type="Boolean"  default="false" />
    <aura:attribute name="InitLoad"   type="Boolean"  default="false" />
    <aura:attribute name="Instance"    	 type="c.IncomeStatementLightning" />
    <aura:attribute name="Tab"           type="String"   default="Tab1" /> 
    <aura:attribute name="setView"           type="String"   default="Annually" />
    <aura:attribute name="setKeys"       type="list" />
    <aura:attribute name="IncomeCOADataList"       type="list" />
    <aura:attribute name="setValues"     type="list" />
    <aura:attribute name="keyList"     type="list" />
    <aura:attribute name="setValues2"    type="list" />
    <aura:attribute name="setValues4"    type="list" />
    <aura:attribute name="chartyLabel"   type="String" />
    <aura:attribute name="Org"           type="String"   />
    <aura:attribute name="SD"            type="Date" />
    <aura:attribute name="ED"            type="Date" />
    <aura:attribute name="IncomeCOAData" type="list"/>
    <aura:attribute name="subCOAData" type="list"/>
    <aura:attribute name="ExpenseCOAData" type="list"/>
    <aura:attribute name="subCOADataExp" type="list"/>
    <aura:attribute name="SelectedCurrency" type="String"/>
    <aura:attribute name="expenseWrapperList" type="object[]"/>
    
    <aura:handler   name="change" value="{!v.Instance.transEdate}"  		     action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.transSdate}" 				 action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.SelectedCurrency}"			 action="{!c.fetchDetailscontroller}"  />
    
    
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Organisation__c}"   action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Project__c}"        action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Customer__c}"       action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Product__c}"        action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Employee__c}"       action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Site__c}"           action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Supplier__c}"       action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Channel__c}"        action="{!c.fetchUpdatedData}"  />
    <aura:handler   name="change" value="{!v.Instance.Select_Organisation.ERP7__Industry__c}"       action="{!c.fetchUpdatedData}"  /> 
    <aura:handler   name="change" value="{!v.Instance.SelectedFy }"                                 action="{!c.changeTabFY}"  /> 
    
    <aura:attribute name="FYOptions" type="List"/>
    <aura:attribute name="indusOptions" type="List"/>
    <aura:attribute name="stStatusOptions" type="List"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doinit}" />
    <aura:attribute name="renderCurrencyOutputField"  	 type="Boolean"  default="true"  />
    
    <body >
        <div class="erp_mark7 slds-container--fluid IncomeStatement-class1 erp" >
            <div class="container-fluid bg-white">
                <div class="slim-pageheader slds-p-around_small">
                    <ol class="breadcrumb slim-breadcrumb">
                        <li class="breadcrumb-item">
                            <span class="IncomeStatement-class12">
                                
                                <a  href="{!'/apex/ERP7__ComparisonIncomeStatement?CurrencyIso='+v.Instance.SelectedCurrency+'&amp;StartDate='+v.SD+'&amp;EndDate='+v.ED+'&amp;view='+v.setView+'&amp;sFY='+v.Instance.SelectedFy}" target="_blank" class="IncomeStatement-class32">
                                    <i class="fa fa-file-pdf-o IncomeStatement-class15" aria-hidden="true"></i>&nbsp;Download PDF </a></span>
                            <span class="IncomeStatement-class13">
                                <a  href="{!'/apex/ERP7__ComparisionIncomeStatement_Excel?CurrencyIso='+v.Instance.SelectedCurrency+'&amp;StartDate='+v.SD+'&amp;EndDate='+v.ED+'&amp;view='+v.setView+'&amp;sFY='+v.Instance.SelectedFy}" target="_blank" class="IncomeStatement-class36">
                                    <i class="fa fa-file-excel-o " aria-hidden="true" ></i>&nbsp;Download Excel </a>
                            </span>
                        </li>
                        
                        
                    </ol>
                    <h6 class="slim-pagetitle ">
                        <div class="row">
                            <div class="col-md-12"> 
                                Income Statement&nbsp;  
                                
                            </div>
                            <!--div class="col-md-12 pt-2">
                                <p class="trialbalance mb-0"> </p>
                            </div-->
                            
                        </div>
                        
                    </h6>
                    
                </div>
            </div>
            <!--Start of container 1-->
            <div class="slds-page-header slds-hide">
                <div class="slds-grid">
                    <div class="slds-col slds-has-flexi-truncate">
                        <div class="slds-media slds-no-space slds-grow">
                            <div class="slds-media__figure">
                                <lightning:icon iconName="utility:description" size="xx-small" alternativeText="description!" title="description" />
                                
                            </div>
                            <div class="slds-media__body">
                                <p class="slds-text-title--caps slds-line-height--reset">Finance</p>
                                <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate" title="">Income Statement </h1>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="epr_Mark7 IncomeStatement-class1" >
                <nav class="navbar  slds-theme--default slds-m-bottom--x-small IncomeStatement-class2 p-0">
                    <div class="container-fluid p-0">
                        <ul class="nav navbar-nav navbar-left IncomeStatement-class3">
                            <li class="{!v.Tab=='Tab1'?'active':''}">
                                <a  target="_blank" id="tabs-path-1" class="IncomeStatement-class4" name="Tab1" onclick="{!c.changeTab}"><i class="fa fa-file-text-o" ></i> Income Statement</a>
                            </li>
                            <li class="{!v.Tab=='Tab2'?'active':''}">
                                <a target="_blank" class="IncomeStatement-class5" id="tabs-path-2" name="Tab2" onclick="{!c.changeTab}"><i class="fa fa-clone"></i> Compare Income Statement</a>
                            </li>
                            <div class="slds-no-flex slds-p-top--xx-small slds-p-right--small IncomeStatement-class5">
                                <div class="slds-grid">
                                    <div class="slds-m-top--xx-small">
                                        <span class="slds-button slds-button_icon slds-button_icon-border-no-filled slds-p-around--x-small IncomeStatement-class6" title="Filters" onclick="{!c.perform}">
                                            <lightning:icon iconName="utility:filterList" size="x-small" alternativeText="filterList!" title="filterList" />
                                            
                                            <span class="slds-assistive-text" >Filters</span>
                                        </span>
                                    </div>
                                    
                                </div>
                            </div>                        
                            <aura:if isTrue="{!v.showFilter}">	
                                <section id="headsec" class="slds-popover slds-nubbin_top IncomeStatement-class7" role="dialog" aria-label="Dialog Title">
                                    
                                    <span class="slds-assistive-text">Close dialog</span>
                                    <div class="epr_Mark7 ">   
                                        
                                        <div class="IncomeStatement-class8" onclick="{!c.closeconfirm}">
                                            <i class="fa fa-times"></i>
                                        </div>
                                        
                                        <div class="container-fluid">
                                            <div class="slds-popover__body IncomeStatement-class3">
                                                <div class="row slds-m-top--small" >
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="Account" label="Organisation" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Organisation__c}" qry="AND (ERP7__Account_Type__C = 'Organisation' OR ERP7__Account_Type__c = 'Organisation/Vendor')"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Project__c" label="Project" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Project__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="Account" label="Customer" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Customer__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="Product2" label="Product" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Product__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row slds-m-top--small" >
                                                    
                                                    
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="Account" label="Employee" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Employee__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" label="Site" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Site__c}" />
                                                            </div>
                                                        </div>
                                                    </div>  
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="Account" label="Suplier" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Supplier__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" >
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Channel__c" label="Channel" IconName="standard:drafts" selectedRecordId="{!v.Instance.Select_Organisation.ERP7__Channel__c}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row slds-m-top--small" >
                                                    
                                                    <div class="col-md-3">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" > 
                                                                <lightning:select label="Industry"  aura:id="indus" value="{!v.Instance.Select_Organisation.ERP7__Industry__c}">
                                                                    <aura:iteration items="{!v.indusOptions}" var="option">
                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Instance.Select_Organisation.ERP7__Industry__c, option.value)}"/>
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                            </div>  
                                        </div>
                                    </div>  
                                </section></aura:if>
                            
                        </ul>
                    </div>
                </nav>
            </div>
            
            <aura:if isTrue="{!v.Tab=='Tab1'}" >
                <div id="content-path-1" class="slds-tabs--path__content slds-show pl-0 pr-0" role="tabpanel" aria-labelledby="tab-path-1" >
                    <!--Start of MainTab1-->
                    <div class="header-maq" id="myHeader">
                        <div class="container-fluid bg-tb slds-p-around_small">
                            <div class="row row-xs" data-aura-rendered-by="379:0">
                                <div class="col-sm-6 col-lg-4" data-aura-rendered-by="380:0">
                                    <div class="card card-status" data-aura-rendered-by="381:0">
                                        <div class="media" data-aura-rendered-by="382:0">
                                            <i class="icon fa fa-calculator tx-primary" data-aura-rendered-by="383:0"></i>
                                            <div class="media-body" data-aura-rendered-by="384:0">
                                                <h1 data-aura-rendered-by="385:0">
                                                    <aura:if isTrue="{!v.renderCurrencyOutputField}">
                                                        <aura:if isTrue="{!(0>v.netProfit)}">
                                                            <strong>
                                                                (
                                                                <c:CurrencyOutputField value="{!(0-v.netProfit)}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                                
                                                                
                                                                )
                                                            </strong>
                                                        </aura:if>
                                                        <aura:if isTrue="{!(v.netProfit>=0)}">
                                                            <!--{!v.Instance.userIsoCode}&nbsp; {!v.netProfit}-->
                                                            <c:CurrencyOutputField value="{!v.netProfit}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                            <strong>
                                                                <!--<ERP7:CurrencyOutputField value="{!v.TotalExpense}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> -->
                                                            </strong>
                                                        </aura:if>
                                                    </aura:if>
                                                </h1>
                                                <p data-aura-rendered-by="387:0">NET PROFIT</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-4 mg-t-10 mg-sm-t-0" data-aura-rendered-by="389:0">
                                    <div class="card card-status" data-aura-rendered-by="390:0">
                                        <div class="media" data-aura-rendered-by="391:0">
                                            <i class="icon fa fa-money tx-pink" data-aura-rendered-by="392:0"></i>
                                            <div class="media-body" data-aura-rendered-by="393:0">
                                                <h1 data-aura-rendered-by="405:0">
                                                    <aura:if isTrue="{!v.renderCurrencyOutputField}">
                                                        <aura:if isTrue="{!(0>v.TotalIncome)}">
                                                            <strong>
                                                                (
                                                                <c:CurrencyOutputField value="{!(0-v.TotalIncome)}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                                
                                                                
                                                                )
                                                            </strong>
                                                        </aura:if>
                                                        <aura:if isTrue="{!(v.TotalIncome>=0)}">
                                                            
                                                            <!--{!v.Instance.userIsoCode}&nbsp; {!v.TotalIncome}-->
                                                            <strong>
                                                                <c:CurrencyOutputField value="{!v.TotalIncome}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                                <!--<ERP7:CurrencyOutputField value="{!v.TotalExpense}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> -->
                                                            </strong>
                                                        </aura:if>
                                                    </aura:if>
                                                </h1>
                                                <p data-aura-rendered-by="398:0">TOTAL REVENUE</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-lg-4 mg-t-10 mg-lg-t-0" data-aura-rendered-by="400:0">
                                    <div class="card card-status" data-aura-rendered-by="401:0">
                                        <div class="media" data-aura-rendered-by="402:0">
                                            <i class="icon fa fa-money tx-teal" data-aura-rendered-by="403:0"></i>
                                            <div class="media-body" data-aura-rendered-by="404:0">
                                                <h1 data-aura-rendered-by="405:0">
                                                    <aura:if isTrue="{!v.renderCurrencyOutputField}">
                                                        <aura:if isTrue="{!(0>v.TotalExpense)}">
                                                            <strong>
                                                                (
                                                                <c:CurrencyOutputField value="{!(0-v.TotalExpense)}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                                
                                                                
                                                                )
                                                            </strong>
                                                        </aura:if>
                                                        <aura:if isTrue="{!(v.TotalExpense>=0)}">
                                                            <!--{!v.Instance.userIsoCode}&nbsp; {!v.TotalExpense}-->
                                                            <strong>
                                                                <c:CurrencyOutputField value="{!v.TotalExpense}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> 
                                                                <!--<ERP7:CurrencyOutputField value="{!v.TotalExpense}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" /> -->
                                                            </strong>
                                                        </aura:if>
                                                    </aura:if>
                                                </h1>
                                                <p data-aura-rendered-by="409:0">TOTAL EXPENSE</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="content-maq">
                        <div class="epr_Mark7">
                            <div class="container-fluid bg-tb pb-3">
                                <div class="slds row slds-p-top--xx-small">
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <div class="slds-col slds-form-element slds-m-right--xx-small">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <label class="slds-form-element__label">Start Date</label>
                                                <lightning:input type="date" class="input" value="{!v.Instance.transSdate}" id="startdate"  placeholder="Start Date"   />
                                                <!--<input id="text-input-01" class="slds-input" type="text" placeholder="Start Date"/>-->
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small ">
                                        <div class="slds-col slds-form-element">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <label class="slds-form-element__label">End Date</label>
                                                <lightning:input type="date" class="input" value="{!v.Instance.transEdate}" id="enddate"  placeholder="End Date"   />
                                                <!--<input id="text-input-01" class="slds-input" type="text" placeholder="End Date"/>-->
                                            </div>
                                        </div>
                                    </div>
                                    <aura:if isTrue="{!v.Instance.multiCurrencyEnabled}"> 
                                        <div class="col-md-3 slds-p-top--xx-small ">
                                            
                                            <div class="slds-col slds-form-element">
                                                <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                    <!--<label class="slds-form-element__label"></label>-->
                                                    <!--<lightning:select label="Currency"  aura:id="stStatus" value="{!v.Instance.SelectedCurrency}" >
                                                    <aura:iteration items="{!v.stStatusOptions}" var="option">
                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Instance.SelectedCurrency, option.value)}"/>
                                                    </aura:iteration>
                                                </lightning:select>-->
                                                </div>
                                            </div>
                                        </div></aura:if>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small" >
                                    </div>
                                </div>
                            </div>
                            
                            <!--Start of MainPb1-->
                            
                            <!--rendered="{!ShowFyWise}"-->
                            
                            <!--Filters-->
                            
                            <div class="container-fluid bg-tb p-0">
                                <div class="row m-0 mg-t-20 pb-7">
                                    <!-- Revenue-->
                                    <div class="col-lg-6">
                                        <div class="card card-table" data-aura-rendered-by="585:0">
                                            <div class="card-header" data-aura-rendered-by="586:0">
                                                <h6 class="slim-card-title" data-aura-rendered-by="587:0">REVENUE</h6>
                                            </div>
                                            <div class="table-responsive slds-p-around_small" data-aura-rendered-by="589:0">
                                                <div class="slds-card__body">
                                                    <ul>
                                                        <!--Start of MainPb1-->
                                                        
                                                        <aura:iteration items="{!v.IncomeCOAData}" var="Fyacc">
                                                            <!--<c:MapIteration map="{!v.IncomeCOAData}" key="{!key}" />-->
                                                            <!--<aura:if isTrue="{!Fyacc.Name=='Income_Revenue'?true:false}">-->
                                                            <li class="slds-tile slds-hint-parent">
                                                                <div class="slds-tile__detail">
                                                                    <dl class="slds-dl--horizontal slds-text-body--medium">
                                                                        <!--<aura:iteration items="{!myMap[key]}" var="Fysubacc">-->
                                                                        <div class="bbColor slds-grid slds-wrap">
                                                                            <!--<aura:if isTrue="{!!Fysubacc.contraFlag}">-->
                                                                            <dt class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_8-of-12 slds-dl--horizontal__label  IncomeStatement-class21" >
                                                                                
                                                                                <lightning:formattedText value="{!if(Fyacc.key == 'Sales','Net '+Fyacc.key,Fyacc.key)}"/><br/>
                                                                                
                                                                            </dt>
                                                                            <dd class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_4-of-12 text-right">
                                                                                <aura:iteration items="{!v.subCOAData}" var="subAcc">
                                                                                    <aura:if isTrue="{!equals(Fyacc.key,subAcc.key)}">
                                                                                        <aura:if isTrue="{!0>subAcc.value}">
                                                                                            (<c:CurrencyOutputField value="{!subAcc.value}" isoCode="{!v.Instance.userIsoCode}" Rate="-1" />)
