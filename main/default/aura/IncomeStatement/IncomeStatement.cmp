                                                                                <dt class="slds-col slds-size_1-of-1 slds-medium-size_6-of-12 slds-large-size_8-of-12 slds-dl--horizontal__label IncomeStatement-class21">
                                                                                    <p class="slds-truncate" >
                                                                                        <a href="{!$Label.c.Report_Access+'fv0='+FyMainacc.AccountName+'&amp;fv1='+v.Instance.transSdate+'&amp;fv2='+v.Instance.transEdate+'&amp;fv4='+v.Instance.Select_Organisation.ERP7__Organisation__c}" target="_blank"><lightning:formattedText value="{!if(FyMainacc.AccountName == 'Sales','Gross '+FyMainacc.AccountName,FyMainacc.AccountName)}"/></a>
