                                                                                </aura:set>
                                                                            </aura:if>
                                                                        </dd>
                                                                        <!--</aura:if>  -->  
                                                                        
                                                                    </div>
                                                                    
                                                                    <aura:iteration items="{!Fyacc.ExpenseList}" var="FyMainacc">
                                                                        <div class="bbColor slds-grid slds-wrap">
