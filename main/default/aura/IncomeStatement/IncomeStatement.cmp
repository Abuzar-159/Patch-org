            </aura:if>
            
            <!--END OF TAB-1-->
            <aura:if isTrue="{!v.Tab=='Tab2'}">
                <div id="content-path-2" class="slds-tabs--path__content IncomeStatement-class1" role="tabpanel" aria-labelledby="tab-path-1">
                    <div class="epr_Mark7  container-fluid">
                        <div class="slds row slds-p-top--xx-small">
                            <div class="col-md-3 slds-p-top--xx-small">
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <c:CustomInputLookUp objectAPIName="Account" label="Organisation" IconName="standard:drafts" selectedRecordId="{!v.Org}" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 slds-p-top--xx-small ">
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control">
                                        <lightning:select aura:id="FY" value="{!v.Instance.SelectedFy}" label="Financial Year (FY)">
                                            <aura:iteration items="{!v.FYOptions}" var="option">
                                                <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Instance.SelectedFy, option.value)}"/>
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 slds-p-top--xx-small ">
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label" >Start Date</label>
                                        <lightning:input type="date" value="{!v.SD}" id="startdate" styleClass="slds-input"  />
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-3 slds-p-top--xx-small">
                                <div class="slds-form-element">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label class="slds-form-element__label" >End Date</label>
                                        <lightning:input type="date" value="{!v.ED}" id="enddate" styleClass="slds-input"  />
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>   
                    <div class="slds-m-top--x-small slds-m-bottom--x-small  slds-p-top--xxx-small slds-p-left--xx-small IncomeStatement-class29">
                        <p class="IncomeStatement-class11">Chart Data </p>
                    </div>
                    <div class="IncomeStatement-class30">
                        <a value="View Annually " name="Fyear" onclick="{!c.changeGraphData}" ><button class="{!v.setView=='Annually'?'slds-button slds-button_outline-brand brand-active':'slds-button slds-button_outline-brand'}"><i class="fa fa-bar-chart"></i>&nbsp;View Annually </button></a>
                        &nbsp;
                        <a value="| View Quaterly  " name="FQuarter" onclick="{!c.changeGraphData}"  ><button class="{!v.setView=='Quaterly'?'slds-button slds-button_outline-brand brand-active':'slds-button slds-button_outline-brand'}"><i class="fa fa-bar-chart"></i>&nbsp;View Quaterly </button></a>
                        &nbsp;
                        <a value="| View Monthly " name="FMonthly" onclick="{!c.changeGraphData}" ><button class="{!v.setView=='Monthly'?'slds-button slds-button_outline-brand brand-active':'slds-button slds-button_outline-brand'}"><i class="fa fa-bar-chart"></i>&nbsp;View Monthly </button></a>
                    </div>
                    <div name="Chart Data">
                        <!--<aura:if isTrue="{!v.showGraph}">
                            <ERP7:Chart keys="{!v.setKeys}" values="{!v.setValues2}" values2="{!v.setValues4}" values3="{!v.setValues}"  xLabel="{!v.Instance.ChartTitle}"  yLabel="{!v.chartyLabel}"  bgColor="#FF0000" bgColor2="#00b200" bgColor3="blue"  chartType="bar" label="Total Income" label2="Total Expense" label3="Net Profit" />
                        </aura:if>-->
                    </div>
                    <div class="slds slds-container--fluid">
                        <div class="slds-m-top--x-small  slds-p-top--xxx-small slds-p-left--xx-small IncomeStatement-class31">
                            <p class="IncomeStatement-class11">
                                Tabular Data 
                                
                                <span class="IncomeStatement-class12">
                                    
                                    <a  href="{!'/apex/ERP7__ComparisonIncomeStatement?CurrencyIso='+v.Instance.SelectedCurrency+'&amp;StartDate='+v.SD+'&amp;EndDate='+v.ED+'&amp;view='+v.setView+'&amp;sFY='+v.Instance.SelectedFy}" target="_blank" class="IncomeStatement-class32"><i class="fa fa-file-pdf-o IncomeStatement-class33" aria-hidden="true" ></i>&nbsp;Download PDF </a></span>
                                <span class="IncomeStatement-class13">
                                    <a  href="{!'/apex/ERP7__ComparisionIncomeStatement_Excel?CurrencyIso='+v.Instance.SelectedCurrency+'&amp;StartDate='+v.SD+'&amp;EndDate='+v.ED+'&amp;view='+v.setView+'&amp;sFY='+v.Instance.SelectedFy}" target="_blank" class="IncomeStatement-class36">
                                        <i class="fa fa-file-excel-o IncomeStatement-class37" aria-hidden="true"></i>&nbsp;Download Excel </a>
                                </span>
                                
                            </p>
                        </div>
                        <div class="slds-card">
                            <div class="slds-card__body">
                                <table class="slds-table slds-no-row-hover">
                                    <tr class="IncomeStatement-class34">
                                        <td  colspan="3" class="assets-text cfd-tabs IncomeStatement-class35">
                                            Financial year
                                        </td>
                                    </tr>
                                </table>
                                
                                <!--Start of Tabular data Header-->
                                <div class="table-responsive">
                                    <table class="slds-table  slds-table--condensed slds-no-row-hover">
                                        <thead>
                                            <tr>
                                                <td width="30%"></td>
                                                
                                                <aura:if isTrue="{!v.Instance.FinancialAccountIncomeStmt2Wrapper.length>0}">
                                                    <aura:if isTrue="{!and(v.Instance.FinancialAccountIncomeStmt2Wrapper[0].innnerWrpperW2, v.Instance.FinancialAccountIncomeStmt2Wrapper[0].innnerWrpperW2.length > 0)}">
                                                        <aura:iteration items="{!v.Instance.FinancialAccountIncomeStmt2Wrapper[0].innnerWrpperW2}" var="sFname" >
                                                            <aura:if isTrue="{!and(sFname.innerWrapperW1, sFname.innerWrapperW1.length > 0)}">
                                                                <td >{!sFname.innerWrapperW1[0].num}</td>
                                                            </aura:if>
                                                        </aura:iteration>
                                                    </aura:if>
                                                </aura:if>
                                            </tr>
                                            
                                            <aura:if isTrue="{!v.Instance.ShowQuartely}">
                                                <tr>
                                                    <td width="30%"></td> 
                                                    <aura:iteration items="{!v.Instance.quarterNames}" var="Q">
                                                        <td class="assets-text IncomeStatement-class19">
                                                            {!Q}
                                                        </td>
                                                    </aura:iteration>
                                                </tr>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!v.Instance.ShowMonthly}">
                                                <tr >    
                                                    <td width="30%"></td> 
                                                    <aura:iteration items="{!v.Instance.monthNames}" var="m">
                                                        <td class="assets-text IncomeStatement-class19">
                                                            {!m}                                                                                      
                                                        </td>
                                                    </aura:iteration>
                                                </tr>
                                            </aura:if>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td width="30%" colspan="13"><strong>Revenue</strong></td>
                                            </tr>
                                            <aura:iteration items="{!v.Instance.FinancialAccountIncomeStmt2Wrapper}" var="sFyear" >
                                                <tr>
                                                    <td width="30%">{!sFyear.W3COA}</td>
                                                    <aura:iteration items="{!sFyear.innnerWrpperW2}" var="sFname" >
                                                        <aura:iteration items="{!sFname.innerWrapperW1}" var="sFq" >
                                                            <!--  <aura:iteration items="{!FinancialAccountIncomeStmt2}" var="tval"> -->
                                                            <td ><!-- class="assets-text IncomeStatement-class18" -->
                                                                <!--              (<apex:outputField value="{!tval.ERP7__Amount__c}"/>) -->
                                                                <aura:if isTrue="{!sFq.W1trans.ERP7__Amount__c>=0}">
                                                                    
                                                                    <c:CurrencyOutputField value="{!sFq.W1trans.ERP7__Amount__c}" isoCode="{!v.Instance.userIsoCode}" Rate="{!v.Instance.currencyRate}" />
                                                                    
                                                                </aura:if>
