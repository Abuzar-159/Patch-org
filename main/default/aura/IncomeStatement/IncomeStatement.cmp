                                                        </li>
                                                        
                                                        <!--</aura:if>-->
                                                    </aura:iteration>
                                                    
                                                    <li class="slds-tile slds-hint-parent">
                                                        <div class="slds-tile__detail">
                                                            
                                                            <dl class="slds-dl--horizontal slds-text-body--medium IncomeStatement-class22" >
                                                                <dt class="slds-dl--horizontal__label col-md-6 pl-0">
                                                                    <p class="slds-truncate mb-0">
                                                                        <a href="javascript:void(0);" class="tx-18" data-aura-rendered-by="679:0">
                                                                            <i class="fa fa-briefcase mg-r-5" data-aura-rendered-by="680:0"></i>&nbsp;
                                                                            <strong data-aura-rendered-by="681:0">TOTAL Operating Expense</strong>
                                                                        </a>  
                                                                    </p>
                                                                </dt>
                                                                <dd class="slds-dl--horizontal__detail slds-tile__meta col-md-6 text-right pr-0">
                                                                    <aura:if isTrue="{!v.renderCurrencyOutputField}">
                                                                        <p class="slds-truncate mb-0 tx-18">
                                                                            <!-- <apex:outputField value="{!Fyacc.Container.ERP7__Amount__c}"/>-->
                                                                            
                                                                            <aura:if isTrue="{!(0>v.TotalExpense)}">
                                                                                <strong>
                                                                                    (
