<aura:component controller="ProductLifecycleManagement" implements="force:appHostable,forceCommunity:availableForAllPageTypes" access="global">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        
        <ltng:require styles="/resource/SLDS/assets/styles/salesforce-lightning-design-system-vf.css, /resource/SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css,
                              /resource/PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/PickPackShipResource/assets/styles/font-awesome.css"/>
    </head>   
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/RoutingDetails.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchEventHandler}"/> 
    <aura:attribute name="ProductId" type="ID" default=""/> 
    <aura:attribute name="Tab" type="String" default="rou"/>
    <aura:attribute name="action" type="String" default=""/>
    <aura:attribute name="showPopup" type="Boolean" default="false"/>
    <aura:attribute name="Product" type="Product2" default=""/>
    <aura:attribute name="Media" type="Media__c" default=""/>
    <aura:attribute name="MediaList" type="String[]"/>
    <aura:attribute name="Routing" type="Routing__c" default=""/>
    <aura:attribute name="RoutingList" type="String[]"/>
    <aura:attribute name="Version" type="Version__c" default=""/>
    <aura:attribute name="VersionList" type="String[]"/>
    
    <aura:attribute name="WarrantyRP" type="Warranty_Return_Policy__c" default=""/>
    <aura:attribute name="WarrantyRPList" type="String[]"/>
    <aura:attribute name="ChangeOrder" type="Change_Order__c" default=""/>
    <aura:attribute name="ChangeOrderList" type="String[]"/>
    <aura:attribute name="QualityOrder" type="Quality_Order__c" default=""/>
    <aura:attribute name="QualityOrderList" type="String[]"/>
    <aura:attribute name="PBE" type="PricebookEntry"/>
    <aura:attribute name="PBEList" type="String[]"/>
    
    <aura:attribute name="ProductFamilyList" type="String[]"/>
    <aura:attribute name="ProductTypeList" type="String[]"/>
    <aura:attribute name="ProductCategoryList" type="String[]"/>
    <aura:attribute name="ProductTaxCodeList" type="String[]"/>
    <aura:attribute name="ProductSubCategoryList" type="String[]"/>
    <aura:attribute name="ProductUoMList" type="String[]"/>
    <aura:attribute name="ProductQuantityUnitOfMeasureList" type="String[]"/>
    <aura:attribute name="ProductStatusList" type="String[]"/>
    <aura:attribute name="ProductWeightDimensionsList" type="String[]"/>
    
    <aura:attribute name="RoutingStatusList" type="String[]"/>
    <aura:attribute name="RoutingTypeList" type="String[]"/>
    <aura:attribute name="VersionStatusList" type="String[]"/>
    <aura:attribute name="VersionTypeList" type="String[]"/>
    <aura:attribute name="VersionCategoryList" type="String[]"/>
    <aura:attribute name="ReturnPolicyRefundOptionList" type="String[]"/>
    
    <aura:attribute name="seBool" type="Boolean" default="false"/>
    <aura:attribute name="sError" type="String" default="All * Fields are mandatory"/>
    <aura:attribute name="priceBookMsg" type="String" default=""/>   
    <aura:attribute name="Index" type="ID" default=""/>
    <aura:attribute name="MediaTypeList" type="String[]"/>
    <aura:attribute name="COCategoryList" type="String[]"/>
    <aura:attribute name="COTypeList" type="String[]"/>
    <aura:attribute name="COStatusList" type="String[]"/>
    <aura:attribute name="COProjectList" type="String[]"/>
    <aura:attribute name="SaveMsg" type="String" default=""/> 
    <aura:attribute name="showMainSpin" type="Boolean" default="false"/> 
    <aura:attribute name="WarrantyRPRO" type="String[]"/>
    
    <aura:attribute name="BOMTypeList" type="String[]"/>
    <aura:attribute name="BOMComponentTypeList" type="String[]"/>
    <aura:attribute name="BOMStatusList" type="String[]"/>
    
    <aura:attribute name="MediaListD" type="String[]"/> 
    <aura:attribute name="RoutingListD" type="String[]"/> 
    <aura:attribute name="VersionListD" type="String[]"/> 
    <aura:attribute name="WarrantyRPListD" type="String[]"/> 
    <aura:attribute name="ChangeOrderListD" type="String[]"/>
    <aura:attribute name="QualityOrderListD" type="String[]"/> 
    <aura:attribute name="PBEListD" type="String[]"/> 
    <aura:attribute name="CloneURL" type="String" default=""/> 
    <aura:attribute name="Clone" type="Boolean" default="false"/>     
    <aura:registerEvent name="AttachmentEvnet" type="c:AttachmentEvnet"/> 
    
    <aura:attribute name="BOM" type="BOM__c"/> 
    <aura:attribute name="BOMList" type="String[]"/> 
    <aura:attribute name="BOMListD" type="String[]"/> 
    
    <aura:attribute name="RoutingId" type="String" default=""/>  <!-- a101o00000Ck6d9AAB  -->
    <aura:attribute name="Operation" type="Operation__c"/> 
    <aura:attribute name="OperationList" type="String[]"/> 
    <aura:attribute name="OperationListD" type="String[]"/> 
    <aura:attribute name="RoutingRTList" type="String[]"/> 
    
    <div class="erp_mark7 RoutingDt-class1" aura:id="body">
        <div class="slds-page-header slds-m-bottom--xx-small">
            <div class="slds-media">
                <div class="slds-media__figure">
                    <span class="slds-icon_container slds-icon-action-back slds-icon--large" title="">              
                        <lightning:icon iconName="standard:product" size="x-small" alternativeText="product!" title="product" />              
                    </span>
                </div>
                <div class="slds-media__body">
                    <h1 class="slds-page-header__title slds-truncate slds-align-middle slds-m-top--small" title="">Product Routing
                        
                        
                    </h1>
                    
                </div>
                <div class="slds-col slds-grid slds-align-middle"><!--Modern Floral Cold Process Kit Routing--> 
                    <h2 class="slds-page-header__title slds-truncate"> {!v.Routing.Name}</h2>
                    
                </div>
                <div class="slds-col slds-no-flex slds-grid slds-align-top">
                    <button class="slds-button slds-button--neutral" 
                            onclick="{!c.cancelRecord}" aura:id="saveProductId">{!$Label.c.EmployeeReviewV2_Back}</button>
                </div> 
            </div>
        </div>
        <div class="epr_Mark7 slds-m-bottom--small">
            <div class="container-fluid">
                <div class="row RoutingDt-class2">
                    <div class="col-md-2 col-xs-2 RoutingDt-class3">
                        
                        <!-- Tabs -->
                        <div class="tabbable tabs-left">
                            <ul class="nav nav-tabs">
                                <li class="active RoutingDt-class4" onclick="{!c.getTab}" data-name="rou" data-service="0" aura:id="TabId">
                                    <a data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-product-hunt"></i></P><span class="slds-truncate RoutingDt-class7" >Routing</span></a>
                                </li>
                                
                                
                                <li class="RoutingDt-class4" onclick="{!c.getTab}" data-name="ope" data-service="1" aura:id="TabId">
                                    <a data-toggle="tab">
                                        <P class="iconclass"><i class="fa fa-stack-overflow"></i></P><span class="slds-truncate RoutingDt-class7" >Operations</span></a>
                                </li>
                                
                            </ul>
                        </div>
                    </div>
                    
                    
                    <div class="col-md-10">
                        <div>
                            <div class="tab-content">
                                
                                
                                <div class="" id="routingTabId" aura:id="routingTabId">
                                    <aura:if isTrue="{!v.Tab=='rou'}">  
                                        
                                        
                                        <aura:if isTrue="{!v.SaveMsg!=''}">
                                            <div class="maq-only erp_mark7">
                                                <div class="slds-notify_container slds-is-relative">
                                                    <div class="slds-notify slds-notify_toast slds-theme--success" role="alert">                                   
                                                        <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top" title="">
                                                            <lightning:icon iconName="action:approval" size="x-small" alternativeText="Success!" title="Success" />
                                                            
                                                        </span>
                                                        <div class="slds-notify__content RoutingDt-class5">
                                                            <h2 class="slds-text-heading_small ">{!v.SaveMsg}</h2>
                                                        </div>
                                                        
                                                        <div class="slds-notify__content RoutingDt-class8">
                                                            <button class="slds-button slds-button_icon slds-notify__close slds-button_icon-inverse" title="Close" 
                                                                    onclick="{!c.getNotificationHide}">
                                                                <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />		
                                                                
                                                                
                                                                <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                            </button>
                                                            
                                                        </div>
                                                        
                                                    </div>
                                                </div>
                                            </div>
                                            
                                        </aura:if>  
                                        
                                        
                                        
                                        <div class="erp_mark7">   
                                            <div>     
                                                <div class="row slds-m-top--small">
                                                    <div class="col-md-12">    
                                                        <span class="{!v.seBool==true?'RoutingDt-class6 red':'RoutingDt-class6 slds-hide'}">
                                                            <i class="fa fa-window-close RoutingDt-class9" aria-hidden="true"></i> &nbsp; Code field is mandatory
                                                        </span>
                                                    </div>
                                                </div>
                                                
                                                <div class="row">
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Code</label>
                                                            <div class="slds-form-element__control">
                                                                <lightning:input type="text" variant="label-hidden" value="{!v.Routing.Name}"/>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <lightning:select value="{!v.Routing.ERP7__Status__c}" label="Status">
                                                                    <aura:iteration items="{!v.RoutingStatusList}" var="option">
                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Routing.ERP7__Status__c, option.value)}"/>
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <lightning:select value="{!v.Routing.ERP7__Type__c}" label="Type">
                                                                    <aura:iteration items="{!v.RoutingTypeList}" var="option">
                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Routing.ERP7__Type__c, option.value)}"/>
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <lightning:select value="{!v.Routing.RecordTypeId}" label="Record Type">
                                                                    <aura:iteration items="{!v.RoutingRTList}" var="option">
                                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.Routing.RecordTypeId, option.value)}"/>
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    
                                                    
                                                    
                                                    <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}" -->
                                                </div>
                                                
                                                <div class="row">
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id">BOM Version</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Version__c" selectedRecordId="{!v.Routing.ERP7__BOM_Version__c}" 
                                                                                        placeholder="Search BOM Versions..." IconName="custom:custom24"/> <!--  qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span> {!$Label.c.Process}</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Process__c" selectedRecordId="{!v.Routing.ERP7__Process__c}" 
                                                                                        placeholder="Search Process..." IconName="standard:orders"/> <!--   qry="{! 'AND ERP7__Product__c = \''+v.ProductId+'\''}"  -->
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Channel_StockTake}</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Channel__c" selectedRecordId="{!v.Routing.ERP7__Channel__c}" 
                                                                                        placeholder="Search Channel..." IconName="custom:custom24"/> 
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span> Finished Products Site</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" selectedRecordId="{!v.Routing.ERP7__Finished_Products_Site__c}" 
                                                                                        placeholder="Search Finished Products Site..." IconName="custom:custom32"/>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                
                                                <div class="row">
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Raw Materials Site</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Site__c" selectedRecordId="{!v.Routing.ERP7__Raw_Materials_Site__c}" 
                                                                                        placeholder="Search Raw Materials Site..." IconName="custom:custom32"/> 
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Planner_ManufacturingWB}</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" selectedRecordId="{!v.Routing.ERP7__Planner__c}" 
                                                                                        placeholder="Search Planners..." IconName="utility:user"/> 
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="input-unique-id">Engineer</label>
                                                            <div class="slds-form-element__control">
                                                                <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" selectedRecordId="{!v.Routing.ERP7__Engineer__c}" 
                                                                                        placeholder="Search Engineers..." IconName="utility:user"/> 
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <lightning:input type="number" label="Minimum Lot Size" value="{!v.Routing.ERP7__Minimum_Lot_Size__c}"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                                
                                                <div class="row">
                                                    <div class="col-md-3 slds-p-top--small">
                                                        <div class="slds-form-element">
                                                            <div class="slds-form-element__control">
                                                                <lightning:input type="number" label="Maximum Lot Size" value="{!v.Routing.ERP7__Maximum_Lot_Size__c}"/>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="row RoutingDt-class10" >                                         
                                                    <div class="row RoutingDt-class11" >                                                                                 
                                                        <div class="mainfloatbutton RoutingDt-class4">
                                                            
                                                            <button class="slds-button slds-button--brand" 
                                                                    onclick="{!c.saveRecord}" aura:id="saveProductId">{!$Label.c.ContractConsole_Save}</button> 
                                                            
                                                            
                                                            
                                                        </div> <!--{!v.VersionId==''?'RedButtonClass slds-button slds-button-brand':'slds-button slds-button-brand'}   -->
                                                    </div>
                                                    
                                                    <div class="row RoutingDt-class11" >                                      
                                                        <div class="col-md-10 RoutingDt-class4" >                                                
                                                            
                                                        </div>
                                                    </div>
                                                    
                                                    
                                                </div>
                                                
                                                
                                                
                                            </div>
                                            
                                        </div>   
                                        
                                    </aura:if>          
                                </div>                       
                                
                                
                                
                                
                                
                                <div class="" id="operationTabId" aura:id="operationTabId">
                                    <aura:if isTrue="{!v.Tab=='ope'}">
                                        
                                        <div class="slds-page-header RoutingDt-class12"> 
                                            <div class="slds-grid">
                                                <div class="slds-col slds-has-flexi-truncate">
                                                    <div class="slds-media slds-no-space slds-grow">
                                                        <div class="slds-media__body">
                                                            <nav>
                                                                <ol class="slds-breadcrumb slds-line-height_reset">
                                                                    
                                                                </ol>
                                                            </nav> 
                                                            <h4 class="slds-m-right_small slds-align-middle" title="">Operations({!v.OperationList.length}) 
                                                                <!--slds-truncate  -->
                                                                
                                                            </h4>    
                                                        </div>
                                                        
                                                    </div>
                                                    
                                                    
                                                </div>
                                                <div class="slds-col slds-align-middle">  
                                                    
                                                    <c:StockTakeSearch Placeholder="Search By Code or Work Center or Fixed Cost"/> 
                                                    
                                                </div>
                                                
                                                <div class="slds-col slds-no-flex slds-align-middle slds-m-top--small">     
                                                    <button onclick="{!c.showNewPopup}" data-name="ope" data-service="new" class="slds-button slds-button--brand">
                                                        <i class="fa fa-plus"></i>&nbsp;{!$Label.c.New_AddTimeCardEntry}</button>
                                                </div> 
                                                
                                            </div>
                                        </div>
                                        <div class="slds-card__body RoutingDt-class13" >
                                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-top--small">
                                                <thead>
                                                    <tr class="slds-text-title--caps">
                                                        <th class="slds-cell-shrink" scope="col">
                                                            &nbsp;
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Actions">  Actions                                                          
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Code">Code
                                                                
                                                            </div>
                                                        </th>
                                                        
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Work Center">{!$Label.c.Work_Center_UserAvailabilities}
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Work Center">Work Planner
                                                                
                                                            </div>
                                                        </th>
                                                        
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Process Cycle">Process Cycle
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Process Cycle">Fixed Cost
                                                                
                                                            </div>
                                                        </th>
                                                        <th scope="col">
                                                            <div class="slds-truncate" title="Process Cycle">Variable Cost
                                                                
                                                            </div>
                                                        </th>
                                                        
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <aura:iteration items="{!v.OperationList}" var="r" indexVar="index">
                                                        <tr class="slds-hint-parent">
                                                            <td scope="row" data-label="">
                                                                
                                                                
                                                            </td>
                                                            <td data-label="Actions">
                                                                
                                                                <img onclick="{!c.getRecord}" class="RoutingDt-class14" data-name="update" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_edit.png" width="20" height="20" id="0" title="Edit" />
                                                                &nbsp;
                                                                <img onclick="{!c.getDelete}" class="RoutingDt-class14" data-name="delete" data-service="{!index}" src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" width="20" height="20" id="0" title="Delete" />
                                                                
                                                            </td>
                                                            <td scope="row" data-label="Name">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!r.Name}"/> 
                                                                </div>
                                                            </td>
                                                            
                                                            <td data-label="Version">
                                                                <div class="slds-truncate">
                                                                    <lightning:formattedText value="{!r.ERP7__Work_Center__r.Name}"/> 
                                                                </div>
                                                            </td>
                                                            <td data-label="Type">
                                                                
                                                                <div class="slds-truncate">
                                                                    <lightning:formattedText value="{!r.ERP7__Work_Planner__r.Name}"/> 
                                                                </div>
                                                            </td>
                                                            <td data-label="Type">
                                                                
                                                                <div class="slds-truncate">
                                                                    <lightning:formattedText value="{!r.ERP7__Process_Cycle__r.Name}"/> 
                                                                </div>
                                                            </td>
                                                            <td data-label="Type">
                                                                
                                                                <div class="slds-truncate">
                                                                    <lightning:formattedNumber style="currency" value="{!r.ERP7__Fixed_Cost__c}"/> 
                                                                </div>
                                                            </td>
                                                            <td data-label="Type">
                                                                
                                                                <div class="slds-truncate">
                                                                    <lightning:formattedNumber style="currency" value="{!r.ERP7__Variable_Cost__c}"/> 
                                                                </div>
                                                            </td>
                                                            
                                                        </tr>
                                                    </aura:iteration>      
                                                    
                                                </tbody>
                                            </table>
                                        </div>
                                        
                                        
                                        <aura:if isTrue="{!v.showPopup}"> 
                                            <div class="erp_mark7"> 
                                                <section id="ppId" role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1"
                                                         class="slds-modal slds-fade-in-open slds-modal--large"> 
                                                    <div class="slds-modal__container">
                                                        
                                                        <div>
                                                            <div class="slds-modal__header">
                                                                <button onclick="{!c.HideNewPopup}" class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close">
                                                                    <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="Close!" title="Close" />		
                                                                    
                                                                    <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                                                </button>
                                                                
                                                                <h4 class="modal-title slds-align--absolute-center" >
                                                                    <aura:if isTrue="{!v.Tab!='update'}"> {!$Label.c.New_AddTimeCardEntry}
                                                                        <aura:set Attribute="else">{!$Label.c.Update}</aura:set>               
                                                                    </aura:if>
                                                                    Operation
                                                                </h4>
                                                            </div>
                                                            <div class="slds-modal__content slds-p-around_medium RoutingDt-class15" >
                                                                <!-- height:250px;   -->
                                                                <div class="row slds-m-top--small">
                                                                    <div class="col-md-12">    
                                                                        <span class="{!v.seBool==true?'RoutingDt-class6 red':'RoutingDt-class6 slds-hide'}" >
                                                                            <i class="fa fa-window-close RoutingDt-class9" aria-hidden="true" ></i> &nbsp;{!v.sError}
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                
                                                                
                                                                
                                                                <div class="row">
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Code</label>
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="text" variant="label-hidden" value="{!v.Operation.Name}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Work_Center_UserAvailabilities}</label>
                                                                            <div class="slds-form-element__control">
                                                                                
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Work_Center__c" selectedRecordId="{!v.Operation.ERP7__Work_Center__c}" 
                                                                                                        placeholder="Work Center..." IconName="standard:address"/>
                                                                            </div>  <!--  qry="{! ' AND ERP7__Product__c=\''+v.ProductId+'\''}"   -->
                                                                            
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id">Work Planner</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Work_Planner__c" selectedRecordId="{!v.Operation.ERP7__Work_Planner__c}" 
                                                                                                        placeholder="Work Planner..." IconName="utility:user"/> 
                                                                            </div>
                                                                            
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <label class="slds-form-element__label" for="input-unique-id"><span class="red">*</span>Process Cycle</label>
                                                                            <div class="slds-form-element__control">
                                                                                <c:CustomInputLookUp objectAPIName="ERP7__Process_Cycle__c" selectedRecordId="{!v.Operation.ERP7__Process_Cycle__c}" 
                                                                                                        placeholder="Process Cycle..." IconName="standard:product"/> 
                                                                            </div>
                                                                        </div>
                                                                    </div>                  
                                                                    
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" formatter="currency" step="0.01" label="Fixed Cost" value="{!v.Operation.ERP7__Fixed_Cost__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control"> 
                                                                                <lightning:input type="number" formatter="currency" step="0.01" label="Variable Cost" value="{!v.Operation.ERP7__Variable_Cost__c}"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>    
                                                                    <div class="col-md-3 slds-p-top--small">
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Operation No" value="{!v.Operation.ERP7__Operation_No__c}"/>
                                                                            </div>
                                                                            
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Next Operation No" value="{!v.Operation.ERP7__Next_Operation_No__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div> 
                                                                </div>
                                                                
                                                                <div class="row">
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Setup Time" value="{!v.Operation.ERP7__Setup_Time__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>   
                                                                    
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Wait Time" value="{!v.Operation.ERP7__Wait_Time__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Run Time" value="{!v.Operation.ERP7__Run_Time__c}"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>   
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:input type="number" label="Move Time" value="{!v.Operation.ERP7__Move_Time__c}" />
                                                                            </div>
                                                                        </div>
                                                                    </div>       
                                                                    
                                                                    
                                                                    
                                                                </div>
                                                                
                                                                <div class="row">
                                                                    <div class="col-md-3 slds-p-top--small"> 
                                                                        <div class="slds-form-element">
                                                                            <div class="slds-form-element__control">
                                                                                <lightning:textarea label="Description" value="{!v.Operation.ERP7__Description__c}"/>
                                                                            </div>
                                                                        </div>
                                                                    </div>      
                                                                </div>    
                                                                
                                                                
                                                                
                                                                
                                                            </div>
                                                            <footer class="slds-modal__footer slds-text-align--center">
                                                                <button  onclick="{!c.HideNewPopup}" type="button" class="slds-button slds-button--neutral" data-dismiss="modal">{!$Label.c.Cancel_ManageLeave}</button>
                                                                <button onclick="{!c.saveRecord}" type="button" class="slds-button slds-button--brand" >{!$Label.c.ContractConsole_Save}</button>
                                                            </footer>
                                                            
                                                        </div>
                                                        
                                                    </div>   
                                                    
                                                </section>	
                                                <div class="slds-backdrop slds-backdrop--open"></div>
                                            </div>
                                        </aura:if>
                                        
                                        
                                    </aura:if>  
                                </div>
                                
                                
                                
                                
                                
                                
                                
                                
                                
                                <!--  ====================================  DELETE RECORDS =========================================== -->                    
                                <div aria-hidden="true" class="slds slds-hide" aura:id="deleteConfirmId"> 
                                    <div aria-hidden="false" role="dialog" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container RoutingDt-class16" >
                                            <div class="slds-modal__content"> 
                                                <div class="slds-modal__content slds-p-around--medium"> 
                                                    <div class="slds-form-element__control">
                                                        <label class="slds-radio">
                                                            <span class="slds-form-element__label"> <!--Record? --> </span> <br/>
                                                            <span class="RoutingDt-class17">Are you sure you want to delete this record?</span>
                                                        </label>
                                                    </div> 
                                                </div>  
                                                <div  class="modal-footer RoutingDt-class18" >  
                                                    <span >
                                                        <button type="button" class="slds-button slds-button--brand" data-dismiss="modal" data-record="Yes" value="Yes" 
                                                                aura:id="yesId" onclick="{!c.saveRecord}">{!$Label.c.Yes_UserAvailabilities}</button> 
                                                        <button type="button" value="No" class="slds-button slds-button--neutral" data-record="NO"  aura:id="noId"
                                                                onclick="{!c.cancelDelete}">{!$Label.c.No}</button> 
                                                        
                                                    </span>   
                                                </div>
                                            </div> 
                                        </div>                    
                                    </div>       
                                    <div class="slds-backdrop slds-backdrop--open"></div>         
                                </div>            
                                
                                
                                
                                
                                
                                
                            </div>    
                        </div>
                    </div>    
                    
                    
                </div>
            </div>
        </div> 
        
    </div>               
</aura:component>