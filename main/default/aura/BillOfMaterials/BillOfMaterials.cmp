<aura:component controller="ProductConfig">
    <ltng:require styles="/resource/ERP7__SLDS213/assets/styles/salesforce-lightning-design-system-vf.css" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="versionComp" type="Version__c"/>
    <aura:attribute name="bomVId" type="String" />
    <aura:attribute name="Vbom" type="Version__c" default="{ 'sobjectType': 'Version__c',
                                                                   'Name': '',
                                                                   'ERP7__Barcode__c':'',
                                                                   'ERP7__Status__c':'',
                                                                   'ERP7__Unit_of_Measure__c':'',
                                                                   'ERP7__Start_Date__c':'',
                                                                   'ERP7__To_Date__c':'',
                                                                   'ERP7__Type__c':'',
                                                                   'ERP7__Category__c':'',
                                                                   'ERP7__Description__c':'',
                                                                   'ERP7__Process__c':''}" />
    <aura:attribute name="boms" type="BOM__c" />
    <aura:attribute name="verBOM" type="BOM__c" default="{'sObjectType':'ERP7__BOM__c','Name':'','ERP7__Process_Cycle__c':'','ERP7__Quantity__c':'','ERP7__Type__c':'','ERP7__Phase__c':'','ERP7__Unit_of_Measure__c':'','ERP7__Active':true}"/>
    <!--Start -->
    <aura:registerEvent name="delete" type="c:billofmaterialDelete" />
    <aura:handler name="delete" action="{!c.handleBOMDelete}" />
    <aura:attribute name="BomTypeOptions" type="List"/>
    <aura:attribute name="BomPhaseOptions" type="List"/>
    <aura:attribute name="BomUoMOptions" type="List"/>
    
    <!--End-->
	<!--Bill Of Materials Tabble starts here-->
                    	<div id="content-path-1" class="slds-tabs--path__content slds-show" role="tabpanel" aria-labelledby="tab-path-1">
                            <div class="epr_Mark7">
                                <div class="row slds-m-top--small">
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01">Name</label>
                                            <div class="slds-form-element__control">
                                                <lightning:input type="text" variant="label-hidden"  maxlength="30" value="{!v.verBOM.Name}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01">Process Cycle</label>
                                            <div class="slds-form-element__control">
                                                <c:ProjectLookups type="Process_Cycle__c"  className="slds-input" value="{!v.verBOM.ERP7__Process_Cycle__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01">Quantity</label>
                                            <div class="slds-form-element__control">
                                                <lightning:input type="text" variant="label-hidden"  maxlength="30" value="{!v.verBOM.ERP7__Quantity__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                    
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="email">Type</label>
                                            <div class="slds-form-element__control">
                                                <lightning:select aura:id="BomType" value="{!v.verBOM.ERP7__Type__c}" variant="label-hidden" class="display-lable">
                                                    <aura:iteration items="{!v.BomTypeOptions}" var="option">
                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.verBOM.ERP7__Type__c, option.value)}"/>
                                                    </aura:iteration>
                                                </lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01" >Phase</label>
                                            <div class="slds-form-element__control">
                                                 <lightning:select aura:id="BomPhase" value="{!v.verBOM.ERP7__Phase__c}" variant="label-hidden" class="display-lable">
                                                    <aura:iteration items="{!v.BomPhaseOptions}" var="option">
                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.verBOM.ERP7__Phase__c, option.value)}"/>
                                                    </aura:iteration>
                                                </lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01">UoM</label>
                                            <div class="slds-form-element__control">
                                                <lightning:select  aura:id="BomUoM" value="{!v.verBOM.ERP7__Unit_of_Measure__c}" variant="label-hidden" class="display-lable">
                                                    <aura:iteration items="{!v.BomUoMOptions}" var="option">
                                                        <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.verBOM.ERP7__Unit_of_Measure__c, option.value)}"/>
                                                    </aura:iteration>
                                                </lightning:select>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label BillOfMaterials-newClass1" for="text-input-01">Active</label>
                                            <div class="slds-form-element__control">
                                                <lightning:input type="checkbox" variant="label-hidden" checked="{!v.verBOM.ERP7__Active__c}"/>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-1">
                                        <div class="slds-form-element">
                                            <label class="slds-form-element__label" for="text-input-01"></label>
                                            <div class="slds-form-element__control">
                                                
                                                <a class="svg" onclick="{!c.handleDelClick}">
                                                    <img src="/resource/ERP7__SLDS0121/assets/icons/action/delete_60_red.png" height="22" title="Remove Item" width="22" />
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                </div>
                                <div class="row slds-m-top--small">
                                    
                                </div>
                            </div>
                        </div>
                    <!--Bill Of Materials Table ends here-->
</aura:component>