                                                                     <aura:if isTrue="{!(sos.MOrders.ERP7__Order__c != null)}" >
                                                                         <lightning:formattedText value="{!sos.MOrders.ERP7__Order__r.Account.Name}" onclick="{!c.NavRecord}" title="{!sos.MOrders.ERP7__Order__r.AccountId}" /> 
                                                                    </aura:if>
                                                                </div> 
                                                            </td>
                                                              <aura:if isTrue="{!v.showInboundDescription}">
                                                                  <td data-label="" class="InboundLog-class23 scanMN" data-id="{!sos.MOrders.Id}">
                                                                  </td>
                                                              </aura:if>
                                                              <td data-label="Action" class="InboundLog-class23">
                                                                  <div class="slds-truncate"> 
                                                                    <table class="InboundLog-class20">
                                                                        <tr>
                                                                            <td width="50%" class="p-0">
                                                                                <div class="erp_Mark7 maqsood">
                                                                                    <div class="card folder m-1 mb-0 mt-0 border-custom-m">
                                                                                        <div class="card-body p-2">
                                                                                            <div class="folder-icon">
                                                                                                <i class="fa fa-level-down InboundLog-class26" aria-hidden="true" ></i>&nbsp;
                                                                                            </div>
                                                                                             <div class="folder-info">
                                                                                                 <a class="InboundLog-class28" onclick="{!c.ReceiveClickedMO}" data-logisticId="{!sos.MOrders.Id}">{!$Label.c.Inbound_Receive}</a>  
                                                                                                 <span><div class="InboundLog-class30" title="{!(sos.MOrders.ERP7__Quantity_Produced__c + sos.MOrders.ERP7__Scrap_Quantity__c) + ' /' + (sos.MOrders.ERP7__Quantity__c)}">{!(sos.MOrders.ERP7__Quantity_Produced__c + sos.MOrders.ERP7__Scrap_Quantity__c)}/{!sos.MOrders.ERP7__Quantity__c}</div></span>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                      </table>
                                                                  </div>
                                                              </td>
                                                              <aura:if isTrue="{!v.ShowAttachment}">
                                                                  <td data-label="" class="InboundLog-class23" >
                                                                      <div class="slds-col">
                                                                          <lightning:input aura:id="fileik" type="file" files="{!v.FileList}" name="{!sos.MOrders.Id}" onchange="{!c.onFileUploaded}" onfocus="{!c.reRender}" oncomplete="{!c.reRender}" onblur="{!c.reRender}" onmouseover="{!c.reRender}" onmouseout="{!c.reRender}" multiple="true" class="InboundLog-class31"/>
                                                                      </div>
                                                                      <div class="scroll-wrap-height-cntl">
                                                                        <aura:iteration var="attch" indexVar="attchIndex" items="{!sos.Attachments}">
                                                                            <aura:if isTrue="{!(attch.Id != undefined)}">
                                                                                
                                                                                <div class="slds-grid slds-p-top_small">
                                                                                    <div class="slds-col">
                                                                                        <lightning:buttonIcon iconName="utility:delete" variant="bare" name="{!attch.Id}" onclick="{!c.DeleteRecordAT}" alternativeText="delete" title="{!sos.MOrders.Id}" class="colorRed"/>
                                                                                        &nbsp;
                                                                                        <lightning:formattedUrl value="{!'/'+attch.Id}" label="{!attch.Name}" tooltip="{!attch.Name}" target="_blank" class="fcolor"/>
                                                                                    </div>
                                                                                    <div class="slds-col">
                                                                                        <img src="{!'/servlet/servlet.FileDownload?file='+attch.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                                                                    </div>
                                                                                </div>
                                                                                
                                                                            </aura:if>
                                                                        </aura:iteration>
                                                                    </div>
                                                                  </td>
                                                              </aura:if>
                                                         </tr>
                                                             
                                                     
                                                     </aura:iteration>
                                                    <!-- <aura:set attribute="else">
                                                       No records are available to view
                                                     </aura:set>-->
                                                </aura:if>
                                            </tbody>                             
                                        </table>
                                    </div> 
                                </aura:if>
                                
                                <!-- commented by Arshad 14/02/23
                                <aura:if isTrue="{!v.shownonReceivedLogs}">
