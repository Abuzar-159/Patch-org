                                <c:CreateBillItem projectId="{!v.Bill.ERP7__Project__c}" DepartmentAccess="{!v.DepartmentAccess}" ProjectAccess="{!v.ProjectAccess}" RT="{!v.setRT}" showExpenseAccount="{!v.showExpenseAccount}" aura:id="billItems" Item="{!item}" typeOpts="{!v.Itemtype}" ExpenseTypeOpts="{!v.Expensetype}" index="{!ind}" deleteIndex="{!v.deleteIndex}" billItems="{!v.billItems}" showVenName = "{!v.showVenName}" showProdCode = "{!v.showProdCode}"
                                                  TDS_Amount="{!v.TDS_Amount}" Field_Display="{!v.CreateBillFLSCheck.OtherTaxAccess}"  TDS_Display="{!v.CreateBillFLSCheck.TDSAccess}" Discount_Display="{!v.CreateBillFLSCheck.DiscountAccess}" showAllocation="{!v.showAllocations}" AutoAccountAllocation="{!v.AutoAccountAllocations}" 
                                                  TDS_Rate="{!v.TDS_Rate}" displayName="{!v.displayName}" TotalPrice="{!v.TotalPrice}"  Tax="{!v.Tax}" fromPortal="{!v.fromPortal}" aura:Id="bill_Items" hideRemove="{#not(empty(v.Bill.ERP7__Purchase_Order__c))}"/>
                            </aura:iteration>
                           </aura:if>-->
                        </tbody>
                    </table>   
                    
                </div>
                
                
                <div class="slds-p-top--small"></div>
                <div class="slds-grid slds-grid_align-center slds-p-around--small">
                    <div class="slds-docked-form-footer">
                        
                        <div class="slds-col-1">
                            <span>       
                                <lightning:button label="{!$Label.c.Cancel_ManageLeave}" class="slds-button slds-button--neutral" onclick="{!v.cancelclick}" variant="neutral" />&nbsp;
                            </span>
                        </div>
                        
                        <div class="slds-col-1">
                            <span>
                                <div onmouseover="{!c.setpostFalse}">
                                    <lightning:button label="{!$Label.c.ContractConsole_Save}" class="slds-button slds-button__brand" onclick="{!c.saveBill}" variant="brand" disabled="{!v.showMmainSpin}"/>
                                </div>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </aura:if>
        
        <aura:if isTrue="{!v.ShowBillType}"> 
            <div class="erp_Mark7 ">
                <section role="dialog" tabindex="-2" aria-labelledby="modal-heading-02" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-modal_medium slds-fade-in-open">
                    <div class="slds-modal__container">
                        <header class="slds-modal__header">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="{!$Label.c.Close_Timesheets}" onclick="{!v.cancelclick}">
                                <lightning:icon iconName="utility:close" variant="inverse" size="small" alternativeText="{!$Label.c.Close_Timesheets}" title="{!$Label.c.Close_Timesheets}" />
                                
                                <span class="slds-assistive-text">{!$Label.c.Close_ProjectScheduler}</span>
                            </button>
                            <p id="modal-heading-01" class="createbill-class8">{!$Label.c.Select_Bill_Type}</p>
                        </header>
                        <div class="slds-modal__content" id="modal-content-id-1">
                            
                            <div class="epr_Mark7">
