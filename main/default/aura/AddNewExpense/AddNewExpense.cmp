<aura:component Controller="ERP7.ExpenseSheetLC">
    <aura:attribute name="parentId" type="Id" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="ExpenselistObj" type="Expense_Line_Item__c[]" />
    <aura:attribute name="emp" type="Employees__c" default="{sobjectType : 'Employees__c'}" />
    <aura:attribute name="expenseComp" type="Expense__c" />
    <aura:registerEvent name="saveEventFired" type="c:saveEvent" />
    <aura:attribute name="expli" type="Object" default="[]"/>
    <aura:attribute name="eLineItem" type="Expense_Line_Item__c" default="{'sobjectType' : 'Expense_Line_Item__c'}" />
    <aura:attribute name="Expense" type="Expense__c" default="{ 'sobjectType': 'Expense__c',
                                                                    'Name':'',                                                                
                                                                    'ERP7__Employees__c': '',
                                                                    'unknown_custom_field':'',
                                                                    'unknown_custom_field':'',
                                                                    'ERP7__Status__c': '',
                                                                    'ERP7__Project__c':''                                                                
                                                                    }" />    
    <div class="erp_mark7">
        <lightning:spinner variant="brand" size="small" aura:id="spinner" class="slds-hide"/>
        <div class="slds-container--fluid">
            
            <!-- Header starts here-->
            <div class="slds-page-header slds-page-header--object-home" role="banner">
                <div class="slds-grid">
                    <div class="slds-col slds-has-flexi-truncate">
                        <div class="slds-media slds-no-space slds-grow">
                            <div class="slds-media__figure">
                                <span aria-hidden="true" class="slds-icon slds-icon-standard-account slds-icon--large AddNewExpense-newClass1"> 
                                    <img src="/resource/1482140524000/erp7__SLDS213/assets/icons/custom/stock_disp.png" width="58"/>
                                </span>
                            </div>
                            <div class="slds-media__bod AddNewExpense-newClass2">
                                <p class="slds-text-title--caps slds-line-height--reset"></p>
                                <nav class="slds-context-bar__secondary" role="navigation">
                                    <ul class="slds-grid">
                                        <li class="slds-context-bar__item slds-context-bar__dropdown-trigger slds-dropdown-trigger slds-dropdown-trigger--hover slds-p-top_small AddNewExpense-newClass3" aria-haspopup="true">
                                            <a class="slds-context-bar__label-action" title="Menu Item" onclick="{!c.Cancel}">
                                                <span class="slds-truncate"><h1 class="slds-page-header__title slds-truncate" title="Sales Order">Add Expenses</h1></span>
                                            </a>
                                        </li>
                                        
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                    <div class="slds-col slds-no-flex slds-grid slds-align-top slds-p-bottom_xx-small">
                        <div class="slds-form-element" >
                            
                            <div  class="AddNewExpense-newClass5">
                                <div class="slds-form-element">
                                    <lightning:icon iconName="standard:contact" size="x-small" alternativeText="contact!" title="contact" />&nbsp;
                                    <div class="slds-form-element__control">
                                        <label class="slds-form-element__label AddNewExpense-newClass6" for="email">{!v.emp.ERP7__First_Name__c} &nbsp;{!v.emp.ERP7__Last_Name__c}</label>
                                    </div>
                                </div>
                            </div>                            
                        </div>
                    </div>
                </div>
            </div>
            <!-- Header ends here-->
            
            <!--BODY starts here-->
            <div class="slds">
                <div aura:id="hide">
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <lightning:input type="text" aura:id="name" label="Name" value="{!v.Expense.Name}" maxlength="30" />
                        </div>
                    </div>
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <c:CustomInputLookUp objectAPIName="ERP7__Project__c" label="Project" IconName="standard:product" selectedRecordId="{!v.Expense.ERP7__Project__c}"/>
                        </div>
                    </div>
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <c:CustomInputLookUp objectAPIName="User" label="Approver" IconName="standard:user" selectedRecordId="{!v.Expense.ERP7__Approver__c}"/>
                        </div>
                    </div>
                    
                    <div class="slds-form-element">
                        <div class="slds-form-element__control">
                            <lightning:select aura:id="status" label="Status" value="{!v.Expense.ERP7__Status__c}" >
                                <option value="Draft">Draft</option>
                                <option value="Submitted">Submitted</option>
                            </lightning:select>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="slds">
                <div class="slds-card__body">
                    <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal">
                        <thead class="slds-box slds-theme--shade">
                            <tr>
                                <th class="slds-text-heading--label slds-size--1-of-10 AddNewExpense-newClass7" scope="col" colspan="2">
                                    <button class="slds-button slds-button--neutral slds-button--small" onclick="{!c.Navigate}">New</button>
                                </th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Name</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Category</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Type</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Date</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Amount Submitted</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">VAT/Tax</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Claimed Amount</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Add Receipt</th>
                                <th class="slds-text-heading--label slds-size--1-of-10" scope="col" colspan="2">Receipt</th>
                            </tr>
                        </thead>
                        <tbody>
                                <c:ExpenseLineItem aura:Id="poli" Expense="{!v.Expense}" expenseComp="{!v.expenseComp}" eLineItem="{!v.eLineItem}"/>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!--BODY ends here-->
            
            <div class="slds-p-top--small"></div>
            
            <div class="slds-text-align--center slds-p-around--medium float-button ">
                <lightning:button label="Cancel"  class="slds-button slds-button--neutral" onclick="{!c.cancelClick}"/> &nbsp;
                <lightning:button label="Save" variant="brand" class="slds-button slds-button--brand white" onclick="{!c.saveExpenseSheet}"/>
            </div>
            
        </div>
    </div>
</aura:component>