<aura:component implements="force:hasSObjectName,force:hasRecordId,force:appHostable,forceCommunity:availableForAllPageTypes,flexipage:availableForRecordHome,force:appHostable,force:lightningQuickActionWithoutHeader" access="global">
	<ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/erp_mark7_bootstrap.css, /resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css,
                          /resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css
                         "/>
   
    <aura:attribute name="value"   type="decimal" access="global" />
    <aura:attribute name="finalValue"   type="decimal" access="global"/>
    <aura:attribute name="isoCode" type="String" access="global" />
    <aura:attribute name="Rate"    type="decimal" access="global"/>
    <aura:handler   name="init" value="{!this}" action="{!c.doInit}"/>
    
    <aura:if isTrue="{!v.finalValue!=null}">
     {!v.isoCode}&nbsp;<lightning:formattedNumber value="{!v.finalValue}"  maximumFractionDigits="2" minimumFractionDigits="2"/>
    </aura:if>
	
</aura:component>