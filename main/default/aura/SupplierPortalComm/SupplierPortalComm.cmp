<aura:component controller="SupplierPortalPO" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global">
    <ltng:require styles="{!join(',',
                          $Resource.ProductListComm + '/ProductListComm/css/bootstrap.custom.min.css',
                          $Resource.ProductListComm + '/ProductListComm/css/style.css')}"/>
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/ProductListComm/css/account.css'}"/>
    
    <ltng:require styles="{!$Resource.SupplierPoratalComm  + '/SupplierPortalComm/CSS/SupplierportalComm.css'}"/>
    
    <ltng:require scripts="{!join(',',
                           $Resource.ProductListComm + '/ProductListComm/script/common_scripts.min.js',                           
                           $Resource.ProductListComm + '/ProductListComm/script/main.js',
                           $Resource.ProductListComm + '/ProductListComm/script/carousel_with_thumbs.js'
                           )}" afterScriptsLoaded="{!c.after}"/>
    
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/SupplierPortalComm.css"/>
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/>
    <aura:handler name="init" value="{!this}" action="{!c.initial}" />
    <aura:registerEvent name="ProductListCommEvent" type="c:ProductListCommEvent"/>
    <aura:attribute name="errMsg" type="String" default="" access="global"/>
    <aura:attribute name="errMsg1" type="String" default="" access="global"/>
    
    <aura:attribute name="securityQuestion" type="String" />
    <aura:attribute name="isVisible" type="boolean" default="true"/>
    <aura:attribute name="forgotPassword" type="boolean" default="false"/>
    
    <aura:attribute name="ResetUsername" type="String" />
    <aura:attribute name="Username" type="String" />
    <aura:attribute name="Password" type="String" />
    <aura:attribute name="askForSecurityQuestion" type="boolean" default="false"/>
    <aura:attribute name="randomQuesNumber" type="String" />
    <aura:attribute name="securityAnswer" type="String" />
    <aura:attribute name="show" type="String" default="login"/>
    <aura:attribute name="mainURL" type="String" />
    <aura:attribute name="registerSuccess" type="Boolean" default="false" />
    <aura:attribute name="mylabel1" type="String"/>
    <aura:attribute name="mylabel" type="String"/>
    
    <aura:attribute name="AccId" type="String" default=""/>
    <aura:attribute name="UserName1" type="String" default=""/>
    <aura:attribute name="PortalUser" type="Boolean" default="false"/>
    <aura:attribute name="Action" type="String" default="SignIn"/>
    <aura:attribute name="ActionName" type="String" default="Sign In"/>
    <aura:attribute name="showSignIn" type="Boolean" default="false"/>
    <aura:handler event="c:ProductListCommEvent" action="{!c.eventHandle1}"/>
    <aura:registerEvent name="SupplierPortalCommEvent" type="c:SupplierPortalCommEvent"/>
    
    <aura:attribute name="Spinner" type="boolean" default="false"/>
    <aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/>
    <aura:attribute name="RegistererrMsg" type="String" default="" access="global"/>    
    <aura:attribute name="RegisterfirstNameInfo" type="String" default="" access="global"/>
    <aura:attribute name="RegistermiddleNameInfo" type="String" default="" access = "global"/>
    <aura:attribute name="RegisterlastNameInfo" type="String" default="" access="global"/>
    <aura:attribute name="RegisteremailInfo" type="String" default="" access="global"/>  
    <aura:attribute name="RegisternewsLetter" type="Boolean" default="false" />
    <aura:attribute name="UserProfId" type="String" default="" />
    <aura:handler event="c:ProductListCommEvent" action="{!c.eventHandle2}"/>
    <aura:attribute name="imageURL" type="String" default=""/>
    <aura:attribute name="showdropdown" type="Boolean" default="false" />
    <!--<aura:if isTrue="{!v.Spinner}">
        <lightning:spinner variant="brand" size="large" alternativeText="Please wait while loading..."/>        
    </aura:if>-->
    
    <div class="erp_mark7">
        <header class="version_1 erp_mark7">
            <div class="layer"></div><!-- Mobile menu overlay mask -->
            <div class="main_nav inner shadow-sm">
                <div class="container-fluid">
                    <div class="row small-gutters">
                        <div class="col-xl-3 col-lg-3 col-md-6 col-6">
                            <nav class="menu"><!--categories-->
                                <ul class="clearfix">
                                    <li><span> 
                                        <a class="SupplierPCm-class1" href="" onclick="{!c.home}">	
                                            <aura:if isTrue="{!v.imageURL != ''}">
                                                <img src="{!v.imageURL}"  class="SupplierPCm-class2"></img> 
                                                <aura:set attribute="else">
                                                	LOGIN PAGE 
                                                </aura:set>
                                            </aura:if>
                                        </a>
                                        </span>
                                        
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <div class="col-xl-6 col-lg-6 col-md-6 d-none d-md-block">
                            
                        </div> 
                        <div class="col-xl-3 col-lg-3 col-md-6 col-6">
                            <ul class="top_tools">
                                <li>
                                    <div class="dropdown dropdown-access" >
                                        <aura:if isTrue="{!v.PortalUser}">
                                            <a href="" onclick="{!c.showdropdownmenu}" class="access_link SupplierPCm-class3" ><span>Account</span>&nbsp;<div class="usersupplierportal SupplierPCm-class4" title="{!v.UserName1}">{!v.UserName1}</div></a>
                                            <aura:if isTrue="{!v.showdropdown}">
                                                <div class="dp1 dropdown-menu" style="display: block !important;">                                                  
                                                    <ul>
                                                        <li>
                                                            <a class="SupplierPCm-class3" onclick="{!c.home}" href=""><i class="ti-home"></i>Dashboards</a>
                                                        </li>
                                                        
                                                        <li>
                                                            <a class="SupplierPCm-class3" href="{!'https://'+$Label.c.Host_PathCustomerPortal+$Label.c.SupplierUserProfile}" onclick="{!c.getChangePassword}"><i class="ti-user"></i>My Profile</a>
                                                        </li>
                                                        
                                                        <li>
                                                            <a class="SupplierPCm-class3" href="{!'https://'+$Label.c.Host_PathCustomerPortal+$Label.c.SupplierSiteURL}"><i class="ti-unlock"></i>Logout</a>
                                                        </li>
                                                        <!--li>
                                                        <a class="SupplierPCm-class3" target="_blank" href="https://support.aqxolt.com/faqs/"><i class="ti-help-alt"></i>Help and Faq</a>
                                                    </li-->
                                                    </ul>
                                                </div>
                                            </aura:if>
                                        </aura:if>
                                    </div>
                                </li>     
                                
                                <!-- /dropdown-access-->
                            </ul>
                        </div>
                    </div>
                    <!-- /row -->
                </div>
                <div class="search_mob_wp">
                    <input type="text" class="form-control" placeholder="Search over 10.000 products"/>
                    <input type="submit" class="btn_1 full-width" value="Search"/>
                </div>
                <!-- /search_mobile -->
            </div>
            <!-- /main_nav --> 
        </header>
        
        <aura:if isTrue="{!!v.PortalUser}">
            <aura:if isTrue="{!!v.forgotPassword}">
                <aura:if isTrue="{!!v.securityQuestion}">
                    <aura:if isTrue="{!v.isVisible}">
                        <div class="page_header"></div>
                        <div class="row justify-content-center m-0">
                            <div class = "{!(v.show == 'login')?'SupplierPCm-class5 col-xl-6 col-lg-6 col-md-8':'SupplierPCm-class6 col-xl-6 col-lg-6 col-md-8'}">
                                <div class="box_account">
                                    <c:ProductListCommSignIn/>
                                </div>
                            </div>
                            <div class = "{!(v.show == 'Register')?'SupplierPCm-class4':'SupplierPCm-class5'}">
                                <aura:if isTrue="{!v.show == 'Register'}">
                                    <aura:if isTrue="{!!v.registerSuccess}"> 
                                        <div class="box_account">
                                            <div class="form_container"> 
                                                <c:ProductListCommRegistration/>
                                                <aura:if isTrue="{!(v.RegistererrMsg != '')}"> 
                                                    <div class="SupplierPCm-class7"> 
                                                        {!v.RegistererrMsg}
                                                    </div>
                                                </aura:if> 
                                            </div>     
                                        </div>
                                        <aura:set attribute="else">
                                            <div class="event-rok">
                                                <div class="container">
                                                    <div class="col-md-12 mb-4 mt-3 text-center">
                                                        <div dir="ltr" data-aura-rendered-by="27:2;a" class="uiOutputRichText mt-5" data-aura-class="uiOutputRichText">
                                                            <br data-aura-rendered-by="28:2;a"/> 
                                                            <br data-aura-rendered-by="28:2;a"/> 
                                                            <p class="tempStyle SupplierPCm-class8" data-aura-rendered-by="28:2;a">
                                                                <i class="fa fa-check-circle chevronright-confirmed1"></i><br/> 
                                                                You have successfully registered!
                                                            </p>
                                                            <p>Please check your email and complete the registration process</p> 
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                            </div>
                                            <lightning:layout class = "slds-container slds-grid getSomeMoreSpace">
                                                
                                                <div class="slds-col slds-m-left--small SupplierPCm-class9">
                                                    <lightning:layoutitem class = "getSomSpace2">    
                                                        <lightning:button label="OK"  class="slds-m-top--medium btn btn-primary"  onclick="{!c.hideRegister}"/>
                                                    </lightning:layoutitem>
                                                </div>
                                                
                                            </lightning:layout>
                                        </aura:set>
                                    </aura:if>
                                </aura:if>
                            </div>
                        </div>
                    </aura:if>
                    <aura:set attribute="else">                
                        <!--Copy security question flow-->
                        <form class="slds-form--stacked getSomeSpace">                    
                            
                            <div class="page_header"></div>
                            <div class="row justify-content-center m-0">
                                <div class="col-xl-6 col-lg-6 col-md-8">
                                    <div class="box_account">
                                        
                                        <div class="form_container">
                                            <div id="error1"> 
                                                <lightning:formattedRichText value="{!v.mylabel1}" class="errorsupplierred"/>
                                            </div>
                                            <div class="slds-form-element ">
                                                <label class="slds-form-element__label " for="SecurityAnswer"> 
                                                    <abbr class="slds-required" title="required">*</abbr> 
                                                    {!v.securityQuestion}
                                                </label>
                                                <div class="slds-form-element__control">
                                                    <label class="slds-form-element__label " for="SecurityAnswer"> 
                                                        <abbr class="slds-required" title="required">*</abbr>Security Answer
                                                    </label>
                                                    <lightning:input type="password" required="true"  value="{!v.securityAnswer}"  aura:id="SecurityAnswer"/>
                                                </div>
                                            </div>
                                            
                                            <div>
                                                <div>
                                                    <span class="slds-radio">
                                                        <input type="radio" aura:id = "nameRadioAuraId" id="nameRadioId" name="options" checked="Checked" />
                                                        <label class="slds-radio__label" for="nameRadioId">
                                                            <span class="slds-radio--faux"></span>
                                                            <span class="slds-form-element__label SupplierPCm-class10" >Ask me a security question each time I login using this device 
                                                                (recommended if you are using a public or shared device)</span>
                                                        </label>
                                                    </span>
                                                </div>
                                                <div>
                                                    <span class="slds-radio">
                                                        <input type="radio" aura:id = "tokenRadioAuraId" value = "tkn" id="tokenRadioId" name="options" />
                                                        <label class="slds-radio__label" for="tokenRadioId">
                                                            <span class="slds-radio--faux"></span>
                                                            <span class="slds-form-element__label SupplierPCm-class10" >Do not ask me a security question each time I login this device</span>
                                                        </label>
                                                    </span>
                                                </div>
                                            </div>    
                                            <div class="slds-grid pt-2 pb-2">
                                                <lightning:button label="Next" class="btn_1 half-width mr-2" onclick="{!c.verifySequrityQuestion}"/>
                                                <button type="button" class="btn_1 gray half-width" onclick="{!c.hideSignIn}">Cancel</button>  
                                                
                                            </div>   
                                            
                                            <!--div class="modal-footer pt-0 pb-0">
                                                <div class="options text-center mt-1 SupplierPCm-class11" >
                                                    <p class = "free-Text mb-2 SupplierPCm-class12" > 
                                                        Forgot	<a href="{!$Label.c.UserProfile+'?UN='+v.Username}" role="menuitem" tabindex="0" class="SupplierPCm-class13"> password/security question ?</a>
                                                    </p>                                                      
                                                </div>                         
                                            </div-->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </aura:set>
                </aura:if>
                <aura:set attribute="else">
                    <!-- Forgot Password--> 
                    <!--<aura:if isTrue="{!v.Action=='ForgotPassword'}">   -->    
                    
                    <div class="page_header">
                        
                        
                    </div>
                    <div class="row justify-content-center m-0">
                        <div class="col-xl-6 col-lg-6 col-md-8">
                            <div class="box_account"> 
                                
                                <div class="form_container">
                                    
                                    <div class="" id="panel9" role="tabpanel">
                                        <aura:renderIf isTrue="{!(v.errMsg != '')}"> 
                                            <div class="{!if((v.errMsg != 'Please check your email and proceed with further steps'),'PL-newClass1','PL-newClass2')}"> 
                                                {!v.errMsg}
                                            </div>        
                                        </aura:renderIf>
                                        <div class="modal-body mb-1 p-3">
                                            
                                            <div id="error1"> 
                                                <lightning:formattedRichText value="{!v.mylabel1}" class="errorsupplier"/>
                                            </div>
                                            <div class="form form-sm mb-3">                    
                                                <lightning:input aura:id="FormReset" 
                                                                 name="Username"
                                                                 type="email"
                                                                 placeholder="Enter Username"
                                                                 value="{!v.ResetUsername}"
                                                                 required="true" label="User Name"
                                                                 class=""                                     
                                                                 />
                                            </div>
                                            <div class="text-center SupplierPCm-class14">
                                                <input type="submit" value="Reset" class="btn_1 half-width mr-2" onclick="{!c.submitresetPass}"/>
                                                <input type="submit" value="Cancel" class="btn_1 gray half-width" onclick="{!c.hidereset}"/>                        
                                            </div>
                                        </div>   
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!--</aura:if>-->
                </aura:set>
            </aura:if>
            <aura:set attribute="else">                
                <!--<h2>{!v.UserName}</h2>&nbsp;&nbsp;&nbsp;&nbsp;
                    <a href="{!$Label.c.SupplierSiteURL}" class="btn_1 mb-2">Logout</a><br/><br/>-->                    
                <c:SupplierPortalCommHome AccId="{!v.AccId}"/> 
            </aura:set>
        </aura:if>
    </div>
    
</aura:component>