<aura:component controller="InternalStockTransfer">
    <aura:attribute name="showMultidelete" type="Boolean" default="false"/> 
    <aura:attribute name="Showputaway" type="Boolean" default="false"/> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:attribute name="CartItemInfo" type="object[]" />
    <aura:attribute name="item" type="Map" default="{Id:null,Name:'',ERP7__Available_Stock__c:0,ERP7__Quantity__c:0.00,ERP7__Product__c:'',ERP7__From_Location__c:'', ERP7__Product__r:{Id:'',Name:'',ERP7__Serialise__c:'',ERP7__Lot_Tracked__c:''}, ERP7__Serial_Number__c:'',ERP7__Serial_Number__r:{Id:'',Name:''},ERP7__Batch_Lot__c:'',ERP7__Batch_Lot__r:{Id:'',Name:''},ERP7__Fixed_Asset__c:'',ERP7__Fixed_Asset__r:{Id:'',Name:''},ERP7__Inventory_Stock__c:''}" />
    <aura:attribute name="prod" type="Map" default="{}" />
    <aura:attribute name="siteID" type="String" default=""/>
    <aura:attribute name="cartID" type="String" default=""/>
    <aura:attribute name="index" type="Integer" />
    <aura:attribute name="pickedQty" type="Decimal" default='0.00'/>
    <aura:attribute name="delindex" type="Integer" />
    <aura:attribute name="assetErrMsg" type="String" Default=""/>
    <aura:attribute name="serialErrMsg" type="String" Default=""/>
    <aura:attribute name="AllowNew" type="Boolean"/>
    <aura:attribute name="scannedValueChanged" type="Boolean" default="false"/> 
    <aura:handler name="change" value="{!v.item.ERP7__Product__c}" action="{!c.fetchInventory}" />
    <aura:handler name="change" value="{!v.item.ERP7__Batch_Lot__c}" action="{!c.fetchInventory}" />
    <aura:handler name="change" value="{!v.item.ERP7__Serial_Number__c}" action="{!c.fetchInventory}" />
    <aura:handler name="change" value="{!v.item.ERP7__From_Location__c}" action="{!c.fetchInventory}" />
    <!--aura:handler name="change" value="{!v.Location}" action="{!c.callChangeLocation}" /-->
    <aura:method name="updateCartPickedItem" action="{!c.updateCartPickedItem}"/>
    <aura:attribute name="checkValidation" type="Boolean" default='true'/>  
    <aura:attribute name="disableSave" type="Boolean" default='false'/>  
    <aura:attribute name="availLocIds" type="String" default=""/>  
    <aura:attribute name="prodLocIds" type="String" default=""/>  
    <aura:attribute name="selectedSerialIds" type="String" default=""/>    
    <aura:attribute name="availBatchIds" type="String" default=""/>   
    <aura:attribute name="availSerialIds" type="String" default=""/>   
    <aura:attribute name="showSpinnerItem" type="Boolean" default="false"/>  
    <aura:attribute name="proceedChangeHandler" type="Boolean" default="true"/>  
    <aura:attribute name="StopfecthInventory" type="Boolean" default='false'/>  
    
    <!-- attributes added by shaguftha on 10/08/23 for multi pick serials -->
    <aura:attribute name="exceptionError" type="String" default=""/>   
    <aura:attribute name="SearchSerialNos" type="String" default=""/>   
    <aura:attribute name="PickSerialNos" type="object[]" />
    <aura:attribute name="PickSelectedSerialNos" type="object[]" />
    <aura:attribute name="disableAdd" type="Boolean" default="true"/>
    <aura:attribute name="disableRemove" type="Boolean" default="true"/>
    <aura:attribute name="Location" type="String" default=""/>
    <aura:attribute name="requiredQty" type="String" default="100"/>
    <aura:attribute name="selectAllSerials" type="Boolean" default="false"/>
    <aura:attribute name="selected" type="Boolean" default="false"/>
    <aura:attribute name="SeletedrowsList" type="object[]"/>
    <aura:handler name="change" value="{!v.exceptionError}" action="{!c.showToast}" />
    <aura:attribute name="fromMultipick" type="Boolean" default="false"/>
    
    <aura:attribute name="callChangeLocation" type="String" default=""/>
    <aura:handler name="change" value="{!v.callChangeLocation}" action="{!c.ChangeLocation}" />
    <!--<aura:handler name="change" value="{!v.Location}" action="{!c.ChangeLocation}" />-->
    <aura:attribute name="openSerialModal" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.openSerialModal}" action="{!c.OpenModalSerial}" />
    <aura:attribute name="callAddSerials" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.callAddSerials}" action="{!c.AddSerials}" />
    <aura:attribute name="callPickMultiSerials" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.callPickMultiSerials}" action="{!c.PickMultiSerials}" />
    <aura:attribute name="callsaveAsDraft" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.callsaveAsDraft}" action="{!c.saveAsDraft}" />
    <aura:attribute name="callRemoveAllSerials" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.callRemoveAllSerials}" action="{!c.RemoveAllSerials}" />
    <aura:attribute name="callFindSerials" type="Boolean" default="false"/>
    <aura:handler name="change" value="{!v.callFindSerials}" action="{!c.FindSerials}" />
    <!--Added by Asra for pickscreenscanflow-->
    <aura:attribute name="serialModalOpen" type="Boolean" default="false" />
    <aura:attribute name="storeProdId" type="String"  />
    <!--<aura:method name="callAddSerials" action="{!c.AddSerials}" />
    <aura:method name="callPickMultiSerials" action="{!c.PickMultiSerials}" />
    <aura:method name="callsaveAsDraft" action="{!c.saveAsDraft}" />
    <aura:method name="callRemoveAllSerials" action="{!c.RemoveAllSerials}" />
    <aura:method name="callFindSerials" action="{!c.FindSerials}" />-->
   <aura:attribute name="storeCompIndex" type="Integer" access="global" default="0"/>
    <aura:attribute name="fromScanFlowforMultiPick" type="Boolean" default="false"/>
    
    <aura:if isTrue="{!and(v.item != '',v.item != undefined)}">
        <tr class="slds-hint-parent"  >
            <td class="slds-cell-edit cartpickeditem-class1" role="gridcell">
                <div class="slds-grid">
                    <span class="slds-truncate slds-p-top_small slds-p-bottom_x-small" >&nbsp; <a data-record="Add" data-target="#myModal" class="c18-blank" data-toggle="modal" >New</a></span>
                    <lightning:input type="checkbox" variant="label-hidden" class="pr-19-checkbox" checked="{!v.selected}" onchange="{!c.getselected}"/>
                </div>
                <!--<a class="svg" onclick="{!c.deleteSlctd}" data-record="{!v.index}">
                    <img src="/resource/ERP7__SLDS0121/assets/icons/action/delete_60_red.png" height="22" title="Remove Item" width="22" />
                </a>-->
            </td>
            <td width="15%" class="slds-cell-edit" role="gridcell">
                   <aura:if isTrue="{!and(v.item.ERP7__Product__c==undefined,v.item.ERP7__Product__c=='')}">
                        <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search Product.."/>
                        <aura:set attribute="else">
                            <c:CustomInputProduct objectAPIName="Product2" IconName="standard:product" selectedRecordId="{!v.item.ERP7__Product__c}" aura:id="product" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}" dontshowList='false'/>
                        </aura:set>
                    </aura:if>
            </td>
            <td class="slds-cell-edit" role="gridcell">
                <span class="slds-truncate maqs">
                    <aura:if isTrue="{!and(or(v.item.ERP7__From_Location__c==undefined,v.item.ERP7__From_Location__c==''),v.item.Id != undefined, v.item.Id != '')}">
                        <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search.."/>
                        <aura:set attribute="else">
                            <c:CustomInputLookUp objectAPIName="ERP7__Location__c" IconName="standard:location" selectedRecordId="{!v.item.ERP7__From_Location__c}" qry="{!' AND ERP7__Site__c =\''+v.siteID+'\''}" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}" /> <!-- qry="{!v.availLocIds}" -->
                        </aura:set>
                    </aura:if>
                </span>
            </td>
            <td class="slds-cell-edit" role="gridcell">
                <span class="slds-truncate maqs">
                    <aura:if isTrue="{!(v.item.ERP7__Product__r.ERP7__Serialise__c == true)}">
                        <aura:if isTrue="{!and(v.item.ERP7__Serial_Number__c==undefined,v.item.ERP7__Serial_Number__c=='')}">
                            <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search serial.."/>
                            <aura:set attribute="else">
                                <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="sl" IconName="standard:customer_portal_users" selectedRecordId="{!v.item.ERP7__Serial_Number__c}" qry="{!v.availSerialIds}" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}"/> <!-- qry="{!' And ERP7__Expired__c=false And ERP7__Product__c = \''+v.item.ERP7__Product__c+'\' AND ERP7__Available__c = true'}" -->
                            </aura:set>
                        </aura:if>
                            <aura:set attribute="else">
                            <aura:if isTrue="{!(v.item.ERP7__Product__r.ERP7__Lot_Tracked__c == true)}">
                                <aura:if isTrue="{!and(or(v.item.ERP7__Batch_Lot__c==undefined,v.item.ERP7__Batch_Lot__c==''),v.item.Id != undefined, v.item.Id != '')}">
                                    <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search.."/>
                                    <aura:set attribute="else">
                                        <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="bt" IconName="standard:customer_portal_users" selectedRecordId="{!v.item.ERP7__Batch_Lot__c}" qry="{!v.availBatchIds}" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}"/> <!-- qry="{!' And ERP7__Expired__c=false And ERP7__Available_Quantity__c > 0 And ERP7__Product__c = \''+v.item.ERP7__Product__c+'\''}" -->
                                    </aura:set>
                                </aura:if>
                                <aura:set attribute="else">
                                    <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="{!$Label.c.EmpCustLookupPage_Search}"/>
                                </aura:set>
                            </aura:if>
                        </aura:set>
                    </aura:if>
                    
                    <!--aura:if isTrue="{!(v.item.ERP7__Product__r.ERP7__Lot_Tracked__c == true)}">
                    <aura:if isTrue="{!and(or(v.item.ERP7__Batch_Lot__c==undefined,v.item.ERP7__Batch_Lot__c==''),v.item.Id != undefined, v.item.Id != '')}">
                        <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search.."/>
                        <aura:set attribute="else">
                            <c:CustomInputLookUp objectAPIName="ERP7__Batch__c" aura:id="bt" IconName="standard:customer_portal_users" selectedRecordId="{!v.item.ERP7__Batch_Lot__c}" qry="{!' And ERP7__Expired__c=false And ERP7__Available_Quantity__c > 0 And ERP7__Product__c = \''+v.item.ERP7__Product__c+'\''}" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}"/>
                        </aura:set>
                    </aura:if>
                    <aura:set attribute="else">
                        <aura:if isTrue="{!(v.item.ERP7__Product__r.ERP7__Serialise__c == true)}">
                            <c:CustomInputLookUp objectAPIName="ERP7__Serial_Number__c" aura:id="sl" IconName="standard:customer_portal_users" selectedRecordId="{!v.item.ERP7__Serial_Number__c}" qry="{!' And ERP7__Expired__c=false And ERP7__Product__c = \''+v.item.ERP7__Product__c+'\' AND ERP7__Available__c = true'}" hideRemove="{!if(and(v.item.Id != undefined, v.item.Id != ''), true, false)}"/>
                            <aura:set attribute="else">
                                <lightning:input type="Search" value="" class="nolble" disabled="true" aura:id="" placeholder="Search.."/>
                            </aura:set>
                        </aura:if>
                    </aura:set>
                </aura:if-->
                    
                    <span class="cartpickeditem-class2">{!v.serialErrMsg}</span>
                </span>
            </td>
            <td class="slds-cell-edit" role="gridcell">
                <span class="slds-truncate2 maqs">
                    <lightning:input type="number" class="slds-input nolble" aura:id="pickedQty" value="{!v.item.ERP7__Quantity__c}" disabled="{!v.item.ERP7__Available_Stock__c == 0}" oncommit="{!c.onCommitCartPickedItem}" onchange="{!c.onChangeCartPickedItem}" step="0.0001"/> <!--oncommit="{!c.updateCartPickedItem}"-->
                </span>
            </td>
            <td class="slds-cell-edit" role="gridcell">
                <span class="slds-truncate2">
                    {!v.item.ERP7__Available_Stock__c}
                </span>
            </td>
            <td class="slds-cell-edit cartpickeditem-class1" role="gridcell">
                <div class="slds-grid">
                    
                     <div  class="slds-p-right_xx-small slds-m-top_xx-small"> 
                         <lightning:button onclick="{!c.updateCartPickedItem}" class="neutralC2" label="" title="Save" iconName="utility:save" iconPosition="left"  variant="brand" disabled="{!v.disableSave}"/>
                     </div>  
                    <aura:if isTrue="{!and(v.item.ERP7__Product__r.ERP7__Serialise__c == true,or(v.item.Id == undefined, v.item.Id == ''))}">
                        <lightning:button name="{!v.item.ERP7__Product__c}" onclick="{!c.OpenModalSerial}" class="neutralC"> 
                            <lightning:icon iconName="utility:multi_picklist" size="small" class="blue-utility-icon"></lightning:icon>
                        </lightning:button>
                    </aura:if>
                   
                    <a class="svg slds-p-top_xx-small slds-p-left_x-small" onclick="{!c.deleteSlctd}" data-record="{!v.index}" title="Delete">
                        <img src="/resource/ERP7__SLDS0121/assets/icons/action/delete_60_red.png" height="22" title="Delete" width="22" />
                    </a>
                    
                </div>
            </td>
        </tr>
        
        <tr colspan="11">
            <section role="dialog" aura:id="myModalPickSerial" tabindex="-1" aria-modal="true" aria-labelledby="modal-heading-01" class="slds-modal slds-modal_large">
                <div class="slds-modal__container">
                    <div class="slds-modal__content" id="modal-content-id-1" style="height: 100vh;background: #fafbfe;">
                        <article class="slds-page-header slds-page-header1">
                            <div class="slds-card__header slds-grid">
                                <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                    <div class="slds-media__figure">
                                        <span class="slds-icon_container slds-icon-standard-account" title="account">
                                            <lightning:icon iconName="standard:product" size="medium"></lightning:icon>
                                            <span class="slds-assistive-text"></span>
                                        </span>
                                    </div>
                                    <div class="slds-media__body">
                                        <h2 class="slds-card__header-title slds-m-top_xxx-small">
                                            <span class="slds-page-header__title slds-truncate"> {!$Label.c.Pick_Multiple_Serial_Numbers}</span>
                                        </h2>
                                    </div>
                                    <div class="slds-notify__content">
                                        <!--h2 class="slds-text-heading_small mb-0 cartpickeditem-class2">{!v.exceptionError}</h2-->
                                    </div>
                                    <div class="slds-no-flex">
                                        
                                    </div>
                                </header>
                            </div>
                        </article>
                        <div class="card shadow-sm slds-m-around_medium">
                            <div class="slds-grid slds-wrap">
                                <div class="slds-col slds-size_1-of-1 slds-large-size_5-of-12">
                                    <article class="slds-card-extra">
                                        <div class="slds-card__header slds-grid">
                                            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                
                                                <div class="slds-media__body">
                                                    
                                                    <div class="slds-grid">
                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                                                            <div class="slds-form-element slds-p-right_small">
                                                                <div class="slds-form-element__control">
                                                                    <ui:inputText value="{!v.SearchSerialNos}" class="slds-input" label="{!$Label.c.EmpCustLookupPage_Search}" placeholder="{!$Label.c.SalesOrderConsole_Search}"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12 slds-p-right_xx-small" onclick="{!c.ChangeLocationmanual}">
                                                            <c:CustomInputLookUp objectAPIName="ERP7__Location__c" label="{!$Label.c.InventoryConsole_Location}" IconName="standard:location" selectedRecordId="{!v.Location}" qry="{!v.prodLocIds}"  placeholder="{!$Label.c.SalesOrderConsole_Search}"/> <!-- qry="{!' AND ERP7__Site__c =\''+v.siteID+'\''}" -->
                                                        </div>  
                                                        <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12 slds-p-right_xx-small" >
                                                            <lightning:select value="{!v.requiredQty}" label="{!$Label.c.MO_ReqQty}" ><!--variant="label-hidden" class="noLabel"-->
                                                                <option value="10">10</option>
                                                                <option value="50">50</option>
                                                                <option value="100">100</option>
                                                                <option value="200">200</option>
                                                                <option value="500">500</option> 
                                                                <!--option value="1000">1000</option-->
                                                            </lightning:select>
                                                        </div>
                                                        <div class="slds-col slds-m-top_large" >
                                                            <button class="slds-button slds-button_brand" onclick="{!c.FindSerials}">{!$Label.c.Find_StockTake}</button>
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="slds-no-flex">
                                                    
                                                </div>
                                            </header>
                                        </div>
                                        
                                        <div class="slds-card__header height56-pick slds-m-bottom_xx-small">
                                            
                                            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                <div class="slds-media__body">
                                                    <h2 class="slds-card__header-title">
                                                        {!$Label.c.Available_Serials} &nbsp; ({!v.PickSerialNos.length}) 
                                                    </h2>
                                                </div> 
                                                <div class="slds-no-flex">
                                                    
                                                </div>
                                            </header>
                                            <aura:if isTrue="{!v.PickSerialNos.length > 0}"><lightning:input type="checkbox" aura:id="selectAllSerials" checked="{!v.selectAllSerials}" label="{!$Label.c.Select_All}" onchange="{!c.selectAllSerials}" class="slds-p-top_xx-small"></lightning:input></aura:if>
                                        </div>
                                        <div class="slds-grid slds-wrap slds-grid slds-wrap slds-p-top_xxx-small" style="max-height: 68vh;overflow: auto;">
                                            <aura:if isTrue="{!v.PickSerialNos.length > 0}">
                                                <aura:iteration items="{!v.PickSerialNos}" var="PSN" indexVar="i" start="0" end="1000">
                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12 slds-p-right_x-small slds-p-left_x-small" data-serialId = "{!PSN.SerialNo.Id}" onclick="{!c.PickSerialNosDiv}">
                                                        <div class="{!if(PSN.isSelected,'card tilebox-one m-2 cursor-pointer active-card-pick','card tilebox-one m-2 cursor-pointer non-active-card-pick')}">
                                                            <div class="card-body">
                                                                <div class="slds-grid">
                                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12 slds-p-right_x-small">
                                                                        <i class="fa fa-file-text-o file-text-size"></i></div>
                                                                    <div class="slds-col slds-size_1-of-1 slds-large-size_10-of-12">
                                                                        <h6 class="mt-1 mb-1 pick_class47">
                                                                            <div class="slds-truncate" title="{!PSN.SerialNo.Name}">{!PSN.SerialNo.Name}</div>
                                                                        </h6>
                                                                    </div>
                                                                </div>
                                                                
                                                            </div>
                                                        </div>
                                                    </div>
                                                </aura:iteration>  
                                            </aura:if>
                                        </div>                       
                                    </article>
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12 text-center" style="padding-top:10%;padding-bottom:10px;">
                                    <lightning:button label="{!$Label.c.SalesOrderConsole_Add}" iconName="utility:right" iconPosition="right" class="width125-pick"  onclick="{!c.AddSerials}" disabled="{!v.disableAdd}"/><br/><br/>
                                    <lightning:button label="{!$Label.c.Remove}" iconName="utility:left" iconPosition="left" class="width125-pick" onclick="{!c.RemoveSerials}" disabled="{!v.disableRemove}"/><br/><br/>
                                    <lightning:button label="{!$Label.c.Remove_All}" iconName="utility:jump_to_left" iconPosition="left" class="slds-button_brand width125-pick" onclick="{!c.RemoveAllSerials}" disabled="{!(v.PickSelectedSerialNos.length==0)}"/>
                                    
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-large-size_5-of-12" >
                                    <article class="slds-card-extra">
                                        <div class="slds-card__header slds-grid height56-pick">
                                            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                                
                                                <div class="slds-media__body">
                                                    <h2 class="slds-card__header-title">
                                                        {!$Label.c.Serial_Numbers_Reserved_Selected} &nbsp; {!v.PickSelectedSerialNos.length}
                                                    </h2>
                                                </div>
                                                <div class="slds-no-flex">
                                                    
                                                </div>
                                            </header>
                                        </div>
                                        <div class="slds-grid slds-wrap" style="max-height: 68vh;overflow: auto;">
                                            <aura:iteration items="{!v.PickSelectedSerialNos}" var="PSN" indexVar="i" start="0" end="1000">
                                                <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12 slds-p-right_x-small slds-p-left_x-small" data-serialId = "{!PSN.SerialNo.Id}" onclick="{!c.PickSelectedSerialNosDiv}">
                                                    <div class="{!if(PSN.isSelected,'card tilebox-one m-2 cursor-pointer active-card-pick', 'card2 tilebox-one m-2 cursor-pointer')}">
                                                        <div class="card-body">
                                                            <div class="slds-grid">
                                                                <div class="slds-col slds-size_1-of-1 slds-large-size_2-of-12 slds-p-right_x-small">
                                                                    <i class="fa fa-file-text-o file-text-size"></i></div>
                                                                <div class="slds-col slds-size_1-of-1 slds-large-size_10-of-12">
                                                                    <h6 class="mt-1 mb-1 pick_class47">
                                                                        <div class="slds-truncate" title="{!PSN.SerialNo.Name}">{!PSN.SerialNo.Name}</div>
                                                                    </h6>
                                                                </div>
                                                            </div>
                                                            
                                                        </div>
                                                    </div>
                                                </div>
                                            </aura:iteration>                                  
                                        </div>
                                    </article>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="slds-modal__footer text-center">
                        <button class="slds-button slds-button_neutral" aria-label="Cancel and close" onclick="{!c.CloseMyModalPickSerial}">{!$Label.c.PackageSlip_Back}</button>
                        <button class="slds-button slds-button_success" onclick="{!c.PickMultiSerials}">{!$Label.c.Pick}</button>
                        <button class="slds-button slds-button_brand" onclick="{!c.saveAsDraft}">{!$Label.c.Save_as_Draft}</button>
                    </div>
                </div>
            </section>
            <!--div class="slds-backdrop" aura:id="myModalMOSerialBackDrop" role="presentation"></div-->
        </tr>
    </aura:if>
</aura:component>