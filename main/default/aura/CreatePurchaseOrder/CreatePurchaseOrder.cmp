                                        <th>
                                            <span class="slds-truncate" title="{!$Label.c.MOsetupProductName}">{!$Label.c.MOsetupProductName}</span> 
                                        </th>
                                    </tr>            
                                </thead>
                                <tbody>
                                    <aura:if isTrue="{!v.showStandardProducts}">
                                        <aura:iteration items="{!v.listOfProducts}" var="prod1" indexVar="index">
                                            <tr>
