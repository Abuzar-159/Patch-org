                                        </aura:if>
                                    </div>
                                </div>  
                                
                                <div class="row padding-t-5 cpo-class6">
                                    <aura:if isTrue="{!v.showDchannelBelow}">
                                        <div class="col-md-3 slds-p-top--xx-small" > 
                                            <aura:if isTrue="{!(v.selectedRecType == v.DropShipPOrecType)}">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Customer__c}" label="{!$Label.c.PO_Customer_Manufacturer}" aura:Id="customerAccount" qry=" AND (ERP7__Account_Type__c = 'Customer' OR ERP7__Account_Type__c = 'Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor') " required="true"/>
                                                <aura:set attribute="else">
                                                    <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Customer__c}" label="{!$Label.c.PO_Customer_If_Applicable}" aura:Id="customerAccount" qry=" AND ERP7__Account_Type__c = 'Customer' " required="false"/>
                                                </aura:set>
                                            </aura:if>
                                        </div>
                                    </aura:if>
                                    
                                    <div class="col-md-3   slds-p-top--xx-small">
                                        <aura:if isTrue="{!!v.isSalesOrder}"> 
                                            <c:CustomInputLookUp objectAPIName="ERP7__Sales_Order__c" IconName="standard:orders" selectedRecordId="{!v.PO.ERP7__Sales_Order__c}" label="{!$Label.c.PO_Sales_Order_If_Applicable}" qry="{!'And (ERP7__Account__c  = \''+v.PO.ERP7__Customer__c+'\' OR ERP7__Organisation__c  = \''+v.PO.ERP7__Organisation__c+'\')'}"/>
                                        </aura:if>
                                        <aura:if isTrue="{!v.isSalesOrder}"> 
                                            <aura:if isTrue="{!(v.selectedRecType == v.DropShipPOrecType)}">
                                                <aura:if isTrue="{!and(and(v.PO.ERP7__Customer__c != '',v.PO.ERP7__Customer__c != null),and(v.recordId != '',v.recordId != null))}">
                                                    <c:CustomInputLookUp objectAPIName="Order" IconName="standard:orders" selectedRecordId="{!v.PO.ERP7__Order__c}" label="{!$Label.c.Order_If_Applicable}" qry="{!'And (AccountId  = \''+v.PO.ERP7__Customer__c+'\')'}" hideRemove = "true"/><!-- required="true" -->
                                                    <aura:set attribute="else">
                                                        <c:CustomInputLookUp objectAPIName="Order" IconName="standard:orders" selectedRecordId="{!v.PO.ERP7__Order__c}" label="{!$Label.c.Order_If_Applicable}" qry="{!'And (AccountId  = \''+v.PO.ERP7__Customer__c+'\')'}" /><!-- required="true" -->
                                                    </aura:set>
                                                </aura:if>
                                                <aura:set attribute="else">
                                                    <c:CustomInputLookUp objectAPIName="Order" IconName="standard:orders" selectedRecordId="{!v.PO.ERP7__Order__c}" label="{!$Label.c.Order_If_Applicable}" qry="{!'And (AccountId  = \''+v.PO.ERP7__Customer__c+'\' OR ERP7__Organisation__c  = \''+v.PO.ERP7__Organisation__c+'\')'}" required="false"/>
                                                </aura:set>
                                            </aura:if>
                                        </aura:if>
                                    </div>
                                    
                                    <aura:if isTrue="{!v.ProjectAccess}"> 
                                        <div class="col-md-3   slds-p-top--xx-small">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Project__c" IconName="standard:orders" selectedRecordId="{!v.PO.ERP7__Project__c}" label="Project"/>
                                        </div>
                                    </aura:if>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <lightning:textarea aura:id="description" name="Special Instructions"  value="{!v.PO.ERP7__Description__c}" placeholder="{!$Label.c.Add_Subscriptions_Special_Instructions}" label="{!$Label.c.Add_Subscriptions_Special_Instructions}" maxlength="32768" messageWhenTooLong="A maximum of 32768 characters are allowed." onchange="{!c.removeHtmltags}"/>
                                    </div>
                                    
                                    <aura:if isTrue="{!(v.selectedRecType != v.DropShipPOrecType)}">
                                        <aura:if isTrue="{!and(!v.fromMultiPO,v.showReceive)}">
                                            <aura:if isTrue="{!!v.returnToVendor}">
                                                <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                                    <label class="slds-form-element__label" for="lookup-348" data-aura-rendered-by="468:0">
                                                        {!$Label.c.PO_Ready_To_Receive}</label><br/>
                                                    <lightning:input type="checkbox" variant="label-hidden" checked="{!v.PO.ERP7__Ready_To_Receive__c}" disabled="{!v.isRecieved}"/>
                                                </div>
                                                <aura:set attribute="else">
                                                    <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                                        <label class="slds-form-element__label" for="lookup-348" data-aura-rendered-by="468:0">
                                                            {!$Label.c.Ready_To_Ship}</label><br/>
                                                        <lightning:input type="checkbox" variant="label-hidden" checked="{!v.PO.ERP7__Ready_To_Pick_Pack__c}"/>
                                                    </div>
                                                </aura:set>
                                            </aura:if>
                                        </aura:if>
                                    </aura:if>
                    
                                    <!--<div class="col-md-3 slds-p-top-xx-small cpo-class8">
                                        <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.SalesOrderToPurchaseOrder_SO_Total_Amount}</label>
                                        <lightning:formattedNumber value="{!v.PO.ERP7__Total_Amount__c}" class="currency" />
                                    </div>-->
                                </div>
                                
                                <div class="row padding-t-5 cpo-class6">
                                    <aura:if isTrue="{!v.isMultiCurrency}">
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            
                                            <div class="slds-col slds-form-element">
                                                <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                    <lightning:select  aura:id="stStatus" value="{!v.POCurrencyIsoCode}" label="{!$Label.c.Currency}" onchange="{!c.updatepocurrency}">
                                                        <aura:iteration items="{!v.currencyList}" var="option">
                                                            <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.POCurrencyIsoCode, option.value)}"/>
                                                        </aura:iteration>
                                                    </lightning:select>
                                                </div>
                                            </div>
                                       
                                        </div>
                                     </aura:if>
                                    <aura:if isTrue="{!v.QuoteAccess}">
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <lightning:input type="text" label="{!$Label.c.PO_Quote_No}" value="{!v.PO.ERP7__Quote_no__c}" />
                                        </div>
                                    </aura:if>
                                    
                                    <aura:if isTrue="{!v.QuoteAccess}">
                                        <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                            <lightning:select name="parentField" aura:id="parentField"
                                                              value="{!v.PO.ERP7__Shipment_Type__c}"
                                                              label="{!$Label.c.PO_Shipment_Type}"> <!-- onchange="{!c.parentFieldChange}"-->
                                                <aura:iteration items="{!v.listControllingValues}" var="item">
                                                    <option value="{!item.value}" selected="{!item.value == v.PO.ERP7__Shipment_Type__c}">{!item.label}</option>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                        
                                        <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                            <lightning:select name="childField"
                                                              value="{!v.PO.ERP7__Shipment_Preference_Speed__c}"
                                                              label="{!$Label.c.PO_Shipping_Speed_Preference}"
                                                              disabled="{!v.bDisabledDependentFld}">
                                                <aura:iteration items="{!v.listDependingValues}" var="item">
                                                    <option value="{!item.value}" selected="{!item.value == v.PO.ERP7__Shipment_Preference_Speed__c}">{!item.label}</option>
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </aura:if>
                                    <aura:if isTrue="{!v.showpackageType}">
                                        <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                            <lightning:select name="poStatus"  label="{!$Label.c.Package_Type}" aura:id="poStatus" value="{!v.PO.ERP7__Package_Type__c}" >
                                                <aura:iteration items="{!v.POTypeoptions}" var="item">
                                                    <option text="{!item.label}" value="{!item.value}" selected="{!v.PO.ERP7__Package_Type__c == item.value}"/>
                                                </aura:iteration>
                                            </lightning:select> 
                                        </div>
                                    </aura:if>
                                </div>
                                
                                <aura:if isTrue="{!v.showfileUpload}">
                                    <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4 slds-p-top_small">
                                        <div class="slds-grid">
                                            <label lightning-input_input="" class="slds-form-element__label slds-no-flex" for="input-199" part="label">{!$Label.c.Attachment}</label>
                                        </div>
                                        <lightning:input aura:id="fileId" type="file" files="{!v.FileList}" onchange="{!c.handleFilesChange}" multiple="true" label="{!$Label.c.Upload_Attachment}" value="{!v.fillList}"/>
                                        <aura:if isTrue="{!v.showDelete}">
                                            <a onclick="{!c.removeAttachment}" title="{!$Label.c.NewCase_Remove_Attachment}" class="createbill-class6">
                                                <i class="fa fa-minus-circle" aria-hidden="true"></i>
                                            </a>                        
                                        </aura:if>
                                        <aura:iteration items="{!v.fillList}" var="file" indexVar='count'>
                                            <div class="slds-text-body_small slds-text-color_error">{!file}&nbsp;&nbsp;&nbsp;
                                            </div>
                                        </aura:iteration>
                                        <aura:if isTrue="{!v.showLoadingSpinner}">
                                            <div class="slds-text-body_small slds-text-color_error">{!$Label.c.Uploading} 
                                                <img src="/auraFW/resources/aura/images/spinner.gif" class="spinner-img" alt="Loading"/>'
                                            </div>
                                        </aura:if>
                                        <br/>
                                        
                                    </div>
                                    <div class="slds-col slds-p-horizontal--medium slds-size--1-of-4 slds-p-top_small">
                                        <aura:if isTrue="{!and(or(v.recordId != null,v.recordId != ''),or(v.clonePOId != null,v.clonePOId != ''))}"> 
                                            <aura:renderif isTrue="{!and(v.uploadedFile != null,v.uploadedFile.length > 0)}"> 
                                                <aura:iteration items="{!v.uploadedFile}" var="file1" >
                                                    
                                                    <aura:if isTrue="{!(file1.Id != null)}"> 
                                                        <div class="slds-grid slds-p-top_xxx-small"> 
                                                            <div class="slds-col">
                                                                <lightning:buttonIcon iconName="utility:delete" variant="bare" name="{!file1.Id}" onclick="{!c.DeleteRecordAT}" alternativeText="delete" title="{!v.recordId}" class="colorRed"/>
                                                                &nbsp;
                                                                <lightning:formattedUrl value="{!'/'+file1.Id}" label="{!file1.Name}" tooltip="{!file1.Name}" target="_blank" class="fcolor"/>
                                                            </div>
                                                            <div class="slds-col slds-hide">
                                                                <img src="{!'/servlet/servlet.FileDownload?file='+file1.Id}" onerror="{!c.imageError}" class="InboundLog-class34"/>
                                                            </div>
                                                        </div>
                                                    </aura:if>
                                                </aura:iteration>
                                            </aura:renderif>
                                        </aura:if>
                                    </div>
                                </aura:if>
                                
                                <aura:if isTrue="{!v.showTaxRate}">
                                    <div class="row padding-t-5 cpo-class6">
                                        <div class="col-md-4 slds-p-top--xx-small">
                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.QuotationPDF_Sub_Total}</label>
                                            <div class="slds-form-element__control">
                                                <lightning:formattedNumber value="{!v.SubTotal}" class="currency" />
                                            </div>
                                        </div>
                                        <div class="col-md-4 slds-p-top--xx-small">
                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.Expense_Tax_Amount}</label>
                                            <div class="slds-form-element__control">
                                                <lightning:formattedNumber value="{!v.TotalTax}" class="currency" />
                                            </div>
                                        </div>
                                        <div class="col-md-4 slds-p-top--xx-small">
                                            <label class="slds-form-element__label" for="input-unique-id">{!$Label.c.SalesOrderToPurchaseOrder_SO_Total_Amount}</label>
                                            <div class="slds-form-element__control">
                                                <lightning:formattedNumber value="{!v.TotalAmount}" class="currency" />
                                            </div>
                                        </div>
                                    </div>
                                </aura:if>
                                
                            </div>
                            
                            <div class="slds-tabs--card slds-tabs--default slds-m-top--small">
                                <ul class="slds-tabs--default__nav" role="tablist">
                                    <li class="slds-tabs--default__item slds-is-active"  title="{!$Label.c.PO_Items_Total}" role="presentation">
                                        <a class="slds-tabs--default__link"   role="tab" tabindex="0" aria-selected="true" aria-controls="tab-default-1" id="tab-default-1__item">
                                            <i class="fa fa-tasks" aria-hidden="true"></i>&nbsp;{!$Label.c.PO_Items_Total}&nbsp; <lightning:formattedNumber value="{!v.PO.ERP7__Total_Amount__c}" />
                                        </a>
                                    </li>
                                    <li class="position-sf2">
                                        <aura:if isTrue="{!v.returnToVendor == false}">
                                            <aura:if isTrue="{!and(v.orderId=='', v.SOId=='')}">
                                                <lightning:button label="{!$Label.c.Add_ManageLeave}" disabled="{!v.isRecieved}" class="slds-button slds-button--brand" iconName="utility:add" onclick="{!c.addNew}"/>
                                                <aura:if isTrue="{!v.allowCustomProd}">
                                                    <lightning:button label="{!$Label.c.Custom_Product}" disabled="{!v.isRecieved}" class="slds-button slds-button--neutral" iconName="utility:add" onclick="{!c.addCustomproductNew}"/>
                                                </aura:if>
                                            </aura:if>
                                        </aura:if>
                                    </li>
                                </ul>
                            </div>
                            
                            <div class="maqsood erp_Mark7">         
                                <div class="table-responsive ProjectWorkbench-newClass50" tabindex="1">
                                    <div>
                                    </div>
                                    <table class="slds-table slds-table_cell-buffer slds-no-row-hover cpo-class14"> <!-- slds-table_cell-buffer slds-no-row-hover cpo-class14-->
                                        <thead>
                                            <tr>
                                                <th class="cpo-class15">
                                                    
                                                </th>
                                                
                                                <th class="slds-text-heading--label cpo-class17" scope="col"> {!$Label.c.CreatePOProduct}<!--<span class="cpo-class21">*</span>--></th>
                                                <aura:if isTrue="{!v.versionAccess}">
                                                    <th class="slds-text-heading--label cpo-class16" scope="col">{!$Label.c.PO_Revision}</th>
                                                </aura:if>
                                                <aura:if isTrue="{!v.POLINameAcc}">
                                                    <th class="slds-text-heading--label cpo-class16" scope="col">{!$Label.c.Product_Code} <!--{!$Label.c.POLine}--></th>
                                                </aura:if> 
                                                <aura:renderif isTrue="{!v.showVenName}">                            
                                                    <th class="slds-text-heading--label cpo-class16" scope="col"> {!$Label.c.PO_Vendor_part_no}<!--{!$Label.c.CreatePOVPN}--></th>
                                                </aura:renderif>                                
                                                <th class="slds-text-heading--label cpo-class18" scope="col">{!$Label.c.InventoryConsole_Cost_Card}</th>
                                                <th class="slds-text-heading--label cpo-class19" scope="col">{!$Label.c.PackageSlip_List_Quantity} <span class="cpo-class21">*</span></th>  
                                                <th class="slds-text-heading--label cpo-class19" scope="col">{!$Label.c.PurchaseOrderPDF_Unit_Price} <span class="cpo-class21">*</span><!--<span class="cpo-class21">*</span>--></th>
                                                <aura:if isTrue="{!v.showTaxRate}">
                                                    <th class="slds-text-heading--label cpo-class19" scope="col">{!$Label.c.Tax_Label}</th>
                                                </aura:if>
                                                <aura:if isTrue="{!v.showTaxName}">
                                                    <th class="slds-text-heading--label cpo-class19" scope="col">{!$Label.c.Tax_Amount}
                                                        
                                                        <lightning:helptext content="{!$Label.c.Tax_Amount_based_on_entered_tax}" ></lightning:helptext> 
                                                        
                                                    </th>
                                                </aura:if>
                                                <th class="slds-text-heading--label cpo-class19" scope="col">{!$Label.c.InventoryConsole_Total_Price}</th>
                                                <aura:if isTrue="{!and(v.ProjectAccess, !v.showAllocations)}"> 
                                                    <th class="slds-text-heading--label cpo-class19" scope="col">Chart Of Account</th>
                                                    
                                                </aura:if>
                                                <aura:if isTrue="{!and(v.ProjectAccess, v.DepartmentAccess)}">
                                                    <aura:if isTrue="{!and(v.PO.ERP7__Project__c!=null, v.PO.ERP7__Project__c!='')}">
                                                    <th class="slds-text-heading--label cpo-class19" scope="col">Project Department</th>
                                                    </aura:if>
                                                </aura:if>
                                                <th class="slds-text-heading--label cpo-class20" scope="col">{!$Label.c.ContractConsole_Description}</th>
                                                <aura:if isTrue="{!and(v.showAllocations, v.PO.ERP7__Total_Amount__c >0)}">
                                                    <th class="slds-text-heading--label cpo-class20" scope="col">
                                                        <label class="slds-form-element__label" for="lookup-348" data-aura-rendered-by="468:0">
                                                            {!$Label.c.Auto_Account}<br/> {!$Label.c.Allocation}</label><br/>
                                                        <lightning:input type="checkbox" variant="label-hidden" checked="{!v.AutoAccountAllocations}"/>
                                                    </th>
                                                </aura:if>
                                                
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <aura:if isTrue="{!v.reRenderPOLIS}">
