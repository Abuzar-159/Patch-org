                                                    </div>
                                                </td> 
                                                <td>
                                                    <div>
                                                        <lightning:input type="number" value="{!prod1.unitPrice}" oncommit="{!c.handleUnitPrice}"  name="{!index}"  step="{!$Label.c.DecimalplacesinPOScreen}" variant="label-hidden" ></lightning:input>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.taxPercent}" oncommit="{!c.handletaxPercent}" name="{!index}" variant="label-hidden"  step="{!$Label.c.DecimalplacesinPOScreen}" messageWhenStepMismatch="Invalid increment." ></lightning:input>
                                                    </div>                                                        
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.taxAmount}" disabled="true" variant="label-hidden"  step="{!$Label.c.DecimalplacesinPOScreen}" ></lightning:input>
                                                        
                                                    </div>                                                        
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.TotalPrice}" disabled="true" step="{!$Label.c.DecimalplacesinPOScreen}" class="no-label-cust no-label-cust2"></lightning:input>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="width180-cp0">
                                                        <lightning:textarea value="{!prod1.prod.Description}"  class='no-input-lable' maxlength="2500" ></lightning:textarea>
                                                        
                                                    </div> 
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </aura:if>
                                     <aura:if isTrue="{!v.reRenderCustPOli}">
                                    <aura:if isTrue="{!!v.showStandardProducts}">
                                        <aura:iteration items="{!v.ClistOfProducts}" var="prod1" indexVar="index2">
                                            <tr>
                                                <td scope="row" class="slds-text-align--center">                                            
                                                    <div class="slds-form-element">
                                                        <div class="slds-form-element__control" >
                                                            <lightning:buttonIcon title='{!$Label.c.Delete_UserAvailabilities}' class="delete-iconcust" iconName="utility:delete" variant="destructive" name="{!index2}" onclick="{!c.deleteNewLine}"></lightning:buttonIcon>
                                                        </div>
                                                    </div>
                                                </td>
                                                
                                                
                                                <td>
                                                    <div class="slds-truncate">
                                                        <lightning:input type="text" value="{!prod1.Name}"  tabindex="0" onfocus="{!c.removeName}" name="{!index2}"  variant="label-hidden" maxlength="80" ></lightning:input>
                                                    </div>   
                                                    
                                                </td>
                                                
                                                
                                                <td>
                                                    <div>
                                                        <lightning:input type="number" value="{!prod1.quantity}" oncommit="{!c.handleProdQuantity}" name="{!index2}"  step="{!$Label.c.DecimalplacesinPOScreen}" variant="label-hidden" maxlength="5" ></lightning:input>
                                                    </div>
                                                </td> 
                                                <td>
                                                    <div>
                                                        <lightning:input type="number" value="{!prod1.unitPrice}" oncommit="{!c.handleProdUnitPrice}" name="{!index2}"  step="{!$Label.c.DecimalplacesinPOScreen}" variant="label-hidden" ></lightning:input>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.taxPercent}" oncommit="{!c.handleProdtaxPercent}" name="{!index2}" variant="label-hidden"  step="{!$Label.c.DecimalplacesinPOScreen}" ></lightning:input>
                                                    </div>                                                        
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.taxAmount}" disabled="true" data-index="{!index2}" variant="label-hidden"  step="{!$Label.c.DecimalplacesinPOScreen}"></lightning:input>
                                                    </div>                                                        
                                                </td>
                                                <td>
                                                    <div class="slds-grid">
                                                        <lightning:input type="number" value="{!prod1.TotalPrice}" disabled="true" step="{!$Label.c.DecimalplacesinPOScreen}"></lightning:input>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div>
                                                        <lightning:textarea value="{!prod1.Description}" data-index="{!index2}" class='no-input-lable' maxlength="2500" ></lightning:textarea>
                                                    </div> 
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </aura:if>
                                    </aura:if>
                                    <aura:if isTrue="{!and(v.showStandardProducts,v.listOfProducts.length == 0)}">
                                        <tr>
                                            <td colspan="10">
                                                <div class="alert alert-warning d-flex align-items-center" role="alert">
                                                    <i class="mdi mdi-alert-circle-check icon-size-warning mr-2"></i>
                                                    <div>{!$Label.c.No_Products_Available} </div>
                                                </div>
                                            </td>
                                        </tr>
                                    </aura:if> 
                                </tbody>
                            </table>                   
                        </div>
                    </div> 
                    <div class="slds-docked-form-footer">
                        <lightning:button label="{!$Label.c.ShipmentManagement_Cancel}" onclick="{!c.backToMainPage}"></lightning:button>&nbsp;&nbsp;
                        <lightning:button label="{!$Label.c.Add_Products}" onclick="{!c.addProducts}" variant="brand"></lightning:button>
                    </div>
                </aura:if>
                
                <aura:set attribute="else">
                    <article class="slds-card">
                        <div class="slds-card__header slds-grid">
                            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                                <div class="slds-media__figure">
                                    <span class="slds-icon_container slds-icon-standard-account" title="">
                                        <lightning:icon iconName="standard:record" size="medium"></lightning:icon>
                                        
                                    </span>
                                </div>
                                <div class="slds-media__body">
                                    <h2 class="slds-card__header-title">
                                        <a href="#" class="slds-card__header-link slds-truncate" title="{!$Label.c.Select_a_record_type}">
                                            <span>{!$Label.c.Select_a_record_type}</span>
                                        </a>
                                    </h2>
                                </div>
                            </header>
                        </div>
                    </article>
                    <div class=""><!-- slds-card -->
                        <div class="slds-card__body slds-card__body_inner">
                            <div class="slds-grid slds-wrap slds-m-around_large-cpo">
                                <aura:iteration items="{!v.POType}" var="recordType">
                                    <div class="slds-col slds-col slds-size_1-of-1 slds-large-size_12-of-12 slds-p-right_medium">
                                        <div class="container">
                                            <div class="card slds-grid card-extra-cpo">
                                                <div class="card-content">
                                                    <div class="card-body p-4">
                                                        <div class="media d-flex slds-grid">
                                                            <div class="align-self-center">
                                                                <lightning:icon iconName="utility:description" size="medium"></lightning:icon>
                                                            </div>
                                                            <div class="media-body p-left28 slds-p-top_x-small">
                                                                <div class="slds-grid">
                                                                    <div class="slds-form-element__control slds-truncate3 UPS-class13">
                                                                        <lightning:input type="radio" variant="label-hidden" aura:id="Fr0" name="{!recordType.label}" checked="{!recordType.selected}" onchange="{!c.setSelectedRec}"/>
                                                                    </div>  
                                                                    <div class="slds-truncate3 label-selection-fsize15" title="">
                                                                        <lightning:formattedText value="{!recordType.label}" title="{!recordType.label}" />
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </aura:iteration>
                            </div>
                        </div>
                    </div>
                    <div class="slds-docked-form-footer">
                        <lightning:button label="{!$Label.c.Cancel_ManageLeave}" onclick="{!v.cancelclick}" ></lightning:button>
                        <lightning:button label="{!$Label.c.Next_UsersShiftMatch}" onclick="{!c.NextClicked}" variant="brand"></lightning:button>
                    </div>
                </aura:set>
            </aura:if>  
        </div>  
    </div>
</aura:component>