                                                        <c:CustomInputLookUp objectAPIName="ERP7__Cost_Card__c" IconName="standard:scan_card" selectedRecordId="{!prod1.selCostCardId}" qry="{!v.CostCardFilter + ' AND ERP7__Product__c =\''+ prod1.prod.Id+'\' AND ERP7__Supplier__c =\''+ v.PO.ERP7__Vendor__c+'\' '}" />
                                                    </div>
                                                </td> 
                                                <td>
                                                    <div>
