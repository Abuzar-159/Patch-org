                                            <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Organisation__c}"  label="{!$Label.c.PO_Purchasing_Company}" required="true" aura:Id="organisationAccount" qry="{!'And (ERP7__Account_Type__c =\'Organisation\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}"/> <!--NameValue="{!v.PO.ERP7__Organisation__r.Name}"  ' AND (ERP7__Account_Type__c= \''Organisation\'' OR ERP7__Account_Type__c = \''Organisation/Vendor\'')'-->
                                        </div>
                                    </aura:if>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Invoice_Address__c}" label="{!$Label.c.CreateCustomer_Billing_Address}" qry="{!'And (ERP7__Customer__c  = \''+v.PO.ERP7__Customer__c+'\' OR ERP7__Customer__c  = \''+v.PO.ERP7__Organisation__c+'\')'}"/>
                                    </div>
                                    <aura:if isTrue="{!v.showDchannelBelow}">
                                        <div class="col-md-3   slds-p-top--xx-small">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Distribution_Channel__c"  aura:id="dcId" IconName="custom:custom32"  selectedRecordId="{!v.dChannelId}" label="{!$Label.c.Receiving_Center_RMA}" />
                                        </div>
                                    </aura:if>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <aura:if isTrue="{!and(v.PO.ERP7__Customer__c != null, v.PO.ERP7__Customer__c != '')}">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Delivery_Address__c}" label="{!$Label.c.PurchaseOrderPDF_Delivery_Address}"  qry="{!'And ERP7__Customer__c  = \''+v.PO.ERP7__Customer__c+'\''}"/>
                                            <aura:set attribute="else">
                                                <aura:if isTrue="{!and(and(or(v.clonePOId == null, v.clonePOId == ''),and(v.PO.ERP7__Vendor__c != null, v.PO.ERP7__Vendor__c != ''),or(v.recordId == null, v.recordId == '')))}">
                                                    <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Delivery_Address__c}" label="{!$Label.c.PurchaseOrderPDF_Delivery_Address}"  FieldValue="POD" POC="{!v.PO}" PoliItems ="{!v.poli}" ShowNew="true" defaultvalues="{!v.defaultVenAddress}" cmpName="ERP7:CreatePurchaseOrder" objName="Delivery Address" APIName="ERP7__Address__c"/><!-- ShowNew="true" defaultvalues="{!v.defaultVenAddress}" cmpName="ERP7:CreatePurchaseOrder" objName="Vendor Address" APIName="ERP7__Address__c" -->
                                                    <aura:set attribute="else">
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Delivery_Address__c}" label="{!$Label.c.PurchaseOrderPDF_Delivery_Address}"  qry="{!'And ERP7__Customer__c  = \''+v.PO.ERP7__Vendor__c+'\''}"/>
                                                    </aura:set>
                                                </aura:if>
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                    
