                                                        <div class="slds-form-element__control">
                                                            <label for="4909:0" class="slds-form-element__label">
                                                                {!$Label.c.Select}&nbsp;{!$Label.c.Sub_Family}
                                                            </label>
                                                            <lightning:select  aura:id="Subfamily" value="{!v.subItemFmily}"  class="no-label-cust no-label-cust2" disabled="{!v.bDisabledSubFamilyFld}" onchange="{!c.fetchSubFamilyProducts}" >
                                                                <aura:iteration items="{!v.subfamilylst}" var="item">
                                                                    <option value="{!item.value}" selected="{!item.value == v.subItemFmily}">{!item.label}</option>
                                                                   <!-- <option text="{!item}" value="{!item}" selected="{!v.subItemFmily == item}"/>-->
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </div>
                                                    </div>                                                     
                                                </div>
                                            </p>
