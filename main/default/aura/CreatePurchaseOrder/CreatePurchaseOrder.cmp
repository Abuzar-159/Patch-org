                                        </th>
                                        <th>
                                            <span class="slds-truncate" title="{!$Label.c.Tax_Label}">{!$Label.c.Tax_Label} </span> 
                                        </th>
                                        <th>
                                            <span class="slds-truncate" title="{!$Label.c.Expense_Tax_Amount}">{!$Label.c.Tax_Amount}</span> 
