                                                                    {!$Label.c.Standard_Product} 
                                                                </label>
                                                            </aura:set>
                                                        </aura:if>
                                                        <lightning:input name="{!$Label.c.Custom_Product}" variant-label="hidden" type="toggle" messageToggleActive="" messageToggleInactive="" onchange="{!c.handletoggle}" checked="{!v.toggleChecked}"/>
