                                            <lightning:icon iconName="standard:products" size="large" ></lightning:icon>
                                            <span class="slds-assistive-text">{!$Label.c.AddSubscription_Product}</span>
                                        </span>
                                    </div>
                                    <div class="slds-media__body">
                                        <div class="slds-page-header__name">
