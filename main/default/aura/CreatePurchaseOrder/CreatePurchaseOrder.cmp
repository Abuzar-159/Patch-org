<aura:component implements="lightning:actionOverride,force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction,lightning:isUrlAddressable" access="global" controller="CreatePO">
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/Createpurchaseorder.css"/> 
    <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/global-axolt.css"/> 
    <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/> 
    <ltng:require styles="/resource/ERP7__PickPackShipResource/assets/styles/font-awesome.css" />
    <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/> 
    <ltng:require styles="{!join(',',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.css',$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.min.css',$Resource.PickPackShipResource + '/assets/styles/erp_mark7_bootstrap.css',$Resource.PickPackShipResource + '/assets/styles/font-awesome.css' )}"/>    
    
    <aura:attribute name="prodRecordId" type="String"  />
    <aura:attribute name="PoQty" type="Decimal" default="0"/>
    <aura:attribute name="POType" type="List" />
    <aura:attribute name="selectedRecType" type="String" default=""/>
    <aura:attribute name="PO" type="PO__c" default="{sObjectType :'ERP7__PO__c',ERP7__Vendor__c:'',ERP7__Channel__r:'',ERP7__Channel__r:{Id:'',Name:''},ERP7__Distribution_Channel__r:'',ERP7__Distribution_Channel__r:{Id:'',Name:''}, ERP7__Distribution_Channel__c:'',ERP7__Shipping_Preference_type__c:'', ERP7__Customer__r:{'Id':'','Name':''},ERP7__Vendor__r:{'Id':'','Name':''},ERP7__Vendor_Address__c:'',ERP7__Vendor_Address__r:{Id:'',Name:''},ERP7__EmployeeRequester__c:'',ERP7__EmployeeRequester__r:{Id:'',Name:''},ERP7__FinalApprover__c:'',ERP7__FinalApprover__r:{Id:'',Name:''}}"/>
    <aura:attribute name="POWrap" type="Object"/>
    <aura:attribute name="orderId" type="String" default=""/>
    <aura:attribute name="POStatusoptions" type="List" /> 
    <aura:attribute name="POTypeoptions" type="List" /> 
    <aura:attribute name="POShipmentoptions" type="List" />
    <aura:attribute name="POShipmentSpeed" type="List" />
    <aura:attribute name="dimensionList" type="object[]"  />
    <aura:attribute name="poli" type="String[]" />
    <aura:attribute name="cancelclick" type="Aura.Action" default="{!c.goBack}"/>
    <aura:attribute name="saveclick" type="Aura.Action" default="{!c.savePO}"/>
    <aura:attribute name="Index2del" type="Integer" default="-1"/>
    <aura:attribute name="vendorId" type="String" default=""/>
    <aura:handler name="change" value="{!v.TotalPrice}" action="{!c.updateTotalPrice}"/>
    <aura:attribute name="MOId" type="String" default=""/>
    <aura:attribute name="MPsMOId" type="String" default=""/>
    <aura:attribute name="SOId" type="String" default=""/>
    <aura:attribute name="WOId" type="String" default=""/>
    <aura:attribute name="TotalPrice" type="Currency"/>
    <aura:attribute name="fromMultiPO" type="boolean" default="false"/>
    <aura:attribute name="ProjectAccess" type="boolean" default="false"/>
    <aura:attribute name="DepartmentAccess" type="boolean" default="false"/>
    <aura:attribute name="hidechannelRemove" type="boolean" default="false"/>
    <aura:attribute name="fromCB" type="boolean" default="false"/>
    <aura:attribute name="fromAP" type="boolean" default="false"/>
    <aura:attribute name="showReceive" type="boolean" default="false"/>
    <aura:attribute name="fromAPB" type="boolean" default="false"/>
    <aura:attribute name="fromProject" type="boolean" default="false"/>
    <aura:attribute name="ProjId" type="String" default=""/>
    <aura:attribute name="recordId" type="String" default=""/>
    <aura:attribute name="clonePOId" type="String" default=""/>
    <aura:attribute name="HideHeader" type="Boolean" default="true"/>
    <aura:attribute name="isFromNone" type="Boolean" default="true"/>
    <aura:attribute name="isRecieved" type="Boolean" default="false"/>
    <aura:attribute name="returnToVendor" type="Boolean" default="false"/>
    <aura:attribute name="navigateToRecord" type="Boolean" default="true"/> 
    <aura:attribute name="vId" type="String"/>
    <aura:attribute name="exceptionError" type="String" default=""/>
    <aura:attribute name="Mtask" type="Actions_Tasks__c"/>
    <aura:attribute name="projectId" type="String"/>
    <aura:attribute name="currentMilestones" type = "object"/>
    <aura:attribute name="currentProject" type = "Project__c"/>
    <aura:attribute name="itemToDel" type="String[]"/>
    <aura:attribute name="RFPsupplier" type="Request_Supplier__c"/>
    <aura:attribute name="RFPrequest" type="Request__c"/>
    <aura:attribute name="rmaliID" type="String" default=""/>
    <aura:attribute name="mpslineId" type="String" default=""/>
    <aura:attribute name="mrplineId" type="String" default=""/>
    <aura:attribute name="quantityMultiplier" type="Decimal" default="1"/>
    <aura:attribute name="RMALI" type="RMA_Line_Item__c"/>
    <aura:attribute name="soliID" type="String" default=""/>
    <aura:attribute name="isSalesOrder" type="Boolean" default="false"/>
    <aura:attribute name="ispaymnetAccess" type="Boolean" default="false"/>
    <aura:attribute name="versionAccess" type="Boolean" default="false"/>
    <aura:attribute name="QuoteAccess" type="Boolean" default="false"/>
    <aura:attribute name="AutoAccountAllocations" type="Boolean" default="false"/>
    <aura:attribute name = "currentProj" type = "Project__c" default="{'sObjectType':'ERP7__Project__c',
                                                                            'Name': '',
                                                                            'ERP7__Status__c': '--none--',
                                                                            'ERP7__Project_Manager__c': '',
                                                                            'ERP7__Organisations__c' : '',
                                                                            'ERP7__Default_Routing__c' : '',
                                                                            'ERP7__Team__c' : '',
                                                                            'ERP7__Account__c' : '',
                                                                            'ERP7__Contact__c' : '',
                                                                            'ERP7__Total_Expense_Amount__c' : '',
                                                                            'ERP7__Total_Income__c' : ''
                                                                            }"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="init" value="{!this}" action="{!c.displayRecords}"/>
    
    <aura:method name="save_PO" action="{!c.savePO}" access="PUBLIC">
        <aura:attribute name="callback" type="Function" />
    </aura:method>  
    <aura:dependency resource="force:showToast"/>
    <aura:handler name="change" value="{!v.PO.ERP7__Vendor__c}" action="{!c.UpdatePO}"/>
    <aura:handler name="change" value="{!v.PO.ERP7__Organisation__c}" action="{!c.UpdateOA}"/>
    <aura:handler name="change" value="{!v.Index2del}" action="{!c.deletePoli}"/>
    <aura:handler name="change" value="{!v.purchaseOrderId}" action="{!c.fetchDetailsonPO}"/>
    <aura:attribute name="Tax" type="Currency"/>
    <aura:attribute name="TotalTax" type="Currency" default="0.00"/>
    <aura:attribute name="SubTotal" type="Currency" default="0.00"/>
    <aura:attribute name="TotalAmount" type="Currency" default="0.00"/>
    <aura:handler name="change" value="{!v.Tax}" action="{!c.updateTotalTax}"/>
    <aura:attribute name="qmsg"  type="String" default=""/>
    <aura:attribute name="isDelete"  type="Boolean" default="false"/>
    <aura:attribute name="fromRequisition"  type="Boolean" default="false"/>
    <aura:attribute name="interCompanyPO"  type="Boolean" default="false"/>
    <aura:attribute name="isNewAddress"  type="Boolean" default="false"/>
    <aura:attribute name="channelId" type="String" default=""/>
    <aura:attribute name="purchaseOrderId" type="String" default=""/>
    <aura:attribute name="dChannelId" type="String" default=""/>
    <aura:attribute name="Channel"  type="Map" default="{'Id':'','Name':''}"/>
    <aura:attribute name="distributionChannel" type="sObject" default="{'Id':'','Name':''}"/>
    <aura:handler name="change" value="{!v.isDelete}" action="{!c.deletePoli}"/>
    <aura:handler name="change" value="{!v.dChannelId}" action="{!c.getDeliveryAdd}"/>
    <aura:attribute name="proceedDeliveryAddChange" type="Boolean" default="true"/>
    
    <aura:handler name="change" value="{!v.PO.ERP7__Shipment_Type__c}" action="{!c.parentFieldChange}"/>
    <aura:handler event="c:RequisitionToPurchaseOrderEvent" action="{!c.deletePoli}"/>
    <aura:attribute name="showMainSpin" type="boolean" default="true"/>
    <aura:attribute name="nameUrl" type="String"/>
    <aura:attribute name="POExisting" type="list"/>
    <aura:attribute name="ShipmentId" type="String"/> 
    <aura:attribute name="PackIds" type="List"/>
    <aura:attribute name="fromshipment" type="Boolean" default="false"/>
    <aura:attribute name="showVenName" type="Boolean" default="false"/>
    <aura:attribute name="POLINameAcc" type="Boolean" default="false"/>
    <aura:attribute name="showTaxName" type="Boolean" default="false"/>
    <aura:attribute name="showAllocations" type="Boolean" default="false"/>
    <aura:attribute name="venAddressRequired" type="Boolean" default="false"/>
    <aura:attribute name="venConRequired" type="Boolean" default="true"/>
    <aura:attribute name="showTaxRate" type="Boolean" default="false"/>
    <aura:attribute name="showpackageType" type="Boolean" default="false"/>
    <aura:attribute name="showOrgName" type="Boolean" default="true"/>
    <aura:attribute name="showDchannelBelow" type="Boolean" default="false"/>
    <aura:attribute name="DcRequired" type="Boolean" default="true"/>
    <aura:attribute name="rmaId" type="String" default="" />
    <aura:attribute name="defaultVenAcc" type="object" />
    <aura:attribute name="defaultVenCon" type="object"  />
    <aura:attribute name="defaultVenAddress" type="object"  />
    <aura:attribute name="ACCRecId" type="String" default=""/>
    <aura:attribute name="ConRecId" type="String" default=""/>
    
    <aura:attribute name="prSelectedOrder" type="String" default=""/>
    <aura:attribute name="salesOrder" type="Boolean" default="false"/> 
    <aura:attribute name="preventChange" type="Boolean" default="true"/>
    <aura:attribute name="QueryRecentRecord" type="Boolean" default="false"/> 
    <aura:attribute name="ObjectAPIName" type="string" default="Account"/>
    <aura:attribute name="FieldToAssign" type="String" default=""/>
    <aura:attribute name="defaultcmpValue" type="object" />
    <aura:handler name="change" value="{!v.PO.ERP7__Vendor_Address__c}" action="{!c.checkforTaxRate}"/>
    
    <!-- For Shipment Dependent Picklists -->
    <aura:attribute name="objDetail" type="string" default="ERP7__PO__c" />
    <aura:attribute name="controllingFieldAPI" type="string" default="ERP7__Shipment_Type__c" description="store field API name of Controller field"/>
    <aura:attribute name="dependingFieldAPI" type="string" default="ERP7__Shipment_Preference_Speed__c" description="store field API name of dependent field"/>
    <aura:attribute name="listDependingValues" type="list" default="" description="to store dependent field values"/>
    <aura:attribute name="listControllingValues" type="list" default="" description="to store controller field values"/>
    <aura:attribute name="bDisabledDependentFld" type="boolean" default="false"/> 
    <aura:attribute name="depnedentFieldMap" type="object" description="map to store dependent values with controlling value"/>
    <aura:attribute name="showchecklistvalue" type="boolean" default="false"/>
    <aura:attribute name="ControllingValue" type="String" default="" description="to store controller field values"/>
    <aura:attribute name="isMultiCurrency" type="Boolean" default="false"/>
    <aura:attribute name="currencyList" type="List"/>
    
    <!-- For file Uplaod -->
    <aura:attribute name="fillList" type="String[]" default="[]"/>
    <aura:attribute name="showDelete" type="Boolean" default="false"/>
    <aura:attribute name="showLoadingSpinner" type="boolean" default="false" />
    <aura:attribute name="FileList" type="object"/>
    <aura:attribute name="fileName" type="String" default="No File Selected.." />
    <aura:attribute name="showfileUpload" type="Boolean" default="false"/>
    <aura:attribute name="successMsg" type="String" default=""/>
    <aura:attribute name="uploadedFile" type="String[]" />
    
    <!-- For add product section -->
    <aura:attribute name="showAddProducts" type="Boolean" default="false"/>
    <aura:attribute name="allowCustomProd" type="Boolean" default="false"/>
    <aura:attribute name="toggleChecked" type="Boolean" default="false"/>
    <aura:attribute name="searchItem" type="String" default=""/>
    <aura:attribute name="seachItemFmily" type="String" default=""/>
    <aura:attribute name="Poructobj" type="string" default="Product2" />
    <aura:attribute name="FamilycontrollingFieldAPI" type="string" default="Family" description="store field API name of Controller field"/>
    <aura:attribute name="SubFamilydependingFieldAPI" type="string" default="ERP7__Product_Service_Family__c" description="store field API name of dependent field"/>
    <aura:attribute name="bDisabledSubFamilyFld" type="boolean" default="true"/> 
    <aura:attribute name="FamilydepnedentFieldMap" type="object" description="map to store dependent values with controlling value"/>    
    <aura:attribute name="subItemFmily" type="String" default=""/>
    <aura:attribute name="familylst" type="List" /> 
    <aura:attribute name="subfamilylst" type="List" /> 
    <aura:attribute name="showStandardProducts" type="Boolean" default="true"/>
    <aura:attribute name="ClistOfProducts" type="List"/>
    <aura:attribute name="listOfProducts" type="String[]" default="[]"/>
    <aura:attribute name="addProductsMsg" type="String" default=""/>
    <aura:attribute name="defaultTaxRate" type="Decimal" default="0"/>
    <aura:attribute name="reRenderPOLIS" type="Boolean" default="true"/>
    <aura:attribute name="globalProdSearch" type="Boolean" default="false"/>
    <aura:attribute name="selectedListOfProducts" type="String[]" default="[]"/>
    <aura:attribute name="SelectedcustomerOrders" type="List"/>
    
    <aura:attribute name="showPOType" type="Boolean" default="true"/>
    <aura:attribute name="DropShipPOrecType" type="String" default="{!$Label.c.DropShipPOrecType}"/>
    <aura:attribute name="ReturnPOrecType" type="String" default="{!$Label.c.ReturnPOrecType}"/>
    <aura:attribute name="NonePicklistType" type="String" default="{!$Label.c.NonePicklistType}"/>
    
    <aura:handler name="change" value="{!v.PO.ERP7__Customer__c}" action="{!c.setDeliveryAdd}"/>
    <aura:handler name="change" value="{!v.PO.ERP7__Order__c}" action="{!c.getOrderItemsforDropShip}"/>
    
    <aura:attribute name="proceedDefaultTaxRateChange" type="Boolean" default="true"/>
    <aura:attribute name="CostCardFilter" type="String" default=""/>
    
    <!-- Added new attributes to shore the data OCR part -->
            <aura:attribute name="billPayload" type="Object"/>
    
    <aura:attribute name="POCurrencyIsoCode" type="String" default=""/>
    <aura:attribute name="filesData2Upload" type="String[]" default="[]"/>
    <aura:attribute name="reRenderCustPOli" type="Boolean" default="true"/>
    <!--SPINNER VALUES-->
    <aura:attribute name="showSpinner" type="Boolean" default="false" />
    
    
         
           
    
    <aura:attribute name="spinnerContent" type="String" default="{!$Label.c.Please_wait_while_loading_UserAvailabilities}"/>
    <div class="erp_mark7 maqsood slds-p-bottom_large" aura:id="body">
        <!--span class="cpo-class2"-->
            <aura:if isTrue="{!v.showSpinner}">
                <div class="custom-spinner slds-spinner_container ">
                    <div role="status" class="slds-spinner slds-spinner_large slds-spinner_brand">
                        <span class="slds-assistive-text">Loading</span>
                        <div class="slds-spinner__dot-a"></div>
                        <div class="slds-spinner__dot-b"></div>
                        
                    </div>
                    <div class="custom-loading-text">
                            {!v.spinnerContent}
                        </div>
                </div>
            </aura:if>
            <!--lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass" /-->
        <!--/span-->
        
        <div class=" slds-container--fluid bg-white"> 
            <div class="{!if(and(v.exceptionError != '', v.exceptionError != undefined),'slds-notify_container slds-is-fixed cpo-class10','slds-notify_container slds-is-fixed cpo-class9')}">
                <div class="slds-notify slds-notify_toast slds-theme_error cpo-class11" role="status">
                    <span class="slds-assistive-text">{!$Label.c.error}&nbsp;</span>
                    <span class="slds-icon_container slds-icon-utility-error slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.error}" title="{!$Label.c.error}" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_x-small cpo-class12">{!v.exceptionError}&nbsp;
                        </h2>
                    </div>
                    <div class="slds-notify__close cpo-class13">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="{!$Label.c.Close_Timesheets}" onclick="{!c.closeError}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="{!$Label.c.Close_Timesheets}" />
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}&nbsp;</span>
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="{!if(and(v.successMsg != '', v.successMsg != undefined),'slds-notify_container slds-is-fixed cpo-class10','slds-notify_container slds-is-fixed cpo-class9')}">
                <div class="slds-notify slds-notify_toast slds-theme_success cpo-class11" role="status">
                    <span class="slds-assistive-text">{!$Label.c.error}&nbsp;</span>
                    <span class="slds-icon_container slds-icon-utility-success slds-m-right_small slds-no-flex slds-align-top">
                        <lightning:icon iconName="utility:success" variant="inverse" size="x-small" alternativeText="{!$Label.c.error}" title="{!$Label.c.error}" />
                    </span>
                    <div class="slds-notify__content">
                        <h2 class="slds-text-heading_x-small cpo-class12">{!v.successMsg}&nbsp;
                        </h2>
                    </div>
                    <div class="slds-notify__close cpo-class13">
                        <button class="slds-button slds-button_icon slds-button_icon-inverse" title="{!$Label.c.Close_Timesheets}" onclick="{!c.closeError}">
                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="{!$Label.c.Close_Timesheets}" />
                            <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}&nbsp;</span>
                        </button>
                    </div>
                </div>
            </div>
            
            <aura:if isTrue="{!!v.showPOType}">
                
                <aura:if isTrue="{!!v.showAddProducts}">
                    <aura:if isTrue="{!v.HideHeader}">
                        <div class="slds-page-header">
                            <div class="slds-grid">
                                <div class="slds-col slds-has-flexi-truncate">
                                    <div class="slds-media slds-no-space slds-grow">
                                        <div class="slds-media__figure">
                                            <lightning:icon iconName="standard:work_plan" variant="inverse" size="x-medium" alternativeText="{!$Label.c.work_plan}" title="" /><!--title="{!$Label.c.work_plan}"-->
                                        </div>
                                        <aura:if isTrue="{!(v.selectedRecType == v.DropShipPOrecType)}">
                                            <div class="slds-media__body">
                                                <p class="slds-text-title--caps slds-line-height--reset slds-m-bottom_xxx-small">{!$Label.c.Create_Drop_Ship_PO}</p>
                                                <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-m-bottom_xxx-small" title="">{!$Label.c.Purchase_Order} </h1>
                                            </div>
                                            <aura:set attribute="else">
                                                <aura:if isTrue="{!v.returnToVendor}">
                                                    <div class="slds-media__body">
                                                        <p class="slds-text-title--caps slds-line-height--reset slds-m-bottom_xxx-small">{!$Label.c.Return}</p>
                                                        <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-m-bottom_xxx-small" title="">{!$Label.c.Purchase_Order} </h1>
                                                        
                                                    </div>
                                                    <aura:set attribute="else">
                                                        <div class="slds-media__body">
                                                            <p class="slds-text-title--caps slds-line-height--reset slds-m-bottom_xxx-small">{!$Label.c.Transfer_Order_Create}</p>
                                                            <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-m-bottom_xxx-small" title="">{!$Label.c.Purchase_Order} </h1>
                                                            
                                                        </div>
                                                    </aura:set>
                                                </aura:if>
                                            </aura:set>
                                        </aura:if>  
                                    </div>
                                    <aura:if isTrue="{!v.returnToVendor}">
                                        <div class="cpo-class365">
                                            <c:CustomInputLookUp objectAPIName="ERP7__PO__c" IconName="standard:address" selectedRecordId="{!v.purchaseOrderId}" aura:Id="Po" />
                                        </div>
                                    </aura:if>
                                </div>
                                <div class="slds-col slds-no-flex slds-grid slds-align-top" >
                                    <div class="slds-grid" >
                                        <div class="slds-col slds-m-right--xx-small">
                                            <div class="cpo-class3">
                                                <c:CustomInputLookUp objectAPIName="ERP7__Channel__c" IconName="custom:custom24" selectedRecordId="{!v.channelId}" label="{!$Label.c.Channel_StockTake}" hideRemove="{!v.hidechannelRemove}"                                                             />
                                            </div>
                                        </div>
                                        <div class="slds-col">
                                            <aura:if isTrue="{!and(!v.showDchannelBelow,v.selectedRecType != v.DropShipPOrecType)}">
                                                
                                                <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                    <div class="cpo-class3"> 
                                                        <c:CustomInputLookUp objectAPIName="ERP7__Distribution_Channel__c" required="true" aura:id="dcId" 
                                                                             IconName="custom:custom32"  selectedRecordId="{!v.dChannelId}" label="{!$Label.c.Distribution_center_receiving}" qry="{!'And ERP7__Channel__c = \''+v.channelId+'\''}"
                                                                             />
                                                    </div>
                                                </div>
                                            </aura:if>
                                        </div>
                                        
                                    </div>      
                                </div>
                            </div>
                        </div>
                    </aura:if>
                    
                    <div class="card shadow-custom MultiplePurchaseOrder-newClass6">
                        <div class="card-body p-2">
                            <aura:if isTrue="{!(empty(v.orderId) || empty(v.SOId))}" >
                                <div class="epr_Mark7 cpo-class4" aura:id="POId">
                                    
                                    <aura:if isTrue="{!v.POExisting.length>0}">   
                                        
                                        <div class="slds-card__body cpo-class5">    
                                            <table class="slds-table slds-table--bordered slds-table_cell-buffer" >
                                                <thead>
                                                    <tr>
                                                        <th class="slds-text-heading--label" scope="col"></th>
                                                        <th class="slds-text-heading--label" scope="col">{!$Label.c.Name_ManageLeave}</th>                                
                                                        <th class="slds-text-heading--label" scope="col">{!$Label.c.Order_RMA}</th>
                                                        <th class="slds-text-heading--label" scope="col">Contact</th>                        
                                                        <th class="slds-text-heading--label" scope="col">{!$Label.c.To_Address}</th> 
                                                        <th class="slds-text-heading--label" scope="col">{!$Label.c.Status}</th>   
                                                    </tr>  
                                                </thead>
                                                
                                                <tbody>                    
                                                    <aura:iteration items="{!v.POExisting}" var="PO" indexVar="index">      
                                                        <tr>          
                                                            <td data-label="">
                                                                <div class="slds-truncate" title=""></div>
                                                            </td>
                                                            <td data-label="Name">
                                                                <div class="slds-truncate" title="">
                                                                    <a class="svg" target="_blank" onclick="{!c.showLogisticRecordDetailsPage}" href="{!v.nameUrl}" data-record="{!PO.Id}">{!PO.Name}</a>
                                                                </div>
                                                            </td>
                                                            <td data-label="Order">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!PO.Order}"/>   
                                                                </div>
                                                            </td>
                                                            <td data-label="Contact">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!PO.Contact}"/>     
                                                                </div>
                                                            </td>
                                                            <td data-label="ToAddress">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!PO.ToAddress}"/>   
                                                                </div>
                                                            </td>
                                                            <td data-label="Status">
                                                                <div class="slds-truncate" title="">
                                                                    <lightning:formattedText value="{!PO.Status}"/>    
                                                                </div>
                                                            </td>                   
                                                        </tr>
                                                    </aura:iteration>              
                                                </tbody>
                                                
                                            </table>
                                        </div>
                                    </aura:if> 
                                </div>
                            </aura:if>
                            
                            <div class="epr_Mark7 cpo-class4"> 
                                <div class="row padding-t-5 cpo-class6"> 
                                    <aura:if isTrue="{!v.showReceive}">
                                        <div class="col-md-3  slds-p-top--xx-small"> 
                                            <div class="cpo-class7">
                                                <label class="slds-form-element__label" style="margin-right: 0.5rem;">{!$Label.c.PO_Purchase_Order_Number}</label>
                                                <lightning:helptext content="{!$Label.c.PO_Number_helptext}" class="customIcon"/>
                                                <lightning:input type="text" variant="label-hidden"  label="{!$Label.c.PO_Purchase_Order_Number}" value="{!v.PO.Name}" aura:id="poName" oncommit="{!c.validateField}" maxlength="80"/>
                                            </div>
                                        </div> 
                                    </aura:if>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <label class="slds-form-element__label" style="margin-right: 0.5rem;">{!$Label.c.POExpectedDate}</label>
                                        <lightning:helptext content="{!$Label.c.Estimated_Delivery_Date}" class="customIcon"/>
                                        <lightning:input type="date" variant="label-hidden" label="{!$Label.c.Expected_Date}" aura:id="Expecteddate"  value="{!v.PO.ERP7__Expected_Date__c}" />
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small cpo-class8">
                                        <lightning:select name="poStatus"  label="{!$Label.c.Status}" aura:id="poStatus" value="{!v.PO.ERP7__Status__c}" >
                                            <aura:iteration items="{!v.POStatusoptions}" var="item">
                                                <option text="{!item.label}" value="{!item.value}" selected="{!v.PO.ERP7__Status__c == item.value}"/>
                                            </aura:iteration>
                                        </lightning:select> 
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <c:CustomInputLookUp objectAPIName="ERP7__Employees__c" required="true" IconName="utility:user" selectedRecordId="{!v.PO.ERP7__EmployeeRequester__c}" label="{!$Label.c.PO_Employee_Requester}"/>
                                    </div> 
                                </div>
                                
                                <div class="row padding-t-5 cpo-class6"> 
                                    <aura:if isTrue="{!!v.showDchannelBelow}">
                                        <div class="col-md-3 slds-p-top--xx-small" > 
                                            <aura:if isTrue="{!(v.selectedRecType == v.DropShipPOrecType)}">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Customer__c}" label="{!$Label.c.PO_Customer_Manufacturer}" aura:Id="customerAccount" qry=" AND (ERP7__Account_Type__c = 'Customer' OR ERP7__Account_Type__c = 'Vendor' OR ERP7__Account_Type__c = 'Organisation/Vendor') " required="true"/>
                                                <aura:set attribute="else">
                                                    <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Customer__c}" label="{!$Label.c.PO_Customer_If_Applicable}" aura:Id="customerAccount" qry=" AND ERP7__Account_Type__c = 'Customer' " required="false"/>
                                                </aura:set>
                                            </aura:if>
                                        </div>
                                    </aura:if>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small"> 
                                        <aura:if isTrue="{!and(or(v.recordId == null, v.recordId == ''),or(v.clonePOId == null, v.clonePOId == ''))}">
                                            <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Vendor__c}" FieldValue="POV" POC="{!v.PO}" PoliItems ="{!v.poli}" label="{!$Label.c.InventoryConsole_Vendor}" required="true" aura:Id="vendorAccount" ShowNew="true" defaultvalues="{!v.defaultVenAcc}" cmpName="ERP7:CreatePurchaseOrder" objName="Vendor" APIName="Account" qry="{! v.PO.ERP7__Organisation__c != ''?' AND ERP7__Organisation__c =\''+ v.PO.ERP7__Organisation__c+'\''+ ' AND (ERP7__Account_Type__c =\'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')' : ' AND (ERP7__Account_Type__c =\'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}" /><!-- qry=" AND ERP7__Account_Type__c= 'Vendor'" -->
                                            <aura:set attribute="else">
                                                <c:CustomInputLookUp objectAPIName="Account" IconName="standard:account" selectedRecordId="{!v.PO.ERP7__Vendor__c}" label="{!$Label.c.InventoryConsole_Vendor}" required="true" aura:Id="vendorAccount"  qry="{! v.PO.ERP7__Organisation__c != ''?' AND ERP7__Organisation__c =\''+ v.PO.ERP7__Organisation__c+'\''+ ' AND (ERP7__Account_Type__c =\'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')' : ' AND (ERP7__Account_Type__c =\'Vendor\' OR ERP7__Account_Type__c = \'Organisation/Vendor\')'}" />
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <aura:if isTrue="{!and(or(v.clonePOId == null, v.clonePOId == ''),and(v.PO.ERP7__Vendor__c != null, v.PO.ERP7__Vendor__c != ''),or(v.recordId == null, v.recordId == ''))}">
                                            <c:CustomInputLookUp objectAPIName="Contact" IconName="standard:contact" selectedRecordId="{!v.PO.ERP7__Vendor_Contact__c}" label="{!$Label.c.Contact_Record_Name}" required="{!v.venConRequired}" aura:Id="vendorContact" FieldValue="POC" POC="{!v.PO}" PoliItems ="{!v.poli}" ShowNew="true" defaultvalues="{!v.defaultVenCon}" cmpName="ERP7:CreatePurchaseOrder" objName="Vendor Contact" APIName="Contact" qry="{!'And AccountId = \''+v.PO.ERP7__Vendor__c+'\''}"/> 
                                            <aura:set attribute="else">
                                                <c:CustomInputLookUp objectAPIName="Contact" IconName="standard:contact" selectedRecordId="{!v.PO.ERP7__Vendor_Contact__c}" label="{!$Label.c.Contact_Record_Name}" required="{!v.venConRequired}" aura:Id="vendorContact" qry="{!'And AccountId = \''+v.PO.ERP7__Vendor__c+'\''}"/> 
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <aura:if isTrue="{!and(and(v.PO.ERP7__Vendor__c != null, v.PO.ERP7__Vendor__c != ''),or(v.recordId == null, v.recordId == ''))}">
                                            <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Vendor_Address__c}" aura:Id="vendorAddress" required="{!v.venAddressRequired}" label="{!$Label.c.InventoryConsole_Vendor_Address}"  qry="{!'And ERP7__Customer__c  = \''+v.PO.ERP7__Vendor__c+'\''}"/><!-- ShowNew="true" defaultvalues="{!v.defaultVenAddress}" cmpName="ERP7:CreatePurchaseOrder" objName="Vendor Address" APIName="ERP7__Address__c" -->
                                            <aura:set attribute="else">
                                                <c:CustomInputLookUp objectAPIName="ERP7__Address__c" IconName="standard:address" selectedRecordId="{!v.PO.ERP7__Vendor_Address__c}" aura:Id="vendorAddress" required="{!v.venAddressRequired}" label="{!$Label.c.InventoryConsole_Vendor_Address}"  qry="{!'And ERP7__Customer__c  = \''+v.PO.ERP7__Vendor__c+'\''}"/>
                                            </aura:set>
                                        </aura:if>
                                    </div>
                                </div>
                                
                                <div class="row padding-t-5 cpo-class6">
                                    <aura:if isTrue="{!v.showOrgName}"> 
