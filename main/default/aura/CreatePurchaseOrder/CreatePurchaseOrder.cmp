                                                                             poli="{!v.poli}" Tax="{!v.Tax}" isDelete="{!v.isDelete}" recId="{!v.recordId}" received="{!v.isRecieved}" dCId = "{!v.dChannelId}" DefTaxRate="{!v.defaultTaxRate}"/> 
                                                </aura:iteration>
                                            </aura:if>
                                        </tbody>   
                                    </table> 
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="slds-p-top--small"></div>
                    
                    <div class="slds-text-align--center slds-docked-form-footer "><!--slds-p-around-mmedium cpo-float-button-->
                        <aura:if isTrue="{!and(v.prodRecordId != null,v.prodRecordId != '')}">
                            <lightning:formattedUrl value="/lightning/n/ERP7__Inventory_Management_Report" label="{!$Label.c.QuotationConsole_Cancel}" class="slds-button slds-button--neutral" />
                            <aura:set attribute="else">
                                <aura:if isTrue="{!v.Mtask}">
                                    <lightning:button label="{!$Label.c.EmployeeReviewV2_Back}"  class="slds-button slds-button--neutral" onclick="{!c.goBackTask}"/> &nbsp;
                                    <aura:set attribute="else">
                                        <aura:if isTrue="{!v.fromshipment}">
                                            <lightning:button label="{!$Label.c.Cancel_ManageLeave}"  class="slds-button slds-button--neutral" onclick="{!c.gobacktoshipment}"/> &nbsp;
                                            <aura:set attribute="else">
                                                <lightning:button label="{!$Label.c.ShippingSlip_Back}"  class="slds-button slds-button--neutral" onclick="{!c.goToRecTypeSelection}"/> &nbsp;<!-- onclick="{!v.cancelclick}" changed by shaguftha on 28/07/23 to fix the issue of cancel -->
                                            </aura:set> 
                                        </aura:if>
                                    </aura:set>
                                </aura:if>
                            </aura:set>
                        </aura:if>
                        
                        <lightning:button label="{!$Label.c.ContractConsole_Save}" variant="brand" class="slds-button slds-button--brand white" onclick="{!v.saveclick}"/><!-- disabled="{!v.isRecieved}" -->
                    </div>
                </aura:if>
                
                <aura:if isTrue="{!v.showAddProducts}">
                    <div class="slds-page-header">
                        <div class="slds-page-header__row">
