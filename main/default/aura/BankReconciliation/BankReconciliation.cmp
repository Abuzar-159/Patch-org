<aura:component controller="BankReconciliationLightning" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <head>
        <ltng:require styles="/resource/ERP7__bootstrap/bootstrap/css/bootstrap.css"/>
        <ltng:require styles="/resource/ERP7__SLDS/assets/styles/salesforce-lightning-design-system-vf.css" /> 
        <ltng:require styles="/resource/ERP7__bootStrap/css/bootstrap-4.1.css"/>
        <ltng:require styles="{!join(',', $Resource.PickPackShipResource+'/assets/styles/font-awesome.css')}"  />
        <ltng:require styles="/resource/ERP7__ProjectWorkbench/css/main-style.css"/>
        <ltng:require styles="/resource/ERP7__CMP_CSS/CSS/BankReconclation.css"/>
        <ltng:require styles="/resource/CMP_CSS/CSS/global-axolt.css"/>
    </head>
    
    <aura:attribute name="FileList" type="object[]"/>
    <aura:attribute name="searchString2" type="String"/>
    <aura:attribute name="searchAmount" type="String"/>
    <aura:attribute name="display" type="Boolean" default="false"/>
    <aura:attribute name="display2" type="Boolean" default="false"/>
    <!-- <aura:attribute name="newTransaction" type="ERP7__Transaction__c"/>-->
    <aura:attribute name="newTransaction" type="Transaction__c" default="{'ERP7__Transaction_Type__c': '',
                                                                               'ERP7__Amount__c': '',
                                                                               'ERP7__Finance_Category_Type__c': 'Credit',
                                                                               }"/>
    <aura:method name="switchTab" action="{!c.switchTab}"></aura:method>
    <aura:attribute name="selectedTransaction" type="list" default=""/>
    <aura:attribute name="selectedTransaction2" type="list" default=""/>
    <aura:attribute name="Total" type="integer" default="0"/> 
    <aura:attribute name="Total2" type="integer" default="0"/> 
    <aura:attribute name="showSubTabs" type="String" default="cus2"/>
    <aura:attribute name="TransactionWrapperList" type="list" default=''/>
    <aura:attribute name="TransactionWrapperList2" type="list" default=''/>
    <aura:attribute name="undoReconcile_Wrapperlist" type="list" default="{'sObjectType' : 'WrapperBankUnReconcile'}"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUserRecord}"/>
    <aura:handler name="Search_Event" event="c:SearchEvent" action="{!c.searchUser}"/>
    <aura:method name="doInit" action="{!c.doInit}"></aura:method>
    <aura:attribute name="nextDisa" type="Boolean" default="false"/>
    <aura:attribute name="AutoReconcile" type="Boolean" default="false"/>
    <aura:attribute name="startDate"      type="Date" />
    <aura:attribute name="endDate"      type="Date" />
    <aura:attribute name="showTabs" type="String" default="cus"/>
    <aura:attribute name="UserId" type="String" default=""/>
    <aura:attribute name="RenderBody" type="Boolean" default="true"/>
    <aura:attribute name="prevDisa" type="Boolean" default="true"/>
    <aura:attribute name="DocumentId" type="String"/>
    <aura:attribute name="ClickOn" type="String" default="Next"/>
    <aura:attribute name="Entries" type="Integer" default="10"/>
    <aura:attribute name="counter" type="Integer" default="0"/>
    <aura:attribute name="counterEnd" type="Integer" default="0"/>
    <aura:attribute name="OrganisationId" type="String"/>
    <aura:attribute name="Bank_Reconciliation_Id" type="String"/>
    <aura:attribute name="selectedBankAccount" type="String"/>
    <aura:attribute name="BankRecon_obj" type="Bank_Reconciliation__c" default=""/>
    <aura:attribute name="showMmainSpin" type="Boolean" default="false"/>
    <aura:attribute name="bankStmtlist" type="Bank_Statement__c[]"/>
    <aura:attribute name="banktranslist" type="Bank_Transaction__c[]"/>
    <aura:attribute name="bankStmtlistDum" type="Bank_Statement__c[]"/>
    <aura:attribute name="pageNumbers" type="String[]" default="1"/> 
    <aura:attribute name="SearchString" type="String" default=""/> 
    <aura:attribute name="Status" type="String" default="Completed"/>
    <aura:attribute name="doc" type="String" default="01524000000VNvO"/> 
    <aura:attribute name="Tab"           type="String"   default="Tab1" /> 
    <aura:attribute name="listitems" type="Account[]"/>
    <aura:attribute name="NoSlotsMessage" type="String" default="No Data available"/>
    <aura:attribute name="BankStatement" type="Bank_Statement__c"/>
    <aura:attribute name="FromSP" type="Boolean" default="false"/>
    <aura:attribute name="SaveErrorMsg" type="String" default=""/>
    <aura:attribute name="stStatus2Options" type="List"/>
    <aura:attribute name="OrderBy" type="String" default="ERP7__Transaction_Date__c"/> 
    <aura:attribute name="Order" type="String" default="DESC"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <!--<aura:handler name="change" value="{!v.Bank_Reconciliation_Id}" action="{!c.fetchDetails}"/>-->
    <div class="maqsood">
        <div class="erp_mark7 erp_Mark7 BankReconciliation-newClass1" aura:id="body">
            <div class=" slds-container--fluid">
                <aura:if isTrue="{!and(v.SaveErrorMsg!=undefined, v.SaveErrorMsg!='')}">
                    <div class="slds-notify_container slds-is-fixed BankReconciliation-newClass2" aura:id="criteriaMsgId">
                        <div class="slds-notify slds-notify_toast slds-theme_alert-texture slds-theme_error BankReconciliation-newClass3 " role="status">
                            <span class="slds-assistive-text">{!$Label.c.warning_UsersShiftMatch}</span>
                            <span class="slds-icon_container slds-icon-utility-warning slds-m-right_small slds-no-flex slds-align-top" title="Description of icon when needed">
                                    <lightning:icon iconName="utility:error" variant="inverse" size="x-small" alternativeText="{!$Label.c.Error_UsersShiftMatch}" title="Error" onclick="{!c.close}"/>
                            </span>
                            <div class="slds-notify__content">
                                <h2 class="slds-text-heading_x-small "> {!v.SaveErrorMsg}
                                </h2>
                            </div>
                            <div class="slds-notify__close">
                                <button class="slds-button slds-button_icon slds-button_icon-inverse" title="Close" onclick="{!c.onClick}">
                                            <lightning:icon iconName="utility:close" variant="inverse" size="x-small" alternativeText="{!$Label.c.Close_Timesheets}" title="close" />
                                    <span class="slds-assistive-text">{!$Label.c.Close_Timesheets}</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </aura:if>
                <div class="slds-page-header">
                    <div class="slds-grid">
                        <div class="slds-col slds-has-flexi-truncate">
                            <div class="slds-media slds-no-space slds-grow">
                                <div class="slds-media__figure">
                                            <lightning:icon iconName="standard:work_plan" variant="inverse" size="x-medium" alternativeText="{!$Label.c.work_plan}" title="work_plan" />
                                </div>
                                <div class="slds-media__body">
                                    <p class="slds-text-title--caps slds-line-height--reset mb-0">{!$Label.c.Bank_Reconcilation_BANK}</p>
                                    <h1 class="slds-page-header__title slds-m-right--small slds-align-middle" title="">{!$Label.c.Bank_Reconcilation_Reconciliation}</h1>
                                    
                                </div>
                            </div>
                            
                        </div>
                        
                    </div>
                </div>
                <!-- </aura:if>-->
                <!-- Start of Edit Layout -->
                <div class="erp_Mark7 BankReconciliation-newClass4"> 
                    <div class="card shadow-sm BankReconciliation-newClass5">
                        
                        <div class="card-body">
                            
                            <div class="row padding-t-5">
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small"> 
                                    <lightning:input type="text"  value="{!v.BankRecon_obj.Name}" label="{!$Label.c.Bank_Reconciliation_Name}" aura:id="poName" oncommit="{!c.validateField}" placeholder="{!$Label.c.Bank_Reconciliation_Name}"/> <!-- required="true"  -->
                                </div> 
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label  class="slds-form-element__label" for="input-unique-id">Organisation</label>
                                        <c:CustomInputLookUp objectAPIName="Account" selectedRecordId="{!v.BankRecon_obj.ERP7__Organisation__c}" 
                                                            IconName="standard:account" placeholder="{!$Label.c.Acc_Recev_Search_Organisation}" qry="AND ERP7__Account_Type__C = 'Organisation'"/> <!-- NameValue="{!v.BankRecon_obj.ERP7__Organisation__r.Name}" -->
                                    </div>
                                </div> 
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small">
                                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                        <label  class="slds-form-element__label" for="input-unique-id">{!$Label.c.Bank_Reconcilation_Bank_Account}</label>
                                        <c:CustomInputLookUp objectAPIName="ERP7__Bank_details__c" selectedRecordId="{!v.BankRecon_obj.ERP7__Bank_Account__c}" 
                                                            IconName="standard:account" placeholder="{!$Label.c.Bank_Reconcilation_Search_Bank_Account}" qry="AND ERP7__Active__c = true"/><!-- NameValue="{!v.BankRecon_obj.ERP7__Bank_Account__r.Name}" -->
                                    </div>
                                </div> 
                                <!--div class="col-md-3  col-xs-6  slds-p-top-xx-small">
                                    Organisation<br/>
                                </div-->
                                <!--div class="col-md-3  col-xs-6  slds-p-top-xx-small">
                                    Bank Account<br/>
                                 </div-->
                                <div class="col-md-3  col-xs-6 slds-p-top--xx-small slds-hide">
                                    <lightning:input type="date" aura:id="StartDate" label="{!$Label.c.AddSubscription_Start_Date}" value="{!v.BankRecon_obj.ERP7__Start_Date__c}" disabled="true"/>
                                </div>
                                <div class="col-md-3  col-xs-6 slds-p-top--xx-small slds-hide">
                                    <lightning:input type="date" aura:id="EndDate" label="{!$Label.c.CreateClubcard_End_Date}" value="{!v.BankRecon_obj.ERP7__End_Date__c}" disabled="true"/>
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide">
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Beginning_Balance__c}" label="{!$Label.c.Bank_Rdconcilation_Beginning_Balance}" aura:id="BRBeginningBalance" disabled="true" /> <!-- required="true"  -->
                                </div>
                                
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide"> <!--Purchase Order Number <span >*</span> -->
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Ending_Balance__c}" label="{!$Label.c.Bank_Reconcilation_Ending_Balance}" aura:id="BREndingBalance" disabled="true" /> <!-- required="true"  -->
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide"> 
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Uncleared_Amount__c}" label="{!$Label.c.Bank_Reconcilation_UnCleared_Amount}" disabled="true"/>
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide"> 
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Calculated_Ending_Balance__c}" label="{!$Label.c.Bank_Reconcilation_Calculated_Ending_Balance}" disabled="true"/> 
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide">
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Cleared_Deposit__c}" label="{!$Label.c.Bank_Reconcilation_Cleared_Deposits}" disabled="true" />
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide"> 
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Cleared_Disbursement__c}" label="{!$Label.c.Bank_Reconcilation_Cleared_Disbursement}" disabled="true"/>
                                </div>
                                <div class="col-md-3 col-xs-6 slds-p-top--xx-small slds-hide"> 
                                    <lightning:input type="text" value="{!v.BankRecon_obj.ERP7__Status__c}" label="{!$Label.c.SalesOrderToPurchaseOrder_SOLI_Status}" disabled="true" /> 
                                </div>
                            </div>
                            <div class="slds-grid slds-wrap slds-p-top_small">
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!$Label.c.AddSubscription_Start_Date}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                       {!v.BankRecon_obj.ERP7__Start_Date__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:event" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!$Label.c.CreateClubcard_End_Date}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                       {!v.BankRecon_obj.ERP7__End_Date__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:event" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1 min-height57">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!$Label.c.Bank_Rdconcilation_Beginning_Balance}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!v.BankRecon_obj.ERP7__Beginning_Balance__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:partner_marketing_budget" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head"> {!$Label.c.Bank_Reconcilation_Ending_Balance}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                       {!v.BankRecon_obj.ERP7__Ending_Balance__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:partner_fund_claim" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!$Label.c.Bank_Reconcilation_UnCleared_Amount}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!v.BankRecon_obj.ERP7__Uncleared_Amount__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:budget_category_value" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!$Label.c.Bank_Reconcilation_Cleared_Deposits}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!v.BankRecon_obj.ERP7__Cleared_Deposit__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:budget" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head"> {!$Label.c.Bank_Reconcilation_Calculated_Ending_Balance}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!v.BankRecon_obj.ERP7__Calculated_Ending_Balance__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:budget_period" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head"> {!$Label.c.Bank_Reconcilation_Cleared_Disbursement}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!v.BankRecon_obj.ERP7__Cleared_Disbursement__c}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:buyer_group_qualifier" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                                <div class="slds-col slds-size_1-of-1 slds-medium-size_3-of-12 slds-large-size_3-of-12 slds-p-right_small">
                                    <div class="card l-bg-cvd mb-2 mt-0 min-height57">
                                        <div class="card-body px-3 py-1">
                                            <div class="d-flex justify-content-between align-items-start" >
                                                <div class="color-card" >
                                                    <p class="mb-0 color-card-head">{!v.BankRecon_obj.ERP7__Status__c}</p>
                                                    <h6 class="text-left mb-0 pt-1">
                                                        {!$Label.c.SalesOrderToPurchaseOrder_SOLI_Status}
                                                    </h6>
                                                </div>
                                                <lightning:icon iconName="standard:work_capacity_usage" size="small" class="mt-2"></lightning:icon>
                                            </div>
                                            
                                        </div>
                                    </div>  
                                </div>
                            </div>
                            <div class="slds-m-bottom--large BankReconciliation-newClass6"></div> 
                            <aura:if isTrue="{!!v.AutoReconcile}">
                            <div class="slds-docked-form-footer">
                                <button class="slds-button slds-button--brand" onclick="{!c.saveEditBankRecon_obj}">{!$Label.c.ContractConsole_Save}</button>
                                <button class="slds-button slds-button_neutral" onclick="{!c.navHome}">{!$Label.c.Cancel_UserAvailabilities}</button>
                                
                                <button class="slds-button slds-button--brand" label="{!$Label.c.Download_Bank_Statement_template}"><a href="{!'/servlet/servlet.FileDownload?file='+v.DocumentId.Id}" target="_blank" class="color-white">Download Bank Statement template </a></button>
                            </div>
                            </aura:if>
                        </div>  
                        <aura:if isTrue="{!v.AutoReconcile}">
                            
                                
                                <div class="card-body p-2">
                                    <h5 class="mb-2"><strong>Auto Reconcile</strong></h5>
                                    <table class="table">         
                                        <thead>
                                            <tr class="slds-line-height_reset">
                                                <th class="" scope="col">
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Transaction Summary">Transaction Summary</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Transaction Summary">Statement Amount</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Transaction Summary">Statement Type</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Transaction Date">Transaction Date </div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Salesforce Transaction Reference">Salesforce Transaction Reference</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="">Deposit</div>
                                                </th>
                                                <th class="" scope="col">
                                                    <div class="slds-truncate2" title="Approver">Disbursement</div>
                                                </th>
                                            </tr> 
                                        </thead> 
                                        <tbody>
                                            <aura:iteration var="bt" indexVar="STCounter" items="{!v.banktranslist}">
                                                <tr class="slds-hint-parent">
                                                    <td name="{!STCounter}">
                                                        <lightning:button class="slds-button slds-button_neutral neutralC" name="{!STCounter}" onclick="{!c.delete_Item}">
                                                            <a title="Remove Item">
                                                                <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="mbr-class12" data-aura-rendered-by="19:1393;a"/>
                                                            </a>
                                                        </lightning:button>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Start Date">
                                                            {!bt.ERP7__Transaction_Summary__c}
                                                        </div>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Beginning Balance">
                                                            <lightning:formattedNumber value="{!bt.ERP7__Statement_Amount__c}" />
                                                        </div>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Beginning Balance">
                                                            {!bt.ERP7__Statement_Type__c}
                                                        </div>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Start Date">
                                                            <lightning:formattedDateTime value="{!bt.ERP7__Transaction_Date__c}" year="numeric" month="numeric" day="numeric" />
                                                        </div>
                                                    </td>
                                                    <td data-label="">
                                                        <a href="{'/'+bt.ERP7__Transaction__c}" target="__blank">{!bt.ERP7__Internal_Reference__c}</a>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Beginning Balance">
                                                            <lightning:formattedNumber value="{!bt.ERP7__Debit__c}" />
                                                        </div>
                                                    </td>
                                                    <td data-label="">
                                                        <div class="slds-truncate2" title="Ending Balance">
                                                            <lightning:formattedNumber value="{!bt.ERP7__Disbursement__c}" />
                                                        </div>
                                                    </td>
                                                </tr>                        
                                            </aura:iteration>
                                        </tbody>
                                    </table>
                                </div>
                            
                            <div class="slds-docked-form-footer">
                                <lightning:button class="slds-button slds-button_neutral" onclick="{!c.closeAuto}" label="Cancel Auto Reconcile"></lightning:button>
                               
                                <lightning:button variant="brand" iconName="utility:change_record_type" label="Reconcile" onclick="{!c.saveAutoReconcile}"></lightning:button>
                                
                            </div>
                        </aura:if>
                        <aura:if isTrue="{!!v.AutoReconcile}">
                        <aura:if isTrue="{!(v.BankRecon_obj.ERP7__Status__c!=v.Status)}">             
                            <div class="slds-tabs--default BankReconciliation-newClass4">
                                <ul class="slds-tabs--default__nav" role="tablist">
                                    <li aura:id="cusId" class="{!(v.showTabs=='cus')?'slds-tabs--default__item slds-active BankReconciliation-newClass8':'slds-tabs--default__item BankReconciliation-newClass8'}" title="Bank Statement" role="presentation">
                                        <a class="slds-tabs--default__link" onclick="{!c.getTab}" data-record="cus" tabindex="-1" aria-selected="false" aria-controls="tab-default-2" id="tab-default-2__item">
                                            {!$Label.c.Bank_Statement}
                                        </a>
                                    </li>
                                    
                                    
                                    
                                    <li aura:id="invId" class="{!(v.showTabs=='inv')?'slds-tabs--default__item slds-active BankReconciliation-newClass8':'slds-tabs--default__item BankReconciliation-newClass8'}" title="Reconcile" role="presentation">
