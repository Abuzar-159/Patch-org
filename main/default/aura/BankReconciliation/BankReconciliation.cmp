                                                                    <aura:if isTrue="{!v.display}">
                                                                        <div class="slds-p-top_small slds-p-bottom_small" onclick="{!c.processReconcile}">
                                                                            <lightning:button variant="brand" iconName="utility:change_record_type" label="Reconcile"></lightning:button>
                                                                        </div>
                                                                    </aura:if>
                                                                </div>
                                                                <div class="slds-col  slds-p-right_small slds-p-top_medium text-right ">
                                                                    <h5 class="slds-m-bottom_xxx-small"><strong>Total</strong>={!v.Total}</h5>   
                                                                </div>
                                                                
                                                            </div>
                                                        <table id="trastbl" class="slds-table slds-table_bordered">
                                                            
                                                            <tr class="BankReconciliation-newClass22">
                                                                <td align="center" class="BankReconciliation-newClass23">
                                                                    <lightning:input type="checkbox" variant="label-hidden" aura:id="select" value="" /><!-- onclick="{!c.getallinvoiceLI}"/> -->
                                                                </td>
                                                                <td align="center" class="BankReconciliation-newClass23">
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Transaction_Date__c" title="{!$Label.c.Acc_Pay_Payments}" class="AccountsPayable-newClass32">
                                                                    Date<lightning:icon iconName="utility:sort" size="x-small" alternativeText="sort!" title="{!$Label.c.Sort_Outbound_logistics}" />                                   
                                                            		</span> 
                                                                </td>
                                                                <td align="center" class="BankReconciliation-newClass23">
                                                                    Customer
                                                                </td>
                                                                <td align="center" class="BankReconciliation-newClass23">
                                                                    {!$Label.c.Name_Payment}
                                                                </td>
                                                                <td align="center" class="BankReconciliation-newClass23">
                                                                    <span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Amount__c" title="{!$Label.c.Acc_Pay_Payments}" class="AccountsPayable-newClass32">
                                                                    {!$Label.c.PaySlip_Amount}<lightning:icon iconName="utility:sort" size="x-small" alternativeText="sort!" title="{!$Label.c.Sort_Outbound_logistics}" />                                   
                                                            		</span> 
                                                                </td>
                                                                <td width="120px" align="center" class="BankReconciliation-newClass23">
                                                                    `<span onclick="{!c.getSortedRecords}" data-service="{!v.Order}" id="ERP7__Finance_Category_Type__c" title="{!$Label.c.Acc_Pay_Payments}" class="AccountsPayable-newClass32">
                                                                    {!$Label.c.Type_ManageLeave}<lightning:icon iconName="utility:sort" size="x-small" alternativeText="sort!" title="{!$Label.c.Sort_Outbound_logistics}" />                                   
                                                            		</span> 
                                                                </td>
                                                            </tr>
                                                            <tr height="7">
                                                                <td height="20">&nbsp;</td>
                                                            </tr>
                                                            <aura:if isTrue="{!and(v.TransactionWrapperList==null,v.BankStatement!=null)}">
                                                                <p class="BankReconciliation-newClass24">{!$Label.c.No_Matches_Found}</p>
                                                                <aura:set attribute="else">
                                                                    <aura:iteration items="{!v.TransactionWrapperList}" var="trans" indexVar="Index">
                                                                        <tr class="{!if(trans.Id != v.selectedTransaction.Id,'BankReconciliation-newClass18','BankReconciliation-newClass17')}">
                                                                            <!-- id="trans_row{!trans_counter}" -->
                                                                            <aura:if isTrue="{!v.TransactionWrapperList!=''}">
                                                                                <td class="innercolclass">
                                                                                    
                                                                                    <lightning:input type="checkbox" variant="label-hidden" aura:id="boxPack" value="{#trans.Id}"  name="{!Index}" onchange="{!c.selectedTransaction}"  /><!-- click="{!c.getinvoiceLI}" -->
                                                                                </td>
                                                                            </aura:if>
                                                                            <td class="innercolclass">
                                                                                <lightning:formattedDateTime value="{!trans.ERP7__Transaction_Date__c}" year="numeric" month="numeric" day="numeric" />
                                                                            </td>
                                                                            <td class="innercolclass">
                                                                                {!trans.ERP7__Payment__r.ERP7__Accounts__r.Name}
                                                                            </td>
                                                                            <td class="innercolclass">
                                                                                <aura:if isTrue="{!trans.ERP7__is_Adjustment__c}">
                                                                                    <a href="{!'/'+trans.Id}" target="__blank">{!trans.Name}</a>|
                                                                                    Adjustment Transaction
                                                                                    <aura:set attribute="else">
                                                                                        <a href="{!'/'+trans.Id}" target="__blank">{!trans.Name}</a>|
                                                                                        <lightning:formattedText value="{!trans.ERP7__Payment__r.Name}" />|
                                                                                        <lightning:formattedText value="{!trans.ERP7__Payment__r.ERP7__Invoice__r.Name}" />|
                                                                                        <lightning:formattedText value="{!trans.ERP7__Expense_Line_Item__r.Name}" />
                                                                                    </aura:set>
                                                                                </aura:if><br/>
                                                                            </td>
                                                                            <td class="innercolclass">
                                                                               <lightning:formattedNumber style="currency" value="{!trans.ERP7__Amount__c}" maximumFractionDigits="2"/>
                                                                            </td>
                                                                            <td class="innercolclass" width="120px">
                                                                                <lightning:formattedText value="{!trans.ERP7__Finance_Category_Type__c}" />
                                                                            </td>
                                                                            <br/>
                                                                        </tr>
                                                                        <tr>
                                                                        </tr>
                                                                    </aura:iteration>
                                                                </aura:set>
                                                            </aura:if>
                                                            <tr >
                                                                <td height="50" colspan="6">
                                                                    <div class="BankReconciliation-newClass26">
                                                                        <a onclick="{!c.ClearList}" class="BankReconciliation-newClass27">Clear Search Results</a><!-- href="{!c.ClearList}" -->
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                            
                                                        </table>
                                                        </div>
                                                        
                                                    </div>
                                                    
                                                </div>
                                                <div class="{!v.showSubTabs=='pay2'?'slds-show':'slds-hide'}">
                                                    <div id="CreatePnl">
                                                        <table border="0" width="100%" cellspacing="0" cellpadding="0">
                                                            
                                                            <tr>
                                                                <td>&nbsp;</td>
                                                            </tr>
                                                        </table>
                                                        <table id="ctTable" border="0" width="100%" height="50%" align="center">
                                                            <tr>
                                                                <td align="right" class="BankReconciliation-newClass28">{!$Label.c.Type_ManageLeave}</td>
                                                                <td class="BankReconciliation-newClass29">
                                                                    <lightning:select label="Status"  aura:id="stStatus2" value="{!v.newTransaction.ERP7__Transaction_Type__c}" >
                                                                        <aura:iteration items="{!v.stStatus2Options}" var="option">
                                                                            <option text="{!option.label}" value="{!option.value}" selected="{!equals(v.newTransaction.ERP7__Transaction_Type__c, option.value)}"/>
                                                                        </aura:iteration>
                                                                    </lightning:select>
                                                                </td>
                                                            </tr>
                                                            <tr><td height="10"></td></tr>
                                                            <tr>
                                                                <td align="left" class="BankReconciliation-newClass28">{!$Label.c.Category} </td>
                                                                <td class="BankReconciliation-newClass30">
                                                                    
                                                                    <lightning:select name="select1" value="{!v.newTransaction.ERP7__Finance_Category_Type__c}" label="Type" required="true">
                                                                        
                                                                        <option value="{!v.newTransaction.ERP7__Finance_Category_Type__c}">{!$Label.c.Acc_Recev_Credit}</option>
                                                                        <option value="{!v.newTransaction.ERP7__Finance_Category_Type__c}">{!$Label.c.Acc_Recev_Debit}</option>
                                                                        
                                                                    </lightning:select>
                                                                    
                                                                </td>
                                                            </tr>
                                                            <tr><td height="20"></td></tr>
                                                            <tr>
                                                                <td align="right" class="BankReconciliation-newClass28">{!$Label.c.PaySlip_Amount} </td>
                                                                <td class="BankReconciliation-newClass29">
                                                                    <lightning:input type="text" value="{!v.newTransaction.ERP7__Amount__c}"/>
                                                                    <lightning:formattedText>
                                                                        <div class="BankReconciliation-newClass31"><strong>{!$Label.c.error}:</strong>&nbsp; {!$Label.c.Enter_Select_Bank_Statment_Amount}</div>
                                                                    </lightning:formattedText>
                                                                </td>
                                                            </tr>
                                                            <tr><td height="10"></td></tr>
                                                            <tr class="BankReconciliation-newClass4">
                                                                <td colspan="2" class="BankReconciliation-newClass34">
                                                                    <div>
                                                                        <span class="BankReconciliation-newClass32" onclick="{!c.CreateTransaction}">
                                                                            <i class="fa fa-retweet BankReconciliation-newClass33" aria-hidden="true"></i>
                                                                        </span>
                                                                    </div>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>
                                                </div>
                                                
                                                <div class="{!v.showSubTabs=='sel2'?'slds-show':'slds-hide'}">
                                                    <aura:if isTrue="{!v.selectedTransaction.length>0}">
                                                        <table class="slds-table slds-table_bordered">
                                                            <thead>
                                                                <tr>
                                                                    <th>Name</th>
                                                                    <th>Transaction Date</th>
                                                                    <th>Transaction Amount</th>
                                                                    <th>Transaction Category</th>
                                                                    <th>Is Adjustment?</th>
                                                                 </tr>
                                                            </thead>
                                                            <tbody>
                                                                <aura:iteration items="{!v.selectedTransaction}" var="trans" indexVar="Index">
                                                                    <tr>
                                                                        <td>{!trans.Name}</td>
                                                                        <td><lightning:formattedDateTime value="{!trans.ERP7__Transaction_Date__c}" year="numeric" month="numeric" day="numeric" /></td>
                                                                        <td><lightning:formattedNumber style="currency" value="{!trans.ERP7__Amount__c}" maximumFractionDigits="2"/></td>
                                                                        <td>{!trans.ERP7__Finance_Category_Type__c}</td>
                                                                        <td>
                                                                        <aura:if isTrue="{!trans.ERP7__is_Adjustment__c}">
                                                                        yes
                                                                        <aura:set attribute="else">
                                                                        No
                                                                        </aura:set>
                                                                        </aura:if>
                                                                        </td>
                                                                    </tr>
                                                                </aura:iteration>
                                                            </tbody>
                                                        </table>
                                                        <aura:set attribute="else">
                                                            <div class="slds-notify_container slds-is-relative createinvoice-class8" aura:id="criteriaMsgId">
                                                                <div class="slds-notify slds-notify_toast slds-theme_warning createinvoice-class9" role="alert">
                                                                    <span class="slds-assistive-text">{!$Label.c.warning}</span>
                                                                    <lightning:icon iconName="utility:warning" size="small" alternativeText="{!$Label.c.warning}"/>
                                                                    <div class="slds-notify__content createinvoice-class10">
                                                                        <h2 class="slds-text-heading_small createinvoice-class11">
                                                                            No Selected Transaction
                                                                        </h2>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    
                                </div>
                            </div></div></div></aura:if>
                <aura:if isTrue="{!(v.BankRecon_obj.ERP7__Status__c!=v.Status)}">
                    <div class="{!v.showTabs=='pay'?'slds-show':'slds-hide'}">
                        <div class="container-fluid">
                            <div id="ReConciletable">
                                
                                <table class="slds-table slds-table--bordered" width="100%">
                                    <tr>
                                        <th>Action</th>
                                        <th>{!$Label.c.Bank_Statement}</th>
                                        <th>
                                            <lightning:formattedText value="Associated Transaction's" />
                                        </th>
                                        <th>{!$Label.c.Spent}</th>
                                        <th>{!$Label.c.Received}</th>
                                    </tr>
                                    <aura:iteration items="{!v.undoReconcile_Wrapperlist}" var="unlist" indexVar="Index">
                                        <tr>
                                            <td>
                                                
                                                <lightning:button aura:id="assignButton" class="neutralC" name="{!Index}" onclick="{!c.undoReconcile}" >
                                                    <a title="Remove" >
                                                        <img src="/resource/ERP7__SCM/SCM/Images/slds_delete.png" class="BankReconciliation-newClass35"/>
                                                    </a>
                                                </lightning:button>
                                                
                                            </td>
                                            <td>
                                                <lightning:formattedText value="{!unlist.bTrans.ERP7__Bank_Statement__r.ERP7__Transaction_Summary__c}"/><!--{!unlist.bTrans.Bank_Statement__r.Transaction_Summary__c}-->
                                            </td>
                                            
                                            <td>
                                                <aura:iteration items="{!unlist.tTranslist}" var="trans">
                                                    <a href="{!'/'+trans.Id}" target="__blank"><lightning:formattedText value="{!trans.Name}"/></a>| <!--{!relatedtlist.Name}-->
                                                  <lightning:formattedDateTime value="{!trans.ERP7__Transaction_Date__c}" year="numeric" month="numeric" day="numeric" />|
                                                    {!trans.ERP7__Amount__c}<br/>
                                                </aura:iteration>
                                                
                                            </td>
                                            <td>
                                                <lightning:formattedNumber style="currency" value="{!unlist.bTrans.ERP7__Bank_Statement__r.ERP7__Withdrawals__c}" maximumFractionDigits="2"/>
                                            </td>
                                            <td>
                                                <lightning:formattedNumber style="currency" value="{!unlist.bTrans.ERP7__Bank_Statement__r.ERP7__Deposits__c}" maximumFractionDigits="2"/>
                                            </td>
                                        </tr>
                                    </aura:iteration>
                                </table>
                                
                            </div></div></div></aura:if>
                <aura:if isTrue="{!(v.BankRecon_obj.ERP7__Status__c==v.Status)}"><div class="slds-notify_container slds-is-relative BankReconciliation-newClass13" aura:id="criteriaMsgId">
                    <div class="slds-notify slds-notify_toast slds-theme_success BankReconciliation-newClass14" role="alert">
                        <span class="slds-assistive-text">{!$Label.c.Success1}</span>
                        <lightning:icon iconName="utility:success" size="small" alternativeText="{!$Label.c.Success1}"/>
                        <div class="slds-notify__content BankReconciliation-newClass15">
                            <h2 class="slds-text-heading_small BankReconciliation-newClass16" >
                                {!$Label.c.Reconciliation_Completed}
                            </h2>
                        </div>
                    </div>
                    </div></aura:if>
            </aura:if>
            </div>
            
            
            
        </div>
    </div>  
    <aura:if isTrue="{!v.showMmainSpin}">
        <span class="BankReconciliation-newClass36">
            <lightning:spinner variant="brand" size="large" alternativeText="{!$Label.c.Please_wait_while_loading_UserAvailabilities}" aura:id="mainSpin" class="mainSpinClass"/>
        </span>
    </aura:if> 
    
    
</aura:component>