<apex:page controller="StockReceiving" sidebar="false" cache="false" id="mainPg" docType="html-5.0" showHeader="true">

    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0121, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />

        <style>
        
        .epr_Mark7 .nav > li > a:hover, .epr_Mark7 .nav > li > a:focus {
        background:transparent;
        }
         .dateFormat {
                padding: 0 2px;
                display: none;
            }
            .epr_Mark7 .navbar-default .navbar-nav > .active > a,
            .epr_Mark7 .navbar-default .navbar-nav > .active > a:hover,
            .epr_Mark7 .navbar-default .navbar-nav > .active > a:focus {
                color: #555;
                background-color: #ffffff;
            }            
            .epr_Mark7 .active {
                background: #3A6690;
            }
            input {
                padding-top: 0;
                border: 1px solid #ddd;
                border-radius : 5px;
                padding: 5px;
            }
        </style>
    </head>

    <body>
        <apex:form id="mainFrm">
            
            <apex:pageMessages />
            
            <apex:actionFunction name="goBack" action="{!back}" immediate="true"/>
                        
            <div class="slds epr_Mark7">                
                <nav class="navbar  slds-theme--shade slds-m-bottom--x-small" style="margin-bottom: 0px;">
                    <div class="container-fluid" style="padding-left:10px;">                
                        <ul class="nav navbar-nav navbar-left">
                            <li><h4 style="line-height: 28px;"><i class="fa fa-list-alt" aria-hidden="true"  style="color:#fe8f60;"></i> Purchase Requisition</h4></li>
                        </ul>
                        
                        <ul class="nav navbar-nav navbar-right"> 
                            <li><a href="#"  style="text-decoration:none; padding:5px 10px;margin-top:10px;margin-right:10px;" class="slds-button slds-button--neutral" onclick="goBack();"><i class="fa fa-chevron-left" aria-hidden="true" style="color:#fe8f60;"></i> Back</a></li>
                        </ul>                           
                    </div>
                </nav>
            </div>
            
            <div class="slds slds-container--fluid">            
                <div class="slds-theme--info slds-m-top--xxx-small  slds-p-around--xx-small">
                    <p>Requisition Details</p>
                </div>
                
                <div class="epr_Mark7" style="padding:10px;">   
                    <!-- Row 1 -->
                    <div class="row padding-t-5">
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Name</p>
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <apex:inputField value="{!newPR.Name}" required="true" styleClass="slds-input" html-placeholder="PR Name"/>
                                </div>
                            </div>
                        </div> 
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;"> Programme </p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Programme__c}" html-placeholder="Programme Name" style="width:100%;"/>
                            </div>
                        </div>                         
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Project</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Project__c}" html-placeholder="Project Name" style="width:100%;"/>
                            </div>
                        </div>                        
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Requisitioned By</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Requisitioned_By__c}" html-placeholder="Requisitioned Name" style="width:100%;"/> 
                            </div>
                        </div>
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;"> Delivery Address</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Delivery_Address__c}" html-placeholder="Delivery Address" style="width:100%;"/>
                            </div>
                        </div>
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Status</p>
                            <div class="slds-form-element">
                                <div class="slds-form-element__control">
                                    <div class="slds-select_container">
                                        <apex:inputField value="{!newPR.Status__c}" styleClass="slds-select"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- @end of Row 1 -->
                    
                    <!-- Row 2 -->
                    <div class="slds row padding-t-5">
                        <div class="col-md-2 slds-p-top--xx-small ">
                            <p class="greyhead" style="font-size:14px;">Actual Delivery Date</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Actual_Delivery_Date__c}" style="width:100%;"/>
                            </div>
                        </div>
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Expected Delivery Date</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newPR.Expected_Delivery_Date__c}" style="width:100%;"/>
                            </div>
                        </div>
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:14px;">Description</p>
                            <div class="slds-form-element__control">
                                <apex:inputTextarea value="{!newPR.Description__c}" styleClass="slds-textarea" html-placeholder="Description" style="width:100%;" rendered="{!$ObjectType.Requisition__c.fields.Description__c.Accessible}"/>
                            </div>
                        </div>
                        <div class="col-md-2 slds-p-top--xx-small"></div>
                        <div class=" col-md-4 slds-p-top--xx-small" style="padding-top: 14px; text-align:left;"></div>
                    </div>
                    <!-- @end of Row 2 -->
                </div>   
                
                <div class="" style="float:left;width:100%;">
                    <div class="slds-theme--info slds-m-top--small slds-p-around--xx-small">
                        <table border="0" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td><p style="color: #ffffff;">&nbsp;&nbsp;Requisition Line Items</p></td>
                                <td width="5%" align="center" valign="middle">
                                    <apex:actionStatus id="spinnerA">
                                        <apex:facet name="start">
                                            <apex:image url="{!URLFOR($Resource.PickPackShipResource,'/assets/images/spinners/slds_spinner_inverse.gif')}" height="30px;" width="30px;"/>
                                        </apex:facet>
                                    </apex:actionStatus> 
                                </td>
                                <td width="5%" align="center" valign="middle">
                                    <apex:commandLink action="{!addPrliWrapperRows}" rerender="prliPnl" status="spinnerA" immediate="true">
                                        <apex:param name="addCount" value="1" assignTo="{!addRow}"/> 
                                        <button style="width:113px;height:30px;margin-bottom:2px;" class="slds-button slds-button--neutral slds-button--small" >Add New <svg  style="height:13.6px;width:13.6px" class="slds-button__icon" aria-hidden="true" ><use xmlns:xlink="https://www.w3.org/1999/xlink" xlink:href="{!URLFOR($Resource.SLDS0121,'/assets/icons/utility-sprite/svg/symbols.svg#add')}"></use></svg></button>
                                     </apex:commandLink> 
                                </td>
                            </tr>
                        </table>
                    </div>
                    
                    <div class="slds-card">
                        <div class="slds-card__body">
                            <apex:outputPanel id="prliPnl">
                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                    <thead>
                                        <tr>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Action</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Name</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Product</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Quantity</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Unit</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Price</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">Description</th>
                                        </tr>
                                    </thead>
                                    
                                    <tbody>
                                        <apex:variable var="prliCounter" value="{!0}"/>                        
                                        <apex:repeat value="{!prliWrapperList}" var="wl">
                                        <tr class="slds-hint-parent">
                                            <td class="slds-size--1-of-8" data-label="Delete">
                                                <apex:commandLink action="{!delPrliWrapperRow}" status="spinnerA" rerender="prliPnl" immediate="true">
                                                    <apex:image url="{!URLFOR($Resource.SLDS0121,'/assets/icons/action/delete_60_red.png')}" height="18" width="18"/>
                                                    <apex:param name="toDelIdent" value="{!wl.ident}" assignTo="{!toDelIdent}"/> 
                                                </apex:commandLink>
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Name"> 
                                                <apex:inputField value="{!wl.prli.Name}" styleClass="slds-input" required="true"/> 
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Product">
                                                <apex:inputField value="{!wl.prli.Product__c}" required="True"/> 
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Quantity">
                                                <apex:inputField value="{!wl.prli.Quantity__c}" id="quan" styleClass="slds-input" required="true"/> 
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Unit">
                                                <apex:inputField value="{!wl.prli.Unit__c}" id="upc" required="true"/> 
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Price">
                                                <apex:inputField value="{!wl.prli.Price__c}" id="tpc" styleClass="slds-input" required="true"/> 
                                            </td>
                                            <td class="slds-size--1-of-8" data-label="Description">
                                                <apex:inputTextarea value="{!wl.prli.Description__c}" styleClass="slds-input" rows="1" cols="15" rendered="{!$ObjectType.Purchase_Requisition_Line_Items__c.fields.Description__c.Accessible}"/> 
                                            </td>
                                        </tr>
                                        <apex:variable var="prliCounter" value="{!prliCounter+1}"/>
                                        </apex:repeat>
                                    </tbody>
                                </table>
                            </apex:outputPanel>
                        </div>
                    </div>
                    
                    <div class="slds-p-top--small"></div>
                    <div class="slds-text-align--center slds-p-around--medium">  
                        <apex:commandButton value="Save" action="{!savePR}" styleClass="slds-button slds-button--brand" rendered="{!$ObjectType.Purchase_Requisition_Line_Items__c.Createable && $ObjectType.Purchase_Requisition_Line_Items__c.Updateable}"/>
                        <apex:commandLink styleClass="slds-button slds-button--neutral" value="Cancel" action="{!back}" immediate="true"/>                                                                          
                    </div>
                    
                </div>                
            </div>
                
        </apex:form>
    </body>
    
    <script>
        function setFocus() {}
    </script>
    
    </html>
</apex:page>