<apex:page controller="PurchaseOrdersPDF" sidebar="false" showHeader="false" id="PO" docType="html-5.0" readOnly="false" renderAs="{!if($CurrentPage.parameters.val == 'pdf' || $CurrentPage.parameters.pdf != null, 'pdf', null)}" action="{!getPOListDownload}">
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
        
        <head>
            <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>    
            <apex:stylesheet value="{!URLFOR($Resource.ProjectWorkbench, '/css/main-style.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.bootStrap, '/css/bootstrap-4.1.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.SLDS, '/assets/styles/salesforce-lightning-design-system-vf.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
            <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />
            <style>
                .wrapper {
                max-width: 800px;
                margin: auto;
                padding: 30px;
                border: 1px solid #eee;
                box-shadow: 0 0 10px rgba(0, 0, 0, .15);
                font-size: 14px;
                line-height: 20px;
                font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
                color: #555;
                }
                .wrapper table {
                width: 100%;
                line-height: inherit;
                text-align: left;
                }
                
                .wrapper table td {
                padding: 5px;
                vertical-align: top;
                }
                
                .wrapper table tr td:nth-child(2) {
                text-align: left;
                }
                
                .wrapper table tr.top table td {
                padding-bottom: 20px;
                }
                
                .wrapper table tr.top table td.title {
                font-size: 30px;
                line-height: 45px;
                color: #333;
                }
                
                .wrapper table tr.information table td {
                padding-bottom: 40px;
                }
                
                .wrapper table tr.heading td {
                background: #eee;
                border-bottom: 1px solid #ddd;
                font-weight: bold;
                }
                
                .wrapper table tr.details td {
                padding-bottom: 20px;
                }
                
                .wrapper table tr.item td{
                border-bottom: 1px solid #eee;
                }
                
                .wrapper table tr.item.last td {
                border-bottom: none;
                }
                
                .wrapper table tr.total td:nth-child(2) {
                border-top: 2px solid #eee;
                font-weight: bold;
                }
                
                @media only screen and (max-width: 600px) {
                .wrapper table tr.top table td {
                width: 100%;
                display: block;
                text-align: center;
                }
                
                .wrapper table tr.information table td {
                width: 100%;
                display: block;
                text-align: center;
                }
                }
                
                /** RTL **/
                .rtl {
                direction: rtl;
                font-family: Tahoma, 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
                }
                
                .rtl table {
                text-align: right;
                }
                
                .rtl table tr td:nth-child(2) {
                text-align: left;
                }
                
            </style>
        </head>
        
        <body style="background: #fffff;">
            
            <div class="wrapper" style="background:#fffff;">
                <div>
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td colspan="2">
                                <table width="100%" border="0" cellspacing="0" >
                                                                       
                                    <tr>
                                        <td class="title" style="font-family: 'Open Sans', sans-serif; font-size:28px; color:#656565;padding:5px;text-align:left;width:70%">
                                            
                                            <span>Purchase Order</span> <br/><br/>
                                            
                                            <!--apex:image url="{!imageURL}" width="200" height="67" /-->
                                            <span style=" margin-left: -32px;">
                                                <img src="{!imageURL}"/>
                                            </span>                                        
                                        
                                        </td>
                                        
                                        <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#757575; padding:5px;">
                                            <table width="100%" border="0" cellpadding="0" cellspacing="0" >
                                                <tr>  
                                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#757575;border:0px solid #000;">
                                                        <strong>Vendor Address</strong><br/>
                                                        <apex:outputText id="acc" value="{!PODownload.ERP7__Vendor_Contact__r.Name}" /><br/>
                                                        <apex:outputText id="compName" value="{!PODownload.ERP7__Vendor__r.Company__c}" /><br/>
                                                        <apex:outputText id="a1" value="{!PODownload.ERP7__Vendor_Address__r.Address_Line1__c}" />&nbsp;
                                                        <apex:outputText id="a2" value="{!PODownload.ERP7__Vendor_Address__r.Address_Line2__c}" />&nbsp;
                                                        <apex:outputText id="a3" value="{!PODownload.ERP7__Vendor_Address__r.Address_Line3__c}" />&nbsp;<br/>
                                                        <apex:outputText id="city" value="{!PODownload.ERP7__Vendor_Address__r.City__c}" />&nbsp;<br/>
                                                        <apex:outputText id="county" value="{!PODownload.ERP7__Vendor_Address__r.County__c}" />&nbsp;<br/>
                                                        <apex:outputText id="country" value="{!PODownload.ERP7__Vendor_Address__r.Country__c}" />&nbsp;<br/>
                                                        <apex:outputText id="pc" value="{!PODownload.ERP7__Vendor_Address__r.ERP7__Postal_Code__c }"/><br/>
                                                        <apex:outputText id="phone" value="{!PODownload.ERP7__Vendor_Contact__r.Phone}" />
                                                    </td>
                                                </tr>
                                               
                                            </table>
                                            
                                            
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="padding:0px;">
                               
                                <table>
                                    <tr>
                                        <td width="32%" style="font-family: Open Sans, sans-serif; font-size:14px; color:#757575; padding:0px;border:0px solid #000;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                                <tbody><tr bgcolor="#cccccc">
                                                    <td style="font: bold 14px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;border-left:2px solid #000000;border-top:2px solid #000000;border-right:2px solid #000000;border-bottom:2px solid #000000;">
                                                        Shipping Address
                                                    </td>
                                                    </tr>
                                                    <tr>
                                                        <td style="font: normal 12px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;border-left:2px solid #000000;border-top:0px solid #000000;border-right:2px solid #000000;border-bottom:2px solid #000000;">
                                                            <apex:outputText id="ShipToacc" value="{!PODownload.ERP7__Vendor_Contact__r.Name}" /><br/>
                                                            <apex:outputText id="ShipTocompName" value="{!PODownload.ERP7__Vendor__r.Company__c}" /><br/>
                                                            <apex:outputText id="ShipToa1" value="{!PODownload.ERP7__Delivery_Address__r.Address_Line1__c}" />&nbsp;
                                                            <apex:outputText id="ShipToa2" value="{!PODownload.ERP7__Delivery_Address__r.Address_Line2__c}" />&nbsp;
                                                            <apex:outputText id="ShipToa3" value="{!PODownload.ERP7__Delivery_Address__r.Address_Line3__c}" />&nbsp;<br/>
                                                            <apex:outputText id="ShipTocity" value="{!PODownload.ERP7__Delivery_Address__r.City__c}" />&nbsp;
                                                            <apex:outputText id="ShipTocounty" value="{!PODownload.ERP7__Delivery_Address__r.County__c}" />&nbsp;
                                                            <apex:outputText id="ShipTocountry" value="{!PODownload.ERP7__Delivery_Address__r.Country__c}" />&nbsp;
                                                            <apex:outputText id="ShipTopc" value="{!PODownload.ERP7__Delivery_Address__r.Postal_Code__c}" /><br/>
                                                            <apex:outputText id="ShipTophone" value="{!PODownload.ERP7__Vendor_Contact__r.Phone}" />
                                                        </td>
                                                    </tr>	
                                                </tbody>
                                            </table>
                                           
                                        </td> 
                                         <td width="30%">&nbsp;</td> 
                                        <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#757575;text-align:left;">
                                          
                                            <table border="1" cellpadding="0" cellspacing="0" width="100%">
                                                <tbody>
                                                    <tr >
                                                    <td bgcolor="#cccccc" style="font: bold 14px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;"> 
                                                        PO Date:
                                                        
                                                          
                                                        </td>
                                                        <td style="font: normal 14px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;">
                                                        
                                                        	<apex:outputText id="PODate" value="{0,date, dd MMM yyyy}">
                                                                <apex:param value="{!PODownload.Order_Date__c}" />
                                                            </apex:outputText>
                                                        </td>
                                                   
                                                    </tr> 
                                                    
                                                    <tr>
                                                        <td bgcolor="#cccccc" style="font: bold 14px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;"> 
                                                          Status:
                                                        
                                                         
                                                            
                                                        </td>
                                                        <td style="font: normal 14px 'Helvetica Neue',Helvetica,Arial,sans-serif;color:#333;text-align:left;padding: 5px;">
                                                        <apex:outputField value="{!PODownload.Status__c}" id="status" />
                                                        </td>
                                                        
                                                    </tr>
                                                    
                                                </tbody>
                                            </table>
                                            
                                            
                                           
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                    <table style="border-top:0px solid #ddd;">
                        <tr>
                        	<td height="30">
                            
                            </td>
                        </tr>
                    </table>
                    <table width="100%" border="1" cellspacing="0" cellpadding="0" >
                        
                        <tr bgcolor="#cccccc">
                            <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000;width=15%; padding:5px;text-align:left;"><strong>Purchase Line Items</strong></td>
                        </tr>
                    </table>
                    <table width="100%" border="1" cellspacing="0" cellpadding="0" tabindex="1" style="border-color:#000;border-top:0px solid #000;" >
                        <thead>
                            <tr bgcolor="#f2f2f2">
                                <th width="15%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Goods/Service</th>
                                <th width="14%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Name</th>
                                <th width="10%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Quantity</th>
                                <th width="10%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Quantity Received</th>
                                <th width="12%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Unit Price</th>
                                <th width="11%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Total Price</th>
                                <th width="11%" valign="top" style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;text-align:left">Shipping Cost</th>
                               
                            </tr>
                        </thead>
                        <tbody>
                            <apex:variable value="{!0}" var="itemCounter" />
                            <apex:repeat var="item" value="{!PoDownloadList}" id="pli">
                                <tr>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000;padding:5px;">
                                        <apex:outputText value="{!item.Name}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif;font-size:14px;color:#000;padding:5px;">
                                        <apex:outputText value="{!item.ERP7__Product__r.Name}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px;color:#000;padding:5px;">
                                        <apex:outputText value="{!item.Quantity__c}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000; padding:5px;">
                                        <apex:outputText value="{!item.Quantity_Received__c}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000; padding:5px;">
                                        <apex:outputText value="{!item.Unit_Price__c}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000; padding:5px;">
                                        <apex:outputText value="{!item.Total_Price__c}" />
                                    </td>
                                    <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#000; padding:5px;">
                                        <apex:outputField value="{!item.Shipping_Cost__c}" />
                                    </td>
                                   
                                </tr>
                                <apex:variable var="itemCounter" value="{!itemCounter + 1}" />
                            </apex:repeat>
                        </tbody>
                    </table>
                    <table cellpadding="0" cellspacing="0" style="margin-top:100px;align:center;border-top:1px solid #ddd;">		   
                        <tr>
                            
                            <td style="font-family: Tahoma, 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif; font-size:14px; color:#757575;text-align:center"><strong>Payment Terms:</strong>&nbsp;	Payment 30 days after invoice date</td>
                            <td style="font-family: 'Open Sans', sans-serif; font-size:14px; color:#757575;text-align:center">
                                <!--<apex:outputField value="{!PODownload.Payment_Terms__c}" id="payTerms" />-->
                            </td>
                        </tr>
                    </table>		
                    
                    
                </div>
            </div>
            
        </body>
        
    </html>
    
</apex:page>