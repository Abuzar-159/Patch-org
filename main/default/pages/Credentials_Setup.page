<apex:outputPanel id="ocrDetails" rendered="{!if(selectedValue == 'OCR', true, false)}">

    <!-- Top "New" button (when not editing) -->
    <div id="ocrNew" style="display:{!if(not(errorMsg),'','none')};" class="slds-m-around--x-small">
        <a onclick="editOcr('');" style="color:#005fb2;background:#fff;padding:4px 12px;border:1px solid #ddd;border-radius:4px;text-decoration:none;font-size:12px;font-weight:normal;">
            New <i class="fa fa-plus" aria-hidden="true" style="color:#005fb2;font-size:10px;"></i>
        </a>
    </div>

    <!-- Available list (reuse existingList, as with other tabs) -->
