                                oncomplete="if('{!ocrCred.Encrypted_Key__c}' == '') document.getElementById('passErrOCR').style.display = ''; else document.getElementById('passErrOCR').style.display = 'none';"/>
                            <apex:commandLink styleClass="slds-button slds-button--neutral" value="Cancel"
                                reRender="mainFrm" action="{!cancelCredential}" immediate="true"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</apex:outputPanel>
<!-- ============== /END OF OCR section ============== -->


            </div>         
        </apex:form>
