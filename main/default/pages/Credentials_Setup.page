                      <!--  <th scope="col"><span class="slds-truncate">Endpoint</span></th>  -->
                        <th scope="col"><span class="slds-truncate">Project ID</span></th>
                        <th scope="col"><span class="slds-truncate">Active</span></th>
                    </tr>
                </thead>
