<apex:page controller="CredentialsSetupController" sidebar="false" cache="false" id="mainPg" docType="html-5.0">
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
    <head>  
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" /> 
        <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}"/>    
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}"/>
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>              
        <apex:includeScript value="{!URLFOR($Resource.bootStrap,'/js/bootstrap.min.js')}"/>
     
    <style>
        .greyhead{
        	font-weight:700;
        }
        .erp_mark7 .slds-table--bordered:not(.slds-no-row-hover) tbody tr:hover > td:not(.slds-is-selected),
        .erp_mark7 .slds-table--bordered:not(.slds-no-row-hover) tbody tr:hover > th:not(.slds-is-selected) {
          box-shadow: #d8dde6 0 -0px 0 inset, #d8dde6 0 0px 0 inset; }
      
        .erp_mark7 .slds-truncate {
            max-width: 170px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        
       .epr_Mark7 .nav-tabs > li > a {
            margin-right: 70px;
            line-height: 1.42857143;
            border: 1px solid transparent;
            border-radius: 4px 4px 0 0;
            color:#60cdde;
            text-transform:uppercase;
        }
    
        .epr_Mark7 .nav>li>a:hover,
        .epr_Mark7 .nav>li>a:focus {        
            text-decoration: none;
            background-color: #fff;
            border-bottom: 2px solid #0070d2!important;
        }   
        
        .epr_Mark7 .nav-tabs > li.active > a, .epr_Mark7 .nav-tabs > li.active > a:hover, .epr_Mark7 .nav-tabs > li.active > a:focus {
            color: #7cdbff;
            cursor: default!important;
            background-color: #fff!important;
            border: 0;
            border-bottom: 3px solid #2196f3!important;
        }        
        
        .epr_Mark7 .nav-tabs > li > a:hover {
            border-color: #fff #fff #fff;    
        }
        
        input {
            padding-top: 0;
            border: 1px solid #ddd;
            border-radius : 5px;
            padding: 5px;
        } 
        
        .slds .slds-table--bordered td {
            border-top: 1px solid #f7f7f7;
        }
    </style>
        
       </head> 
    <body>
        <apex:form id="mainFrm">
            <apex:pageMessages ></apex:pageMessages>
            
            <apex:actionFunction name="passValPayment" reRender=";" immediate="true">
                <apex:param name="p1" value="" assignTo="{!Paymentcred.Password_Transkey__c}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="passValPayPal" reRender=";" immediate="true" >
                <apex:param name="p2" value="" assignTo="{!PayPalCred.Password_Transkey__c}" />
            </apex:actionFunction>
            
            <apex:actionFunction name="passValUPS" reRender=";" immediate="true">
                <apex:param name="p3" value="" assignTo="{!upscred.Password_Transkey__c}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="passValFedex" reRender=";" immediate="true">
                <apex:param name="p4" value="" assignTo="{!fedexcred.Password_Transkey__c}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="passValeComm" reRender=";" immediate="true">
                <apex:param name="p6" value="" assignTo="{!eCommcred.Password_Transkey__c}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="parentPassValFedex" reRender=";" immediate="true">
                <apex:param name="p5" value="" assignTo="{!fedexcred.Parent_Password__c}"/>
            </apex:actionFunction>       
                    
            <apex:actionFunction name="Payment" action="{!fetchAvailableCredentials}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="param1" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editPayment" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO" >
                 <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="savePayment" action="{!saveCredentials}" reRender="mainFrm" oncomplete="if('{!Paymentcred.Password_Transkey__c}' == '') document.getElementById('passErrA').style.display = ''; else document.getElementById('passErrA').style.display = 'none';" >
                 <!-- <apex:param name="credId" value="" assignTo="{!credentialId}"/> -->
            </apex:actionFunction>
            
            <apex:actionFunction name="canPayment" action="{!cancelCredential}" reRender="mainFrm" immediate="true"  >
                 <!-- <apex:param name="credId" value="false" assignTo="{!errorMsg}"/> -->
            </apex:actionFunction>
              
            <apex:actionFunction name="paypal" action="{!fetchAvailableCredentials}"  reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="param2" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editPaypal" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO" >
                 <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="savePay" action="{!saveCredentials}" reRender="mainFrm" oncomplete="if('{!PayPalCred.Password_Transkey__c}' == '') document.getElementById('passErrP').style.display = ''; else document.getElementById('passErrP').style.display = 'none';" >
                 <!-- <apex:param name="credId" value="" assignTo="{!credentialId}"/> -->
            </apex:actionFunction>
            
            <apex:actionFunction name="ups" action="{!fetchAvailableCredentials}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="param3" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editUps" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO" >
                 <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="saveUps" action="{!saveCredentials}" reRender="mainFrm" oncomplete="if('{!upsCred.Password_Transkey__c}' == '') document.getElementById('passErrU').style.display = ''; else document.getElementById('passErrU').style.display = 'none';" >
                 <!-- <apex:param name="credId" value="" assignTo="{!credentialId}"/> -->
            </apex:actionFunction>
            
            <apex:actionFunction name="fedex" action="{!fetchAvailableCredentials}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="param4" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editFedex" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO" > 
                 <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="saveFed" action="{!saveCredentials}" reRender="mainFrm" oncomplete="if('{!fedexCred.Password_Transkey__c}' == '') document.getElementById('passErrF').style.display = ''; else document.getElementById('passErrF').style.display = 'none';" >
                 <!-- <apex:param name="credId" value="" assignTo="{!credentialId}"/> -->
            </apex:actionFunction>
            
            <apex:actionFunction name="eComm" action="{!fetchAvailableCredentials}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="param4" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editeComm" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO" > 
                 <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="saveeComm" action="{!saveCredentials}" reRender="mainFrm" oncomplete="if('{!eCommCred.Password_Transkey__c}' == '') document.getElementById('passErrF').style.display = ''; else document.getElementById('passErrF').style.display = 'none';" >
            </apex:actionFunction>  
            
            <apex:actionFunction name="beforeDelete" action="{!deleteCredential}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            
           <!-- ===== OCR: action functions ===== -->
            <apex:actionFunction name="passValOCR" reRender=";" immediate="true">
                <!-- put the typed API Key into Encrypted Key -->
                <apex:param name="pOCR" value="" assignTo="{!ocrCred.ERP7__Encrypted_Key__c}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="ocr" action="{!fetchAvailableCredentials}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="paramOCR" value="" assignTo="{!selectedValue}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="editOcr" action="{!editCredential}" reRender="mainFrm" immediate="true" status="spinnerO">
                <apex:param name="credId" value="" assignTo="{!credentialId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="saveOcr" action="{!saveCredentials}" reRender="mainFrm"
                oncomplete="if('{!ocrCred.Encrypted_Key__c}' == '') document.getElementById('passErrOCR').style.display = ''; else document.getElementById('passErrOCR').style.display = 'none';">
            </apex:actionFunction>

            
            <!-- <apex:pagemessages ></apex:pagemessages> -->
            
            <div class="erp_mark7">
                         <div class="slds-page-header">
                          <div class="slds-grid">
                            <div class="slds-col slds-has-flexi-truncate">
                              <div class="slds-media slds-no-space slds-grow">
                                <div class="slds-media__figure">
                                  <span class="slds-icon slds-icon-action-back slds-p-around--xx-small" aria-hidden="true" style="padding: 15px 17px;">
                                      <i class="fa fa-keyboard-o" aria-hidden="true" style="font-size:25px; color:#fff;"></i>
                                  </span>
                                </div>
                                <div class="slds-media__body">
                                  <p class="slds-text-title--caps slds-line-height--reset">Setup</p>
                                  <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate" title="Credentials Setup">Credentials Setup</h1>
                                </div>
                              </div>
                            </div>
                          </div> 
                        </div>
                
                <div class="epr_Mark7">   
                
                   
                                                    
                    <nav class="navbar  slds-theme--default slds-m-bottom--x-small" style="margin-bottom: 0px;">
                        <div class="">
                            <ul class="nav nav-tabs  navbar-left" style="width: 100%;">
                                <li class="{!if(selectedValue == 'Payment', 'active', '')}"> <!-- onclick="paypal('paypal');" onclick="ups('ups');" onclick="fedex('fedex');" -->
                                    <a href="#" style="text-decoration:none;" onclick="Payment('Payment');"><i class="fa fa-credit-card" aria-hidden="true" style="color:#7cdbff;"></i> Payment</a>
                                </li>
                                <!--<li class="{!if(selectedValue == 'paypal', 'active', '')}">
                                    <a href="#" style="text-decoration:none;" onclick="paypal('paypal');"><i class="fa fa-credit-card" aria-hidden="true" style="color:#7cdbff;"></i> Paypal</a>
                                </li> -->
                                <li class="{!if(selectedValue == 'Shipment', 'active', '')}">
                                    <a href="#" style="text-decoration:none;" onclick="ups('Shipment');"><i class="fa fa-plane" aria-hidden="true" style="color:#7cdbff;"></i> Shipment</a>
                                </li>
                                <!--<li class="{!if(selectedValue == 'fedex', 'active', '')}">
                                    <a href="#" style="text-decoration:none;" onclick="fedex('fedex');"><i class="fa fa-plane" aria-hidden="true" style="color:#7cdbff;"></i> FedEx</a>
                                </li>-->
                                
                                <li class="{!if(selectedValue == 'eComm', 'active', '')}">
                                    <a href="#" style="text-decoration:none;" onclick="eComm('eComm');"><i class="fa fa-shopping-cart" aria-hidden="true" style="color:#7cdbff;"></i> E-Commerce</a>
                                </li>
                                
                                <li class="{!if(selectedValue == 'OCR', 'active', '')}">
                                    <a href="#" style="text-decoration:none;" onclick="ocr('OCR');">
                                        <i class="fa fa-file-text-o" aria-hidden="true" style="color:#7cdbff;"></i> OCR
                                    </a>
                                </li>
                                
                                <li>
                                    <apex:actionStatus id="spinnerO">
                                        <apex:facet name="start">
                                            <apex:image url="{!URLFOR($Resource.PickPackShipResource,'/assets/images/spinners/slds_spinner_brand.gif')}" height="40px;" width="40px;" style="margin-left:15px;padding-top:5px;"/>
                                        </apex:facet>
                                    </apex:actionStatus>
                                </li>
                            </ul>                                              
                        </div>
                    </nav>
                </div>
                
                <!-- Payment section -->
                    
                    <apex:outputPanel id="PaymenthDetails" rendered="{!if(selectedValue == 'Payment', true, false)}">
                        <div id="PaymentNew" style="display:{!if(not(errorMsg),'','none')};" class="slds-m-around--x-small">
                            <a onclick="editPayment('');" style="color:#005fb2;background: #fff;padding: 4px 12px;border: 1px solid #ddd;border-radius: 4px;text-decoration: none;font-size:12px;font-weight:normal;" >
                            New <i class="fa fa-plus" aria-hidden="true" style="color:#005fb2;font-size:10px;"></i></a>
                        </div>
                        <div id="availPaymentDetail" style="display:{!if(not(errorMsg),'','none')};">
                            <apex:outputPanel > <!-- rendered="{!if(existingList.size > 0 , true, false)}" --> 
                                <!-- <div class="slds-theme--info slds-m-top--xxx-small  slds-p-around--xx-small">
                                    <p>Available Authorize.Net Credentials</p>
                                </div> -->
                                
                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal">
                                    <thead>
                                        <tr class="slds-text-heading--label">
                                            <th scope="col" class="slds-is-sortable">
                                                <span class="slds-truncate">Action</span>
                                            </th>
                                            <th scope="col" class="slds-is-sortable">
                                                <span class="slds-truncate">Name</span>
                                            </th>
                                            <th scope="col" class="slds-is-sortable">
                                                <span class="slds-truncate">Username</span>
                                            </th>
                                            <th scope="col" class="slds-is-sortable">
                                                <span class="slds-truncate">URL</span>
                                            </th>
                                            <th scope="col" class="slds-is-sortable">
                                                <!--<span class="slds-truncate">Channel Id</span>-->
                                                <span class="slds-truncate">Organization Id</span>
                                            </th>
                                            <th scope="col" class="slds-is-sortable">
                                                <span class="slds-truncate">Active</span>
                                            </th>
                                        </tr>
                                    </thead>
                                    
                                    <tbody>
                                        <apex:repeat value="{!existingList}" var="crd">
                                            <tr class="slds-hint-parent">
                                                <td data-label="Action">
                                                    <table  class="table table--bordered" style="border: 0px solid #d8dde6 !important;">
                                                        <tr>
                                                            <td data-label="Action" style="padding:0px !important; border-top: 0px solid #d8dde6; cursor: pointer;">
                                                                   
                                                                <apex:commandLink onclick="showPayment('{!crd.Id}');" immediate="true" reRender=";" >
                                                                    <apex:image url="{!URLFOR($Resource.SLDS0121,'assets/icons/action/edit_60_green.png')}" width="18" height="18" title="Edit Credential"/>
                                                                    <apex:param name="credId" value="{!crd.Id}" assignTo="{!credentialId}"/>
                                                                </apex:commandLink>
                                                                
                                                                | &nbsp; 
                                                            </td>
                                                            <td align="left" width="80%" style="padding:0px !important; border-top: 0px solid #d8dde6; cursor:pointer;">
                                                                <apex:image url="{!URLFOR($Resource.SLDS0121,'assets/icons/action/delete_60_red.png')}" width="18" height="18" title="Remove Credentials" onclick="var r = confirm('Are you sure you want to delete?'); if (r == true) { beforeDelete('{!crd.Id}'); }"/>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>                                        
                                                <td class="greyheadlabel" data-label="Credential Name">
                                                   <div class="slds-truncate"> <apex:outputText value="{!crd.Name}" rendered="{!$ObjectType.Credentials__c.fields.Name.Accessible}" title="{!crd.Id}"/></div>
                                                </td>
                                                <td class="greyheadlabel" data-label="Username">
                                                    <div class="slds-truncate"><apex:outputText value="{!crd.Username_Login__c}" rendered="{!$ObjectType.Credentials__c.fields.Username_Login__c.Accessible}"/></div>
                                                </td>
                                                <td class="greyheadlabel" data-label="URL">
                                                    <div class="slds-truncate"><apex:outputText value="{!crd.URL__c}" rendered="{!$ObjectType.Credentials__c.fields.URL__c.Accessible}"/></div>
                                                </td>
                                                <td class="greyheadlabel" data-label="Channel Id">
                                                    <div class="slds-truncate"><apex:outputText value="{!crd.Channel_Id__c}" rendered="{!$ObjectType.Credentials__c.fields.Channel_Id__c.Accessible}"/></div>
                                                </td>
                                                <td class="greyheadlabel" data-label="Active">
                                                    <label class="slds-checkbox">
                                                        <apex:outputField value="{!crd.Active__c}" rendered="{!$ObjectType.Credentials__c.fields.Active__c.Accessible}"/>
                                                     </label>
                                                </td>
                                            </tr>
                                        </apex:repeat>
                                    </tbody>
                                </table>
                                <div>&nbsp;</div>
                            </apex:outputPanel>
                        </div>
                        
                        <div id="PaymentDetail" style="display:{!if(errorMsg,'','none')};">
                            <div class="epr_Mark7" style="padding:10px;">
                                <!-- Row 1 -->
                                <div class="row padding-t-5">
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <p class="greyhead" style="font-size:14px;">Name</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField id="auRecName" value="{!Paymentcred.Name}"  required="true" styleClass="slds-input" html-placeholder="Credentials Name" onchange="if(this.value.includes('Paypal') || this.value.includes('paypal')) document.getElementById('sigfield').style.display=''; else document.getElementById('sigfield').style.display='none';">
                                                </apex:inputField>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small"> 
                                        <p class="greyhead" style="font-size:14px;">Username / Login</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Username_Login__c}" required="true" styleClass="slds-input" html-placeholder="Username"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <p class="greyhead" style="font-size:14px;">Password / Transkey</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                            <apex:outputPanel rendered="{!$ObjectType.Credentials__c.fields.Password_Transkey__c.Accessible}"> <!-- type="Password" -->
                                                <input type="Password" value="{!Paymentcred.Password_Transkey__c}" onblur="passValPayment(this.value);" required="true" style="height : 36px;width:100%;" styleClass="slds-input" placeholder="Password"/>
                                            </apex:outputPanel>
                                             <div id='passErrA' class="errorMsg" style="display:none;"><strong>Error:</strong> You must enter a value</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--xx-small" id="sigfield" style="display:{!if(OR(Paymentcred.Name == 'Paypal',Paymentcred.Name == 'Plaid') ,'','none')}">
                                        <p class="greyhead" style="font-size:14px;">Signature</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:outputPanel rendered="{!$ObjectType.Credentials__c.fields.Signature__c.Accessible}">
                                                
                                                    <apex:inputField value="{!Paymentcred.Signature__c}" required="{!IF((CONTAINS(Paymentcred.Name,'Paypal') || CONTAINS(Paymentcred.Name,'paypal')), true, false)}" styleClass="slds-input" html-placeholder="Signature"/>
                                                
                                                    <!-- <apex:inputField value="{!Paymentcred.Signature__c}" required="true" styleClass="slds-input" html-placeholder="Signature"/> -->
                                                </apex:outputPanel>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                               <div class="row padding-t-5">
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">URL</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.URL__c}" required="true" styleClass="slds-input" html-placeholder="URL"/>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Organization Id</p>
                                        <!--<p class="greyhead" style="font-size:14px;">Channel Id</p>-->
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Channel_Id__c}" styleClass="slds-input" html-placeholder="Organization Id"/>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Bank COA ID</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Bank_COA_ID__c}" styleClass="slds-input" html-placeholder="Bank COA Id"/><!--required="true" -->
                                            </div>
                                        </div>
                                    </div>
                                    
                                   <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Source Drive ID</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Source_Drive_ID__c}" styleClass="slds-input" html-placeholder="Source Drive ID"/><!--required="true" -->
                                            </div>
                                        </div>
                                    </div>                                    
                                </div>   
                                <div class="row padding-t-5">                                    
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Bill Drive ID</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Bill_Drive_ID__c}" styleClass="slds-input" html-placeholder="Bill Drive ID"/><!--required="true" -->
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Logistic Drive ID</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:inputField value="{!Paymentcred.Logistic_Drive_ID__c}" styleClass="slds-input" html-placeholder="Logistic Drive ID"/><!--required="true" -->
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-3 slds-p-top--small">
                                        <p class="greyhead" style="font-size:14px;">Purchase Order Drive ID</p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
