    <script>
        
        var errmsg = false;
        function saveRecA(){
            savePayment();
        }
        function saveRecP(){
            savePay();
        }
        function saveRecU(){
            saveUps();
        }
        function saveRecF(){
            saveFed();
        }
        function saveRecAM(){
            saveeComm();
        }
        function showPayment(val) {
            if(val) editPayment(val);
            else editPayment('');
        }     
        function showPay(val) {
            if(val) editPaypal(val);
            else editPaypal(''); 
        } 
        function showUps(val) {
            if(val) editUps(val);
            else  editUps('');  
        }    
        function showFed(val) {
            if(val) editFedex(val);
            else editFedex('');
        } 
        function showeComm(val) {
            if(val) editeComm(val);
            else editeComm('');
        }
        
        function saveRecOCR(){
            saveOcr();
        }
        function showOcr(val){
            if(val) editOcr(val);
            else editOcr('');
        }
    </script>   
      
