    <script>
        function setFocus(){}
        var startDate;
            var $j = jQuery.noConflict();
            $j(document).ready(function(){
                $j('[id$=startdate]').datepicker({onSelect:function(date){ startDate = date;refresh(); }, dateFormat: 'dd/mm/yy',minDate:new Date('{!start_date}'),maxDate:new Date('{!end_date}')});
                $j('[id$=enddate]').datepicker({ dateFormat: 'dd/mm/yy' ,maxDate:new Date('{!end_date}'),minDate:startDate}); 
                    var PLACEHOLDER = '';
                    var searchObject;
                    var queryTerm;
                    
                    
                    $j('[id$=orgName]')
                        .autocomplete({
                            minLength: 0,
                            source: function(request, response) {
                                queryTerm = request.term;
                                //alert('IN'+queryTerm);
                                Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.TrialBalance.searchOrg}', request.term, function(result, event) {
                                    if(event.type == 'exception') {
                                        alert(event.message);
                                    } else {
                                        searchObject = result;
                                        response(searchObject);
                                    }
                                },
                                {
                                    escape: true
                                });
                            },
                            focus: function(event, ui) {
                                $j('[id$=orgName]')
                                    .val(ui.item.Name);
                                //alert('out1');
                                return false;
                            },
                            select: function(event, ui) {
                                $j('[id$=orgName]')
                                    .val(ui.item.Name);
                                $j('[id$=searchOrgtId]')
                                    .val(ui.item.Id);
                                //alert('out2');
                                Evaluate();
                                return false;
                            },
                        })
                        
                        .data("ui-autocomplete")
                        ._renderItem = function(ul, item) {
                            //alert(item.Name);
                            var entry = "<a style='text-decoration:none;color:#333;'>" + item.Name;
                            //alert('out3');
                            entry = entry + "</a>";
                            entry = entry.replace(queryTerm, "<b>" + queryTerm + "</b>");
                            return $j("<li class='liclassik'></li>")
                                .data("item.autocomplete", item)
                                .append(entry)
                                .appendTo(ul);
                        };
            });
    </script>
