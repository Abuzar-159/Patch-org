                </div>
                
                <div class="" style="float:left;width:100%;">
                    <div class="slds-theme--info slds-m-top--small slds-p-around--xx-small">
                        <table border="0" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td><p style="color: #ffffff;">&nbsp;&nbsp; Order Line Items</p></td>
                                <td width="5%" align="center" valign="middle">
                                    <apex:actionStatus id="spinnerA">
                                        <apex:facet name="start">
                                            <apex:image url="{!URLFOR($Resource.PickPackShipResource,'/assets/images/spinners/slds_spinner_inverse.gif')}" height="25px;" width="25px;"/>
                                        </apex:facet>
                                    </apex:actionStatus> 
                                </td>                                
                            </tr>
                        </table>                        
                    </div>
                    
                    <div class="slds-card">
                        <div class="slds-card__body">
                            <apex:actionRegion >
                            <apex:outputPanel id="soliPnl">
                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                    <thead>
                                        <tr>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Code</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Item</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Qnty</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Return Qnty</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Rem Qnty.</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Total Price</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Return Reason</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Return Status</th>
                                            <th class="slds-text-heading--label slds-size--1-of-9" scope="col">Deduction</th>
                                        </tr>
                                    </thead>
                                    
                                    <tbody>
                                        <apex:repeat value="{!itemWrapperList}" var="item" id="tblResultss">  
                                        <tr>
                                            <td class="slds-size--1-of-9" data-label="Name"> 
                                                <apex:outputText value="{!item.code}" rendered="{!$ObjectType.Product2.Fields.SKU__c.Accessible}"/>    
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Item"> 
                                                <apex:outputText value="{!item.itm}" rendered="{!$ObjectType.Product2.Accessible}"/>    
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Quantity"> 
                                                <apex:outputText value="{!item.Quantity_s}" rendered="{!$ObjectType.Sales_Order_Line_Item__c.Fields.Quantity__c.Accessible}"/>    
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Return Quantity"> 
                                              
                                                <apex:inputText id="retQuan" value="{!item.quantity_Return}" size="5" onchange="processQuantity('{!item.orderLineItemId}','{!item.Quantity_s}',this.value);" style="display:{!if(item.isWarrantyExist,'','none')}"/> 
                                                <apex:outputText value="{!item.quantity_Return}" style="width:100px; height:20px; border-radius:4px; display:{!if(item.isWarrantyExist,'none','')}"/>   
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Current Quantity"> 
                                                <apex:outputText id="currQuan" value="{!item.current_quantity}"/>    
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Total Price"> 
                                                <apex:outputText value="{!item.totalPrice}" rendered="{!$ObjectType.Sales_Order_Line_Item__c.Fields.Total_Price__c.Accessible}"/>    
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Return Reason">  
                                                <apex:inputTextarea value="{!item.returnReason}" disabled="{!!item.isWarrantyExist}" styleClass="slds-input" rows="1" cols="20"/> 
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Return Status"> 
                                                <div class="slds-select_container">
                                                    <apex:inputField value="{!item.rmaLI.Return_Status__c}" styleClass="slds-select" style="display:{!if(item.isWarrantyExist,'','none')}"/>   
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="Total Deduction"> 
                                                <apex:outputText id="td" value="{!item.totalDeduction}"/>    
                                            </td>
                                        </tr>
                                        </apex:repeat>
                                    </tbody>
                                </table>
                            </apex:outputPanel>
                            </apex:actionRegion>
                        </div>
                    </div>
                    
                    <div class="slds-p-top--small"></div>
                    <div class="slds-text-align--center slds-p-around--medium" style="position:fixed;bottom:0;left: 0; text-align:center; width:100%; background: rgba(255, 255, 255, 0.7);">                             
                        <apex:commandButton value="Save" action="{!Save}" styleClass="slds-button slds-button--brand" rendered="{!$ObjectType.Sales_Order__c.Updateable && $ObjectType.Return_Merchandise_Authorisation__c.Updateable && $ObjectType.Loyalty_Points__c.Updateable}"/>
                        <apex:commandLink styleClass="slds-button slds-button--neutral" value="Cancel" action="{!Back2Order}" immediate="true"/>                         
                    </div>
                    
                </div>            
            </div>            
           </div> 
        </apex:form>    
    </body>
    
    <script type="text/javascript">      
        function setFocus() {}
        
        function removeItem(itemId){
            deleteItem(itemId);
        }
        function processQuantity(itemId,availQuantity,returnQuantity){
           processItemQuantitys(itemId);          
        }
      
        function setupclosepopup(){ 
             top.window.opener.lookupPick2('{!JSENCODE(FormTag)}','{!JSENCODE(TextBox)}_lkid','{!JSENCODE(TextBox)}','{!JSENCODE(contact.id)}','{!JSENCODE(contact.FirstName)} {!JSENCODE(contact.LastName)}', true);
        }           
    </script>
      
    </html>
</apex:page>