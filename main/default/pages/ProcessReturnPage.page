<apex:page standardController="Channel__c" extensions="ProcessReturn" sidebar="false" cache="false" id="page" docType="html-5.0" standardStylesheets="true">

 <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
    <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>       
     <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
    
    <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}"/>    
    <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}"/>    
    
    <style>
    .epr_Mark7 h1, .epr_Mark7 .h1, .epr_Mark7 h2, .epr_Mark7 .h2, .epr_Mark7 h3, .epr_Mark7 .h3 {
    margin-top: 10px;
    margin-bottom: 10px;
}
    .bodyDiv .outerNoSidebar {
    padding: 0px 10px 0px;
}
    .greyhead{
        font-weight:bold;
    }
    .epr_Mark7 p {
        margin: 0px 0px 2px;
    }
    .slds-form-element__control1{
        border: 1px solid lightgrey;
        height: 30px;
        border-radius: 4px;
        padding: 4px 0px 0px 5px;
        background: #f7f8f7;
    }
     .dateFormat {
            padding: 0 2px;
            display: none;
        }
        .epr_Mark7 .nav > li > a:hover, .epr_Mark7 .nav > li > a:focus{
                background:transparent;
            }
        .epr_Mark7 .navbar-default .navbar-nav > .active > a,
        .epr_Mark7 .navbar-default .navbar-nav > .active > a:hover,
        .epr_Mark7 .navbar-default .navbar-nav > .active > a:focus {
            color: #555;
            background-color: #ffffff;
        }            
        .epr_Mark7 .active {
            background: #3A6690;
        }
        input {
            padding-top: 0;
            border: 1px solid #ddd;
            border-radius : 5px;
            padding: 5px;
        }
        outputText {
            padding-top: 0;
            border: 1px solid #ddd;
            border-radius : 5px;
            padding: 5px;
        }
    </style>        
    </head>
    
    <body>
        <apex:form id="myform">
            
            <apex:pageMessages /> 
            
            <apex:actionFunction action="{!processItemQuantity}" name="processItemQuantitys" reRender="myform" status="spinnerA"> 
                <apex:param name="param1" value="" assignTo="{!Item2DeleteId}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="goBack" action="{!Back2Order}" immediate="true"/>
            
            <apex:actionFunction name="fetchSOs" reRender=";" oncomplete="testAct();"/>
            <apex:actionFunction name="testAct" action="{!fetchSalesOrder}"/>
            <div class="erp_mark7">
            <div class="epr_Mark7">
                <div class="slds-page-header">
  <div class="slds-grid">
    <div class="slds-col slds-has-flexi-truncate">
      <div class="slds-media slds-no-space slds-grow">
        <div class="slds-media__figure">
          <svg class="slds-icon slds-icon--large slds-icon-standard-user slds-p-around--x-small" aria-hidden="true" >
           <use xlink:href="{!URLFOR($Resource.SLDS213, 'assets/icons/action-sprite/svg/symbols.svg#share_file')}"></use>
          </svg>
        </div>
        <div class="slds-media__body">
          
        <h1 class="slds-page-header__title slds-truncate" title="RMA">RMA</h1>
        </div>
      </div>
    </div>
    <div class="slds-col slds-no-flex slds-grid slds-align-top">

      <div class="slds-button-group" role="group">
        <a href="#" style="text-decoration:none;" onclick="goBack();" class="slds-button slds-button--brand"><i class="fa fa-chevron-left" aria-hidden="true" ></i> Back to Order</a>
      </div>
    </div>
  </div>

</div>
            </div>
            
            <div class="slds slds-container--fluid">
                <div class="slds-theme--info slds-m-top--xxx-small  slds-p-around--xx-small">
                    <p>&nbsp;&nbsp; Order Details</p>
                </div>
                                
                <div class="epr_Mark7" style="padding:10px;">   
                    <div class="row padding-t-5">
                        <div class="col-md-3 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Order Number</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newCurrentItems.Sales_Order__c}" style="width:100%" onchange="fetchSOs();"/>
                            </div>
                        </div> 
                        <div class="col-md-3 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;">Payment Type</p>
                            <div class="slds-form-element__control">
                                <div class="slds-select_container">
                                    <!--<apex:selectList id="chooseReturnMethod" value="{!returnMethod}" size="1" styleClass="slds-select">
                                        <apex:selectOptions value="{!returnMethods}"/>                                                           
                                    </apex:selectList>-->  
                                    <apex:inputField value="{!payment.Payment_Type__c}" style="" styleClass="slds-select"/> 
                                </div>
                            </div>
                        </div> 
                        
                        <div class="col-md-3 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Return to Site</p>
                            <div class="slds-form-element__control slds-form-element__control">
                                <apex:inputField value="{!RMA.Site__c}" style="width:90%;"/>
                            </div>
                        </div> 
                       <div class="col-md-3 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Return Contact</p>
                            <div class="slds-form-element__control slds-form-element__control">
                                <apex:inputField value="{!RMA.Return_Contact__c}"  style="width:90%;"/>
                            </div>
                        </div>
                    </div> 
                
                               
                    <!-- Row 1 -->
                    <!--
                      <div class="row padding-t-5">
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Order Number</p>
                            <div class="slds-form-element__control">
                                <apex:inputField value="{!newCurrentItems.Sales_Order__c}" style="width:100%" onchange="fetchSOs();"/>
                            </div>
                        </div> 
