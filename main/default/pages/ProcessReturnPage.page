                    <div class="slds row padding-t-5 ">
                        
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Total Due</p>
                            <div class="slds-form-element__control slds-form-element__control1">
                                <apex:outputField id="tdue" value="{!currentSalesOrder.Total_Due__c}" style="background: #fff; cursor: not-allowed;"/>
                            </div>
                        </div>
                        
                        <div class="col-md-2 slds-p-top--xx-small">
                            <p class="greyhead" style="font-size:12px;"> Return Amount</p>
                            <div class="slds-form-element__control slds-form-element__control1">
                                <apex:outputField id="soa" value="{!currentSalesOrder.ReturnAmount__c}" style="background: #fff; cursor: not-allowed;"/>
