<apex:page standardController="WO__c" extensions="OperationLabel" docType="html-5.0" sidebar="false" standardStylesheets="true" showHeader="false" id="OLabel" action="{!createPDF}">
    <head>
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/jQuery/js/jquery_3.5.0.min.js')}"/>
        <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
        <apex:stylesheet value="{!URLFOR($Resource.BankReconcile, 'css/font-awesome.css')}"/>
        <style type="text/css" media="print">
        @page {
            size: 4in 6in;
            @top-center {
                content: element(header);
            }
            @bottom-left {
                content: element(footer);
            }
        }
        
        div.header {
            padding: 5px;
            position: running(header);
        }
        
        div.footer {
            display: block;
            padding: 5px;
            position: running(footer);
        }
        
        .pagenumber:before {
            content: counter(page);
        }
        
        .pagecount:before {
            content: counter(pages);
        }

        </style>
        <style>
            @page {
            //size: 8.27in 11.69in;
            size: 6in 4in;
            margin: 25mm;
            color: #f9f9f9;
            .italicText {
                font-style: Bold;
                font-size: 1.2em;
                font-family: Arial, Helvetica, sans-serif;
                text-decoration: none;
                color: #ff0000;
            }
            .headerText {
                font-weight: bold;
                font-size: 1em;
                text-align: center;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }
            .NoteText {
                font-weight: bold;
                font-size: 1em;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }
        </style>
    </head>
    <body>
        <div class="erp_mark7">
            <apex:form id="mainform">
                <apex:pageMessages ></apex:pageMessages>
                <div class="wrapper">
                    
                    <table border="0" Style="background-color:#FFF;" width="100%">
                        <div style="width:300px;">
                        <div style="float:right;"><a href="{!'/apex/ERP7__OperationLabel?WId='+ Record.Id+'&ra=pdf'}" target="_blank" class="Name" style="width:30px;text-align:right;{!if(prnt == 'false','display:none','display:block')}"> 
                            <i class="fa fa-print" aria-hidden="true" style="font-size:18px;color:#ff0000;"></i>
                        </a></div>
                    </div>
                    
                        <tr>
                            <td> 
                                <apex:iframe src="https://{!sfdcBaseURL}/email/templaterenderer?id={!MailselectedTemplate.id}&recipient_type_id={!currentContact.id}&related_to_id={!Record.id}&base_href=https://{!sfdcBaseURL}salesforce.com&preview_frame=previewFrame&render_type=REPLACED_HTML_BODY&setupid=CommunicationTemplatesEmail" width="100%" height="800"/>
                             <!-- <apex:iframe src="https://{!sfdcBaseURL}documentforce.com/email/templaterenderer?id={!MailselectedTemplate.id}&recipient_type_id={!currentContact.id}&related_to_id={!Record.id}&base_href=https://{!sfdcBaseURL}salesforce.com&preview_frame=previewFrame&render_type=REPLACED_HTML_BODY&setupid=CommunicationTemplatesEmail" width="100%" height="800"/>-->
                            </td>
                        </tr>
                    </table>
                </div>
            </apex:form>
        </div>
    </body>
</apex:page>