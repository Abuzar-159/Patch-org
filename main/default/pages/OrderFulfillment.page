    <script type="text/javascript">
        function completeAction(sortby, orderFormat){
            
            var ik = document.getElementById(sortby); 
            var ikicon = document.getElementById(sortby+'icon');
            
            var kkvalue = sortby;
            var kkval = "";
            if(kkvalue == "product") kkval = "Product";
            else if(kkvalue == "order") kkval = "Order #";
            else if(kkvalue == "customer") kkval = "Customer";
            else if(kkvalue == "contact") kkval = "Contact";
            else if(kkvalue == "stock") kkval = "Stock";
            else if(kkvalue == "orderDate") kkval = "Order Date";
            
            ik.style. fontStyle = "normal";
            ik.style.color = "red";
            ik.style. fontWeight = "bold";
            ik.style.fontFamily = "Arial,Glyphicons Halflings";
            
            if(orderFormat == 'ASC'){ 
                ik.title = 'ASC';
                ikicon.className = "fa fa-sort-asc";
                
                
            } 
            else { 
                ikicon.className = "fa fa-sort-desc";
            }
        }
    </script>
    <body>
        <apex:form id="myform">
        
            <apex:actionFunction name="sortList" action="{!sortList}" reRender="pbik" status="spinnerwhite" oncomplete="completeAction('{!sortBy}','{!orderFormat}');">
                <apex:param assignTo="{!sortBy}" value="" name="sortBy"/>
                <apex:param assignTo="{!orderFormat}" value="" name="orderFormat"/>
            </apex:actionFunction>
            
            <div id="wrapper" style="margin-top:5px;margin-bottom:5px;">

                <nav class="navbar" style="min-height: 0px; margin-bottom: 0px;">
                    <div class="row erp-bg" style="height:35px;border-radius: 0px;">
                        <div class="col-md-5">
                            <h4 style=" font-size:14px; line-height:35px; padding-left:20px;"></h4>
                        </div>

                        <div class="col-md-6">
                            <h4 style=" font-size:16px; line-height:35px;padding-left:0px;">Sales Order Fulfillment &nbsp;&nbsp;&nbsp;</h4>
                            <apex:actionStatus id="spinnerwhite">
                                <apex:facet name="start">
                                    <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/whiteloader.gif')}" height="20px;" width="25px;" style="padding-left:5px;" />
                                </apex:facet>
                            </apex:actionStatus>
                        </div>
                    </div>
                </nav>
                <table width="100%" style="display:{!if(!(StockWrapperList.size > 0),'','none')};margin-top:5px;">
                    <tr><td align="center" valign="top" style="color:red;">{!errMsg}</td></tr>
                </table>
                <div class="container" style="font-size:14px;margin-top: 5px;display:{!if(StockWrapperList.size > 0,'','none')}">
                    <apex:pageBlock title="Sales order line items to be fulfilled" id="pbik">
                       <script>
                            $(document).ready(function() {
                                $('[data-toggle="popover"]').popover();
                            });
            
                            function scrollToCustom(scrolltocusId) {
                                $('html, body').animate({
                                    scrollTop: $(scrolltocusId).offset().top
                                }, 'slow');
                                return false;
                            }
                        </script>
                        <apex:pageBlockButtons >
                            <apex:commandButton value="Save" style="width:150px; height:30px;" title="Save" action="{!FulfillOrders}" reRender="pbik" status="spinnerwhite"/>
                            <apex:commandButton value="Cancel" style="width:150px; height:30px;" title="Cancel" action="{!Cancel}"/>
                            <apex:commandButton value="Order Console" style="width:150px; height:30px;" title="Order Console" action="{!OrderConsole}"/>
                          
                       </apex:pageBlockButtons>
                       
                        <apex:pageBlockTable var="wrap" value="{!StockWrapperList}" style="font-size:13px;" id="pbtab" cellspacing="50">
                        
                            <apex:column headerValue="Preview" styleClass="{!if(wrap.fulfilled,'success','')}">
                                <a href="#" onmouseover="" data-toggle="popover" data-trigger="hover" data-placement="bottom" data-html="true" data-content="{!wrap.SOLI.Product__r.Preview_Image__c}">
                                    <apex:image url="{!wrap.SOLI.Product__r.Picture__c}" height="40px" width="40px" id="itemimage" />
                                </a>
                            </apex:column>
                            
                            <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span id="product" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('product',formatOrd);">Product &nbsp;<i id="producticon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!wrap.SOLI.Product__c}"/> 
                            </apex:column>
                            
                            <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span id="order" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('order',formatOrd);">Order No. &nbsp;<i id="ordericon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!wrap.SOLI.Sales_Order__c}"/> 
                            </apex:column>
                         
                            <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span id="customer" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('customer',formatOrd);">Customer &nbsp;<i id="customericon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!wrap.SOLI.Sales_Order__r.Account__c}" /> 
                            </apex:column>
                       
                            <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span >Warehouse</span></apex:facet>
                                 <apex:outputField value="{!wrap.stock.Warehouse__c}"/> 
                            </apex:column>
                            
                            
                            <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span id="stock" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('stock',formatOrd);">Stock &nbsp;<i id="stockicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!wrap.PPLI.Site_Product_Service_Inventory_Stock__c}" /> 
                            </apex:column>
                            
                             <apex:column styleClass="{!if(wrap.fulfilled,'success','')}">
                                 <apex:facet name="header"><span id="orderDate" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('orderDate',formatOrd);">Order Date &nbsp;<i id="orderDateicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!wrap.SOLI.Sales_Order__r.Order_Date__c}" /> 
                            </apex:column>
                           
                            <apex:column value="{!wrap.SOLI.Quantity__c}" headerValue="Quantity" styleClass="{!if(wrap.fulfilled,'success','')}"/>
                            <apex:column headerValue="Inventory Stock" styleClass="{!if(wrap.fulfilled,'success','')}" style="font-weight:bold;">
                                <apex:outputText value="{!wrap.InternalCount}"/>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                <apex:actionStatus id="spinnerwhites">
                                    <apex:facet name="start">
                                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/spinner24.gif')}" height="20px;" width="25px;" style="padding-left:5px;" />
                                    </apex:facet>
                                </apex:actionStatus>
                            </apex:column>
                            <apex:column headerValue="" styleClass="{!if(wrap.fulfilled,'success','')}">
                                <apex:inputCheckbox value="{!wrap.fulfilled}" disabled="{!if(wrap.SOLI.Quantity__c > wrap.InternalCount && !wrap.fulfilled,true,false)}" style="cursor:pointer;">
                                    <apex:actionSupport event="onchange" action="{!EvaluateStock}" reRender="pbik" status="spinnerwhites"/>
                                </apex:inputCheckbox>
                            </apex:column>
                       </apex:pageBlockTable>
                    </apex:pageBlock>
                </div>
            </div>
                
            <script>
            
            </script>
        </apex:form>
    </body>
</apex:page>