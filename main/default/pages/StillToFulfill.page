       <style>
           .maq .transition, p, ul li i:before, ul li i:after {
              transition: all 0.25s ease-in-out;
            }
            
             .maq .flipIn, h1, ul li {
              animation: flipdown 0.5s ease both;
            }
            
             .maq .no-select, h2 {
              -webkit-tap-highlight-color: rgba(0, 0, 0, 0);
              -webkit-touch-callout: none;
              -webkit-user-select: none;
              -khtml-user-select: none;
              -moz-user-select: none;
              -ms-user-select: none;
              user-select: none;
            }
            
             .maq html {
              width: 100%;
              height: 100%;
              perspective: 900;
              overflow-y: scroll;
              background-color: #dce7eb;
              font-family: "Titillium Web", sans-serif;
              color: rgba(48, 69, 92, 0.8);
            }
            
            .maq body {
              min-height: 0;
              display: inline-block;
              position: relative;
              left: 50%;
              margin: 90px 0;
              transform: translate(-50%, 0);
              box-shadow: 0 10px 0 0 #ff6873 inset;
              background-color: #fefffa;
              max-width: 450px;
              padding: 30px;
            }
            @media (max-width: 550px) {
             .maq  body {
                box-sizing: border-box;
                transform: translate(0, 0);
                max-width: 100%;
                min-height: 100%;
                margin: 0;
                left: 0;
              }
            }
            
             .maq h1, h2 {
              color: #31d0e5;
            }
            
            .maq h1 {
              text-transform: uppercase;
              font-size: 36px;
              line-height: 42px;
              letter-spacing: 3px;
              font-weight: 100;
            }
            
            .maq h2 {
              font-size: 18px;
              line-height: 34px;
              font-weight: 300;
              letter-spacing: 1px;
              display: block;
              background-color: #fefffa;
              margin: 0;
              cursor: pointer;
            }
            
             .maq p {
              color: rgba(48, 69, 92, 0.8);
              font-size: 17px;
              line-height: 26px;
              letter-spacing: 1px;
              position: relative;
              overflow: hidden;
              max-height: 800px;
              opacity: 1;
              transform: translate(0, 0);
              margin-top: 14px;
              z-index: 2;
            }
            
             .maq ul {
              list-style: none;
              perspective: 900;
              padding: 0;
              margin: 0;
            }
             .maq ul li {
              position: relative;
              padding: 0;
              margin: 0;
              padding-bottom: 10px;
              padding-top: 10px;
              border-top: 1px dotted #dce7eb;
            }
             .maq ul li:nth-of-type(1) {
              animation-delay: 0.5s;
            }
            .maq ul li:nth-of-type(2) {
              animation-delay: 0.75s;
            }
            .maq ul li:nth-of-type(3) {
              animation-delay: 1s;
            }
             .maq ul li:last-of-type {
              padding-bottom: 0;
            }
             .maq ul li i {
              position: absolute;
              transform: translate(-6px, 0);
              margin-top: 16px;
              right: 0;
            }
             .maq ul li i:before, ul li i:after {
              content: "";
              position: absolute;
              background-color: #31d0e5;
              width: 3px;
              height: 9px;
            }
            .maq  ul li i:before {
              transform: translate(-2px, 0) rotate(45deg);
            }
             .maq ul li i:after {
              transform: translate(2px, 0) rotate(-45deg);
            }
             .maq ul li input[type=checkbox] {
              position: absolute;
              cursor: pointer;
              width: 100%;
              height: 100%;
              z-index: 1;
              opacity: 0;
            }
             .maq ul li input[type=checkbox]:checked ~ p {
              margin-top: 0;
              max-height: 0;
              opacity: 0;
              transform: translate(0, 50%);
            }
             .maq ul li input[type=checkbox]:checked ~ i:before {
              transform: translate(2px, 0) rotate(45deg);
            }
             .maq ul li input[type=checkbox]:checked ~ i:after {
              transform: translate(-2px, 0) rotate(-45deg);
            }
            
            @keyframes flipdown {
              0% {
                opacity: 0;
                transform-origin: top center;
                transform: rotateX(-90deg);
              }
              5% {
                opacity: 1;
              }
              80% {
                transform: rotateX(8deg);
              }
              83% {
                transform: rotateX(6deg);
              }
              92% {
                transform: rotateX(-3deg);
              }
              100% {
                transform-origin: top center;
                transform: rotateX(0deg);
              }
            }
            
       </style>
