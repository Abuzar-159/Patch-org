<apex:page controller="BalanceSheet" tabStyle="Bank_Reconciliation__c"  standardStylesheets="false" readOnly="true" renderAs="pdf"  sidebar="false">
    
    <body>
        <div style="font-family:Arial, Helvetica, sans-serif; font-size:12px;border-left:1px solid #ddd;border-right:1px solid #ddd;border-top:1px solid #ddd;padding:10px;width:97%;">
            <span style="font-family:Arial, Helvetica, sans-serif; font-size:18px;padding:10px;"><apex:outputField value="{!Select_Organisation.Organisation__c}"  /></span> 
            <div style="font-family:Arial, Helvetica, sans-serif; font-size:24px;padding:5px;text-align:right;"><apex:outputText value="Balance Sheet"/></div>
            <div style="font-family:Arial, Helvetica, sans-serif; font-size:16px;font-weight:bold;padding:5px;text-align:right;">
                <apex:outputText value=" {0,date,MMMM d, yyyy}">
                    <apex:param value="{!EDate}"/>
                </apex:outputText>
            </div>
        </div>
          
                    <div style="width:50%;float:left;">
                         <!-- column 1-->  
                        <apex:outputPanel rendered="{!assetList!=null}"> 
                            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                                <tr style="background:#0270d3;">
                                    <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;" >
                                        Assets
                                    </td>
                                </tr>
                            </table>
                            
                            <apex:outputPanel rendered="{!assetList!=null}"> 
                                <apex:repeat value="{!assetList}" var="Fysubacc">
                                    <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                                        <td width="1%">&nbsp;</td>
                                        <td width="40%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">{!Fysubacc['AccountName']}
                                        </td>
                                        <td  class="assets-text" width="59%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                            {!checkCurrency.userISO}&nbsp;{!(Fysubacc['Debit']-Fysubacc['Credit'])}
                                            <apex:param value="{!(Fysubacc['Debit']-Fysubacc['Credit'])*checkCurrency.conversionRate}"/>
                                            
                                        </td>
                                    </table>
                                </apex:repeat>
                            </apex:outputPanel>
                            
                            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">                 
                                <tr>
                                    <td width="1%">&nbsp;</td>
                                    <td width="40%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;" class="assets-text">
                                        <strong>Total Assets
                                        </strong> 
                                    </td>
                                    <td  class="assets-text" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                        {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}">
                                        <apex:param value="{!totalAsset*checkCurrency.conversionRate}"/>
                                        </apex:outputText>
                                    </td>
                                </tr>
                            </table>  
                        </apex:outputPanel>
                        <!-- column 1-->   
                    </div>
        
                    <div style="width:50%;float:right;">
                        <!-- column 2-->        
                        <apex:outputPanel rendered="{!liabilityList!=null}"> 
                            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                                <tr style="background:#0270d3;">
                                    <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;" >
                                        Liability and Equity
                                    </td>
                                </tr>
                            </table>
                            
                            <apex:outputPanel rendered="{!liabilityList!=null}"> 
                                <apex:repeat value="{!liabilityList}" var="Fysubacc">
                                    <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                                        <td width="1%">&nbsp;</td>
                                        <td width="40%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">{!Fysubacc['AccountName']}
                                        </td>
                                        <td  class="assets-text" width="59%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                            {!checkCurrency.userISO}&nbsp;{!(Fysubacc['Credit']-Fysubacc['Debit'])}
                                            <apex:param value="{!(Fysubacc['Debit']-Fysubacc['Credit'])*checkCurrency.conversionRate}"/>
                                            
                                        </td>
                                    </table>
                                </apex:repeat>
                            </apex:outputPanel>
                            <apex:outputPanel rendered="{!EquityList!=null}"> 
                                <apex:repeat value="{!EquityList}" var="Fysubacc">
                                    <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                                        <td width="1%">&nbsp;</td>
                                        <td width="40%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">{!Fysubacc['AccountName']}
                                        </td>
                                        <td  class="assets-text" width="59%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                            {!checkCurrency.userISO}&nbsp;{!(Fysubacc['Credit']-Fysubacc['Debit'])}
                                            <apex:param value="{!(Fysubacc['Debit']-Fysubacc['Credit'])*checkCurrency.conversionRate}"/>
                                            
                                        </td>
                                    </table>
                                </apex:repeat>
                            </apex:outputPanel>
                            <tr>
                                <td width="1%">&nbsp;</td>
                                <td width="40%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;" class="assets-text">
                                    <strong>Equity
                                    </strong> 
                                </td>
                                <td  class="assets-text" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                    {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}">
                                    <apex:param value="{!(totalAsset-totalLiabEqui) *checkCurrency.conversionRate}"/>
                                    </apex:outputText>
                                </td>
                            </tr>
                            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">                 
                                <tr>
                                    <td width="1%">&nbsp;</td>
                                    <td width="40%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;" class="assets-text">
                                        <strong>Total Liability and Equity
                                        </strong> 
                                    </td>
                                    <td  class="assets-text" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                        {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}">
                                        <apex:param value="{!totalAsset*checkCurrency.conversionRate}"/>
                                        </apex:outputText>
                                    </td>
                                </tr>
                            </table>  
                        </apex:outputPanel>
                        <!-- column 2 ends here--> 
                    </div>
       		 
       
        
		
        <div style="width:100%;float:left;">
            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;"> 
                <tr style="background:#009688;">
                    <td style="background:#009688; color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                        <strong>Total Asset</strong>
                    </td>
                    
                    <td style="background:#009688;color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px;">
                        -
                    </td>
                    <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                        <strong>Total Liability </strong>	 
                    </td>
                </tr>
                <tr style="background:#009688;">
                    <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                        {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}" id="totalRev" ><apex:param value="{!totalAsset*checkCurrency.conversionRate}"/></apex:outputText>
                    </td>
                    <td> <h5 class="top-texttb" style="line-height: 28px;"></h5></td>
                    <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                        {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}"  id="totalExp" ><apex:param value="{!totalAsset*checkCurrency.conversionRate}"/></apex:outputText>
                    </td> 
                </tr>
            </table>
        </div>
        
        
    </body>
</apex:page>