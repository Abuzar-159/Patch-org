<apex:page sidebar="false" cache="false"  docType="html-5.0" showHeader="true" controller="StockRunRate" id="pges" renderAs="pdf">
    <html>

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
       <apex:stylesheet value="{!URLFOR($Resource.SLDS0121, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />
        <style>
        @media (min-width: 992px){
        .col-md-3 {
            width: 12%;
        }
        }
                .slds .slds-table--bordered {
            border-top: 1px solid #d8dde6;
            border-bottom: 1px solid #d8dde6;
           
        }
      
        .slds .slds-button--primary {
            padding-left: 16px;
            padding-right: 16px;
            text-align: center;
            vertical-align: middle;
            background-color: #337ab7;
            border-image-source: initial;
            border-image-slice: initial;
            border-image-width: initial;
            border-image-outset: initial;
            border-image-repeat: initial;
            color: white;
            border-width: 1px;
            border-style: solid;
            border-color: #2e6da4;
        }
        
        .slds .slds-button--primary:hover {
            color: white;
            background-color: #286090;
            border-color: #204d74;
        }
        
        .slds .slds-button--success {
            padding-left: 16px;
            padding-right: 16px;
            text-align: center;
            vertical-align: middle;
            background-color: #5cb85c;
            border-image-source: initial;
            border-image-slice: initial;
            border-image-width: initial;
            border-image-outset: initial;
            border-image-repeat: initial;
            color: white;
            border-width: 1px;
            border-style: solid;
            border-color: #4cae4c;
        }
        
        .slds .slds-button--success:hover {
            color: white;
            background-color: #449d44;
            border-color: #398439;
        }
        
        .slds .slds-button--info {
            padding-left: 16px;
            padding-right: 16px;
            text-align: center;
            vertical-align: middle;
            background-color: #5bc0de;
            border-image-source: initial;
            border-image-slice: initial;
            border-image-width: initial;
            border-image-outset: initial;
            border-image-repeat: initial;
            color: white;
            border-width: 1px;
            border-style: solid;
            border-color: #46b8da;
        }
        
        .slds .slds-button--info:hover {
            color: white;
            background-color: #31b0d5;
            border-color: #269abc;
        }
        
        .slds .slds-button--warning {
            padding-left: 16px;
            padding-right: 16px;
            text-align: center;
            vertical-align: middle;
            background-color: #f0ad4e;
            border-image-source: initial;
            border-image-slice: initial;
            border-image-width: initial;
            border-image-outset: initial;
            border-image-repeat: initial;
            color: white;
            border-width: 1px;
            border-style: solid;
            border-color: #eea236;
        }
        
        .slds .slds-button--warning:hover {
            color: white;
            background-color: #ec971f;
            border-color: #d58512;
        }
        
        .slds .slds-button--danger {
            padding-left: 16px;
            padding-right: 16px;
            text-align: center;
            vertical-align: middle;
            background-color: #d9534f;
            border-image-source: initial;
            border-image-slice: initial;
            border-image-width: initial;
            border-image-outset: initial;
            border-image-repeat: initial;
            color: white;
            border-width: 1px;
            border-style: solid;
            border-color: #d43f3a;
        }
        
        .slds .slds-button--danger:hover {
            color: white;
            background-color: #c9302c;
            border-color: #ac2925;
        }
        
        .epr_Mark7 .navbar-default .navbar-nav> .active> a,
        .epr_Mark7 .navbar-default .navbar-nav> .active> a:hover,
        .epr_Mark7 .navbar-default .navbar-nav> .active> a:focus {
            color: #555;
            background-color: #ffffff;
        }
        
        .epr_Mark7 .active {
            background: #3A6690;
        }

        </style>
    </head>
    <script>
    $(document)
        .ready(function() {
            $('#example')
                .DataTable();
        });
    window.onload = setFocus();

    function setFocus() {
        document.getElementById('{!$Component.myform.panelb}')
            .focus();
    }

    </script>

    <body>
        <apex:form id="mainFrm">
            <div class="slds slds-container--fluid">
                
                <div class="slds">
                    <div class="epr_Mark slds-m-top--small">
                       
                        <h4 style="text-align:center;padding:30px;font-family: Arial, Helvetica, sans-serif; font-size:18px;"><u>Stock Run Rate</u></h4>
                      <div class="container-fluid">  
                        <div class="row slds-m-bottom--small">
                            
                            
                            <div class="col-md-6 slds-m-bottom--small">
                                <table>
                                    <tr>
                                        <td width="200px;" style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><b> Sales (Week Avg) </b></td>
                                        <td style="padding-right: 4px;font-family:arial; font-size:12px;">  From
                               
                                 </td>
                                 <td style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;" rendered="{!$ObjectType.Stock_Outward_Line_Item__c.fields.CreatedDate.Accessible}">
                                         <apex:param value="{!wsFrom}"/>
                                     </apex:outputText>
                                </td>
                                   
                                        <td style="padding-right: 4px;font-family: Arial, Helvetica, sans-serif; font-size:12px;"> To
                                        </td>
                                        <td style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;" rendered="{!$ObjectType.Stock_Outward_Line_Item__c.fields.CreatedDate.Accessible}">
                                         <apex:param value="{!wsTo}"/>
                                     </apex:outputText>
                                </td>
                                  </tr>
                                  </table>
                                        
                            
                                
                            </div>
                          
                            
                            
                             <div class="col-md-6 slds-m-bottom--small">
                                 <table>
                                  <tr>
                                      <td width="200px;" style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><b> Inward Projection </b></td>
                                        <td style="padding-right: 4px;font-family: Arial, Helvetica, sans-serif; font-size:11px;">
                                        From
                                        </td>
                                        
                                        <td style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;" rendered="{!$ObjectType.PO__c.fields.Order_Date__c.Accessible}">
                                         <apex:param value="{!ipfrom}"/>
                                     </apex:outputText>
                                </td>
                                  
                                        <td style="padding-right: 4px;font-family: Arial, Helvetica, sans-serif; font-size:12px;">
                                        To
                                        </td>
                                        
                                        <td><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;" rendered="{!$ObjectType.PO__c.fields.Order_Date__c.Accessible}">
                                         <apex:param value="{!ipTo}"/>
                                     </apex:outputText>
                                </td>
                                   </tr>  
                                </table>      
                                 
                                     
                            </div>                                   
                        </div>
                        <div class="row slds-m-top--small slds-m-bottom--small">
                            
                             <div class="col-md-6 slds-m-bottom--small">
                                 <table>
                                  <tr>
                                         <td width="200px;" style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><b>Outward Projection</b></td>
                                        <td style="padding-right: 4px; font-family:arial; font-size:12px;">
                                        From
                                        </td>
                                        
                                        <td style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;">
                                             <apex:param value="{!opTo}"/>
                                         </apex:outputText>
                                        </td>
                                 
                                        <td style="padding-right: 4px;font-family: Arial, Helvetica, sans-serif; font-size:12px;">
                                        To
                                        </td>
                                        
                                       <td style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><apex:outputText value="{0, date, MM/dd/yyyy}" style="font-size: 12px;width:85%;">
                                         <apex:param value="{!opTo}"/>
                                     </apex:outputText>
                                </td>
                                   </tr>  
                                </table>      
                              
                                
                            </div>
                              <div class="col-md-6">
                                  
                                    
                            
                                
                                 <table>
                                  <tr>
                                         <td width="200px;" style="font-family: Arial, Helvetica, sans-serif; font-size:12px;"><b> Lead Time (Days)</b></td>
                                        <td style="padding-right: 4px;font-family:arial; font-size:12px;">
                                        <apex:outputText value="{!leadTimeTypeStr}" />
                                        </td>
                                        
                                        
                                   </tr>  
                                </table>   
                            </div>
                          </div>
                       </div> 
                      <div class="table-responsive">
                          <div class="col-sm-12">  
                        <table  width="100%" cellpadding="0" cellspacing="0" border="0">
                            <thead>
                                <tr>
                                    <th width="12.5%" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Status</th>
                                    <th width="15%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Product</th>
                                    <th width="15%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Code</th>
                                     <th width="10%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Lead Time</th>

                                    <th width="10%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Stock</th>
                                    
                                    <th width="10%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Inward</th>
                                    <th width="12.5%" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;border-right:1px solid #ddd;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Outward</th>
                                    <th width="10%"   style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;border-right:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">Sales</th>
                                </tr>
                            </thead>
                            
                            <tbody>
                               
                                
                                    <apex:repeat value="{!runRates}" var="RR">
                                        <tr >
                                            <td data-label="Current Status" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:4px;"><apex:outputText value="{!RR.status}" style=""/></td>
                                            <td data-label="Product Name" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:4px;">
                                                <apex:outputText value="{!RR.product.Name}" rendered="{!$ObjectType.Product2.fields.Name.Accessible}"/>
                                            </td>
                                            <td data-label="Product Code" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px; display:{!if($ObjectType.Product2.fields.Barcode__c.Accessible,' ','none')}">{!RR.product.Barcode__c}</td>
                                            <td data-label="Lead Time (Days)" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; display:{!if(leadTimeTypeStr=='Purchase' && $ObjectType.Product2.fields.Purchase_Lead_Time_days__c.Accessible,'','none')};font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">{!RR.product.Purchase_Lead_Time_days__c}</td>
                                            <td data-label="Current Stock" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px; display:{!if($ObjectType.Inventory_Stock__c.fields.Number_of_Item_In_Stock__c.Accessible,' ','none')}">{!RR.currentStock}</td>
                                            <td data-label="Inward Projection" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px; display:{!if($ObjectType.Purchase_Line_Items__c.fields.Remaining_Quantity__c.Accessible,' ', 'none')}">{!RR.inwardStock}</td>
                                            <td data-label="Outward Projection" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; border-right:1px solid #f7f7f7;border-bottom:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px;">{!RR.outStock}</td>
                                            <td data-label="Sales (week avg)" style="border-top:1px solid #f7f7f7; border-left:1px solid #f7f7f7; border-right:1px solid #f7f7f7;font-family: Arial, Helvetica, sans-serif; font-size:12px;padding:6px; display:{!if($ObjectType.Stock_Outward_Line_Item__c.fields.Quantity__c.Accessible,' ','none')}">{!RR.salesStock}</td>
                                            
                                        </tr>
                                    </apex:repeat>
                               
                            </tbody>
                        </table>
                      </div>
                     </div>   
                    </div>
                </div>
                <!-- Table bootstrap -->
                <div style="margin-top:10px; float:left; width:100%;"> </div>
            </div>
        </apex:form>
    </body>

    </html>
</apex:page>