                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__No_of_columns}</h5>
                                    <apex:selectList value="{!NoofColumns}" size="1" id="colm" StyleClass="form-control" style="width:100%; height:30px;">
                                        <apex:selectOption itemLabel="1" itemValue="1" />
                                        <apex:selectOption itemLabel="2" itemValue="2" />
                                        <apex:selectOption itemLabel="3" itemValue="3" />
                                    </apex:selectList>
                                </div>
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__Search_by_Name}</h5>
                                    <apex:inputText value="{!RecordName}"  id="Search" styleClass="form-control" style="width:100%; height:30px; " />
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-2">
                                    <h5 style="color:#666;">{!$Label.ERP7__Label_Value_Position}
                                    </h5>
                                    <apex:selectList value="{!LabelLoc}" size="1" id="lloc" StyleClass="form-control" style="width:100%; height:30px;" onchange="BarcodeLocSwitch();">
                                        <apex:selectOption itemLabel="Top" itemValue="Top" />
                                        <apex:selectOption itemLabel="Bottom" itemValue="Bottom" />
                                    </apex:selectList>
                                </div>
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__Label}</h5>
                                    <table>
                                        <tr>
                                            <td>
                                                <apex:selectList value="{!LabelField}" size="1" id="lbl" StyleClass="form-control" style="width:100%;height:30px;">
                                                    <apex:actionSupport event="onchange" action="{!Evaluate}" reRender="pbik" status="spinnerb" />
                                                    <apex:selectOptions value="{!LabelList}"></apex:selectOptions>
                                                </apex:selectList>
                                            </td>
                                            <td>
                                                <label class="erp_mark7 switch" style="margin:5px 0px 5px 0px;">
                                                    <apex:inputCheckbox value="{!LabelDisplay}" styleClass="erp_mark7 switch-input"/>
                                                    <span class="erp_mark7 switch-label" data-on="On" data-off="Off"></span>
                                                    <span class="erp_mark7 switch-handle"></span>
                                                </label>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.No_of_rows}</h5>
                                    <apex:selectList value="{!NoofRows}" size="1" id="rws" StyleClass="form-control" style="width:100%; height:30px;">
                                        <apex:selectOption itemLabel="1" itemValue="1" />
                                        <apex:selectOption itemLabel="2" itemValue="2" />
                                        <apex:selectOption itemLabel="3" itemValue="3" />
                                        <apex:selectOption itemLabel="4" itemValue="4" />
                                        <apex:selectOption itemLabel="5" itemValue="5" />
                                        <apex:selectOption itemLabel="6" itemValue="6" />
                                        <apex:selectOption itemLabel="7" itemValue="7" />
                                        <apex:selectOption itemLabel="8" itemValue="8" />
                                        <apex:selectOption itemLabel="9" itemValue="9" />
                                        <apex:selectOption itemLabel="10" itemValue="10" />
                                    </apex:selectList>
                                </div>
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__Barcode_Type}</h5>                                    
                                    <apex:selectList value="{!brcdType}" size="1" id="brct" StyleClass="form-control" style="width:100%; height:30px;" >                                    
                                        <apex:actionSupport event="onchange" action="{!Evaluate}" reRender="pbik" status="spinnerb" />
                                        <apex:selectOption itemLabel="Code-128" itemValue="code128" />
                                        <apex:selectOption itemLabel="Code-39" itemValue="code39" />
                                        <apex:selectOption itemLabel="EAN-8" itemValue="ean8" />
                                        <apex:selectOption itemLabel="EAN-13" itemValue="ean13" />
                                        <apex:selectOption itemLabel="QRCode" itemValue="qrcode" />
                                        <apex:selectOption itemLabel="PDF417" itemValue="pdf417" />
                                    </apex:selectList>
                                </div>
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__Page_size}</h5>
                                    <apex:selectList value="{!PageSize}" size="1" id="pagesize" StyleClass="form-control" style="width:100%; height:30px;">
                                        <apex:selectOption itemLabel="6/4 in(152.4mm x 101.6mm)" itemValue="6in 4in" />
                                        <apex:selectOption itemLabel="A0 (841mm x 1189mm)" itemValue="A0" />
                                        <apex:selectOption itemLabel="A1 (594mm x 841mm)" itemValue="A1" />
                                        <apex:selectOption itemLabel="A2 (420mm x 594mm)" itemValue="A2" />
                                        <apex:selectOption itemLabel="A3 (297mm x 420mm)" itemValue="A3" />
                                        <apex:selectOption itemLabel="A4 (210mm x 297mm)" itemValue="A4" />
                                        <apex:selectOption itemLabel="A5 (148.5 x 210mm)" itemValue="A5" />
                                        <apex:selectOption itemLabel="A6 (105mm x 148.5mm)" itemValue="A6" />
                                        <apex:selectOption itemLabel="A7 (74mm x 105mm)" itemValue="A7" />
                                        <apex:selectOption itemLabel="A8 (52mm x 74mm)" itemValue="A8" />
                                        <apex:selectOption itemLabel="A9 (37mm x 52mm)" itemValue="A9" />
                                        <apex:selectOption itemLabel="A10 (26mm x 37mm)" itemValue="A10" />
                                    </apex:selectList>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-2">
                                    <h5 style="color:#666;line-height:17px;">{!$Label.ERP7__Header_Value}</h5>
                                    <apex:inputText value="{!headVal}" styleClass="form-control" style="width:100%; height:30px; " />
                                </div>
                                <div class="col-md-5">
                                    <table>
                                        <tr>
                                            <td width="37%">
                                                <h5 style="color:#666;">{!$Label.ERP7__All_Fields}</h5>
                                                <apex:selectList value="{!myFields}" multiselect="true" id="flds" StyleClass="form-control" style="height:100px;">
                                                    <apex:selectOptions value="{!FieldList}"></apex:selectOptions>
                                                </apex:selectList>
                                            </td>
                                            <td width="6%" style="text-align:center;">
                                                <apex:commandLink action="{!AddFields}" value="" reRender="fldsld,flds" styleClass="slds-button slds-button--neutral fa fa-angle-double-right" style="font-size: 15px;height: 20px; width: 30px;line-height: 20px;padding-left: 10px;" status="spinnerb"/>
                                                <apex:commandLink action="{!RemoveFields}" value="" reRender="fldsld,flds" styleClass="slds-button slds-button--neutral fa fa-angle-double-left" style="font-size: 15px;height: 20px; width: 30px;margin-top: 10px;margin-left: 0px;line-height: 20px;padding-left: 10px;" status="spinnerb"/>
                                            </td>
                                            <td width="33%">
                                                <h5 style="color:#666;">{!$Label.ERP7__Selected_Fields}</h5>
                                                <apex:selectList value="{!FieldListSelecteds}" multiselect="true" id="fldsld" StyleClass="form-control" style="height:100px;">
                                                    <apex:selectOptions value="{!FieldListSelectedsOptions}"></apex:selectOptions>
                                                </apex:selectList>
                                            </td>
                                            <td width="5%" style="text-align:center;">
                                                <apex:commandLink action="{!top}" value="" reRender="fldsld" styleClass="slds-button slds-button--neutral fa fa-angle-double-up" style="font-size: 15px;height: 20px;margin-top: 15px; width: 25px;line-height: 20px;padding-left: 7px;" status="spinnerb"/>
                                                <apex:commandLink action="{!up}" value="" reRender="fldsld" styleClass="slds-button slds-button--neutral fa fa-angle-up" style="font-size: 15px;height: 20px; width: 25px;margin-top: 7px;margin-left: 0px;line-height: 20px;padding-left: 7px;" status="spinnerb"/>
                                                <apex:commandLink action="{!down}" value="" reRender="fldsld" styleClass="slds-button slds-button--neutral fa fa-angle-down" style="font-size: 15px;height: 20px; width: 25px;margin-left: 0px;line-height: 20px;padding-left:7px;" status="spinnerb"/>
                                                <apex:commandLink action="{!bottom}" value="" reRender="fldsld" styleClass="slds-button slds-button--neutral fa fa-angle-double-down" style="font-size: 15px;height: 20px; width: 25px;margin-top: 7px;margin-left: 0px;line-height: 20px;padding-left: 7px;" status="spinnerb"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-4">
                                    <table>
                                        <tr>
                                            <td width="57%">
                                                <table>
                                                    <tr>
                                                        <td width="25%">
                                                            <h5 style="color:#666;">{!$Label.ERP7__Frame}</h5>
                                                        </td>
                                                        <td>
                                                            <label class="erp_mark7 switch">
                                                                <apex:inputCheckbox value="{!Frame}" styleClass="erp_mark7 switch-input"/>
                                                                <span class="erp_mark7 switch-label" data-on="On" data-off="Off"></span>
                                                                <span class="erp_mark7 switch-handle"></span>
                                                            </label>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                            <td>
                                                <apex:commandLink value="Go" styleClass="slds-button slds-button--brand" onclick="if('{!myObject}' == '' || '{!BarcodeField}' == '') return false;" action="{!Evaluate}"  style="width:100px; height:30px; margin-top:15px;" title="Go" id="cmdbut" />
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <table width="100%" style="margin-top:5px;">
                                <tr>
                                    <td align="center" valign="top" style="color:red;">{!errMsg}</td>
                                </tr>
                            </table>
                        </div>                        
                    </div>
                    
                    <div class="erp_mark7" style="overflow:auto;margin-bottom:50px;">
                    <apex:outputPanel id="pbik" style="display:{!if(BarcodeWrapperList.size > 0,true,false)}">
                        
                        <apex:outputPanel rendered="{!if(BarcodeWrapperList.size == 0 ,true,false)}">
                            <div  class="slds-notify slds-notify_alert slds-theme_alert-texture slds-theme_error" role="alert" style="position: absolute;top: 14px;width: 24%; left: 39%;">
                                No record Found
                            </div>                                                    
                        </apex:outputPanel>
                        
                        <table class="slds-table slds-table--condensed slds-max-medium-table--stacked-horizontal slds-no-row-hover slds-m-bottom--large">
                            
                            <thead style="display:{!if(BarcodeWrapperList.size > 0,'','none')}">
                                <tr class="slds-text-title--caps" style="border-top: 1px solid rgb(216, 221, 230);border-bottom: 1px solid rgb(216, 221, 230);">
                                    <th scope="col">
                                    <div class="slds-truncate" title="">
                                        <apex:inputCheckbox value="{!selectAll}" style="">
                                                    <apex:actionSupport event="onchange" action="{!selectAll}" reRender="pbik" status="spinnerb" />
                                                </apex:inputCheckbox>
                                    </div>
                                    </th>
                                    <th scope="col">
                                    <div class="slds-truncate" title="Sl.No"></div>
                                    </th>
                                    <th scope="col">
                                    <div class="slds-truncate" title="Name">{!$Label.Name_ManageLeave}</div>
                                    </th>
                                    <th scope="col">
                                    <div class="slds-truncate" title="Code">{!$Label.UPS_Code}</div>
                                    </th>
                                    <th scope="col">
                                    <div class="slds-truncate" title="Label">{!$Label.Label}</div>
                                    </th>
                                    <th scope="col">
                                    <div class="slds-truncate" title="Barcode">{!$Label.Barcode_Outbound_logistics}</div>
                                    </th>
                                    
                                </tr>
                            </thead>
                            
                             <apex:variable var="count" value="{!counter}"/>
                                    <apex:repeat value="{!BarcodeWrapperList}" var="wrap">
                            <tbody>
                            <tr>
                                <td scope="row" data-label="" style="padding: 0.5rem">
                                <div class="slds-truncate" title="">                            
                                 <apex:inputCheckbox value="{!wrap.selected}" style="padding: 0.5rem" >
                                     <apex:actionSupport event="onchange" action="{!deselect}" reRender="pbik" status="spinnerb" />
                                 </apex:inputCheckbox>
                                
                                </div>
                                </td>
                                <td data-label="Sl No" style="padding: 0.5rem">
                                <div class="slds-truncate" title="">
                                <apex:outputText value="{!count+1}." style="padding-left:10px;"/>
                                </div>
                                </td>
                                <td data-label="Name" style="padding: 0.5rem">
                                <div class="slds-truncate" title="">
                                 <apex:outputLink value="/{!wrap.Id}" target="_blank">{!wrap.Name}</apex:outputLink>
                                 </div>
                                </td>
                                <td data-label="Code">
                                <div class="slds-truncate" title="">
                                <apex:outputText value="{!wrap.Barcode}" />
                                </div>
                                </td>
                                <td data-label="Label" style="padding: 0.5rem">
                                <div class="slds-truncate" title="">
                                     <apex:outputText value="{!wrap.Label}" />
                                            <apex:variable var="count" value="{!count+1}"/>
                                </div>
                                </td>
                                
                               <!-- <td data-label="Barcode" >
                                    <div class="slds-truncate" title="">
                                        <c:AQBarcodeZone BrcdType="{!brcdType}" Value="{!wrap.Barcode}"/>                                       
                                    </div>
                                </td>-->
                                
                               <td data-label="Barcode" style="padding:10px;">                               
                                   <apex:outputPanel rendered="{!(brcdType == 'code128' || brcdType == 'code39' || brcdType == 'ean8' || brcdType == 'ean13')}">
                                       <c:AQBarcodeZone BrcdType="{!brcdType}" Value="{!wrap.Barcode}"/>
                                    </apex:outputPanel>
                                    <apex:outputPanel rendered="{!(brcdType == 'qrcode' || brcdType == 'pdf417')}">
                                       <c:AC2DBarcode BrcdType="{!brcdType}" Value="{!wrap.Barcode}" Brcd-sObjectParentId="{!count}"/>
                                    </apex:outputPanel>
                                </td>
                            </tr>
                            
                                </tbody>
                             </apex:repeat>   
                          </table>
                          <div class="container-fluid" style="">
                            <div>
                                    <div class="row" style="margin: 0px;position: fixed; bottom: 0; width:100%;background: rgba(255, 255, 255, 0.8);padding-bottom:10px;padding-top:10px;" >
                                       <div class="col-md-4 col-xs-4" style="text-align:left;">
                                   
                                        Show &nbsp;
                                        <apex:selectList size="1" value="{!list_size}"  style="width:60px; height:25px; ">
                                            <apex:actionSupport event="onchange" action="{!Evaluate}" rerender="pbik" status="spinnerb"/>
                                            <apex:selectOption itemLabel="10" itemValue="10" />
                                            <apex:selectOption itemLabel="100" itemValue="100" />
                                            <apex:selectOption itemLabel="200" itemValue="200"/>
                                            <apex:selectOption itemLabel="300" itemValue="300"/>
                                            <apex:selectOption itemLabel="400" itemValue="400"/>
                                            <apex:selectOption itemLabel="500" itemValue="500"/>
                                        </apex:selectList>
                                        entries &nbsp;&nbsp;
                                        <apex:outputText > {!counter+1} - </apex:outputText>
                                        <apex:outputText rendered="{!if(Total_size < counter+list_size,true,false)}"> {!Total_size}</apex:outputText>
                                        <apex:outputText rendered="{!if(Total_size < counter+list_size,false,true)}"> {!counter+list_size}</apex:outputText>
                                        <apex:outputText > of {!Total_size} </apex:outputText>
                                        <apex:outputText > &nbsp;&nbsp;&nbsp; Page {!PageNumber} of {!TotalPages}</apex:outputText>
                                   </div>
                                   <apex:outputText rendered="{!IF(pageTarget=='showPreview', true, false)}">   
                                     <div class="col-md-4 col-xs-4" style="text-align:center;">
                                            <apex:commandLink value="{!$Label.ERP7__PDF_preview}" styleClass="slds-button slds-button--brand" action="{!PrintPreview}" style="width:150px; height:30px;" title="Preview PDF" id="cmdbutp"  target="_blank" />
                                        </div>
                                        </apex:outputText> 
                                        <apex:outputText rendered="{!IF(pageTarget=='', true, false)}">   
                                     <div class="col-md-4 col-xs-4" style="text-align:center;">
                                            <apex:commandLink value="{!$Label.ERP7__PDF_preview}" styleClass="slds-button slds-button--brand" action="{!PrintPreview}"
                  style="width:150px; height:30px; pointer-events: none; cursor: default; opacity: 0.5;"
                  title="Preview PDF" id="cmdbutp2" target="_blank" />

                                        </div>
                                        </apex:outputText> 
                                        <div class="col-md-4 col-xs-4" style="text-align:right;">
                                        <!--<apex:commandButton action="{!Beginning}" title="Beginning" value="<<" disabled="{!disablePrevious}" rerender="pbik" status="spinnerb"/>-->
                                        <apex:commandButton action="{!Previous}" styleClass="slds-button slds-button--neutral " title="Previous" value="Previous" disabled="{!disablePrevious}" rerender="pbik" status="spinnerb"/>
                                        <apex:commandButton action="{!Next}" styleClass="slds-button slds-button--neutral " title="Next" value="Next" disabled="{!disableNext}" rerender="pbik" status="spinnerb" />
                                        <!--<apex:commandButton action="{!End}" title="End" value=">>" disabled="{!disableNext}" rerender="pbik" status="spinnerb"/>-->        
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                       
                    </div>
                     
                </div>
            </apex:form>
        </body>
    </html>
</apex:page>