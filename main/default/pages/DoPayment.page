<script>
    function valueConversationtoNumber(str) {
        var arr = str.split(",");
        var strNew = '';
        for(var x=0;x<arr.length;x++) strNew += arr[x];
        return strNew;
    }
    function validate(val){
        val = valueConversationtoNumber(val);
        if(!(isNaN(val)) && val <= parseFloat('{!actualAmount}')){
            document.getElementById('errMsg').style.display='none';
        assign_payment(val); 
        }else{
            document.getElementById('errMsg').style.display='';
            document.getElementById('paymentPage:myform:paymentAmount').focus();
        }
    }
</script>
