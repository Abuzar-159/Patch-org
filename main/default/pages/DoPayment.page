    <script type="text/javascript"> 
      function loading(val){ 
          var paystatus = '';
          if(val == 'true'){ paystatus = 'Completed' };
           var FormTag = '{!JSENCODE(FormTag)}';
                  
          if((paystatus == 'Completed' || paystatus == 'SuccessWithWarning') && (FormTag == '')){
              Back2Order();
          }   
          
          else if((paystatus == 'Completed' || paystatus == 'SuccessWithWarning')){
                closepopup(val)
          } 
      }     
      
      function closepopup(val){
        var FormTag = '{!JSENCODE(FormTag)}';
        var textBox = '{!JSENCODE(TextBox)}';
        var textBoxId = '{!JSENCODE(TextBox)}' + '_lkid';
        var currentSalesorderId = '{!JSENCODE(currentSalesorder.Id)}';
        var currentSalesorderName = '{!JSENCODE(currentSalesorder.Name)}';
        top.window.opener.lookupPick2(FormTag, textBoxId, textBox, currentSalesorderId, currentSalesorderName, false);
      }
  </script> 
