<apex:page standardController="Product2" docType="html-5.0" sidebar="false" showHeader="false">
    <apex:includeLightning />

    
    <script>
    
        var barvalue = '{!JSENCODE($CurrentPage.Parameters.Code)}';
        var barType = '{!JSENCODE($CurrentPage.Parameters.Type)}';
        var barId = 'brCode';
        
        if(barvalue == undefined || barvalue == '' || barvalue == null) barvalue = "{!JSENCODE(Product2.Barcode__c)}";
        if(barType == undefined || barType == '' || barType == null) barType = "{!JSENCODE(Product2.Barcode_Type__c)}";
        
        if(barType == "code128" || barType == "code39" || barType == "ean8" || barType == "ean13"){
            
            !$Lightning.use("ERP7:BarcodeLightning", function() {
            !$Lightning.createComponent(
                "ERP7:ACBarcodeZoneLightning",
                {Value: barvalue, BrcdType: barType},
                "Con",
                function(cmp) {
                });
            });
        }
        else if(barType == "qrcode" || barType == "pdf417"){
            
            !$Lightning.use("ERP7:Barcode2DLightning", function() {
            !$Lightning.createComponent(
                "ERP7:AC2DBarcodeZoneLightning",
                {Value: barvalue, BrcdType: barType, D2BarcodeId: barId},
                "Con",
                function(cmp) {
                });
            });
        }
        
    </script>
    <div id="Con"></div>
    
</apex:page>