                                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/whiteloader.gif')}" height="20px;" width="25px;" style="padding-left:5px;"/>
                                            </apex:facet>
                                        </apex:actionStatus></td>
                                   <td width="30%">&nbsp;</td>
                                    
                                </tr>
                            </table>
                        </div>
                    </div>
                </nav>
                
                
                <div class="container" style="font-size:14px;margin-top: 5px;display:{!if(MRPWrapperList.size > 0,'','none')}">
                    
                    <table width="100%" style="display:{!if(!(MRPWrapperList.size > 0),'','none')};margin-top:5px;">
                    <tr><td align="center" valign="top" style="color:red;">{!errMsg}</td></tr>
                    </table>
                    <div class="row erp-box-shadow" style="background:#ffffff;padding:10px;margin-bottom:5px;margin-right:0px;margin-left:0px;">
                    <div class="col-md-12 xs">
                    <table border="0" width="100%" cellpadding="0" cellsapacing="0">
                        <tr>
                            <td align="left">
                                <h5 style="color:#666;line-height:17px;">MRP Name:</h5>
                             </td>
                            <td  align="left">
                                
                                <apex:inputText value="{!mrpName}" style="width:100%" rendered="{!$ObjectType.MRP__c.Fields.Name.Accessible}"/>
                            </td>
                         
                                <apex:outputPanel id="schedules">
                                    
                                        <td  align="right" style="display:{!if(scheduleType=='Production Schedule','','')}">
                                        <h5 style="color:#666;line-height:17px;padding-right: 10px;">&nbsp;Purchase Order:&nbsp;</h5>
                                     </td>
                                    
                                    <td align="left" style="display:{!if(scheduleType=='Production Schedule','','')}">
                                         <apex:inputField value="{!MRP.Purchase_Order__c}" style="width:90%" >
                                          
                                         </apex:inputField>
                                    </td>
                                     <td align="right" style="display:{!if(scheduleType=='Maintenance Schedule','','')}">
                                        <h5 style="color:#666;line-height:17px; padding-right: 10px">&nbsp;Work Order:&nbsp;</h5>
                                     </td>
                                    
                                       <td align="left" style="display:{!if(scheduleType=='Maintenance Schedule','','')}">
                                              <apex:inputField value="{!MRP.Work_Order__c}"  style="width:90%">
                                               
                                             </apex:inputField>  
                                       </td>
                                       <td align="left" style="display:{!if(scheduleType=='Maintenance Schedule','','')}">
                                               <apex:commandButton value="Go" action="{!populateSchedule}" status="spinnerb" reRender="pbk" style="width:80px; height:30px;margin-left:80px;" title="Go"/>
                                       </td>
                                   
                                 </apex:outputPanel>
                          
                        </tr>
                    </table>
                    
                     </div>                    
                </div>
                    
                    <apex:pageBlock title="MRPs Fulfillment" id="pbk">
                       
                      <script>
                            $(document).ready(function() {
                                $('[data-toggle="popover"]').popover();
                            });
            
                            function scrollToCustom(scrolltocusId) {
                                $('html, body').animate({
                                    scrollTop: $(scrolltocusId).offset().top
                                }, 'slow');
                                return false;
                            }
                        </script>
                        <apex:pageBlockButtons style="font-size:13px;">
                            <apex:commandButton value="Save" action="{!save}" style="width:120px; height:30px;" title="Save" reRender="pbk" status="spinnerb" rendered="{!$ObjectType.Stock_Outward_Line_Item__c.Createable && $ObjectType.Stock_Outward_Line_Item__c.Updateable && $ObjectType.MRP__c.Createable && $ObjectType.MRP__c.Updateable}"/>
                            <apex:commandButton value="Create Purchase Order"  action="{!createPO}" style="width:150px; height:30px;" title="Create Purchase Order" rendered="{!$ObjectType.PO__c.Createable && $ObjectType.PO__c.Updateable}"/>
                            <apex:commandButton value="Create Work Order" action="{!createWO}" style="width:150px; height:30px;" title="Create Work Order" rendered="{!$ObjectType.WO__c.Createable && $ObjectType.WO__c.Updateable}"/>
                            <apex:commandButton value="Cancel" action="{!cancel}" style="width:120px; height:30px;" title="Cancel" />
                            
                       </apex:pageBlockButtons>
                        
                        <apex:variable value="{!0}" var="counter"/>
                        
