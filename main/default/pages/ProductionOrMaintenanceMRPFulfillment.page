                                 <apex:variable var="counter" value="{!counter+1}"/>
                             </apex:column>
                             <apex:column >
                                 <apex:facet name="header"><span id="mrp" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('mrp',formatOrd);">MRP &nbsp;<i id="mrpicon" class="fa fa-sort"></i></span></apex:facet>
                                 
                                 <a href="/{!MRPL.MRP.Id}">{!MRPL.MRP.Name}</a>
                            </apex:column>
                            
                             <apex:column headerValue="Preview">
                                <a href="#" onmouseover="" data-toggle="popover" data-trigger="hover" data-placement="bottom" data-html="true" data-content="{!MRPL.MRP.MRP_Product__r.Preview_Image__c}">
                                    <apex:image url="{!MRPL.MRP.MRP_Product__r.Picture__c}" height="40px" width="40px" id="itemimage" />
                                </a>
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header"><span id="prod" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('prod',formatOrd);">Product &nbsp;<i id="prodicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.MRP_Product__c}"/> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header"><span id="ps" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('ps',formatOrd);">Production Schedule &nbsp;<i id="psicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Schedule__c}"/> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header"><span id="po" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('po',formatOrd);">Purchase Order &nbsp;<i id="poicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Purchase_Order__c}"/> 
                            </apex:column>
                            <apex:column >
                                 <apex:facet name="header"><span id="wo" style="cursor:pointer;" title="DESC" onclick="if(this.title == 'ASC') formatOrd = 'DESC'; else formatOrd = 'ASC';sortList('wo',formatOrd);">Work Order &nbsp;<i id="woicon" class="fa fa-sort"></i></span></apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Work_Order__c}"/> 
                            </apex:column>
                             <apex:column >
                                 <apex:facet name="header">Site</apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Sourced_Site__c}"/> 
                            </apex:column>
                            <apex:column >
                                 <apex:facet name="header">Requested</apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Required_Amount__c}"/> 
                            </apex:column>
                            <apex:column >
                                 <apex:facet name="header">Fulfilled</apex:facet>
                                 <apex:outputField value="{!MRPL.MRP.Fulfilled_Amount__c}" styleClass="inputallfields"/> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Required</apex:facet>
                                 <apex:outputText value="{!MRPL.MRP.Required_Amount__c}" styleClass="inputallfields" style="font-weight:bold;"/> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Quantity</apex:facet>
                                    <apex:inputField value="{!MRPL.remainingQuantityMRP.Fulfilled_Amount__c}" styleClass="inputallfields" style="width:100px;display:{!if(MRPL.inStock <= 0,'none','')}" /> 
             
                                   <apex:OutputField value="{!MRPL.remainingQuantityMRP.Fulfilled_Amount__c}" style="width:100px;display:{!if(MRPL.inStock > 0,'none','')}" />
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Stock</apex:facet>
