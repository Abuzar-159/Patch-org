    <script>
        function completeAction(sortby, orderFormat){
            var ik = document.getElementById(sortby); 
            var ikicon = document.getElementById(sortby+'icon');
            
            var kkvalue = sortby;
            var kkval = "";
            if(kkvalue == "mrp") kkval = "MRP";
            else if(kkvalue == "prod") kkval = "Product";
            else if(kkvalue == "ps") kkval = "Production Schedule";
            else if(kkvalue == "ms") kkval = "Maintanance Schedule";
            else if(kkvalue == "po") kkval = "Purchase Order";
            else if(kkvalue == "wo") kkval = "Work Order";
            
            ik.style. fontStyle = "normal";
            ik.style.color = "red";
            ik.style. fontWeight = "bold";
            ik.style.fontFamily = "Arial,Glyphicons Halflings";
             
            if(orderFormat == 'ASC'){ 
                ik.title = 'ASC';
                 ikicon.className = "fa fa-sort-asc";
                
                
            } 
            else { 
                 ikicon.className = "fa fa-sort-desc";
            }
        }
    </script>
    <body>
        <apex:form id="myform">
             
            <apex:actionFunction name="scannerMethod" action="{!scannerMethod}" reRender="mainFrm" status="spinnerb">
                <apex:param name="scannedItem" value="" assignTo="{!barcode}" />
            </apex:actionFunction>
            
             <apex:actionFunction name="evaluate" action="{!processMRPs}" reRender="pbk" status="spinnerb" oncomplete="completeAction('{!sortBy}','{!orderFormat}');">
                <apex:param assignTo="{!counter}" value="" name="counter"/>
            </apex:actionFunction>
            
             <apex:actionFunction name="sortList" action="{!sortList}" reRender="pbk" status="spinnerb" oncomplete="completeAction('{!sortBy}','{!orderFormat}');">
                <apex:param assignTo="{!sortBy}" value="" name="sortBy"/>
                <apex:param assignTo="{!orderFormat}" value="" name="orderFormat"/>
            </apex:actionFunction>
            
            <div id="wrapper" style="margin-top:5px;margin-bottom:5px;">
                 
                 
