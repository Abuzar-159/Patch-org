                                    <tr>
                                        <td align="left" height="15" class="namestxt"></td>
                                    </tr>
                                    <tr>
                                        <td align="center">
                                            <apex:commandButton value=" " onclick="validate();" reRender=";" style="width:130px; height:40px; background:url({!URLFOR($Resource.SCM,'SCM/Images/paynowbtn.png')}) repeat; border:none; color:#fff;" onMouseOver="this.style.background='url({!URLFOR($Resource.SCM,'SCM/Images/paynowbtn.png')})';" onMouseOut="this.style.background='url({!URLFOR($Resource.SCM,'SCM/Images/paynowbtn.png')})';" rendered="{!$ObjectType.Payment__c.Createable && $ObjectType.Payment__c.Updateable}" />
                                            <apex:commandButton value="" action="{!close}" style="width:130px; height:40px; padding-bottom: 15px; background:url({!URLFOR($Resource.SCM,'SCM/Images/closebtn.png')}) repeat; border:none; color:#fff;" immediate="true" onMouseOver="this.style.background='url({!URLFOR($Resource.SCM,'SCM/Images/closebtnh.png')})';" onMouseOut="this.style.background='url({!URLFOR($Resource.SCM,'SCM/Images/closebtn.png')})';" /> </td>
