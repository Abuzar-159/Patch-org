        <apex:actionFunction name="payNow" action="{!Pay}"/>
        <script>
            function validate(){
                var pType = document.getElementById('{!$Component.typepay}').value;
                var bank = document.getElementById('{!$Component.bank}').value;
                var cheque = document.getElementById('{!$Component.cheque}').value;
                if(pType == 'Bank' && bank == '' && cheque == ''){
                    document.getElementById('{!$Component.bank}').style.borderColor = "red";
                    document.getElementById('{!$Component.cheque}').style.borderColor = "red";
                }
                else if(pType == 'Bank' && bank == '' && cheque != ''){
                    document.getElementById('{!$Component.bank}').style.borderColor = "red";
                    document.getElementById('{!$Component.cheque}').style.borderColor = "#DDDDDD";
                }
                else if(pType == 'Bank' && bank != '' && cheque == ''){
                    document.getElementById('{!$Component.bank}').style.borderColor = "#DDDDDD";
                    document.getElementById('{!$Component.cheque}').style.borderColor = "red";
                }
                else payNow();
            }
        </script>
        <style>
            input[type=text],
            textarea,
            select {
                -webkit-transition: all 0.30s ease-in-out;
