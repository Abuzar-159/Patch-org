        </style>
        <script type="text/javascript">
        function doInit() {
            var showIframe = '{!showIframe}';
            console.log('showIframe~>'+showIframe+'typeOf~>'+typeof showIframe);
            
            var val = '{!JSENCODE($currentPage.Parameters.val)}';
            console.log('val in PrintUPSLabel vf~>'+val);
            if(val != null && val != undefined && val != '' && showIframe == 'false'){
                if(val == 'pdf'){
                    printDocument('#fl');
                }
            }
        }
        </script>
    </head>
    
    <body onload="doInit();">
        <apex:form id="mainFrm">
            
            <apex:pageMessages />
            <div class="shadow-custom" style="margin:10px;border-radius:10px;height:750px;">
                <apex:outputPanel rendered="{!if(($CurrentPage.parameters.val == 'pdf' || $CurrentPage.parameters.val == 'nopdf'), false, true)}">
                    <div class="erpmark7"> 
                        <div class="wrapper">
                            <!-- Link Section -->
                            <table border="0" width="100%" cellpadding="1" cellspacing="0">
                                <tr><td>&nbsp;</td></tr>                                
                                <tr>
                                    <td align="center" valign="middle">                                        
                                        <apex:commandLink value="Send Label" action="{!sendLabel}" style="font-size: 16px;color: #2196f3;background: #fff;padding: 12px; border: 1px solid #ddd; border-radius: 10px;text-decoration: none;font-family: Arial;"/> 
                                    </td>
                                </tr>
                                <tr><td>&nbsp;</td></tr>
                            </table>                            
                            <!-- @end of Link Section -->
                            
                            <!-- Recipient Div Section -->
                            <div style="padding:10px;float:left;width:99%;">
                                <div style="width:100%; height:35px;background: #289cf5!important; box-shadow: .3rem .325rem .40rem rgba(0, 0, 0, .075)!important;color:#fff;border-radius:.25rem;" onclick="var element = document.getElementById('{!$Component.MainBlock}'),style = window.getComputedStyle(element),top = style.getPropertyValue('display');if(top =='none'){document.getElementById('{!$Component.MainBlock}').style.display='block'; document.getElementById('offExpand').style.display='none';document.getElementById('onExpand').style.display='block';}else {document.getElementById('{!$Component.MainBlock}').style.display='none';document.getElementById('offExpand').style.display='block';document.getElementById('onExpand').style.display='none';}">
                                    <a href="#" style="text-decoration:none; color:#fff;line-height:0px;padding-left:0px;">
                                        <table border="0" width="100%">
                                            <tr>
                                                <td height="30" align="left" valign="middle" width="3%">
                                                    <img src="{!URLFOR($Resource.SCM,'SCM/Images/plus.png')}" id="offExpand" title="click to Expand" style="display: block;"/>
                                                    <img src="{!URLFOR($Resource.SCM,'SCM/Images/minus.png')}" id="onExpand" style="display:none"/>
                                                </td>                            
                                                <td align="left" valign="middle" width="97%" style="text-decoration:none; color:#fff;">Add Recipients</td>
                                            </tr>
                                        </table>
                                    </a>
                                </div>       
                                
                                <!-- @end of Recipient Div Section -->
                                
                                <!-- Recipient Panel -->
                                <apex:outputPanel id="MainBlock" style="display:none; background:none;">
                                    <apex:pageBlock id="MainPB" tabStyle="Product2">
                                        <table border="0" align="center" width="100%" style="border:0px solid black;" bgcolor="#f9f9f9">
                                            <tr><td>&nbsp;</td></tr>
                                            
                                            <tr style="border-bottom:1px solid black;">
                                                <td>&nbsp;</td>
                                                <th> <apex:outputLabel value="To"/><span style="color:red;">*</span> </th>
                                                <td>
                                                    <apex:input type="email" value="{!toEmail_Address}" style="background : #ffffff; border-radius : 5px; height : 20px; width : 25%; border:1px solid #ddd; padding:5px;"/>
                                                </td>                                            
                                            </tr>
                                            
                                            <tr width="100%">
                                                <td>&nbsp;</td>
                                                <th> <apex:outputLabel value="Cc"/>  </th>
                                                <td>
                                                    <table border="0" cellpadding="0" cellspacing="0"  width="100%">
                                                        <tr>
                                                            <td style="width: 78%;">
                                                                <apex:input type="email" value="{!ccEmail_Addresses}" style="border-radius : 5px; height : 20px; width :97%; border:1px solid #ddd; padding:5px;"/>
                                                            </td>
                                                            <td>
                                                                <div class="" style="position:relative;left:0px;">
                                                                    <span> You can have multiple email addresses with comma separation. </span>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                                <td>&nbsp;</td> 
                                            </tr>
                                            
                                            <tr>
                                                <td>&nbsp;</td>
                                                <th> <apex:outputLabel value="Subject"/> </th>
                                                <td>
                                                    <apex:inputText style="width:510px; border:1px solid #ddd; border-radius: 5px; padding:5px;" value="{!EmailSubject}"/>                                            
                                                </td>
                                            </tr>
                                            
                                            <tr>
                                                <td>&nbsp;</td>
                                                <th style="vertical-align:top;"> <apex:outputLabel value="Email Body"/><span style="color:red;">*</span> </th>
                                                <td>
                                                    <apex:inputTextarea id="editTemplate" value="{!emailBody}" cols="95" rows="12" style="border:1px solid #ddd; border-radius: 5px; padding:5px;"/>
                                                </td>
                                            </tr>
                                        </table>                                    
                                    </apex:pageBlock>                                
                                </apex:outputPanel> <br/> <br/>                            
                                <!-- @end of Recipient Panel -->     
                            </div>                     
                        </div>                    
                    </div>                
                </apex:outputPanel>
                <div style="padding-left:20px;padding-bottom:20px;">
                    <div class="css-square" name="flDiv" id="fl" > <!--  -ms-transform: rotate(90deg); -webkit-transform: rotate(90deg); transform: rotate(90deg); -->
                        <apex:variable value="{!0}" var="count" /> 
                        <apex:outputPanel rendered="{!(showIframe == false)}">  
                            <apex:repeat id="attrep" value="{!attachList}" var="att" > 
                         <!-- Added by shaguftha the style on 31_03_23 o show attachments in different pages -->        
                                <div style="page-break-after: always; margin-top: {!if(count>=1, '20px', '8px;')};"> <!-- margin-top:{!if(count>=1 ,'20px','8px;')};"> page-break-after: {!if(count>=1 ,'always','avoid')};-->
                                    <apex:image rendered="{!NOT(showIframe)}"  
                                                id="attFile" 
                                                url="/servlet/servlet.FileDownload?file={!att.Id}" 
                                                style="{!IF(labelName == 'UPS_Label', $Label.ERP7__UPS_Label_style, $Label.ERP7__Fedex_Label_style_Only_Image)}" 
                                                />

                                </div>
                                <apex:variable value="{!count+1}" var="count"/>
                            </apex:repeat>
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!(showIframe == true)}">
                            <apex:repeat id="attrep2" value="{!attachList}" var="att" rows="1" first="0"> 
                            <div style=""> <!-- margin-top:{!if(count>=1 ,'20px','8px;')};"> page-break-after: {!if(count>=1 ,'always','avoid')};-->
                                 <apex:iframe rendered="{!showIframe}" id="attFilepdf" src="/servlet/servlet.FileDownload?file={!att.Id}" width="100%" height="600px"/> <!--margin: 10px 10px auto; width: 250px; height: 200px; style="width: 590px; height: 340px;" -ms-transform: rotate(90deg); -webkit-transform: rotate(90deg); transform: rotate(90deg);"/> -->
                            </div>
                            <apex:variable value="{!count+1}" var="count"/>
                            </apex:repeat>
                        </apex:outputPanel>
                    </div>
                </div>
            </div>
            <script>
            function printDocument(selector) {
                print();
            }
            </script>
            
        </apex:form>
    </body>
    
</apex:page>