<apex:page controller="OutboundLogistics" sidebar="false" standardStylesheets="false" applyBodyTag="false" showHeader="false" id="mainPg" renderAs="pdf">
    
    <head>
        <style type="text/css" media="print">
        @page {
            size: 4in 6in;
            @top-center {
                content: element(header);
            }
            @bottom-left {
                content: element(footer);
            }
        }
        
        div.header {
            padding: 5px;
            position: running(header);
        }
        
        div.footer {
            display: block;
            padding: 5px;
            position: running(footer);
        }
        
        .pagenumber:before {
            content: counter(page);
        }
        
        .pagecount:before {
            content: counter(pages);
        }

        </style>
        <style>
            @page {
            //size: 8.27in 11.69in;
            size: 6in 4in;
            margin: 25mm;
            color: #f9f9f9;
            .italicText {
                font-style: Bold;
                font-size: 1.2em;
                font-family: Arial, Helvetica, sans-serif;
                text-decoration: none;
                color: #ff0000;
            }
            .headerText {
                font-weight: bold;
                font-size: 1.8em;
                text-align: center;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }
            .NoteText {
                font-weight: bold;
                font-size: 1.8em;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }

        </style>
    </head>        
    
    <apex:form >
        <div class="header">
            <div style="color:#cccccc; text-align:right;">{!PB.headVal}</div>
        </div>
        <div class="footer">
            <div style="color:#cccccc; text-align:center;">Page <span class="pagenumber" /> of <span class="pagecount" /></div>
        </div>
        <div class="content">
            <apex:repeat value="{!packageRecords}" var="s">
                <div style="page-break-after: always; width:283px; min-height:425px; float:left; height:auto; border:0px solid #dddddd; border-radius:5px; padding:0px; padding-top:20px;">
                    <div>
                        <div style="color:#333; font-size:18px;padding-top:10px;padding-left:10px;font-family: sans-serif, arial;">
                            Package Number:
                        </div>
                        <div style="color:#333; font-size:20px; font-weight:bold;padding-left:10px;font-family: sans-serif, arial;"> 
                            {!s.Name__c}
                        </div><br/>
                        <div style="color:#333; font-size:18px; padding-left:10px;font-family: sans-serif, arial;">
                            Customer:<strong> {!s.ERP7__Logistic__r.Account__r.Name}</strong>
                        </div>
                        <div style="color:#333; font-size:14px; padding-left:10px;margin-top:20px;font-family: sans-serif, arial;">
                            <strong> Shipping to: </strong> <br/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line1__c}<br/>" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line1__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line2__c}<br/>" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line2__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line3__c}<br/>" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Address_Line3__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.City__c}, " escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.City__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.State__c}<br/>" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.State__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Postal_Code__c}, " escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Postal_Code__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Country__c}<br/>" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Country__c != null, true, false)}"/>
                            <apex:outputText value="{!s.ERP7__Logistic__r.ERP7__To_Address__r.Contact__r.Phone}" escape="false" rendered="{!if(s.ERP7__Logistic__r.ERP7__To_Address__r.Contact__r.Phone != null, true, false)}"/>
                        </div>
                        <div style="color:#333; font-size:14px; padding-left:10px;margin-top:20px;font-family: sans-serif, arial;">     
                            <strong> Packed By: </strong> {!s.Owner.Name} <br/>
                            <strong> Date Packed: </strong> <apex:outputText value="{0,date, dd/MM/yyyy}">
                                                                <apex:param value="{!s.CreatedDate}"/>
                                                            </apex:outputText> <br/>
                            <strong> Weight: </strong> {!s.Weight__c} <br/>
                        </div> 
                        <div style="color:#333; font-size:12px; text-align:center; padding-left:0px;margin-top:20px;font-family: sans-serif, arial;">  
                            <apex:outputPanel rendered="{!if(s.Barcode__c != null, true, false)}">
                                <c:AQBarcodeZone id="brcd128" BrcdHeight="35" BrcdType="{!'code128'}" Value="{!s.Barcode__c}">
                                </c:AQBarcodeZone>
                            </apex:outputPanel>
                        </div>                    
                    </div>
                </div>
            </apex:repeat>
        </div>        
    </apex:form>    
    
</apex:page>