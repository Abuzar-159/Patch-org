                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.Address_Line1__c)}<br/>" escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.Address_Line1__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.Address_Line2__c)}<br/>" escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.Address_Line2__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.Address_Line3__c)}<br/>" escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.Address_Line3__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.City__c)}, " escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.City__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.State__c)}<br/>" escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.State__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.Postal_Code__c)}, " escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.Postal_Code__c != null, true, false)}"/>
                                                 <apex:outputText value="{!HTMLENCODE(sos.RMA.SO__r.Ship_To_Address__r.Country__c)}" escape="false" rendered="{!if(sos.RMA.SO__r.Ship_To_Address__r.Country__c != null, true, false)}"/>             
                                             </apex:outputPanel>                                                     
                                        </td> 
                                        <td data-label="Track No">
                                            <div style="min-height: 10px; max-height: 100px; overflow-y : auto; width:100%; float:left;font-size:13px;">
                                                <apex:outputText value="{!sos.trackingNo}" escape="false"/>
                                            </div>                                                                
                                        </td>
                                        <td data-label="Action">
                                            <span class="slds-truncate"> 
                                                <i class="fa fa-shopping-cart" aria-hidden="true" style="color:#666666;display:{!if(sos.RMA.Total_Quantity__c > 0 && sos.RMA.Picked_Quantity__c == 0.00,'','none')}"></i>
                                                <i class="fa fa-shopping-cart" aria-hidden="true" style="color:#fe8f60;display:{!if(sos.RMA.Total_Quantity__c > 0 && sos.RMA.Picked_Quantity__c > 0 && sos.RMA.Picked_Quantity__c < sos.RMA.Total_Quantity__c,'','none')}"></i>
                                                <i class="fa fa-shopping-cart" aria-hidden="true" style="color:#0dc2d9;display:{!if(sos.RMa.Total_Quantity__c > 0 && sos.RMA.Total_Quantity__c == sos.RMA.Picked_Quantity__c,'','none')}"></i>
                                                &nbsp;<apex:outputText value="Pick" rendered="{!if(sos.RMA.Total_Quantity__c == sos.RMA.Picked_Quantity__c,true,false)}" style="color: #337ab7;"/>
                                                <apex:commandLink value="Pick" action="{!redirect2NextTab}" rendered="{!if(sos.RMA.Total_Quantity__c == sos.RMA.Picked_Quantity__c,false,true)}">
                                                    <apex:param name="soId" value="{!sos.RMA.Id}" assignTo="{!salesreturnId}"/>
                                                </apex:commandLink>&nbsp;&nbsp;
                                                
                                                <i class="fa fa-archive" aria-hidden="true" style="color:#666666;display:{!if(sos.RMA.Total_Quantity__c > 0 && sos.RMA.Packed_Quantity__c == 0.00,'','none')}"></i>
                                                <i class="fa fa-archive" aria-hidden="true" style="color:#fe8f60;display:{!if(sos.RMA.Total_Quantity__c > 0 && sos.RMA.Packed_Quantity__c > 0 && sos.RMA.Packed_Quantity__c < sos.RMA.Total_Quantity__c,'','none')}"></i>
                                                <i class="fa fa-archive" aria-hidden="true" style="color:#0dc2d9;display:{!if(sos.RMA.Total_Quantity__c > 0 && sos.RMA.Total_Quantity__c == sos.RMA.Packed_Quantity__c,'','none')}"></i>
                                                &nbsp;<apex:outputText value="Pack" rendered="{!if(sos.isAvailablePackages == false, true, false)}" style="color: #337ab7;"/>
                                                <apex:commandLink value="Pack" action="{!createPacks}" rendered="{!if(sos.isAvailablePackages == false, false, true)}">
                                                    <apex:param name="soId" value="{!sos.RMA.Id}" assignTo="{!salesreturnId}"/>
                                                </apex:commandLink>&nbsp;&nbsp;
                                                
                                                <i class="fa fa-plane" aria-hidden="true" style="color:#666666;display:{!if(sos.isAvailableShipments == false,'','none')}"></i>
                                                <i class="fa fa-plane" aria-hidden="true" style="color:#fe8f60;display:{!if(sos.isAvailableShipments == true && sos.isAllShipmentsDelivered == false,'','none')}"></i>
                                                <i class="fa fa-plane" aria-hidden="true" style="color:#0dc2d9;display:{!if(sos.isAllShipmentsDelivered == true,'','none')}"></i>                                            
                                                &nbsp;<apex:outputText value="Ship" rendered="{!if(sos.isAvailableShipments == false, true, false)}" style="color: #337ab7;"/>                    
                                                <apex:commandLink value="Ship" action="{!createShipments}" rendered="{!if(sos.isAvailableShipments == false, false, true)}">
                                                    <apex:param name="soId" value="{!sos.RMA.Id}" assignTo="{!salesreturnId}"/>
                                                </apex:commandLink>
                                            </span>
                                        </td> 
                                    </tr>
                                    <apex:variable var="SRCounter" value="{!SRCounter + 1}"/>                          
                                    </apex:repeat>
                                </tbody>                                                
                            </table>                            
                        </apex:outputPanel>                        
                    </div>                    
               </div>               
           </div>
        </apex:form> 
    </body>
     
    <script>
        function setFocus() {}

        function checkAll1(cb) {
            var inputElem = document.getElementsByTagName("input");
            for (var i = 0; i < inputElem.length; i++) {
                if (inputElem[i].id.indexOf("checkedone1") != -1) {
                    inputElem[i].checked = cb.checked;
                }
            }
        }

        function uncheckSelectAllBox1(flag) {
            var selectAllFlag = document.getElementById('{!$Component.mainPg.mainFrm.selectAll1}').checked;
            if (!flag) document.getElementById('{!$Component.mainPg.mainFrm.selectAll1}').checked = false;
        }
    </script>

    </html>        
</apex:page>