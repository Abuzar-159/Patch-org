<apex:page controller="StockTakeDoc" sidebar="false" showHeader="false" id="mainPg" action="{!createPDF}"> 
    <apex:includeScript value="{!URLFOR($Resource.Barcode_Scanner_JS)}" />
    <head>  
        <style>
            /*.wrapper {
            width:800px;
            margin:50px auto 50px;
            box-shadow: 1px 3px 10px 2px rgb(0 0 0 / 5%);
            padding: 10px;
            border-radius: 10px;
            }  */     
        </style>
        <script>
        var $j = jQuery.noConflict();
        $j(document).ready(function() {
            setTimeout(function(){
                window.print();},1000);
            //window.print();
        });
        </script>
        
    </head>
    <body>
        <div class="wrapper" >
            <div>
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td style="font-family:'Open Sans',sans-serif;font-size:22px;color:#757575;padding:5px;text-align:center">{!$Label.stock_take_document}</td>
                    </tr>
                </table>
            </div>
           
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                 <apex:outputPanel rendered="{!ShowOrgDetails}">
                    <td width="60%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px"><strong style="font-size:16px"><apex:outputText id="Org1" value="{!$Organization.Name}" /></strong><br/>
                        <apex:outputText id="Org2" value="{!$Organization.Street}" />&nbsp;
                        <apex:outputText id="Org3" value="{!$Organization.City}" />&nbsp;
                        <apex:outputText id="Org4" value="{!$Organization.State}" /> <br/>
                        <apex:outputText id="Org5" value="{!$Organization.Country}" /> <br/>
                        <apex:outputText id="Org6" value="{!$Organization.Phone}" /><br/>
                        <apex:outputText id="Org7" value="{!$Organization.Fax}" />
                    </td>
                    </apex:outputPanel>
                    <td width="40%" align="left">
                        <apex:image url="{!imageURl}" height="70" width="190" />
                    </td>
                   
                </tr>
            </table>
            
            <apex:outputPanel rendered="{!if(stockTake.Id != null, true, false)}">
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td width="60%">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px;vertical-align: top;"><strong>{!$Label.Storage_Location}</strong><br/>
                                        <apex:outputPanel rendered="{!if(stockTake.Site__c != null, true, false)}">
                                            <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.Address__c != null, true, false)}">
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Contact__c != null, true, false)}">
                                                    <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Contact__r.Name != null, true, false)}">
                                                        {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Contact__r.Name}<br/>
                                                    </apex:outputPanel>
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Customer__c != null, true, false)}">
                                                    <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Customer__r.Name != null, true, false)}">
                                                        {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Customer__r.Name} <br/>
                                                    </apex:outputPanel>
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Address_Line1__c != null, true, false)}">
                                                {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Address_Line1__c}&nbsp;
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Address_Line2__c != null, true, false)}">
                                                {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Address_Line2__c}&nbsp;
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Address_Line3__c != null, true, false)}">
                                                {!stockTake.ERP7__Site__r.ERP7__Address__r.Address_Line3__c} <br/>
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.City__c != null, true, false)}">
                                                {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__City__c}&nbsp;
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Postal_Code__c != null, true, false)}">
                                                {!stockTake.ERP7__Site__r.ERP7__Address__r.Postal_Code__c} <br/>  
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.State__c != null, true, false)}">
                                                    {!stockTake.ERP7__Site__r.ERP7__Address__r.State__c} 
                                                    <br/>
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Country__c != null, true, false)}">
                                                    {!stockTake.ERP7__Site__r.ERP7__Address__r.Country__c}<br/>
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.Contact__c != null, true, false)}">
                                                    <apex:outputPanel rendered="{!if(stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Contact__r.Phone != null, true, false)}">
                                                        {!stockTake.ERP7__Site__r.ERP7__Address__r.ERP7__Contact__r.Phone}   
                                                    </apex:outputPanel>
                                                </apex:outputPanel>
                                            </apex:outputPanel>
                                        </apex:outputPanel>
                                    </td>
                                    <td width="32%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px;vertical-align: top;">
                                        
                                    </td>
                                    <td width="2%"> </td>
                                </tr>
                            </table> 
                         
                        
                        </td>
                        <td width="40%">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td width="76%" height="20" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.StockTakeName} : </strong>
                                        <apex:outputText >{!stockTake.Name}&nbsp;<wbr/> </apex:outputText>
                                    </td>
                                    
                                </tr>
                                <tr>
                                    <td width="76%" height="20" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.Created_Date} </strong>
                                        <apex:outputPanel rendered="{!if(stockTake.Start_Date__c != null, true, false)}">
                                        <apex:outputText value="{0,date,MM/dd/yy}">
                                            <apex:param value="{!stockTake.Start_Date__c}" />  
                                        </apex:outputText>&nbsp;
                                        </apex:outputPanel>
                                    </td>
                                   
                                </tr>
                                <tr>
                                    <td width="76%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.Stock_Take_Status} : </strong>
                                        <apex:outputPanel rendered="{!if(stockTake.Status__c != null, true, false)}">
                                        <apex:outputText >{!stockTake.ERP7__Status__c}&nbsp;</apex:outputText>
                                        </apex:outputPanel>
                                    </td>
                                    
                                </tr>
                                <tr>
                                    <td width="76%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.Stock_Take_total_items} : </strong>
                                        <apex:outputText rendered="{!if((stockTake.Line_Item_Count__c != null),true,false)}" value="{0, number, ###,##0}">
                                            <apex:param value="{!stockTake.Line_Item_Count__c}"/>
                                        </apex:outputText>
                                        <apex:outputText rendered="{!if((stockTake.Line_Item_Count__c != null),false,true)}">
                                            0
                                        </apex:outputText>
                                    </td>
                                    
                                </tr>
                                <tr>
                                    <td width="76%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.Stock_Take_Approver} : </strong>
                                        <apex:outputPanel rendered="{!if(and(approvers != null,approvers != ''), true, false)}">
                                            <apex:outputText >
                                                {!approvers}&nbsp;
                                            </apex:outputText>
                                        </apex:outputPanel>
                                        <apex:outputPanel rendered="{!if(and(stockTake.Approver__c != null,approvers == null), true, false)}">
                                            <apex:outputText >
                                                {!stockTake.ERP7__Approver__r.Name}&nbsp;
                                            </apex:outputText>
                                        </apex:outputPanel>
                                    </td>
                                    
                                </tr>
                                 <tr>
                                    <td width="76%" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px">
                                        <strong>{!$Label.Stock_Take_Approved_Date} : </strong>
                                        <apex:outputPanel rendered="{!if(stockTake.Approver__c != null, true, false)}">
                                       <apex:outputText value="{0,date,MM/dd/yy}">
                                            <apex:param value="{!stockTake.Approved_Date__c}" />  
                                        </apex:outputText>&nbsp;
                                          <!--  <apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!stockTake.Approved_Date__c}" />&nbsp;</apex:outputText>-->
                                        </apex:outputPanel>
                                    </td>
                                    
                                </tr>
                            </table>
                            
                        </td>
                    </tr>
                </table>
               
                
            </table>
            
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                    <td height="10" style="font-family:'Open Sans',sans-serif;font-size:14px;color:#757575;padding:5px"></td>
                </tr>
                <tr style="background:#dddddd">
                    <td style="font-family:'Open Sans',sans-serif;font-size:14px; font-weight:bold;padding:5px;text-align:center;text-transform:uppercase;border:1px solid #333;border-bottom:0px solid #333;">{!$Label.Stock_Take_Line_Items}</td>
                </tr>
            </table>
            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border-color: #333">
                <thead>
                    <tr style="background:#f7f7f7">
                        <th style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-left:1px solid #333; border-right:1px solid #333; border-top:1px solid #333;border-bottom:1px solid #333;" width="5%">S.No</th>
                        <th width="25%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Stock_Take_Product}</th>
                        <th width="14%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Serial}</th>
                        <th width="14%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Lot}</th>
                        <th width="10%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Stock}<br/> {!$Label.Available}</th>
                        <th width="10%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Variance}</th>
                         <th width="14%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Stock}<br/> {!$Label.Stock_Take_In_Hand}</th>
            
                        <apex:outputPanel rendered="{!ShowAdjustedQty}">
                            <th width="10%" style="font-family:'Open Sans',sans-serif;font-size:12px;color:#333333;padding:5px;text-align:left;vertical-align:top;border-right:1px solid #333; border-bottom:1px solid #333; border-top:1px solid #333;">{!$Label.Adjusted_Qty}</th>
                        </apex:outputPanel>
                    </tr>
                </thead>
                <tbody>
                    <apex:variable var="stliCounter" value="{!1}" />
                    <apex:repeat value="{!STLI}" var="item" id="loItem">
                        <tr>
                            <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px;text-align:left;border-left:1px solid #333; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                {!stliCounter}
                            </td>
                            <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                {!item.ERP7__Product__r.Name} {!item.ERP7__Product__r.ProductCode}
                            </td>
                            <td style="font-family: 'Open Sans', sans-serif;font-size:12px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.ERP7__Product__r.Serialise__c && item.Serial__c != null),true,false)}" style="text-decoration:none !important;"  >
                                    {!item.ERP7__Serial__r.Serial_Number__c} 
                                </apex:outputText>
                            </td>
                            <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.ERP7__Product__r.Lot_Tracked__c && item.Material_Batch_Lot__c != null),true,false)}" style="text-decoration:none !important;"  >
                                    {!item.ERP7__Material_Batch_Lot__r.Name}
                                </apex:outputText>
                            </td>
                           
                            
                             
                            <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.Stock_Available__c != null),true,false)}" value="{0, number, ###,##0}">
                                    <apex:param value="{!item.Stock_Available__c}"/>
                                </apex:outputText>
                                <apex:outputText rendered="{!if((item.Stock_Available__c != null),false,true)}">
                                    0
                                </apex:outputText>
                            </td>  
                             <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.Variance__c != null),true,false)}" value="{0, number, ###,##0}">
                                    <apex:param value="{!item.Variance__c}"/>
                                </apex:outputText>
                                <apex:outputText rendered="{!if((item.Variance__c != null),false,true)}">
                                    0
                                </apex:outputText>
                            </td>
                             <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.Stock_In_Hand__c != null),true,false)}" value="{0, number, ###,##0}">
                                    <apex:param value="{!item.Stock_In_Hand__c}"/>
                                </apex:outputText>
                                <apex:outputText rendered="{!if((item.Stock_In_Hand__c != null),false,true)}">
                                    0
                                </apex:outputText>
                            </td>
                            <apex:outputPanel rendered="{!ShowAdjustedQty}">
                            <td style="font-family: 'Open Sans', sans-serif;font-size:10px;color:#333333;padding:5px; border-right:1px solid #333; border-top:0px solid #333;border-bottom:1px solid #333;">
                                <apex:outputText rendered="{!if((item.Adjusted_Quantity__c != null),true,false)}" value="{0, number, ###,##0}">
                                    <apex:param value="{!item.Adjusted_Quantity__c}"/>
                                </apex:outputText>
                                <apex:outputText rendered="{!if((item.Adjusted_Quantity__c != null),false,true)}">
                                    0
                                </apex:outputText>
                            </td>
                            </apex:outputPanel>
                        </tr>
                        <apex:variable var="stliCounter" value="{!stliCounter+1}" />
                    </apex:repeat>
                </tbody>
            </table>
            </apex:outputPanel>
        </div>
    </body>
</apex:page>