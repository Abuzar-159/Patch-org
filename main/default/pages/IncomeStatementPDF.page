<apex:page controller="IncomeStatement"  standardStylesheets="false"  sidebar="false" renderAs="pdf" >
    
    <apex:form id="MainForm" acceptcharset="utf-8" >
        <div style="text-align:center;font-family:Arial, Helvetica, sans-serif; font-size:12px;border:0px solid #ececec;">
            <span style="font-family:Arial, Helvetica, sans-serif; font-size:15px;"><apex:outputField value="{!Select_Organisation.Organisation__c}" /></span> <br/>
            <span style="font-family:Arial, Helvetica, sans-serif; font-size:16px;"><apex:outputText value="Income Statement"/></span><br/>
            
            
            <span style="font-family:Arial, Helvetica, sans-serif; font-size:16px;font-weight:bold;">
                <apex:outputText value=" {0,date,MMMM d, yyyy}">
                    <apex:param value="{!EDate}"/>
                </apex:outputText>
            </span>
        </div>
        <br/>            
        
        <apex:outputPanel rendered="{!incomeList!=null}"> 
            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                    <tr style="background:#0270d3;">
                        <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;" >
                            Net Sales
                        </td>
                    </tr>
                </table>
                
                <apex:outputPanel rendered="{!incomeList!=null}"> 
                    <apex:repeat value="{!incomeList}" var="Fysubacc">
                        <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                            <td width="1%">&nbsp;</td>
                                    <td width="40%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">{!Fysubacc['AccountName']}
                                    </td>
                                    <td  class="assets-text" width="59%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                        {!checkCurrency.userISO}&nbsp;{!(Fysubacc['Credit']-Fysubacc['Debit'])}
                                        <apex:param value="{!(Fysubacc['Debit']-Fysubacc['Credit'])*checkCurrency.conversionRate}"/>
                                        
                                    </td>
                        </table>
                    </apex:repeat>
                </apex:outputPanel>
                
                <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">                 
                    <tr>
                        <td width="1%">&nbsp;</td>
                        <td width="40%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;" class="assets-text">
                            <strong>Total Operating Income
                            </strong> 
                        </td>
                        <td  class="assets-text" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                            {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}">
                            <apex:param value="{!totalIncome*checkCurrency.conversionRate}"/>
                            </apex:outputText>
                        </td>
                    </tr>
                </table>  
        </apex:outputPanel>
        
        
        <apex:outputPanel rendered="{!ExpenseList!=null}"> 
            <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                    <tr style="background:#0270d3;">
                        <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;" >
                            Expense
                        </td>
                    </tr>
                </table>
                
                <apex:outputPanel rendered="{!ExpenseList!=null}"> 
                    <apex:repeat value="{!ExpenseList}" var="Fysubacc">
                        <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">
                            <td width="1%">&nbsp;</td>
                                    <td width="40%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">{!Fysubacc['AccountName']}
                                    </td>
                                    <td  class="assets-text" width="59%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                                        {!checkCurrency.userISO}&nbsp;{!(Fysubacc['Debit']-Fysubacc['Credit'])}
                                        <apex:param value="{!(Fysubacc['Debit']-Fysubacc['Credit'])*checkCurrency.conversionRate}"/>
                                        
                                    </td>
                        </table>
                    </apex:repeat>
                </apex:outputPanel>
                
                <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;">                 
                    <tr>
                        <td width="1%">&nbsp;</td>
                        <td width="40%" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;" class="assets-text">
                            <strong>Total Operating Expense
                            </strong> 
                        </td>
                        <td  class="assets-text" style="border: 0px solid #ffffff; font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                            {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}">
                            <apex:param value="{!totalExpense*checkCurrency.conversionRate}"/>
                            </apex:outputText>
                        </td>
                    </tr>
                </table>  
        </apex:outputPanel>
        
        
        
        <table class="table table-bordered" border="0" width="100%" style="margin-left:0%;"> 
            <tr style="background:#4cca81;">
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;"> Net Profit
                </td>
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px;">
                    =
                </td>
                <td style="background:#4cca81; color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                    Total Revenue
                </td>
                
                <td style="background:#4cca81;color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px;">
                    -
                </td>
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                    Total Expense  
                </td>
            </tr>
            <tr style="background:#4cca81;">
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                    {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}" id="netprofit" ><apex:param value="{!(totalIncome-totalExpense)*checkCurrency.conversionRate}" /></apex:outputText>
                </td>
                <td>
                </td>
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                    {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}" id="totalRev" ><apex:param value="{!totalIncome*checkCurrency.conversionRate}"/></apex:outputText>
                </td>
                <td> <h5 class="top-texttb" style="line-height: 28px;"></h5></td>
                <td style="color:#ffffff;vertical-align: middle;font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px;">
                    {!checkCurrency.userISO}&nbsp;<apex:outputText value="{0, number, ###,###,###,##0.00}"  id="totalExp" ><apex:param value="{!totalExpense*checkCurrency.conversionRate}"/></apex:outputText>
                </td> 
            </tr>
        </table>
    </apex:form>
</apex:page>