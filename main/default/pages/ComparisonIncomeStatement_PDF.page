                                        <td  style=" font-weight:bold;text-align:right;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text" colspan="1" >
                                                                                                                               
                                        </td>
                                    </apex:repeat>
                                </apex:repeat>
                            </apex:repeat>
                            <!--End of Tabular data Header-->
                        </tr>
                    </thead>
