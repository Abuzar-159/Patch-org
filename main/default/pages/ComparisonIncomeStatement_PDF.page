                                                {!checkCurrency.userISO}<apex:param value="{!tval.ERP7__Amount__c*checkCurrency.conversionRate}" />
                                                </apex:outputText>
                                                )
                                                </apex:outputText>
                                            </td>
                                        </apex:repeat>
                                    </apex:repeat>
                                </apex:repeat>
                            </tr>
                        </apex:repeat>
