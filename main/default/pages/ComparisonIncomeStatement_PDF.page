<apex:page controller="IncomeStatement" standardStylesheets="false"  sidebar="false" renderAs="pdf"><!--renderAs="pdf"-->
    
     
    
        <div style="text-align:center;">
            <span style="text-decoration:none !important;font-size:15px;font-family:Arial, Helvetica, sans-serif;"><apex:outputField value="{!Select_Organisation.Organisation__c}" style="text-decoration: none !important;" /></span>
            <br/>
           <span style="font-family:Arial, Helvetica, sans-serif; font-size:15px;"> <apex:outputText value="Income Statement"/></span>
            <br/>
          <span style="font-family:Arial, Helvetica, sans-serif; font-size:15px;font-weight:bold;">   <apex:outputText value=" {0,date,MMMM d, yyyy}">
                <apex:param value="{!EDate}"/>
            </apex:outputText></span>
        </div>
        <br/>
       
     <div class="slds-card">
        <div class="slds-card__body">
            <table class="slds-table slds-no-row-hover" style="width:100%;">
                <tr >
                    <td  colspan="3" style="text-align:left; color:#ffffff;background:#434343;padding:5px;font-family:Arial, Helvetica, sans-serif;font-size:14px;" class="assets-text cfd-tabs">
                        Financial year
                    </td>
                </tr>
            </table>
            <apex:outputPanel id="tabularSecpnl">
                <!--Start of Tabular data Header-->
                <table class="slds-table  slds-table--bordered slds-row-hover" style="width:100%;">
                    <thead>
                        <tr style="border-bottom:3px solid #ffffff; display:{!if(ShowFyWise,'','none')}">
                            <td width="30%"></td>
                            <!--<apex:outputPanel id="YearWise" style="display:{!if(ShowFyWise,'','none')}"><!--rendered="{!ShowFyWise}"-->
                            <apex:repeat value="{!FinancialAccountIncomeStmt}" var="sFyear" rows="1">
                                <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear]}" var="sFname" >
                                    <td style="font-weight:bold;text-align:right;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text">
                                        <apex:outputPanel >{!sFname}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                            </apex:repeat>
                            <!--   </apex:outputPanel>-->
                        </tr>
                        <!--<apex:outputPanel rendered="{!ShowQuartely}">-->
                        <tr style="display:{!if(ShowQuartely,'','none')}">
                            <td width="30%" ></td>
                            <apex:repeat value="{!FinancialAccountIncomeStmt}" var="sFyear" rows="1">
                                <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear]}" var="sFname" >
                                    <td  style=" font-weight:bold;text-align:center;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text"  colspan="4">
                                        <apex:outputPanel >{!sFname}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                            </apex:repeat> 
                        </tr>
                        <tr style="display:{!if(ShowMonthly,'','none')}">
                            <td width="30%"></td>
                            <apex:repeat value="{!FinancialAccountIncomeStmt}" var="sFyear" rows="1">
                                <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear]}" var="sFname" >
                                    <td  style=" font-weight:bold;text-align:center;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text"  colspan="12">
                                        <apex:outputPanel >{!sFname}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                            </apex:repeat>
                            <!-- 
                                </apex:outputPanel>-->
                        </tr>
                        <tr style="display:{!if(ShowFyWise == true,'','none')}">
                            <td width="30%"></td>
                            <apex:repeat value="{!FinancialAccountIncomeStmt}" var="sFyear" rows="1">
                                <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear]}" var="sFname" >
                                    <td style="font-weight:bold;text-align:right;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text"> 
                                    </td>
                                </apex:repeat>
                            </apex:repeat>
                        </tr>
                        <tr style="display:{!if(ShowQuartely == true,'','none')}">
                            <td width="30%"></td>
                            <apex:repeat value="{!FinancialAccountIncomeStmt}" var="sFyear1" rows="1" rendered="{!ShowQuartely}">
                                <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear1]}" var="sFname" >
                                    <apex:repeat value="{!FinancialAccountIncomeStmt[sFyear1][sFname]}" var="sFq" >
                                        <td  style="font-weight:bold;text-align:right;font-family:Arial, Helvetica, sans-serif;font-size:12px;" class="assets-text"  >
                                            {!IntegerToQuarterName[sFq]}
                                        </td>
                                    </apex:repeat>
                                </apex:repeat>
                            </apex:repeat>
                        </tr>
