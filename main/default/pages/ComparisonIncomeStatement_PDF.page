                                                <!-- {!tval} -->
                                                <!--<apex:outputText value="({0, number, ###,###,###,##0.00})">
                                                    <apex:param value="{!tval.ERP7__Amount__c}"/> 
                                                </apex:outputText>-->
                                                <apex:outputText rendered="{!tval.ERP7__Amount__c==0}">
                                                    <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                        {!checkCurrency.userISO}<apex:param value="{!tval.ERP7__Amount__c*checkCurrency.conversionRate}" />
                                                    </apex:outputText>
                                                </apex:outputText>
                                                <apex:outputText rendered="{!tval.ERP7__Amount__c>0}">
                                                    <apex:outputText value="{0, number, ###,###,###,##0.00}">
