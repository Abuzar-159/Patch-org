                                <div class="container-fluid">
                                    <div class="slds row slds-p-top--xx-small">

                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                    <apex:inputField style="height: 32px;border-radius: 0px;" value="{!voucher.Vendor__c}" id="VendorName" html-placeholder="Select Vendor" onchange="on_change()" />
                                                   

                                                </div>
                                            </div>
                                        </div>
                                        <apex:outputPanel id="showCredits" rendered="{!if(voucher.Vendor__c != null,true,false)}">
                                            <div class="col-md-3 slds-p-top--xx-small">
                                                <apex:outputText value="Total Credit&#39;s Available" escape="false" /><br/>
                                                <apex:outputField value="{!vendorInfo.ERP7__Credit_Balance__c }" />
                                            </div>
                                            <div class="col-md-3 slds-p-top--xx-small">
                                               <apex:commandLink styleClass="slds-button slds-button--brand" value="Apply Credits" reRender=";" onclick="showModal('CreditModal');"/>
                                            </div>
                                        </apex:outputPanel>
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                        <br/>
                        <div class="slds-theme--info slds-m-top--x-small  slds-p-top--xxx-small slds-p-left--xx-small" style="margin-top:0px;height:30px">
                            Item Details
                        </div>
                        <apex:outputPanel id="BillList">
                            <apex:variable var="counter" value="{!0}" />
                            <apex:dataTable value="{!Bill_WrapList}" var="b" id="bill_tbl" styleClass="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <apex:column >
                                    <apex:facet name="header">
                                        <apex:inputCheckbox id="selectAll" title="Pay All" value="{!selectAll}" onchange="selectAll();" /> </apex:facet>
                                    <apex:inputCheckbox id="checkbox" value="{!b.isSelect}" onchange="on_select()" />
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">Voucher ID</apex:facet>
                                    <apex:outputField value="{!b.voucher.Name}" />
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">VENDOR </apex:facet>
                                    <apex:outputField value="{!b.voucher.Vendor__r.Name}" />
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">BILL# </apex:facet>
                                    <apex:outputField value="{!b.voucher.Vendor_invoice_Bill__r.Name}" />
                                    <apex:facet name="footer">Totals </apex:facet>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">Voucher AMT</apex:facet>
                                    <apex:outputField value="{!b.voucher.Total_Amount__c}" />
                                    <apex:facet name="footer">
                                        <apex:outputField value="{!voucher.Total_Amount__c}" /></apex:facet>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">AMT DUE</apex:facet>
                                    <apex:outputField value="{!b.voucher.Amount_Due__c}" />
                                    <apex:facet name="footer">
                                        <apex:outputField value="{!voucher.Amount__c}" /></apex:facet>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">
                                        <apex:outputText value="Credit's Used" /></apex:facet>
                                    <apex:outputField value="{!b.voucher.Credit_Used__c}" />
                                    <apex:facet name="footer">
                                        <apex:outputField value="{!voucher.Credit_Used__c}" /></apex:facet>
                                </apex:column>
                                <apex:column >
                                    <apex:facet name="header">AMT TO PAY</apex:facet>
                                    <apex:inputField value="{!b.voucher.Amount__c}" onchange="qtyChange()" />
                                    <apex:facet name="footer">
                                        <apex:outputField value="{!voucher.Amount_Paid__c}" /></apex:facet>
                                </apex:column>

                                <apex:variable var="counter" value="{!counter + 1}" />
                            </apex:dataTable>

                        </apex:outputPanel>
                        <br/>
                        <apex:outputPanel id="showRef">
                            <div class="container-fluid slds-card">
                                <div class="slds row slds-p-top--xx-small">
                                    <div class="col-md-3 slds-p-top--xx-small ">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                             
                                                <strong>Payment Account: </strong>
                                                <apex:inputField value="{!voucher.Payment_Account__c}" id="payAcc" style="" styleClass="slds-input" html-placeholder="Payment Account" onchange="fetchCoa();" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small ">
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right">
                                                <svg aria-hidden="true" class="slds-input__icon slds-icon-text-default" style="margin-top: 0.1rem;">
                                          <use xlink:href="{!URLFOR($Resource.SLDS0121,'/assets/icons/action-sprite/svg/symbols.svg#new_event')}"></use>
                                      </svg>
                                                <strong> Payment Date: </strong>
                                                <apex:inputField value="{!payment.Posted_Date__c}" id="receiveddate" style="" styleClass="slds-input" html-placeholder="Payment Date" />
                                                
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small " style="display:{!if(CONTAINS(paymentAcc.Name,'Cash'),'none','')}">
                                        <div class="slds-form-element">
                                            <strong>Payment Method : </strong>
                                            <apex:inputField value="{!voucher.Payment_Methods__c}" id="paymentMetd" onchange="showRef();" styleClass="slds-select" html-placeholder="Payment Method" rendered="{!if(CONTAINS(paymentAcc.Name,'Cash'),false,true)}" />
                                        </div>
                                    </div>

                                    <div class="col-md-3 slds-p-top--xx-small " style="display:{!if(voucher.Payment_Methods__c =='Cheque','','none')}">
                                        <div class="slds-form-element">
                                            <strong>Starting Cheque# : </strong>
                                            <apex:inputField value="{!voucher.Reference__c}" id="refNo" style="" styleClass="slds-select" html-placeholder="Cheque No#" />
                                        </div>
                                    </div>


                                </div>
                                <div class="slds row slds-p-top--xx-small">
                                    <div class="col-md-3 slds-p-top--xx-small " style=" border-radius: 2px; margin-top: 5px;">
                                        <div class="slds-form-element">
                                            <strong>Balance as on*: </strong><span class="slds-text-heading--medium"><strong><apex:outputField value="{!paymentAcc.Calculated_Ending_Balance__c}" id="accountBalance"/></strong></span>
                                        </div>
                                    </div>
                                    <div class="col-md-9 slds-p-top--xx-small ">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon--right" style="text-align:right;">
                                            <apex:commandButton styleClass="slds-button slds-button--brand" action="{!Save}" value="Pay Bills" style="color:#fff;" /> &nbsp;
                                            <apex:commandLink styleClass="slds-button slds-button--brand" action="{!SaveandPrint}" value="Pay and Print Checks" style="color:#fff;" rendered="{!if(Bill.Vendor__c != null,true,false)}" /> &nbsp;
                                            <apex:commandButton styleClass="slds-button slds-button--neutral" action="{!cancel}" value="Cancel" style="border:1px solid #ddd;" />
                                        </div>
                                    </div>
                                </div>
                                <div class="slds row slds-p-top--xx-small">


                                </div>
                            </div>
                        </apex:outputPanel>
                    </div>
                </div>

                <div id="CreditModal" class="slds-hide" style="height: 640px;">

                    <section role="dialog" tabindex="-1" aria-label="Meaningful description of the modal content" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">

                        <div class="slds-modal__container">
                            <header class="slds-modal__header slds-modal__header slds-modal__header_empty">
                                <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" >
                                  <svg class="slds-button__icon slds-button__icon_large" aria-hidden="true">
                                    <use xlink:href="{!URLFOR($Resource.SLDS0121,'/assets/icons/action-sprite/svg/symbols.svg#close')}" xmlns:xlink="https://www.w3.org/1999/xlink" ></use>
                                  </svg>
                                  <span class="slds-assistive-text">Close</span>
                                </button>
                                <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"><apex:outputField value="{!vendorinfo.name}"/></h2>
                                <p class="slds-m-top_x-small"> <apex:outputText value="Total Credit&#39;s Available" escape="false" />
                                                <a href="javascript:void(0);"><apex:outputField value="{!vendorInfo.ERP7__Credit_Balance__c }" id="dialog_cb"/></a>.</p>
 
                            </header>
                                 <apex:outputPanel id="creditpnl">
                                      <apex:repeat value="{!Bill_WrapList}" var="item" rows="1" first="{!first}">
