<apex:page id="page" docType="html-5.0">
    <!--
controller="payBills"
<html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">

    <head>
        <meta charset="utf-8" />
        <apex:slds />
        <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>
        
        <style>
            .erp_mark7 .slds-table th {
                font-weight: 600;
            }

            .dateFormat {
                display: none;
            }

            td {

                color: #16325c;
            }

            .slds .slds-table:not(.slds-no-row-hover) tbody tr:hover>td {
                background-color: #36a0fe;
                font-size: 14px;
                color: #fff;
            }

            .slds .slds-theme--alt-inverse a:not(.slds-button--neutral):hover,
            .slds .slds-theme--alt-inverse a:not(.slds-button--neutral):focus {
                color: rgba(255, 255, 255, 1);
            }

            .epr_Mark7 .active {
                background: none !important;
                border-bottom: 3px solid #0070d2;
            }

            .epr_Mark7 .inactive {
                background: transparent;
            }

            .epr_Mark7 .active a:hover {
                background: none !important;
            }

            .epr_Mark7 .active a:focus {
                background: none !important;
            }

            input {
                padding-top: 0;
                border: 1px solid #ddd;
                border-radius: 5px;
                padding: 5px;
            }

            .slds .slds-table--bordered td {
                border-top: 1px solid #f7f7f7;
            }

            a.slds-input {
                border: none !important;
                padding: 0px !important;
                display: inline !important;
            }

            .slds [hidden],
            .slds template {
                display: inline !important;
            }
            .lookupIconOn {
        background-image: url(/resource/1487765880000/ERP7__ERPCustomIcons/erpicons/ERPicon-lookup20x21.png);
        }
            .lookupIcon {
        background-image: url(/resource/1487765880000/ERP7__ERPCustomIcons/erpicons/ERPicon-lookup20x21.png);
       
        }
        .lookupInput{
                background:#ffffff;
                
            }
             input {
            padding-top: 0;
            border: 1px solid #ddd;
            border-radius : 5px;
            padding: 5px;
        } 
        </style>
        <script>
            function showModal(eid){
            var ele = document.getElementById(eid);
            if(ele.getAttribute('class')=='slds-hide')
            ele.setAttribute('class','slds-show');
            else 
            ele.setAttribute('class','slds-hide');     
           }
        </script>
    </head>

    <body>
  
        <apex:form id="mainFrm">
            <apex:actionFunction name="credit_change" action="{!applyCredits}" reRender="creditpnl,dialog_cb,BillList"/>
            <apex:actionFunction name="on_change" action="{!fetchAllBills}" />
            <apex:actionFunction name="fetchCoa" action="{!getCoaDetails}"  />
            <apex:actionFunction name="on_select" action="{!onselect}" reRender="BillList,bill_tbl,creditpnl,TotalCount,prev,next" />
            <apex:actionFunction name="selectAll" action="{!select_All}" reRender="BillList,bill_tbl,creditpnl,TotalCount,prev,next" />
            <apex:actionFunction name="showRef" action="{!refreshPage}"/>
            <apex:pageMessages ></apex:pageMessages>
            <div class="slds">
                <div class="erp_mark7 slds-container--fluid">
                    <div class="slds-page-header">
                        <div class="slds-grid">
                            <div class="slds-col slds-has-flexi-truncate">
                                <div class="slds-media slds-no-space slds-grow">
                                    <div class="slds-media__figure">
                                        <svg class="slds-icon slds-icon-standard-account slds-p-around--xx-small" aria-hidden="true">
            <use xlink:href="{!URLFOR($Resource.SLDS213, '/assets/icons/action-sprite/svg/symbols.svg#quote')}"></use>
          </svg>
                                    </div>
                                    <div class="slds-media__body">
                                        <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate" title="">Pay Bills</h1>
                                        <div style="text-align:center;float:left;width: 100%; height: 6px;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="epr_Mark7 ">
                        <apex:outputPanel id="PaymentAcc">
