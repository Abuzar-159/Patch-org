                                          <div class="slds-grid slds-wrap">
                                                <div class="slds-size_1-of-3">  
                                                    <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">
                                                        <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="name">Voucher Id#</label><br/>
                                                            <div class="slds-form-element__control">
                                                                <apex:outputField value="{!item.voucher.Name}" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="slds-size_1-of-3">  
                                                <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">
                                                    <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="name">Voucher AMT</label><br/>
                                                        <div class="slds-form-element__control">
                                                             <apex:outputField value="{!item.voucher.Total_Amount__c}" />
                                                        </div>
                                                    </div>
                                                </div> 
                                                </div> 
                                                <div class="slds-size_1-of-3">  
                                                <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">   
                                                    <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="name">AMT DUE</label><br/>
                                                        <div class="slds-form-element__control">
                                                             <apex:outputField value="{!item.voucher.Amount_Due__c}" />
                                                        </div>
                                                    </div>
                                                </div>      
                                                </div> 
                                            <div class="slds-size_1-of-3">  
                                                <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">  
                                                    <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="name"><apex:outputText value="Credit's Used" /></label><br/>
                                                        <div class="slds-form-element__control">
                                                             <apex:outputField value="{!item.voucher.Credit_Used__c}" />
                                                        </div>
                                                    </div>
                                                </div>      
                                                </div>  
                                            <div class="slds-size_1-of-3">  
                                                    <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">    
                                                        <div class="slds-form-element">
                                                                <label class="slds-form-element__label" for="name">AMT TO PAY</label><br/>
                                                            <div class="slds-form-element__control">
                                                                <apex:outputField value="{!item.voucher.Amount__c}"/>
                                                            </div>
                                                        </div>
                                                    </div>      
                                                </div>
                                                 <div class="slds-size_1-of-3">  
                                                <div class="slds-box slds-box_x-small slds-text-align_center slds-m-around_x-small">  
                                                    <div class="slds-form-element">
                                                            <label class="slds-form-element__label" for="name"><apex:outputText value="Apply Credit" /></label><br/>
                                                        <div class="slds-form-element__control">
                                                             <apex:input type="auto" value="{!item.applycredit}" html-min="0" html-step=".01" onchange="credit_change();"/>
                                                             <div class="errorMsg" style="display:{!if(ISBLANK(TRIM(item.errMsg)),'none','')};"><strong>Error:</strong> {!item.errMsg}</div>
                                                        </div>
                                                    </div>
                                                </div>      
                                                </div> 
                                        </div>
                                       </div>
                                   </apex:outputPanel>
                                      </apex:repeat>
                                 </apex:outputPanel>
                            <footer class="slds-modal__footer">
                                <apex:outputPanel id="TotalCount">
                                    <p>
                                         {!first+1}/{!selecttSize}
                                    </p>
                                </apex:outputPanel>
                                <apex:commandButton id="prev" reRender="creditpnl,prev,next,TotalCount" Styleclass="slds-button slds-button_brand" disabled="{!if(first==0,true,false)}" action="{!prev}" value="<" />
                                <apex:commandButton id="next" reRender="creditpnl,prev,next,TotalCount" Styleclass="slds-button slds-button_brand" action="{!next}" value=">" disabled="{!if((first+1) == selecttSize,true,false)}"/>
                              
                                <apex:commandButton Styleclass="slds-button slds-button_neutral" value="Cancel" />
                                <apex:commandButton id="apply" Styleclass="slds-button slds-button_brand" action="{!ApplyCreditExit}" value="Apply" />
                                
                            </footer>

                        </div>

                    </section>

                    <div class="slds-backdrop slds-backdrop_open"></div>

                </div>
            </div>
        </apex:form>
