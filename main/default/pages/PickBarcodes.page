<apex:page controller="OutboundLogisticsLCPages" sidebar="false" showHeader="false" id="page" standardStylesheets="false" tabStyle="Product2" docType="html-5.0" applyBodyTag="false" renderAs="pdf" action="{!createBarcodes}">
    <head>
        <style type="text/css" media="print">
        @page {
            size: 4in 6in;
            @top-center {
                content: element(header);
            }
            @bottom-left {
                content: element(footer);
            }
        }
        
        div.header {
            padding: 5px;
            position: running(header);
        }
        
        div.footer {
            display: block;
            padding: 5px;
            position: running(footer);
        }
        
        .pagenumber:before {
            content: counter(page);
        }
        
        .pagecount:before {
            content: counter(pages);
        }

        </style>
        <style>
            @page {
            //size: 8.27in 11.69in;
            size: 6in 4in;
            margin: 25mm;
            color: #f9f9f9;
            .italicText {
                font-style: Bold;
                font-size: 1.2em;
                font-family: Arial, Helvetica, sans-serif;
                text-decoration: none;
                color: #ff0000;
            }
            .headerText {
                font-weight: bold;
                font-size: 1.8em;
                text-align: center;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }
            .NoteText {
                font-weight: bold;
                font-size: 1.8em;
                font-family: Arial, Helvetica, sans-serif;
                color: #636363;
            }

        </style>
    </head>
    <apex:form >
        <div class="header">
            <div style="color:#cccccc; text-align:right;">{!PB.headVal}</div>
        </div>
        <div class="footer">
            <div style="color:#cccccc; text-align:center;">Page <span class="pagenumber" /> of <span class="pagecount" /></div>
        </div>
        <div class="content">
            <apex:variable var="count" value="{!0}"/>
            <apex:repeat id="sos" value="{!PB.BarcodeWrapperList}" var="barcodeWrap">
                <div style="page-break-before: {!if(count==0,'avoid','always')}; width:283px; min-height:425px; float:left; height:auto; border:0px solid #dddddd; border-radius:5px; padding:0px; padding-top:20px;">
                    <div>
                        <apex:image url="{!imageURL}" width="200" height="67" /> </div>
                        <div class="content" style="width:270px; float:left; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:15px"> 
                            <span style="font-size:15px; font-weight:bold;">Product Name:</span> {!barcodeWrap.products.Name} <br/>
                            <span style="font-size:15px; font-weight:bold;">Product SKU Code:</span> 
                            <apex:outputText rendered="{!and(barcodeWrap.products.ProductCode != null,barcodeWrap.products.ProductCode !='')}">{!barcodeWrap.products.ProductCode}  </apex:outputText> 
                           <apex:outputText rendered="{!and(barcodeWrap.products.ProductCode == null,barcodeWrap.products.ProductCode =='')}">{!barcodeWrap.products.SKU__c}  </apex:outputText>  <br/>
                            <span style="font-size:15px; font-weight:bold;">ASIN Code:</span> {!barcodeWrap.products.ASIN_Code__c}<br/> 
                             <br/>
                            
                                <span style="padding-top:5px;font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:15px">
                                  <span style="font-size:11px; font-weight:bold;">Colour:</span> <span style="font-size:11px;"> {!barcodeWrap.products.Colour__c} </span> <br/> 
                                  <span style="font-size:11px; font-weight:bold;">Sold/Type:</span> <span style="font-size:11px;"> {!barcodeWrap.products.Item_Type__c} </span> <br/> 
                                  <span style="font-size:11px; font-weight:bold;">Weight:</span> <span style="font-size:11px;"> {!barcodeWrap.products.Weight__c} {!barcodeWrap.products.Weight_Dimensions__c} </span> <br/><br/>
                                </span>
                              
                            <span style="font-size:13px; font-weight:bold;">Pick Notes:</span> 
                            <span style="font-size:13px;"> 
                               <apex:outputText rendered="{!and(barcodeWrap.products.Description != null,barcodeWrap.products.Description !='')}">{!barcodeWrap.products.Description} </apex:outputText> 
                                <apex:outputText rendered="{!or(barcodeWrap.products.Description == null,barcodeWrap.products.Description =='')}">{!barcodeWrap.products.Item_Description__c} </apex:outputText> 
                            </span> 
                            <br/>
                                  
                                   
                                
                        </div>
                        <div  style="float:left;">
                            <div style="margin-bottom:35px;"><c:AQBarcodeZone id="brcd128" BrcdHeight="80" BrcdType="{!'code128'}" Value="{!barcodeWrap.Barcode}"> </c:AQBarcodeZone></div>
                        </div>
                        
                </div>
            <apex:variable var="count" value="{!count+1}"/>
            </apex:repeat>
        </div>
    </apex:form>
</apex:page>