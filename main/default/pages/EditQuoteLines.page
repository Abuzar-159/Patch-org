<apex:page controller="SalesOrderAndQuotationManagement" action="{!EditQuoteLines}" tabStyle="Quotes__c" sidebar="false" docType="html-5.0">
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>
        <apex:includeScript value="{!URLFOR($Resource.bootStrap,'/js/bootstrap.min.js')}"/>
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.Order_Console, '/assets/styles/font-awesome.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>
        
        <style type="text/css">
            .bPageBlock .requiredInput {
                position: relative;
                height: 53%;
            }

            .bPageBlock .requiredInput .requiredBlock {
                background-color: #c00;
                position: absolute;
                left: -4px;
                width: 3px;
                top: 1px;
                bottom: 0px;
            }

            .noSidebarCell,
            .sidebarCell .fixed {
                padding: 10px;
                padding-top: 0px;
            }

            #createNew {
                display: none;
                position: static;
                height: 20px;
            }

            .sidebarCell,
            #sidebarDiv {
                width: 150px;
                background-color: #fff;
            }

            .whitetext a {
                color: #fff !important;
            }

            .lookupInput a {
                padding: 0 1rem 0 0;
            }

            body .bPageBlock .pbBottomButtons {
                background-color: #fff;
                background-image: none;
                margin: 0;
            }

            body .bPageBlock .pbHeader {
                background-color: #fff;
                padding: 0;
                margin: 0;
            }

            .bEditBlock .pbHeader>table,
            .apexp .bPageBlock.apexDefaultPageBlock .pbHeader>table,
            #ep.bLayoutBlock .pbHeader>table {
                border-bottom: 1px solid #fff;
            }

            .apexp .bPageBlock.apexDefaultPageBlock .pbBody {
                margin: 0px 0px 0px;
            }

            body .pbBody table.list tr.headerRow td,
            body .pbBody table.list tr.headerRow th {
                //background: #fff;
                border-width: 0 0 1px 1px;
                border-color: #e0e3e5;
                color: #000;
                font-size: 1em;
                font-weight: bold;
                padding: 5px 10px 4px 10px;
            }

            .slds-input {
                background-color: #fff;
                color: #16325c;
                border: 1px solid #d8dde6;
                border-radius: .25rem;
                width: 65%;
                transition: border .1s linear, background-color .1s linear;
                display: inline-block;
                padding: 0 1rem 0 .45rem;
                line-height: 1.875rem;
                min-height: calc(1.875rem + (1px * 2));
            }

            input {
                border: 1px solid #d8dde6;

            }

            select {
                border: 1px solid #d8dde6;
                height: 34px;
                width: 115px;
            }

            .btn {
                color: #fff !important;
                margin: 1px;
                padding: 7px 17px !important;
                border: 1px solid #31d0e5 !important;
                border-bottom-color: #7f7f7f;
                background: #31d0e5 !important;
                font-weight: bold;
                font-size: 12px !important;
                -moz-border-radius: 3px;
                -webkit-border-radius: 3px;
                border-radius: 3px;
            }

            .slds-button--neutral {
                padding-left: 1rem;
                padding-right: 1rem;
                text-align: center;
                vertical-align: middle;
                border: 1px solid #d8dde6 !important;
                background-color: #fff !important;
                color: #31d0e5 !important;
                font-size: 12px !important;
            }

            .lookupInput img {
                margin-right: 20px;
                margin-left: -6px;
            }

            .backg {
                background: lightskyblue;
            }

            .backw {
                background: white;
            }
        </style>
    </head>
    <div class="erp_mark7 epr_Mark7">
        <div class="slds-page-header">
            <div class="slds-grid">
                <div class="slds-col slds-has-flexi-truncate">
                    <div class="slds-media slds-no-space slds-grow">
                        <div class="slds-media__figure">
                            <svg class="slds-icon slds-icon--large slds-icon-standard-user slds-p-around--x-small" aria-hidden="true">
                                <use xlink:href="{!URLFOR($Resource.SLDS213, 'assets/icons/utility-sprite/svg/symbols.svg#description')}"></use>
                              </svg>
                        </div>
                        <div class="slds-media__body">

                            <h1 class="slds-page-header__title slds-truncate slds-p-top--small" title="Scheduler">Quote Edit &nbsp;&nbsp;{!Quote.Name}</h1>
                            <p></p>
                        </div>
                    </div>
                </div>
                <div class="slds-col slds-no-flex slds-grid slds-align-top">

                    <!--<div class="slds-button" role="group">
                        <button class="slds-button slds-button--brand">Builder</button>
                        <button class="slds-button slds-button--neutral"><i class="fa fa-chevron-left"></i>&nbsp;Back</button>
                    </div> -->
                </div>
            </div>
        </div>
        <apex:form >
            <script>
            </script>
            <!-- <apex:sectionHeader title="Quote Edit" subtitle="{!Quote.Name}" />
     <apex:pageMessages ></apex:pageMessages>-->
            <apex:actionFunction name="SalesOrder2QuoteCancel" action="{!SalesOrder2QuoteCancel}" />

            <apex:actionFunction name="rendr" reRender="QLines" />

            <apex:pageBlock title="Quote Line Items">

                <apex:pageBlockButtons id="pb">

                    <apex:actionStatus id="spinne">
                        <apex:facet name="start">
                            <apex:image url="{!URLFOR($Resource.PickPackShipResource,'/assets/images/spinners/slds_spinner_brand.gif')}" height="30px;" width="30px;" />
                        </apex:facet>
                    </apex:actionStatus>
                    <div style="float:right;margin-right: 500px;">
                        <apex:commandButton value="Save" action="{!SaveQuoteLines}" />
                        <apex:commandButton value="Cancel" action="{!Quote2SalesOrderCancel}" styleClass="slds-button--neutral " />
                    </div>
                </apex:pageBlockButtons>
                <apex:variable var="count" value="{!0}" />
                <apex:pageBlockTable value="{!QLines}" var="QLI" id="QLines">
                    <div>
                        <apex:column headerValue="Line Item Name" style="height:40px;color:#fff; width:5%;">
                            <apex:inputField value="{!QLI.QLI.Name}" styleClass="slds-input" style="width:100px;" required="true" rendered="{!!QLI.QLI.Converted__c}" />
                            <div class="lup" style="color: black;text-align:center;">
                                <apex:outputField value="{!QLI.QLI.Name}" style="" rendered="{!QLI.QLI.Converted__c}" />
                            </div>
                        </apex:column>
                        <apex:column headerValue="Product" style="height:40px;color:#fff;width:15%;">
                            <div class="lup">
                                <apex:outputField value="{!QLI.QLI.Product__c}" style="color: #16325c;  border-radius: .25rem; width: 70%; padding: 0 1rem 0 5px;  min-height: calc(1.875rem + (1px * 2)); " />
                            </div>
                            <!--border-color: #d8dde6; border-width: 1px; border-style: solid;-->
                        </apex:column>
                        <apex:column headerValue="Description" style="height:40px;color:#fff;width:10%;">
                            <apex:inputTextarea value="{!QLI.QLI.Description__c}" styleClass="slds-input" style="width:85%;" rendered="{!!QLI.QLI.Converted__c}" />
                            <div class="lup" style="color: black;text-align:center;">
                                <apex:outputText value="{!QLI.QLI.Description__c}" style="width:85%;" rendered="{!QLI.QLI.Converted__c}" />
                            </div>
                        </apex:column>
                        <apex:column headerValue="Base Price" style="height:40px;color:#fff; width:10%;">
                            <apex:actionRegion >
                                <apex:inputField value="{!QLI.QLI.Base_Price__c}" styleClass="slds-input" required="true" style="" rendered="{!!QLI.QLI.Converted__c}">
                                    <apex:actionSupport action="{!QuantityChange}" event="onchange" reRender="tpout" status="spinne">
                                        <apex:param assignTo="{!countR}" value="{!count}" name="param1" />
                                    </apex:actionSupport>
                                </apex:inputField>
                            </apex:actionRegion>
                            <div class="lup" style="color: black;text-align:center;">
                                <apex:outputField value="{!QLI.QLI.Base_Price__c}" style="" rendered="{!QLI.QLI.Converted__c}" />
                            </div>
                        </apex:column>
                        <apex:column headerValue="Quantity" style="height:40px;color:#fff; width:13%;">
                            <apex:actionRegion >
                                <apex:inputField value="{!QLI.QLI.Quantity__c}" styleClass="slds-input" required="true" style="" rendered="{!!QLI.QLI.Converted__c}">
                                    <apex:actionSupport action="{!QuantityChange}" event="onchange" reRender="tpout" status="spinne">
                                        <apex:param assignTo="{!countR}" value="{!count}" name="param1" />
                                    </apex:actionSupport>
                                </apex:inputField>
                            </apex:actionRegion>
                            <div class="lup" style="color: black;text-align:center;">
                                <apex:outputField value="{!QLI.QLI.Quantity__c}" style="" rendered="{!QLI.QLI.Converted__c}" />
                            </div>
                        </apex:column>
                        <apex:column headerValue="Total Price" style="height:40px;color:#fff; width:5%;">
                            <div class="lup" style="color: black;text-align:center;">
                                <apex:outputField value="{!QLI.QLI.Total_Price__c}" style="color: #16325c;  " id="tpout" />
                            </div>
                        </apex:column>
                    </div>

                </apex:pageBlockTable>
            </apex:pageBlock>
        </apex:form>
    </div>

    </html>
</apex:page>