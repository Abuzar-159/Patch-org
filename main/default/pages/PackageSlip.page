<apex:page controller="Package_Shipment_Slip" cache="false" sidebar="false" standardStylesheets="true" showHeader="false" id="mainPage" docType="html-5.0" renderAs="{!if($CurrentPage.parameters.val == 'pdf' || $CurrentPage.parameters.pdf != null, 'pdf', null)}">

    <head>
        <style>
        .helpOrb {
            background-position:-22px;
        }
        div.tooltip {
            width: 20px;
            float: left;
            display:inline;
        }    
        div.tooltip span {
            display: none;
            font-weight:normal;
            text-align:left;
            padding: 3px 5px;
            margin-left: 8px;
            width: 125px;
        }    
        div.tooltip:hover span {
            display: inline;
            position: absolute;
            border: 1px solid #cccccc;
            background: #FFC;
            color: #000000;
            z-index:10000;
        }
        .erpmark7 .wrapper{
            width:800px;
            margin:0 auto;
        }
        </style>        
    </head>
    
    <body>
        <apex:form id="mainFrm">
        
            <div class="erpmark7">                
                <div class="wrapper">
                    
                    <!-- Link Section -->
                        <apex:outputPanel rendered="{!if($CurrentPage.parameters.val == 'pdf' || $CurrentPage.parameters.pdf != null, 'pdf', null)}">
                            <table border="0" width="100%" cellpadding="0" cellspacing="0">
                                <tr><td>&nbsp;</td></tr>
                                
                                <tr>
                                    <td align="center" valign="middle">                                        
                                        <apex:commandLink value="{!$Label.ERP7__PackageSlip_Print}" rendered="{!$ObjectType.Package__c.Accessible}" action="{!viewSlip}" style="padding-left:17px; font-size:18px; font-family: bold; color:#ff0000;"/> &nbsp;&nbsp;                               
                                        <apex:commandLink value="{!$Label.ERP7__PackageSlip_Send_Slip}" rendered="{!$ObjectType.Package__c.Accessible}" action="{!sendPackagingSlip}" style="padding-left:17px; font-size:18px; font-family: bold; color:#ff0000;"/> &nbsp;&nbsp;
                                        <apex:commandLink value="{!$Label.ERP7__PackageSlip_Back}" action="/{!$CurrentPage.Parameters.PackId}" style="padding-left:17px; font-size:18px; font-family: bold; color:#ff0000;"/> &nbsp;&nbsp;
                                    </td>
                                </tr>
                                
                                <tr><td>&nbsp;</td></tr>
                            </table>
                        </apex:outputPanel>
                    <!-- @end of Link Section -->
                    
                    <apex:pageMessages />
                    
                    <!-- error section -->
                        <table border="0" wdith="100%" align="center" cellpadding="0" style="display : {!if(errorMsg != null && errorMsg != '', '', 'none')}">
                            <tr>
                                <td>
                                    <apex:outputLabel id="errmsg" value="{!errorMsg}" style="color:#000000; font-weight:bold; font-size:15px;"></apex:outputLabel>
                                </td>
                            </tr>
                        </table>
                    <!-- @end of error section -->
                    
                    <!-- Exception section -->    
                        <table border="0" wdith="100%" align="center" cellpadding="0" style="display : {!if(exceptionMsg == null || exceptionMsg == '', 'none', '')};">
                            <tr>
                                <td>
                                    <apex:outputLabel id="excepmsg" value="{!exceptionMsg}" style="color:#ff0000; font-weight:bold; font-size:15px;"></apex:outputLabel>
                                </td>
                            </tr>
                        </table>
                    <!-- @end of Exception section -->
            
                    <!-- Recipient Div Section -->
                        <apex:outputPanel rendered="{!if($CurrentPage.parameters.val == 'pdf' || $CurrentPage.parameters.pdf != null, 'pdf', null)}">
                            <div style="width:100%; height:35px; background:#54698d; color:#fff;" onclick="var element = document.getElementById('{!$Component.MainBlock}'),style = window.getComputedStyle(element),top = style.getPropertyValue('display');if(top =='none'){document.getElementById('{!$Component.MainBlock}').style.display='block'; document.getElementById('offExpand').style.display='none';document.getElementById('onExpand').style.display='block';}else {document.getElementById('{!$Component.MainBlock}').style.display='none';document.getElementById('offExpand').style.display='block';document.getElementById('onExpand').style.display='none';}">
                                <a href="#" style="text-decoration:none; color:#fff;line-height:0px;padding-left:0px; ">
                                    <table border="0" width="100%">
                                        <tr>
                                            <td height="30" align="left" valign="middle" width="3%">
                                                <img src="{!URLFOR($Resource.SCM,'SCM/Images/plus.png')}" id="offExpand" title="click to Expand" style="display: block;"/>
                                                <img src="{!URLFOR($Resource.SCM,'SCM/Images/minus.png')}" id="onExpand" style="display:none"/>
                                            </td>                            
                                            <td align="left" valign="middle" width="97%" style="text-decoration:none; color:#fff;">{!$Label.PackageSlip_Add_Recipients}</td>
                                        </tr>
                                    </table>
                                </a>
                            </div>
                        <!-- @end of Recipient Div Section -->
                        
                        <!-- Recipient Panel -->
                            <apex:outputPanel id="MainBlock" style="display:none; background:none;">
                                <apex:pageBlock id="MainPB" tabStyle="Product2">
                                    <table border="0" align="center" width="100%" style="border:0px solid black;" bgcolor="#f9f9f9">
                                        <tr><td>&nbsp;</td></tr>
                                        <tr style="border-bottom:1px solid black;">
                                            <td>&nbsp;</td>
                                            <th>            
                                                <apex:outputLabel value="{!$Label.ERP7__PackageSlip_To}"/>
                                            </th>
                                            <td>
                                                <apex:input type="email" value="{!toEmail_Address}" style="background : #ffffff; border-radius : 5px; height : 20px; width : 25%; border:1px solid #ddd; padding:5px;"/>
                                            </td>                                            
                                        </tr>
                                        
                                        <tr width="100%">
                                            <td>&nbsp;</td>
                                            <th>
                                               <apex:outputLabel value="{!$Label.ERP7__PackageSlip_Cc}"/> 
                                            </th>                                            
                                            <td>
                                                <table border="0" cellpadding="0" cellspacing="0"  width="100%">
                                                    <tr>
                                                        <td style="width: 78%;">
                                                            <apex:input type="email" value="{!ccEmail_Addresses}" style="border-radius : 5px; height : 20px; width :97%; border:1px solid #ddd; padding:5px;"/>
                                                        </td>
                                                        <td>
                                                            <div class="helpOrb tooltip" style="position:relative;left:0px;">
                                                                <span> {!$Label.PackageSlip_You_can_have_multiple_email_addresses_with_comma_separation}</span>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>                                            
                                            <td>&nbsp;</td>                                                                               
                                        </tr>
                                                                                
                                        <tr>
                                            <td>&nbsp;</td>
                                            <th>
                                                <apex:outputLabel value="{!$Label.ERP7__PackageSlip_Subject}"/>
                                            </th>                                                    
                                            <td>
                                                <apex:inputText style="width:510px; border:1px solid #ddd; border-radius: 5px; padding:5px;" value="{!EmailSubject}"/>                                            
                                            </td>
                                        </tr>
                                        
                                        <tr>
                                            <td>&nbsp;</td>
                                            <th style="vertical-align:top;">
                                                <apex:outputLabel value="{!$Label.ERP7__PackageSlip_Email_Body}"/>
                                            </th>
                                            <td>
                                                <apex:inputTextarea id="editTemplate" value="{!emailBody}" cols="95" rows="12" style="border:1px solid #ddd; border-radius: 5px; padding:5px;"/>
                                            </td>
                                        </tr>
                                    </table>
                                </apex:pageBlock>
                            </apex:outputPanel>
                        </apex:outputPanel>
                    <!-- @end of Recipient Panel -->
                    
                    <!-- Logo Section --->  
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="border:0px solid #ddd;">
                            <tr>
                                <td width="20%" style="padding:4px;">
                                    <apex:image url="{!imageURL}" width="208" height="61" title="Aqxolt Pvt Ltd."/>
                                </td>
                                <td width="50%">&nbsp;</td>
                                <td width="30%">
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:14px; color:#4b4f52;">
                                                <strong> <apex:outputText value="{!$Organization.Name}"/> </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; color:#4b4f52;">
                                                <apex:outputText value="{!$Organization.Street}"/> <br/>
                                                <apex:outputText value="{!$Organization.City}"/>, <apex:outputText value="{!$Organization.PostalCode}"/> <br/>
                                                <apex:outputText value="{!$Organization.Country}"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            
                            <tr>
                                <td style="padding:4px;">&nbsp;</td>
                                <td>&nbsp;</td>
                                <td>
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; color:#4b4f52;">&nbsp;</td>                                            
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:14px; color:#4b4f52;">
                                                <strong>{!$Label.PackageSlip_TEL} :</strong> <apex:outputText value="{!$Organization.Phone}"/> <br/>
                                                <strong>{!$Label.ERP7__PackageSlip_FAX} :</strong> <apex:outputText value="{!$Organization.Fax}"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>                            
                        </table>
                    <!-- @end of Logo Section --->  
                    
                    <!-- Invoice Title -->     
                        <table width="100%" border="0" cellspacing="0" cellpadding="0">                          
                            <tr>
                                <td style="font-family:Arial, Helvetica, sans-serif; font-size:17px; padding:10px; text-align:center; color:#4b4f52;">
                                    <strong>{!$Label.PackageSlip_PACKING_LIST}</strong>
                                </td>
                            </tr>                          
                        </table>
                    <!-- @end of Invoice Title -->
                        
                    <!-- Billto shipto ---> 
                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                            <tr>
                                <td width="50%" style="border:1px solid #ececec; font-family:Arial, Helvetica, sans-serif; font-size:14px;">
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td align="left" valign="top">
                                                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                                    <tr>
                                                        <td align="left" valign="top" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                            {!$Label.PackageSlip_Ship_to}:
                                                        </td> 
                                                        <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52;">
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Customer__r.Name}"/><br/>
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Address_Line1__c}"/>,
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Address_Line2__c}"/>,
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Address_Line3__c}"/><br/>
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Postal_Code__c}"/>,
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.City__c}"/>,
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.County__c}"/><br/>
                                                            <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Country__c}"/>,                                                            
                                                        </td>
                                                    </tr>  
                                                </table>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_to_ATTN} : <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Contact__r.Name}"/>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_to_TEL} : <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Contact__r.Phone}"/>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_to_FAX} : <apex:outputField value="{!pack.Sales_Order__r.Ship_To_Address__r.Contact__r.Fax}"/>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                    </table>
                                </td>                        
                                <td width="50%" style="border:1px solid #ececec; font-family:Arial, Helvetica, sans-serif; font-size:14px;">
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                        <tr>
                                            <td align="left" valign="top">
                                                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                                    <tr>
                                                        <td align="left" valign="top" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52;">
                                                            <strong>{!$Label.PackageSlip_Ship_From}:</strong>
                                                        </td>
                                                        <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52;">
                                                            <apex:outputText value="{!$Organization.Name}"/> <br/>
                                                            <apex:outputText value="{!$Organization.Street}"/> <br/>
                                                            <apex:outputText value="{!$Organization.City}"/>, <apex:outputText value="{!$Organization.PostalCode}"/> <br/>
                                                            <apex:outputText value="{!$Organization.Country}"/>
                                                        </td>
                                                    </tr>
                                                </table>
                                                <td>&nbsp;</td>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_From_ATTN} : <apex:outputText value="{!$Organization.Name}"/>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_From_TEL} : <apex:outputText value="{!$Organization.Phone}"/>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                        <tr>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52; font-weight:bold;">
                                                {!$Label.PackageSlip_Ship_From_FAX} : <apex:outputText value="{!$Organization.Fax}"/>
                                            </td>
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px 10px 5px 10px;color:#4b4f52;">&nbsp;</td>
                                        </tr>                                        
                                    </table>
                                </td>
                            </tr>
                            <tr><td>&nbsp;</td></tr>
                        </table>
                    <!-- @end of Billto shipto --->          
                    
                    <!-- Package line items section -->  
                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                            <tr style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; text-align:center; color:#4b4f52;">
                                <td bgcolor="#54698d">&nbsp;</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Package}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Sales_Order}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Line_Item_Name}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Line_Item_Description}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_Item}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Product_Kit}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_SKU}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Weight}</td>
                                <td bgcolor="#54698d" align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#ffffff;">{!$Label.PackageSlip_List_Quantity}</td>                                                                                                
                            </tr>
                            
                            <apex:repeat value="{!packList}" var="pkgList">
                                <tr>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">&nbsp;</td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Package__r.Name}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Sales_Order_Line_Item__r.Sales_Order__r.Name}"/>    
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Sales_Order_Line_Item__r.Name}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Sales_Order_Line_Item__r.Description__c}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Sales_Order_Line_Item__r.Product__r.Name}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Sales_Order_Line_Item__r.Product__r.Is_Kit__c}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.SKU__c}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Package_Weight__c}"/>
                                    </td>
                                    <td align="left" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#4b4f52;">
                                        <apex:outputField value="{!pkgList.Quantity__c}"/>
                                    </td> 
                                </tr>
                            </apex:repeat>
                            
                            <tr><td>&nbsp;</td></tr>
                        </table>
                    <!-- @end of Package line items section --> 
                    
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td style="border-top:1px solid #ccc;">
                                <p align="center"><font face="Arial"><i>{!$Label.Invoice_Copyright} {!$Organization.Name}.</i></font></p>
                            </td>
                        </tr>
                    </table>
                     
                </div>
            </div>
                
        </apex:form>
    </body>
</apex:page>