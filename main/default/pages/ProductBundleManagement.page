    <script type="text/javascript">
        function setFocus(){}
        
        function removeProfile(pos,val) {
            var r = confirm("Are you sure you want to remove profile?");
            if (r == true) {
                removecurrentProfile(pos,val);
            }
        }
        
        function removeItems(pos,val) {
            var r = confirm("Are you sure you want to remove product?");
            if (r == true) {
                removecurrentItem(pos,val);
            }
        } 
        
        function removeRecommendation(pos,val) {
            var r = confirm("Are you sure you want to remove recommended product?");
            if (r == true) {
                removeRecommendedItem(pos,val);
            }
        }
        
        function removeAccessory(pos,val) {
            var r = confirm("Are you sure you want to remove related product?");
            if (r == true) {
                removeAccessoryItem(pos,val);
            }
        }
        
        function reload() {
            var r = confirm("Are you sure to reload?");
            if (r == true) {
              location.reload();
            }
        }        
        
        var $j = jQuery.noConflict();
        $j(document).ready(function(){
            $j('table.search-table').tableSearch({
                searchPlaceHolder:'&nbsp;Profile Name'
            });
            
            $j('table.search-table1').tableSearch1({
                searchPlaceHolder:'&nbsp;Item Name'
            });
            
            $j('table.search-table2').tableSearch2({
                searchPlaceHolder:'&nbsp;Product Name'
            });
            
            $j('table.search-table3').tableSearch3({
                searchPlaceHolder:'&nbsp;Product Name'
            });
        });
                
    <!-- jQuery for profile list search -->
        (function($j){  
        $j.fn.tableSearch = function(options){
            if(!$j(this).is('table')){
                return;
            }
            var tableObj = $j(this),
                searchText = (options.searchText)?options.searchText:'',
                searchPlaceHolder = (options.searchPlaceHolder)?options.searchPlaceHolder:'',
                divObj = $j('<div style="float:right; margin:-27px 174px 0px 0px; border:0px solid black;">'+searchText+'</div><br /><br />'),
                inputObj = $j('<input type="text" class="inputallfields" placeholder="'+searchPlaceHolder+'" />'),
                caseSensitive = (options.caseSensitive===true)?true:false,
                searchFieldVal = '',
                pattern = '';
                
                inputObj.off('keyup').on('keyup', function(){
                searchFieldVal = $j(this).val();
                pattern = (caseSensitive)?RegExp(searchFieldVal):RegExp(searchFieldVal, 'i');
                tableObj.find('tbody tr').hide().each(function(){
                    var currentRow = $j(this);
                    currentRow.find('td').each(function(){
                        if(pattern.test($j(this).html())){
                            currentRow.show();
                            return false;
                        }
                    });
                });
            });
            tableObj.before(divObj.append(inputObj));
            return tableObj;
        }
        }(jQuery));
    <!-- @end of jQuery for profile list search -->
    
    
