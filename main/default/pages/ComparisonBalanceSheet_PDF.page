<apex:page controller="BalanceSheet" standardStylesheets="false" renderAs="pdf" sidebar="false">
    
 <body>
    <div style="font-family:Arial, Helvetica, sans-serif; font-size:12px;border-left:1px solid #ddd;border-right:1px solid #ddd;border-top:1px solid #ddd;padding:10px;width:97%;">
      <span style="font-family:Arial, Helvetica, sans-serif; font-size:18px;padding:10px;"><apex:outputField value="{!Select_Organisation.Organisation__c}" /></span> 
       <div style="font-family:Arial, Helvetica, sans-serif; font-size:24px;padding:5px;text-align:right;"> <apex:outputText value="Balance Sheet"/></div>
       <div style="font-family:Arial, Helvetica, sans-serif; font-size:16px;font-weight:bold;padding:5px;text-align:right;">
        <apex:outputText value=" {0,date,MMMM d, yyyy}">
                <apex:param value="{!EDate}"/>
            </apex:outputText>
          </div>
    </div>
       
        
        <table class="table" style="width:100%; padding:4px; border-left:1px solid #ddd; border-right:1px solid #ddd;">
            <tr>
                <td width="50%" style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; color:#ffffff; background:#0270d3; text-transform:uppercase;">Accounts</td>
                <td  width="50%"  style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; color:#ffffff; background:#0270d3; text-transform:uppercase;">Financial year</td>
            </tr> 
        </table>
        <apex:outputPanel id="tabularSecpnl">
            <!--Start of Tabular data Header--> 
            <table class="slds-table  slds-table--bordered slds-row-hover" style="border-left:1px solid #ddd; border-right:1px solid #ddd;border-bottom:1px solid #ddd;padding:5px;">
                <thead>
                    <tr style="border-bottom:3px solid #ffffff; display:{!if(ShowFyWise,'','none')}">
                        <td width="30%"></td>
                        <!--<apex:outputPanel id="YearWise" style="display:{!if(ShowFyWise,'','none')}"><!--rendered="{!ShowFyWise}"-->
                        
                        <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear" rows="1">
                            <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="sFname">
                                <apex:repeat value="{!sFname.FywiseValues}" var="Fy">
                                    <td style="font-family:Arial, Helvetica, sans-serif; font-size:15px; padding:10px; color:#000000; font-weight:bold;text-align:right;" class="assets-text">
                                        <apex:outputPanel >{!Fy}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                            </apex:repeat>
                            
                        </apex:repeat>
                        <!-- </apex:outputPanel>-->
                    </tr>
                    <tr style="display:{!if(ShowQuartely,'','none')}">
                        <td width="30%"></td>
                        <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear" rows="1">
                            
                            <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="sFname">
                                <apex:repeat value="{!sFname.FywiseValues}" var="Fy">
                                    <td style="font-weight:bold;text-align:center;" class="assets-text" colspan="4">
                                        <apex:outputPanel >{!Fy}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                                
                            </apex:repeat>
                            
                        </apex:repeat>
                        
                        
                    </tr>
                    <tr style="display:{!if(ShowQuartely,'','none')}">
                        <td width="30%"></td>
                        <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear" rows="1" rendered="{!ShowQuartely}">
                            
                            <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="sFname">
                                <apex:repeat value="{!sFname.FywiseValues}" var="Fy">
                                    <apex:repeat value="{!sFname.FywiseValues[Fy]}" var="Fys">
                                        <td style="font-weight:bold;text-align:right;" class="assets-text">
                                            <apex:outputPanel >{!IntegerToQuarterName[Fys]}</apex:outputPanel>
                                        </td>
                                    </apex:repeat>
                                </apex:repeat>
                            </apex:repeat>
                            
                        </apex:repeat>
                        
                        
                    </tr>
                    <tr style="display:{!if(ShowMonthly,'','none')}">
                        <td width="30%"></td>
                        <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear" rows="1">
                            
                            <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="sFname">
                                <apex:repeat value="{!sFname.FywiseValues}" var="Fy">
                                    <td style="font-weight:bold;text-align:center;" class="assets-text" colspan="12">
                                        <apex:outputPanel >{!Fy}</apex:outputPanel>
                                    </td>
                                </apex:repeat>
                                
                            </apex:repeat>
                            
                        </apex:repeat>
                        
                        
                    </tr>
                    <tr style="display:{!if(ShowMonthly == true,'','none')}">    
                        <td width="30%"></td> 
                        <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear" rows="1" rendered="{!ShowMonthly}">
                            <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="sFname">
                                <apex:repeat value="{!sFname.FywiseValues}" var="Fy">
                                    <apex:repeat value="{!sFname.FywiseValues[Fy]}" var="Fys">
                                        <td style="font-weight:bold;text-align:right;" class="assets-text">
                                            {!IntegerToMonthName[Fys]}                                                                                      
                                        </td>
                                    </apex:repeat>
                                </apex:repeat>
                            </apex:repeat>
                        </apex:repeat>
                        <!--End of Tabular data Header-->
                        
                    </tr>
                    
                </thead>
                <tbody>
                    <tr>
                        <td width="30%" colspan="13"><strong>Balance Sheet</strong></td>
                        
                    </tr>
                    <apex:repeat value="{!compareBalanceSheetMap}" var="sFyear">
                        <tr>
                            <td width="30%">{!sFyear}</td>
                            <td> </td>
                        </tr>
                        
                        <apex:repeat value="{!compareBalanceSheetMap[sFyear]}" var="tval">
                            
                            <apex:repeat value="{!tval.SubAccountList}" var="subtval">
                                <tr>
                                    <td width="30%" style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; color:#000000; border-bottom:0px solid #ececec; ">
                                        &nbsp;&nbsp;&nbsp; {!subtval.Name}
                                    </td>
                                    <td> </td>
                                </tr>
                                <apex:repeat value="{!subtval.SubAccountList}" var="subtFy">
                                    <tr>
                                        <td width="30%" style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#000000;">
                                            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; {!subtFy.Name}
                                        </td>
                                        <apex:repeat value="{!subtFy.FywiseValues}" var="Fval">
                                            <apex:repeat value="{!subtFy.FywiseValues[Fval]}" var="vval">
                                                <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#000000;text-align:right;" class="assets-text">
                                                    <apex:outputPanel rendered="{!if(subtFy.FywiseValues[Fval][vval] < 0.00,true,false)}">
                                                        (
                                                        <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                        {!checkCurrency.userISO}<apex:param value="{!subtFy.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}"/>
                                                        </apex:outputText>
                                                       )
                                                    </apex:outputPanel>
                                                    <apex:outputPanel rendered="{!if(subtFy.FywiseValues[Fval][vval] >= 0.00,true,false)}">
                                                        <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                        {!checkCurrency.userISO}<apex:param value="{!subtFy.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}" />
                                                        </apex:outputText>
                                                        
                                                    </apex:outputPanel>
                                                </td>
                                            </apex:repeat>
                                        </apex:repeat>
                                    </tr>
                                </apex:repeat>
                                <tr>
                                    <td width="30%" style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; color:#000000; border-bottom:0px solid #ececec; ">
                                        Total {!subtval.Name}
                                    </td>
                                    
                                    <apex:repeat value="{!subtval.FywiseValues}" var="Fval">
                                        <apex:repeat value="{!subtval.FywiseValues[Fval]}" var="vval">
                                            <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#000000;text-align:right;" class="assets-text">
                                                <apex:outputPanel rendered="{!if(subtval.FywiseValues[Fval][vval] < 0.00,true,false)}">
                                                    (
                                                    <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                    {!checkCurrency.userISO}<apex:param value="{!subtval.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}"/>
                                                    </apex:outputText>
                                                    )
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(subtval.FywiseValues[Fval][vval] >= 0.00,true,false)}">
                                                    <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                    {!checkCurrency.userISO}<apex:param value="{!subtval.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}" />
                                                    </apex:outputText>
                                                    
                                                    
                                                </apex:outputPanel>
                                            </td>
                                        </apex:repeat>
                                    </apex:repeat>
                                </tr>
                            </apex:repeat>
                            <tr>
                                <td width="30%" style="font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px; color:#000000; border-bottom:0px solid #ececec; ">Total {!sFyear}</td>
                                <apex:repeat value="{!tval.FywiseValues}" var="Fval">
                                    <apex:repeat value="{!tval.FywiseValues[Fval]}" var="vval">
                                        
                                        <td style="font-family:Arial, Helvetica, sans-serif; font-size:12px; padding:10px; color:#000000;text-align:right;" class="assets-text">
                                            <apex:outputPanel rendered="{!if(tval.FywiseValues[Fval][vval] < 0.00,true,false)}">
                                                (
                                                <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                {!checkCurrency.userISO}<apex:param value="{!tval.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}"/>
                                                </apex:outputText>
                                                )
                                            </apex:outputPanel>
                                            <apex:outputPanel rendered="{!if(tval.FywiseValues[Fval][vval] >= 0.00,true,false)}">
                                               
                                                <apex:outputText value="{0, number, ###,###,###,##0.00}">
                                                {!checkCurrency.userISO}<apex:param value="{!tval.GContainerFyWValues[Fval][vval].ERP7__Amount__c*checkCurrency.conversionRate}"/>
                                                </apex:outputText>
                                                
                                            </apex:outputPanel>
                                        </td>
                                    </apex:repeat>
                                    <!---->
                                </apex:repeat>
                            </tr>
                        </apex:repeat>
                        
                    </apex:repeat>
                </tbody>
            </table>
            <table class="table" width="100%"  cellpadding="0" cellspacing="0" border="0">
            <tr style="background:#4cca81;">
                <td style="color:#ffffff;vertical-align: middle; font-family:Arial, Helvetica, sans-serif; font-size:10px; padding:10px;">TOTAL LIABILITY AND STOCKHOLDERS EQUITY</td>
                <td style="text-align:right; color:#ffffff; font-size:22px;font-family:Arial, Helvetica, sans-serif; font-size:14px; padding:10px;">
                   <!-- <apex:outputText value="{!EAc.Value}"/>-->
                    <!--<apex:outputField value="{!EAc.Container.Amount__c}"/>-->
                    <apex:outputText value="{0, number, ###,###,###,##0.00}">
                    {!checkCurrency.userISO}<apex:param value="{!Total_Liab_Equity.ERP7__Opening_Balance__c*checkCurrency.conversionRate }"/>
                    </apex:outputText>
                   
                </td>
            </tr>
        </table> 
        </apex:outputPanel>
    </body>
</apex:page>