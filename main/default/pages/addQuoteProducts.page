        <script>
        var $j = jQuery.noConflict();
        $j(document).ready(function() {
            $j('#prodTable').tableSearch1({
                searchPlaceHolder: '&nbsp;Product Name'
            });
        });
        (function($j) {
            $j.fn.tableSearch1 = function(options) {
                if (!$j(this).is('table')) {
                    return;
                }
                var tableObj = $j(this),
                    searchText = (options.searchText) ? options.searchText : '',
                    searchPlaceHolder = (options.searchPlaceHolder) ? options.searchPlaceHolder : '',
                    divObj = $j('<div style="float:right; margin:0px; border:0px solid black;">' + searchText + '</div>'),
                    inputObj = $j('<input type="hidden" id="pTableSearch" class="inputallfields"  />'),
                    caseSensitive = (options.caseSensitive === true) ? true : false,
                    searchFieldVal = '',
                    pattern = '';
                
                $j('#productName').off('keyup').on('keyup', function() {
                    searchFieldVal = $j(this).val();
                    pattern = (caseSensitive) ? RegExp(searchFieldVal) : RegExp(searchFieldVal, 'i');
                    tableObj.find('tbody tr').hide().each(function() {
                        var currentRow = $j(this);
                        currentRow.find('td').each(function() {
                            if (pattern.test($j(this).html())) {
                                currentRow.show();
                                return false;
                            }
                        });
                    });
                });
                tableObj.before(divObj.append(inputObj));
                return tableObj;
            }
        }(jQuery));
        <!-- @end of jQuery for product list search -->  
            
            function removeItems(pos, val) {
                //alert('inside removeItems : = ' + pos +'   '+ val);
                var r = confirm("Are you sure you want to delete?");
                if (r == true) {
                    removecurrentItem(pos, val);
                }
            }
        
        function checkAll1(cb) {
            //alert('inside checkAll1 : = ' + cb);
            var inputElem = document.getElementsByTagName("input");
            //alert('inputElem : = '+ inputElem);
            for (var i = 0; i < inputElem.length; i++) {
                if (inputElem[i].id.indexOf("checkedone1") != -1) {
                    inputElem[i].checked = cb.checked;
                }
            }
        }
        
        function checkAll2(cb) {
            //alert('inside checkAll2 : = ' + cb);
            var inputElem = document.getElementsByTagName("input");
            //alert('inputElem : = '+ inputElem);
            for (var i = 0; i < inputElem.length; i++) {
                if (inputElem[i].id.indexOf("checkedone2") != -1) {
                    inputElem[i].checked = cb.checked;
                }
            }
        }
        
        function checkAll3(cb) {
            //alert('inside checkAll3 : = ' + cb);
            var inputElem = document.getElementsByTagName("input");
            //alert('inputElem : = '+ inputElem);
            for (var i = 0; i < inputElem.length; i++) {
                if (inputElem[i].id.indexOf("checkedone3") != -1) {
                    inputElem[i].checked = cb.checked;
                }
            }
        }
        
        function saveSOs() {
            //alert('inside saveSOs');
            var lineItemCount = $j('[id$=lineItemCount]').val();
            var orderStatus = $j('[id$=orderStage]').val();
            if (lineItemCount == 0) {
                $j('[id$=errmsg]').html("Please add product line Item!");
            } else if (orderStatus == 'Closed') {
                $j('[id$=errmsg]').html("You cannot edit/save a closed sales order!");
            } else saveSalesOrders();
        }
        
        function fetchMoreRecords(offsetH,scrollH,totalH){
            scrollH+=offsetH;
            
            if(scrollH == totalH){
                fetchMore();
            }
