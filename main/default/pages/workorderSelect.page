<apex:page showHeader="false" sidebar="false" controller="SchedulerCustomLookups" action="{!WorkOrderSelect}" tabStyle="Tax__c" docType="html-5.0" title="{!$User.Id}">
      <apex:stylesheet value="{!URLFOR($Resource.ganttchart, 'assets/styles/salesforce-lightning-design-system.css')}" />
          <apex:stylesheet value="{!URLFOR($Resource.ganttchart, 'assets/styles/salesforce-lightning-design-system-scoped.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.SCM, 'SCM/Css/newpage.css')}"/>
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
  <style>
  
  .slds .slds-page-header {
    padding: 1rem 0.1rem;
    border-bottom: 1px solid #d8dde6;
    background: #f4f6f9;
}
  @media (min-width: 48em){
.slds .slds-page-header {
    padding: 1.5rem 0.1rem 0.75rem;
}
}
  body{
  background:#F0F8FF;
      margin-top: 0px
  }
  input[type=text], textarea {
  -webkit-transition: all 0.30s ease-in-out;
  -moz-transition: all 0.30s ease-in-out;
  -ms-transition: all 0.30s ease-in-out;
  -o-transition: all 0.30s ease-in-out;
  outline: none;
  padding: 3px 0px 3px 3px;
  border: 1px solid #DDDDDD;
}
 
input[type=text]:focus, textarea:focus {
  box-shadow: 0 0 5px rgba(255, 0, 24, 1);
  padding: 3px 0px 3px 3px;
  border: 1px solid rgba(255, 0, 24, 1);
}
 input[type=button]{
  -webkit-transition: all 0.30s ease-in-out;
  -moz-transition: all 0.30s ease-in-out;
  -ms-transition: all 0.30s ease-in-out;
  -o-transition: all 0.30s ease-in-out;
  outline: none;
  
}
 
input[type=button]:focus,{
  -webkit-box-shadow: 0 0 0px rgba(255, 0, 24, 1);
  box-shadow: 0 0 0px rgba(255, 0, 24, 1);
  -o-box-shadow: 0 0 0px rgba(255, 0, 24, 1); 
  
}
  .fields{                                               

    width:180px;
    height:20px;
    border-radius:3px;
     -webkit-border-radius:3px;
    border:1px solid #bfc1c1;
    -webkit-transition: all 0.4s ease-in-out;
    -moz-transition: all 0.4s ease-in-out;
    -o-transition: all 0.4s ease-in-out;
     }
  </style>
 
  <apex:form id="form">
  <apex:outputPanel id="pan" layout="block" style="margin:0px;padding-top:0px;">
  <div class="slds"> 
      <div class="slds-page-header" role="banner">
                      <div class="slds-media">
                     

                          <div class="slds-media__figure">
                              <svg aria-hidden="true" class="slds-icon slds-icon--large slds-icon-standard-orders">
                                <use xlink:href="{!URLFOR($Resource.ganttchart,'/assets/icons/standard-sprite/svg/symbols.svg#record')}"></use>
                              </svg>
                           </div>
                        <div class="slds-media__body">
                          <p class="slds-page-header__title slds-truncate slds-align-middle" title="Search Work Orders" style="padding-top:15px;font-size:1.25em;">Search Work Orders</p>
                        </div>
                      </div>
                </div>
      <form class="slds-form--inline ">
          
                <div class="slds-form-element slds-p-around--small ">
                    <div class="slds-form-element__control">
                          <label class="slds-form-element__label" for="txtSearch" style="color:#000;font-weight:bold;">Name</label>
                    </div>
                      
                           <apex:input type="text" id="fn" value="{!NameSearch}" styleClass="fields" style="height:32px; " rendered="{!$ObjectType.Schedule__c.Accessible && $ObjectType.Process__c.Accessible}"/>
                      
                          <span class="slds-p-right--medium"> <apex:commandButton styleClass="slds-button slds-button--brand"  action="{!WorkOrderSelect}" value="Search" style=" line-height: 1.925rem;" rendered="{!$ObjectType.WO__c.Accessible}"/></span>
                    
                </div>
        </form>
    </div>  
          
     <div class="slds-container--fluid" style="padding:10px;height:400px;overflow:scroll;">     
       <apex:pageBlock id="searchResults"> 
          <apex:pageBlockTable width="55%" value="{!workOrderList}" var="wocls" id="tblResults" >
            <apex:column width="20%" >
              <apex:facet name="header">Work Order</apex:facet>      
               <apex:outputLink value="#" onclick="fillIn('{!JSENCODE(wocls.rec.name)} ','{!JSENCODE(wocls.rec.id)}','{!JSENCODE(wocls.rec.Process__r.Name)} ','{!JSENCODE(wocls.rec.Process__c)}','{!JSENCODE(wocls.rec.Process__r.Work_Station__r.Name)} ','{!JSENCODE(wocls.rec.Process__r.Work_Station__c)}','{!JSENCODE(wocls.lineItemName)} ','{!JSENCODE(wocls.lineItemId)}')" rendered="true">{!wocls.rec.Name}</apex:outputLink>     
            </apex:column>
            <apex:column width="20%" >
                    <apex:facet name="header">Process</apex:facet>           
                     <apex:outputText value="{!wocls.rec.Process__r.Name}" rendered="{!$ObjectType.Process__c.Accessible && $ObjectType.Process__c.fields.Name.Accessible && $ObjectType.WO__c.Accessible && $ObjectType.WO__c.fields.Process__c.Accessible}"/> 
                </apex:column>
                <apex:column width="20%" >
                    <apex:facet name="header">Work Station</apex:facet>           
                     <apex:outputText value="{!wocls.rec.Process__r.Work_Station__r.Name}" rendered="{!$ObjectType.Process__c.Accessible && $ObjectType.Process__c.fields.Work_Station__c.Accessible && $ObjectType.Work_Station__c.Accessible && $ObjectType.Work_Station__c.fields.Name.Accessible && $ObjectType.WO__c.Accessible && $ObjectType.WO__c.fields.Process__c.Accessible}"/> 
                 </apex:column> 
                 <apex:column width="20%" >
                    <apex:facet name="header">Process Type</apex:facet>           
                     <apex:outputText value="{!wocls.rec.Process__r.RecordType.Name} "  rendered="{!$ObjectType.Process__c.Accessible && $ObjectType.RecordType.Accessible && $ObjectType.RecordType.fields.Name.Accessible && $ObjectType.WO__c.Accessible && $ObjectType.WO__c.fields.Process__c.Accessible}"/> 
                 </apex:column> 
                               
              </apex:pageBlockTable>
            </apex:pageBlock>
      </div>   
  </apex:outputPanel>
  </apex:form>
  
  <script language="javascript">
  
   window.onload = new function() 
   { 
      window.focus(); 
      var ele=document.getElementById('{!JSENCODE($Component.form.block.section.searchString)}');
      if (ele)
      {
         ele.focus();
      }
   }
   
   function fillIn(name, id, processname, processid, wsname, wsid, linename, lineid)
   {  
      var winMain=window.opener;
      if (null==winMain){
         winMain=window.parent.opener;
      }
      
      var elewo = winMain.document.getElementById("workorderId");
      var elewon = winMain.document.getElementById("workorderName");
      var eleprocess = winMain.document.getElementById("processId");
      var eleprocessn = winMain.document.getElementById("processName");
      //var eleproduct = winMain.document.getElementById("productId");
      //var eleproductn = winMain.document.getElementById("productName");
      var elews = winMain.document.getElementById("workstationId");
      var elewsn = winMain.document.getElementById("workstationName");
      var eleline = winMain.document.getElementById("lineitemId");
      var elelinen = winMain.document.getElementById("lineitemName");
      elewo.value=id.substring(0, id.length);   
      elewon.value=name.substring(0, name.length-1);
      eleprocess.value=processid.substring(0, processid.length);   
      eleprocessn.value=processname.substring(0, processname.length-1); 
      //eleproduct.value=productid.substring(0, productid.length);   
      //eleproductn.value=productname.substring(0, productname.length-1); 
      eleline.value=lineid.substring(0, lineid.length);   
      elelinen.value=linename.substring(0, linename.length-1);   
      CloseWindow();
   }

   function CloseWindow()
   {
      var winMain=window.opener;
      if (null==winMain)
      {
         winMain=window.parent.opener;
      }
      winMain.closeLookupPopup();
   }
   
  
   
  
</script>
</htmL>
</apex:page>