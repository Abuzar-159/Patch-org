<apex:page sidebar="false" cache="false" showHeader="false" docType="html-5.0">
    <apex:includeLightning />
    <apex:includeScript value="/lightning/lightning.out.js" />
    
    <script>
        var so = '{!JSENCODE($currentPage.Parameters.SON)}';
        var inv = '{!JSENCODE($currentPage.Parameters.IVN)}';
        !$Lightning.use("ERP7:CardPaymentApp", function() {
            !$Lightning.createComponent(
                "ERP7:StripeCardPayment", {
                "SON":so, "IVN":inv, "AccountId":'{!JSENCODE($currentPage.Parameters.AccountId)}', "DueAmount":'{!JSENCODE($currentPage.Parameters.DA)}'
                },
                accounts,
                function(cmp) {
                    
                });
        });
    </script>
    
    <div id="accounts"></div>
</apex:page>