<apex:page sidebar="false" cache="false" showHeader="true" docType="html-5.0">
    <style>
        
        .uiInput--datetime+.datePicker-openIcon, .uiInput--datetime .datePicker-openIcon, .uiInput--datetime+.timePicker-openIcon, .uiInput--datetime .timePicker-openIcon {
        display:none;
        }
        .uiDayInMonthCell--default {
        background-color: #fff;
        color: #696e71;
        display: block;
        font-family: 'ProximaNovaSoft-Regular';
        font-size: 14px;
        height: 30px;
        width: 30px;
        line-height: 30px;
        text-align: center;
        }
        .uiInput--input .input,  .uiInput--input.input {
        background-color: rgb(255, 255, 255);
        color: rgb(22, 50, 92);
        border: 1px solid rgb(221, 219, 218);
        border-radius: 0.25rem;
        width: 100%;
        transition: border .1s linear,background-color .1s linear;
        display: inline-block;
        padding: 0 0.7rem 0 0.7rem;
        line-height: 1.875rem;
        min-height: calc(1.94rem + 2px);
        }
        .custominput-class2 {
        width: 100% !important;
        z-index: 10 !important;
        height: 32px;
        }
        .slds-table thead th {
        background-color: #dee2e6!important;
        color: rgb(81, 79, 77);
        padding: 0.5rem;
        font-weight: bold!important;
        text-transform: uppercase;
        }
        .slds-tabs_default__item.slds-active,  .slds-tabs_default__item.slds-is-active,  .slds-tabs--default__item.slds-active,  .slds-tabs--default__item.slds-is-active {
        color: #03a9f4!important;
        }
        .createbill-class4-blue {
        font-size: 25px;
        padding-top: 10px;
        color: #2196f3;
        cursor: pointer;
        }
    </style>
    <apex:slds />
    <apex:includeScript value="/lightning/lightning.out.js" />
    <apex:includeLightning />
    <script>
    !$Lightning.use("ERP7:GenerateBillApp", function() {
        !$Lightning.createComponent(
            "ERP7:CreateBill",
            {
                "recordId" : '{!JSENCODE($CurrentPage.parameters.BId)}',
                "navigateToRecord":true,
                "clone":'{!JSENCODE($CurrentPage.parameters.clone)}'
            },
            accounts,
            function(cmp) {
                
            });
    });
    </script>
    
    <div id="accounts"></div>
    
    
</apex:page>