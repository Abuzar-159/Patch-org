    <style>
    input[type=text], textarea, select {
        -webkit-transition: all 0.30s ease-in-out;
        -moz-transition: all 0.30s ease-in-out;
        -ms-transition: all 0.30s ease-in-out;
        -o-transition: all 0.30s ease-in-out;
        outline: none;
        padding: 3px 0px 3px 3px;
        border: 1px solid #DDDDDD;
    } 
    input[type=text]:focus, textarea:focus,select:focus {
        box-shadow: 0 0 5px rgba(255, 0, 24, 1);
        border: 1px solid rgba(255, 0, 24, 1);
     }         
    .bdr {
        -webkit-transition: all 0.30s ease-in-out;
        -moz-transition: all 0.30s ease-in-out;
        -ms-transition: all 0.30s ease-in-out;
        -o-transition: all 0.30s ease-in-out;
        outline: none;    
    } 
    .bdr:focus,{
        -webkit-box-shadow: 0 0 0px rgba(255, 0, 24, 1);
        box-shadow: 0 0 0px rgba(255, 0, 24, 1);
        -o-box-shadow: 0 0 0px rgba(255, 0, 24, 1); 
    }    
    .textfield {
        width:90%;
        height:29px;
        padding: .45em .6em;
        display: inline-block;
        border: 1px solid #dddddd;
        font-size: 1.0em;
        border-radius: 4px;
        -webkit-box-sizing: border-box;
        -moz-box-sizing: border-box;
        box-sizing: border-box;
        color: #9b9b9b;
        background-color:#ffffff;
        text : bold;
    }        
    .right {
        float:left;
        width:50%;
        height:445px;
        border-radius:7px;
        box-shadow:0px 3px 5px 0px rgba(0,0,0, .2);
        background:#f9f9f9;
    }
    .left {
        float:left;
        width:100%; 
        border-radius:7px;
        box-shadow:0px 3px 5px 0px rgba(0,0,0, .2);
        background:#f9f9f9;
        height:445px;
    }
    .titlescn {
        font-family:Arial;
        font-size:11px;
        color:#666666;
        font-weight:bold;
        text-align:center;
        background:#f2f2f2;                
    }
    .titlescn:hover {
        font-family:Arial;
        font-size:12px;
        color:red;        
        font-weight:bold;
        text-align:center;
        background:#f2f2f2;            
    }
    #resultsB {
        width:100%;
        min-height:30px;
        max-height:475px;
        overflow:auto;
    }
    </style>
    
    <script type="text/javascript">
    
    function preventEdit() {                        
        var stage = "{!JSENCODE(upsSetup.Stage__c)}";    
        var accNumber = "{!JSENCODE(upsSetup.UPS_Account_Number__c)}";
        var invDetails = "{!JSENCODE(upsSetup.Invoice_Number__c)}";
      
        document.getElementById('{!$Component.mainform.IPaddress}').disabled = true;
        document.getElementById('{!$Component.mainform.stage}').disabled = true;
        
        if(stage == 'Registered') { document.getElementById('{!$Component.mainform.InvDet}').disabled = true; }
        
        if(stage == 'Processed') {                    
            document.getElementById('{!$Component.mainform.custName}').disabled = true;
            document.getElementById('{!$Component.mainform.compName}').disabled = true;          
            document.getElementById('{!$Component.mainform.title}').disabled = true;
            document.getElementById('{!$Component.mainform.mobileNo}').disabled = true;
            document.getElementById('{!$Component.mainform.email}').disabled = true;
            document.getElementById('{!$Component.mainform.street}').disabled = true;
            document.getElementById('{!$Component.mainform.city}').disabled = true;
            document.getElementById('{!$Component.mainform.country}').disabled = true;
            document.getElementById('{!$Component.mainform.postCode}').disabled = true;
            document.getElementById('{!$Component.mainform.province}').disabled = true;         
            document.getElementById('{!$Component.mainform.comurl}').disabled = true;  
            document.getElementById('{!$Component.mainform.InvDet}').disabled = true;                
        }                  
        
        
    }
   
    function colorToggle(){
        var cl = document.getElementById("mycustomheader").className;
        if(cl == "salesorderdetailsNew") { document.getElementById("mycustomheader").className = "salesorderdetails"; }
        else { document.getElementById("mycustomheader").className = "salesorderdetailsNew"; }    
    }                            
    </script>
    
