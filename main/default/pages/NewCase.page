                                <apex:actionStatus id="spinner3">
                                    <apex:facet name="start">
                                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/spinner24.gif')}" height="19px;" width="19px;"/>
                                    </apex:facet>
                                </apex:actionStatus>  
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <table border="0" width="100%">
                                    <tr>
                                        <td width="30%">
                                            <span style="font-weight:bold; margin-left:12px;">                                                                                                          
                                              <apex:selectList size="1" value="{!category}" id="assist" onchange="hideErr(this.value,'cat');passValue(this.value);" rendered="{!$ObjectType.RecordType.fields.Name.Accessible}">
                                                  <apex:selectOptions value="{!rTypeList}"></apex:selectOptions>
                                              </apex:selectList>                                    
                                          </span><br/>
                                          <label id="cat" for="cat" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_select_a_category}</label>
                                        </td>
                                                                                
                                        <td width="50%">
                                            <apex:repeat value="{!fetchLookup}" var="f"> 
                                                <apex:outputLabel styleClass="icefiledsERP"> <b> {!customLabel}:</b> &nbsp; </apex:outputLabel>
                                                <apex:inputField value="{!newICE[f]}"/>
                                            </apex:repeat> 
                                        </td>                                        
                                    </tr>
                                </table>
                            </td>
                        </tr>

                        <tr>
                            <td>&nbsp;</td>
                        </tr>

                        <tr>
                            <td><span style="font-weight:bold; margin-left:15px;" class="icefiledsERP"> {!$Label.NewCase_Specific_topic}</span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <span style="font-weight:bold; margin-left:15px;">                                   
                                  <apex:inputField value="{!topicList.Topic__c}" id="topic" onchange="hideErr(this.value,'top');" style="width:76%;"/>                                                                   
                                </span><br/>
                                <label id="top" for="top" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_select_a_topic}</label>
                            </td>
                        </tr>

                        <tr>
                            <td>&nbsp;</td>
                        </tr>

                        <tr>
                            <td><span style="font-weight:bold; margin-left:15px;" class="icefiledsERP"> {!$Label.NewCase_Severity} </span> </td>
                        </tr>
                        <tr>
                            <td>
                                <span style="font-weight:bold; margin-left:15px;">                                                                    
                                    <apex:selectList size="1" id="sev" style="width:76%;" value="{!severity}" rendered="{!$ObjectType.ICE__c.fields.Priority__c.Accessible}">
                                        <apex:selectOptions value="{!Priority}"></apex:selectOptions>
                                    </apex:selectList>
                                </span><br/>
                                <label id="seve" for="seve" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_select_a_severity}</label>
                            </td>
                        </tr>

                        <tr>
                            <td>&nbsp;</td>
                        </tr>

                        <tr>
                            <td> <span style="font-weight:bold; margin-left:15px;" class="icefiledsERP"> {!$Label.NewCase_Subject} </span> </td>
                        </tr>
                        <tr>
                            <td>
                                <span style="font-weight:bold; margin-left:15px;">
                                    <apex:inputText size="71" id="sub" onkeyup="hideErr(this.value,'sub');" value="{!subject}" style="width:76%;" rendered="{!$ObjectType.ICE__c.fields.Subject__c.Accessible}"/>
                                </span><br/>
                                <label id="sub" for="sub" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_enter_a_subject}</label>
                            </td>
                        </tr>

                        <tr>
                            <td>&nbsp;</td>
                        </tr>

                        <tr>
                            <td><span style="font-weight:bold; margin-left:15px;" class="icefiledsERP"> {!$Label.NewCase_Description} </span> </td>
                        </tr>
                        <tr>
                            <td>
                                <span style="font-weight:bold; margin-left:15px;"> 
                                  <apex:inputTextarea rows="4" cols="68" id="desp" value="{!description}" onkeyup="hideErr(this.value,'desp');" style="width:76%;" rendered="{!$ObjectType.ICE__c.fields.Description__c.Accessible}"/> 
                              </span><br/>
                              <label id="desp" for="desp" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_enter_a_description}</label>
                            </td>
                        </tr>

                        <tr>
                            <td>&nbsp;</td>
                        </tr>

                        <tr>
                            <td align="center">
                                <apex:commandLink value="{!$Label.ERP7__NewCase_Cancel}" action="{!Back2Support}" styleClass="newcase-btn" style="margin-bottom:10px;" />&nbsp;&nbsp;&nbsp;
                                <input type="button" value="{!$Label.NewCase_Submit_Case}" onclick="iceValidate();" Class="newcase-btn" style="border:0px;" />&nbsp;&nbsp;&nbsp;
                                <apex:actionStatus id="spinner1">
                                    <apex:facet name="start">
                                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/spinner24.gif')}" height="24px;" width="24px;"/>
                                    </apex:facet>
                                </apex:actionStatus>                              
                            </td>
                        </tr>
                    </table>
                    </apex:outputPanel>
                </div>
                <!-- end of div left -->

                <!-- right div -->
                                
                <div style="border-top:1px solid #e7e7e7; border-bottom:1px solid #e7e7e7; border-left:1px solid #e7e7e7; width:48%; min-height:400px; height:auto; float:right;" class="pure-form">
                    <apex:outputPanel id="commAttach">
                     <apex:outputPanel rendered="{!showComments_Attachcments}">  
                        <table border="0" width="100%" style="margin-top:15px;">
                            <tr>
                                <td>
                                    <span style="font-weight:bold; font-size:20px; margin-left:15px;" class="icefiledsERP"> {!$Label.NewCase_Comments_amp_Attachments} </span>
                                    <apex:inputHidden value="{!currentIndex}" id="cntValue" />
                                </td>
                            </tr>
                            
                            <tr> <td>&nbsp;</td> </tr>
                            
                            <tr>
                                <td>
                                    <table border="0" width="100%" bgcolor="f9f9f9" >
                                        <tr>
                                            <td width="4%"><apex:image url="{!URLFOR($Resource.ICE_NewCase,'SRC/images/comment_icon.png')}" width="28" height="28"/></td>
                                            <td width="10%">                                    
                                                <apex:commandLink value="{!$Label.ERP7__NewCase_Comment}" status="spinner8" action="{!uploadComment_Attachment}" id="comm" reRender="commnts,showAttach" style="color:#666; text-decoration:none; font-size:15px; font-weight:bold;" rendered="{!$ObjectType.Note.Accessible}">
                                                    <apex:param name="selectValue" value="Comment" assignTo="{!selectValue}" />
                                                </apex:commandLink>                                  
                                            </td>
                                             <td width="4%"><apex:image url="{!URLFOR($Resource.ICE_NewCase,'SRC/images/attachment_icon.png')}" width="28" height="28"/></td>
                                            <td width="10%">
                                                <apex:commandLink value="{!$Label.ERP7__NewCase_Attachment}" status="spinner8" action="{!uploadComment_Attachment}" id="attach" reRender="showAttach,commnts" style="color:#666; text-decoration:none; font-size:15px; font-weight:bold;" rendered="{!$ObjectType.Note.Accessible}">
                                                    <apex:param name="selectValue" value="Attachment" assignTo="{!selectValue}" /> 
                                                </apex:commandLink>
                                            </td>
                                            
                                            <td width="6%" align="center">
                                                <apex:actionStatus id="spinner8">
                                                    <apex:facet name="start">
                                                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/spinner24.gif')}" height="19px;" width="19px;"/>
                                                    </apex:facet>
                                                </apex:actionStatus>
                                            </td>
                                            <td>&nbsp;</td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>                        
                        </table> 
                     </apex:outputPanel> 
                  </apex:outputPanel>
                    
                    <!-- Add Comments -->
                    <apex:outputPanel id="commnts">
                    <apex:outputPanel id="comment" rendered="{!showCommentBlock}">
                        <table border="" width="100%"  bgcolor="f9f9f9" >
                            <tr>
                                <td>                                      
                                    <span> 
                                        <apex:inputTextarea rows="4" cols="68" value="{!noteDesp}" id="comDesp" style="width:100%;" onkeyup="hideErr(this.value,'comDes');"/>
                                    </span><br/>
                                    <label id="comDes" for="comDes" style="margin-left:15px; font-size:12px;display:none; color:red;">{!$Label.NewCase_Please_enter_a_description}</label>
                                </td>
                            </tr>
                            <tr>
                            <td>&nbsp;</td>
                            </tr>
                            <tr> 
                            <td align="right">
                                 
                                <apex:actionStatus id="spinner7">
                                    <apex:facet name="start">
                                        <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/spinner24.gif')}" height="22px;" width="22px;"/>
                                    </apex:facet>
                                </apex:actionStatus>&nbsp;&nbsp;&nbsp;&nbsp;
                                <input type="button" value="{!$Label.NewCase_Add}" onclick="commentValidate();" Class="newcase-btn" style="border:0px; margin-bottom:10px;" />&nbsp;&nbsp;&nbsp;
                            </td>
                            </tr>
                            <tr>
                            <td>&nbsp;</td>
                            </tr>
                         </table> <br/> 
                         <table border="" width="100%">
                             <apex:repeat value="{!notesList}" var="nl">
                             <tr>
                                 <td>
                                     <span style="margin-left:15px;" > {!nl.Body} </span>
                                 </td>
                             </tr>      
                             <tr><td>&nbsp;</td></tr>                      
                             <tr>
                                 <td>
                                     <span style="margin-left:15px;" > {!$USer.FirstName} &nbsp; {!$User.LastName} </span>
                                 </td>
                             </tr>                             
                             <tr><td>&nbsp;</td></tr>
                             <tr>
                                 <td>
                                 <span style="margin-left:15px;" > 
                                     <apex:outputText value="{0,date, dd/MM/YYYY HH:mm}">
                                         <apex:param value="{!nl.CreatedDate}"/>
                                     </apex:outputText>
                                 </span>     
                                 </td>
                             </tr>
                             <tr><td>&nbsp;</td></tr>
                             </apex:repeat>
                         </table>       
                     </apex:outputPanel>       
                 </apex:outputPanel>        
                    <!-- Add Atachments -->      
                  <apex:outputPanel id="showAttach">                
                    <apex:outputPanel id="attachment" rendered="{!showAttachBlock}">                    
                    <table border="" width="100%">
                                    <tr>
                                        <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">{!$Label.NewCase_FileName}</td>
                                        <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">{!$Label.NewCase_Select_Attachment}</td>
                                        <td align="center" width="25%" style="font-weight:bold;" class="icefiledsERP">{!$Label.NewCase_Attached_Date}</td>
                                        <td align="center" width="25%"> {!$Label.NewCase_Action} </td>
                                    </tr>

                                    <apex:variable var="attachmentCounter" value="{!0}" />
                                    <apex:repeat value="{!attachmentList}" var="attach">
                                        <tr>
                                            <td align="center">  
                                                <apex:outputLink value="{!URLFOR($Action.Attachment.Download,attach.Att.Id)}" rendered="{!if(attach.Att.id != Null,true,false)}" target="_blank"
                                                  styleClass="titlesB" style="color:red;">
                                                   <apex:outputText value="{!attach.attName}" />  
                                              </apex:outputLink>
                                            </td>

                                            <td align="center">
                                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/whiteplus.png')}" title="{!$Label.ERP7__NewCase_Add_Attachment}" onclick=" if('{!preventDisplay}' == 'false') { popupAttach('{!attachmentCounter + 1}');}" />
                                            </td>

                                            <td align="center">
                                                <apex:outputText value="{0,date, dd/MM/YYYY HH:MM}">
                                                    <apex:param value="{!attach.dt}" />
                                                </apex:outputText>
                                            </td>

                                            <td align="center">
                                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/plus.png')}" style="cursor:pointer;" 
                                                    rendered="{!if(attachmentCounter == 0 && !(preventDisplay), true, false)}" onclick="addAttachment('{!attachmentCounter + 1}');" title="{!$Label.ERP7__NewCase_Add_Attachment}"></apex:image>
                                                
                                                <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/minus.png')}" rendered="{!if(attachmentCounter != 0 && attachmentListSize > 1 && !(preventDisplay), true, false)}"
                                                        style="cursor:pointer;" onclick="removeAttachment('{!attachmentCounter + 1}');" title="{!$Label.ERP7__NewCase_Remove_Attachment}"></apex:image>    
                                            </td>
                                        </tr>
                                        <apex:variable var="attachmentCounter" value="{!attachmentCounter + 1}" />
                                    </apex:repeat>
                                </table>                            
                    </apex:outputPanel> 
                 </apex:outputPanel>
                </div>
                <!-- end of div right -->    
                </div>            
            </div>
        <apex:outputPanel id="popform">
            <div id="fade" class="popupBackground"></div>
            <div id="light9" class="customPopup">
                <DIV class="headerTitle"></DIV>
                <div style="position:absolute; top: -1px; left:358px;">
                    <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/close.png')}" onclick="closepopup();"></apex:image>
                </div>
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td height="30">&nbsp;</td>
                    </tr>
                    <tr>
                        <td width="7%"> <!-- -->
                            <apex:inputHidden value="{!currentIndex}" id="indexvalform" />
                        </td>
                        <td width="24%" class="rtext">{!$Label.NewCase_File_Upload}</td>
                        <td width="69%" align="left">
                            <apex:inputFile value="{!newAttachment.body}" filename="{!newAttachment.name}" id="attId" />
                        </td>
                    </tr>
                </table>
                <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                        <td width="55%" align="center" height="40">&nbsp;</td>
                    </tr>
                    <tr>
                        <td width="55%" align="center">
                            <apex:commandLink value="{!$Label.ERP7__NewCase_Upload}" action="{!uploadAttachment}" styleClass="newcase-btn" onclick="var ik = document.getElementById('{!$Component.popform.attId}').value; if(ik == '') return false;" rendered="{!$ObjectType.Attachment.Createable}"/>
                        </td>
                    </tr>
                    <tr>
                        <td width="14%">&nbsp;</td>
                    </tr>
                </table>
            </div></apex:outputPanel>
        </apex:form>
    </body>

    <style>
        .popupBackground {
            background-color: black;
            opacity: 0.20;
            filter: alpha(opacity=20);
            position: absolute;
            width: 100%;
            height: 1000%;
            top: 0;
            left: 0;
            z-index: 9998;
            display: none;
        }
        .customPopup {
            background: #ffffff;
            border-style: solid;
            border-width: 0px;
            left: 35%;
            display: none;
            border-radius: 7px;
            position: absolute;
            z-index: 9999;
            width: 380px;
            height: 170px;
            top: 180px;
        }
        .ui-btnsubmit {
            height: 40px;
            width: 156px;
            border: 1px solid #fff;
            background: url({!URLFOR($Resource.SCM,'SCM/Images/submitbtn.png')
        }
        );
        cursor:pointer;
    }
    .ui-btnsubmit:hover {
        height: 40px;
        width: 156px;
        background: url({!URLFOR($Resource.SCM,'SCM/Images/submitbtnh.png')
    }
    );
    border:1px solid #fff;
    cursor:pointer;
}
.ui-btncancel {
    height:40px;
    width:156px;
    border:1px solid #fff;
    background:url({!URLFOR($Resource.SCM,'SCM/Images/cancel_icon.png')
}
);
cursor:pointer;
}
.ui-btncancel:hover {
    height:40px;
    width:156px;
    background:url({!URLFOR($Resource.SCM,'SCM/Images/cancel_iconh.png')
}
);
border:1px solid #fff;
cursor:pointer;
}
.ui-btnsave {
    height:40px;
    width:156px;
    border:1px solid #fff;
    background:url({!URLFOR($Resource.SCM,'SCM/Images/save_icon.png')
}
);
cursor:pointer;
}
.ui-btnsave:hover {
    height:40px;
    width:156px;
    background:url({!URLFOR($Resource.SCM,'SCM/Images/save_iconh.png')
}
);
border:1px solid #fff;
