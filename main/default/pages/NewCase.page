    <body> <!-- prevent Edit-->
        <apex:form id="myFrm">
            <apex:actionFunction name="{!$Label.ERP7__NewCase_addAttachments}" action="{!addAttachment}" reRender="myFrm" status="spinner8"/>
              
            <apex:actionFunction name="{!$Label.ERP7__NewCase_removeAttachments}" action="{!removeAttachment}" reRender="myFrm" status="spinner8"/>
                        
            <apex:actionFunction name="newICE" action="{!saveNewICE}" reRender="commnts,commAttach,iceDetails" status="spinner1"> 
                <apex:param name="assistance" value="" assignTo="{!category}" />
                <apex:param name="topic" value="" assignTo="{!topic}" />
                <apex:param name="sev" value="" assignTo="{!severity}" />
                <apex:param name="sub" value="" assignTo="{!subject}" />
                <apex:param name="desp" value="" assignTo="{!description}" />
            </apex:actionFunction>

            <apex:actionFunction name="popLookup" action="{!fetchLookup}" reRender="myFrm" status="spinner3">
                <apex:param name="lookupId" value="" assignTo="{!lookupId}" />
            </apex:actionFunction>
            
            <apex:actionFunction name="uploadComments" action="{!uploadComment}" reRender="myFrm" status="spinner7">
                <apex:param name="param1" value="" assignTo="{!noteDesp}"/>
            </apex:actionFunction>
            

