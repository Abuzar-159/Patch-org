<apex:page standardController="Project__c" extensions="ProjectDocument" docType="html-5.0" sidebar="false" standardStylesheets="true" showHeader="false" id="ProjectDoc">
    <script>
      function resizeIframe(obj) {
        obj.style.height = obj.contentWindow.document.body.scrollHeight + 'px';
      }
    //window.print();
    </script>  
    <style>
    @page {
        size: 6in 4in;
        @top-center {
            content: element(header);
        }
        @bottom-left {
            content: element(footer);
        }
    }
    </style>
  <form> 
  <iframe src="data:application/pdf;base64,{!pdf}" style="width:100%;height:700px;" id="frame" frameborder="0" onload="resizeIframe(this);"></iframe><!--height:1680px;-->
  </form>
</apex:page>