<apex:page docType="html-5.0" standardController="ICE__c" standardStylesheets="false" showHeader="false" cache="false">
    <script src="/soap/ajax/29.0/connection.js" type="text/javascript"></script>
    <script> 
        window.oncontextmenu = function() {return false;}
        sforce.connection.sessionId = "{!$Api.Session_Id}";
    </script>

    <c:e_Sign_Component id="mycin" signName="{!'Signature'}"></c:e_Sign_Component>
    
    <apex:outputPanel >
        <img id="signImage" />
        <script>
            var recId = '{!$CurrentPage.parameters.id}';            
            var specificQuery = sforce.connection.query("select Id, ParentId, Name from Attachment where ParentId = '"+recId+"' "+" Limit 1");            
            var records = specificQuery.getArray("records");
            
            if(records[0].Id != null){            
                var pathArray = window.location.pathname.split( '/' );                     
                if(pathArray[2] == undefined) { 
                    
                } else { 
                    var strurl = '/servlet/servlet.FileDownload?file='+records[0].Id;                        
                    document.getElementById('signImage').src = strurl;
                    $('[id$=mycin]').hide();
                }
            }else{
                $('[id$=mycin]').show();
            }
        </script>
    </apex:outputPanel>
</apex:page>