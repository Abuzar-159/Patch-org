<apex:page controller="Receiving_Label" sidebar="false" showHeader="false" id="page" standardStylesheets="false" tabStyle="Product2" docType="html-5.0" applyBodyTag="false"  renderAs="pdf" readOnly="true" action="{!createLabel}"><!-- renderAs="advanced_pdf" -->
    <head>
        <style type="text/css" media="print">
            @page {
            size: 3in 4in;
            /*@top-center {
            content: element(header);
            }
            @bottom-left {
            content: element(footer);
            }*/
            }
            
            /*  div.header {
            padding: 2px;
            position: running(header);
            }
            
            div.footer {
            display: block;
            padding: 2px;
            
            position: running(footer);
            }*/
            
            /*  .pagenumber:before {
            content: counter(page);
            }
            
            .pagecount:before {
            content: counter(pages);
            }*/
            
        </style>
        
    </head>
    <apex:form >
        
        <div class="content">
            <apex:variable var="count" value="{!0}"/>
            <apex:repeat id="sos" value="{!wrap.stcklist}" var="wrp">
                <div style="page-break-before: {!if(count==0,'avoid','always')}; width:100%;min-height:125px;float:left;height:auto;border:0px solid #dddddd;padding:0px;">
                    <div style="width:100%;float:left;">
                        <div style="color:#333;font-size:12px;padding-top:10px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <strong>Date:</strong><apex:outputText value="{0, date, dd/MM/yyyy}">
                            <apex:param value="{!wrp.CreatedDate}" /> 
                            </apex:outputText>&nbsp;<br/>
                            <apex:outputText rendered="{!and(wrp.Logistic__c != null,wrp.Logistic__c != '')}">
                                <strong>PO : </strong>{!wrp.ERP7__Logistic__r.ERP7__Purchase_Order__r.Name}
                            </apex:outputText>
                            <apex:outputText rendered="{!and(wrp.Manufacturing_Order__c != null,wrp.Manufacturing_Order__c != '')}">
                                <strong>MO : </strong>{!wrp.ERP7__Manufacturing_Order__r.Name}
                            </apex:outputText>
                        </div>
                        <div style="color:#333;padding-top:5px;font-size:14px;font-weight:bold;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;"> 
                            Product : {!wrp.ERP7__Product__r.Name} 
                        </div>
                        <div style="color:#333;font-size:12px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <br/><strong>Product Code:</strong>  {!wrp.ERP7__Product__r.ProductCode}
                        </div>
                        <div style="color:#333;font-size:12px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <br/><strong>
                            Quantity:</strong>  
                            <apex:outputText value="{0, number, {!$Label.ERP7__Decimal_places_in_Receiving_label}}">
                                <apex:param value="{!wrp.Quantity__c}" />
                            </apex:outputText>
                            <!--{!wrp.Quantity__c} -->
                            <apex:outputText rendered="{!and(wrp.ERP7__Product__r.QuantityUnitOfMeasure != null,wrp.ERP7__Product__r.QuantityUnitOfMeasure != '')}">({!wrp.ERP7__Product__r.QuantityUnitOfMeasure})</apex:outputText>
                        </div>
                        <div style="color:#333;font-size:12px;padding-left:0px;margin-top:4px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <apex:outputText rendered="{!wrp.ERP7__Product__r.Lot_Tracked__c}"><strong>Lot Number: </strong>{!wrp.ERP7__Material_Batch_Lot__r.Name}</apex:outputText>
                            <apex:outputText rendered="{!wrp.ERP7__Product__r.Serialise__c}"> <strong>Serial Number: </strong>{!wrp.ERP7__Serial__r.Name}</apex:outputText>
                            
                        </div>
                        
                        <div style="color:#333;font-size:10px;text-align:center;font-family:sans-serif,arial;float:left;width:100%;height:auto;">  
                            
                            <c:AQBarcodeZone id="brcd128" BrcdHeight="60" BrcdType="{!'code128'}" Value="{!if(wrp.ERP7__Product__r.Lot_Tracked__c,wrp.ERP7__Material_Batch_Lot__r.Name,wrp.ERP7__Serial__r.Name)}"> </c:AQBarcodeZone>
                            
                        </div>    
                        <div style="color:#333;font-size:12px;padding-left:0px;padding-top:20px;margin-top:10px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;overflow:hidden;">
                            <strong>Expiry Date :</strong> 
                            <apex:outputText rendered="{!wrp.ERP7__Product__r.Lot_Tracked__c}" value="{0, date, dd/MM/yyyy}"><apex:param value="{!wrp.ERP7__Material_Batch_Lot__r.Shelf_Life_Expiration_Date__c}" /> </apex:outputText>
                            <apex:outputText rendered="{!wrp.ERP7__Product__r.Serialise__c}" value="{0, date, dd/MM/yyyy}"><apex:param value="{!wrp.ERP7__Serial__r.Shelf_Life_Expiration_Date__c}" /> </apex:outputText>
                            
                        </div>                      
                    </div> 
                </div>
                <apex:variable var="count" value="{!count+1}"/>
            </apex:repeat>
            <apex:repeat id="lot" value="{!wrap.Lotlist}" var="batch">
                <div style="page-break-before: {!if(count==0,'avoid','always')}; width:100%;min-height:125px;float:left;height:auto;border:0px solid #dddddd;padding:0px;">
                    <div style="width:100%;float:left;">
                        <div style="color:#333;font-size:12px;padding-top:10px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <strong>Date:</strong><apex:outputText value="{0, date, dd/MM/yyyy}">
                            <apex:param value="{!batch.lot.CreatedDate}" /> 
                            </apex:outputText>&nbsp;<br/>
                        </div>
                         <div style="color:#333;padding-top:5px;font-size:14px;font-weight:bold;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;"> 
                            Product : {!batch.lot.ERP7__Product__r.Name} 
                        </div>
                        <div style="color:#333;font-size:12px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <br/><strong>Product Code:</strong>  {!batch.lot.ERP7__Product__r.ProductCode}
                        </div>
                         <div style="color:#333;font-size:12px;padding-left:0px;margin-top:4px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                        <strong>Lot Number: </strong>{!batch.lot.Name}
                        </div>
                        <div style="color:#333;font-size:10px;text-align:center;font-family:sans-serif,arial;float:left;width:100%;height:auto;">  
                            <c:AQBarcodeZone id="brcd128" BrcdHeight="60" BrcdType="{!'code128'}" Value="{!batch.lot.Name}"> </c:AQBarcodeZone><br/>
                        </div>
                       
                        <div style="color:#333;font-size:12px;padding-left:0px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;">
                            <br/><strong>
                            Quantity:</strong>  
                            <apex:outputText value="{0, number, {!$Label.ERP7__Decimal_places_in_Receiving_label}}">
                                <apex:param value="{!batch.lot.Available_Quantity__c}" />
                            </apex:outputText>
                            <!--{!wrp.Quantity__c} -->
                            <apex:outputText rendered="{!and(batch.lot.ERP7__Product__r.QuantityUnitOfMeasure != null,batch.lot.ERP7__Product__r.QuantityUnitOfMeasure != '')}">({!batch.lot.ERP7__Product__r.QuantityUnitOfMeasure})</apex:outputText>
                        </div>
                         <div style="color:#333;font-size:12px;padding-left:0px;margin-top:4px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        <strong>Avaialble Locations :</strong>
                             <div style="width:100%;overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                 {!batch.availableLocations}
                             </div>
                        </div>
                        <div style="color:#333;font-size:12px;padding-left:0px;padding-top:10px;margin-top:10px;font-family:sans-serif,arial;text-align:left;float:left;width:100%;overflow:hidden;">
                            <strong>Expiry Date :</strong> 
                            <apex:outputText value="{0, date, dd/MM/yyyy}"><apex:param value="{!batch.lot.Shelf_Life_Expiration_Date__c}" /> </apex:outputText>
                            
                        </div> 
                    </div>
                </div>
            </apex:repeat>
        </div>
    </apex:form>
</apex:page>