<apex:page controller="StillToFulfill" docType="html-5.0" sidebar="false"  id="page" standardStylesheets="false">
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width,initial-scale=1"/>
            <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
            <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource,'assets/styles/erp_mark7_bootstrap.css')}"/>
            <apex:stylesheet value="{!URLFOR($Resource.Accordions,'/Src/jquery-ui.css')}"/>
            <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
            <style>
           
           .ui-accordion .ui-accordion-content {
    padding: 1em 0em;
    border-top: 0;
    overflow: auto;
}
        .ui-accordion .ui-accordion-header {
    display: block;
    cursor: pointer;
    position: relative;
    margin: 2px 0 0 0;
    
    min-height: 0;
    font-size: 100%;
}
               .ui-widget-content {
    border: 0px solid #ddd;
    min-height: 100px;
    border-radius:0px;
    }
    .ui-state-default .ui-icon {
    background-image:url('https://erp-mark-7-dev-ed--erp7.visualforce.com/resource/1474534974000/erp7__Accordions/Src/images/ui-icons_454545_256x240.png');
    color:#fff !important;
   
}
    
        /* Interaction states----------------------------------*/
        .ui-state-default,
        .ui-widget-content .ui-state-default,
        .ui-widget-header .ui-state-default {
            /*border: 0px solid #dddddd;
            background: #b5b4b4;
            font-weight: normal;
            color: #ffffff;*/
            border: 0px solid #31d0e5;
            background: transparent;
            font-weight: normal;
            color: #31d0e5;
            border-top: 1px dotted #dddddd;
            border-radius: 0px;
        }
        .ui-state-default a,
        .ui-state-default a:link,
        .ui-state-default a:visited {
            color: #555555;
            text-decoration: none;
        }
        .ui-state-hover,
        .ui-widget-content .ui-state-hover,
        .ui-widget-header .ui-state-hover,
        .ui-state-focus,
        .ui-widget-content .ui-state-focus,
        .ui-widget-header .ui-state-focus {
            border: 0px solid #dddddd;
            background: #31d0e5;
            font-weight: normal;
            color: #FFFFFF;
            outline: none;
            border: none;
        }
        .ui-state-hover a,
        .ui-state-hover a:hover,
        .ui-state-hover a:link,
        .ui-state-hover a:visited,
        .ui-state-focus a,
        .ui-state-focus a:hover,
        .ui-state-focus a:link,
        .ui-state-focus a:visited {
            color: #212121;
            text-decoration: none;
        }
        .ui-state-active,
        .ui-widget-content .ui-state-active,
        .ui-widget-header .ui-state-active {
           /* border: 0px solid #dddddd;
            background: #31d0e5;
            font-weight: normal;
            color: #ffffff;*/
            border: 0px solid #31d0e5;
            background: #31d0e5;
            font-weight: normal;
            color: #ffffff;
            border-top: 1px dotted #dddddd;
            border-radius: 0px;
        }
        .ui-state-active a,
        .ui-state-active a:link,
        .ui-state-active a:visited {
            color: #212121;
            text-decoration: none;
        }
                .erp_mark7 .slds-button--brand {
                padding-left: 1rem;
                padding-right: 1rem;
                text-align: center;
                vertical-align: middle;
                background-color: #31d0e5;
                border: 1px solid #31d0e5;
                color: #fff;
                }
                .erp_mark7 .slds-button--brand:hover, .erp_mark7 .slds-button--brand:focus {
                background-color: #65d6e5;
                color: white;
                }
                .epr_Mark7 h1, .epr_Mark7 .h1, .epr_Mark7 h2, .epr_Mark7 .h2, .epr_Mark7 h3, .epr_Mark7 .h3 {
                margin-top: 0px;
                margin-bottom: 10px;
                }
            </style>
            <script>
                $(function() {
                    $("#accordion").accordion({
                        active: 0,
                        heightStyle: "content"
                    });
                });
                
                
                var j$ = jQuery.noConflict();
                var apexAccountList = [];
                
                <apex:repeat value="{!accountList}" var="accList">
                apexAccountList.push("{!accList.name}"); 
                </apex:repeat>
                
                //on Document ready
                j$(document).ready(function() {
                    j$(".apexaccountautocomplete").autocomplete({
                        source: apexAccountList,
                        select:function(event, ui)
                        {
                          showSelected(ui.item.value); 
                           
                        }
                        
                        
                        
                    });
                });
            </script>
            <style>
                .
                .search {
                position: auto;
                }
                .search input {
                text-indent: 30px;
                }
                .search .fa-search {
                position: relative;
                top: 2px;
                left: 110px;
                font-size: 15px;
                }
                #imaginary_container{
                margin-top:20%; 
                }
                .stylish-input-group .input-group-addon{
                background: white !important; 
                }
                .stylish-input-group .form-control{
                border-right:0; 
                box-shadow:0 0 0; 
                border-color:#ccc;
                }
                .stylish-input-group button{
                border:0;
                background:transparent;
                }
            </style>
        </head>
        <body>
            <apex:form id="mainFrm">
                <apex:pageMessages id="pmsg"/>
                <apex:outputPanel >
                </apex:outputPanel>
                <apex:actionFunction name="showSelected" reRender="solable" oncomplete="Load();" status="spinnerSS">
                    <apex:param name="param1" value="" assignTo="{!sOrder}" />
                </apex:actionFunction>
                <apex:actionFunction name="Load" action="{!StillToFulfillCustomSO}"/>
                
                <apex:slds />
                <div class="erp_mark7">
                    <div class="slds-page-header slds-page-header_object-home">
                        <div class="slds-grid">
                            <div class="slds-col slds-has-flexi-truncate">
                                <div class="slds-media slds-no-space slds-grow">
                                    <div class="slds-media__figure">
                                        <span class="slds-icon_container slds-icon-standard-work-type">
                                            <svg class="slds-icon slds-icon--large " aria-hidden="true">
                                                <use xlink:href="{!URLFOR($Resource.SLDS213, 'assets/icons/standard-sprite/svg/symbols.svg#work_type')}"></use>
                                            </svg>
                                        </span>
                                    </div>
                                    <div class="slds-media--body" style="width:207px">
                                        <h1 class="slds-page-header--title slds-p-right_x-small slds-m-top--xx-small" style="font-size:20px;" >
                                            Still To Fulfill
                                        </h1>
                                    </div>
                                      
                                      
                                </div>
                                
                            </div>
                             <apex:outputPanel rendered="{!if(Back2SO != '',true,false)}">
                                       <div class="slds-col slds-no-flex slds-grid slds-align-top slds-p-bottom_xx-small">
                                       <ul  style=" display:inline-flex;">
                                        <li style="padding-right: 30px;">
                                            <a href="/{!Back2SO}" style="text-decoration:none;" class="slds-button slds-button--brand">Back</a>
                                        </li>
                                        <!--<li style="padding-right: 30px;">
                                            <a href="#" style="text-decoration:none;" onclick="createPackages();"><i class="fa fa-archive" aria-hidden="true"  style="color:#0dc2d9;"></i> Pack</a>
                                        </li>
                                        <li style="padding-right: 30px;">
                                            <a href="#" style="text-decoration:none;" onclick="createShipments();"><i class="fa fa-plane" aria-hidden="true"  style="color:#00c6b7;"></i> Ship</a>
                                        </li>-->
                                        </ul>
                                        </div>
                                        </apex:outputPanel>
                        </div>
                        
                    </div>
                </div>
              
                <div class="erp_mark7">
                    <div class="slds-grid slds-m-around--small">
                        <!--<apex:outputLabel style="font-size:16px;" id="solable">Sales Order &nbsp;</apex:outputLabel>-->
                        <!--<apex:inputField styleClass="apexaccountautocomplete slds-input" value="{!so.Name}" onselect="showSelected(this.value);" style="width:200px;"/> &nbsp;&nbsp;-->
                        <apex:actionStatus id="spinnerSS">
                            <apex:facet name="start">
                                <apex:image url="{!URLFOR($Resource.PickPackShipResource,'/assets/images/spinners/slds_spinner_brand.gif')}" height="25px;" width="25px;"/>
                            </apex:facet>
                        </apex:actionStatus>
                    </div>
                </div>
                
              
                
                <apex:outputPanel id="accor" >
                    <apex:slds />
                    <div class="erp_mark7">
                        <div id="accordion">
                            <h3>
                                Items that has not been picked 
                                <apex:outputPanel rendered="{!if(pickItems!=null,true,false)}"> 
                                    ({!pickItems})    
                                </apex:outputPanel>
                            </h3>
                            <!--({!pickItems})-->
                            <div>
                                <p>
                                <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <th scope="col">
                                                <div class="slds-truncate" title="Product">Product</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Line Item">Line Item</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Family">Family</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Quantity">Quantity</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Picked Quantity">Picked</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Packed Quantity">Packed</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Shipped Quantity">Shipped</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Shipped Quantity">In Stock</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <apex:outputPanel id="one">
                                        <apex:repeat value="{!soliItemList}" var="so_li">
                                            <apex:outputPanel rendered="{!if(so_li.Picked_Quantity__c != so_li.Quantity__c,true,false)}">
                                                <tbody>
                                                    <tr>
                                                        <td scope="row" data-label="Product">
                                                            <apex:outputLink value="/{!so_li.ERP7__Product__r.Id}" target="_blank" style="color:#005fb2;">{!so_li.ERP7__Product__r.Name}</apex:outputLink>
                                                            &nbsp;<apex:image url="{!so_li.Product__r.Picture__c}" id="itemImage" style="height: 40px; width: 40px;" rendered="{!if(so_li.Product__r.Picture__c != null,true,false)}"/>
                                                        </td>
                                                        <td data-label="Line Item">
                                                            <apex:outputLink value="/{!so_li.Id}" target="_blank" style="color:#005fb2;">{!so_li.Name}</apex:outputLink>
                                                            <!--<div class="slds-truncate" title="{!so_li.Name}">{!so_li.Name}</div>-->
                                                        </td>
                                                        <th scope="row" data-label="Family">
                                                            <div class="slds-truncate" title="{!so_li.ERP7__Product__r.Family}"><a href="javascript:void(0);">{!so_li.ERP7__Product__r.Family}</a></div>
                                                        </th>
                                                        <td data-label="Quantity">
                                                            <div class="slds-truncate" title="{!so_li.Quantity__c}">{!so_li.Quantity__c}</div>
                                                        </td>
                                                        <td data-label="Picked">
                                                            <div class="slds-truncate" title="{!so_li.Picked_Quantity__c}">{!so_li.Picked_Quantity__c}</div>
                                                        </td>
                                                        <td data-label="Packed">
                                                            <div class="slds-truncate" title="{!so_li.Packed_Quantity__c}">{!so_li.Packed_Quantity__c}</div>
                                                        </td>
                                                        <td data-label="Shipped">
                                                            <div class="slds-truncate" title="{!so_li.Shipped_Quantity__c}">{!so_li.Shipped_Quantity__c}</div>
                                                        </td>
                                                        <td data-label="Shipped">
                                                            <div class="slds-truncate" title="{!so_li.Shipped_Quantity__c}">{!so_li.ERP7__Reserved_Quantity__c}</div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </apex:outputPanel>
                                        </apex:repeat>
                                    </apex:outputPanel>
                                </table>
                                </p>
                            </div>
                            <h3>
                                Items that has been picked but not packed 
                                <apex:outputPanel rendered="{!if(packItems!=null,true,false)}">
                                    ({!packItems})
                                </apex:outputPanel>
                                <!--<ul class="slds-grid--vertical-align-left" style=" display:inline-flex;float: right;background: #fff; padding: 5px; border-radius: 2px;font-size: 12px;"> 
                                    <li style="">
                                        <a href="#" style="text-decoration:none;color: #337ab7;" onclick="createPackages();"><i class="fa fa-archive" aria-hidden="true" style="color:#666666;"></i> Pack</a>
                                    </li>
                                    </ul>-->
                            </h3>
                            <div>
                                <p>
                                <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <th scope="col">
                                                <div class="slds-truncate" title="Product">Product</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Line Item">Line Item</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Family">Family</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Quantity">Quantity</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Picked Quantity">Picked</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Packed Quantity">Packed</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Shipped Quantity">Shipped</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <apex:repeat value="{!soliItemList}" var="so_li">
                                        <apex:outputPanel rendered="{!if(so_li.Picked_Quantity__c != Null && so_li.Picked_Quantity__c > 0 && ((so_li.Packed_Quantity__c != Null && so_li.Picked_Quantity__c > so_li.Packed_Quantity__c) || so_li.Packed_Quantity__c == Null),true,false)}">
                                            <tbody>
                                                <tr>
                                                    <td scope="row" data-label="Product">
                                                        <apex:outputLink value="/{!so_li.ERP7__Product__r.Id}" target="_blank" style="color:#005fb2;">{!so_li.ERP7__Product__r.Name}</apex:outputLink>
                                                        &nbsp;<apex:image url="{!so_li.Product__r.Picture__c}" id="itemImage" style="height: 40px; width: 40px;" rendered="{!if(so_li.Product__r.Picture__c != null,true,false)}"/>
                                                    </td>
                                                    <td data-label="Line Item">
                                                        <apex:outputLink value="/{!so_li.Id}" target="_blank" style="color:#005fb2;">{!so_li.Name}</apex:outputLink>
                                                        <!--<div class="slds-truncate" title="{!so_li.Name}">{!so_li.Name}</div>-->
                                                    </td>
                                                    <th scope="row" data-label="Family">
                                                        <div class="slds-truncate" title="{!so_li.ERP7__Product__r.Family}"><a href="javascript:void(0);">{!so_li.ERP7__Product__r.Family}</a></div>
                                                    </th>
                                                    <td data-label="Quantity">
                                                        <div class="slds-truncate" title="{!so_li.Quantity__c}">{!so_li.Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Picked">
                                                        <div class="slds-truncate" title="{!so_li.Picked_Quantity__c}">{!so_li.Picked_Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Packed">
                                                        <div class="slds-truncate" title="{!so_li.Packed_Quantity__c}">{!so_li.Packed_Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Shipped">
                                                        <div class="slds-truncate" title="{!so_li.Shipped_Quantity__c}">{!so_li.Shipped_Quantity__c}</div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </apex:outputPanel>
                                    </apex:repeat>
                                </table>
                                </p>
                            </div>
                            <h3>
                                Items that has been picked, packed but not shipped 
                                <apex:outputPanel rendered="{!if(shipItems != null,true,false)}">
                                    ({!shipItems})
                                </apex:outputPanel>
                                <!--<ul class="slds-grid--vertical-align-left" style=" display:inline-flex;float: right;background: #fff; padding: 5px; border-radius: 2px;font-size: 12px;"> 
                                    <li style="">
                                       <a href="#" style="text-decoration:none;color: #337ab7;" onclick="createShipments();"><i class="fa fa-plane" aria-hidden="true"  style="color:#666666;"></i> Ship</a>
                                    </li>
                                    </ul> -->
                            </h3>
                            <div>
                                <p>
                                <table class="slds-table slds-table--bordered slds-table--cell-buffer">
                                    <thead>
                                        <tr class="slds-text-title--caps">
                                            <th scope="col">
                                                <div class="slds-truncate" title="Product">Product</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Line Item">Line Item</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Family">Family</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Quantity">Quantity</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Picked Quantity">Picked</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Packed Quantity">Packed</div>
                                            </th>
                                            <th scope="col">
                                                <div class="slds-truncate" title="Shipped Quantity">Shipped</div>
                                            </th>
                                        </tr>
                                    </thead>
                                    <apex:repeat value="{!soliItemList}" var="so_li">
                                        <apex:outputPanel rendered="{!if(so_li.Packed_Quantity__c != Null && so_li.Packed_Quantity__c > 0 && ((so_li.Shipped_Quantity__c != Null && so_li.Packed_Quantity__c > so_li.Shipped_Quantity__c) || so_li.Shipped_Quantity__c == Null),true,false)}">
                                            <tbody>
                                                <tr>
                                                   <td scope="row" data-label="Product">
                                                        <apex:outputLink value="/{!so_li.ERP7__Product__r.Id}" target="_blank" style="color:#005fb2;">{!so_li.ERP7__Product__r.Name}</apex:outputLink>
                                                        &nbsp;<apex:image url="{!so_li.Product__r.Picture__c}" id="itemImage" style="height: 40px; width: 40px;" rendered="{!if(so_li.Product__r.Picture__c != null,true,false)}"/>
                                                    </td>
                                                    <td data-label="Line Item">
                                                        <apex:outputLink value="/{!so_li.Id}" target="_blank" style="color:#005fb2;">{!so_li.Name}</apex:outputLink>
                                                        <!--<div class="slds-truncate" title="{!so_li.Name}">{!so_li.Name}</div>-->
                                                    </td>
                                                    <th scope="row" data-label="Family">
                                                        <div class="slds-truncate" title="{!so_li.ERP7__Product__r.Family}"><a href="javascript:void(0);">{!so_li.ERP7__Product__r.Family}</a></div>
                                                    </th>
                                                    <td data-label="Quantity">
                                                        <div class="slds-truncate" title="{!so_li.Quantity__c}">{!so_li.Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Picked">
                                                        <div class="slds-truncate" title="{!so_li.Picked_Quantity__c}">{!so_li.Picked_Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Packed">
                                                        <div class="slds-truncate" title="{!so_li.Packed_Quantity__c}">{!so_li.Packed_Quantity__c}</div>
                                                    </td>
                                                    <td data-label="Shipped">
                                                        <div class="slds-truncate" title="{!so_li.Shipped_Quantity__c}">{!so_li.Shipped_Quantity__c}</div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </apex:outputPanel>
                                    </apex:repeat>
                                </table>
                                </p>
                            </div>
                        </div>
                    </div>
                </apex:outputPanel>
            </apex:form>
        </body>
    </html>
</apex:page>