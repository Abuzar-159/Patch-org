    <script>
            var j$ = jQuery.noConflict();
        var apexAccountList = [];
        var apexManList = [];
        var apexProjectList = [];
        var apexTeamList = [];
 
        $(function() {
            $("#accordion").accordion({
            
                active: 0,
                heightStyle: "content"
            });
        });       
        
        <apex:repeat value="{!projectList}" var="accList">
            apexProjectList.push("{!accList.name}"); 
        </apex:repeat>
        
        <apex:repeat value="{!TeamList}" var="tmList">
            apexTeamList.push("{!tmList.name}");
        </apex:repeat>
        
        //on Document ready
        j$(document).ready(function() {
            j$(".apexaccountautocomplete").autocomplete({
                source: apexProjectList,
                select:function(event, ui)
                {
                  showSelected(ui.item.value); 
                   
                }
            });
        });
        
        j$(document).ready(function() {
            j$(".apexmanautocomplete").autocomplete({
                source: apexTeamList,
                select:function(event, ui)
                {
                  showSelected(ui.item.value); 
                   
                }
            });
        });
               
    </script>

