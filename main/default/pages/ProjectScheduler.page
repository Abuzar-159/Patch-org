                    $('[id$=productTextBoxId]')
                        .autocomplete({
                            minLength: 2,
                            source: function(request, response) {
                                queryTerm = request.term;
                                Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.ManagePROJs.searchProjects}', request.term, function(result, event) {
                                    if(event.type == 'exception') {
                                        alert(event.message);
                                    } else {
                                        alert(result);
                                        searchObject = result;
                                        response(searchObject);
                                    }
                                },
                                {
                                    escape: true
                                });
                            },
                            focus: function(event, ui) {
                                $('[id$=productTextBoxId]')
                                    .val(ui.item.Name);
                                
                                return false;
                            },
                            select: function(event, ui) {
                                $('[id$=productTextBoxId]')
                                    .val(ui.item.Name);
                                $('[id$=searchProductId]')
                                    .val(ui.item.Id);
                                
                                Evaluate();
                                return false;
                            },
                        })
                        .data("ui-autocomplete")
                        ._renderItem = function(ul, item) {
                           
                            var entry = "<a style='text-decoration:none;color:#333;'>" + item.Name;
                            
                            entry = entry + "</a>";
                            entry = entry.replace(queryTerm, "<b>" + queryTerm + "</b>");
                            return $("<li class='liclassik'></li>")
                                .data("item.autocomplete", item)
                                .append(entry)
                                .appendTo(ul);
                        };
                        
                          window.onload = setFocus();
                    
                          function setFocus() {
                             document.getElementById('{!$Component.autoCompleteForm.panelb}').focus();
