<apex:page controller="OutboundLogistics" sidebar="false" showHeader="false" id="mainPg">
    
    <apex:includeScript value="{!URLFOR($Resource.Barcode_Scanner_JS)}" />
    
    <head>  
    <style>
    .wrapper {
        width:800px;
        height:auto;
        //height:1680px;
        margin:50px auto 50px;
    }       
    </style>
       
    <script>
    var $j = jQuery.noConflict();
    $j(document).ready(function() {
        window.print();
    });
    </script>
    
    </head>
    
    <div class="wrapper" >
        <apex:repeat value="{!packageRecords}" var="s">
            <div style="page-break-after: always;">
                <table border="0" Style="background-color:#FFF;" width="100%">
                    <tr>
                        <td>
                            <apex:iframe id="previewFrame" title="HTML Preview" 
                            src="https://{!sfdcBaseURL}documentforce.com/email/templaterenderer?id={!packingTemplate.id}&recipient_type_id={!s.ERP7__Logistic__r.Contact__c}&related_to_id={!S.Id}&base_href=https://{!sfdcBaseURL}salesforce.com&preview_frame=previewFrame&render_type=REPLACED_HTML_BODY&setupid=CommunicationTemplatesEmail"
                            frameborder="false" width="100%" height="{!PackingSlipHeight}"/> <!-- height="10000px" -->
                            <!-- <script>document.getElementById('previewFrame').height = auto;</script> <script>document.getElementById('previewFrame').height = window.innerHeight - 220;</script> -->
                        </td>
                    </tr>
                </table>
            </div>
        </apex:repeat>
    </div>
    
</apex:page>