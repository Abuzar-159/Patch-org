<apex:page standardController="Payment__c" extensions="paymentRefund" action="{!processRefund}" cache="false" sidebar="false" id="mainpg" docType="html-5.0" >
    <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
    <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.min.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}"/>    
    <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}"/>          
    
    <!-- 
    response_1 :&nbsp;<apex:outputText value="{!response_1}"></apex:outputText> <br/><br/><br/>
    response_2 :&nbsp;<apex:outputText value="{!response_2}"></apex:outputText> <br/><br/> -->
    
    <apex:form >
        <div class="epr_Mark7">
            <div class="container" style="margin-top:05%;">
                <div class="alert alert-success" style="display: {!if(SuccessMsg != null && SuccessMsg != '', '', 'none')}">
                    <strong><apex:outputText value="{!SuccessMsg}"></apex:outputText></strong>
                </div>
      
                <div class="alert alert-danger" style="display: {!if(errorMessage != null && errorMessage != '', '', 'none')}">
                    <apex:outputText value="{!errorMessage}"></apex:outputText>
                </div>
                <div style="text-align:center;">
                    <apex:commandButton action="{!ClosePage}" value="Close" styleClass="btn btn-info"/>
                    <!-- <button type="button" class="btn btn-info">Close</button> -->
                    <br/><br/>
                </div>
            </div>
        </div>
    </apex:form>
  
</apex:page>