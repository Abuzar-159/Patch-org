<apex:page extensions="Addsubscription" standardController="Subscription__c" sidebar="false" showHeader="false" standardStylesheets="true" action="{!populateLineItems}">
    <apex:stylesheet value="{!URLFOR($Resource.SubSrc, 'SubSrc1/css/style.css')}" />
      <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
       <!-- <apex:stylesheet value="{!URLFOR($Resource.SLDS0121, 'assets/styles/salesforce-lightning-design-system-vf.css')}" /> -->
          <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />
        <style>
        .erp_mark7 .slds-truncate {
    max-width: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
         .epr_Mark7 .input{    
        border: 1px solid #ddd;
    width: 100%;
    height: 27px;
    padding-left: 5px;
    border-radius:3px;
    }
    .epr_Mark7 .select{    
        border: 1px solid #ddd;
    width: 100%;
    height: 27px !important;
    padding-left: 5px;
    border-radius:3px;
    }
    .epr_Mark7 .textarea{    
        border: 1px solid #ddd;
    width: 100%;
    padding-left: 5px;
    border-radius:3px;
    }
        body {
    background: #ffffff;
}
            .epr_Mark7 .navbar-default .navbar-nav>.active>a,
            .epr_Mark7 .navbar-default .navbar-nav>.active>a:hover,
            .epr_Mark7 .navbar-default .navbar-nav>.active>a:focus {
                color: #555;
                background-color: #ffffff;
            }
            .epr_Mark7 .active {
                background: #3A6690;
            }
        </style>
    </head>
    <style>
        input[type=text],
        textarea,
        select {
            -webkit-transition: all 0.30s ease-in-out;
            -moz-transition: all 0.30s ease-in-out;
            -ms-transition: all 0.30s ease-in-out;
            -o-transition: all 0.30s ease-in-out;
            outline: none;
            padding: 3px 0px 3px 3px;
            /*margin: 5px 1px 3px 0px;*/
            border: 1px solid #DDDDDD;
        }
        
        input[type=text]:focus,
        textarea:focus,
        select:focus {
            box-shadow: 0 0 5px rgba(255, 0, 24, 1);
            /*padding: 3px 0px 3px 3px;
            margin: 5px 1px 3px 0px;*/
            border: 1px solid rgba(255, 0, 24, 1);
        }
        
        .bdr {
            -webkit-transition: all 0.30s ease-in-out;
            -moz-transition: all 0.30s ease-in-out;
            -ms-transition: all 0.30s ease-in-out;
            -o-transition: all 0.30s ease-in-out;
            outline: none;
        }
        
        .bdr:focus,
        {
            -webkit-box-shadow: 0 0 0px rgba(255, 0, 24, 1);
            box-shadow: 0 0 0px rgba(255, 0, 24, 1);
            -o-box-shadow: 0 0 0px rgba(255, 0, 24, 1);
        }
        
        .erp-bg {
            font-family: sans-serif;
            background-color: #f62b2b;
            background-image: -webkit-gradient(linear, left top, left bottom, from(#f62b2b), to(#d20202));
            background-image: -webkit-linear-gradient(top, #f62b2b, #d20202);
            background-image: -moz-linear-gradient(top, #f62b2b, #d20202);
            background-image: -ms-linear-gradient(top, #f62b2b, #d20202);
            background-image: -o-linear-gradient(top, #f62b2b, #d20202);
            background-image: linear-gradient(to bottom, #f62b2b, #d20202);
            filter: progid: DXImageTransform.Microsoft.gradient(GradientType=0, startColorstr=#f62b2b, endColorstr=#d20202);
            border-color: #ddd;
            text-align: left;
            padding-left: 10px;
            color: #ffffff;
            /*  text-shadow: 0 1px 0 #eee;*/
            font-weight: normal;
            /*background-color: #ff6767; background-image: -webkit-gradient(linear, left top, left bottom, from(#ff6767), to(#ff0d0d));
                background-image: -webkit-linear-gradient(top, #ff6767, #ff0d0d);
                background-image: -moz-linear-gradient(top, #ff6767, #ff0d0d);
                background-image: -ms-linear-gradient(top, #ff6767, #ff0d0d);
                background-image: -o-linear-gradient(top, #ff6767, #ff0d0d);
                background-image: linear-gradient(to bottom, #ff6767, #ff0d0d);filter:progid:DXImageTransform.Microsoft.gradient(GradientType=0,startColorstr=#ff6767, endColorstr=#ff0d0d);*/
            -webkit-border-top-left-radius: 7px;
            -moz-border-radius-topleft: 7px;
            border-top-left-radius: 7px;
            -webkit-border-top-right-radius: 7px;
            -moz-border-radius-topright: 7px;
            border-top-right-radius: 7px;
            -webkit-border-bottom-right-radius: 7px;
            -moz-border-radius-bottomright: 7px;
            border-bottom-right-radius: 7px;
            -webkit-border-bottom-left-radius: 7px;
            -moz-border-radius-bottomleft: 7px;
            border-bottom-left-radius: 7px;
        }
        
        .bodytxt3 {
            font-family: Arial;
            font-size: 12px;
            font-weight: bold;
            color: #5e5f60;
            padding-left: 10px;
        }
        
        .bodytxt2 {
            font-family: Arial;
            font-size: 12px;
            font-weight: bold;
            color: #5e5f60;
        }
        
        .bodytxt4 {
            font-family: Arial;
            font-size: 12px;
            color: #5e5f60;
            padding-left: 10px;
        }
        
        .left-panel-bar {
            height: 32px;
            width: 100%;
            float: left;
            background: #27a8df;
        }
        
        .headertxtpanel {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 14px;
            font-weight: bold;
            color: #f2f2f2;
            float: left;
            padding-left: 10px;
        }
        
        .headertxtpanel2 {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 14px;
            font-weight: bold;
            color: #f2f2f2;
            text-align: center;
            background: #FFF;
            border-radius: 5px;
        }
        
        .c1 {
            height: 219px;
            box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, .2);
            border-radius: 7px;
        }
        
        .bodytxt {
            font-family: Arial;
            font-size: 12px;
            font-weight: bold;
            color: #5e5f60;
            padding-left: 10px;
        }
        
        .bodytxt2 {
            font-family: Arial;
            font-size: 12px;
            font-weight: bold;
            color: #5e5f60;
        }
        
        .input1 {
            width: 190px;
            height: 20px;
        }
        
        .inputnew1 {
            width: 220px;
            height: 20px;
        }
        
        .inputnew2 {
            width: 100px;
            height: 20px;
        }
        
        .input2 {
            width: 150px;
            height: 15px;
        }
        
        .input3 {
            width: 150px;
            height: 60px;
            font-size: 12px;
            font-family: Arial, Helvetica, sans-serif;
        }
        
        .input4 {
            width: 50px;
            height: 20px;
        }
        
        .salesorder {
            width: 100%;
            height: 147px;
            float: left;
        }
        
        .input5 {
            width: 190px;
            height: 70px;
            font-family: Arial, Helvetica, sans-serif;
            color: #000;
            font-size: 12px;
        }
        
        textarea:disabled {
            background-color: #ddddd;
            border-top: 1px solid #dddddd;
            border-bottom: 1px solid #dddddd;
            border-right: 1px solid #dddddd;
            border-left: 1px solid #dddddd;
        }
        
        #bodypanel-top {
            width: 100%;
            height: 178px;
            float: left;
            margin: 0px auto;
            background-color: #fff;
            box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, .2);
            border-radius: 7px;
        }
        
        .input2-1 {
            width: 150px;
            height: 20px;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            text-align: center;
        }
    </style>
    <script type="text/javascript">
        function setupclosepopup() {
            top.window.returnValue = 1;
            top.window.close();
        }
        function disableFields() {
            document.getElementById('{!$Component.ssForm.flsbta}').disabled = true;
            document.getElementById('{!$Component.ssForm.flssta}').disabled = true;
            document.getElementById('{!$Component.ssForm.flssi}').disabled = true;
            document.getElementById('{!$Component.ssForm.flsd}').disabled = true;
        }
    </script>
    <body  onLoad="disableFields();">
        <apex:form id="ssForm">
        <apex:pageMessages />
            <div id="main-wrapper">
                <div class="wrapper">
                    <div class="erp_mark7">
                         <div class="slds-page-header slds-m-bottom--xx-small">
  <div class="slds-grid">
    <div class="slds-col slds-has-flexi-truncate">
      <div class="slds-media slds-no-space slds-grow">
        <div class="slds-media__figure">
          <svg class="slds-icon slds-icon-standard-account slds-p-around--xx-small" aria-hidden="true">
            <use xlink:href="{!URLFOR($Resource.SLDS213, 'assets/icons/action-sprite/svg/symbols.svg#record')}"></use>
          </svg>
        </div>
        <div class="slds-media__body">
          <p class="slds-text-title--caps slds-line-height--reset"></p>
          <h1 class="slds-page-header__title slds-m-right--small slds-align-middle " title="{!subscription.Name}">Subscription : <apex:outputText value="{!subscription.Name}" style="font-size:16px;"/></h1>
          <div style="text-align:center;float:left;width: 100%; height: 6px;"><apex:outputLabel value="{!errorMsg}" id="err" style="font-family:Arial,Helvetica, sans-serif;font-size:14px; color:red; text-align:center;" /></div>  
        </div>
      </div>
    </div>
    <div class="slds-col slds-no-flex slds-grid slds-align-top">
        <apex:commandButton value="Back to Subscription" styleClass="slds-button slds-button--brand" action="/{!sId}"/>
        <!--<a href=";" style="text-decoration:none;" status="idStatus" reRender="pro" onclick="setupclosepopup();" class="slds-button slds-button--brand"></i>&nbsp;Close</a>-->
    </div>
  </div>
</div>

                       
                        <div class="slds-theme--info slds-m-top--xxx-small  slds-p-around--xx-small">
                            <p>Customer Details</p>
                        </div>
                        <!-- Row 1 -->
                        <div class="epr_Mark7 padding-t-5">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <p class="greyhead" style="font-size:14px;">
                                            <b>Customer</b></p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control ">
                                                <apex:outputText value="{!contactName}" Id="cust"  rendered="{!$ObjectType.Contact.Fields.Name.Accessible}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small ">
                                        <p class="greyhead" style="font-size:14px;">
                                            <b>Subcription Plan </b>
                                        </p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:outputField value="{!subscription.SubscriptionPlan__r.Name}" Id="sp" styleClass="input" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <p class="greyhead" style="font-size:14px;">
                                            <b>Start Date </b>
                                        </p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control ">
                                                <apex:outputField value="{!subscription.Subscription_Date__c}" Id="sd" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 slds-p-top--xx-small">
                                        <p class="greyhead" style="font-size:14px;">
                                            <b>Duration in Months </b>
                                        </p>
                                        <div class="slds-form-element">
                                            <div class="slds-form-element__control">
                                                <apex:outputText value="{!subscription.Duration_In_Months__c}" Id="sm" styleClass="" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- @end of Row 1 -->
                            <!-- Row 2-->
                            <div class="epr_Mark7 slds padding-t-5 ">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <b>Billing Address</b>
                                            </p>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <apex:outputText styleClass="" value="{!pageSubscription.Bill_To_Address__c}" id="flsbta" label="" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <b>Shipping Address</b>
                                            </p>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <apex:outputText styleClass="" value="{!pageSubscription.Ship_To_Address__c}" id="flssta" label="" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <b>Description </b>
                                            </p>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <apex:outputText styleClass="" value="{!subscription.Description__c}" id="flsd" label="" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <b>Special Instructions </b>
                                            </p>
                                            <div class="slds-form-element">
                                                <div class="slds-form-element__control">
                                                    <apex:outputText styleClass="" value="{!currentSalesOrder.Special_Instructions__c}" id="flssi" label="" />
                                                </div>
                                            </div>
                                        </div>
                                        <table>
                                            <tr>
                                                &nbsp;
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="slds-theme--info slds-m-top--xxx-small  slds-p-around--xx-small">
                            <p style="margin: 0 0 0px;">Products Line Items Detail </p>
                        </div>
                        <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover ">
                            <thead>
                                <tr class="slds-text-heading--label">
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Code
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Product
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Quantity
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Points
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Price
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Discount
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Vat
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Tax
                                        </div>
                                    </th>
                                    <th class="slds-is-sortable" scope="col">
                                        <div class="slds-truncate">Total
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <apex:variable value="{!0}" var="itemCounter" />
                                <apex:repeat var="item" value="{!ItemWrapperList}" id="rp1">
                                    <tr class="slds-hint-parent">
                                        <th class="slds-truncate" scope="row" data-label="Code">
                                            <apex:outputText value="{!item.Code}" />
                                        </th>
                                        <td class="slds-truncate" data-label="Product">
                                            <apex:outputText value="{!item.Itm}" />
                                        </td>
                                        <td class="" data-label="Quantity">
                                            <apex:outputText value="{!item.Quantity}" />
                                        </td>
                                        <td class="slds-truncate" data-label="Points">
                                            <apex:outputText value="{!item.RewardPoints}" />
                                        </td>
                                        <td class="" data-label="Price">
                                            <apex:outputText value="{!item.Price}" />
                                        </td>
                                        <td class="" data-label="Discount">
                                            <apex:outputText value="{!item.Discount}" />
                                        </td>
                                        <td class="slds-truncate" data-label="Vat">
                                            <apex:outputText value="{!item.Vat}" />
                                        </td>
                                        <td class="slds-truncate" data-label="Tax">
                                            <apex:outputText value="{!item.Tax}" />
                                        </td>
                                        <td class="slds-cell-shrink" data-label="Total">
                                            <apex:outputText value="{!item.PriceWithVat}" />
                                        </td>
                                    </tr>
                                    <apex:variable var="itemCounter" value="{!itemCounter + 1}" /></apex:repeat>
                            </tbody>
                        </table>
                        <apex:outputPanel id="table1">
                            <div class="epr_Mark7">
                                <div class="container-fluid">
                                    <div class="row" style="box-shadow: 1px 3px 2px -3px;background:#f8f9fb;">
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <table>
                                                    <tr>
                                                        <td><b>SubTotal:</b></td>
                                                        <td>
                                                            <apex:outputText value="{!subTotal}" styleClass="bodytxt" />
                                                        </td>
                                                    </tr>
                                                </table>
                                            </p>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <table>
                                                    <tr>
                                                        <td><b>Discounts:</b></td>
                                                        <td>
                                                            <apex:outputText value="{!totalDiscount}" styleClass="bodytxt" />
                                                        </td>
                                                    </tr>
                                                </table>
                                            </p>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <p class="greyhead" style="font-size:14px;">
                                                    <table>
                                                        <tr>
                                                            <td><b>Taxes:</b></td>
                                                            <td>
                                                                <apex:outputText value="{!totalTax}" styleClass="bodytxt" />
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </p>
                                            </p>
                                        </div>
                                        <div class="col-md-3 slds-p-top--xx-small">
                                            <p class="greyhead" style="font-size:14px;">
                                                <table>
                                                    <tr>
                                                        <td><b>Total Due:</b></td>
                                                        <td>
                                                            <apex:outputText value="{!totalDue}" styleClass="bodytxt" />
                                                        </td>
                                                    </tr>
                                                </table>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                    </div>
                </div>
            </div>
        </apex:form>
        </body>
        </html>
    
</apex:page>