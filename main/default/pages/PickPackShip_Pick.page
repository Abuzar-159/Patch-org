<apex:page controller="PickPackShipController" sidebar="false" cache="false" id="mainPg" docType="html-5.0" showHeader="true">    
    
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width,initial-scale=1"/>        
            <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.css')}"/>
            <apex:stylesheet value="{!URLFOR($Resource.SLDS213, 'assets/styles/salesforce-lightning-design-system-vf.min.css')}" />
            <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}"/>    
            <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}"/>  
            <apex:includeScript value="{!URLFOR($Resource.bootStrap,'/js/bootstrap.min.js')}"/>
            
            <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>         
            
            
            <style>
                .erp_mark7 a, .erp_mark7 button {
                cursor: pointer;
                text-decoration:none !important;
                }
                .no-sort::after { display: none!important; }
                
                .no-sort { pointer-events: none!important; cursor: default!important; }
                .erp_mark7 .slds-button--neutral2 {
                padding-left: 1rem;
                padding-right: 1rem;
                text-align: center;
                vertical-align: middle;
                border: 1px solid #d8dde6;
                background-color: #fff;
                color: #65d6e5;
                }
                .erp_mark7 .slds-button--neutral2:hover, .erp_mark7 .slds-button--neutral2:focus {
                background-color: #f4f6f9;
                color: #65d6e5;
                }
