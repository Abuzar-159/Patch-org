    <script type="text/javascript">
    /* script for scanner code */
    var $j = jQuery.noConflict();
    $j(document)
        .ready(function() {
            var pressed = false;
            var chars = [];
            $j(window)
                .keypress(function(e) {
                    chars.push(String.fromCharCode(e.which));
                    if(pressed == false) {
                        setTimeout(function() {
                            if(chars.length >= 5) {
                                var barcode = chars.join("");
                                scannerMethodManufacturing(barcode);
                            }
                            chars = [];
                            pressed = false;
                        }, 500);
                    }
                    pressed = true;
                }); // end of window key press function
            $j(window)
                .keypress(function(e) {
                    if(e.which === 13) {
                        e.preventDefault();
                    }
                }); // end of preventing from default enter 
        }); // end of document ready function
        
        function stockandline(counter, warehouse) {
           
            stockandlines(counter);
        }
        window.onload = setFocus();

        function setFocus() {
            document.getElementById('{!$Component.mainform.temp}')
                .focus();
        }

    </script>

