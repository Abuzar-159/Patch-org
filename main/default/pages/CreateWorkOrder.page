    <script>
        function completeAction(sortby, orderFormat){
            var ik = document.getElementById(sortby); 
            var ikicon = document.getElementById(sortby+'icon');
            
            var kkvalue = sortby;
            var kkval = "";
            if(kkvalue == "mrp") kkval = "MRP";
            else if(kkvalue == "prod") kkval = "Product";
            else if(kkvalue == "ps") kkval = "Production Schedule";
            else if(kkvalue == "ms") kkval = "Maintanance Schedule";
            else if(kkvalue == "po") kkval = "Purchase Order";
            else if(kkvalue == "wo") kkval = "Work Order";
            
            ik.style. fontStyle = "normal";
            ik.style.color = "red";
            ik.style. fontWeight = "bold";
            ik.style.fontFamily = "Arial,Glyphicons Halflings";
            
            if(orderFormat == 'ASC'){ 
                ik.title = 'ASC';
                ikicon.className = "fa fa-sort-asc";
                
                
            } 
            else { 
                ikicon.className = "fa fa-sort-desc";
            }
        }
    </script>
    <body>
        <apex:form id="myform">
         
             <div id="wrapper" style="margin-top:5px;margin-bottom:5px;">
                <nav class="navbar" style="min-height: 0px; margin-bottom: 0px;">
                    <div class="row erp-bg" style="height:35px;border-radius: 0px;">
                        <div class="col-md-5">
                            <h4> <apex:commandLink value="Back" action="{!back}" immediate="true" style="font-size:14px; line-height:35px; padding-left:20px;text-decoration:none;color:#ffffff;"/></h4>
                        </div>

                        <div class="col-md-6">
                            <h4 style=" font-size:16px; line-height:35px;padding-left:0px;">Work Order Details &nbsp;&nbsp;&nbsp;</h4>
                            <apex:actionStatus id="spinnerwhite">
                                <apex:facet name="start">
                                    <apex:image url="{!URLFOR($Resource.SCM,'SCM/Images/whiteloader.gif')}" height="20px;" width="25px;" style="padding-left:5px;" />
                                </apex:facet>
                            </apex:actionStatus>
                        </div>
                    </div>
                </nav>
              <div class="container">
               
               <div class="row">
                  <div class="col-md-12" style="height:10px;"> </div>
               </div>
               <div class="row erp-box-shadow" style="background:#ffffff;padding:5px;font-size:14px;">
                  
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;">Name</h4>
                     <br />
                     <apex:inputField value="{!WO.Name}" required="true" style="color: #666; font-size: 12px;width:90%;padding:3px;" />
                  </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;">Supplier</h4>
                     <br />
                     <apex:inputField value="{!WO.WO_Supplier__c}" style="color: #666; font-size: 12px;width:90%;padding:3px;" />
                  </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:13px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Employee_Requester}</h4>
                     <br />
                     <apex:inputField value="{!WO.Employee_Requester__c}" style="width:90%;padding:3px;font-size:14px;"/> </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Manufacturing_Process}</h4>
                     <br />
                     <apex:inputField value="{!WO.Process__c}" style="width:90%;padding:3px;font-size:12px;"/> 
                  </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Manufacturing_Schedule}</h4>
                     <br />
                     <apex:inputField value="{!WO.Schedule__c}" style="width:90%;padding:3px;font-size:12px;"/> 
                  </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Production_Cycle}</h4>
                     <br />
                     <apex:inputField value="{!WO.Production_Cycle__c}" style="width:90%;padding:3px;font-size:12px;"/> </div>
                  
               </div>
              <div class="clearfix"></div>
               <div class="row erp-box-shadow" style="background:#ffffff;padding:5px;">
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:12px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Status}</h4>
                     <br />
                     <apex:inputField value="{!WO.Status__c}" styleClass="ftmout" style="width:90%;padding:3px;font-size:12px;"/> </div>
                  
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:13px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Approved_Date}</h4>
                     <br />
                     <apex:inputField value="{!WO.Approved_Date__c}" style="width:90%;padding:3px;font-size:14px;"/>
                    
                  </div>
                  <div class="col-md-2">
                     <h4 style="color:#444; font-size:13px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Completion_Date}</h4>
                     <br />
                     <apex:inputField value="{!WO.Completion_Date__c}" style="width:90%;padding:3px;font-size:14px;"/>
                    
                  </div>
                  <div class="col-md-4">
                     <h4 style="color:#444; font-size:13px; font-weight: 600;" class="ftm">{!$Label.InventoryConsole_Description}</h4>
                     <br />
                     <apex:inputTextarea value="{!WO.Description__c}" styleClass="ftmout" cols="50" rows="3" rendered="{!$ObjectType.WO__c.fields.Description__c.Accessible}"/> </div>
               </div>
               </div>
                <div class="container" style="margin-top: 10px 0px 0px 0px !important ;padding: 10px 0px 0px 0px !important;">
                    <apex:pageBlock title="Work Order Line Items">
                        <apex:pageBlockButtons style="font-size:13px;" location="bottom">
                            <apex:commandButton value="Save" action="{!saveWO}" style="margin-left: 60px;width:120px; height:30px;" title="Save" rendered="{!$ObjectType.Work_Order_Line_Items__c.Createable && $ObjectType.Work_Order_Line_Items__c.Updateable && $ObjectType.MRP__c.Createable && $ObjectType.MRP__c.Updateable}"/>Work_Order_Line_Items__c
                            <apex:commandLink styleClass="btn" value="Cancel" action="{!back}" style="padding-top:5px;width:120px; height:30px;" title="Cancel" immediate="true"/>
                        </apex:pageBlockButtons>
                         <apex:variable var="wcounter" value="{!0}"/>
                        <apex:actionRegion >
                        <apex:pageBlockTable var="woli" value="{!Wolis}" style="font-size: 13px;" id="tabpk">
                            
                            <apex:column >
                                 <apex:facet name="header">Product</apex:facet>
                                 <apex:inputField value="{!woli.Product__c}" styleClass="inputallfields" /> 
                            </apex:column>
                             <apex:column >
                                 <apex:facet name="header">MRP</apex:facet>
                                 <apex:inputField value="{!woli.MRP_Material_Requirements_Planning__c}" styleClass="inputallfields" /> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Quantity</apex:facet>
                                 <apex:inputField value="{!woli.Quantity__c}" id="quan" styleClass="inputallfields" required="true"/> 
                            </apex:column>
                            
                            <apex:column >
                                     <apex:facet name="header">Cost Card</apex:facet>
                                     
                                     <apex:inputField value="{!woli.Cost_Card__c}" styleClass="inputallfields">
                                         <apex:actionSupport event="onchange" action="{!processCostcardValuesWO}" reRender="upc,tpc">
                                             <apex:param assignTo="{!wrapCounter}" name="counter" value="{!wcounter}"/>
                                         </apex:actionSupport>
                                     </apex:inputField>
                                     
                                </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Unit Price</apex:facet>
                                 <apex:inputField value="{!woli.Unit_Price__c}" id="upc" styleClass="inputallfields" /> 
                            </apex:column>
                            
                            <apex:column >
                                 <apex:facet name="header">Total Price</apex:facet>
                                 <apex:inputField value="{!woli.Total_Cost__c}" id="tpc" styleClass="inputallfields" /> 
                            </apex:column>
                            <apex:column >
                                 <apex:facet name="header">Special Instruction</apex:facet>
                                 <apex:inputTextarea value="{!woli.Special_Instruction__c}" styleClass="inputallfields" cols="30" rendered="{!$ObjectType.Work_Order_Line_Items__c.fields.Special_Instruction__c.Accessible}"/> 
                                 <apex:variable var="wcounter" value="{!wcounter+1}"/>
                            </apex:column>
                            
                            
                        </apex:pageBlockTable>
                        </apex:actionRegion>
                    </apex:pageBlock>
                </div>
            </div>
        </apex:form>
    </body>
</apex:page>