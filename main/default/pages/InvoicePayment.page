<apex:page sidebar="false" showHeader="true" standardStylesheets="false">
  <apex:includeScript value="/lightning/lightning.out.js" />
  <script>
        !$Lightning.use("ERP7:CreateInvoiceApp", function() {
            !$Lightning.createComponent(
                "ERP7:RecordPayment",             
                  {
                      "recordId":'{!JSENCODE($CurrentPage.parameters.invId)}',
                      "paymentId" : '{!JSENCODE($CurrentPage.parameters.payId)}',
                      "showPage" : true,
                      "Refund" : true,
                      "navigateToRecord" : true
                  },
                "accounts"
             );
            });
    </script>
    <div id="accounts"></div>
</apex:page>