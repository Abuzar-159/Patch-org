<apex:page controller="BankReconciliationLightning">
    <apex:slds />
    <style>
    .slds-scope .slds-form-element__legend {
    font-weight: 700;
    float: none;
    padding-bottom: 10px;
    font-size: 15px;
}
        </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
   
	<!--apex:form >
        <apex:pageBlock title="Link/Update Yodlee Account">
            <apex:commandButton action="{!navigateToPage1}" value="Link New Account"/>
                <apex:commandButton action="{!navigateToPage2}" value="Update Account"/>
        </apex:pageBlock>
    </apex:form-->
     
    <fieldset class="slds-form-element" style="text-align: center;margin-top:10%;">
        <img src=" https://www.axolt.com/wp-content/uploads/2017/10/aqxolt-logo-red.png" width="150px;"/>
        <img src="https://www.yodlee.com/themes/custom/yodlee/images/brand/Yodlee_color_rgb_131x57.55.svg" width="100px;"/>
        
        <div class="slds-form-element__control">
            <legend class="slds-form-element__legend slds-form-element__label slds-p-top_medium">Link/Update Yodlee Account</legend>
            <div class="slds-visual-picker slds-visual-picker_small">
                <input type="checkbox" id="visual-picker-371" value="visual-picker-371" name="example-unique-name-141" />
                <label for="visual-picker-371">
                     <apex:form >
                         <apex:commandLink action="{!navigateToPage1}" >
                             <span class="slds-visual-picker__figure slds-visual-picker__icon slds-align_absolute-center">
                                 <span class="slds-is-selected">
                                     <span class="slds-icon_container">
                                         
                                     </span>
                                 </span>
                                 <span class="slds-is-not-selected">
                                     <span class="slds-icon_container">
                                         <div id="lightning-container">
                                             
                                             <i class="fa fa-file-text fa-2x"></i>
                                         </div>
                                     </span>
                                 </span>
                             </span>
                         </apex:commandLink>
                         <span class="slds-visual-picker__body">
                             
                             <apex:commandLink action="{!navigateToPage1}" value="Link New Account"/>
                             
                         </span>
                    </apex:form>
                </label>
                   
            </div>
            
            <div class="slds-visual-picker slds-visual-picker_small">
                <input type="checkbox" id="visual-picker-371" value="visual-picker-371" name="example-unique-name-141" />
                <label for="visual-picker-371">
                     <apex:form >
                         <apex:commandLink action="{!navigateToPage2}" >
                             <span class="slds-visual-picker__figure slds-visual-picker__icon slds-align_absolute-center">
                                 <span class="slds-is-selected">
                                     <span class="slds-icon_container">
                                         
                                     </span>
                                 </span>
                                 <span class="slds-is-not-selected">
                                     <span class="slds-icon_container">
                                         <div id="lightning-container">
                                             
                                             <i class="fa fa-address-card fa-2x"></i>
                                         </div>
                                     </span>
                                 </span>
                             </span>
                         </apex:commandLink>
                         <span class="slds-visual-picker__body">
                             
                              <apex:commandLink action="{!navigateToPage2}" value="Update Account"/>
                             
                         </span>
                    </apex:form>
                </label>
                   
            </div>
            
            
        </div>
    </fieldset>

</apex:page>