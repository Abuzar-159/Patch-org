<apex:page controller="EmployeeReviewV2" sidebar="false">
    <html>

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0121, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/erp_mark7_bootstrap.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.PickPackShipResource, '/assets/styles/font-awesome.css')}" />
        <apex:includeScript value="{!URLFOR($Resource.jQuery,'/js/jquery_3.5.0.min.js')}"/>
        <apex:includeScript value="{!URLFOR($Resource.Accordions,'Src/jquery-ui.js')}" />
        <apex:stylesheet value="{!URLFOR($Resource.Accordions,'Src/jquery-ui.css')}" />
        <apex:stylesheet value="{!URLFOR($Resource.Accordions,'Src/style.css')}" />
        <script>
            $(function() {
                $("#accordion").accordion({
                    collapsible: true,
                    heightStyle: "content"
                });
            });
        </script>
        <style>
            a:link {
                text-decoration: none;
            } //the original link with no underline
            a:visited {
                text-decoration: none;
            } //the visited link with no underline
            a:hover {
                text-decoration: underline;
            } //mouseover link and an underline appears
            .buttonsmall {
                width: 107px;
                height: 32px;
                border: none;
                text-align: center;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 11px;
                color: #ffffff;
                font-weight: bold;
                background: #3da3ce;
                /* Old browsers */
                background: -moz-linear-gradient(top, #3da3ce 0%, #1da2db 45%, #299cce 100%);
                /* FF3.6+ */
                background: -webkit-gradient(linear, left top, left bottom, color-stop(0%, #3da3ce), color-stop(45%, #1da2db), color-stop(100%, #299cce));
                /* Chrome,Safari4+ */
                background: -webkit-linear-gradient(top, #3da3ce 0%, #1da2db 45%, #299cce 100%);
                /* Chrome10+,Safari5.1+ */
                background: -o-linear-gradient(top, #3da3ce 0%, #1da2db 45%, #299cce 100%);
                /* Opera 11.10+ */
                background: -ms-linear-gradient(top, #3da3ce 0%, #1da2db 45%, #299cce 100%);
                /* IE10+ */
                background: linear-gradient(to bottom, #3da3ce 0%, #1da2db 45%, #299cce 100%);
                /* W3C */
                filter: progid: DXImageTransform.Microsoft.gradient( startColorstr='#3da3ce', endColorstr='#299cce', GradientType=0);
                /* IE6-9 */
                -moz-box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, .2);
                -webkit-box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, .2);
                box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, .2);
                border-radius: 5px;
                text-decoration: none;
            }
            
            .buttonsmall:hover {
                width: 107px;
                height: 32px;
                border: none;
                cursor: pointer;
                text-align: center;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 12px;
                color: #ffffff;
                font-weight: bold;
                background: #7d7e7d;
                /* Old browsers */
                background: -moz-linear-gradient(top, #7d7e7d 0%, #606060 100%);
                /* FF3.6+ */
                background: -webkit-gradient(linear, left top, left bottom, color-stop(0%, #7d7e7d), color-stop(100%, #606060));
                /* Chrome,Safari4+ */
                background: -webkit-linear-gradient(top, #7d7e7d 0%, #606060 100%);
                /* Chrome10+,Safari5.1+ */
                background: -o-linear-gradient(top, #7d7e7d 0%, #606060 100%);
                /* Opera 11.10+ */
                background: -ms-linear-gradient(top, #7d7e7d 0%, #606060 100%);
                /* IE10+ */
                background: linear-gradient(to bottom, #7d7e7d 0%, #606060 100%);
                /* W3C */
                filter: progid: DXImageTransform.Microsoft.gradient( startColorstr='#7d7e7d', endColorstr='#606060', GradientType=0);
                /* IE6-9 */
                border-radius: 5px;
                text-decoration: none;
            }
            
            #wrapReview {
                width: 100%;
                min-height: 360px;
                height: auto;
                margin: 0 auto;
            }
            
            .erpbg77 {
                background-color: #f62b2b;
                background-image: -webkit-gradient(linear, left top, left bottom, from(#f62b2b), to(#d20202));
                background-image: -webkit-linear-gradient(top, #f62b2b, #d20202);
                background-image: -moz-linear-gradient(top, #f62b2b, #d20202);
                background-image: -ms-linear-gradient(top, #f62b2b, #d20202);
                background-image: -o-linear-gradient(top, #f62b2b, #d20202);
                background-image: linear-gradient(to bottom, #f62b2b, #d20202);
                filter: progid: DXImageTransform.Microsoft.gradient(GradientType=0, startColorstr=#f62b2b, endColorstr=#d20202);
            }
        </style>
        <style>
            .epr_Mark7 .navbar-default .navbar-nav > .active > a,
            .epr_Mark7 .navbar-default .navbar-nav > .active > a:hover,
            .epr_Mark7 .navbar-default .navbar-nav > .active > a:focus {
                color: #555;
                background-color: #ffffff;
            }
            
            .epr_Mark7 .active {
                background: #3A6690;
            }
            
            input {
                padding-top: 0;
                border: 1px solid #ddd;
                border-radius: 5px;
                padding: 5px;
            }
            
            .slds .slds-table--bordered td {
                border-top: 1px solid #f7f7f7;
            }
        </style>
    </head>

    <body>
        <apex:form id="mainFrm">

            <div class="slds slds-container--fluid">

                <div class="epr_Mark7">
	
                    <nav class="navbar  slds-theme--alt-default slds-m-bottom--x-small slds-m-top--small" style="margin-bottom: 0px;border: 1px solid #ddd;">
                        <div class="container-fluid">
                            <ul class="nav navbar-nav navbar-left">
                                <li><a href="#" style="text-decoration:none;"><i class="fa fa-file-text-o" aria-hidden="true" style="color:#a094ed;"></i>
                               {!$Label.EmployeeReview_My_Profile}</a></li>

                            </ul>


                        </div>
                    </nav>
                </div>

                <!-- search Table -->
                <div class="epr_Mark7 ">
                    <div class="container-fluid">
                        <div class="slds row slds-p-top--xx-small">

                            <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($objectType.Employees__c.fields.Name.Accessible,'','none')}">
                                <b>{!$Label.EmployeeReview_Employee_ID}</b> : {!employee.Name}

                            </div>

                            <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($objectType.Employees__c.fields.Email__c.Accessible,'','none')}">
                                <b>{!$Label.EmployeeReview_Email}</b> : {!employee.Email__c}

                            </div>

                            <div class="col-md-4 slds-p-top--xx-small " style="display:{!if($objectType.Employees__c.fields.Organisation__c.Accessible && $objectType.Account.fields.Name.Accessible,'','none')}">

                                <b>{!$Label.EmployeeReview_Organisation}</b> : {!employee.Organisation__r.Name}

                            </div>





                        </div>

                        <div class="slds row slds-p-top--xx-small">

                            <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($objectType.Employees__c.fields.First_Name__c.Accessible && $objectType.Employees__c.fields.Last_Name__c.Accessible,'','none')}">
                                <b>{!$Label.EmployeeReview_Name}</b> : {!employee.First_Name__c}&nbsp;{!employee.Last_Name__c}

                            </div>

                            <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($objectType.Employees__c.fields.Job_Title__c.Accessible,'','none')}">
                                <b>{!$Label.EmployeeReview_Job_Title}</b> : {!employee.Job_Title__c}

                            </div>

                            <div class="col-md-4 slds-p-top--xx-small " style="display:{!if($objectType.Employees__c.fields.Organisation_Business_Unit__c.Accessible && $objectType.ERP7__Business_Unit__c.fields.Name.Accessible,'','none')}">
                                <b>{!$Label.EmployeeReview_Organisation_Business_Unit}</b> : {!employee.Organisation_Business_Unit__r.Name}
                            </div>
                        </div>
                    </div>

                    <!-- Reviews-->
                    <div class="slds-theme--info slds-m-top--x-small  slds-p-top--xxx-small slds-p-left--xx-small">
                        <p style="margin: 0 0 0px;padding:5px;">{!$Label.EmployeeReview_Reviews}</p>


                    </div>
                    <div class="slds-form--inline slds-p-around--small">
                        <div class="slds-form-element">
                            <label class="slds-form-element__label" for="name">{!$Label.EmployeeReview_Review_Type}</label>
                            <div class="slds-form-element">

                                <div class="slds-form-element__control">
                                    <apex:inputField value="{!review.Review_Type__c}" style="height:27px; border-radius:4px;"/>
                                </div>
                            </div>
                        </div>

                        <div class="slds-form-element">
                            <apex:commandLink action="{!filterReviews}" reRender="reviewListFilter" rendered="{!$ObjectType.Review__c.Accessible}">
                                <button class="slds-button slds-button--brand" type="button">{!$Label.ERP7__EmployeeReview_Find_Review}</button>
                            </apex:commandLink>
                        </div>
                        <div class="slds-form-element">
                            <apex:commandLink action="{!addNewEmpReviewPageRedirect}" rendered="{!$ObjectType.Review__c.Accessible || $ObjectType.Employee_Review_Recommendation__c.Accessible || $ObjectType.Employee_Organisational_Objective__c.Accessible || $ObjectType.Employee_Organisational_Goal__c.Accessible || $ObjectType.Employee_Initiative__c.Accessible || $ObjectType.Objective__c.Accessible}">
                                <apex:param name="param1" assignto="{!revId}" value="{!review.Id}" />
                                <apex:param name="param2" assignto="{!tb1}" value="true" />
                                <button class="slds-button slds-button--neutral" type="button">
      
      {!$Label.EmployeeReview_Add_Review}&nbsp; <i class="fa fa-plus" aria-hidden="true"></i>
      
      </button>

                            </apex:commandLink>
                        </div>
                    </div>



                    <div class="slds-card">
                        <div class="slds-card__body">
                            <apex:outputPanel id="reviewListFilter">
                                <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                    <thead>
                                        <tr>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Review_Name}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_of_Overall_Goals_Achieved}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Manager}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Start_Date}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Target_End_Date}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Submition_Date}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-8" scope="col">{!$Label.ERP7__EmployeeReview_Review_Type}</th>
                                            <th class="slds-text-heading--label slds-size--1-of-12" scope="col">{!$Label.ERP7__EmployeeReview_Status}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <apex:repeat value="{!reviewList}" var="review">
                                            <tr class="slds-hint-parent">
                                                <td class="slds-size--1-of-8" data-label="Review Name">
                                                    <apex:outputText value="{!review.Name}" rendered="{!if(review.Status__c == 'Submitted To Manager' || review.Status__c == 'Signed Off', true, false && $ObjectType.Review__c.fields.Name.Accessible)}"></apex:outputText>
                                                    <apex:commandLink value="{!review.Name}" action="{!viewEmpReviewPageRedirect}" style="color:#0000FF;" styleClass="toptext3" rendered="{!if(review.Status__c != 'Submitted To Manager' && review.Status__c != 'Signed Off', true, false) && $ObjectType.Review__c.Accessible || $ObjectType.Employee_Review_Recommendation__c.Accessible || $ObjectType.Employee_Organisational_Objective__c.Accessible || $ObjectType.Employee_Organisational_Goal__c.Accessible || $ObjectType.Employee_Initiative__c.Accessible || $ObjectType.Objective__c.Accessible }">
                                                        <apex:param name="param1" assignto="{!revId}" value="{!review.Id}" />
                                                        <apex:param name="param2" assignto="{!tb1}" value="true" />
                                                    </apex:commandLink>
                                                </td>
                                                <td class="slds-size--1-of-8" data-label="% of Overall Goals Achieved">
                                                    <apex:outputField value="{!review.of_Over_All_Goals_Achieved__c}" />
                                                </td>
                                                <td class="slds-size--1-of-4" data-label="Manager">
                                                    <apex:outputText rendered="{!$ObjectType.Employees__c.fields.Employee_User__c.Accessible}">{!employee.Employee_User__r.Manager.Name}</apex:outputText>
                                                </td>
                                                <td class="slds-size--1-of-8" data-label="Start Date">
                                                    <apex:outputField value="{!review.Start_Date__c}" />
                                                </td>

                                                <td class="slds-size--1-of-8" data-label="Target End Date">
                                                    <apex:outputField value="{!review.Target_Completion_Date__c}" />
                                                </td>
                                                <td class="slds-size--1-of-8" data-label="Submition Date">
                                                    <apex:outputField value="{!review.Date_Submitted_to_Manager__c}" />
                                                </td>
                                                <td class="slds-size--1-of-8" data-label="Review Type">
                                                    <apex:outputField value="{!review.Review_Type__c}" />
                                                </td>
                                                <td class="slds-size--1-of-12" data-label="Status">
                                                    <apex:outputField value="{!review.Status__c}" />
                                                </td>
                                            </tr>
                                        </apex:repeat>
                                    </tbody>
                                </table>
                            </apex:outputPanel>
                        </div>

                    </div>

                </div>
               
            </div>
            
            <div class="slds slds-container--fluid">
            
            <apex:outputPanel id="empReviewList" rendered="{!isManager}">
                                
                <div id="accordion">
                    <apex:variable value="{!0}" var="empListCounter" />
                    <apex:repeat value="{!EmployeeReviewWrapperList}" var="emp">
                        <span style="display:{!if($objectType.Employees__c.fields.First_Name__c.Accessible && $objectType.Employees__c.fields.Last_Name__c.Accessible,'','none')}">{!emp.wrapEmployee.First_Name__c}&nbsp;{!emp.wrapEmployee.Last_Name__c}</span>
                        
                        <div class="epr_Mark7 ">
                            <div class="container-fluid">
                                <div class="slds row slds-p-top--xx-small">

                                    <div class="col-md-4 slds-p-top--xx-small">
                                        <b>{!$Label.EmployeeReview_Name}</b> :
                                        <apex:outputText rendered="{!$ObjectType.Employees__c.fields.First_Name__c.Accessible && $objectType.Employees__c.fields.Last_Name__c.Accessible}">{!emp.wrapEmployee.First_Name__c}&nbsp;{!emp.wrapEmployee.Last_Name__c}</apex:outputText>

                                    </div>

                                    <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($ObjectType.Employees__c.fields.Email__c.Accessible,'','none')}">
                                        <b>{!$Label.ERP7__EmployeeReview_Email}</b> : {!emp.wrapEmployee.Email__c}

                                    </div>

                                    <div class="col-md-4 slds-p-top--xx-small" style="display:{!if($ObjectType.Employees__c.fields.Job_Title__c.Accessible,'','none')}">

                                        <b>{!$Label.ERP7__EmployeeReview_Job_Title}</b> : {!emp.wrapEmployee.Job_Title__c}

                                    </div>
                                </div>
                                
                                <table class="slds-table slds-table--bordered slds-no-row-hover">
                                    <tr>
                                        <tbody>    
                                        <td class="slds-text-heading--label slds-size--1-of-6">
                                        <div class="slds-form-element">
                                            <apex:commandLink value="{!$Label.ERP7__EmployeeReview_New_Review}" action="{!addNewMngrEmpReviewPageRedirect}" styleClass="slds-button--neutral" style="border-radius:5px; color:#005fb2;font-size:14px;padding:4px;font-weight:bold;text-transform:none;" rendered="{!$ObjectType.Review__c.Accessible || $ObjectType.Employee_Review_Recommendation__c.Accessible || $ObjectType.Employee_Organisational_Objective__c.Accessible || $ObjectType.Employee_Organisational_Goal__c.Accessible || $ObjectType.Employee_Initiative__c.Accessible || $ObjectType.Objective__c.Accessible}">
                                                <i class="fa fa-plus" aria-hidden="true"></i>
                                                <apex:param name="param1" assignto="{!employeeMngr}" value="{!emp.wrapEmployee.Id}" />
                                                <apex:param name="param2" assignto="{!tb2}" value="true" />
                                            </apex:commandLink>
                                            </div>
                                        </td>
                                        </tbody>
                                    </tr>
                                </table>
                                
                                        <div class="slds-card">
                                        <div class="slds-card__body">
                                        
                                        <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                            <thead>
                                                <apex:variable value="{!0}" var="empReviewListCounter" />
                                                <tr>
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Review_Name}</th>
                                                    
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Review_Type}</th>
                                                    
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Start_Date}</th>
                                                    
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Date_Completed}</th>
                                                    
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Date_Last_Modified}</th>
                                                    
                                                    <th class="slds-text-heading--label slds-size--1-of-6" scope="col">{!$Label.ERP7__EmployeeReview_Action}</th>
                                                    
                                                </tr>
                                            </thead>
                                            <apex:repeat value="{!emp.wrapEmpReviewList}" var="rev" >
                                            <tbody>
                                                  <tr class="slds-hint-parent">
                                                        <td class="slds-size--1-of-6" data-label="Review Name"><apex:outputField value="{!rev.Name}"/></td>
                                                
                                                <td class="slds-size--1-of-6" data-label="Review Type"><apex:outputField value="{!rev.Review_Type__c}"/></td>
                                                
                                                <td class="slds-size--1-of-6" data-label="Start Date"><apex:outputField value="{!rev.Start_Date__c}"/></td>
                                                
                                                <td class="slds-size--1-of-6" data-label="Date Completed"><apex:outputField value="{!rev.Target_Completion_Date__c}"/></td>
                                                
                                                <td class="slds-size--1-of-6" data-label="Date Last Modified"><apex:outputField value="{!rev.LastModifiedDate}"/></td>
                                                
                                                <td class="slds-size--1-of-6" data-label="Action">
                                                    <apex:commandLink action="{!viewMngrEmpReviewPageRedirect}" styleClass="buttonsmall" onmouseover="this.style.background = '#7d7e7d';this.style.font-size = '13px';" onmouseout="this.style.background = '#3da3ce';this.style.font-size = '11px'" 
                                                        style="box-shadow:0px 3px 5px 0px rgba(0,0,0, .2);padding:2px;width:107px;height:32px;border:none;text-align:center;font-family:Arial, Helvetica, sans-serif;font-size:11px;color:#ffffff;font-weight:normal;border-radius:5px;text-decoration:none;color:#ffffff;background: #f62b2b;" rendered="{!$ObjectType.Review__c.Accessible || $ObjectType.Employee_Review_Recommendation__c.Accessible || $ObjectType.Employee_Organisational_Objective__c.Accessible || $ObjectType.Employee_Organisational_Goal__c.Accessible || $ObjectType.Employee_Initiative__c.Accessible || $ObjectType.Objective__c.Accessible}">
                                                        <apex:param name="param1" assignto="{!viewEmpRev}" value="{!rev.Id}"/>
                                                        <apex:param name="param2" assignto="{!viewEmpMngr}" value="{!emp.wrapEmployee.Id}"/>
                                                        <apex:param name="param3" assignto="{!tb2}" value="true"/>
                                                        &nbsp;&nbsp;&nbsp;{!$Label.EmployeeReview_Start_Review}&nbsp;&nbsp;&nbsp;&nbsp;
                                                    </apex:commandLink>
                                                    
                                                </td>
                                                
                                            </tr>
                                            </tbody>
                                            <apex:variable var="empReviewListCounter" value="{!ROUND(empReviewListCounter+1 ,0)}"/>
                                            </apex:repeat>
                                        </table>
                                        
                                    </div>
                                </div>
                                
                                
                                

                            </div>
                        </div>
                        
                            
                    </apex:repeat>
                    
                </div>
                
                
            </apex:outputPanel>
            
            </div>
                
            

        </apex:form>
    </body>

    </html>
</apex:page>