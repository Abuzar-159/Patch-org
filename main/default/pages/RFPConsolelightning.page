<apex:page sidebar="false" showHeader="true" standardStylesheets="false">
<style>
.uiInputDate+.display, 
.uiInputDate .display {
    display: none !important;
}
.uiInputDate+.display, .uiInputDate .display {
    display: none;
}
.assistiveText{
  display:none;
}
.uiDayInMonthCell--default{
background-color:#fff;
color:#696e71;
display:block;
font-family:'ProximaNovaSoft-Regular';
font-size:14px;
height:30px;
width:30px;
line-height:30px;
text-align:center;
}
.uiDatePicker--default .dateBar .monthYear {
    font-family: ProximaNovaSoft-Bold,Arial,sans-serif;
    font-size: 18px;
    color: #3c3d3e;
    line-height: 1px!important;
}
.uiDatePickerGrid--default .slds-text-link {
    color: #0070d2;
    text-decoration: none;
    transition: color .1s linear;
    height: 19px;
    line-height: 16px;
    cursor: pointer;
}
</style>
  <apex:includeScript value="/lightning/lightning.out.js" />
  <apex:includeLightning />
  <script>
        !$Lightning.use("ERP7:RFPConsoleAPP", function() {
            !$Lightning.createComponent(
                "ERP7:RFPConsole",             
                  {
                   "reqSupplierId":'{!JSENCODE($CurrentPage.parameters.id)}',
                   "reqSupplierName":'{!JSENCODE($CurrentPage.parameters.name)}',
                   "requestId":'{!JSENCODE($CurrentPage.parameters.req)}'
                  },
                "accounts"
             );
            });
    </script>
    <div id="accounts"></div>    
</apex:page>