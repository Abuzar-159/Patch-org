<apex:page controller="PrintBarcodes" sidebar="false" showHeader="false" id="page" standardStylesheets="true" docType="html-5.0" applyBodyTag="false" renderAs="pdf"> <!--tabStyle="Product_Service__c"  renderAs="pdf" -->
    
    <head>
        <style type="text/css" media="print">           
            @page {
            size: {!PageSize};
            @top-center {
            content: element(header);
            }
            @bottom-left {
            content: element(footer);
            }
            }
            div.header {
            padding: 10px;
            position: running(header);
            }
            div.footer {
            display: block;
            padding: 5px;
            position: running(footer);
            }
            .pagenumber:before {
            content: counter(page);
            }
            .pagecount:before {
            content: counter(pages);
            }
        </style>
        <style>
            @page {
            /*size: 8.27in 11.69in;*/ 
             size:6in 4in;
            /*size: 210mm 297mm;*/
            margin: 10mm;
            
            color: #f9f9f9;
            .italicText {
            font-style: Bold;
            font-size: 1.2em;
            font-family: Arial, Helvetica, sans-serif;
            text-decoration: none;
            color: #ff0000;
            }
            .headerText {
            font-weight: bold;
            font-size: 1.8em;
            text-align: center;
            font-family: Arial, Helvetica, sans-serif;
            color: #636363;
            }
            .NoteText {
            font-weight: bold;
            font-size: 1.8em;
            font-family: Arial, Helvetica, sans-serif;
            color: #636363;
            }
           
        </style>
        </head>
    <apex:form >
        <div class="header" style="display:{!if(headVal != null,'','none')}">
            <div style="color:#cccccc; text-align:right;">{!headVal}</div>
        </div>
        <div class="footer">
            <div style="color:#cccccc; text-align:center;">Page <span class="pagenumber" /> of <span class="pagecount" /></div>
        </div>
        <div class="content" style="">
        <!--<br/>-->
        <apex:variable var="count" value="{!1}" />
        <apex:repeat id="sos" value="{!barcodeWrapperCol1}" var="barcodeWrap">
            <table width="100%" border="0" style="{!if(Frame,'border:1px solid #bcbcbc;','')}" cellspacing="0" cellpadding="0">
                <tr>
                    <td width="33%" align="left" valign="middle" style=""><!--padding:10px;-->
                        <div class="main" >
                            <!-- || count != NoofRows-1 -->
                            <table width="100%" style="padding-bottom:10px;" border="0" cellspacing="0" cellpadding="0">
                                <apex:repeat value="{!barcodeWrap.sObj}" var="res">
                                   
                                    <apex:repeat value="{!FieldListSelectedsOptions}" var="field">
                                        <tr>
                                            <td width="48%">
                                                <apex:outputText value="{!field.Label}"/>
                                            </td>
                                            <td width="4%">:</td>
                                            <td width="48%">
                                                <apex:outputField value="{!res[field.Value]}"/>
                                                <!--<apex:image url="https://erp-mark-7-dev-ed--c.eu5.content.force.com/servlet/servlet.FileDownload?file=00P2400000g3QTJ" width="50" height="50"> </apex:image>-->
                                            </td>
                                        </tr>
                                    </apex:repeat>
                                </apex:repeat>
                            </table>
                            <apex:outputText value="{!barcodeWrap.Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Top','','none')}" />
                            <apex:outputText value="{!barcodeWrap.Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Top','','none')}" />
                            <div style="margin-bottom:0px;">
                                    <apex:outputPanel rendered="{!(BrcdType== 'code128' || BrcdType== 'code39' || BrcdType== 'ean8' || BrcdType== 'ean13')}">                                
                                       <c:AQBarcodeZone id="brcd1281" BrcdType="{!BrcdType}" Value="{!barcodeWrap.Barcode}"/> 
                                    </apex:outputPanel> <br/>                                  
                            </div>
                            <!--<c:BarcodeTemplate id="brcdtemp" ObjNames="Product2" RecIds="{!barcodeWrap.Id}"></c:BarcodeTemplate>-->
                            <apex:outputText value="{!barcodeWrap.Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Bottom','','none')}" />
                            <apex:outputText value="{!barcodeWrap.Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Bottom','','none')}" />
                            <br/>
                        </div>
                    </td>
                    <td width="33%" align="left" valign="middle" style="display:{!if(count <= barcodeWrapperCol2.size,'','none')};" ><!--padding:10px;-->
                        <div class="main" >
                            <apex:outputPanel rendered="{!if(count <= barcodeWrapperCol2.size,true,false)}">
                                <table width="100%" style="padding-bottom:10px;" border="0" cellspacing="0" cellpadding="0">
                                    <apex:repeat value="{!barcodeWrapperCol2[count-1].sObj}" var="res">
                                        <apex:repeat value="{!FieldListSelectedsOptions}" var="field">
                                            <tr>
                                                <td width="48%">
                                                    <apex:outputText value="{!field.Label}"/>
                                                </td>
                                                <td width="4%">:</td>
                                                <td width="48%">
                                                    <apex:outputField value="{!res[field.Value]}"/>
                                                </td>
                                            </tr>
                                        </apex:repeat>
                                    </apex:repeat>
                                </table>
                                <apex:outputText value="{!barcodeWrapperCol2[count-1].Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Top','','none')}" />
                                <apex:outputText value="{!barcodeWrapperCol2[count-1].Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Top','','none')}" />
                                <div style="margin-bottom:0px;">
                                    <apex:outputPanel rendered="{!(BrcdType== 'code128' || BrcdType== 'code39' || BrcdType== 'ean8' || BrcdType== 'ean13')}">
                                       <c:AQBarcodeZone BrcdType="{!BrcdType}" Value="{!barcodeWrapperCol2[count-1].Barcode}"/> 
                                    </apex:outputPanel> <br/>                                                                      
                                </div>
                                <apex:outputText value="{!barcodeWrapperCol2[count-1].Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Bottom','','none')}" />
                                <apex:outputText value="{!barcodeWrapperCol2[count-1].Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Bottom','','none')}" />
                                <br/>
                            </apex:outputPanel>                            
                        </div>
                    </td>
                    <td width="33%" align="left" valign="middle" style="display:{!if(count <= barcodeWrapperCol3.size,'','none')};"><!--padding:10px;-->
                        <div class="main" style="page-break-before:avoid;">
                            <!-- style="page-break-before: {!if(count!=1 && MOD(count,(NoofRows))==0 ,'always','avoid')}" -->
                            <apex:outputPanel rendered="{!if(count <= barcodeWrapperCol3.size,true,false)}">
                                <table width="100%" style="padding-bottom:10px;" border="0" cellspacing="0" cellpadding="0">
                                    <apex:repeat value="{!barcodeWrapperCol3[count-1].sObj}" var="res">
                                        <apex:repeat value="{!FieldListSelectedsOptions}" var="field">
                                            <tr>
                                                <td width="48%">
                                                    <apex:outputText value="{!field.Label}"/>
                                                </td>
                                                <td width="4%">:</td>
                                                <td width="48%">
                                                    <apex:outputField value="{!res[field.Value]}"/>
                                                </td>
                                            </tr>
                                        </apex:repeat>
                                    </apex:repeat>
                                </table>
                                <apex:outputText value="{!barcodeWrapperCol3[count-1].Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Top','','none')}" />
                                <apex:outputText value="{!barcodeWrapperCol3[count-1].Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Top','','none')}" />
                                <div style="margin-bottom:0px;">
                                     <apex:outputPanel rendered="{!(BrcdType== 'code128' || BrcdType== 'code39' || BrcdType== 'ean8' || BrcdType== 'ean13')}">
                                       <c:AQBarcodeZone BrcdType="{!BrcdType}" Value="{!barcodeWrapperCol3[count-1].Barcode}"/> 
                                    </apex:outputPanel> <br/>                                   
                                </div>
                                <apex:outputText value="{!barcodeWrapperCol3[count-1].Label}" style="margin-left:15px;display:{!if(LabelDisplay && LabelLoc=='Bottom','','none')}" />
                                <apex:outputText value="{!barcodeWrapperCol3[count-1].Barcode}" style="margin-left:15px;padding-bottom:50px;height:100%;text-align:center;font-family:Times New Roman,Georgia,Serif;display:{!if(BarcodeDisplay && BarcodeLoc=='Bottom','','none')}" />
                                <br/>
                            </apex:outputPanel>                                   
                        </div>
                    </td>
                    <div class="main" style="page-break-before: {!if( count!=barcodeWrapperCol1.size && MOD(count,(NoofRows))==0 ,'always','avoid')};"/>
                </tr>
            </table>
            <apex:variable var="count" value="{!count+1}" />
        </apex:repeat>
        </div>
    </apex:form>
</apex:page>