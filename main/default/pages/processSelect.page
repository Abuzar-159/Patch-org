<apex:page showHeader="false" sidebar="false" controller="SchedulerCustomLookups" action="{!ProcessSelect}" tabStyle="Tax__c" docType="html-5.0">
      <apex:stylesheet value="{!URLFOR($Resource.ganttchart, 'assets/styles/salesforce-lightning-design-system.css')}" />
          <apex:stylesheet value="{!URLFOR($Resource.ganttchart, 'assets/styles/salesforce-lightning-design-system-scoped.css')}" />
    <apex:stylesheet value="{!URLFOR($Resource.SCM, 'SCM/Css/newpage.css')}"/>
    <html xmlns="https://www.w3.org/2000/svg" xmlns:xlink="https://www.w3.org/1999/xlink">
  <style>
  .slds .slds-page-header {
    padding: 1rem 0.1rem;
    border-bottom: 1px solid #d8dde6;
    background: #f4f6f9;
}
  @media (min-width: 48em){
.slds .slds-page-header {
    padding: 1.5rem 0.1rem 0.75rem;
}
}
  body{
  background:#F0F8FF;
      margin-top: 0px
  }
  input[type=text], textarea {
  -webkit-transition: all 0.30s ease-in-out;
  -moz-transition: all 0.30s ease-in-out;
  -ms-transition: all 0.30s ease-in-out;
  -o-transition: all 0.30s ease-in-out;
  outline: none;
  padding: 3px 0px 3px 3px;
  /*margin: 5px 1px 3px 0px;*/
  border: 1px solid #DDDDDD;
}
 
input[type=text]:focus, textarea:focus {
  box-shadow: 0 0 5px rgba(255, 0, 24, 1);
  padding: 3px 0px 3px 3px;
  /*margin: 5px 1px 3px 0px;*/
  border: 1px solid rgba(255, 0, 24, 1);
}
 input[type=button]{
  -webkit-transition: all 0.30s ease-in-out;
  -moz-transition: all 0.30s ease-in-out;
  -ms-transition: all 0.30s ease-in-out;
  -o-transition: all 0.30s ease-in-out;
  outline: none;
  
}
 
input[type=button]:focus,{
  -webkit-box-shadow: 0 0 0px rgba(255, 0, 24, 1);
  box-shadow: 0 0 0px rgba(255, 0, 24, 1);
  -o-box-shadow: 0 0 0px rgba(255, 0, 24, 1); 
  
}
  .fields{                                               

    width:180px;
    height:20px;
    border-radius:3px;
     -webkit-border-radius:3px;
    border:1px solid #bfc1c1;
    -webkit-transition: all 0.4s ease-in-out; /* fade in effect */
    -moz-transition: all 0.4s ease-in-out;
    -o-transition: all 0.4s ease-in-out;
     }
  </style>
 
  <apex:form id="form">
  <apex:outputPanel id="pan" layout="block" style="margin:0px;padding-top:0px;">
  <div class="slds"> 
      <div class="slds-page-header" role="banner">
                      <div class="slds-media">
                     

                          <div class="slds-media__figure">
                              <svg aria-hidden="true" class="slds-icon slds-icon--large slds-icon-standard-orders">
                                <use xlink:href="{!URLFOR($Resource.ganttchart,'/assets/icons/standard-sprite/svg/symbols.svg#record')}"></use>
                              </svg>
                           </div>
                        <div class="slds-media__body">
                          <p class="slds-page-header__title slds-truncate slds-align-middle" title="Search Processes" style="padding-top:15px;font-size:1.25em;">Search Processes</p>
                           
                        </div>
                      </div>
                </div>
  
      <form class="slds-form--inline ">
          
                <div class="slds-form-element slds-p-around--small ">
                    <div class="slds-form-element__control">
                          <label class="slds-form-element__label" for="txtSearch" style="color:#000;font-weight:bold;">Name</label>
                    </div>
                      
                           <apex:input type="text" id="fn" value="{!NameSearch}" styleClass="fields" style="height:32px; "/>
                      
                          <span class="slds-p-right--medium"> <apex:commandButton styleClass="slds-button slds-button--brand"  action="{!ProcessSelect}" rendered="{!$ObjectType.Process__c.Accessible}" value="Search" style=" line-height: 1.925rem;"/></span>
                    
                </div>
        </form>
    </div>  
          
     <div class="slds-container--fluid" style="padding:10px;height:400px;overflow:scroll;">     
       <apex:pageBlock id="searchResults"> 
          <apex:pageBlockTable width="55%" value="{!Processes}" var="rec" id="tblResults" >
            <apex:column width="33%" >
              <apex:facet name="header">Process</apex:facet>      
               <apex:outputLink value="#" onclick="fillIn('{!JSENCODE(rec.name)} ','{!JSENCODE(rec.id)}')" rendered="true">{!rec.Name}</apex:outputLink>     
            </apex:column>
            
             <apex:column width="33%" >
                <apex:facet name="header">Work Order</apex:facet>           
                 <apex:outputField value="{!rec.Type__c} "  /> 
             </apex:column> 
             <apex:column width="33%" >
                <apex:facet name="header">Record Type</apex:facet>           
                 <apex:outputField value="{!rec.RecordType.Name} "  /> 
             </apex:column> 
                               
              </apex:pageBlockTable>
            </apex:pageBlock>
      </div>   
  </apex:outputPanel>
  </apex:form>
  
  <script language="javascript">
  
   window.onload = new function() 
   { 
      window.focus(); 
      var ele=document.getElementById('{!JSENCODE($Component.form.block.section.searchString)}');
       if (ele)
      {
         ele.focus();
      }
   }
   
   function fillIn(name, id)
   {  var winMain=window.opener;
      if (null==winMain)
      {
         winMain=window.parent.opener;
      }
      var ele = winMain.document.getElementById("processId");
      var elen = winMain.document.getElementById("processName");
      //var elep = winMain.document.getElementById("productId");
      //var elenp = winMain.document.getElementById("productName");
      ele.value=id.substring(0, id.length);   
      elen.value=name.substring(0, name.length-1);
      //elep.value=pid.substring(0, pid.length);   
      //elenp.value=pname.substring(0, pname.length-1);   
      CloseWindow();
   }

   function CloseWindow()
   {
      var winMain=window.opener;
      if (null==winMain)
      {
         winMain=window.parent.opener;
      }
      winMain.closeLookupPopup();
    
   }
   
  
   
  
</script>
</htmL>
</apex:page>