<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>SendEmailtoNewcussalesOrder</fullName>
        <description>SendEmailtoNewcussalesOrder</description>
        <protected>false</protected>
        <recipients>
            <field>Customer_Email__c</field>
            <type>email</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Email_Template/EmailtoCustomerSalesOrder</template>
    </alerts>
    <fieldUpdates>
        <fullName>Assign_Sales_Order_Number</fullName>
        <field>Barcode__c</field>
        <formula>Code__c</formula>
        <name>Assign Sales Order Number</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Automate_Authorise_Update</fullName>
        <field>Authorised__c</field>
        <literalValue>1</literalValue>
        <name>Automate Authorise Update</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Is_Fulfilled</fullName>
        <field>Fulfilled__c</field>
        <literalValue>0</literalValue>
        <name>Is_Fulfilled</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Is_Fulfilled_Checked</fullName>
        <field>Fulfilled__c</field>
        <literalValue>1</literalValue>
        <name>Is Fulfilled Checked</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Name_Update</fullName>
        <field>Name</field>
        <formula>Code__c</formula>
        <name>Name Update</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Ready_To_Pick</fullName>
        <field>Ready_To_Pick_Pack__c</field>
        <literalValue>1</literalValue>
        <name>Ready To Pick</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>true</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Sales_Order_Status_Timestamp</fullName>
        <field>Status_TimeStamp__c</field>
        <formula>NOW()</formula>
        <name>Sales Order Status Timestamp</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Shipping_Tax_Amount</fullName>
        <field>Shipping_VAT__c</field>
        <formula>IF(Shipping_Tax__c != Null,  Shipping_Tax__r.Tax_Rate__c* (Total_Shipping_Amount__c- Shipping_Discount__c), 0)</formula>
        <name>Shipping Tax Amount</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Update_Is_BackOrder</fullName>
        <field>Is_Back_Order__c</field>
        <literalValue>1</literalValue>
        <name>Update Is BackOrder</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Update_Is_Back_Order</fullName>
        <field>Is_Back_Order__c</field>
        <literalValue>0</literalValue>
        <name>Update Is Back Order</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Update_Is_PreOrder</fullName>
        <field>Is_Pre_Order__c</field>
        <literalValue>1</literalValue>
        <name>Update Is PreOrder</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Authorised</fullName>
        <actions>
            <name>Ready_To_Pick</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Authorised__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Automate Authorise</fullName>
        <actions>
            <name>Automate_Authorise_Update</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.CreatedById</field>
            <operation>notEqual</operation>
            <value>Null</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Fulfilled Check</fullName>
        <actions>
            <name>Is_Fulfilled_Checked</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>Total_Number_of_Items__c == Number_of_Fulfilled_Items__c &amp;&amp; Total_Number_of_Items__c &gt; 0</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Fulfilled UnCheck</fullName>
        <actions>
            <name>Is_Fulfilled</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>Number_of_Fulfilled_Items__c &lt; Total_Number_of_Items__c &amp;&amp; Total_Number_of_Items__c &gt; 0</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>SO Clear Back Order</fullName>
        <actions>
            <name>Update_Is_Back_Order</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Back_Order_Items__c</field>
            <operation>equals</operation>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <field>Sales_Order__c.Is_Back_Order__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Sales Order Barcode Update</fullName>
        <actions>
            <name>Assign_Sales_Order_Number</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Name_Update</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Name</field>
            <operation>notEqual</operation>
            <value>null</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Sales Order Is back order</fullName>
        <actions>
            <name>Update_Is_BackOrder</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Back_Order_Items__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Sales Order Is pre order</fullName>
        <actions>
            <name>Update_Is_PreOrder</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Pre_Order_Items__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Sales Order Status Timestamp</fullName>
        <actions>
            <name>Sales_Order_Status_Timestamp</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>ISCHANGED( Status__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Sales_Order_Email_Notification</fullName>
        <actions>
            <name>SendEmailtoNewcussalesOrder</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Sales_Order__c.Customer_Email__c</field>
            <operation>notEqual</operation>
            <value>null</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
</Workflow>
