<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Send_Purchase_Order_Alert</fullName>
        <ccEmails>mohammed.fairoz@aqxolt.com</ccEmails>
        <description>Send Purchase Order Alert</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Email_Template/Purchase_Order_Attachment</template>
    </alerts>
    <fieldUpdates>
        <fullName>update_po_status_to_Reconciled</fullName>
        <field>Status__c</field>
        <literalValue>Reconciled</literalValue>
        <name>update po status to Reconciled</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Change Po status to Reconciled</fullName>
        <actions>
            <name>update_po_status_to_Reconciled</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Change po status to Reconciled</description>
        <formula>Reconciled_Quantity__c  =  Total_Quantity__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Send Purchase Order to Customer</fullName>
        <actions>
            <name>Send_Purchase_Order_Alert</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>PO__c.CreatedById</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>PO__c.Total_Quantity__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
