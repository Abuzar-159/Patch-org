<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>BOM_Cost</fullName>
        <field>BOM_Actual_Cost__c</field>
        <formula>BOM__r.Cost_Card__r.Cost__c *  Fulfilled_Amount__c</formula>
        <name>BOM Cost</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>BOM_Requirement_Cost</fullName>
        <field>BOM_Requirement_Cost__c</field>
