<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>Calculated_Emp_Pay</fullName>
        <field>Calculated_Gross_Pay__c</field>
        <formula>IF(DATEVALUE(Employees__r.CreatedDate) == Employees__r.First_Working_Day__c , 
((Employees__r.Employee_Profiling__r.Cost_to_Company__r.Amount__c/12) / 30) * (30 - (DAY(DATEVALUE(Employees__r.CreatedDate)) - 1)), (Employees__r.Employee_Profiling__r.Cost_to_Company__r.Amount__c/12) 
)</formula>
        <name>Calculated Emp Pay</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Other_Tax_Amount_Calculation</fullName>
        <field>Other_Tax_Amount__c</field>
        <formula>Employees__r.Employee_Profiling__r.Cost_to_Company__r.Fixed_Tax_Amount__c /12</formula>
        <name>Other Tax Amount Calculation</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Tax_Amount_Calculation</fullName>
        <field>Tax_Amount__c</field>
        <formula>Employees__r.Employee_Profiling__r.Cost_to_Company__r.Tax__c / 12</formula>
        <name>Tax Amount Calculation</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>update_Actual_Gross_Pay</fullName>
        <field>Actual_Gross_Pay__c</field>
        <formula>Employees__r.Employee_Profiling__r.Cost_to_Company__r.Amount__c / 12</formula>
        <name>update Actual Gross Pay</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Calculated Emp Pay</fullName>
        <actions>
            <name>Calculated_Emp_Pay</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Other_Tax_Amount_Calculation</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Tax_Amount_Calculation</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>update_Actual_Gross_Pay</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Employee_Pay__c.Name</field>
            <operation>notEqual</operation>
            <value>Null</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
</Workflow>
