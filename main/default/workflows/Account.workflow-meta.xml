<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>Credit_Balance</fullName>
        <field>Credit_Balance__c</field>
        <formula>Credit_Note_Credit_Balance__c + Prepaid_Credit_Balance__c</formula>
        <name>Credit Balance</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>true</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Debit_Balance</fullName>
        <field>Debit_Balance__c</field>
        <formula>Debit_Note_Balance__c +  Prepaid_Debit_Balance__c + Credit_Note_Debit_Balance__c</formula>
        <name>Debit Balance</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>true</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Credit%2FDebit Balance</fullName>
        <actions>
            <name>Credit_Balance</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Debit_Balance</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Account.CreatedById</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
