<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Reorder_Purchase_Rule</fullName>
        <description>Reorder Purchase Rule</description>
        <protected>false</protected>
        <recipients>
            <recipient>admin@erp7_1.1534_2.patch</recipient>
            <type>user</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Email_Template/Reordering_Rule</template>
    </alerts>
    <fieldUpdates>
        <fullName>Maximum_Stock</fullName>
        <field>Maximum_Stock__c</field>
        <formula>Reordering_Rule__r.Maximum_Quantity__c</formula>
        <name>Maximum Stock</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Minimum_Stock</fullName>
        <field>Minimum_Inventory__c</field>
        <formula>Reordering_Rule__r.Minimum_Quantity__c</formula>
        <name>Minimum Stock</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Reorder Purchase Rule</fullName>
        <actions>
            <name>Reorder_Purchase_Rule</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <description>To reorder stocks when the stock level reaches minimum value.</description>
        <formula>Number_of_Item_In_Stock__c  &lt;=  Reordering_Rule__r.Minimum_Quantity__c</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
