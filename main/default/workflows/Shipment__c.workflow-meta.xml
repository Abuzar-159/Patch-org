<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>Shipment_Name</fullName>
        <field>Name</field>
        <formula>LEFT( Logistic__r.Sales_Order__r.Employees__r.First_Name__c, 1) + Logistic__r.Sales_Order__r.Employees__r.Last_Name__c + &apos;-&apos; + Logistic__r.Sales_Order__r.Name + &apos;-Ship&apos;</formula>
        <name>Shipment Name</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Shipment_Status_Timestamp</fullName>
        <field>Status_TimeStamp__c</field>
        <formula>Now()</formula>
        <name>Shipment Status Timestamp</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Shipment Status Timestamp</fullName>
        <actions>
            <name>Shipment_Status_Timestamp</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>ISCHANGED( Shipment_Status__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
